<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LanCopy.App"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="ChromeBg" Color="#1E1E1E"/>
                    <SolidColorBrush x:Key="PanelBg" Color="#252526"/>
                    <SolidColorBrush x:Key="ToolbarBg" Color="#2D2D30"/>
                    <SolidColorBrush x:Key="InputBg" Color="#3E3E42"/>
                    <SolidColorBrush x:Key="DividerBg" Color="#3F3F46"/>
                    <SolidColorBrush x:Key="TextFg" Color="#E8E8E8"/>
                    <SolidColorBrush x:Key="MutedFg" Color="#D2D2D2"/>
                    <SolidColorBrush x:Key="SubtleFg" Color="#C2C2C2"/>
                    <SolidColorBrush x:Key="BorderFg" Color="#707070"/>
                    <SolidColorBrush x:Key="InputFg" Color="White"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="ChromeBg" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="PanelBg" Color="#F3F3F3"/>
                    <SolidColorBrush x:Key="ToolbarBg" Color="#ECECEC"/>
                    <SolidColorBrush x:Key="InputBg" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="DividerBg" Color="#D0D0D0"/>
                    <SolidColorBrush x:Key="TextFg" Color="#1E1E1E"/>
                    <SolidColorBrush x:Key="MutedFg" Color="#454545"/>
                    <SolidColorBrush x:Key="SubtleFg" Color="#5C5C5C"/>
                    <SolidColorBrush x:Key="BorderFg" Color="#888888"/>
                    <SolidColorBrush x:Key="InputFg" Color="#1E1E1E"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
