<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:LanCopy.Models"
        x:Class="LanCopy.MainWindow"
        Title="LanCopy — Transferencia en red local"
        Icon="/Assets/app.png"
        Width="1060" Height="680"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ══ Barra superior ══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="12,8">
            <StackPanel Spacing="6">
            <!-- Fila 1: conexión principal -->
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                <TextBlock Grid.Column="0" Text="🌐 Mi IP:" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Grid.Column="1" x:Name="txtMyIp" Text="…" Foreground="#FFD700" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,4,0"
                           ToolTip.Tip="Tu IP en la red local. Dala al otro PC para que se conecte."/>
                <Button    Grid.Column="2" x:Name="btnCopyIp" Content="📋" Click="CopyIp_Click"
                           Background="Transparent" Foreground="#CCCCCC" Padding="4,1" Margin="0,0,12,0"
                           ToolTip.Tip="Copiar mi IP al portapapeles"/>
                <TextBlock Grid.Column="3" Text="Puerto 8742" Foreground="#666666" FontSize="11" VerticalAlignment="Center" Margin="0,0,24,0"/>

                <TextBlock Grid.Column="4"/><!-- spacer -->

                <TextBlock Grid.Column="5" Text="Conectar a:" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox  Grid.Column="6" x:Name="cmbPeers" Width="150" Background="#3E3E42" Foreground="White"
                           PlaceholderText="🔍 LAN..." Padding="4,4" BorderBrush="#555"
                           SelectionChanged="CmbPeers_SelectionChanged"
                           ToolTip.Tip="PCs descubiertos automáticamente en la red. Selecciona uno para auto-completar IP/puerto."/>
                <TextBox   Grid.Column="7" x:Name="txtRemoteIp" Width="150" Background="#3E3E42" Foreground="White"
                           PlaceholderText="192.168.1.x" Padding="6,4" BorderBrush="#555" KeyDown="TxtRemoteIp_KeyDown"
                           ToolTip.Tip="IP del otro PC (ej: 192.168.1.25). Pulsa Enter o haz clic en Conectar."/>
                <TextBlock Grid.Column="8" Text=":" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="4,0"/>
                <TextBox   Grid.Column="9" x:Name="txtRemotePort" Text="8742" Width="58" Background="#3E3E42"
                           Foreground="White" Padding="6,4" BorderBrush="#555" KeyDown="TxtRemoteIp_KeyDown"
                           ToolTip.Tip="Puerto TCP (1-65535, defecto 8742). Ambos PCs deben usar el mismo."/>
                <Button    Grid.Column="10" x:Name="btnConnect" Content="Conectar" Click="Connect_Click"
                           Background="#007ACC" Foreground="White" Padding="12,5" Margin="8,0,0,0"
                           ToolTip.Tip="Conectar al PC remoto (también puedes pulsar Enter en el campo IP)."/>
                <TextBlock Grid.Column="11" x:Name="txtConnStatus" Text="⚫ Desconectado" Foreground="#FF6B6B"
                           VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12"/>
                <TextBlock Grid.Column="12" Text="PIN:" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="12,0,4,0"
                           ToolTip.Tip="PIN opcional. Si lo configuras, el otro PC debe usar el mismo PIN para conectar."/>
                <TextBox   Grid.Column="13" x:Name="txtPin" Width="70" Background="#3E3E42" Foreground="White"
                           PlaceholderText="(vacío)" Padding="6,4" BorderBrush="#555"
                           PasswordChar="●" TextChanged="TxtPin_TextChanged"
                           ToolTip.Tip="PIN de autenticación (dejar vacío para sin PIN)"/>
            </Grid>
            <!-- Fila 2: perfiles + opciones -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Perfil:" Foreground="#CCCCCC" VerticalAlignment="Center" FontSize="11"/>
                <ComboBox x:Name="cmbProfiles" Width="160" Background="#3E3E42" Foreground="White"
                          Padding="4,3" BorderBrush="#555" FontSize="11"
                          SelectionChanged="CmbProfiles_SelectionChanged"
                          ToolTip.Tip="Perfiles de conexión guardados"/>
                <Button Content="💾 Guardar" Click="SaveProfile_Click"
                        Background="#3E3E42" Foreground="White" Padding="6,3" FontSize="11"
                        ToolTip.Tip="Guardar IP/puerto como perfil nombrado"/>
                <Button Content="❌" Click="DeleteProfile_Click"
                        Background="#3E3E42" Foreground="#FF6B6B" Padding="6,3" FontSize="11"
                        ToolTip.Tip="Eliminar perfil seleccionado"/>
                <Border Width="1" Background="#3F3F46" Margin="4,0"/>
                <CheckBox x:Name="chkTls" Content="🔒 TLS" Foreground="#CCCCCC" FontSize="11"
                          IsCheckedChanged="ChkTls_Changed"
                          ToolTip.Tip="Cifrar la conexión con TLS (ambos extremos deben tenerlo activado)"/>
                <CheckBox x:Name="chkCompress" Content="🗃 Comprimir" Foreground="#CCCCCC" FontSize="11"
                          IsCheckedChanged="ChkCompress_Changed"
                          ToolTip.Tip="Comprimir archivos en tránsito (Deflate, máx 200 MB)"/>
                <Border Width="1" Background="#3F3F46" Margin="4,0"/>
                <TextBlock x:Name="txtSparkline" Foreground="#00FF88" FontFamily="Consolas,Courier New,monospace"
                           FontSize="13" VerticalAlignment="Center" ToolTip.Tip="Velocidad de transferencia (últimos 10s)"/>
                <TextBlock x:Name="txtWatchStatus" Foreground="Orange" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ Paneles de archivos ═════════════════════════════════════════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*">

            <!-- ── Panel izquierdo: Local ──────────────────────────────────── -->
            <Grid Grid.Column="0" RowDefinitions="Auto,Auto,Auto,Auto,*" Background="#1E1E1E">
                <Border Grid.Row="0" Background="#2D2D30" Padding="10,7">
                    <TextBlock Text="💻 Este PC" Foreground="White" FontWeight="Bold" FontSize="13"/>
                </Border>
                <Border Grid.Row="1" Background="#252526" Padding="6,4" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="28,*,28">
                        <Button Grid.Column="0" Content="↑" Click="LocalGoUp"
                                Background="#3E3E42" Foreground="White" Padding="0" Width="24" Height="24"
                                ToolTip.Tip="Subir a la carpeta superior"/>
                        <TextBlock Grid.Column="1" x:Name="txtLocalPath"
                                   Text="—" Foreground="#CCCCCC" FontSize="11"
                                   VerticalAlignment="Center" Margin="6,0" TextTrimming="CharacterEllipsis"
                                   ToolTip.Tip="{Binding #txtLocalPath.Text}"/>
                        <Button Grid.Column="2" Content="🏠" Click="LocalGoHome"
                                Background="#3E3E42" Foreground="White" Padding="0" Width="24" Height="24"
                                ToolTip.Tip="Ir a carpeta personal"/>
                    </Grid>
                </Border>
                <!-- Filtro búsqueda local -->
                <Border Grid.Row="2" Background="#252526" Padding="6,3" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                    <TextBox x:Name="txtLocalFilter" PlaceholderText="🔍 Filtrar archivos..." 
                             Background="#3E3E42" Foreground="White" Padding="5,3" BorderBrush="#555"
                             TextChanged="TxtLocalFilter_TextChanged"/>
                </Border>
                <!-- Cabeceras de ordenación local (Feature 6) -->
                <Border Grid.Row="3" Background="#252526" Padding="4,2" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button x:Name="btnLocalSortName" Content="Nombre ⇅" Click="LocalSortName_Click"
                                Background="Transparent" Foreground="#888888" FontSize="10" Padding="2,1"
                                ToolTip.Tip="Ordenar por nombre"/>
                        <Button x:Name="btnLocalSortSize" Content="Tamaño ⇅" Click="LocalSortSize_Click"
                                Background="Transparent" Foreground="#888888" FontSize="10" Padding="2,1"
                                ToolTip.Tip="Ordenar por tamaño"/>
                        <Button x:Name="btnLocalSortDate" Content="Fecha ⇅" Click="LocalSortDate_Click"
                                Background="Transparent" Foreground="#888888" FontSize="10" Padding="2,1"
                                ToolTip.Tip="Ordenar por fecha"/>
                    </StackPanel>
                </Border>
                <!-- DragDrop.AllowDrop para recibir archivos arrastrados desde el panel remoto (#14) -->
                <ListBox Grid.Row="4" x:Name="localList"
                         SelectionMode="Multiple"
                         Background="Transparent" BorderThickness="0"
                         DoubleTapped="LocalList_DoubleTapped"
                         SelectionChanged="LocalList_SelectionChanged"
                         DragDrop.AllowDrop="True">
                    <ListBox.ItemContainerTheme>
                        <ControlTheme TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Padding" Value="6,3"/>
                        </ControlTheme>
                    </ListBox.ItemContainerTheme>
                    <ListBox.ContextMenu>
                        <ContextMenu Opening="LocalCtx_Opening">
                            <MenuItem x:Name="ctxLocalSend"   Header="→ Enviar al remoto"    Click="LocalCtx_Send"/>
                            <Separator/>
                            <MenuItem x:Name="ctxLocalRename" Header="✏️ Renombrar"           Click="LocalCtx_Rename"/>
                            <MenuItem x:Name="ctxLocalDelete" Header="🗑️ Borrar"              Click="LocalCtx_Delete"/>
                            <Separator/>
                            <MenuItem x:Name="ctxLocalVerify" Header="✓ Verificar en remoto" Click="LocalCtx_Verify"/>
                            <Separator/>
                            <MenuItem                          Header="📋 Copiar ruta"         Click="LocalCtx_CopyPath"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:FileEntry">
                            <Grid ColumnDefinitions="22,*,75">
                                <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="#CCCCCC"
                                           FontSize="12" VerticalAlignment="Center" Margin="4,0"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2" Text="{Binding SizeText}" Foreground="#888888"
                                           FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- ── Botones de transferencia ─────────────────────────────────── -->
            <Border Grid.Column="1" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1,0" Padding="10,0">
                <StackPanel VerticalAlignment="Center" Spacing="10">
                    <Button x:Name="btnSend" Content="→ Enviar" Click="CopyToRemote"
                            Background="#28A745" Foreground="White" Width="90" Padding="8,7"
                            HorizontalContentAlignment="Center"
                            ToolTip.Tip="Enviar archivos/carpetas al remoto. Ctrl+clic múltiples, Ctrl+A todo. También puedes arrastrar."/>
                    <Button x:Name="btnReceive" Content="← Recibir" Click="CopyToLocal"
                            Background="#007ACC" Foreground="White" Width="90" Padding="8,7"
                            HorizontalContentAlignment="Center"
                            ToolTip.Tip="Recibir archivos/carpetas del remoto. Ctrl+clic múltiples, Ctrl+A todo. También puedes arrastrar."/>
                    <!-- Botón cancelar (#11) -->
                    <Button x:Name="btnCancel" Content="⛔ Cancelar" Click="CancelTransfer_Click"
                            Background="#C0392B" Foreground="White" Width="90" Padding="8,5"
                            HorizontalContentAlignment="Center" FontSize="11" IsEnabled="False"
                            ToolTip.Tip="Cancelar la transferencia en curso"/>
                    <!-- Pausa/reanudación (#F1) -->
                    <Button x:Name="btnPause" Content="⏸ Pausar" Click="PauseTransfer_Click"
                            Background="#795548" Foreground="White" Width="90" Padding="8,5"
                            HorizontalContentAlignment="Center" FontSize="11" IsEnabled="False"
                            ToolTip.Tip="Pausar la transferencia"/>
                    <Button x:Name="btnResume" Content="▶ Reanudar" Click="ResumeTransfer_Click"
                            Background="#4CAF50" Foreground="White" Width="90" Padding="8,5"
                            HorizontalContentAlignment="Center" FontSize="11" IsEnabled="False"
                            ToolTip.Tip="Reanudar la transferencia pausada"/>
                    <Separator Background="#3F3F46" Height="1" Margin="0,4"/>
                    <Button Content="↻ Local" Click="RefreshLocal_Click"
                            Background="#555555" Foreground="White" Width="90" Padding="8,5"
                            HorizontalContentAlignment="Center" FontSize="11"
                            ToolTip.Tip="Actualizar lista de archivos local"/>
                    <Button Content="↻ Remoto" Click="RefreshRemote_Click"
                            Background="#555555" Foreground="White" Width="90" Padding="8,5"
                            HorizontalContentAlignment="Center" FontSize="11"
                            ToolTip.Tip="Actualizar lista de archivos remota"/>
                    <Separator Background="#3F3F46" Height="1" Margin="0,4"/>
                    <!-- Feature 1: Sync de carpetas -->
                    <Button x:Name="btnSyncToRemote" Content="⇒ Sync" Click="SyncToRemote_Click"
                            Background="#5C4A8A" Foreground="White" Width="90" Padding="8,5"
                            HorizontalContentAlignment="Center" FontSize="11"
                            ToolTip.Tip="Sincronizar carpeta local → remoto (solo archivos distintos)"/>
                    <Button x:Name="btnSyncToLocal" Content="⇐ Sync" Click="SyncToLocal_Click"
                            Background="#5C4A8A" Foreground="White" Width="90" Padding="8,5"
                            HorizontalContentAlignment="Center" FontSize="11"
                            ToolTip.Tip="Sincronizar carpeta remota → local (solo archivos distintos)"/>
                    <!-- Feature 8: Watch folder -->
                    <Button x:Name="btnWatch" Content="👁 Vigilar" Click="WatchFolder_Click"
                            Background="#795548" Foreground="White" Width="90" Padding="8,5"
                            HorizontalContentAlignment="Center" FontSize="11"
                            ToolTip.Tip="Vigilar carpeta local y auto-enviar cambios al remoto"/>
                </StackPanel>
            </Border>

            <!-- ── Panel derecho: Remoto ─────────────────────────────────────── -->
            <Grid Grid.Column="2" RowDefinitions="Auto,Auto,Auto,*" Background="#1E1E1E">
                <Border Grid.Row="0" Background="#2D2D30" Padding="10,7">
                    <TextBlock Text="🖥️ PC Remoto" Foreground="White" FontWeight="Bold" FontSize="13"/>
                </Border>
                <Border Grid.Row="1" Background="#252526" Padding="6,4" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="28,*,28">
                        <Button Grid.Column="0" Content="↑" Click="RemoteGoUp"
                                Background="#3E3E42" Foreground="White" Padding="0" Width="24" Height="24"
                                ToolTip.Tip="Subir a la carpeta superior (PC remoto)"/>
                        <TextBlock Grid.Column="1" x:Name="txtRemotePath"
                                   Text="—" Foreground="#CCCCCC" FontSize="11"
                                   VerticalAlignment="Center" Margin="6,0" TextTrimming="CharacterEllipsis"
                                   ToolTip.Tip="{Binding #txtRemotePath.Text}"/>
                        <Button Grid.Column="2" Content="🏠" Click="RemoteGoHome"
                                Background="#3E3E42" Foreground="White" Padding="0" Width="24" Height="24"
                                ToolTip.Tip="Volver a la lista de unidades del PC remoto"/>
                    </Grid>
                </Border>
                <!-- Cabeceras de ordenación remota (Feature 6) -->
                <Border Grid.Row="2" Background="#252526" Padding="4,2" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button x:Name="btnRemoteSortName" Content="Nombre ⇅" Click="RemoteSortName_Click"
                                Background="Transparent" Foreground="#888888" FontSize="10" Padding="2,1"
                                ToolTip.Tip="Ordenar por nombre"/>
                        <Button x:Name="btnRemoteSortSize" Content="Tamaño ⇅" Click="RemoteSortSize_Click"
                                Background="Transparent" Foreground="#888888" FontSize="10" Padding="2,1"
                                ToolTip.Tip="Ordenar por tamaño"/>
                        <Button x:Name="btnRemoteSortDate" Content="Fecha ⇅" Click="RemoteSortDate_Click"
                                Background="Transparent" Foreground="#888888" FontSize="10" Padding="2,1"
                                ToolTip.Tip="Ordenar por fecha"/>
                    </StackPanel>
                </Border>
                <ListBox Grid.Row="3" x:Name="remoteList"
                         SelectionMode="Multiple"
                         Background="Transparent" BorderThickness="0"
                         DoubleTapped="RemoteList_DoubleTapped"
                         SelectionChanged="RemoteList_SelectionChanged"
                         DragDrop.AllowDrop="True">
                    <ListBox.ItemContainerTheme>
                        <ControlTheme TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Padding" Value="6,3"/>
                        </ControlTheme>
                    </ListBox.ItemContainerTheme>
                    <ListBox.ContextMenu>
                        <ContextMenu Opening="RemoteCtx_Opening">
                            <MenuItem x:Name="ctxRemoteReceive" Header="← Recibir al local"    Click="RemoteCtx_Receive"/>
                            <Separator/>
                            <MenuItem x:Name="ctxRemoteRename"  Header="✏️ Renombrar"           Click="RemoteCtx_Rename"/>
                            <MenuItem x:Name="ctxRemoteDelete"  Header="🗑️ Borrar"              Click="RemoteCtx_Delete"/>
                            <Separator/>
                            <MenuItem x:Name="ctxRemoteVerify"  Header="✓ Verificar en local"  Click="RemoteCtx_Verify"/>
                            <Separator/>
                            <MenuItem                            Header="📋 Copiar ruta"         Click="RemoteCtx_CopyPath"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:FileEntry">
                            <Grid ColumnDefinitions="22,*,75">
                                <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="#CCCCCC"
                                           FontSize="12" VerticalAlignment="Center" Margin="4,0"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2" Text="{Binding SizeText}" Foreground="#888888"
                                           FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <!-- ══ Barra de estado / progreso ══════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#2D2D30" Padding="12,6" BorderBrush="#3F3F46" BorderThickness="0,1,0,0">
            <Grid RowDefinitions="Auto,Auto,Auto">
                <!-- Progreso + velocidad (#12) -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                    <ProgressBar Grid.Column="0" x:Name="transferProgress"
                                 Minimum="0" Maximum="100" Value="0"
                                 Height="4" Foreground="#28A745"/>
                    <TextBlock Grid.Column="1" x:Name="txtSpeed"
                               Text="" Foreground="#888888" FontSize="10"
                               VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="75"/>
                </Grid>
                <!-- Texto de estado -->
                <TextBlock Grid.Row="1" x:Name="txtStatus"
                           Text="Listo. Comparte tu IP con el otro PC para conectar."
                           Foreground="#CCCCCC" FontSize="11"/>
                <!-- Historial de transferencias (#17) -->
                <Expander x:Name="historyExpander" Grid.Row="2" Header="📋 Historial" Foreground="#888888" FontSize="11"
                          IsExpanded="False" Margin="0,4,0,0">
                    <ListBox x:Name="historyList" MaxHeight="110"
                             Background="Transparent" BorderThickness="0"
                             IsHitTestVisible="False">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:TransferRecord">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Time}"  Foreground="#555555" FontSize="10" FontFamily="Consolas"/>
                                    <TextBlock Text="{Binding Text}"  Foreground="{Binding Color}" FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Expander>
            </Grid>
        </Border>
    </Grid>
</Window>