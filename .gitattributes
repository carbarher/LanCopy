# Auto detect text files and normalize line endings
* text=auto

# Source code
*.cs text diff=csharp
*.axaml text
*.csproj text
*.slnx text
*.json text
*.md text
*.yml text
*.yaml text

# Scripts
*.sh text eol=lf
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary
*.png binary
*.ico binary
*.exe binary
*.dll binary
*.pdb binary
*.zip binary
*.gz binary
*.deb binary
*.dmg binary
