using System;
using System.Windows.Forms;

namespace SlskDown
{
    static class ProgramTest
    {
        [STAThread]
        static void Main()
        {
            Console.WriteLine("ProgramTest - Main iniciado");
            
            try
            {
                System.IO.File.WriteAllText(@"c:\p2p\programtest_debug.txt", 
                    $"[{DateTime.Now:HH:mm:ss.fff}] ProgramTest INICIADO\n");
            }
            catch { }
            
            Application.EnableVisualStyles();
            Application.SetCompatibleTextRenderingDefault(false);
            
            try
            {
                var form = new MainFormTest();
                Console.WriteLine("MainFormTest creado OK");
                
                System.IO.File.AppendAllText(@"c:\p2p\programtest_debug.txt", 
                    $"[{DateTime.Now:HH:mm:ss.fff}] MainFormTest creado OK\n");
                
                Application.Run(form);
            }
            catch (Exception ex)
            {
                var msg = $"ERROR: {ex.Message}\n{ex.StackTrace}";
                Console.WriteLine(msg);
                
                System.IO.File.WriteAllText(@"c:\p2p\programtest_error.txt", msg);
                MessageBox.Show(msg, "Error");
            }
        }
    }
}
