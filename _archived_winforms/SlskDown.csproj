<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>p2p</AssemblyName>
    <AssemblyVersion>4.2.0.0</AssemblyVersion>
    <FileVersion>4.2.0.0</FileVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <EnableNETAnalyzers>false</EnableNETAnalyzers>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- Usar Program como punto de entrada -->
    <StartupObject>SlskDown.Program</StartupObject>
    <!-- Deshabilitar generación automática de AssemblyInfo -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <!-- SOLUCIÓN NUCLEAR: Deshabilitar inclusión automática de archivos -->
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <EnableDefaultItems>false</EnableDefaultItems>
    <!-- Suprimir advertencias comunes (sin nulabilidad ni campos no usados) -->
    <NoWarn>CS0067;CS0168;CS0169;CS0219;CS0414;CS0649;CS1998;CS4014;CS8600;CS8601;CS8602;CS8603;CS8604;CS8618;CS8619;CS8620;CS8622;CS8625;CS8629;CS8632;CS8714;CS8767;CA1416;CA1805;CA1852;CA1031;CA1062;CA1303;CA1304;CA1305;CA1307;CA1309;CA1310;CA1311;CA1508;CA1707;CA1711;CA1716;CA1720;CA1724;CA1806;CA1822;CA1829;CA1835;CA1847;CA1848;CA1854;CA1859;CA1860;CA1861;CA1862;CA1865;CA1866;CA1868;CA1869;CA2007;CA2201;CA2211;CA2219;CA2249;CA5351;CA5394;SYSLIB1045;SYSLIB1054;NU1701;NETSDK1206;WFAC010</NoWarn>
    
    <!-- MEJORA #45: Optimizaciones avanzadas del compilador .NET 9 -->
    <TieredCompilation>true</TieredCompilation>
    <TieredCompilationQuickJit>false</TieredCompilationQuickJit>
    <PublishReadyToRun>true</PublishReadyToRun>
    <InvariantGlobalization>false</InvariantGlobalization>
    <ServerGarbageCollection>true</ServerGarbageCollection>
    <ConcurrentGarbageCollection>true</ConcurrentGarbageCollection>
    <RetainVMGarbageCollection>true</RetainVMGarbageCollection>
  </PropertyGroup>

