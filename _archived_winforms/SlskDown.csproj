  <!-- Copiar DLL de Rust al directorio de salida (Build y Publish) -->
  <Target Name="CopyRustDLL" AfterTargets="Build;Publish">
    <PropertyGroup>
      <RustCoreReleaseDll>rust_core\target\release\slskdown_core.dll</RustCoreReleaseDll>
      <RustCoreDebugDll>rust_core\target\debug\slskdown_core.dll</RustCoreDebugDll>
      <RustCopyDestinationDir Condition="'$(PublishDir)' != ''">$(PublishDir)</RustCopyDestinationDir>
      <RustCopyDestinationDir Condition="'$(PublishDir)' == ''">$(TargetDir)</RustCopyDestinationDir>
    </PropertyGroup>
    <!-- DLL del nuevo módulo rust_core -->
    <Copy SourceFiles="$(RustCoreReleaseDll)" DestinationFolder="$(TargetDir)" SkipUnchangedFiles="true" Condition="Exists('$(RustCoreReleaseDll)')" />

    <Copy SourceFiles="$(RustCoreDebugDll)" DestinationFolder="$(TargetDir)" SkipUnchangedFiles="true" Condition="!Exists('$(RustCoreReleaseDll)') AND Exists('$(RustCoreDebugDll)')" />

    <Copy SourceFiles="$(RustCoreReleaseDll)" DestinationFolder="$(PublishDir)" SkipUnchangedFiles="true" Condition="'$(PublishDir)' != '' AND Exists('$(RustCoreReleaseDll)')" />

    <Copy SourceFiles="$(RustCoreDebugDll)" DestinationFolder="$(PublishDir)" SkipUnchangedFiles="true" Condition="'$(PublishDir)' != '' AND !Exists('$(RustCoreReleaseDll)') AND Exists('$(RustCoreDebugDll)')" />
    <!-- DLL del módulo antiguo (si existe) -->
    <Copy SourceFiles="slsk_native\target\release\slsk_native.dll" DestinationFolder="$(TargetDir)" SkipUnchangedFiles="true" Condition="Exists('slsk_native\target\release\slsk_native.dll')" />

    <Copy SourceFiles="slsk_native\target\release\slsk_native.dll" DestinationFolder="$(PublishDir)" SkipUnchangedFiles="true" Condition="'$(PublishDir)' != '' AND Exists('slsk_native\target\release\slsk_native.dll')" />

    <Message Text="✅ DLL de Rust copiada a $(TargetDir)" Condition="Exists('$(RustCoreReleaseDll)') OR Exists('$(RustCoreDebugDll)')" Importance="high" />
    <Warning Text="⚠️ DLL Rust no encontrada. Compila Rust: cd rust_core &amp;&amp; cargo build --release" Condition="!Exists('$(RustCoreReleaseDll)') AND !Exists('$(RustCoreDebugDll)')" />
  </Target>

