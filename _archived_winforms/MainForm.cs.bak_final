        }
        
        // ===== DETECCIÃ“N DE SERIES =====
        private (string seriesName, int? volume) DetectSeries(string filename)
        {
            var patterns = new[]
            {
                @"(.+?)\s+(?:Vol\.?|Volume|Tomo|Libro)\s*(\d+)",
                @"(.+?)\s+(\d+)\s+(?:de|of)\s+\d+",
                @"(.+?)\s+\[(\d+)\]",
                @"(.+?)\s+-\s+(\d+)",
                @"(.+?)\s+#(\d+)"
            };
            
            foreach (var pattern in patterns)
            {
                var match = System.Text.RegularExpressions.Regex.Match(filename, pattern, System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                if (match.Success)
                {
                    string seriesName = match.Groups[1].Value.Trim();
                    if (int.TryParse(match.Groups[2].Value, out int volume))
                    {
                        return (seriesName, volume);
                    }
                }
            }
            
            return (null, null);
        }
        
        private Dictionary<string, List<ListViewItem>> GroupBySeries(List<ListViewItem> items)
        {
            var series = new Dictionary<string, List<ListViewItem>>();
            
            foreach (var item in items)
            {
                string filename = item.SubItems[1].Text;
                var (seriesName, volume) = DetectSeries(filename);
                
                if (seriesName != null)
                {
                    if (!series.ContainsKey(seriesName))
                        series[seriesName] = new List<ListViewItem>();
                    
                    series[seriesName].Add(item);
                }
            }
            
            return series;
        }
        
        private void ShowSeriesDetection()
        {
            var allItems = lvResults.Items.Cast<ListViewItem>().ToList();
            var seriesGroups = GroupBySeries(allItems);
            
            if (seriesGroups.Count == 0)
            {
                MessageBox.Show("No se detectaron series en los resultados actuales.", "DetecciÃ³n de Series", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }
            
            var form = new Form
            {
                Text = "ðŸ“š Series Detectadas",
                Size = new Size(800, 600),
                BackColor = Color.FromArgb(25, 25, 25),
                ForeColor = Color.White,
                StartPosition = FormStartPosition.CenterParent
            };
            
            var listView = new ListView
            {
                Dock = DockStyle.Fill,
                View = View.Details,
                FullRowSelect = true,
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.White
            };
            
            listView.Columns.Add("Serie", 400);
            listView.Columns.Add("VolÃºmenes", 100);
            listView.Columns.Add("Archivos", 100);
            listView.Columns.Add("TamaÃ±o Total", 150);
            
            foreach (var kvp in seriesGroups.OrderByDescending(x => x.Value.Count))
            {
                var volumes = kvp.Value.Select(item => DetectSeries(item.SubItems[1].Text).volume)
                    .Where(v => v.HasValue)
                    .Select(v => v.Value)
                    .OrderBy(v => v)
                    .ToList();
                
                long totalSize = 0;
                foreach (var item in kvp.Value)
                {
                    dynamic tag = item.Tag;
                    totalSize += tag?.Size ?? 0;
                }
                
                string volumeRange = volumes.Count > 0 ? $"{volumes.Min()}-{volumes.Max()}" : "?";
                
                var listItem = new ListViewItem(new[]
                {
                    kvp.Key,
                    volumeRange,
                    kvp.Value.Count.ToString(),
                    FormatSize(totalSize)
                });
                listItem.Tag = kvp.Value;
                listItem.BackColor = Color.FromArgb(30, 30, 30);
                listItem.ForeColor = Color.White;
                listView.Items.Add(listItem);
            }
            
            listView.DoubleClick += (s, e) =>
            {
                if (listView.SelectedItems.Count > 0)
                {
                    var items = (List<ListViewItem>)listView.SelectedItems[0].Tag;
                    lvResults.SelectedItems.Clear();
                    foreach (var item in items)
                    {
                        item.Selected = true;
                        item.EnsureVisible();
                    }
                    form.Close();
                }
            };
            
            var btnPanel = new Panel { Dock = DockStyle.Bottom, Height = 50, BackColor = Color.FromArgb(25, 25, 25) };
            var btnDownloadSeries = new Button 
            { 
                Text = "â¬‡ï¸ Descargar Serie Completa", 
                Location = new Point(10, 10), 
                Size = new Size(200, 30),
                BackColor = Color.FromArgb(0, 150, 0),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat
            };
            btnDownloadSeries.Click += async (s, e) =>
            {
                if (listView.SelectedItems.Count > 0)
                {
                    var items = (List<ListViewItem>)listView.SelectedItems[0].Tag;
                    lvResults.SelectedItems.Clear();
                    foreach (var item in items)
                        item.Selected = true;
                    
                    form.Close();
                    await DownloadMultipleAsync();
                }
            };
            btnPanel.Controls.Add(btnDownloadSeries);
            
            form.Controls.Add(btnPanel);
            form.Controls.Add(listView);
            form.ShowDialog();
        }
        
        private async Task AnalyzeUserCollection()
        {
            if (lvResults.SelectedItems.Count == 0)
            {
                MessageBox.Show("Selecciona un archivo para analizar la colecciÃ³n de su usuario.", "AnÃ¡lisis de ColecciÃ³n", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }
            
            dynamic tag = lvResults.SelectedItems[0].Tag;
            string username = tag?.Username;
            
            if (string.IsNullOrEmpty(username))
                return;
            
            var result = MessageBox.Show($"Â¿Buscar todos los archivos del usuario '{username}'?\n\nEsto puede tardar varios segundos.", 
                "AnÃ¡lisis de ColecciÃ³n", MessageBoxButtons.YesNo, MessageBoxIcon.Question);
            
            if (result != DialogResult.Yes)
                return;
            
            try
            {
                if (lblStatus != null) lblStatus.Text = $"Analizando colecciÃ³n de {username}...";
                Log($"Obteniendo informaciÃ³n de usuario: {username}");
                
                var userInfo = await client.GetUserInfoAsync(username);
                
                var stats = new StringBuilder();
                stats.AppendLine($"ðŸ‘¤ Usuario: {username}");
                stats.AppendLine($"ðŸ“ DescripciÃ³n: {userInfo.Description ?? "Sin descripciÃ³n"}");
                stats.AppendLine($"ðŸ–¼ï¸ Imagen: {(userInfo.HasPicture ? "SÃ­" : "No")}");
                stats.AppendLine($"ðŸ“ Carpetas en cola: {userInfo.QueueLength}");
                stats.AppendLine();
                stats.AppendLine("Â¿Deseas buscar todos sus archivos?");
                
                var searchResult = MessageBox.Show(stats.ToString(), $"ColecciÃ³n de {username}", 
                    MessageBoxButtons.YesNo, MessageBoxIcon.Information);
                
                if (searchResult == DialogResult.Yes)
                {
                    // Buscar por usuario especÃ­fico
                    cmbSearch.Text = username;
                    await SearchAsync();
                }
                
                if (lblStatus != null) lblStatus.Text = "AnÃ¡lisis completado";
            }
            catch (Exception ex)
            {
                Log($"Error al analizar colecciÃ³n: {ex.Message}");
                MessageBox.Show($"Error al obtener informaciÃ³n del usuario:\n{ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
        private void SortResults(int column)
        {
            if (sortColumn == column)
                sortAscending = !sortAscending;
            else
            {
                sortColumn = column;
                sortAscending = true;
            }
            
            var items = lvResults.Items.Cast<ListViewItem>().ToList();
            
            items.Sort((a, b) =>
            {
                var result = 0;
                
                if (column == 2) // TamaÃ±o - ordenar por bytes reales
                {
                    // Obtener el tamaÃ±o real del Tag
                    dynamic tagA = a.Tag;
                    dynamic tagB = b.Tag;
                    long sizeA = tagA?.Size ?? 0;
                    long sizeB = tagB?.Size ?? 0;
                    result = sizeA.CompareTo(sizeB);
                }
                else
                {
                    // OrdenaciÃ³n alfabÃ©tica para otras columnas
                    result = string.Compare(a.SubItems[column].Text, b.SubItems[column].Text, StringComparison.OrdinalIgnoreCase);
                }
                
                return sortAscending ? result : -result;
            });
            
            lvResults.BeginUpdate();
            lvResults.Items.Clear();
            lvResults.Items.AddRange(items.ToArray());
            lvResults.EndUpdate();
        }
        
        
        private void OpenDownloadedFile()
        {
            if (lvDownloads.SelectedItems.Count == 0)
                return;
            
            var fileName = lvDownloads.SelectedItems[0].Text;
            var filePath = Path.Combine(downloadDir, fileName);
            
            if (System.IO.File.Exists(filePath))
            {
                try
                {
                    Process.Start(new ProcessStartInfo(filePath) { UseShellExecute = true });
                }
                catch (Exception ex)
                {
                    MessageBox.Show($"Error al abrir archivo: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            }
            else
            {
                MessageBox.Show("El archivo no existe", "Error", MessageBoxButtons.OK, MessageBoxIcon.Warning);
            }
        }
        
