        private void LoadLastAuthorsFile()
        {
            try
            {
                var configFile = Path.Combine(dataDir, "auto_config.json");
                if (System.IO.File.Exists(configFile))
                {
                    var json = System.IO.File.ReadAllText(configFile);
                    var config = JsonSerializer.Deserialize<Dictionary<string, string>>(json);
                    if (config != null && config.ContainsKey("lastAuthorsFile"))
                    {
                        lastAuthorsFilePath = config["lastAuthorsFile"];
                        if (System.IO.File.Exists(lastAuthorsFilePath))
                        {
                            LoadAuthorsFromFile(lastAuthorsFilePath);
                            return;
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                AutoLog($"âš ï¸ Error al cargar configuraciÃ³n: {ex.Message}");
            }
            
            AutoLog("ðŸ“š Selecciona un archivo TXT con la lista de autores");
        }
        
        private void SelectAndLoadAuthorsFile()
        {
            var openDialog = new OpenFileDialog
            {
                Filter = "Archivos de texto (*.txt)|*.txt|Todos los archivos (*.*)|*.*",
                Title = "Seleccionar archivo de autores",
                InitialDirectory = !string.IsNullOrEmpty(lastAuthorsFilePath) ? Path.GetDirectoryName(lastAuthorsFilePath) : ""
            };
            
            if (openDialog.ShowDialog() == DialogResult.OK)
            {
                lastAuthorsFilePath = openDialog.FileName;
                SaveLastAuthorsFile();
                LoadAuthorsFromFile(openDialog.FileName);
            }
        }
        
        private void SaveLastAuthorsFile()
        {
            try
            {
                var config = new Dictionary<string, string>
                {
                    ["lastAuthorsFile"] = lastAuthorsFilePath
                };
                var json = JsonSerializer.Serialize(config);
                var configFile = Path.Combine(dataDir, "auto_config.json");
                System.IO.File.WriteAllText(configFile, json);
            }
            catch (Exception ex)
            {
                AutoLog($"âš ï¸ Error al guardar configuraciÃ³n: {ex.Message}");
            }
        }
        
        private void DeleteSelectedAuthors()
        {
            if (lvAutoAuthors.CheckedItems.Count == 0)
            {
                AutoLog("âš ï¸ No hay autores seleccionados para borrar");
                return;
            }
            
            var count = lvAutoAuthors.CheckedItems.Count;
            var result = MessageBox.Show(
                $"Â¿Borrar {count} autor(es) seleccionado(s)?",
                "Confirmar borrado",
                MessageBoxButtons.YesNo,
                MessageBoxIcon.Question
            );
            
            if (result == DialogResult.Yes)
            {
                var itemsToRemove = lvAutoAuthors.CheckedItems.Cast<ListViewItem>().ToList();
                foreach (var item in itemsToRemove)
                {
                    lvAutoAuthors.Items.Remove(item);
                }
                
                AutoLog($"ðŸ—‘ï¸ Borrados {count} autor(es)");
                
                // Guardar cambios en el archivo
                SaveAuthorsToFile();
            }
        }
        
        private void SaveAuthorsToFile()
        {
            if (string.IsNullOrEmpty(lastAuthorsFilePath))
            {
                AutoLog("âš ï¸ No hay archivo cargado para guardar");
                return;
            }
            
            try
            {
                var authors = lvAutoAuthors.Items.Cast<ListViewItem>()
                    .Select(item => item.Text)
                    .ToList();
                
                System.IO.File.WriteAllLines(lastAuthorsFilePath, authors);
                AutoLog($"ðŸ’¾ Guardados {authors.Count} autores en {Path.GetFileName(lastAuthorsFilePath)}");
            }
            catch (Exception ex)
            {
                AutoLog($"âŒ Error al guardar archivo: {ex.Message}");
                MessageBox.Show($"Error al guardar:\n{ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
        private void LoadAuthorsFromFile(string filePath)
        {
            try
            {
                if (!System.IO.File.Exists(filePath))
                {
                    AutoLog($"âŒ No se encontrÃ³ el archivo: {filePath}");
                    return;
                }
                
                var authors = System.IO.File.ReadAllLines(filePath)
                    .Where(line => !string.IsNullOrWhiteSpace(line))
                    .Select(line => line.Trim())
                    .Distinct()
                    .OrderBy(a => a)
                    .ToArray();
                
                if (authors.Length == 0)
                {
                    AutoLog($"âš ï¸ El archivo estÃ¡ vacÃ­o: {Path.GetFileName(filePath)}");
                    return;
                }
                
                lvAutoAuthors.Items.Clear();
                foreach (var author in authors)
                {
                    var item = new ListViewItem(author);
                    item.SubItems.Add("0"); // Archivos
                    item.SubItems.Add("Listo"); // Estado
                    item.BackColor = Color.FromArgb(30, 30, 30);
                    item.ForeColor = Color.White;
                    lvAutoAuthors.Items.Add(item);
                }
                
                AutoLog($"âœ… Cargados {authors.Length} autores desde {Path.GetFileName(filePath)}");
            }
            catch (Exception ex)
            {
                AutoLog($"âŒ Error al cargar autores: {ex.Message}");
            }
        }
        
        private void AutoLog(string message)
        {
            if (txtAutoLog != null)
            {
                var timestamp = DateTime.Now.ToString("HH:mm:ss");
                txtAutoLog.AppendText($"[{timestamp}] {message}\r\n");
            }
        }
        
        private void UpdateAuthorInList(string authorName, int totalFiles, string status, bool reset = false)
        {
            foreach (ListViewItem item in lvAutoAuthors.Items)
            {
                if (item.Text == authorName)
                {
                    // Actualizar archivos (columna 1)
                    if (reset)
                    {
                        item.SubItems[1].Text = totalFiles.ToString();
                    }
                    else
                    {
                        item.SubItems[1].Text = totalFiles.ToString(); // Ya es el total acumulado
                    }
                    
                    // Actualizar estado (columna 2)
                    item.SubItems[2].Text = status;
                    break;
                }
            }
        }
        
        private void UpdateAuthorStatus(string authorName, string status)
        {
            foreach (ListViewItem item in lvAutoAuthors.Items)
            {
                if (item.Text == authorName)
                {
                    item.SubItems[2].Text = status;
                    break;
                }
            }
        }
        
        private bool autoSearchRunning = false;
        private CancellationTokenSource autoSearchCts;
        
        private async Task StartAutomaticSearch()
        {
            if (lvAutoAuthors.CheckedItems.Count == 0)
            {
                AutoLog("âš ï¸ No hay autores seleccionados");
                MessageBox.Show("Selecciona al menos un autor de la lista", "BÃºsqueda AutomÃ¡tica", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }
            
            if (client == null)
            {
                AutoLog("âŒ Cliente no inicializado");
                MessageBox.Show("Error: Cliente no inicializado", "BÃºsqueda AutomÃ¡tica", MessageBoxButtons.OK, MessageBoxIcon.Error);
                return;
            }
            
            // Verificar si estÃ¡ conectado (puede tener mÃºltiples flags)
            bool isConnected = client.State.HasFlag(SoulseekClientStates.Connected) || 
                               client.State.HasFlag(SoulseekClientStates.LoggedIn);
            
            if (!isConnected)
            {
                AutoLog($"âŒ No estÃ¡s conectado a Soulseek (Estado: {client.State})");
                MessageBox.Show($"Debes estar conectado a Soulseek\nEstado actual: {client.State}", "BÃºsqueda AutomÃ¡tica", MessageBoxButtons.OK, MessageBoxIcon.Error);
                return;
            }
            
            AutoLog($"âœ… Conectado (Estado: {client.State})");
            
            var selectedAuthors = lvAutoAuthors.CheckedItems.Cast<ListViewItem>()
                .Select(item => item.Text)
                .ToList();
            
            autoSearchRunning = true;
            autoSearchCts = new CancellationTokenSource();
            
            // Habilitar/deshabilitar botones
            if (btnStartAuto != null) btnStartAuto.Enabled = false;
            if (btnStopAuto != null) btnStopAuto.Enabled = true;
            
            AutoLog("â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•");
            AutoLog("ðŸš€ INICIANDO BÃšSQUEDA AUTOMÃTICA");
            AutoLog($"ðŸ“š {selectedAuthors.Count} autores seleccionados");
            AutoLog("â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•");
            
            int round = 1;
            bool anyResultsFound = true;
            int totalNewFilesThisRound = 0;
            var authorNoResultsCount = new Dictionary<string, int>();
            var authorUniqueFiles = new Dictionary<string, HashSet<string>>(); // Trackear archivos Ãºnicos por autor
            var globalUniqueFiles = new HashSet<string>(); // Todos los archivos Ãºnicos globales
            
            // Inicializar contador para cada autor y resetear contadores
            foreach (var author in selectedAuthors)
            {
                authorNoResultsCount[author] = 0;
                authorUniqueFiles[author] = new HashSet<string>();
                
                // Resetear columnas de archivos y estado
                if (InvokeRequired)
                {
                    Invoke(new Action(() => UpdateAuthorInList(author, 0, "Listo", true)));
                }
                else
                {
                    UpdateAuthorInList(author, 0, "Listo", true);
                }
            }
            
            try
            {
                while (anyResultsFound && autoSearchRunning)
                {
                    AutoLog("");
                    AutoLog($"ðŸ”„ â•â•â• RONDA {round} â•â•â•");
                    anyResultsFound = false;
                    totalNewFilesThisRound = 0;
                    var authorsToRemove = new List<string>();
                    
                    // BÃºsqueda en paralelo (mÃ¡ximo 3 simultÃ¡neas)
                    var semaphore = new SemaphoreSlim(3, 3);
                    var tasks = selectedAuthors.ToList().Select(async author =>
                    {
                        await semaphore.WaitAsync(autoSearchCts.Token);
                        try
                        {
                            if (!autoSearchRunning || autoSearchCts.Token.IsCancellationRequested)
                            {
                                return;
                            }
                            
                            AutoLog($"ðŸ” Buscando: {author}");
                            
                            // Actualizar estado a "Buscando..."
                            if (InvokeRequired)
                            {
                                Invoke(new Action(() => UpdateAuthorStatus(author, "ðŸ” Buscando...")));
                            }
                            else
                            {
                                UpdateAuthorStatus(author, "ðŸ” Buscando...");
                            }
                            
                            try
                            {
                                var searchOptions = new SearchOptions(
                                    searchTimeout: 15000,
                                    responseLimit: 10000,
                                    filterResponses: true,
                                    minimumResponseFileCount: 1,
                                    minimumPeerUploadSpeed: 0
                                );
                                
                                var results = await client.SearchAsync(
                                    SearchQuery.FromText(author),
                                    options: searchOptions,
                                    cancellationToken: autoSearchCts.Token
                                );
                                
                                int totalFiles = results.Responses.Sum(r => r.FileCount);
                                int totalUsers = results.Responses.Count;
                                
                                // Contar archivos Ãºnicos (nombre + tamaÃ±o)
                                int uniqueNewFiles = 0;
                                foreach (var response in results.Responses)
                                {
                                    foreach (var file in response.Files)
                                    {
                                        string fileKey = $"{file.Filename}|{file.Size}";
                                        if (!authorUniqueFiles[author].Contains(fileKey))
                                        {
                                            authorUniqueFiles[author].Add(fileKey);
                                            globalUniqueFiles.Add(fileKey);
                                            uniqueNewFiles++;
                                        }
                                    }
                                }
                                
                                lock (authorNoResultsCount)
                                {
                                    if (uniqueNewFiles > 0)
                                    {
                                        anyResultsFound = true;
                                        totalNewFilesThisRound += uniqueNewFiles;
                                        authorNoResultsCount[author] = 0; // Resetear contador
                                        int totalUniqueForAuthor = authorUniqueFiles[author].Count;
                                        AutoLog($"   âœ… {author}: {uniqueNewFiles} nuevos (total Ãºnico: {totalUniqueForAuthor}, respuestas: {totalFiles}, usuarios: {totalUsers})");
                                        
                                        // Actualizar columnas con total de archivos Ãºnicos del autor
                                        if (InvokeRequired)
                                        {
                                            Invoke(new Action(() => UpdateAuthorInList(author, totalUniqueForAuthor, "âœ… Encontrado", false)));
                                        }
                                        else
                                        {
                                            UpdateAuthorInList(author, totalUniqueForAuthor, "âœ… Encontrado", false);
                                        }
                                    }
                                    else
                                    {
                                        authorNoResultsCount[author]++;
                                        AutoLog($"   âšª {author}: Sin resultados ({authorNoResultsCount[author]}/3)");
                                        
                                        // Actualizar estado
                                        if (InvokeRequired)
                                        {
                                            Invoke(new Action(() => UpdateAuthorStatus(author, $"âšª Sin resultados ({authorNoResultsCount[author]}/3)")));
                                        }
                                        else
                                        {
                                            UpdateAuthorStatus(author, $"âšª Sin resultados ({authorNoResultsCount[author]}/3)");
                                        }
                                        
                                        // Si lleva 3 rondas sin resultados, marcarlo para eliminar
                                        if (authorNoResultsCount[author] >= 3)
                                        {
                                            authorsToRemove.Add(author);
                                            AutoLog($"   ðŸš« {author} serÃ¡ eliminado (3 rondas sin resultados)");
                                            
                                            if (InvokeRequired)
                                            {
                                                Invoke(new Action(() => UpdateAuthorStatus(author, "ðŸš« Eliminado")));
                                            }
                                            else
                                            {
                                                UpdateAuthorStatus(author, "ðŸš« Eliminado");
                                            }
                                        }
                                    }
                                }
                            }
                            catch (OperationCanceledException)
                            {
                                AutoLog($"â¹ï¸ {author}: BÃºsqueda cancelada");
                            }
                            catch (Exception ex)
                            {
                                AutoLog($"   âŒ {author}: Error - {ex.Message}");
                            }
                        }
                        finally
                        {
                            semaphore.Release();
                        }
                    });
                    
                    await Task.WhenAll(tasks);
                    
                    // Eliminar autores que llevan 3 rondas sin resultados
                    if (authorsToRemove.Count > 0)
                    {
                        AutoLog("");
                        AutoLog($"ðŸ—‘ï¸ Eliminando {authorsToRemove.Count} autor(es) inactivo(s):");
                        foreach (var author in authorsToRemove)
                        {
                            selectedAuthors.Remove(author);
                            authorNoResultsCount.Remove(author);
                            AutoLog($"   âŒ {author}");
                        }
                    }
                    
                    if (!anyResultsFound || selectedAuthors.Count == 0)
                    {
                        AutoLog("");
                        AutoLog("â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•");
                        if (selectedAuthors.Count == 0)
                        {
                            AutoLog($"âœ… COMPLETADO - Todos los autores eliminados (sin resultados)");
                        }
                        else
                        {
                            AutoLog($"âœ… COMPLETADO - NingÃºn autor devolviÃ³ resultados en ronda {round}");
                        }
                        AutoLog("â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•");
                    }
                    else
                    {
                        AutoLog("");
                        AutoLog($"ðŸ“Š RESUMEN RONDA {round}:");
                        AutoLog($"   ðŸ“ Total archivos nuevos: {totalNewFilesThisRound}");
                        AutoLog($"   ðŸ‘¥ Autores activos: {selectedAuthors.Count}");
                        AutoLog($"   â–¶ï¸ Continuando con ronda {round + 1}...");
                        round++;
                    }
                }
            }
            finally
            {
                autoSearchRunning = false;
                if (btnStartAuto != null) btnStartAuto.Enabled = true;
                if (btnStopAuto != null) btnStopAuto.Enabled = false;
            }
        }
        
        private void CreateLogTab(TabPage parent)
        {
            var panel = new Panel { Dock = DockStyle.Fill, BackColor = Color.FromArgb(25, 25, 25), Padding = new Padding(10) };
            
            // TextBox para el log
            txtLog = new TextBox
            {
                Dock = DockStyle.Fill,
                Multiline = true,
                ReadOnly = true,
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.LightGray,
                Font = new Font("Consolas", 9),
                ScrollBars = ScrollBars.Vertical,
                WordWrap = false
            };
            
            // Mostrar mensajes de log tempranos
            if (earlyLogMessages.Count > 0)
            {
                txtLog.Text = string.Join(Environment.NewLine, earlyLogMessages) + Environment.NewLine;
                earlyLogMessages.Clear();
            }
            
            panel.Controls.Add(txtLog);
            
            // BotÃ³n para limpiar log
            var btnClearLog = new Button
            {
                Text = "ðŸ—‘ï¸ Limpiar Log",
                Location = new Point(10, 10),
                Size = new Size(120, 30),
                BackColor = Color.FromArgb(60, 60, 60),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Anchor = AnchorStyles.Top | AnchorStyles.Right
            };
            btnClearLog.Click += (s, e) => txtLog.Clear();
            panel.Controls.Add(btnClearLog);
            btnClearLog.BringToFront();
            
            parent.Controls.Add(panel);
        }
        
        private void Log(string message)
        {
            try
            {
                System.IO.Directory.CreateDirectory(logDir);
                var logFile = Path.Combine(logDir, $"slskdown-{DateTime.Now:yyyy-MM-dd}.txt");
                var logMessage = $"[{DateTime.Now:HH:mm:ss}] {message}";
                
                // Guardar mensajes tempranos si txtLog aÃºn no existe
                if (txtLog == null)
                {
                    earlyLogMessages.Add(logMessage);
                    // AÃºn asÃ­ escribir en el archivo
                    System.IO.File.AppendAllText(logFile, logMessage + Environment.NewLine);
                    return;
                }
                
                // Escribir en archivo
                System.IO.File.AppendAllText(logFile, logMessage + Environment.NewLine);
                
                // Limitar tamaÃ±o del archivo a 5MB
                if (System.IO.File.Exists(logFile))
                {
                    var fileInfo = new System.IO.FileInfo(logFile);
                    if (fileInfo.Length > 5 * 1024 * 1024) // 5MB
                    {
                        // Leer Ãºltimas 3000 lÃ­neas y reescribir el archivo
                        var lines = System.IO.File.ReadAllLines(logFile);
                        if (lines.Length > 3000)
                        {
                            var lastLines = lines.Skip(lines.Length - 3000).ToArray();
                            System.IO.File.WriteAllLines(logFile, lastLines);
                        }
                    }
                }
                
                System.IO.File.AppendAllText(logFile, logMessage + Environment.NewLine);
                
                // TambiÃ©n mostrar en la pestaÃ±a de log
                if (txtLog != null)
                {
                    if (InvokeRequired)
                    {
                        Invoke(new Action(() =>
                        {
                            // Limitar a 1000 lÃ­neas (aproximadamente 50KB)
                            var lines = txtLog.Lines;
                            if (lines.Length > 1000)
                            {
                                txtLog.Text = string.Join(Environment.NewLine, lines.Skip(lines.Length - 1000));
                            }
                            
                            txtLog.AppendText(logMessage + Environment.NewLine);
                            txtLog.SelectionStart = txtLog.Text.Length;
                            txtLog.ScrollToCaret();
                        }));
                    }
                    else
                    {
                        // Limitar a 1000 lÃ­neas (aproximadamente 50KB)
                        var lines = txtLog.Lines;
                        if (lines.Length > 1000)
                        {
                            txtLog.Text = string.Join(Environment.NewLine, lines.Skip(lines.Length - 1000));
                        }
                        
                        txtLog.AppendText(logMessage + Environment.NewLine);
                        txtLog.SelectionStart = txtLog.Text.Length;
                        txtLog.ScrollToCaret();
                    }
                }
            }
            catch { }
        }
        
        private async Task<string> GetCountryAsync(string ip)
        {
            if (string.IsNullOrEmpty(ip) || ip == "0.0.0.0")
                return "??";
            
            if (countryCache.ContainsKey(ip))
                return countryCache[ip];
            
            try
            {
                using (var client = new HttpClient())
                {
                    client.Timeout = TimeSpan.FromSeconds(2);
                    var response = await client.GetStringAsync($"http://ip-api.com/json/{ip}?fields=countryCode");
                    var json = JsonSerializer.Deserialize<Dictionary<string, object>>(response);
                    var country = json.ContainsKey("countryCode") ? json["countryCode"].ToString() : "??";
                    countryCache[ip] = country;
                    
                    if (countryCache.Count % 50 == 0)
                        SaveCountryCache();
                    
                    return country;
                }
            }
            catch
            {
                return "??";
            }
        }
        
        private bool IsHispanic(string country)
        {
            var hispanicCountries = new[] { "ES", "MX", "AR", "CO", "CL", "PE", "VE", "EC", "GT", "CU", "BO", "DO", "HN", "PY", "SV", "NI", "CR", "PA", "UY", "PR" };
            return hispanicCountries.Contains(country);
        }
        
        private void SaveCountryCache()
        {
            try
            {
                var json = JsonSerializer.Serialize(countryCache, new JsonSerializerOptions { WriteIndented = true });
                System.IO.File.WriteAllText(countryCachePath, json);
            }
            catch { }
        }
        
        private void UpdateSelectionCount()
        {
            int count = lvResults.SelectedItems.Count;
            long totalSize = 0;
            
            foreach (ListViewItem item in lvResults.SelectedItems)
            {
                if (item.Tag != null)
                {
                    dynamic result = item.Tag;
                    totalSize += (long)result.Size;
                }
            }
            
            lblSelectionCount.Text = count > 0 
                ? $"{count} archivos seleccionados ({FormatSize(totalSize)})" 
                : "0 archivos seleccionados";
        }
        
