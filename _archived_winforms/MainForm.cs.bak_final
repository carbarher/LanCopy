        private void SaveAuthors()
        {
            try
            {
                System.IO.File.WriteAllLines(authorsPath, authors);
                Log($"Lista de autores guardada: {authors.Count} autores");
            }
            catch (Exception ex)
            {
                Log($"Error al guardar autores: {ex.Message}");
            }
        }
        
        private void LoadAuthors()
        {
            try
            {
                if (System.IO.File.Exists(authorsPath))
                {
                    authors = System.IO.File.ReadAllLines(authorsPath).ToList();
                    Log($"Lista de autores cargada: {authors.Count} autores");
                }
                else
                {
                    Log("No se encontrÃ³ lista de autores");
                }
            }
            catch (Exception ex)
            {
                Log($"Error al cargar autores: {ex.Message}");
            }
        }
        
        private void SaveWatchlist()
        {
            try
            {
                System.IO.File.WriteAllLines(watchlistPath, watchlist);
            }
            catch { }
        }
        
        private async Task CheckWatchlist()
        {
            if (client == null || watchlist.Count == 0)
                return;
            
            foreach (var term in watchlist)
            {
                try
                {
                    var oldSearch = cmbSearch.Text;
                    cmbSearch.Text = term;
                    await SearchAsync();
                    await Task.Delay(2000);
                    cmbSearch.Text = oldSearch;
                }
                catch { }
            }
        }
        
        private async Task RetryDownload()
        {
            if (lvDownloads.SelectedItems.Count == 0)
                return;
            
            var selectedItem = lvDownloads.SelectedItems[0];
            var fileName = selectedItem.Text;
            
            // Buscar en resultados
            var resultItem = lvResults.Items.Cast<ListViewItem>()
                .FirstOrDefault(i => Path.GetFileName(((dynamic)i.Tag).Filename) == fileName);
            
            if (resultItem != null)
            {
                dynamic result = resultItem.Tag;
                selectedItem.SubItems[2].Text = "0%";
                selectedItem.SubItems[3].Text = "ðŸ”„ Reintentando...";
                selectedItem.ForeColor = Color.White;
                
                // Limpiar de cola de reintentos si existe
                var existingRetry = retryQueue.FirstOrDefault(r => Path.GetFileName(((dynamic)r.result).Filename) == fileName);
                if (existingRetry.result != null)
                    retryQueue.Remove(existingRetry);
                
                await DownloadFileAsync(selectedItem, result);
            }
            else
            {
                MessageBox.Show("No se encontrÃ³ el archivo en los resultados de bÃºsqueda", "Error", MessageBoxButtons.OK, MessageBoxIcon.Warning);
            }
        }
        
        private string FormatDuration(int seconds)
        {
            var ts = TimeSpan.FromSeconds(seconds);
            return ts.Hours > 0 ? $"{ts.Hours}:{ts.Minutes:D2}:{ts.Seconds:D2}" : $"{ts.Minutes}:{ts.Seconds:D2}";
        }
        
        private void FilterResults()
        {
            if (string.IsNullOrWhiteSpace(txtFilterResults.Text))
            {
                foreach (ListViewItem item in lvResults.Items)
                    item.BackColor = Color.FromArgb(45, 45, 45);
                return;
            }
            
            var filter = txtFilterResults.Text.ToLower();
            foreach (ListViewItem item in lvResults.Items)
            {
                bool matches = item.SubItems.Cast<ListViewItem.ListViewSubItem>()
                    .Any(sub => sub.Text.ToLower().Contains(filter));
                
                item.BackColor = matches ? Color.FromArgb(45, 45, 45) : Color.FromArgb(30, 30, 30);
            }
        }
        
        private void ExportToCSV()
        {
            try
            {
                using (var dialog = new SaveFileDialog())
                {
                    dialog.Filter = "CSV files (*.csv)|*.csv";
                    dialog.FileName = $"slskdown-results-{DateTime.Now:yyyy-MM-dd-HHmmss}.csv";
                    
                    if (dialog.ShowDialog() == DialogResult.OK)
                    {
                        var lines = new List<string>();
                        lines.Add("Usuario,Archivo,TamaÃ±o,Velocidad,Bitrate,DuraciÃ³n,ExtensiÃ³n,Carpeta");
                        
                        foreach (ListViewItem item in lvResults.Items)
                        {
                            var line = string.Join(",", item.SubItems.Cast<ListViewItem.ListViewSubItem>().Select(s => $"\"{s.Text}\""));
                            lines.Add(line);
                        }
                        
                        System.IO.File.WriteAllLines(dialog.FileName, lines);
                        MessageBox.Show($"Exportado {lvResults.Items.Count} resultados a CSV", "SlskDown", MessageBoxButtons.OK, MessageBoxIcon.Information);
                        Log($"Exportado {lvResults.Items.Count} resultados a {dialog.FileName}");
                    }
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error al exportar: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
        private async Task TestConnection()
        {
            try
            {
                var testClient = new SoulseekClient(new SoulseekClientOptions(
                    listenPort: listenPort,
                    enableDistributedNetwork: enableDistributedNetwork
                ));
                
                await testClient.ConnectAsync(username, password);
                testClient.Dispose();
                
                MessageBox.Show("âœ… ConexiÃ³n exitosa!", "Test ConexiÃ³n", MessageBoxButtons.OK, MessageBoxIcon.Information);
                Log("Test de conexiÃ³n exitoso");
            }
            catch (Exception ex)
            {
                MessageBox.Show($"âŒ Error de conexiÃ³n: {ex.Message}", "Test ConexiÃ³n", MessageBoxButtons.OK, MessageBoxIcon.Error);
                Log($"Test de conexiÃ³n fallido: {ex.Message}");
            }
        }
        
        private void TabControl_DrawItem(object sender, DrawItemEventArgs e)
        {
            TabControl tabControl = (TabControl)sender;
            TabPage tabPage = tabControl.TabPages[e.Index];
            Rectangle tabRect = tabControl.GetTabRect(e.Index);
            
            // Color de fondo de la pestaÃ±a
            Color backColor = (e.State == DrawItemState.Selected) 
                ? Color.FromArgb(45, 45, 45) 
                : Color.FromArgb(25, 25, 25);
            
            using (SolidBrush brush = new SolidBrush(backColor))
            {
                e.Graphics.FillRectangle(brush, tabRect);
            }
            
            // Borde superior de la pestaÃ±a seleccionada
            if (e.State == DrawItemState.Selected)
            {
                using (Pen pen = new Pen(Color.FromArgb(0, 120, 215), 3))
                {
                    e.Graphics.DrawLine(pen, tabRect.Left, tabRect.Top, tabRect.Right, tabRect.Top);
                }
            }
            
            // Texto de la pestaÃ±a
            TextRenderer.DrawText(
                e.Graphics,
                tabPage.Text,
                tabControl.Font,
                tabRect,
                Color.White,
                TextFormatFlags.HorizontalCenter | TextFormatFlags.VerticalCenter
            );
        }
        
        // ===== FUNCIONALIDADES ADICIONALES =====
        
        private async Task SearchMultipleTerms(List<string> terms)
        {
            try
            {
                // Crear nuevo CancellationTokenSource
                searchCancellationTokenSource?.Cancel();
                searchCancellationTokenSource = new System.Threading.CancellationTokenSource();
                
                if (btnSearch != null) btnSearch.Enabled = false;
                if (btnStopSearch != null) btnStopSearch.Enabled = true;
                if (lblStatus != null) lblStatus.Text = $"Buscando {terms.Count} tÃ©rminos...";
                if (lvResults != null) lvResults.Items.Clear();
                allResults.Clear();
                
                int totalFiles = 0;
                
                // Interpretar 0 como sin lÃ­mite
                int actualResponseLimit = responseLimit == 0 ? int.MaxValue : responseLimit;
                int actualFileLimit = fileLimit == 0 ? int.MaxValue : fileLimit;
                int actualTimeout = searchTimeout == 0 ? int.MaxValue : searchTimeout * 1000;
                
                // Procesar tÃ©rminos en lotes paralelos segÃºn maxParallelSearches
                for (int i = 0; i < terms.Count; i += maxParallelSearches)
                {
                    var batch = terms.Skip(i).Take(maxParallelSearches).ToList();
                    Log($"ðŸ“¦ Procesando lote {(i/maxParallelSearches)+1}: {batch.Count} tÃ©rminos en paralelo");
                    
                    // Crear tareas de bÃºsqueda para este lote
                    var searchTasks = batch.Select(async term =>
                    {
                        try
                        {
                            // Verificar si se cancelÃ³
                            searchCancellationTokenSource.Token.ThrowIfCancellationRequested();
                            
                            var startTime = DateTime.Now;
                            Log($"ðŸ” Iniciando: {term} (timeout: {actualTimeout/1000}s)");
                            
                            var searchOptions = new SearchOptions(
                                responseLimit: actualResponseLimit, 
                                fileLimit: actualFileLimit,
                                searchTimeout: actualTimeout
                            );
                            
                            var searchResult = await client.SearchAsync(
                                SearchQuery.FromText(term), 
                                options: searchOptions
                            );
                            
                            var results = searchResult.Responses;
                            var elapsed = (DateTime.Now - startTime).TotalSeconds;
                            Log($"âœ… {term}: {results.Count()} respuestas en {elapsed:F1}s");
                            
                            return (term, results);
                        }
                        catch (Exception ex)
                        {
                            Log($"âŒ Error en {term}: {ex.Message}");
                            return (term, Enumerable.Empty<Soulseek.SearchResponse>());
                        }
                    }).ToList();
                    
                    // Esperar a que todas las bÃºsquedas del lote terminen
                    var batchResults = await Task.WhenAll(searchTasks);
                    
                    // Procesar resultados de este lote
                    long minSizeBytes = numMinSize != null ? (long)(numMinSize.Value * 1024) : 0;
                    long maxSizeBytes = numMaxSize != null && numMaxSize.Value > 0 ? (long)(numMaxSize.Value * 1024) : long.MaxValue;
                    string extFilter = cmbExtension?.SelectedItem?.ToString();
                    
                    foreach (var (term, results) in batchResults)
                    {
                        foreach (var response in results)
                        {
                            // Verificar cancelaciÃ³n
                            searchCancellationTokenSource.Token.ThrowIfCancellationRequested();
                            
                            if (blacklist.Contains(response.Username))
                                continue;
                            
                            foreach (var file in response.Files.Take(500))
                            {
                                // Descartar archivos de tamaÃ±o 0
                                if (file.Size == 0)
                                    continue;
                                
                                if (minSizeBytes > 0 && file.Size < minSizeBytes)
                                    continue;
                                if (maxSizeBytes < long.MaxValue && file.Size > maxSizeBytes)
                                    continue;
                                
                                string fileExt = Path.GetExtension(file.Filename).ToLower();
                                if (!MatchesCategory(fileExt, extFilter))
                                    continue;
                                
                                // Filtro de idioma espaÃ±ol
                                if (chkSpanishOnly != null && chkSpanishOnly.Checked && !IsSpanishText(file.Filename))
                                    continue;
                                
                                string icon = GetFileIcon(fileExt);
                                var item = new ListViewItem(new string[] 
                                { 
                                    response.Username,
                                    icon + " " + Path.GetFileName(file.Filename), 
                                    FormatSize(file.Size), 
                                    fileExt,
                                    Path.GetDirectoryName(file.Filename) ?? ""
                                });
                                item.Tag = new { response.Username, file.Filename, file.Size, UploadSpeed = response.UploadSpeed };
                                item.BackColor = Color.FromArgb(30, 30, 30);
                                item.ForeColor = GetQualityColor(file.Size, fileExt);
                                allResults.Add(item);
                                totalFiles++;
                                
                                // Actualizar contador cada 100 archivos
                                if (totalFiles % 100 == 0)
                                {
                                    if (InvokeRequired)
                                    {
                                        Invoke(new Action(() => 
                                        {
                                            if (lblResultsCount != null) lblResultsCount.Text = $"{totalFiles} archivos...";
                                            if (lblStatus != null) lblStatus.Text = $"BÃºsqueda mÃºltiple... {totalFiles} encontrados";
                                        }));
                                    }
                                }
                            }
                        }
                    }
                }
                
                // Mostrar todos los resultados sin paginaciÃ³n
                if (lvResults != null)
                {
                    lvResults.BeginUpdate();
                    lvResults.Items.Clear();
                    foreach (var item in allResults)
                    {
                        lvResults.Items.Add((ListViewItem)item.Clone());
                    }
                    lvResults.EndUpdate();
                }
                
                if (lblStatus != null) lblStatus.Text = $"{totalFiles} archivos encontrados ({terms.Count} bÃºsquedas)";
                if (lblResultsCount != null) lblResultsCount.Text = $"{totalFiles} resultados";
                Log($"âœ… BÃºsqueda mÃºltiple completada: {totalFiles} archivos de {terms.Count} tÃ©rminos");
            }
            catch (OperationCanceledException)
            {
                if (lblStatus != null) lblStatus.Text = "BÃºsqueda mÃºltiple cancelada";
                if (lblResultsCount != null) lblResultsCount.Text = $"{allResults.Count} resultados (cancelado)";
                Log("BÃºsqueda mÃºltiple cancelada por el usuario");
            }
            catch (Exception ex)
            {
                if (lblStatus != null) lblStatus.Text = $"Error: {ex.Message}";
                Log($"Error en bÃºsqueda mÃºltiple: {ex.Message}");
            }
            finally
            {
                if (btnSearch != null) btnSearch.Enabled = true;
                if (btnStopSearch != null) btnStopSearch.Enabled = false;
            }
        }
        
        
        private void SaveStats()
        {
            try
            {
                var stats = new
                {
                    totalSearches,
                    totalDownloads,
                    searchStats,
                    lastUpdate = DateTime.Now
                };
                System.IO.File.WriteAllText(statsPath, JsonSerializer.Serialize(stats));
            }
            catch (Exception ex)
            {
                Log($"Error al guardar estadÃ­sticas: {ex.Message}");
            }
        }
        
        private void LoadStats()
        {
            try
            {
                if (System.IO.File.Exists(statsPath))
                {
                    var json = System.IO.File.ReadAllText(statsPath);
                    var doc = JsonDocument.Parse(json);
                    totalSearches = doc.RootElement.GetProperty("totalSearches").GetInt32();
                    totalDownloads = doc.RootElement.GetProperty("totalDownloads").GetInt32();
                    
                    if (doc.RootElement.TryGetProperty("searchStats", out var statsElement))
                    {
                        foreach (var prop in statsElement.EnumerateObject())
                        {
                            searchStats[prop.Name] = prop.Value.GetInt32();
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                Log($"Error al cargar estadÃ­sticas: {ex.Message}");
            }
        }
        
        // ===== RECONEXIÃ“N AUTOMÃTICA =====
        
        private async Task CheckAndReconnect()
        {
            if (!autoReconnect)
                return;
            
            try
            {
                // Verificar si el cliente estÃ¡ desconectado
                if (client != null && client.State == SoulseekClientStates.Disconnected)
                {
                    Log("âš ï¸ ConexiÃ³n perdida. Intentando reconectar...");
                    this.Invoke(() => 
                    {
                        lblStatus.Text = "Reconectando...";
                        lblStatus.ForeColor = Color.Orange;
                    });
                    
                    await client.ConnectAsync(username, password);
                    
                    this.Invoke(() => 
                    {
                        btnConnect.Text = "Desconectar";
                        btnConnect.Enabled = true;
                        btnSearch.Enabled = true;
                        lblStatus.Text = "Reconectado";
                        lblStatus.ForeColor = Color.FromArgb(0, 200, 0);
                    });
                    
                    Log("âœ… ReconexiÃ³n exitosa");
                }
            }
            catch (Exception ex)
            {
                Log($"âŒ Error en reconexiÃ³n automÃ¡tica: {ex.Message}");
                // IntentarÃ¡ de nuevo en el prÃ³ximo ciclo del timer
            }
        }
        
