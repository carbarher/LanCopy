            var panel = new Panel { Dock = DockStyle.Fill, Padding = new Padding(20), BackColor = Color.FromArgb(18, 18, 18) };
            
            var lblTitle = new Label { Text = "ðŸ‘¤ BÃºsqueda por Autor", Location = new Point(20, 20), Size = new Size(400, 30), ForeColor = Color.White, Font = new Font("Segoe UI", 14, FontStyle.Bold) };
            panel.Controls.Add(lblTitle);
            
