            btnSearchAuthor.Click += async (s, e) =>
            {
                if (lstAuthors.SelectedItem != null)
                {
                    string authorName = lstAuthors.SelectedItem.ToString();
                    Log($"Iniciando bÃºsqueda de autor: {authorName}");
                    
                    // Cambiar a pestaÃ±a de bÃºsqueda
                    if (InvokeRequired)
                    {
                        Invoke(new Action(() =>
                        {
