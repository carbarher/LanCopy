        private void CreateBlacklistTab(TabPage parent)
        {
            parent.BackColor = Color.FromArgb(18, 18, 18);
            var panel = new Panel { Dock = DockStyle.Fill, Padding = new Padding(20), BackColor = Color.FromArgb(18, 18, 18) };
            
            var lblTitle = new Label { Text = "ðŸš« Lista Negra de Usuarios", Location = new Point(20, 20), Size = new Size(400, 30), ForeColor = Color.White, Font = new Font("Segoe UI", 14, FontStyle.Bold) };
            panel.Controls.Add(lblTitle);
            
            var lblInfo = new Label { Text = "Los usuarios bloqueados no aparecerÃ¡n en los resultados de bÃºsqueda.", Location = new Point(20, 60), Size = new Size(500, 20), ForeColor = Color.LightGray };
            panel.Controls.Add(lblInfo);
            
            var lstBlacklist = new ListBox { Location = new Point(20, 100), Size = new Size(400, 400), BackColor = Color.FromArgb(45, 45, 45), ForeColor = Color.White };
            lstBlacklist.Items.AddRange(blacklist.ToArray());
            panel.Controls.Add(lstBlacklist);
            
            var txtUser = new TextBox { Location = new Point(440, 100), Size = new Size(200, 25), BackColor = Color.FromArgb(60, 60, 60), ForeColor = Color.White };
            panel.Controls.Add(txtUser);
            
            var btnAdd = new Button { Text = "âž• Agregar", Location = new Point(440, 140), Size = new Size(200, 35), BackColor = Color.FromArgb(60, 60, 60), ForeColor = Color.White, FlatStyle = FlatStyle.Flat };
            btnAdd.Click += (s, e) =>
            {
                if (!string.IsNullOrWhiteSpace(txtUser.Text) && !blacklist.Contains(txtUser.Text))
                {
                    blacklist.Add(txtUser.Text);
                    lstBlacklist.Items.Add(txtUser.Text);
                    SaveBlacklist();
                    txtUser.Clear();
                }
            };
            panel.Controls.Add(btnAdd);
            
            var btnRemove = new Button { Text = "âŒ Eliminar", Location = new Point(440, 185), Size = new Size(200, 35), BackColor = Color.FromArgb(60, 60, 60), ForeColor = Color.White, FlatStyle = FlatStyle.Flat };
            btnRemove.Click += (s, e) =>
            {
                if (lstBlacklist.SelectedItem != null)
                {
                    blacklist.Remove(lstBlacklist.SelectedItem.ToString());
                    lstBlacklist.Items.Remove(lstBlacklist.SelectedItem);
                    SaveBlacklist();
                }
            };
            panel.Controls.Add(btnRemove);
            
            var btnClear = new Button { Text = "ðŸ—‘ï¸ Limpiar todo", Location = new Point(440, 230), Size = new Size(200, 35), BackColor = Color.FromArgb(60, 60, 60), ForeColor = Color.White, FlatStyle = FlatStyle.Flat };
            btnClear.Click += (s, e) =>
            {
                if (MessageBox.Show("Â¿Eliminar todos los usuarios de la lista negra?", "Confirmar", MessageBoxButtons.YesNo, MessageBoxIcon.Question) == DialogResult.Yes)
                {
                    blacklist.Clear();
                    lstBlacklist.Items.Clear();
                    SaveBlacklist();
                }
            };
            panel.Controls.Add(btnClear);
            
            parent.Controls.Add(panel);
        }
        
        private void BlacklistSelectedUser()
        {
            if (lvResults.SelectedItems.Count == 0)
                return;
            
            dynamic result = lvResults.SelectedItems[0].Tag;
            string username = (string)result.Username;
            
            if (!blacklist.Contains(username))
            {
                blacklist.Add(username);
                SaveBlacklist();
                MessageBox.Show($"Usuario '{username}' agregado a la lista negra", "SlskDown", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
        }
        
        private void CancelDownload()
        {
            if (lvDownloads.SelectedItems.Count == 0)
                return;
            
            var fileName = lvDownloads.SelectedItems[0].Text;
            
            if (activeDownloads.ContainsKey(fileName))
            {
                activeDownloads[fileName].Cancel();
                lvDownloads.SelectedItems[0].SubItems[3].Text = "â¸ï¸ Cancelando...";
            }
        }
        
        private void SaveBlacklist()
        {
            try
            {
                var json = JsonSerializer.Serialize(blacklist, new JsonSerializerOptions { WriteIndented = true });
                System.IO.File.WriteAllText(blacklistPath, json);
                Log($"Blacklist guardada: {blacklist.Count} usuarios");
            }
            catch (Exception ex)
            {
                Log($"Error al guardar blacklist: {ex.Message}");
            }
        }
        
        private void LoadBlacklist()
        {
            try
            {
                if (System.IO.File.Exists(blacklistPath))
                {
                    blacklist = JsonSerializer.Deserialize<List<string>>(System.IO.File.ReadAllText(blacklistPath)) ?? new List<string>();
                    Log($"Blacklist cargada: {blacklist.Count} usuarios");
                }
                else
                {
                    Log("No se encontrÃ³ blacklist");
                }
            }
            catch (Exception ex)
            {
                Log($"Error al cargar blacklist: {ex.Message}");
            }
        }
        
