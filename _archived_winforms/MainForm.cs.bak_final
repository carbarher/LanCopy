        private async Task ConnectToSoulseek()
        {
            if (client != null && client.State.HasFlag(SoulseekClientStates.Connected))
            {
                Log("Ya estÃ¡ conectado");
                return;
            }
            
            if (InvokeRequired)
            {
                Invoke(new Action(() =>
                {
                    if (btnConnect != null) btnConnect.Enabled = false;
                    if (lblStatus != null)
                    {
                        if (lblStatus != null) lblStatus.Text = "Conectando...";
                        if (lblStatus != null) lblStatus.ForeColor = Color.Orange;
                    }
                }));
            }
            else
            {
                if (btnConnect != null) btnConnect.Enabled = false;
                if (lblStatus != null)
                {
                    if (lblStatus != null) lblStatus.Text = "Conectando...";
                    if (lblStatus != null) lblStatus.ForeColor = Color.Orange;
                }
            }
            
            Log($"Intentando conectar como: {username}");
            
            // Intentar con varios puertos si falla
            int maxAttempts = 5;
            bool connected = false;
            
            for (int attempt = 1; attempt <= maxAttempts && !connected; attempt++)
                {
                    try
                    {
                        // Generar puerto aleatorio
                        int randomPort = new Random().Next(50000, 60000);
                        Log($"Intento {attempt}/{maxAttempts} - Puerto: {randomPort}");
                        
                        var options = new SoulseekClientOptions(
                            listenPort: randomPort,
                            enableDistributedNetwork: enableDistributedNetwork,
                            serverConnectionOptions: new ConnectionOptions(
                                inactivityTimeout: 300000  // 5 minutos de timeout
                            )
                        );
                        client = new SoulseekClient(options);
                        
                        // Suscribirse a evento de desconexiÃ³n
                        client.Disconnected += async (sender, args) =>
                        {
                            Log($"âš ï¸ Evento de desconexiÃ³n detectado: {args.Message}");
                            if (autoReconnect)
                            {
                                await Task.Delay(2000);
                                await CheckAndReconnect();
                            }
                        };
                        
                        await client.ConnectAsync(username, password);
                        
                        Log($"âœ… ConexiÃ³n exitosa en puerto {randomPort}");
                        Log($"Estado del cliente: {client.State}");
                        
                        if (InvokeRequired)
                        {
                            Invoke(new Action(() =>
                            {
                                if (btnConnect != null)
                                {
                                    btnConnect.Text = "Desconectar";
                                    btnConnect.Enabled = true;
                                }
                                if (btnSearch != null) btnSearch.Enabled = true;
                                if (lblStatus != null)
                                {
                                    lblStatus.Text = "Conectado";
                                    lblStatus.ForeColor = Color.FromArgb(0, 200, 0);
                                }
                            }));
                        }
                        else
                        {
                            if (btnConnect != null)
                            {
                                btnConnect.Text = "Desconectar";
                                btnConnect.Enabled = true;
                            }
                            if (btnSearch != null) btnSearch.Enabled = true;
                            if (lblStatus != null)
                            {
                                lblStatus.Text = "Conectado";
                                lblStatus.ForeColor = Color.FromArgb(0, 200, 0);
                            }
                        }
                        
                        connected = true;
                    }
                    catch (Exception ex)
                    {
                        client?.Dispose();
                        client = null;
                        
                        if (attempt < maxAttempts)
                        {
                            Log($"âŒ Intento {attempt} fallÃ³: {ex.Message}. Reintentando...");
                            await Task.Delay(500); // PequeÃ±a pausa entre intentos
                        }
                        else
                        {
                            // Ãšltimo intento fallÃ³
                            string errorMsg = ex.Message;
                            if (errorMsg.Contains("Failed to start listening") || errorMsg.Contains("port may be in use"))
                            {
                                errorMsg = $"No se pudo encontrar un puerto disponible despuÃ©s de {maxAttempts} intentos.\nCierra otras instancias de SlskDown.";
                            }
                            
                            Log($"âŒ Error final de conexiÃ³n: {ex.Message}");
                            if (btnConnect != null)
                            {
                                btnConnect.Text = "Conectar";
                                btnConnect.Enabled = true;
                            }
                            if (lblStatus != null) lblStatus.Text = "Error de conexiÃ³n";
                            
                            MessageBox.Show(errorMsg, "Error de ConexiÃ³n", MessageBoxButtons.OK, MessageBoxIcon.Error);
                        }
                    }
                }
        }
        
        private async Task ConnectAsync()
        {
            if (client != null && client.State.HasFlag(SoulseekClientStates.Connected))
            {
                // Desconectar
                client.Dispose();
                client = null;
                if (btnConnect != null) btnConnect.Text = "Conectar";
                if (btnSearch != null) btnSearch.Enabled = false;
                if (lblStatus != null)
                {
                    lblStatus.Text = "Desconectado";
                    lblStatus.ForeColor = Color.Gray;
                }
                Log("Desconectado manualmente");
            }
            else
            {
                // Conectar
                await ConnectToSoulseek();
            }
        }
        
        private (int totalFiles, int processedResponses, int processedFiles, int filteredBySize, int filteredByExt, int filteredBySpanish, int filteredByBlacklist) 
            ProcessAndDisplayResults(List<SearchResponse> responses, long minSizeBytes, long maxSizeBytes, string extFilter,
            int totalFiles, int processedResponses, int processedFiles,
            int filteredBySize, int filteredByExt, int filteredBySpanish, int filteredByBlacklist)
        {
            foreach (var response in responses)
            {
                processedResponses++;
                
                if (blacklist.Contains(response.Username))
                {
                    filteredByBlacklist++;
                    continue;
                }
                
                foreach (var file in response.Files.Take(500))
                {
                    processedFiles++;
                    
                    if (minSizeBytes > 0 && file.Size < minSizeBytes)
                    {
                        filteredBySize++;
                        continue;
                    }
                    if (maxSizeBytes < long.MaxValue && file.Size > maxSizeBytes)
                    {
                        filteredBySize++;
                        continue;
                    }
                    
                    string fileExt = Path.GetExtension(file.Filename).ToLower();
                    if (!MatchesCategory(fileExt, extFilter))
                    {
                        filteredByExt++;
                        continue;
                    }
                    
                    if (chkSpanishOnly.Checked && !IsSpanishText(file.Filename))
                    {
                        filteredBySpanish++;
                        continue;
                    }
                    
                    var item = new ListViewItem(new string[] 
                    { 
                        response.Username,
                        Path.GetFileName(file.Filename), 
                        FormatSize(file.Size), 
                        fileExt,
                        Path.GetDirectoryName(file.Filename) ?? ""
                    });
                    item.Tag = new { response.Username, file.Filename, file.Size, UploadSpeed = response.UploadSpeed };
                    allResults.Add(item);
                    totalFiles++;
                }
            }
            
            // Actualizar grilla con todos los nuevos resultados
            int currentTotal = totalFiles;
            if (InvokeRequired)
            {
                Invoke(new Action(() => 
                {
                    var itemsToAdd = allResults.Skip(lvResults.Items.Count).ToArray();
                    if (itemsToAdd.Length > 0)
                    {
                        lvResults.Items.AddRange(itemsToAdd);
                        lblResultsCount.Text = $"{currentTotal} archivos";
                        lblStatus.Text = $"Buscando... {currentTotal} encontrados";
                    }
                }));
            }
            else
            {
                var itemsToAdd = allResults.Skip(lvResults.Items.Count).ToArray();
                if (itemsToAdd.Length > 0)
                {
                    lvResults.Items.AddRange(itemsToAdd);
                    lblResultsCount.Text = $"{currentTotal} archivos";
                    lblStatus.Text = $"Buscando... {currentTotal} encontrados";
                }
            }
            
            return (totalFiles, processedResponses, processedFiles, filteredBySize, filteredByExt, filteredBySpanish, filteredByBlacklist);
        }
        
        private async Task SearchAsync()
        {
            if (client == null || string.IsNullOrWhiteSpace(cmbSearch.Text)) 
                return;
            
            // Guardar en historial
            if (!searchHistory.Contains(cmbSearch.Text))
            {
                searchHistory.Insert(0, cmbSearch.Text);
                if (searchHistory.Count > 20) searchHistory.RemoveAt(20);
                cmbSearch.Items.Clear();
                cmbSearch.Items.AddRange(searchHistory.ToArray());
                SaveSearchHistory();
            }
            
            // EstadÃ­sticas
            totalSearches++;
            
            // BÃºsqueda mÃºltiple (separada por comas)
            var searchTerms = cmbSearch.Text.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries)
                .Select(t => t.Trim())
                .Where(t => !string.IsNullOrEmpty(t))
                .ToList();
            
            if (searchTerms.Count > 1)
            {
                Log($"BÃºsqueda mÃºltiple: {searchTerms.Count} tÃ©rminos (mÃ¡x {maxParallelSearches} simultÃ¡neos)");
                await SearchMultipleTerms(searchTerms);
                return;
            }
            
            if (client == null || !client.State.HasFlag(SoulseekClientStates.Connected))
            {
                if (lblStatus != null)
                {
                    lblStatus.Text = "âŒ No conectado - Presiona el botÃ³n CONECTAR primero";
                    lblStatus.ForeColor = Color.Red;
                }
                Log($"Error: Cliente no conectado. Estado actual: {client?.State.ToString() ?? "null"}");
                
                // Verificar si estÃ¡ en proceso de conexiÃ³n
                if (btnConnect != null && btnConnect.Text == "Conectar" && btnConnect.Enabled == false)
                {
                    MessageBox.Show("La conexiÃ³n estÃ¡ en proceso. Espera unos segundos e intenta de nuevo.", 
                        "Conectando...", MessageBoxButtons.OK, MessageBoxIcon.Information);
                }
                else
                {
                    MessageBox.Show("Debes conectarte a Soulseek antes de buscar.\n\nPresiona el botÃ³n 'Conectar' en la parte superior.", 
                        "No Conectado", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                }
                return;
            }
            
            Log($"Iniciando bÃºsqueda: {cmbSearch.Text}");
            Log($"Estado del cliente: {client.State}");
            Log($"Red distribuida: {enableDistributedNetwork}");
            
            try
            {
                Log("Creando CancellationTokenSource...");
                // Crear nuevo CancellationTokenSource
                searchCancellationTokenSource?.Cancel();
                searchCancellationTokenSource = new System.Threading.CancellationTokenSource();
                
                Log("Actualizando controles UI...");
                if (btnSearch != null) btnSearch.Enabled = false;
                if (btnStopSearch != null) btnStopSearch.Enabled = true;
                if (lblStatus != null) lblStatus.Text = "Buscando...";
                
                Log("Limpiando resultados anteriores...");
                if (lvResults != null) lvResults.Items.Clear();
                allResults.Clear();
                
                Log("Calculando parÃ¡metros de bÃºsqueda...");
                // Interpretar 0 como sin lÃ­mite (int.MaxValue)
                int actualResponseLimit = responseLimit == 0 ? int.MaxValue : responseLimit;
                int actualFileLimit = fileLimit == 0 ? int.MaxValue : fileLimit;
                int actualTimeout = searchTimeout == 0 ? int.MaxValue : searchTimeout * 1000;
                
                Log($"ParÃ¡metros: responseLimit={actualResponseLimit}, fileLimit={actualFileLimit}, timeout={actualTimeout/1000}s");
                
                Log("Creando SearchOptions...");
                var searchOptions = new SearchOptions(
                    responseLimit: actualResponseLimit, 
                    fileLimit: actualFileLimit,
                    searchTimeout: actualTimeout
                );
                
                Log($"Iniciando bÃºsqueda en red Soulseek...");
                Log($"TÃ©rmino de bÃºsqueda: '{cmbSearch.Text}'");
                
                Log("Obteniendo filtros...");
                long minSizeBytes = numMinSize != null ? (long)(numMinSize.Value * 1024) : 0;
                long maxSizeBytes = numMaxSize != null && numMaxSize.Value > 0 ? (long)(numMaxSize.Value * 1024) : long.MaxValue;
                string extFilter = cmbExtension?.SelectedItem?.ToString();
                
                string maxSizeStr = maxSizeBytes == long.MaxValue ? "sin lÃ­mite" : $"{maxSizeBytes/1024}KB";
                Log($"Filtros: minSize={minSizeBytes/1024}KB, maxSize={maxSizeStr}, ext={extFilter}");
                
                int processedResponses = 0;
                int processedFiles = 0;
                int filteredBySize = 0;
                int filteredByExt = 0;
                int filteredBySpanish = 0;
                int filteredByBlacklist = 0;
                int totalFiles = 0;
                
                // BÃºsqueda continua inteligente: continÃºa mientras haya respuestas nuevas
                if (continuousSearch && actualTimeout > 2000)
                {
                    Log($"ðŸ”„ Modo bÃºsqueda continua inteligente: mostrando resultados cada 2 segundos...");
                    Log($"â¹ï¸ Se detendrÃ¡ despuÃ©s de 3 bÃºsquedas consecutivas sin resultados nuevos");
                    
                    int maxIterations = actualTimeout / 2000;
                    var allResponses = new List<SearchResponse>();
                    var seenUsers = new HashSet<string>();
                    int emptySearches = 0;
                    int iteration = 0;
                    
                    while (iteration < maxIterations && emptySearches < 3)
                    {
                        searchCancellationTokenSource.Token.ThrowIfCancellationRequested();
                        iteration++;
                        
                        Log($"ðŸ“¡ BÃºsqueda {iteration} (2s)...");
                        
                        var shortOptions = new SearchOptions(
                            responseLimit: actualResponseLimit,
                            fileLimit: actualFileLimit,
                            searchTimeout: 2000  // 2 segundos
                        );
                        
                        var searchResult = await client.SearchAsync(
                            SearchQuery.FromText(cmbSearch.Text),
                            options: shortOptions
                        );
                        
                        // Filtrar respuestas nuevas (no repetidas)
                        var newResponses = searchResult.Responses
                            .Where(r => !seenUsers.Contains(r.Username))
                            .ToList();
                        
                        if (newResponses.Count == 0)
                        {
                            emptySearches++;
                            Log($"âš ï¸ Sin respuestas nuevas ({emptySearches}/3)");
                            
                            if (emptySearches >= 3)
                            {
                                Log($"â¹ï¸ Deteniendo bÃºsqueda: 3 intentos consecutivos sin resultados nuevos");
                                break;
                            }
                        }
                        else
                        {
                            emptySearches = 0;  // Resetear contador si hay respuestas nuevas
                            
                            foreach (var r in newResponses)
                            {
                                seenUsers.Add(r.Username);
                                allResponses.Add(r);
                            }
                            
                            Log($"âœ… +{newResponses.Count} respuestas nuevas (total: {allResponses.Count})");
                            
                            // Procesar y mostrar resultados nuevos inmediatamente
                            foreach (var response in newResponses)
                            {
                                processedResponses++;
                                
                                if (blacklist != null && blacklist.Contains(response.Username))
                                {
                                    filteredByBlacklist++;
                                    continue;
                                }
                                
                                foreach (var file in response.Files.Take(500))
                                {
                                    processedFiles++;
                                    
                                    // Descartar archivos de tamaÃ±o 0
                                    if (file.Size == 0)
                                    {
                                        filteredBySize++;
                                        continue;
                                    }
                                    
                                    if (minSizeBytes > 0 && file.Size < minSizeBytes)
                                    {
                                        filteredBySize++;
                                        continue;
                                    }
                                    if (maxSizeBytes < long.MaxValue && file.Size > maxSizeBytes)
                                    {
                                        filteredBySize++;
                                        continue;
                                    }
                                    
                                    string fileExt = Path.GetExtension(file.Filename).ToLower();
                                    if (!MatchesCategory(fileExt, extFilter))
                                    {
                                        filteredByExt++;
                                        continue;
                                    }
                                    
                                    string icon = GetFileIcon(fileExt);
                                    var item = new ListViewItem(new string[] 
                                    { 
                                        response.Username,
                                        icon + " " + Path.GetFileName(file.Filename), 
                                        FormatSize(file.Size), 
                                        fileExt,
                                        Path.GetDirectoryName(file.Filename) ?? ""
                                    });
                                    item.Tag = new { response.Username, file.Filename, file.Size, UploadSpeed = response.UploadSpeed };
                                    item.BackColor = Color.FromArgb(30, 30, 30);
                                    item.ForeColor = GetQualityColor(file.Size, fileExt);
                                    
                                    if (InvokeRequired)
                                    {
                                        Invoke(new Action(() => 
                                        {
                                            if (lvResults != null) lvResults.Items.Add(item);
                                        }));
                                    }
                                    else
                                    {
                                        if (lvResults != null) lvResults.Items.Add(item);
                                    }
                                    
                                    totalFiles++;
                                    
                                    if (totalFiles % 100 == 0 && lblResultsCount != null)
                                    {
                                        if (InvokeRequired)
                                        {
                                            Invoke(new Action(() => 
                                            {
                                                if (lblResultsCount != null) lblResultsCount.Text = $"{totalFiles} archivos...";
                                            }));
                                        }
                                        else
                                        {
                                            lblResultsCount.Text = $"{totalFiles} archivos...";
                                        }
                                    }
                                }
                            }
                        }
                    }
                    
                    Log($"âœ… BÃºsqueda continua completada. Total: {allResponses.Count} respuestas en {iteration} bÃºsquedas");
                    var results = allResponses;
                }
                else
                {
                    // BÃºsqueda normal (una sola vez)
                    Log($"â³ Esperando respuestas (timeout: {actualTimeout/1000}s)...");
                    
                    var searchResult = await client.SearchAsync(
                        SearchQuery.FromText(cmbSearch.Text),
                        options: searchOptions
                    );
                    
                    Log($"âœ… BÃºsqueda completada. Total respuestas recibidas: {searchResult.Responses.Count()}");
                    
                    var results = searchResult.Responses;
                    Log($"Procesando {results.Count()} respuestas...");
                    
                    foreach (var response in results)
                    {
                        // Verificar cancelaciÃ³n
                        searchCancellationTokenSource.Token.ThrowIfCancellationRequested();
                        
                        processedResponses++;
                        
                        // Filtrar usuarios en lista negra
                        if (blacklist.Contains(response.Username))
                    {
                        Log($"Usuario bloqueado: {response.Username}");
                        filteredByBlacklist++;
                        continue;
                    }
                    
                    int filesInResponse = response.Files.Count();
                    Log($"Usuario {response.Username}: {filesInResponse} archivos");
                    
                    foreach (var file in response.Files.Take(500))
                    {
                        processedFiles++;
                        
                        // Descartar archivos de tamaÃ±o 0
                        if (file.Size == 0)
                        {
                            filteredBySize++;
                            continue;
                        }
                        
                        // Aplicar filtros de tamaÃ±o
                        if (minSizeBytes > 0 && file.Size < minSizeBytes)
                        {
                            filteredBySize++;
                            continue;
                        }
                        if (maxSizeBytes < long.MaxValue && file.Size > maxSizeBytes)
                        {
                            filteredBySize++;
                            continue;
                        }
                        
                        string fileExt = Path.GetExtension(file.Filename).ToLower();
                        if (!MatchesCategory(fileExt, extFilter))
                        {
                            filteredByExt++;
                            continue;
                        }
                        
                        // Filtro de idioma espaÃ±ol
                        if (chkSpanishOnly.Checked && !IsSpanishText(file.Filename))
                        {
                            filteredBySpanish++;
                            continue;
                        }
                        
                        // Extraer bitrate y duraciÃ³n si estÃ¡n disponibles
                        string icon = GetFileIcon(fileExt);
                        var item = new ListViewItem(new string[] 
                        { 
                            response.Username,
                            icon + " " + Path.GetFileName(file.Filename), 
                            FormatSize(file.Size), 
                            fileExt,
                            Path.GetDirectoryName(file.Filename) ?? ""
                        });
                        item.Tag = new { response.Username, file.Filename, file.Size, UploadSpeed = response.UploadSpeed };
                        item.BackColor = Color.FromArgb(30, 30, 30);
                        item.ForeColor = GetQualityColor(file.Size, fileExt);
                        allResults.Add(item);
                        totalFiles++;
                        
                        // Agregar a la grilla en tiempo real cada 50 archivos
                        if (totalFiles % 50 == 0)
                        {
                            if (InvokeRequired)
                            {
                                Invoke(new Action(() => 
                                {
                                    // Agregar Ãºltimos items a la grilla
                                    var itemsToAdd = allResults.Skip(lvResults.Items.Count).ToArray();
                                    if (itemsToAdd.Length > 0)
                                    {
                                        lvResults.BeginUpdate();
                                        lvResults.Items.AddRange(itemsToAdd);
                                        lvResults.EndUpdate();
                                    }
                                    lblResultsCount.Text = $"{totalFiles} archivos";
                                    lblStatus.Text = $"Buscando... {totalFiles} encontrados";
                                }));
                            }
                            else
                            {
                                var itemsToAdd = allResults.Skip(lvResults.Items.Count).ToArray();
                                if (itemsToAdd.Length > 0)
                                {
                                    lvResults.BeginUpdate();
                                    lvResults.Items.AddRange(itemsToAdd);
                                    lvResults.EndUpdate();
                                }
                                lblResultsCount.Text = $"{totalFiles} archivos";
                                lblStatus.Text = $"Buscando... {totalFiles} encontrados";
                            }
                        }
                    }
                    }  // Cierre del foreach
                }  // Cierre del else
                
                Log($"=== RESUMEN DE BÃšSQUEDA ===");
                Log($"Respuestas procesadas: {processedResponses}");
                Log($"Usuarios bloqueados: {filteredByBlacklist}");
                Log($"Archivos procesados: {processedFiles}");
                Log($"Filtrados por tamaÃ±o: {filteredBySize}");
                Log($"Filtrados por extensiÃ³n: {filteredByExt}");
                Log($"Filtrados por idioma espaÃ±ol: {filteredBySpanish}");
                Log($"Archivos que pasaron filtros: {totalFiles}");
                Log($"Archivos en allResults: {allResults?.Count ?? 0}");
                
                // Actualizar estadÃ­sticas
                if (!searchStats.ContainsKey(cmbSearch.Text))
                    searchStats[cmbSearch.Text] = 0;
                searchStats[cmbSearch.Text]++;
                SaveStats();
                
                // Agregar items restantes que no llegaron al mÃºltiplo de 50
                if (InvokeRequired)
                {
                    Invoke(new Action(() => 
                    {
                        if (lvResults != null && allResults != null)
                        {
                            var itemsToAdd = allResults.Skip(lvResults.Items.Count).ToArray();
                            if (itemsToAdd.Length > 0)
                            {
                                lvResults.BeginUpdate();
                                lvResults.Items.AddRange(itemsToAdd);
                                lvResults.EndUpdate();
                            }
                        }
                        if (lblStatus != null) lblStatus.Text = $"{totalFiles} archivos encontrados";
                        if (lblResultsCount != null) lblResultsCount.Text = $"{totalFiles} resultados";
                    }));
                }
                else
                {
                    if (lvResults != null && allResults != null)
                    {
                        var itemsToAdd = allResults.Skip(lvResults.Items.Count).ToArray();
                        if (itemsToAdd.Length > 0)
                        {
                            lvResults.BeginUpdate();
                            lvResults.Items.AddRange(itemsToAdd);
                            lvResults.EndUpdate();
                        }
                    }
                    if (lblStatus != null) lblStatus.Text = $"{totalFiles} archivos encontrados";
                    if (lblResultsCount != null) lblResultsCount.Text = $"{totalFiles} resultados";
                }
                
                Log($"BÃºsqueda completada: {totalFiles} archivos");
            }
            catch (OperationCanceledException)
            {
                lblStatus.Text = "BÃºsqueda cancelada";
                lblResultsCount.Text = $"{allResults.Count} resultados (cancelado)";
                Log("BÃºsqueda cancelada por el usuario");
            }
            catch (Exception ex) 
            { 
                if (lblStatus != null) lblStatus.Text = $"Error: {ex.Message}";
                Log($"Error en bÃºsqueda: {ex.Message}");
            }
            finally 
            { 
                if (btnSearch != null) btnSearch.Enabled = true;
                if (btnStopSearch != null) btnStopSearch.Enabled = false;
            }
        }
        
        private void StopSearch()
        {
            if (searchCancellationTokenSource != null && !searchCancellationTokenSource.IsCancellationRequested)
            {
                Log("â¹ï¸ BotÃ³n DETENER presionado - Cancelando bÃºsqueda...");
                searchCancellationTokenSource.Cancel();
                if (lblStatus != null) lblStatus.Text = "â¹ï¸ Deteniendo bÃºsqueda...";
                if (btnStopSearch != null) btnStopSearch.Enabled = false;
            }
        }
        
        private async Task DownloadMultipleAsync()
        {
            if (lvResults.SelectedItems.Count == 0 || client == null)
                return;
            
            var itemsToDownload = new List<(ListViewItem downloadItem, dynamic result)>();
            
            foreach (ListViewItem selectedItem in lvResults.SelectedItems)
            {
                try
                {
                    dynamic result = selectedItem.Tag;
                    var fileName = Path.GetFileName((string)result.Filename);
                    
                    System.IO.Directory.CreateDirectory(downloadDir);
                    
                    var downloadItem = new ListViewItem(fileName);
                    downloadItem.SubItems.Add((string)result.Username);
                    downloadItem.SubItems.Add("0%");
                    downloadItem.SubItems.Add("En cola...");
                    downloadItem.SubItems.Add(FormatSize((long)result.Size));
                    lvDownloads.Items.Add(downloadItem);
                    
                    itemsToDownload.Add((downloadItem, result));
                }
                catch { }
            }
            
            tabControl.SelectedIndex = 1;
            
            // Modo Turbo: descargas paralelas
            if (maxParallelDownloads > 1)
            {
                var tasks = new List<Task>();
                var semaphore = new System.Threading.SemaphoreSlim(maxParallelDownloads);
                
                foreach (var (downloadItem, result) in itemsToDownload)
                {
                    await semaphore.WaitAsync();
                    
                    var task = Task.Run(async () =>
                    {
                        try
                        {
                            await DownloadFileAsync(downloadItem, result);
                        }
                        finally
                        {
                            semaphore.Release();
                        }
                    });
                    
                    tasks.Add(task);
                }
                
                await Task.WhenAll(tasks);
            }
            else
            {
                // Modo normal: descargas secuenciales
                foreach (var (downloadItem, result) in itemsToDownload)
                {
                    await DownloadFileAsync(downloadItem, result);
                }
            }
        }
        
        private async Task DownloadFileAsync(ListViewItem downloadItem, dynamic result)
        {
            try
            {
                var fileName = Path.GetFileName((string)result.Filename);
                var localPath = Path.Combine(downloadDir, fileName);
                var cts = new System.Threading.CancellationTokenSource();
                
                activeDownloads[fileName] = cts;
                
                this.Invoke(() =>
                {
                    downloadItem.SubItems[3].Text = "Descargando...";
                });
                
                await client.DownloadAsync(
                    (string)result.Username,
                    (string)result.Filename,
                    () => Task.FromResult<Stream>(new FileStream(localPath, FileMode.Create)),
                    (long)result.Size,
                    cancellationToken: cts.Token,
                    options: new TransferOptions(
                        progressUpdated: (args) =>
                        {
                            var percent = (int)((args.Transfer.BytesTransferred / (double)result.Size) * 100);
                            this.Invoke(() =>
                            {
                                downloadItem.SubItems[2].Text = $"{percent}%";
                                downloadItem.SubItems[3].Text = $"Descargando... {FormatSize(args.Transfer.BytesTransferred)} / {FormatSize((long)result.Size)}";
                            });
                        }
                    )
                );
                
                this.Invoke(() =>
                {
                    downloadItem.SubItems[2].Text = "100%";
                    downloadItem.SubItems[3].Text = "âœ“ Completado";
                    downloadItem.ForeColor = Color.LimeGreen;
                });
                
                activeDownloads.Remove(fileName);
            }
            catch (OperationCanceledException)
            {
                this.Invoke(() =>
                {
                    downloadItem.SubItems[3].Text = "â¸ï¸ Cancelado";
                    downloadItem.ForeColor = Color.Orange;
                });
                activeDownloads.Remove((string)result.Filename);
            }
            catch (Exception ex)
            {
                var fileName = Path.GetFileName((string)result.Filename);
                this.Invoke(() =>
                {
                    downloadItem.SubItems[3].Text = $"âœ— Error: {ex.Message}";
                    downloadItem.ForeColor = Color.Red;
                    Log($"Error en descarga: {fileName} - {ex.Message}");
                });
                activeDownloads.Remove(fileName);
                
                // Agregar a cola de reintentos si estÃ¡ habilitado
                if (maxRetries > 0)
                {
                    var existingRetry = retryQueue.FirstOrDefault(r => Path.GetFileName(((dynamic)r.result).Filename) == fileName);
                    if (existingRetry.result != null)
                    {
                        var retryCount = existingRetry.retryCount + 1;
                        retryQueue.Remove(existingRetry);
                        
                        if (retryCount <= maxRetries)
                        {
                            retryQueue.Add((result, downloadItem, retryCount));
                            this.Invoke(() =>
                            {
                                downloadItem.SubItems[3].Text = $"ðŸ”„ Reintentando ({retryCount}/{maxRetries})...";
                                downloadItem.ForeColor = Color.Orange;
                            });
                            Log($"Reintentando descarga: {fileName} (intento {retryCount}/{maxRetries})");
                            
                            // Reintentar despuÃ©s de 3 segundos
                            await Task.Delay(3000);
                            await DownloadFileAsync(downloadItem, result);
                        }
                        else
                        {
                            this.Invoke(() =>
                            {
                                downloadItem.SubItems[3].Text = $"âœ— Fallo despuÃ©s de {maxRetries} reintentos";
                                downloadItem.ForeColor = Color.DarkRed;
                            });
                            Log($"Descarga fallida definitivamente: {fileName}");
                        }
                    }
                    else
                    {
                        retryQueue.Add((result, downloadItem, 1));
                        this.Invoke(() =>
                        {
                            downloadItem.SubItems[3].Text = "ðŸ”„ Reintentando (1/" + maxRetries + ")...";
                            downloadItem.ForeColor = Color.Orange;
                        });
                        Log($"Reintentando descarga: {fileName} (intento 1/{maxRetries})");
                        
                        await Task.Delay(3000);
                        await DownloadFileAsync(downloadItem, result);
                    }
                }
            }
        }
        
        private async Task DownloadAsync()
        {
            if (lvResults.SelectedItems.Count == 0 || client == null) 
                return;
            
            try
            {
                dynamic result = lvResults.SelectedItems[0].Tag;
                var fileName = Path.GetFileName((string)result.Filename);
                var localPath = Path.Combine(downloadDir, fileName);
                
                System.IO.Directory.CreateDirectory(downloadDir);
                
                // Agregar a lista de descargas
                var downloadItem = new ListViewItem(fileName);
                downloadItem.SubItems.Add((string)result.Username);
                downloadItem.SubItems.Add("0%");
                downloadItem.SubItems.Add("Descargando...");
                downloadItem.SubItems.Add(FormatSize((long)result.Size));
                lvDownloads.Items.Add(downloadItem);
                
                // Cambiar a pestaÃ±a de descargas
                tabControl.SelectedIndex = 1;
                
                lblStatus.Text = $"Descargando: {fileName}...";
                
                await client.DownloadAsync(
                    (string)result.Username, 
                    (string)result.Filename, 
                    () => Task.FromResult<Stream>(new FileStream(localPath, FileMode.Create)), 
                    (long)result.Size,
                    options: new TransferOptions(
                        progressUpdated: (args) =>
                        {
                            var percent = (int)((args.Transfer.BytesTransferred / (double)result.Size) * 100);
                            this.Invoke(() =>
                            {
                                downloadItem.SubItems[2].Text = $"{percent}%";
                                downloadItem.SubItems[3].Text = $"Descargando... {FormatSize(args.Transfer.BytesTransferred)} / {FormatSize((long)result.Size)}";
                            });
                        }
                    )
                );
                
                downloadItem.SubItems[2].Text = "100%";
                downloadItem.SubItems[3].Text = "âœ“ Completado";
                downloadItem.ForeColor = Color.LimeGreen;
                Log($"Descarga completada: {fileName}");
                lblStatus.Text = $"âœ“ Descargado: {fileName}";
                
                // Actualizar estadÃ­sticas
                totalDownloads++;
                SaveStats();
            }
            catch (Exception ex) 
            { 
                lblStatus.Text = $"Error: {ex.Message}"; 
            }
        }
        
        private string FormatSize(long bytes)
        {
            string[] sizes = { "B", "KB", "MB", "GB" };
            double len = bytes;
            int order = 0;
            while (len >= 1024 && order < sizes.Length - 1) 
            { 
                order++; 
                len /= 1024; 
            }
            return $"{len:0.##} {sizes[order]}";
        }
        
        private void LoadConfig()
        {
            try
            {
                // Logging para debug
                Log($"ðŸ” Iniciando LoadConfig()");
                Log($"ðŸ“ Buscando config en: {configPath}");
                Log($"ðŸ“‚ Directorio base: {AppDomain.CurrentDomain.BaseDirectory}");
                
                if (!System.IO.File.Exists(configPath))
                {
                    Log($"âš ï¸ Archivo config.json NO encontrado, creando con valores por defecto...");
                    SaveConfig(); // Crear archivo con valores actuales
                }
                
                if (System.IO.File.Exists(configPath))
                {
                    Log($"âœ… Archivo config.json encontrado");
                    var json = System.IO.File.ReadAllText(configPath);
                    Log($"ðŸ“„ JSON leÃ­do: {json.Substring(0, Math.Min(100, json.Length))}...");
                    var config = JsonSerializer.Deserialize<Dictionary<string, object>>(json);
                    if (config != null && config.ContainsKey("searchHistory"))
                    {
                        var historyElement = (JsonElement)config["searchHistory"];
                        searchHistory = JsonSerializer.Deserialize<List<string>>(historyElement.GetRawText()) ?? new List<string>();
                    }
                    if (config != null && config.ContainsKey("favorites"))
                    {
                        var favElement = (JsonElement)config["favorites"];
                        favorites = JsonSerializer.Deserialize<List<string>>(favElement.GetRawText()) ?? new List<string>();
                        // Solo actualizar el control si ya existe
                        if (cmbFavorites != null)
                        {
                            cmbFavorites.Items.Clear();
                            cmbFavorites.Items.Add("-- Seleccionar --");
                            cmbFavorites.Items.AddRange(favorites.ToArray());
                            cmbFavorites.SelectedIndex = 0;
                        }
                    }
                    if (config != null && config.ContainsKey("downloadDir"))
                    {
                        downloadDir = config["downloadDir"].ToString();
                    }
                    if (config != null && config.ContainsKey("username"))
                    {
                        username = config["username"].ToString();
                    }
                    if (config != null && config.ContainsKey("password"))
                    {
                        password = config["password"].ToString();
                    }
                    if (config != null && config.ContainsKey("autoConnect"))
                    {
                        autoConnect = ((JsonElement)config["autoConnect"]).GetBoolean();
                    }
                    if (config != null && config.ContainsKey("maxParallelDownloads"))
                    {
                        maxParallelDownloads = ((JsonElement)config["maxParallelDownloads"]).GetInt32();
                    }
                    if (config != null && config.ContainsKey("maxParallelSearches"))
                    {
                        maxParallelSearches = ((JsonElement)config["maxParallelSearches"]).GetInt32();
                        Log($"Config cargado - maxParallelSearches: {maxParallelSearches}");
                    }
                    if (config != null && config.ContainsKey("maxRetries"))
                    {
                        maxRetries = ((JsonElement)config["maxRetries"]).GetInt32();
                    }
                    if (config != null && config.ContainsKey("searchTimeout"))
                    {
                        searchTimeout = ((JsonElement)config["searchTimeout"]).GetInt32();
                        Log($"Config cargado - searchTimeout: {searchTimeout}");
                    }
                    if (config != null && config.ContainsKey("responseLimit"))
                    {
                        responseLimit = ((JsonElement)config["responseLimit"]).GetInt32();
                        Log($"Config cargado - responseLimit: {responseLimit}");
                    }
                    if (config != null && config.ContainsKey("fileLimit"))
                    {
                        fileLimit = ((JsonElement)config["fileLimit"]).GetInt32();
                        Log($"Config cargado - fileLimit: {fileLimit}");
                    }
                    if (config != null && config.ContainsKey("listenPort"))
                    {
                        listenPort = ((JsonElement)config["listenPort"]).GetInt32();
                    }
                    if (config != null && config.ContainsKey("enableDistributedNetwork"))
                    {
                        enableDistributedNetwork = ((JsonElement)config["enableDistributedNetwork"]).GetBoolean();
                    }
                }
                
                // Cargar lista negra
                if (System.IO.File.Exists(blacklistPath))
                {
                    var json = System.IO.File.ReadAllText(blacklistPath);
                    blacklist = JsonSerializer.Deserialize<List<string>>(json) ?? new List<string>();
                }
                
                // Cargar autores
                if (System.IO.File.Exists(authorsPath))
                {
                    authors = System.IO.File.ReadAllLines(authorsPath).ToList();
                }
                
                // Cargar watchlist
                if (System.IO.File.Exists(watchlistPath))
                {
                    watchlist = System.IO.File.ReadAllLines(watchlistPath).ToList();
                }
                
                // Cargar cachÃ© de paÃ­ses
                if (System.IO.File.Exists(countryCachePath))
                {
                    var json = System.IO.File.ReadAllText(countryCachePath);
                    countryCache = JsonSerializer.Deserialize<Dictionary<string, string>>(json) ?? new Dictionary<string, string>();
                }
            }
            catch (Exception ex)
            {
                Log($"âŒ ERROR en LoadConfig: {ex.Message}");
                Log($"Stack: {ex.StackTrace}");
            }
            
            Log($"âœ… LoadConfig completado. responseLimit={responseLimit}, fileLimit={fileLimit}");
        }
        
        private void SaveConfig()
        {
            try
            {
                var config = new Dictionary<string, object>
                {
                    ["searchHistory"] = searchHistory,
                    ["favorites"] = favorites,
                    ["downloadDir"] = downloadDir,
                    ["username"] = username,
                    ["password"] = password,
                    ["autoConnect"] = autoConnect,
                    ["maxParallelDownloads"] = maxParallelDownloads,
                    ["maxParallelSearches"] = maxParallelSearches,
                    ["maxRetries"] = maxRetries,
                    ["searchTimeout"] = searchTimeout,
                    ["responseLimit"] = responseLimit,
                    ["fileLimit"] = fileLimit,
                    ["listenPort"] = listenPort,
                    ["enableDistributedNetwork"] = enableDistributedNetwork
                };
                var json = JsonSerializer.Serialize(config, new JsonSerializerOptions { WriteIndented = true });
                System.IO.File.WriteAllText(configPath, json);
            }
            catch { }
        }
        
