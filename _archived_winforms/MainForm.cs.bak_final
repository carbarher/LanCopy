                            tabControl.SelectedIndex = 0;
                        }));
                    }
                    else
                    {
                        cmbSearch.Text = authorName;
                        tabControl.SelectedIndex = 0;
                    }
                    
                    // Esperar a que se cambie de pestaÃ±a
                    await Task.Delay(200);
                    
                    // Iniciar bÃºsqueda
                    await SearchAsync();
                }
                else
                {
                    MessageBox.Show("Selecciona un autor de la lista primero", "SlskDown", MessageBoxButtons.OK, MessageBoxIcon.Information);
                }
