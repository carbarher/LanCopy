        private void CreateDownloadsTab(TabPage parent)
        {
            parent.BackColor = Color.FromArgb(18, 18, 18);
            var panel = new Panel { Dock = DockStyle.Fill, Padding = new Padding(20), BackColor = Color.FromArgb(18, 18, 18) };
            
            lvDownloads = new ListView 
            { 
                Dock = DockStyle.Fill, 
                View = View.Details, 
                FullRowSelect = true, 
                GridLines = true,
                OwnerDraw = true,
                BackColor = Color.Black, 
                ForeColor = Color.White 
            };
            lvDownloads.DrawColumnHeader += LvResults_DrawColumnHeader;
            lvDownloads.DrawItem += LvResults_DrawItem;
            lvDownloads.DrawSubItem += LvResults_DrawSubItem;
            lvDownloads.Columns.Add("Archivo", 300);
            lvDownloads.Columns.Add("Usuario", 120);
            lvDownloads.Columns.Add("Progreso", 100);
            lvDownloads.Columns.Add("Estado", 100);
            lvDownloads.Columns.Add("TamaÃ±o", 80);
            lvDownloads.DoubleClick += (s, e) => OpenDownloadedFile();
            
            // MenÃº contextual para descargas
            var downloadContextMenu = new ContextMenuStrip();
            downloadContextMenu.BackColor = Color.FromArgb(45, 45, 45);
            downloadContextMenu.ForeColor = Color.White;
            
            var cancelItem = new ToolStripMenuItem("âŒ Cancelar descarga");
            cancelItem.Click += (s, e) => CancelDownload();
            downloadContextMenu.Items.Add(cancelItem);
            
            var retryItem = new ToolStripMenuItem("ðŸ”„ Reintentar descarga");
            retryItem.Click += async (s, e) => await RetryDownload();
            downloadContextMenu.Items.Add(retryItem);
            
            downloadContextMenu.Items.Add(new ToolStripSeparator());
            
            var openFileItem = new ToolStripMenuItem("ðŸ“„ Abrir archivo");
            openFileItem.Click += (s, e) => OpenDownloadedFile();
            downloadContextMenu.Items.Add(openFileItem);
            
            var openFolderItem = new ToolStripMenuItem("ðŸ“ Abrir carpeta");
            openFolderItem.Click += (s, e) => Process.Start("explorer.exe", downloadDir);
            downloadContextMenu.Items.Add(openFolderItem);
            
            lvDownloads.ContextMenuStrip = downloadContextMenu;
            
            panel.Controls.Add(lvDownloads);
            parent.Controls.Add(panel);
        }
        
        private void CreateConfigTab(TabPage parent)
        {
            parent.BackColor = Color.FromArgb(18, 18, 18);
            var panel = new Panel { Dock = DockStyle.Fill, Padding = new Padding(20), BackColor = Color.FromArgb(18, 18, 18) };
            
            var lblTitle = new Label { Text = "âš™ï¸ ConfiguraciÃ³n", Location = new Point(20, 20), Size = new Size(400, 35), ForeColor = Color.White, Font = new Font("Segoe UI", 16, FontStyle.Bold) };
            panel.Controls.Add(lblTitle);
            
            // === COLUMNA IZQUIERDA: CUENTA ===
            var lblAccountSection = new Label { Text = "CUENTA", Location = new Point(20, 70), Size = new Size(300, 20), ForeColor = Color.FromArgb(0, 120, 215), Font = new Font("Segoe UI", 10, FontStyle.Bold) };
            panel.Controls.Add(lblAccountSection);
            
            // Usuario
            var lblUser = new Label { Text = "Usuario Soulseek:", Location = new Point(20, 100), Size = new Size(150, 20), ForeColor = Color.LightGray };
            panel.Controls.Add(lblUser);
            
            txtUsername = new TextBox { Location = new Point(180, 97), Size = new Size(250, 25), BackColor = Color.FromArgb(60, 60, 60), ForeColor = Color.White, Text = username };
            txtUsername.TextChanged += (s, e) => { username = txtUsername.Text; SaveConfig(); };
            panel.Controls.Add(txtUsername);
            
            // ContraseÃ±a
            var lblPass = new Label { Text = "ContraseÃ±a:", Location = new Point(20, 135), Size = new Size(150, 20), ForeColor = Color.LightGray };
            panel.Controls.Add(lblPass);
            
            txtPassword = new TextBox { Location = new Point(180, 132), Size = new Size(250, 25), BackColor = Color.FromArgb(60, 60, 60), ForeColor = Color.White, Text = password };
            txtPassword.TextChanged += (s, e) => { password = txtPassword.Text; SaveConfig(); };
            panel.Controls.Add(txtPassword);
            
            // Carpeta de descargas
            var lblDir = new Label { Text = "Carpeta descargas:", Location = new Point(20, 170), Size = new Size(150, 20), ForeColor = Color.LightGray };
            panel.Controls.Add(lblDir);
            
            txtDownloadDir = new TextBox { Location = new Point(180, 167), Size = new Size(250, 25), BackColor = Color.FromArgb(60, 60, 60), ForeColor = Color.White, Text = downloadDir };
