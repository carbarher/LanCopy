        // ===== DETECCIÃ“N DE IDIOMA ESPAÃ‘OL =====
        
        private bool IsSpanishText(string text)
        {
            if (string.IsNullOrWhiteSpace(text))
                return false;
            
            text = text.ToLower();
            
            // Palabras comunes en inglÃ©s que NO son espaÃ±ol
            string[] englishWords = { " the ", " and ", " for ", " with ", " from ", " this ", " that ", " have ", " been ", " were ", " what ", " when ", " where ", " which ", " their ", " there ", " would ", " could ", " should ", " about ", " after ", " before ", " through ", " between " };
            foreach (var word in englishWords)
            {
                if (text.Contains(word))
                    return false;
            }
            
            // Palabras comunes en francÃ©s
            string[] frenchWords = { " le ", " la ", " les ", " une ", " des ", " dans ", " pour ", " avec ", " sur ", " par ", " est ", " sont ", " ont ", " vous ", " nous ", " leur ", " leurs ", " cette ", " ces ", " tout ", " tous ", " toute ", " toutes " };
            foreach (var word in frenchWords)
            {
                if (text.Contains(word))
                    return false;
            }
            
            // Palabras comunes en italiano
            string[] italianWords = { " il ", " lo ", " gli ", " della ", " delle ", " degli ", " nella ", " nelle ", " alla ", " alle ", " dal ", " dai ", " sul ", " sui ", " per ", " con ", " sono ", " hanno ", " questo ", " questa ", " questi ", " queste " };
            foreach (var word in italianWords)
            {
                if (text.Contains(word))
                    return false;
            }
            
            // Palabras comunes en alemÃ¡n
            string[] germanWords = { " der ", " die ", " das ", " den ", " dem ", " des ", " ein ", " eine ", " einen ", " einem ", " und ", " oder ", " aber ", " mit ", " von ", " zu ", " auf ", " fÃ¼r ", " durch ", " Ã¼ber ", " unter ", " zwischen " };
            foreach (var word in germanWords)
            {
                if (text.Contains(word))
                    return false;
            }
            
            // Palabras comunes en espaÃ±ol (indicadores positivos)
            string[] spanishWords = { " el ", " la ", " los ", " las ", " un ", " una ", " de ", " del ", " en ", " por ", " para ", " con ", " sin ", " sobre ", " entre ", " desde ", " hasta ", " como ", " cuando ", " donde ", " que ", " cual ", " quien ", " este ", " esta ", " estos ", " estas ", " ese ", " esa ", " esos ", " esas " };
            int spanishCount = 0;
            foreach (var word in spanishWords)
            {
                if (text.Contains(word))
                    spanishCount++;
            }
            
            // Caracteres especiales del espaÃ±ol
            bool hasSpanishChars = text.Contains("Ã±") || text.Contains("Ã¡") || text.Contains("Ã©") || text.Contains("Ã­") || text.Contains("Ã³") || text.Contains("Ãº") || text.Contains("Ã¼");
            
            // Si tiene caracteres espaÃ±oles o al menos 2 palabras espaÃ±olas, es espaÃ±ol
            return hasSpanishChars || spanishCount >= 2;
        }
    }
}




