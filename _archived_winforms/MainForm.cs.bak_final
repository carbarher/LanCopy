        public MainForm()
        {
            try
            {
                // Crear carpeta de datos persistente
                System.IO.Directory.CreateDirectory(dataDir);
                Log($"ðŸ“‚ Carpeta de datos: {dataDir}");
                Text = "SlskDown - Cliente Soulseek";
                Size = new Size(1100, 700);
                BackColor = Color.FromArgb(18, 18, 18);
                StartPosition = FormStartPosition.CenterScreen;
                
                LoadConfig();
            
            // Aplicar tema oscuro a todos los controles
            ApplyDarkTheme();
            
            tabControl = new TabControl
            {
                Dock = DockStyle.Fill,
                BackColor = Color.FromArgb(25, 25, 25),
                ForeColor = Color.White,
                DrawMode = TabDrawMode.OwnerDrawFixed
            };
            tabControl.DrawItem += TabControl_DrawItem;
            
            var searchTab = new TabPage("ðŸ” BÃºsqueda");
            CreateSearchTab(searchTab);
            
            var downloadsTab = new TabPage("â¬‡ï¸ Descargas");
            CreateDownloadsTab(downloadsTab);
            
            var configTab = new TabPage("âš™ï¸ ConfiguraciÃ³n");
            CreateConfigTab(configTab);
            
            var blacklistTab = new TabPage("ðŸš« Lista Negra");
            CreateBlacklistTab(blacklistTab);
            
            var authorsTab = new TabPage("ðŸ‘¤ Autores");
            CreateAuthorsTab(authorsTab);
            
            var watchlistTab = new TabPage("ðŸ‘ï¸ Watchlist");
            CreateWatchlistTab(watchlistTab);
            
            var autoTab = new TabPage("ðŸ¤– AutomÃ¡tico");
            CreateAutoTab(autoTab);
            
            var logTab = new TabPage("ðŸ“‹ Log");
            CreateLogTab(logTab);
            
            tabControl.TabPages.Add(searchTab);
            tabControl.TabPages.Add(downloadsTab);
            tabControl.TabPages.Add(blacklistTab);
            tabControl.TabPages.Add(authorsTab);
            tabControl.TabPages.Add(watchlistTab);
            tabControl.TabPages.Add(autoTab);
            tabControl.TabPages.Add(logTab);
            tabControl.TabPages.Add(configTab);
            
            // Iniciar watchlist timer
            watchlistTimer = new System.Windows.Forms.Timer();
            watchlistTimer.Interval = 300000; // 5 minutos
            watchlistTimer.Tick += async (s, e) => await CheckWatchlist();
            watchlistTimer.Start();
            
            // Iniciar timer de reconexiÃ³n automÃ¡tica
            reconnectTimer = new System.Windows.Forms.Timer();
            reconnectTimer.Interval = 10000; // 10 segundos (mÃ¡s agresivo)
            reconnectTimer.Tick += async (s, e) => await CheckAndReconnect();
            reconnectTimer.Start();
            
            // Auto-conectar si estÃ¡ habilitado
            if (autoConnect)
            {
                Log("Auto-conexiÃ³n habilitada, iniciando en 2 segundos...");
                Task.Run(async () => 
                {
                    await Task.Delay(2000); // Esperar a que la UI estÃ© lista
                    Log("Ejecutando auto-conexiÃ³n...");
                    try
                    {
                        await ConnectToSoulseek();
                    }
                    catch (Exception ex)
                    {
                        Log($"Error en auto-conexiÃ³n: {ex.Message}");
                    }
                });
            }
            
            Controls.Add(tabControl);
            
            // Cargar datos despuÃ©s de crear la UI
            LoadFavorites();
            LoadSearchHistory();
            LoadBlacklist();
            LoadAuthors();
            LoadStats();
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error crÃ­tico al inicializar la aplicaciÃ³n:\n\n{ex.Message}\n\nStack Trace:\n{ex.StackTrace}", 
                    "Error de UI", MessageBoxButtons.OK, MessageBoxIcon.Error);
                Application.Exit();
            }
        }
        
