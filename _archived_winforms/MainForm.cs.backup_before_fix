        private async Task GenerateRecommendationsAsync()
        {
            try
            {
                Log("🔮 Generando recomendaciones...");
                lvRecommendations.Items.Clear();
                recommendations.Clear();
                
                await Task.Run(() =>
                {
                    // 1. Recomendaciones basadas en autores descargados
                    var downloadedAuthors = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
                    lock (downloadQueueLock)
                    {
                        foreach (var task in downloadQueue.Where(d => d.Status == DownloadStatus.Completed))
                        {
                            var author = ExtractAuthorFromFilename(task.File.FileName);
                            if (!string.IsNullOrEmpty(author))
                            {
                                if (!downloadedAuthors.ContainsKey(author))
                                    downloadedAuthors[author] = 0;
                                downloadedAuthors[author]++;
                            }
                        }
                    }
                    
                    // Top 5 autores más descargados
                    var topAuthors = downloadedAuthors.OrderByDescending(x => x.Value).Take(5);
                    foreach (var author in topAuthors)
                    {
                        var score = Math.Min(100, author.Value * 10);
                        lock (recommendationsLock)
                        {
                            recommendations.Add(new RecommendationItem
                            {
                                ItemName = author.Key,
                                Type = "🧑 Autor",
                                Score = score,
                                Reason = "Más descargado",
                                Details = $"{author.Value} archivos descargados"
                            });
                        }
                    }
                    
                    // 2. Recomendaciones basadas en búsquedas recientes
                    if (searchHistory != null && searchHistory.Count > 0)
                    {
                        var recentSearches = searchHistory
                            .Take(5)
                            .Select((search, index) => new { Query = search, Score = 100 - (index * 15) });
                        
                        foreach (var search in recentSearches)
                        {
                            lock (recommendationsLock)
                            {
                                recommendations.Add(new RecommendationItem
                                {
                                    ItemName = search.Query,
                                    Type = "🔍 Búsqueda",
                                    Score = search.Score,
                                    Reason = "Búsqueda reciente",
                                    Details = "Basado en tu historial"
                                });
                            }
                        }
                    }
                    
                    // 3. Recomendaciones basadas en autores de watchlist
                    if (watchlist != null && watchlist.Count > 0)
                    {
                        foreach (var item in watchlist.Take(5))
                        {
                            lock (recommendationsLock)
                            {
                                recommendations.Add(new RecommendationItem
                                {
                                    ItemName = item,
                                    Type = "⭐ Watchlist",
                                    Score = 85,
                                    Reason = "En tu watchlist",
                                    Details = "Autor favorito"
                                });
                            }
                        }
                    }
                    
                    // 4. Recomendaciones basadas en similitud (autores relacionados)
                    foreach (var author in topAuthors.Take(3))
                    {
                        var relatedAuthors = FindRelatedAuthors(author.Key);
                        foreach (var related in relatedAuthors.Take(2))
                        {
                            lock (recommendationsLock)
                            {
                                if (!recommendations.Any(r => r.ItemName.Equals(related, StringComparison.OrdinalIgnoreCase)))
                                {
                                    recommendations.Add(new RecommendationItem
                                    {
                                        ItemName = related,
                                        Type = "🔗 Relacionado",
                                        Score = 70,
                                        Reason = "Similar a tus gustos",
                                        Details = $"Relacionado con {author.Key}"
                                    });
                                }
                            }
                        }
                    }
                });
                
                // Ordenar por score y actualizar UI
                var sortedRecommendations = recommendations.OrderByDescending(r => r.Score).ToList();
                
                lvRecommendations.BeginUpdate();
                foreach (var rec in sortedRecommendations)
                {
                    var item = new ListViewItem(rec.ItemName);
                    item.SubItems.Add(rec.Type);
                    item.SubItems.Add($"{rec.Score:F0}%");
                    item.SubItems.Add(rec.Reason);
                    item.SubItems.Add(rec.Details);
                    item.Tag = rec;
                    
                    // Color según score
                    if (rec.Score >= 80)
                        item.ForeColor = Color.FromArgb(100, 255, 100); // Verde brillante
                    else if (rec.Score >= 60)
                        item.ForeColor = Color.FromArgb(100, 200, 255); // Azul claro
                    else
                        item.ForeColor = Color.LightGray;
                    
                    lvRecommendations.Items.Add(item);
                }
                lvRecommendations.EndUpdate();
                
                Log($"✅ {sortedRecommendations.Count} recomendaciones generadas");
                MessageBox.Show($"Se generaron {sortedRecommendations.Count} recomendaciones basadas en tu actividad", 
                    "Recomendaciones", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                Log($"❌ Error generando recomendaciones: {ex.Message}");
                MessageBox.Show($"Error: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
        private string ExtractAuthorFromFilename(string filename)
        {
            try
            {
                // Intentar extraer autor de patrones comunes
                // "Autor - Título.epub" o "Autor_Título.epub"
                var name = Path.GetFileNameWithoutExtension(filename);
                
                // Patrones comunes
                var patterns = new[] { " - ", "_-_", " _ " };
                foreach (var pattern in patterns)
                {
                    if (name.Contains(pattern))
                    {
                        var parts = name.Split(new[] { pattern }, StringSplitOptions.None);
                        if (parts.Length >= 2)
                        {
                            var author = parts[0].Trim();
                            if (author.Length > 2 && author.Length < 50)
                                return author;
                        }
                    }
                }
                
                // Si no hay patrón, usar primeras palabras (hasta 3)
                var words = name.Split(new[] { ' ', '_' }, StringSplitOptions.RemoveEmptyEntries);
                if (words.Length >= 2)
                {
                    return string.Join(" ", words.Take(Math.Min(3, words.Length)));
                }
            }
            catch { }
            
            return null;
        }
        
        private List<string> FindRelatedAuthors(string author)
        {
            var related = new List<string>();
            
            try
            {
                // Buscar autores con nombres similares o en el mismo "género"
                lock (downloadQueueLock)
                {
                    var allAuthors = downloadQueue
                        .Where(d => d.Status == DownloadStatus.Completed)
                        .Select(d => ExtractAuthorFromFilename(d.File.FileName))
                        .Where(a => !string.IsNullOrEmpty(a) && !a.Equals(author, StringComparison.OrdinalIgnoreCase))
                        .Distinct(StringComparer.OrdinalIgnoreCase)
                        .ToList();
                    
                    // Buscar autores que compartan palabras con el autor base
                    var authorWords = author.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries)
                        .Select(w => w.ToLower()).ToHashSet();
                    
                    foreach (var otherAuthor in allAuthors)
                    {
                        var otherWords = otherAuthor.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries)
                            .Select(w => w.ToLower()).ToHashSet();
                        
                        var commonWords = authorWords.Intersect(otherWords).Count();
                        if (commonWords > 0)
                        {
                            related.Add(otherAuthor);
                        }
                    }
                }
            }
            catch { }
            
            return related;
        }
        
