        private (List<SearchResultItem> FilteredItems, SearchFilterStatistics Stats) FilterSearchItemsWithRust(
            List<SearchResultItem> candidates,
            long minSizeBytes,
            long maxSizeBytes,
            string extFilter,
            bool spanishOnly)
        {
            var stats = new SearchFilterStatistics();

            if (candidates == null || candidates.Count == 0)
            {
                stats.TotalCandidates = 0;
                return (new List<SearchResultItem>(), stats);
            }

            stats.TotalCandidates = candidates.Count;

            var fallbackFiltered = new List<SearchResultItem>(candidates.Count);
            foreach (var item in candidates)
            {
                if (minSizeBytes > 0 && item.Size < minSizeBytes)
                {
                    stats.FilteredBySize++;
                    continue;
                }

                if (maxSizeBytes < long.MaxValue && item.Size > maxSizeBytes)
                {
                    stats.FilteredBySize++;
                    continue;
                }

                if (!MatchesCategory(item.Extension, extFilter))
                {
                    stats.FilteredByExtension++;
                    continue;
                }

                if (spanishOnly && !IsSpanishText(item.Filename))
                {
                    stats.FilteredBySpanish++;
                    continue;
                }

                fallbackFiltered.Add(item);
            }

            List<SearchResultItem> filtered = fallbackFiltered;

            if (RustAdvancedCore.IsAvailable())
            {
                try
                {
                    var extensionFilters = ResolveExtensionsFromFilter(extFilter);
                    var rustFiltered = RustAdvancedCore.FilterResultsParallel(
                        candidates,
                        minSizeBytes,
                        maxSizeBytes,
                        extensionFilters,
                        spanishOnly,
                        0);

                    if (rustFiltered != null && rustFiltered.Count == fallbackFiltered.Count)
                    {
                        filtered = rustFiltered;
                    }
                    else
                    {
                        if (rustFiltered != null && rustFiltered.Count != fallbackFiltered.Count)
                        {
                            Log($"⚠️ Inconsistencia filtrando con Rust (esperado {fallbackFiltered.Count:N0}, obtenido {rustFiltered.Count:N0}). Usando fallback.");
                        }
                    }
                }
                catch (Exception ex)
                {
                    Log($"⚠️ Error filtrando con Rust: {ex.Message}");
                }
            }

            return (filtered, stats);
        }

        private static List<string> ResolveExtensionsFromFilter(string extFilter)
        {
            if (string.IsNullOrWhiteSpace(extFilter))
            {
                return new List<string>();
            }

            extFilter = extFilter.Trim();
            if (extFilter.Equals("Todos", StringComparison.OrdinalIgnoreCase))
            {
                return new List<string>();
            }

            var categoryMap = new Dictionary<string, List<string>>(StringComparer.OrdinalIgnoreCase)
            {
                ["Libros/Docs"] = new List<string> { ".pdf", ".epub", ".mobi", ".azw3", ".djvu", ".doc", ".docx", ".txt" },
                ["Documentos"] = new List<string> { ".pdf", ".epub", ".mobi", ".azw3", ".djvu", ".doc", ".docx", ".txt" },
                ["Comics"] = new List<string> { ".cbr", ".cbz", ".cb7", ".cbt" },
                ["Videos"] = new List<string> { ".mp4", ".mkv", ".avi", ".mov", ".wmv", ".flv", ".webm" },
                ["Musica"] = new List<string> { ".mp3", ".flac", ".wav", ".m4a", ".ogg", ".wma", ".aac" },
                ["Música"] = new List<string> { ".mp3", ".flac", ".wav", ".m4a", ".ogg", ".wma", ".aac" },
                ["Audio"] = new List<string> { ".mp3", ".flac", ".wav", ".m4a", ".ogg", ".wma", ".aac" },
                ["Comprimidos"] = new List<string> { ".zip", ".rar", ".7z", ".tar", ".gz", ".bz2" }
            };

            if (categoryMap.TryGetValue(extFilter, out var extensions))
            {
                return extensions;
            }

            if (!extFilter.StartsWith("."))
            {
                extFilter = "." + extFilter;
            }

            return new List<string> { extFilter.ToLowerInvariant() };
        }

