        private void ClearCompletedDownloads()
        {
            try
            {
                var completedTasks = downloadQueueService.Update(list =>
                {
                    var tasksToRemove = list
                        .Where(t => t.Status == DownloadStatus.Completed || t.Status == DownloadStatus.Cancelled)
                        .ToList();

                    foreach (var task in tasksToRemove)
                    {
                        list.Remove(task);
                    }

                    return tasksToRemove;
                });

                var removedCount = completedTasks.Count;

                if (removedCount > 0)
                {
                    SafeLog($"🧹 Limpiadas {removedCount} descargas completadas/canceladas");
                    UpdateProgressDisplay();
                    MarkDownloadStatsDirty();
                    ScheduleQueuePrioritization();
                    MarkDownloadsDirty();
                }
                else
                {
                    MessageBox.Show("No hay descargas completadas para limpiar", "Info", MessageBoxButtons.OK, MessageBoxIcon.Information);
                }
            }
            catch (Exception ex)
            {
                SafeLog($" Error limpiando descargas: {ex.Message}");
            }
        }
        
        private void DeleteCompletedFilesFromDisk()
        {
            try
            {
                var completedTasks = downloadQueueService.WithQueueLock(list =>
                    list.Where(t => t.Status == DownloadStatus.Completed && !string.IsNullOrWhiteSpace(t.LocalPath))
                        .ToList());

                if (completedTasks.Count == 0)
                {
                    MessageBox.Show("No hay archivos descargados para eliminar", "Info", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    return;
                }

                var confirmation = MessageBox.Show(
                    "Se eliminarán los archivos de disco para las descargas completadas.\n\nEsta acción no se puede deshacer. ¿Continuar?",
                    "Eliminar archivos descargados",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Warning);

                if (confirmation != DialogResult.Yes)
                {
                    return;
                }

                int deletedCount = 0;
                int missingCount = 0;
                int errorCount = 0;

                foreach (var task in completedTasks)
                {
                    try
                    {
                        if (string.IsNullOrWhiteSpace(task.LocalPath))
                        {
                            missingCount++;
                            continue;
                        }

                        if (!File.Exists(task.LocalPath))
                        {
                            missingCount++;
                            continue;
                        }

                        File.Delete(task.LocalPath);
                        deletedCount++;

                        try
                        {
                            task.UiStatusText = "🗑️ Eliminado";
                        }
                        catch
                        {
                        }
                        MarkDownloadsDirty();
                    }
                    catch (Exception ex)
                    {
                        errorCount++;
                        SafeLog($" Error eliminando archivo {task.LocalPath}: {ex.Message}");
                    }
                }

                var summary = $"Eliminados: {deletedCount}\nNo encontrados: {missingCount}\nErrores: {errorCount}";
                MessageBox.Show(summary, "Resultado de eliminación", MessageBoxButtons.OK, MessageBoxIcon.Information);

                if (deletedCount > 0)
                {
                    SafeLog($"🗑️ Eliminados {deletedCount} archivos descargados");
                    MarkDownloadStatsDirty();
                    ScheduleQueuePrioritization();
                }
            }
            catch (Exception ex)
            {
                SafeLog($" Error eliminando archivos descargados: {ex.Message}");
                MessageBox.Show($"Error eliminando archivos:\n{ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
