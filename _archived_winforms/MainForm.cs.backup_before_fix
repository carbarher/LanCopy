        private static MainForm? ResolveMainForm(IWin32Window? owner)
        {
            try
            {
                if (owner is MainForm main)
                {
                    return main;
                }

                if (Form.ActiveForm is MainForm active)
                {
                    return active;
                }

                foreach (Form f in Application.OpenForms)
                {
                    if (f is MainForm mf)
                    {
                        return mf;
                    }
                }

                return null;
            }
            catch
            {
                return null;
            }
        }

