        private async Task CleanupNonSpanishDownloadsAsync()
        {
            if (cleanupDownloadsRunning)
            {
                MessageBox.Show("Ya hay una limpieza en curso.", "Limpieza de descargas", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            if (string.IsNullOrWhiteSpace(downloadDir) || !Directory.Exists(downloadDir))
            {
                MessageBox.Show($"La carpeta de descargas no existe:\n{downloadDir}", "Carpeta no encontrada", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            cleanupDownloadsRunning = true;
            UseWaitCursor = true;
            Cursor.Current = Cursors.WaitCursor;

            try
            {
                AutoLog("🔍 Analizando carpeta de descargas para localizar documentos no españoles...");

                var analysisResult = await Task.Run(() =>
                {
                    var allFiles = Directory.GetFiles(downloadDir, "*.*", SearchOption.AllDirectories);
                    var nonSpanish = new List<string>();
                    var errors = new List<string>();
                    int documentCount = 0;

                    foreach (var file in allFiles)
                    {
                        var fileName = Path.GetFileName(file);
                        if (!IsDocumentFile(fileName))
                            continue;

                        documentCount++;

                        try
                        {
                            if (!IsSpanishFileByContent(file, useCache: false))
                            {
                                nonSpanish.Add(file);
                            }
                        }
                        catch (Exception ex)
                        {
                            errors.Add($"{file}: {ex.Message}");
                        }
                    }

                    return (TotalFiles: allFiles.Length, DocumentFiles: documentCount, NonSpanish: nonSpanish, Errors: errors);
                });

                AutoLog($"📊 Analizados {analysisResult.DocumentFiles} documentos (de {analysisResult.TotalFiles} archivos totales). No españoles: {analysisResult.NonSpanish.Count}");

                if (analysisResult.Errors.Count > 0)
                {
                    AutoLog($"⚠️ {analysisResult.Errors.Count} archivos no se pudieron analizar. Guarda el log para revisarlos.");
                }

                if (analysisResult.NonSpanish.Count == 0)
                {
                    MessageBox.Show("No se encontraron documentos no españoles en la carpeta de descargas.", "Limpieza de descargas", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    AutoLog("✅ Limpieza completada: no se encontraron archivos a eliminar.");
                    return;
                }

                using (var preview = new QuarantinePreviewForm(analysisResult.NonSpanish, downloadDir))
                {
                    var previewResult = preview.ShowDialog(this);
                    if (previewResult != DialogResult.OK)
                    {
                        AutoLog("⚠️ Eliminación cancelada tras vista previa.");
                        return;
                    }

                    var filesToDelete = preview.SelectedPaths;
                    if (filesToDelete.Count == 0)
                    {
                        AutoLog("⚠️ Eliminación cancelada: no hay archivos seleccionados.");
                        return;
                    }

                    var deletionResult = await Task.Run(() =>
                    {
                        int deleted = 0;
                        int failed = 0;
                        var failures = new List<string>();

                        foreach (var file in filesToDelete)
                        {
                            try
                            {
                                if (File.Exists(file))
                                {
                                    File.Delete(file);
                                    deleted++;
                                    AppendQuarantineLog("deleted", Path.GetFileName(file), file, string.Empty, RustCore.IsAvailable() ? "rust" : "fallback");
                                }
                            }
                            catch (Exception ex)
                            {
                                failed++;
                                failures.Add($"{file}: {ex.Message}");
                            }
                        }

                        return (Deleted: deleted, Failed: failed, Failures: failures);
                    });

                    AutoLog($"🧽 Limpieza terminada. Eliminados: {deletionResult.Deleted}, Fallidos: {deletionResult.Failed}");

                    if (deletionResult.Failures.Count > 0)
                    {
                        AutoLog("⚠️ Algunos archivos no se pudieron eliminar. Revisa los detalles en el log.");
                    }

                    var resultMessage = new StringBuilder()
                        .AppendLine($"Archivos eliminados: {deletionResult.Deleted}")
                        .AppendLine($"Fallidos: {deletionResult.Failed}");

                    if (analysisResult.Errors.Count > 0)
                    {
                        resultMessage.AppendLine($"\nArchivos sin analizar: {analysisResult.Errors.Count} (ver log)");
                    }

                    if (deletionResult.Failures.Count > 0)
                    {
                        resultMessage.AppendLine("\nAlgunos archivos no se pudieron eliminar. Consulta el log para más detalles.");
                    }

                    MessageBox.Show(resultMessage.ToString(), "Limpieza de descargas", MessageBoxButtons.OK, MessageBoxIcon.Information);
                }
            }
            finally
            {
                cleanupDownloadsRunning = false;
                UseWaitCursor = false;
                Cursor.Current = Cursors.Default;
            }
        }

        private async Task ReevaluateQuarantineAsync()
        {
            if (reanalyzeQuarantineRunning)
            {
                MessageBox.Show("Ya hay una reevaluación en curso.", "Cuarentena", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            if (string.IsNullOrWhiteSpace(downloadDir) || !Directory.Exists(downloadDir))
            {
                MessageBox.Show($"La carpeta de descargas no existe:\n{downloadDir}", "Carpeta no encontrada", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            string quarantineDir = Path.Combine(downloadDir, "_NoEspanol");
            if (!Directory.Exists(quarantineDir))
            {
                MessageBox.Show("No existe la carpeta de cuarentena (_NoEspanol).", "Cuarentena", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            var quarantineFiles = Directory.GetFiles(quarantineDir, "*.*", SearchOption.AllDirectories)
                .Where(f => IsDocumentFile(Path.GetFileName(f)))
                .ToArray();

            if (quarantineFiles.Length == 0)
            {
                MessageBox.Show("No hay documentos en cuarentena para reevaluar.", "Cuarentena", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            var confirm = MessageBox.Show(
                $"Se reevaluarán {quarantineFiles.Length} archivos de la carpeta _NoEspanol.\n\n" +
                "Los que se detecten como español volverán a la carpeta de descargas.\n\n¿Deseas continuar?",
                "Reevaluar cuarentena",
                MessageBoxButtons.YesNo,
                MessageBoxIcon.Question,
                MessageBoxDefaultButton.Button2);

            if (confirm != DialogResult.Yes)
            {
                AutoLog("⚠️ Reevaluación cancelada por el usuario.");
                return;
            }

            reanalyzeQuarantineRunning = true;
            UseWaitCursor = true;
            Cursor.Current = Cursors.WaitCursor;

            try
            {
                AutoLog("♻️ Iniciando reevaluación de cuarentena...");

                var result = await Task.Run(() =>
                {
                    int restored = 0;
                    int kept = 0;
                    int errors = 0;
                    var errorList = new List<string>();

                    foreach (var file in quarantineFiles)
                    {
                        try
                        {
                            if (IsSpanishFileByContent(file, useCache: false))
                            {
                                string targetPath = Path.Combine(downloadDir, Path.GetFileName(file));
                                int counter = 1;
                                while (File.Exists(targetPath))
                                {
                                    var name = Path.GetFileNameWithoutExtension(file);
                                    var ext = Path.GetExtension(file);
                                    targetPath = Path.Combine(downloadDir, $"{name}_{counter}{ext}");
                                    counter++;
                                }

                                Directory.CreateDirectory(Path.GetDirectoryName(targetPath) ?? downloadDir);
                                File.Move(file, targetPath);
                                restored++;
                            }
                            else
                            {
                                kept++;
                            }
                        }
                        catch (Exception ex)
                        {
                            errors++;
                            errorList.Add($"{Path.GetFileName(file)}: {ex.Message}");
                        }
                    }

                    return (Restored: restored, Kept: kept, Errors: errors, ErrorDetails: errorList);
                });

                AutoLog($"♻️ Reevaluación completada. Restaurados: {result.Restored}, Se mantienen en cuarentena: {result.Kept}, Errores: {result.Errors}");

                var sb = new StringBuilder();
                sb.AppendLine($"Restaurados: {result.Restored}");
                sb.AppendLine($"En cuarentena: {result.Kept}");
                sb.AppendLine($"Errores: {result.Errors}");

                if (result.ErrorDetails.Count > 0)
                {
                    AutoLog("⚠️ Algunos archivos no se pudieron mover al reevaluar cuarentena. Revisa el log para más detalles.");
                    sb.AppendLine("\nSe encontraron errores. Consulta el log para detalles.");
                }

                MessageBox.Show(sb.ToString(), "Reevaluación de cuarentena", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            finally
            {
                reanalyzeQuarantineRunning = false;
                UseWaitCursor = false;
                Cursor.Current = Cursors.Default;
            }
        }
        
