        private async Task EnsureAuthorsDatabaseReadyAsync()
        {
            if (authorsDatabaseReady)
            {
                return;
            }

            await authorsDatabaseSemaphore.WaitAsync().ConfigureAwait(false);
            try
            {
                if (authorsDatabaseReady)
                {
                    return;
                }

                if (slskDatabase == null)
                {
                    InitializeSlskDatabase();
                }

                if (slskDatabase == null)
                {
                    AutoLog("❌ SlskDatabase no se pudo inicializar.");
                    MessageBox.Show(
                        $"La base de datos de autores no se pudo inicializar. {(string.IsNullOrWhiteSpace(slskDatabaseInitializationError) ? "Revisa los permisos de escritura en la carpeta de datos o vuelve a intentarlo." : slskDatabaseInitializationError)}",
                        "Autores",
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Error);
                    return;
                }

                await EnsureUniversalAuthorsSeedAsync().ConfigureAwait(false);
                await EnsureAuthorsSeededCoreAsync().ConfigureAwait(false);
                await LoadAuthorsFromDatabaseAsync().ConfigureAwait(false);
                authorsDatabaseReady = true;
            }
            finally
            {
                authorsDatabaseSemaphore.Release();
            }
        }

        private async Task EnsureAuthorsSeededCoreAsync()
        {
            if (slskDatabase == null)
            {
                return;
            }

            try
            {
                var existingCount = await slskDatabase.GetAuthorCountAsync().ConfigureAwait(false);
                if (existingCount > 0)
                {
                    AutoLog($"📚 Autores existentes en base de datos: {existingCount:N0}");
                    return;
                }

                var authorsFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Data", "gutenberg_authors.txt");
                if (!File.Exists(authorsFile))
                {
                    AutoLog("⚠️ No se encontró Data/gutenberg_authors.txt para seed inicial");
                    return;
                }

                var fileAuthors = File.ReadAllLines(authorsFile)
                    .Where(line => !string.IsNullOrWhiteSpace(line))
                    .Select(line => line.Trim())
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToList();

                if (fileAuthors.Count == 0)
                {
                    AutoLog("⚠️ El archivo Data/gutenberg_authors.txt está vacío");
                    return;
                }

                await slskDatabase.BulkInsertAuthorsAsync(fileAuthors, "Gutenberg").ConfigureAwait(false);
                AutoLog($"✅ Seed de autores completado: {fileAuthors.Count:N0} registros");
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error al inicializar autores: {ex.Message}");
            }
        }

