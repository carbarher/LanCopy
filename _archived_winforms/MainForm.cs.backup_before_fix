        private void UpdateProviderStats(string username, bool success, double speedMBps, long bytes)
        {
            if (string.IsNullOrWhiteSpace(username))
            {
                return;
            }

            lock (providerStatsLock)
            {
                if (!providerStats.TryGetValue(username, out var stats))
                {
                    stats = new ProviderStats { Username = username };
                    providerStats[username] = stats;
                }

                stats.TotalDownloads++;

                if (success)
                {
                    stats.SuccessfulDownloads++;
                    stats.TotalBytesDownloaded += Math.Max(0, bytes);

                    if (speedMBps > 0)
                    {
                        var weighted = (stats.AverageSpeed * Math.Max(0, stats.SuccessfulDownloads - 1)) + speedMBps;
                        stats.AverageSpeed = weighted / Math.Max(1, stats.SuccessfulDownloads);
                    }
                }
                else
                {
                    stats.FailedDownloads++;
                }

                stats.LastDownload = DateTime.Now;

                UpdateAdaptiveProviderMetricsLocked(username, success, speedMBps);
                PruneStaleAdaptiveMetricsLocked();
            }

            try
            {
                providerScoreCache.Add(username.Trim(), GetDeterministicProviderScoreInt(username));
            }
            catch
            {
            }
        }

