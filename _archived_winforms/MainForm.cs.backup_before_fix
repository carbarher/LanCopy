        // MEJORA #6: Backoff exponencial en errores del servidor
        private void HandleServerError(Exception ex)
        {
            lock (rateLimiterLock)
            {
                consecutiveServerErrors++;
                lastServerError = DateTime.Now;
                
                // Después de 3 errores consecutivos, reducir tráfico temporalmente
                if (consecutiveServerErrors >= 3)
                {
                    int newLimit = Math.Max(10, maxSearchesPerMinute - 10);
                    
                    if (maxSearchesPerMinute != newLimit)
                    {
                        maxSearchesPerMinute = newLimit;
                        Log($"⚠️ BACKOFF ACTIVADO: Reduciendo límite a {maxSearchesPerMinute} búsq/min por {consecutiveServerErrors} errores consecutivos");
                        
                        SafeInvoke(() =>
                        {
                            ShowNotification("⚠️ Backoff Activado",
                                $"Detectados {consecutiveServerErrors} errores del servidor\n\nLímite reducido a {maxSearchesPerMinute} búsq/min temporalmente",
                                ToolTipIcon.Warning);
                        });
                    }
                }
            }
        }
        
        private void ResetServerErrorCounter()
        {
            lock (rateLimiterLock)
            {
                // Si han pasado 10 minutos sin errores, resetear
                if ((DateTime.Now - lastServerError).TotalMinutes >= 10)
                {
                    if (consecutiveServerErrors > 0)
                    {
                        consecutiveServerErrors = 0;
                        
                        // Restaurar límite original
                        if (maxSearchesPerMinute != originalMaxSearchesPerMinute)
                        {
                            maxSearchesPerMinute = originalMaxSearchesPerMinute;
                            Log($"✅ BACKOFF DESACTIVADO: Restaurando límite a {maxSearchesPerMinute} búsq/min");
                        }
                    }
                }
            }
        }
        
        // MEJORA #9: Modo pausa inteligente
        private void CheckAndActivateIntelligentPause()
        {
            // Limpiar reconexiones antiguas (más de 1 hora)
            var oneHourAgo = DateTime.Now.AddHours(-1);
            reconnectionHistory.RemoveAll(dt => dt < oneHourAgo);
            reconnectionsLastHour = reconnectionHistory.Count;
            
            // Limpiar latencias antiguas (mantener últimas 50)
            if (latencyHistory.Count > 50)
            {
                latencyHistory.RemoveRange(0, latencyHistory.Count - 50);
            }
            
            if (latencyHistory.Count > 0)
            {
                averageLatencyMs = latencyHistory.Average();
            }
            
            // Condiciones para activar pausa inteligente:
            // 1. 5+ timeouts consecutivos
            // 2. 10+ reconexiones en última hora
            // 3. Latencia promedio >5 segundos
            bool shouldPause = false;
            string reason = "";
            
            if (consecutiveTimeouts >= 5)
            {
                shouldPause = true;
                reason = $"{consecutiveTimeouts} timeouts consecutivos";
            }
            else if (reconnectionsLastHour >= 10)
            {
                shouldPause = true;
                reason = $"{reconnectionsLastHour} reconexiones en última hora";
            }
            else if (averageLatencyMs > 5000)
            {
                shouldPause = true;
                reason = $"Latencia alta ({averageLatencyMs:F0}ms promedio)";
            }
            
            if (shouldPause && !intelligentPauseActive)
            {
                // Pausar por 15 minutos
                intelligentPauseActive = true;
                intelligentPauseUntil = DateTime.Now.AddMinutes(15);
                
                Log($"⏸️ MODO PAUSA INTELIGENTE ACTIVADO: {reason}");
                Log($"   Pausando operaciones por 15 minutos hasta {intelligentPauseUntil:HH:mm:ss}");
                
                SafeInvoke(() =>
                {
                    ShowNotification("⏸️ Pausa Inteligente",
                        $"Sistema pausado por sobrecarga del servidor:\n\n{reason}\n\nReanudando en 15 minutos",
                        ToolTipIcon.Warning);
                });
                
                // Resetear contadores
                consecutiveTimeouts = 0;
            }
        }
        
