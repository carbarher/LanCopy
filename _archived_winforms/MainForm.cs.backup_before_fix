        private async Task RunPipelineBenchAsync()
        {
            if (pipelineBenchRunning)
            {
                return;
            }

            pipelineBenchRunning = true;
            if (btnPipelineBench != null)
            {
                btnPipelineBench.Enabled = false;
            }
            if (lblPipelineBench != null)
            {
                lblPipelineBench.Text = "Benchmark pipeline: running...";
            }

            try
            {
                var spanishOnly = chkSpanishOnly?.Checked ?? false;
                var hasSinglePass = SlskNativeInterop.SupportsSearchPipeline;

                var result = await Task.Run(() =>
                {
                    var data = GenerateBenchDataset(seed: 12345, count: 50000);
                    const int warmup = 1;
                    const int iters = 5;

                    var stagedTimes = new List<long>(iters);
                    var spTimes = new List<long>(iters);

                    for (int i = 0; i < warmup + iters; i++)
                    {
                        var input = new List<SearchResultItem>(data);
                        var sw = System.Diagnostics.Stopwatch.StartNew();
                        _ = ProcessSearchResultsStagedOnly(input, spanishOnly);
                        sw.Stop();
                        if (i >= warmup)
                        {
                            stagedTimes.Add(sw.ElapsedMilliseconds);
                        }
                    }

                    if (hasSinglePass)
                    {
                        for (int i = 0; i < warmup + iters; i++)
                        {
                            var input = new List<SearchResultItem>(data);
                            var sw = System.Diagnostics.Stopwatch.StartNew();
                            _ = ProcessSearchResultsSinglePassNativeInPlace(
                                input,
                                minSize: 0,
                                maxSize: long.MaxValue,
                                extensions: null,
                                spanishOnly: spanishOnly,
                                minQuality: 60);
                            sw.Stop();
                            if (i >= warmup)
                            {
                                spTimes.Add(sw.ElapsedMilliseconds);
                            }
                        }
                    }

                    static (long p50, long p90) Percentiles(List<long> xs)
                    {
                        if (xs.Count == 0)
                        {
                            return (0, 0);
                        }

                        xs.Sort();
                        long P(double q)
                        {
                            var idx = (int)Math.Round((xs.Count - 1) * q);
                            idx = Math.Max(0, Math.Min(xs.Count - 1, idx));
                            return xs[idx];
                        }

                        return (P(0.50), P(0.90));
                    }

                    var (st50, st90) = Percentiles(stagedTimes);
                    var (sp50, sp90) = Percentiles(spTimes);
                    return (st50, st90, sp50, sp90, hasSinglePass);
                });

                BeginInvoke(new Action(() =>
                {
                    if (lblPipelineBench == null)
                    {
                        return;
                    }

                    if (!result.hasSinglePass)
                    {
                        var reason = SlskNativeInterop.GetSearchPipelineSupportSummary();
                        lblPipelineBench.Text = $"Benchmark pipeline: staged p50={result.st50}ms p90={result.st90}ms | single-pass: n/a ({reason})";
                    }
                    else
                    {
                        lblPipelineBench.Text = $"Benchmark pipeline: staged p50={result.st50}ms p90={result.st90}ms | single-pass p50={result.sp50}ms p90={result.sp90}ms";
                    }
                }));
            }
            catch (Exception ex)
            {
                BeginInvoke(new Action(() =>
                {
                    if (lblPipelineBench != null)
                    {
                        lblPipelineBench.Text = $"Benchmark pipeline: error: {ex.Message}";
                    }
                }));
            }
            finally
            {
                pipelineBenchRunning = false;
                if (btnPipelineBench != null)
                {
                    btnPipelineBench.Enabled = true;
                }
            }
        }

        private List<SearchResultItem> ProcessSearchResultsStagedOnly(List<SearchResultItem> results, bool spanishOnly)
        {
            if (results == null || results.Count == 0)
            {
                return results;
            }

            if (results.Count > 5000)
            {
                results = FilterResultsOptimized(
                    results,
                    minSize: 0,
                    extensions: null,
                    spanishOnly: spanishOnly);
            }

            if (results.Count > 10000)
            {
                results = DeduplicateResultsOptimized(results);
            }

            if (results.Count > 1000)
            {
                results = SortSearchResultsOptimized(results);
            }

            return results;
        }

        private static List<SearchResultItem> GenerateBenchDataset(int seed, int count)
        {
            var rng = new Random(seed);
            var items = new List<SearchResultItem>(count);
            string[] usernames = { "u1", "u2", "u3", "u4", "u5" };
            string[] exts = { ".pdf", ".epub", ".mobi", ".txt" };
            var baseCount = (int)(count * 0.7);

            for (int i = 0; i < baseCount; i++)
            {
                var ext = exts[rng.Next(exts.Length)];
                items.Add(new SearchResultItem
                {
                    Username = usernames[rng.Next(usernames.Length)],
                    Filename = $"Book_{i % 5000:D5}{ext}",
                    Extension = ext,
                    Size = rng.NextInt64(10 * 1024, 12 * 1024 * 1024),
                    QualityScore = rng.Next(0, 101)
                });
            }

            while (items.Count < count)
            {
                var pick = items[rng.Next(items.Count)];
                items.Add(new SearchResultItem
                {
                    Username = usernames[rng.Next(usernames.Length)],
                    Filename = pick.Filename,
                    Extension = pick.Extension,
                    Size = pick.Size,
                    QualityScore = rng.Next(0, 101)
                });
            }

            for (int i = items.Count - 1; i > 0; i--)
            {
                int j = rng.Next(i + 1);
                (items[i], items[j]) = (items[j], items[i]);
            }

            return items;
        }

        private static void RotateFileIfTooLarge(string path, long maxBytes, int maxBackups)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(path) || maxBytes <= 0)
                {
                    return;
                }

                var info = new FileInfo(path);
                if (!info.Exists || info.Length <= maxBytes)
                {
                    return;
                }

                var directory = info.DirectoryName ?? string.Empty;
                if (string.IsNullOrWhiteSpace(directory))
                {
                    return;
                }

                Directory.CreateDirectory(directory);

                var stamp = DateTime.Now.ToString("yyyyMMdd_HHmmss", CultureInfo.InvariantCulture);
                var baseName = Path.GetFileNameWithoutExtension(path);
                var ext = Path.GetExtension(path);
                var rotated = Path.Combine(directory, $"{baseName}_{stamp}{ext}");

                File.Move(path, rotated);

                var pattern = $"{baseName}_*{ext}";
                var backups = Directory.GetFiles(directory, pattern)
                    .Select(p => new FileInfo(p))
                    .OrderByDescending(f => f.LastWriteTimeUtc)
                    .Skip(Math.Max(0, maxBackups))
                    .ToList();

                foreach (var b in backups)
                {
                    try
                    {
                        b.Delete();
                    }
                    catch
                    {
                    }
                }
            }
            catch
            {
            }
        }

        private static string GetPipelineBin(int count)
        {
            if (count <= 10000)
            {
                return "s";
            }

            if (count <= 50000)
            {
                return "m";
            }

            return "l";
        }

        private static string EscapeCsv(string value)
        {
            if (value == null)
            {
                return string.Empty;
            }

            var needsQuotes = value.Contains(",", StringComparison.Ordinal) || value.Contains("\"", StringComparison.Ordinal) || value.Contains("\n", StringComparison.Ordinal) || value.Contains("\r", StringComparison.Ordinal);
            if (!needsQuotes)
            {
                return value;
            }

            return "\"" + value.Replace("\"", "\"\"", StringComparison.Ordinal) + "\"";
        }

