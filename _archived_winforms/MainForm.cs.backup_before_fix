        private async Task ScanLibraryAsync()
        {
            try
            {
                Log("🔄 Escaneando biblioteca...");
                lvLibrary.Items.Clear();
                libraryItems.Clear();
                
                if (!System.IO.Directory.Exists(downloadDir))
                {
                    MessageBox.Show($"La carpeta de descargas no existe: {downloadDir}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                    return;
                }
                
                await Task.Run(() =>
                {
                    var files = System.IO.Directory.GetFiles(downloadDir, "*.*", SearchOption.AllDirectories);
                    
                    foreach (var file in files)
                    {
                        try
                        {
                            var fileInfo = new FileInfo(file);
                            var ext = fileInfo.Extension.ToLower();
                            
                            // Solo archivos relevantes
                            if (new[] { ".epub", ".mobi", ".pdf", ".azw3", ".mp3", ".flac", ".m4a", ".ogg", ".docx", ".txt" }.Contains(ext))
                            {
                                var item = new LibraryItem
                                {
                                    FileName = fileInfo.Name,
                                    FilePath = fileInfo.FullName,
                                    Size = fileInfo.Length,
                                    Extension = ext,
                                    DateAdded = fileInfo.CreationTime,
                                    Category = GetCategoryFromExtension(ext),
                                    Rating = 0,
                                    Read = false
                                };
                                
                                lock (libraryLock)
                                {
                                    libraryItems.Add(item);
                                }
                            }
                        }
                        catch (Exception ex)
                        {
                            Log($"Error procesando archivo {file}: {ex.Message}");
                        }
                    }
                });
                
                UpdateLibraryView();
                Log($"✅ Biblioteca escaneada: {libraryItems.Count} archivos encontrados");
                MessageBox.Show($"Se encontraron {libraryItems.Count} archivos en la biblioteca", "Escaneo Completo", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                Log($"❌ Error escaneando biblioteca: {ex.Message}");
                MessageBox.Show($"Error: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
        private string GetCategoryFromExtension(string ext)
        {
            return ext switch
            {
                ".epub" or ".mobi" or ".pdf" or ".azw3" => "📚 Libro",
                ".mp3" or ".flac" or ".m4a" or ".ogg" => "🎵 Audio",
                ".docx" or ".txt" => "📄 Documento",
                _ => "❓ Otro"
            };
        }
        
        private void UpdateLibraryView()
        {
            lvLibrary.BeginUpdate();
            lvLibrary.Items.Clear();
            
            foreach (var item in libraryItems)
            {
                var listItem = new ListViewItem(item.FileName);
                listItem.SubItems.Add(item.Category);
                listItem.SubItems.Add(FormatFileSize(item.Size));
                listItem.SubItems.Add(item.DateAdded.ToString("yyyy-MM-dd HH:mm"));
                listItem.SubItems.Add(item.Rating > 0 ? new string('⭐', item.Rating) : "-");
                listItem.SubItems.Add(item.Read ? "✅ Leído" : "📖 Pendiente");
                listItem.Tag = item;
