                            "Importar autores",
                            MessageBoxButtons.OK,
                            MessageBoxIcon.Information);
                        return;
                    }

                    AutoLog($"📥 Importando {authorsToImport.Count:N0} autores desde {Path.GetFileName(filePath)}...");
                    await slskDatabase.BulkInsertAuthorsAsync(
                        authorsToImport,
                        source: "UserImport",
                        isCanonicalFunc: IsCanonicalAuthorName,
                        priorityFunc: GetAuthorPriority).ConfigureAwait(false);

                    await LoadAuthorsFromDatabaseAsync().ConfigureAwait(false);
                    AutoLog($"✅ Importación completada: {authorsToImport.Count:N0} autores");
