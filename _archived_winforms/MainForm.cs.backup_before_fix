        private static string GetRelativePathSafe(string fullPath, string rootPath)
        {
            if (string.IsNullOrWhiteSpace(fullPath) || string.IsNullOrWhiteSpace(rootPath))
            {
                return fullPath ?? string.Empty;
            }

            try
            {
                var rootFull = Path.GetFullPath(rootPath);
                var pathFull = Path.GetFullPath(fullPath);

                if (!pathFull.StartsWith(rootFull, StringComparison.OrdinalIgnoreCase))
                {
                    return fullPath;
                }

                var relative = pathFull.Substring(rootFull.Length).TrimStart(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar);
                return string.IsNullOrEmpty(relative) ? Path.GetFileName(pathFull) ?? string.Empty : relative;
            }
            catch
            {
                return fullPath;
            }
        }

        private string FormatDuration(int seconds)
        {
            var ts = TimeSpan.FromSeconds(seconds);
            return ts.Hours > 0 ? $"{ts.Hours}:{ts.Minutes:D2}:{ts.Seconds:D2}" : $"{ts.Minutes}:{ts.Seconds:D2}";
        }
        
        private void FilterResults()
        {
            if (string.IsNullOrWhiteSpace(txtFilterResults.Text))
            {
                for (int i = 0; i < lvResults.Items.Count; i++)
                {
                    lvResults.Items[i].BackColor = Color.FromArgb(45, 45, 45);
                }
                return;
            }
            
            var filterText = txtFilterResults.Text.ToLower();
            for (int i = 0; i < lvResults.Items.Count; i++)
            {
                var item = lvResults.Items[i];
                bool matches = false;
                
                for (int j = 0; j < item.SubItems.Count; j++)
                {
                    if (item.SubItems[j].Text.ToLower().Contains(filterText))
                    {
                        matches = true;
                        break;
                    }
                }
                
                item.BackColor = matches ? Color.FromArgb(45, 45, 45) : Color.FromArgb(30, 30, 30);
            }
        }
        
