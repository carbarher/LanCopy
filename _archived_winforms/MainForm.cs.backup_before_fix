        private void FilterAuthors(string searchText)
        {
            if (string.IsNullOrWhiteSpace(searchText))
            {
                filteredAuthorsData = new List<AuthorData>(allAuthorsData);
            }
            else
            {
                try
                {
                    if (SlskDown.Core.RustSearchIndex.IsRustAvailable() && authorSearchIndex == null)
                    {
                        IndexAuthorsForSearch();
                    }

                    if (authorSearchIndex != null)
                    {
                        var matches = SearchAuthorIntelligentSilent(searchText.Trim());
                        if (matches.Count > 0)
                        {
                            var matchSet = new HashSet<string>(matches, StringComparer.OrdinalIgnoreCase);
                            filteredAuthorsData = allAuthorsData
                                .Where(a => !string.IsNullOrEmpty(a.Name) && matchSet.Contains(a.Name))
                                .ToList();
                        }
                        else
                        {
                            filteredAuthorsData = new List<AuthorData>();
                        }
                    }
                    else
                    {
                        var filter = searchText.Trim();
                        filteredAuthorsData = allAuthorsData
                            .Where(a => !string.IsNullOrEmpty(a.Name) && a.Name.Contains(filter, StringComparison.OrdinalIgnoreCase))
                            .ToList();
                    }
                }
                catch
                {
                    var filter = searchText.Trim();
                    filteredAuthorsData = allAuthorsData
                        .Where(a => !string.IsNullOrEmpty(a.Name) && a.Name.Contains(filter, StringComparison.OrdinalIgnoreCase))
                        .ToList();
                }
            }

            RefreshAuthorsListView();
            UpdateAuthorCount();
        }

        private void UpdateAuthorCount()
        {
            var countLabel = lblAuthorCount;
            if (countLabel == null)
            {
                return;
            }

            int total = allAuthorsData.Count;
            int filtered = filteredAuthorsData.Count;

            int valid = 0;
            int canonicalFiltered = 0;

            foreach (var author in filteredAuthorsData)
            {
                if (author.FilesCount > 0)
                {
                    valid++;
                }

                if (author.IsCanonical)
                {
                    canonicalFiltered++;
                }
            }

            var culture = CultureInfo.CurrentCulture;
            var canonicalFilteredPct = filtered > 0
                ? (double)canonicalFiltered / filtered
                : 0d;
            var canonicalChunk = canonicalFiltered > 0
                ? $" | {canonicalFiltered.ToString("N0", culture)} priorizados ({canonicalFilteredPct.ToString("P0", culture)})"
                : string.Empty;

            var duplicates = duplicateAuthorTotalCount;
            var duplicateChunk = duplicates > 0
                ? $" | 🧬 {duplicates.ToString("N0", culture)} duplicados potenciales"
                : string.Empty;

            countLabel.Text = total == filtered
                ? $"{total:N0} autores | {valid:N0} válidos{canonicalChunk}{duplicateChunk}"
                : $"{filtered:N0} de {total:N0} autores | {valid:N0} válidos{canonicalChunk}{duplicateChunk}";
        }

