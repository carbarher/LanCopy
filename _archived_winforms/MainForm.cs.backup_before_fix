        // MEJORA #9: Iniciar heartbeat
        private void StartHeartbeat()
        {
            StopHeartbeat(); // Detener si existe
            
            heartbeatTimer = new System.Threading.Timer(async _ =>
            {
                try
                {
                    if (client?.State == SoulseekClientStates.Connected)
                    {
                        // Verificar que el estado sea realmente válido
                        var state = client.State;
                        
                        if (state == SoulseekClientStates.Connected)
                        {
                            lastHeartbeatSuccess = DateTime.Now;
                        }
                    }
                    else
                    {
                        // Si no está conectado y pasaron 60s desde último heartbeat exitoso
                        if ((DateTime.Now - lastHeartbeatSuccess).TotalSeconds > 60 && 
                            lastHeartbeatSuccess != DateTime.MinValue)
                        {
                            Log("💔 Heartbeat detectó conexión zombie - forzando desconexión");
                            SafeInvoke(() =>
                            {
                                try
                                {
                                    client?.Disconnect();
                                }
                                catch { }
                            });
                        }
                    }
                }
                catch (Exception ex)
                {
                    Log($"⚠️ Error en heartbeat: {ex.Message}");
                }
            }, null, 30000, 30000); // Cada 30 segundos
            
            Log("💓 Heartbeat iniciado (cada 30s)");
        }
        
        private void StopHeartbeat()
        {
            try
            {
                heartbeatTimer?.Dispose();
                heartbeatTimer = null;
                Log("💔 Heartbeat detenido");
            }
            catch { }
        }

