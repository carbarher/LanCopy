        private static TitleSearchFromTxtService.TitleSearchQuery ParseTitleSearchLine(string rawLine)
        {
            var line = (rawLine ?? string.Empty).Trim();
            if (string.IsNullOrWhiteSpace(line))
            {
                return new TitleSearchFromTxtService.TitleSearchQuery(string.Empty, string.Empty);
            }

            if (line.StartsWith("#", StringComparison.Ordinal))
            {
                return new TitleSearchFromTxtService.TitleSearchQuery(string.Empty, string.Empty);
            }

            static bool TrySplit(string text, string separator, out string left, out string right)
            {
                var idx = text.IndexOf(separator, StringComparison.Ordinal);
                if (idx <= 0)
                {
                    left = string.Empty;
                    right = string.Empty;
                    return false;
                }

                left = text[..idx].Trim();
                right = text[(idx + separator.Length)..].Trim();
                return !string.IsNullOrWhiteSpace(left) && !string.IsNullOrWhiteSpace(right);
            }

            if (TrySplit(line, " - ", out var authorDash, out var titleDash) ||
                TrySplit(line, " — ", out authorDash, out titleDash) ||
                TrySplit(line, " – ", out authorDash, out titleDash))
            {
                var query = $"{authorDash} {titleDash}";
                return new TitleSearchFromTxtService.TitleSearchQuery(query, authorDash);
            }

            var byIndex = line.IndexOf(" by ", StringComparison.OrdinalIgnoreCase);
            if (byIndex > 0)
            {
                var title = line[..byIndex].Trim();
                var author = line[(byIndex + 4)..].Trim();
                if (!string.IsNullOrWhiteSpace(title) && !string.IsNullOrWhiteSpace(author))
                {
                    var query = $"{author} {title}";
                    return new TitleSearchFromTxtService.TitleSearchQuery(query, author);
                }
            }

            return new TitleSearchFromTxtService.TitleSearchQuery(line, "ObrasTXT");
        }

        private static string NormalizeTxtQueryKey(string text)
        {
            if (string.IsNullOrWhiteSpace(text))
            {
                return string.Empty;
            }

            var normalized = text.Normalize(NormalizationForm.FormD);
            var sb = new StringBuilder(normalized.Length);
            bool prevSpace = true;

            foreach (var ch in normalized)
            {
                var cat = CharUnicodeInfo.GetUnicodeCategory(ch);
                if (cat == UnicodeCategory.NonSpacingMark)
                {
                    continue;
                }

                if (char.IsLetterOrDigit(ch))
                {
                    sb.Append(char.ToLowerInvariant(ch));
                    prevSpace = false;
                    continue;
                }

                if (!prevSpace)
                {
                    sb.Append(' ');
                    prevSpace = true;
                }
            }

            return sb.ToString().Trim();
        }

        private sealed class TxtSearchCheckpoint
        {
            public string SourceFilePath { get; set; } = string.Empty;
            public long SourceFileSizeBytes { get; set; }
            public DateTime SourceFileLastWriteUtc { get; set; }
            public int TotalCount { get; set; }
            public int CompletedCount { get; set; }
            public DateTime Timestamp { get; set; }
            public int TotalResults { get; set; }
            public List<TitleSearchFromTxtService.TitleSearchQuery> RemainingQueries { get; set; } = new List<TitleSearchFromTxtService.TitleSearchQuery>();
        }

        private async Task<(bool shouldResume, int totalCount, int completedCount, List<TitleSearchFromTxtService.TitleSearchQuery> remainingQueries)> LoadTxtCheckpointIfExistsAsync(string selectedFilePath)
        {
            try
            {
                if (!System.IO.File.Exists(txtCheckpointPath))
                {
                    return (false, 0, 0, new List<TitleSearchFromTxtService.TitleSearchQuery>());
                }

                var json = await System.IO.File.ReadAllTextAsync(txtCheckpointPath);
                var checkpoint = JsonSerializer.Deserialize<TxtSearchCheckpoint>(json);
                if (checkpoint == null)
                {
                    return (false, 0, 0, new List<TitleSearchFromTxtService.TitleSearchQuery>());
                }

                try
                {
                    var selectedInfo = new FileInfo(selectedFilePath);
                    if (selectedInfo.Exists)
                    {
                        if (checkpoint.SourceFileSizeBytes != selectedInfo.Length ||
                            checkpoint.SourceFileLastWriteUtc != selectedInfo.LastWriteTimeUtc)
                        {
                            AutoLog("⚠️ Checkpoint TXT no coincide con el archivo seleccionado (size/mtime). Ignorando.");
                            System.IO.File.Delete(txtCheckpointPath);
                            return (false, 0, 0, new List<TitleSearchFromTxtService.TitleSearchQuery>());
                        }
                    }
                }
                catch
                {
                }

                if ((DateTime.Now - checkpoint.Timestamp).TotalHours > 24)
                {
                    AutoLog("⏰ Checkpoint TXT antiguo (>24h), ignorando");
                    System.IO.File.Delete(txtCheckpointPath);
                    return (false, 0, 0, new List<TitleSearchFromTxtService.TitleSearchQuery>());
                }

                var result = MessageBox.Show(
                    $"🔄 CHECKPOINT TXT ENCONTRADO\n\n" +
                    $"Fecha: {checkpoint.Timestamp:dd/MM/yyyy HH:mm}\n" +
                    $"Procesadas: {checkpoint.CompletedCount}/{checkpoint.TotalCount} consultas\n" +
                    $"Resultados: {checkpoint.TotalResults:N0} archivos\n" +
                    $"Restantes: {Math.Max(0, checkpoint.TotalCount - checkpoint.CompletedCount)} consultas\n\n" +
                    $"TXT actual: {Path.GetFileName(selectedFilePath)}\n" +
                    $"Checkpoint: {Path.GetFileName(checkpoint.SourceFilePath)}\n\n" +
                    $"¿Continuar desde el checkpoint?",
                    "Recuperar Progreso (TXT)",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Question);

                if (result == DialogResult.Yes)
                {
                    AutoLog($"✅ Continuando TXT desde checkpoint: {checkpoint.RemainingQueries.Count} consultas restantes");
                    var remaining = checkpoint.RemainingQueries ?? new List<TitleSearchFromTxtService.TitleSearchQuery>();
                    var completed = Math.Max(0, checkpoint.TotalCount - remaining.Count);
                    return (true, checkpoint.TotalCount, completed, remaining);
                }

                System.IO.File.Delete(txtCheckpointPath);
                AutoLog("🔄 Checkpoint TXT descartado, iniciando búsqueda completa");
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error cargando checkpoint TXT: {ex.Message}");
            }

            return (false, 0, 0, new List<TitleSearchFromTxtService.TitleSearchQuery>());
        }

        private async Task SaveTxtCheckpointAsync(string sourceFilePath, int totalCount, int completedCount, List<TitleSearchFromTxtService.TitleSearchQuery> remainingQueries)
        {
            try
            {
                var totalResultsSnapshot = allResults?.Count ?? 0;

                long fileSizeBytes = 0;
                DateTime lastWriteUtc = DateTime.MinValue;
                try
                {
                    var info = new FileInfo(sourceFilePath);
                    if (info.Exists)
                    {
                        fileSizeBytes = info.Length;
                        lastWriteUtc = info.LastWriteTimeUtc;
                    }
                }
                catch
                {
                }

                var checkpoint = new TxtSearchCheckpoint
                {
                    SourceFilePath = sourceFilePath ?? string.Empty,
                    SourceFileSizeBytes = fileSizeBytes,
                    SourceFileLastWriteUtc = lastWriteUtc,
                    TotalCount = totalCount,
                    CompletedCount = completedCount,
                    Timestamp = DateTime.Now,
                    TotalResults = totalResultsSnapshot,
                    RemainingQueries = remainingQueries
                };

                var json = JsonSerializer.Serialize(checkpoint, new JsonSerializerOptions { WriteIndented = true });
                await System.IO.File.WriteAllTextAsync(txtCheckpointPath, json).ConfigureAwait(false);
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error guardando checkpoint TXT: {ex.Message}");
            }
        }

