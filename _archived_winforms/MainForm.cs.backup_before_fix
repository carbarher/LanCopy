            public void SetSamples(IEnumerable<double> values)
            {
                lock (syncRoot)
                {
                    samples = values?.Select(v => double.IsFinite(v) ? v : 0d).ToArray() ?? Array.Empty<double>();
                }

                Invalidate();
            }

            protected override void OnPaint(PaintEventArgs e)
            {
                base.OnPaint(e);

                double[] localSamples;
                lock (syncRoot)
                {
                    localSamples = samples;
                }

                if (localSamples.Length == 0)
                {
                    DrawPlaceholder(e.Graphics);
                    return;
                }

                var bounds = ClientRectangle;
                bounds.Inflate(-Padding.Left, -Padding.Top);
                if (bounds.Width <= 2 || bounds.Height <= 2)
                {
                    DrawPlaceholder(e.Graphics);
                    return;
                }

                double min = localSamples.Min();
                double max = localSamples.Max();
                if (Math.Abs(max - min) < 1e-6)
                {
                    max = min + 1e-6;
                }

                using var backgroundBrush = new SolidBrush(Color.FromArgb(32, Color.LightGray));
                e.Graphics.FillRectangle(backgroundBrush, bounds);

                e.Graphics.SmoothingMode = SmoothingMode.AntiAlias;

                var pointCount = localSamples.Length;
                var step = (double)(bounds.Width - 1) / Math.Max(pointCount - 1, 1);
                var points = new PointF[pointCount];
                for (int i = 0; i < pointCount; i++)
                {
                    var value = localSamples[i];
                    var normalized = (value - min) / (max - min);
                    var x = bounds.Left + (float)(i * step);
                    var y = bounds.Bottom - (float)(normalized * (bounds.Height - 1));
                    points[i] = new PointF(x, y);
                }

                using var linePen = new Pen(Color.FromArgb(0, 200, 255), 2f);
                if (points.Length >= 2)
                {
                    e.Graphics.DrawLines(linePen, points);
                }

                var latest = localSamples[^1];
                using var textBrush = new SolidBrush(Color.FromArgb(200, Color.White));
                var info = latest.ToString("F2") + " MB/s";
                var textSize = e.Graphics.MeasureString(info, Font);
                var textLocation = new PointF(bounds.Right - textSize.Width, bounds.Top);
                e.Graphics.DrawString(info, Font, textBrush, textLocation);
            }

            private void DrawPlaceholder(Graphics graphics)
            {
                using var placeholderPen = new Pen(Color.FromArgb(80, Color.LightGray), 1f);
                graphics.DrawLine(placeholderPen, 0, Height / 2, Width, Height / 2);
            }
        }

