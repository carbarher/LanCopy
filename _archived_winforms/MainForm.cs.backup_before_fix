                    totalDownloads,
                    searchStats,
                    lastUpdate = DateTime.Now
                };
                var json = JsonSerializer.Serialize(stats);
                lock (jsonSaveLock)
                {
                    for (int attempt = 0; attempt < 3; attempt++)
                    {
                        try
                        {
                            using (var stream = new FileStream(searchStatsPath, FileMode.Create, FileAccess.Write, FileShare.Read))
