        private void UpdateAdaptiveSpeed(double speedMBps)
        {
            lock (recentSpeeds)
            {
                recentSpeeds.Add(speedMBps);
                
                // Mantener solo las últimas N velocidades
                if (recentSpeeds.Count > SPEED_HISTORY_SIZE)
                {
                    recentSpeeds.RemoveAt(0);
                }
                
                // Calcular velocidad promedio
                averageDownloadSpeed = recentSpeeds.Average();
                
                // Ajustar descargas paralelas según velocidad
                AdjustParallelDownloads();
            }
        }
        
        private void AdjustParallelDownloads()
        {
            if (!adaptiveSpeed) return;

            double failureRatio = GetRecentFailureRatio();

            int activeDownloads;
            int queuedDownloads;

            lock (downloadQueueLock)
            {
                activeDownloads = downloadQueue.Count(t => t.Status == DownloadStatus.Downloading);
                queuedDownloads = downloadQueue.Count(t => t.Status == DownloadStatus.Queued);
            }

            bool hasDemand = queuedDownloads > 0 || activeDownloads >= maxParallelDownloads;
            bool highSpeed = averageDownloadSpeed >= SPEED_INCREASE_THRESHOLD;
            bool lowSpeed = averageDownloadSpeed <= SPEED_DECREASE_THRESHOLD;
            bool lowFailure = failureRatio <= RETRY_SAFE_THRESHOLD;
            bool highFailure = failureRatio >= RETRY_DECREASE_THRESHOLD;

            if (hasDemand && highSpeed && lowFailure)
            {
                adaptiveIncreaseVotes++;
                adaptiveDecreaseVotes = Math.Max(0, adaptiveDecreaseVotes - 1);
            }
            else if (highFailure || lowSpeed)
            {
                adaptiveDecreaseVotes++;
                adaptiveIncreaseVotes = Math.Max(0, adaptiveIncreaseVotes - 1);
            }
            else
            {
                if (adaptiveIncreaseVotes > 0) adaptiveIncreaseVotes--;
                if (adaptiveDecreaseVotes > 0) adaptiveDecreaseVotes--;
            }

            bool cooldownElapsed = (DateTime.Now - lastParallelAdjustment).TotalSeconds >= ADAPTIVE_ADJUSTMENT_COOLDOWN_SECONDS;
            int newMaxParallel = maxParallelDownloads;

            if (cooldownElapsed && adaptiveIncreaseVotes >= ADAPTIVE_VOTE_THRESHOLD && maxParallelDownloads < MAX_ADAPTIVE_PARALLEL)
            {
                newMaxParallel = Math.Min(maxParallelDownloads + 1, MAX_ADAPTIVE_PARALLEL);
                adaptiveIncreaseVotes = 0;
                adaptiveDecreaseVotes = 0;
                lastParallelAdjustment = DateTime.Now;
                Log($"🚀 Ajuste adaptativo: +1 slot (Velocidad {averageDownloadSpeed:F2} MB/s, fallos {failureRatio:P0})");
            }
            else if (cooldownElapsed && adaptiveDecreaseVotes >= ADAPTIVE_VOTE_THRESHOLD && maxParallelDownloads > MIN_ADAPTIVE_PARALLEL)
            {
                newMaxParallel = Math.Max(maxParallelDownloads - 1, MIN_ADAPTIVE_PARALLEL);
                adaptiveIncreaseVotes = 0;
                adaptiveDecreaseVotes = 0;
                lastParallelAdjustment = DateTime.Now;
                Log($"🐢 Ajuste adaptativo: -1 slot (Velocidad {averageDownloadSpeed:F2} MB/s, fallos {failureRatio:P0})");
            }

            if (newMaxParallel != maxParallelDownloads)
            {
                CommitParallelDownloadLimit(newMaxParallel);
            }
        }

        private void RecordDownloadOutcome(bool success)
        {
            lock (recentDownloadOutcomes)
            {
                recentDownloadOutcomes.Enqueue(success);
                while (recentDownloadOutcomes.Count > MAX_OUTCOME_HISTORY)
                {
                    recentDownloadOutcomes.Dequeue();
                }
            }
        }

        private double GetRecentFailureRatio()
        {
            lock (recentDownloadOutcomes)
            {
                if (recentDownloadOutcomes.Count == 0)
                    return 0;

                int failures = 0;
                foreach (var outcome in recentDownloadOutcomes)
                {
                    if (!outcome)
                    {
                        failures++;
                    }
                }
                return failures / (double)recentDownloadOutcomes.Count;
            }
        }
        
