                    var cooldownSnapshot = dm.GetCooldownSnapshot();

                    var users = new HashSet<string>(blacklistSnapshot.Keys, StringComparer.OrdinalIgnoreCase);
                    foreach (var u in cooldownSnapshot.Keys)
                    {
                        users.Add(u);
                    }

                    foreach (var username in users.OrderBy(u => u, StringComparer.OrdinalIgnoreCase).Take(300))
                    {
                        int failures = 0;
                        double hoursRemaining = 0;
                        if (dm.TryGetBlacklistInfo(username, out var f, out var hrs))
                        {
                            failures = f;
                            hoursRemaining = hrs;
                        }

                        var cooldownReason = SlskDown.Models.DownloadFailureReason.Unknown;
                        var cooldownRemaining = TimeSpan.Zero;
                        var hasCooldown = dm.TryGetCooldownInfo(username, out cooldownReason, out cooldownRemaining);

                        var item = new ListViewItem(username);
                        item.SubItems.Add(failures.ToString());
                        item.SubItems.Add(hoursRemaining > 0 ? hoursRemaining.ToString("F2", CultureInfo.InvariantCulture) : "0");
                        item.SubItems.Add(hasCooldown ? $"{cooldownRemaining.TotalMinutes:F0}m" : "-");
                        item.SubItems.Add(hasCooldown ? cooldownReason.ToString() : "-");
                        lvProviders.Items.Add(item);
                    }
                }
