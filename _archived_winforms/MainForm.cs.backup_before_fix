        private void UpdateMetricsCharts(object sender, EventArgs e)
        {
            try
            {
                if (WindowState == FormWindowState.Minimized)
                {
                    return;
                }

                var selectedTab = tabControl?.SelectedTab;
                if (selectedTab == null || !selectedTab.Text.Contains("Métricas"))
                {
                    return;
                }

                lock (metricsLock)
                {
                    var now = DateTime.Now;
                    
                    // Calcular velocidad de descarga actual
                    double currentSpeed = CalculateCurrentDownloadSpeed();
                    downloadSpeedHistory.Add((now, currentSpeed));
                    
                    // Obtener uso de memoria
                    long currentMemory = GC.GetTotalMemory(false);
                    memoryHistory.Add((now, currentMemory));
                    
                    // Mantener solo últimos 60 puntos (2 minutos)
                    if (downloadSpeedHistory.Count > 60)
                        downloadSpeedHistory.RemoveAt(0);
                    if (memoryHistory.Count > 60)
                        memoryHistory.RemoveAt(0);
                    
                    // Actualizar gráfico de velocidad
                    if (chartDownloadSpeed != null && downloadSpeedHistory.Count > 0)
                    {
                        chartDownloadSpeed.Plot.Clear();
                        var times = downloadSpeedHistory.Select(x => x.time.ToOADate()).ToArray();
                        var speeds = downloadSpeedHistory.Select(x => x.speed).ToArray();
                        
                        var scatter = chartDownloadSpeed.Plot.Add.Scatter(times, speeds);
                        scatter.Color = ScottPlot.Color.FromHex("#00C8FF");
                        scatter.LineWidth = 2;
                        
                        chartDownloadSpeed.Plot.Axes.DateTimeTicksBottom();
                        chartDownloadSpeed.Refresh();
                        
                        lblMetricsDownloadSpeed.Text = $"{FormatSpeed(currentSpeed)}";
                    }
                    
                    // Actualizar gráfico de memoria
                    if (chartMemory != null && memoryHistory.Count > 0)
                    {
                        chartMemory.Plot.Clear();
                        var times = memoryHistory.Select(x => x.time.ToOADate()).ToArray();
                        var memories = memoryHistory.Select(x => x.memory / (1024.0 * 1024.0)).ToArray(); // MB
                        
                        var scatter = chartMemory.Plot.Add.Scatter(times, memories);
                        scatter.Color = ScottPlot.Color.FromHex("#00FF88");
                        scatter.LineWidth = 2;
                        
                        chartMemory.Plot.Axes.DateTimeTicksBottom();
                        chartMemory.Refresh();
                        
                        lblMetricsMemory.Text = $"{currentMemory / (1024 * 1024)} MB";
                    }
                    
                    // Actualizar estadísticas generales
                    if (lblMetricsTotalDownloads != null)
                    {
                        int completedCount = downloadQueue.Count(d => d.Status == DownloadStatus.Completed);
                        lblMetricsTotalDownloads.Text = $"Descargas completadas: {completedCount}";
                    }
                    
                    // Actualizar métricas de autores canónicos
                    if (lblMetricsCanonicalAuthors != null && slskDatabase != null)
                    {
                        Task.Run(async () =>
                        {
                            try
                            {
                                int totalAuthors = await slskDatabase.GetAuthorCountAsync();
                                int canonicalCount = await slskDatabase.GetCanonicalAuthorCountAsync();
                                double percentage = totalAuthors > 0 ? (canonicalCount * 100.0 / totalAuthors) : 0;
                                SafeInvoke(() =>
                                {
                                    if (lblMetricsCanonicalAuthors != null)
                                        lblMetricsCanonicalAuthors.Text = $"Autores canónicos: {canonicalCount} / {totalAuthors} ({percentage:F1}%)";
                                });
                            }
                            catch { }
                        });
                    }
                    
                    // Actualizar progreso de auto-búsqueda
                    if (lblMetricsAutoProgress != null && allAuthorsData.Count > 0)
                    {
                        int totalAuthors = allAuthorsData.Count;
                        int processedAuthors = allAuthorsData.Count(a => !string.IsNullOrEmpty(a.Status) && a.Status != "Listo");
                        double progress = totalAuthors > 0 ? (processedAuthors * 100.0 / totalAuthors) : 0;
                        lblMetricsAutoProgress.Text = $"Progreso auto-búsqueda: {processedAuthors}/{totalAuthors} ({progress:F1}%)";
                        
                        // Calcular velocidad de búsqueda (autores/min)
                        if (lblMetricsSearchRate != null)
                        {
                            var elapsed = DateTime.Now - lastAutoSearchMetricUpdate;
                            if (elapsed.TotalSeconds > 10)
                            {
                                int authorsDelta = processedAuthors - lastProcessedAuthorCount;
                                double rate = elapsed.TotalMinutes > 0 ? authorsDelta / elapsed.TotalMinutes : 0;
                                lblMetricsSearchRate.Text = $"Velocidad búsqueda: {rate:F1} autores/min";
                                lastAutoSearchMetricUpdate = DateTime.Now;
                                lastProcessedAuthorCount = processedAuthors;
                            }
                        }
                    }
                    
                    // Actualizar mejor proveedor
                    if (lblMetricsTopProvider != null && slskDatabase != null)
                    {
                        Task.Run(async () =>
