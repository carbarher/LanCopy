                    if (string.IsNullOrWhiteSpace(fullPath))
                    {
                        return false;
                    }

                    lock (fileExistsCacheLock)
                    {
                        if (fileExistsCache.TryGetValue(fullPath, out var cached))
                        {
                            if ((DateTime.UtcNow - cached.checkedAt) <= cacheExpiration)
                            {
                                return cached.exists;
                            }
                        }
                    }

                    var exists = IsFileDownloaded(fullPath);

                    lock (fileExistsCacheLock)
                    {
                        fileExistsCache[fullPath] = (exists, DateTime.UtcNow);
                    }

                    return exists;
                }
                catch
                {
                    return IsFileDownloaded(fullPath);
                }
            }

            void UpdateStatsLabel(int? overrideCheckedCount = null)
            {
                try
                {
                    var checkedCount = overrideCheckedCount ?? lvFiles.CheckedItems.Count;
                    lblStats.Text = $"Mostrando: {lvFiles.Items.Count:N0} | Descargados: {existingCountSnapshot:N0} | Pendientes: {pendingCountSnapshot:N0} | Seleccionados: {checkedCount:N0}";
                }
                catch
