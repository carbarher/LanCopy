        private sealed class QueueSchedulingSnapshot
        {
            public List<DownloadTask> OldFailures { get; init; } = new List<DownloadTask>();
            public DownloadTask[] PendingSnapshot { get; init; } = Array.Empty<DownloadTask>();
            public DownloadTask[] TasksToSchedule { get; init; } = Array.Empty<DownloadTask>();
            public DownloadTask[] StuckTasks { get; init; } = Array.Empty<DownloadTask>();
            public DownloadTask[] CandidateFailed { get; init; } = Array.Empty<DownloadTask>();
            public bool RemovedOldFailures { get; init; }
            public int ActiveDownloads { get; init; }
            public int ScheduledCount { get; init; }
        }

        private QueueSchedulingSnapshot CaptureQueueSchedulingSnapshot()
        {
            var now = DateTime.Now;

            return downloadQueueService.WithQueueLock(list =>
            {
                var oldFailures = list
                    .Where(t =>
                        t.Status == DownloadStatus.Failed &&
                        !t.AutoRetryEnabled &&
                        t.FinalFailureTime.HasValue &&
                        (now - t.FinalFailureTime.Value).TotalDays > 7)
                    .ToList();

                if (oldFailures.Count > 0)
                {
                    foreach (var task in oldFailures)
                    {
                        list.Remove(task);
                    }
                }

                var pendingSnapshot = list
                    .Where(t => t.Status == DownloadStatus.Queued)
                    .ToArray();

                var stuckTasks = list
                    .Where(t =>
                        t.Status == DownloadStatus.Downloading &&
                        t.ProgressPercent == 0 &&
                        t.StartTime.HasValue &&
                        (now - t.StartTime.Value).TotalSeconds > 180)
                    .ToArray();

                var candidateFailed = list
                    .Where(t =>
                        t.Status == DownloadStatus.Failed &&
                        t.FinalFailureTime.HasValue &&
                        t.LastRetryTime.HasValue &&
                        t.AutoRetryEnabled &&
                        t.RetryCount < t.MaxRetries)
                    .ToArray();

                var activeDownloads = list.Count(t =>
                    t.Status == DownloadStatus.Downloading ||
                    t.Status == DownloadStatus.GettingStatus);

                var scheduledCount = list.Count(t => t.IsScheduled && t.Status == DownloadStatus.Queued);

                return new QueueSchedulingSnapshot
                {
                    OldFailures = oldFailures,
                    PendingSnapshot = pendingSnapshot,
                    StuckTasks = stuckTasks,
                    CandidateFailed = candidateFailed,
                    RemovedOldFailures = oldFailures.Count > 0,
                    ActiveDownloads = activeDownloads,
                    ScheduledCount = scheduledCount
                };
            });
        }

