        private bool IsSpanishText(string text, bool allowRust = true)
        {
            if (string.IsNullOrWhiteSpace(text))
                return false;

            if (spanishTextCache.TryGetValue(text, out var cached))
                return cached;

            if (allowRust)
            {
                try
                {
                    if ((text.Contains('\\') || text.Contains('/')) && File.Exists(text))
                    {
                        var contentResult = IsSpanishFileByContent(text);
                        spanishTextCache.Add(text, contentResult);
                        if (contentResult)
                        {
                            LanguageFilterStats.Instance.RecordPassed();
                        }
                        else
                        {
                            LanguageFilterStats.Instance.RecordFiltered("spanish");
                        }
                        return contentResult;
                    }
                }
                catch
                {
                }

                try
                {
                    if (SlskNativeInterop.IsAvailable)
                    {
                        var nativeResult = SlskNativeInterop.IsSpanishText(text);
                        spanishTextCache.Add(text, nativeResult);
                        if (nativeResult)
                        {
                            LanguageFilterStats.Instance.RecordPassed();
                        }
                        else
                        {
                            LanguageFilterStats.Instance.RecordFiltered("spanish");
                        }
                        return nativeResult;
                    }
                }
                catch
                {
                }
            }

            bool? rustResult = null;
            if (allowRust && RustCore.IsAvailable())
            {
                rustResult = RustCore.IsSpanishText(text);
                if (rustResult.Value)
                {
                    spanishTextCache.Add(text, true);
                    LanguageFilterStats.Instance.RecordPassed();
                    return true;
                }
            }

            var fallbackResult = EvaluateSpanishFallback(text, out var englishPenaltyTriggered);

            bool finalResult = fallbackResult;

            spanishTextCache.Add(text, finalResult);

            if (finalResult)
            {
                LanguageFilterStats.Instance.RecordPassed();
            }
            else
            {
                LanguageFilterStats.Instance.RecordFiltered("spanish");
            }

            return finalResult;

            bool EvaluateSpanishFallback(string input, out bool englishPenalty)
            {
                var textLower = input.ToLowerInvariant();
                var spanishKeywordScore = 0;
                int stopwordMatches = 0;

                if (spanishChars.Any(c => textLower.IndexOf(c) >= 0)) spanishKeywordScore += 3;
                if (textLower.Contains("español") || textLower.Contains("spanish") || textLower.Contains("castellano")) spanishKeywordScore += 3;
                if (input.IndexOf('¡') >= 0 || input.IndexOf('¿') >= 0) spanishKeywordScore += 3;

                var tokens = textLower.Split(spanishWordSeparators, StringSplitOptions.RemoveEmptyEntries);

                foreach (var token in tokens)
                {
                    if (spanishStopwords.Contains(token))
                    {
                        stopwordMatches++;
                    }

                    if (spanishCommonTokens.Contains(token))
                    {
                        spanishKeywordScore++;
                        continue;
                    }

                    foreach (var suffix in spanishCommonSuffixes)
                    {
                        if (token.EndsWith(suffix, StringComparison.Ordinal))
                        {
                            spanishKeywordScore++;
                            break;
                        }
                    }
                }

                if (stopwordMatches >= 7)
                {
                    spanishKeywordScore += 6;
                }
                else if (stopwordMatches >= 5)
                {
                    spanishKeywordScore += 4;
                }
                else if (stopwordMatches >= 3)
                {
                    spanishKeywordScore += 2;
                }

                // Frases frecuentes en español (se evalúan sobre una cadena acolchada para capturar límites de palabra)
                var padded = " " + textLower + " ";
                var spanishPatterns = new (string Pattern, int Score)[]
                {
                    (" que ", 4),
                    (" de ", 3),
                    (" del ", 5),
                    (" los ", 3),
                    (" las ", 3),
                    (" en ", 2),
                    (" por ", 3),
                    (" para ", 4),
                    (" con ", 2),
                    (" sin ", 3),
                    (" una ", 2),
                    (" uno ", 1),
                    (" esta ", 2),
                    (" este ", 2),
                    (" ese ", 2),
                    (" esa ", 2),
                    (" sobre ", 3),
                    (" entre ", 3),
                    (" hasta ", 3),
                    (" donde ", 4),
                    (" cuando ", 4),
                    (" porque ", 4),
                    (" aunque ", 3),
                    (" mientras ", 3)
                };

                foreach (var (pattern, score) in spanishPatterns)
                {
                    int index = padded.IndexOf(pattern, StringComparison.Ordinal);
                    while (index >= 0)
                    {
                        spanishKeywordScore += score;
                        index = padded.IndexOf(pattern, index + pattern.Length, StringComparison.Ordinal);
                    }
                }

                var englishCount = tokens.Count(t => englishPenaltyTokens.Contains(t));
                englishPenalty = (spanishKeywordScore < 2 && englishCount >= 4)
                    || (spanishKeywordScore < 3 && englishCount >= 2 && stopwordMatches == 0);
                if (englishPenalty)
                {
                    return false;
                }

                if (stopwordMatches >= 6)
                {
                    return true;
                }

                double stopwordRatio = tokens.Length > 0 ? (double)stopwordMatches / tokens.Length : 0;
                if (stopwordRatio >= 0.02 && stopwordMatches >= 3)
                {
                    return true;
                }

                if (textLower.Length < 300 && spanishKeywordScore >= 2)
                {
                    return true;
                }

                return spanishKeywordScore >= 3;
            }
        }

        private bool IsSpanishFileByContent(string filePath, bool useCache = true)
        {
            if (string.IsNullOrWhiteSpace(filePath) || !File.Exists(filePath))
                return false;

            if (useCache && spanishFileContentCache.TryGetValue(filePath, out var cached))
                return cached;

            try
            {
                bool isSpanish;
                string? sample = null;

                if (RustCore.IsAvailable())
                {
                    isSpanish = RustCore.IsSpanishFile(filePath);
                    if (!isSpanish)
                    {
                        sample = RustCore.ExtractTextSample(filePath, CONTENT_SAMPLE_MAX_CHARS);
                        if (string.IsNullOrWhiteSpace(sample))
                        {
                            sample = ExtractTextSampleForLanguageDetection(filePath, CONTENT_SAMPLE_MAX_CHARS);
                        }

                        if (!string.IsNullOrWhiteSpace(sample))
                        {
                            try
                            {
                                isSpanish = RustCore.IsSpanishText(sample);
                            }
                            catch
                            {
                                isSpanish = false;
                            }

                            if (!isSpanish)
                            {
                                isSpanish = IsSpanishText(sample, allowRust: false);
                            }
                        }
                    }
                }
                else
                {
                    sample = ExtractTextSampleForLanguageDetection(filePath, CONTENT_SAMPLE_MAX_CHARS);

                    if (string.IsNullOrWhiteSpace(sample))
                    {
                        AutoLog($"⚠️ No se pudo extraer contenido legible de '{Path.GetFileName(filePath)}'; se marcará como NO español.");
                        isSpanish = false;
                    }
                    else
                    {
                        isSpanish = IsSpanishText(sample);
                    }
                }

                if (!isSpanish && !string.IsNullOrWhiteSpace(sample))
                {
                    // Intento final con heurística sobre sample extraído por métodos propios
                    isSpanish = IsSpanishText(sample, allowRust: false);
                }

                spanishFileContentCache[filePath] = isSpanish;
                return isSpanish;
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error analizando contenido de '{Path.GetFileName(filePath)}': {ex.Message}");
                spanishFileContentCache[filePath] = false;
                return false;
            }
        }

        private string ExtractTextSampleForLanguageDetection(string filePath, int maxChars)
        {
            var extension = Path.GetExtension(filePath) ?? string.Empty;

            if (textContentExtensions.Contains(extension))
            {
                return ReadTextFileSample(filePath, maxChars);
            }

            if (zipContentExtensions.Contains(extension))
            {
                return ExtractTextFromZipDocument(filePath, maxChars);
            }

            if (extension.Equals(".pdf", StringComparison.OrdinalIgnoreCase))
            {
                return ExtractPdfLikeSample(filePath, maxChars);
            }

            if (extension.Equals(".mobi", StringComparison.OrdinalIgnoreCase) || extension.Equals(".azw3", StringComparison.OrdinalIgnoreCase))
            {
                return ExtractPrintableBytesSample(filePath, maxChars);
            }

            // Fallback genérico
            return ExtractPrintableBytesSample(filePath, maxChars);
        }

        private static string ReadTextFileSample(string filePath, int maxChars)
        {
            try
            {
                using var reader = new StreamReader(filePath, Encoding.UTF8, detectEncodingFromByteOrderMarks: true, bufferSize: 8192);
                var buffer = new char[Math.Min(maxChars, 8192)];
                var sb = new StringBuilder(Math.Min(maxChars, 8192));
                int read;
                while ((read = reader.Read(buffer, 0, Math.Min(buffer.Length, maxChars - sb.Length))) > 0)
                {
                    sb.Append(buffer, 0, read);
                    if (sb.Length >= maxChars)
                        break;
                }

                return sb.ToString();
            }
            catch
            {
                return string.Empty;
            }
        }

        private static string ExtractTextFromZipDocument(string filePath, int maxChars)
        {
            try
            {
                using var archive = ZipFile.OpenRead(filePath);
                ZipArchiveEntry selectedEntry = null;

                foreach (var entry in archive.Entries.OrderBy(e => e.FullName.Length))
                {
                    var entryExtension = Path.GetExtension(entry.FullName);
                    if (zipPreferredEntryExtensions.Contains(entryExtension))
                    {
                        selectedEntry = entry;
                        break;
                    }

                    if (string.IsNullOrEmpty(entryExtension) && selectedEntry == null)
                    {
                        selectedEntry = entry;
                    }
                }

                if (selectedEntry == null)
                    return string.Empty;

                using var entryStream = selectedEntry.Open();
                using var reader = new StreamReader(entryStream, Encoding.UTF8, detectEncodingFromByteOrderMarks: true, bufferSize: 8192);
                var buffer = new char[Math.Min(maxChars, 8192)];
                var sb = new StringBuilder(Math.Min(maxChars, 8192));
                int read;

                while ((read = reader.Read(buffer, 0, Math.Min(buffer.Length, maxChars - sb.Length))) > 0)
                {
                    sb.Append(buffer, 0, read);
                    if (sb.Length >= maxChars)
                        break;
                }

                return StripMarkup(sb.ToString());
            }
            catch
            {
                return string.Empty;
            }
        }

        private static string ExtractPdfLikeSample(string filePath, int maxChars)
        {
            try
            {
                using var stream = new FileStream(filePath, FileMode.Open, FileAccess.Read, FileShare.Read);
                int bufferSize = (int)Math.Min(stream.Length, CONTENT_SAMPLE_MAX_BYTES);
                bufferSize = Math.Min(bufferSize, maxChars * 8);

                var buffer = new byte[bufferSize];
                var read = stream.Read(buffer, 0, buffer.Length);

                if (read == 0)
                    return string.Empty;

                var combined = new StringBuilder(Math.Min(maxChars, 8192));

                combined.Append(ExtractPrintableBytes(buffer, read, maxChars));

                if (combined.Length < maxChars)
                {
                    var remaining = maxChars - combined.Length;
                    combined.Append(ExtractPdfStreamsText(buffer, read, remaining));
                }

                return combined.ToString();
            }
            catch
            {
                return string.Empty;
            }
        }

        private static string ExtractPrintableBytesSample(string filePath, int maxChars)
        {
            try
            {
                using var stream = new FileStream(filePath, FileMode.Open, FileAccess.Read, FileShare.Read);
                int bufferSize = (int)Math.Min(stream.Length, CONTENT_SAMPLE_MAX_BYTES);
                bufferSize = Math.Min(bufferSize, maxChars * 4);

                var buffer = new byte[bufferSize];
                var read = stream.Read(buffer, 0, buffer.Length);

                return ExtractPrintableBytes(buffer, read, maxChars);
            }
            catch
            {
                return string.Empty;
            }
        }

        private static string ExtractPrintableBytes(byte[] buffer, int count, int maxChars)
        {
            var sb = new StringBuilder(Math.Min(maxChars, 8192));
            for (int i = 0; i < count && sb.Length < maxChars; i++)
            {
                byte current = buffer[i];
                if (current == 0x0A || current == 0x0D || current == 0x09)
                {
                    sb.Append(' ');
                    continue;
                }

                if (current >= 32 && current <= 126)
                {
                    sb.Append((char)current);
                }
            }

            return sb.ToString();
        }

        private void RestoreListViewLayout(string prefix, ListView? listView)
        {
            if (listView == null || listView.Columns.Count == 0)
            {
                return;
            }

            try
            {
                var widths = configManager.GetValue<List<int>>($"{prefix}ColumnWidths", new List<int>());
                var order = configManager.GetValue<List<int>>($"{prefix}ColumnOrder", new List<int>());

                if (widths != null && widths.Count == listView.Columns.Count)
                {
                    const int minColumnWidth = 30;
                    for (int i = 0; i < widths.Count; i++)
                    {
                        listView.Columns[i].Width = Math.Max(widths[i], minColumnWidth);
                    }
                }

                if (order != null && order.Count == listView.Columns.Count)
                {
                    for (int i = 0; i < order.Count; i++)
                    {
                        listView.Columns[i].DisplayIndex = order[i];
                    }
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ No se pudo restaurar layout de {prefix}: {ex.Message}");
            }
        }

