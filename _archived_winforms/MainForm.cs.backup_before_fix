                }
                lvAutoAuthors.Columns[i].Text = header;
            }

            // Recargar items en modo normal
            RefreshAuthorsListView();
        }
        
        private List<AuthorData> FilterAuthorsInternal(List<AuthorData> authors, string searchText)
        {
            if (string.IsNullOrWhiteSpace(searchText))
                return authors;

            try
            {
                if (SlskDown.Core.RustSearchIndex.IsRustAvailable() && authorSearchIndex == null)
                {
                    IndexAuthorsForSearch();
                }

                if (authorSearchIndex != null)
                {
                    var matches = SearchAuthorIntelligentSilent(searchText.Trim());
                    if (matches.Count > 0)
                    {
                        var matchSet = new HashSet<string>(matches, StringComparer.OrdinalIgnoreCase);
                        return authors.Where(a => matchSet.Contains(a.Name)).ToList();
                    }
                }
            }
            catch
            {
            }

            var search = searchText.ToLowerInvariant();
            return authors.Where(a => a.Name.ToLowerInvariant().Contains(search)).ToList();
        }

