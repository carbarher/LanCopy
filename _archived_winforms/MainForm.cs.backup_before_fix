        private DateTime lastUpdateTime = DateTime.MinValue;
        private const int UPDATE_THROTTLE_MS = 500; // Actualizar UI máximo cada 500ms
        private const int DOWNLOADS_VIRTUAL_MODE_THRESHOLD = 500;
        
        /// <summary>
        /// Actualiza los resultados de búsqueda usando Virtual ListView cuando >1000 items
        /// </summary>
        private void UpdateSearchResults(List<SearchResultItem> items)
        {
            // Throttling: solo actualizar si han pasado 500ms desde la última actualización
            var now = DateTime.Now;
            if ((now - lastUpdateTime).TotalMilliseconds < UPDATE_THROTTLE_MS)
            {
                return; // Saltar esta actualización para no saturar el UI thread
            }
            lastUpdateTime = now;

            var totalCount = items?.Count ?? 0;
            var uiLimit = responseLimit > 0 ? Math.Min(responseLimit, totalCount) : totalCount;
            if (uiLimit < totalCount)
            {
                items = items.Take(uiLimit).ToList();
            }
            
            SafeInvokeBlocking(() =>
            {
                const int VIRTUAL_MODE_THRESHOLD = 1000;
                bool useVirtualMode = items.Count > VIRTUAL_MODE_THRESHOLD;

                if (useVirtualMode && !lvResults.VirtualMode)
                {
                    lvResults.BeginUpdate();
                    lvResults.Items.Clear();
                    lvResults.VirtualMode = true;
                    lvResults.EndUpdate();
                }
                else if (!useVirtualMode && lvResults.VirtualMode)
                {
                    lvResults.BeginUpdate();
                    lvResults.VirtualMode = false;
                    lvResults.Items.Clear();
                    lvResults.EndUpdate();
                }

                if (useVirtualMode)
                {
                    virtualResultsCache.Clear();
                    lvResults.VirtualListSize = items.Count;
                    lvResults.Invalidate();
                    lblResultsCount.Text = totalCount == items.Count
                        ? $"{items.Count:N0} archivos (modo virtual)"
                        : $"{items.Count:N0} / {totalCount:N0} archivos (modo virtual)";
                }
                else
                {
                    // Suspender redibujado durante actualización masiva
                    lvResults.BeginUpdate();
                    try
                    {
                        lvResults.Items.Clear();
                        
                        // Crear array de items para agregar en batch
                        var listItems = new ListViewItem[items.Count];
                        for (int i = 0; i < items.Count; i++)
                        {
                            listItems[i] = CreateSearchResultListItem(items[i]);
                        }
                        
                        // Agregar todos los items de una vez (más rápido que Add individual)
                        lvResults.Items.AddRange(listItems);
                        lblResultsCount.Text = totalCount == items.Count
                            ? $"{items.Count:N0} archivos"
                            : $"{items.Count:N0} / {totalCount:N0} archivos";
                    }
                    finally
                    {
                        lvResults.EndUpdate();
                    }

                    lvResults.Invalidate();
                }

                if (totalCount > items.Count && lblStatus != null)
                {
                    lblStatus.Text = $"Mostrando {items.Count:N0} de {totalCount:N0} (limitado por ResponseLimit)";
                }
            });
        }

        private ListViewItem CreateSearchResultListItem(SearchResultItem item)
        {
            var listItem = new ListViewItem(item.Filename);
            listItem.SubItems.Add(item.Extension);
            listItem.SubItems.Add(item.Username);
            listItem.SubItems.Add(FormatSize(item.Size));
            listItem.SubItems.Add(item.UploadSpeed > 0 ? $"{item.UploadSpeed / 1024:F0} KB/s" : "-");
            listItem.SubItems.Add(item.FolderPath);
            listItem.Tag = item;

            try
            {
                listItem.ToolTipText = GetRankTooltipCached(item);
            }
            catch
            {
            }
            
            // Aplicar colores según calidad
            if (item.Extension.ToLower() == ".flac")
                listItem.ForeColor = Color.FromArgb(50, 255, 255);
            else if (item.Size > 100 * 1024 * 1024)
                listItem.ForeColor = Color.FromArgb(255, 80, 80);
            
            return listItem;
        }

        private string GetRankTooltipCached(SearchResultItem item)
        {
            var key = $"{item.Filename}|{item.Username}|{item.Size}|{item.Extension}|{item.UploadSpeed}|{item.QueueLength}|{item.FreeUploadSlots}";

            lock (rankTooltipCacheLock)
            {
                if (rankTooltipCache.TryGetValue(key, out var cached))
                {
                    return cached;
                }
            }

            var tooltip = BuildRankTooltip(item);

            lock (rankTooltipCacheLock)
            {
                if (rankTooltipCache.Count >= RankTooltipCacheMaxEntries)
                {
                    rankTooltipCache.Clear();
                }
                rankTooltipCache[key] = tooltip;
            }

            return tooltip;
        }

        private string BuildRankTooltip(SearchResultItem item)
        {
            var parsed = ParseFileName(item.Filename);
            var author = string.IsNullOrWhiteSpace(item.Author) ? parsed.author : item.Author;

            var candidate = new SlskDown.Core.CandidateFileInfo
            {
                FileName = item.Filename ?? string.Empty,
                Extension = string.IsNullOrWhiteSpace(item.Extension) ? Path.GetExtension(item.Filename) : item.Extension,
                Username = item.Username ?? string.Empty,
                FolderPath = item.FolderPath,
                SizeBytes = item.Size,
                UploadSpeed = item.UploadSpeed,
                QueueLength = item.QueueLength,
                FreeUploadSlots = item.FreeUploadSlots,
                Author = author,
                Network = string.IsNullOrWhiteSpace(item.Network) ? "Soulseek" : item.Network
            };

            var ranked = candidateRanker.Rank(candidate, author, parsed.title);
            var reasons = ranked.Reasons ?? new List<string>();

            var limitedReasons = reasons.Count > 12
                ? reasons.Take(12).Concat(new[] { "..." }).ToList()
                : reasons;

            var header = $"Rank: {ranked.Score:F1}/100";
            if (!string.IsNullOrWhiteSpace(author) || !string.IsNullOrWhiteSpace(parsed.title))
            {
                header += $"\nTarget: {(string.IsNullOrWhiteSpace(author) ? "?" : author)} | {(string.IsNullOrWhiteSpace(parsed.title) ? "?" : parsed.title)}";
            }

            var tooltip = header + "\n" + string.Join("\n", limitedReasons);
            return tooltip.Length > 1500 ? tooltip.Substring(0, 1500) : tooltip;
        }

        private readonly Dictionary<int, ListViewItem> virtualResultsCache = new Dictionary<int, ListViewItem>();

        private readonly object downloadVirtualLock = new object();
        private List<DownloadTask> downloadVirtualSnapshot = new List<DownloadTask>();
        private readonly Dictionary<int, ListViewItem> virtualDownloadsCache = new Dictionary<int, ListViewItem>();

        private void LvResults_RetrieveVirtualItem(object sender, RetrieveVirtualItemEventArgs e)
        {
            if (virtualResultsCache.TryGetValue(e.ItemIndex, out var cached))
            {
                e.Item = cached;
                return;
            }

            if (e.ItemIndex >= 0 && e.ItemIndex < allResults.Count)
            {
                var item = CreateSearchResultListItem(allResults[e.ItemIndex]);
                virtualResultsCache[e.ItemIndex] = item;
                e.Item = item;
            }
        }

        private void LvResults_CacheVirtualItems(object sender, CacheVirtualItemsEventArgs e)
        {
            if (virtualResultsCache.Count > 0 &&
                e.StartIndex >= virtualResultsCache.Keys.Min() &&
                e.EndIndex <= virtualResultsCache.Keys.Max())
            {
                return;
            }

            virtualResultsCache.Clear();

            for (int i = e.StartIndex; i <= e.EndIndex && i < allResults.Count; i++)
            {
                if (!virtualResultsCache.ContainsKey(i))
                {
                    virtualResultsCache[i] = CreateSearchResultListItem(allResults[i]);
                }
            }
        }

        private void LvDownloads_RetrieveVirtualItem(object sender, RetrieveVirtualItemEventArgs e)
        {
            if (virtualDownloadsCache.TryGetValue(e.ItemIndex, out var cached))
            {
                e.Item = cached;
                return;
            }

            DownloadTask task;
            lock (downloadVirtualLock)
            {
                if (e.ItemIndex < 0 || e.ItemIndex >= downloadVirtualSnapshot.Count)
                {
                    return;
                }
                task = downloadVirtualSnapshot[e.ItemIndex];
            }

            var item = CreateDownloadListViewItem(task);
            virtualDownloadsCache[e.ItemIndex] = item;
            e.Item = item;
        }

        private void LvDownloads_CacheVirtualItems(object sender, CacheVirtualItemsEventArgs e)
        {
            lock (downloadVirtualLock)
            {
                virtualDownloadsCache.Clear();
                for (int i = e.StartIndex; i <= e.EndIndex && i < downloadVirtualSnapshot.Count; i++)
                {
                    if (!virtualDownloadsCache.ContainsKey(i))
                    {
                        virtualDownloadsCache[i] = CreateDownloadListViewItem(downloadVirtualSnapshot[i]);
                    }
                }
            }
        }

        private ListViewItem CreateDownloadListViewItem(DownloadTask task)
        {
            var fileName = task?.File?.FileName ?? string.Empty;
            var username = task?.File?.Username ?? string.Empty;
            var size = task?.File?.SizeReadable ?? string.Empty;

            var progress = task != null && task.ProgressPercent > 0
                ? $"{task.ProgressPercent:F1}%"
                : "0%";

            var statusText = task == null
                ? string.Empty
                : (string.IsNullOrWhiteSpace(task.UiStatusText) ? GetStatusText(task.Status) : task.UiStatusText);

            var item = new ListViewItem(Path.GetFileName(fileName));
            item.SubItems.Add(username);
            item.SubItems.Add(progress);
            item.SubItems.Add(statusText);
            item.SubItems.Add(size);
            item.Tag = task;

            if (task != null && task.IsDuplicate && task.Status == DownloadStatus.Completed)
            {
                item.ForeColor = Color.MediumPurple;
            }
            else
            {
                item.ForeColor = task?.Status switch
                {
                    DownloadStatus.Completed => Color.FromArgb(0, 200, 0),
                    DownloadStatus.Failed => Color.FromArgb(200, 0, 0),
                    DownloadStatus.Downloading => Color.FromArgb(100, 200, 255),
                    DownloadStatus.Paused => Color.Gray,
                    _ => Color.White
                };
            }

            return item;
        }

        private IOrderedEnumerable<DownloadTask> SortDownloadsSnapshot(IEnumerable<DownloadTask> tasks)
        {
            Func<DownloadTask, object> keySelector = lvDownloadsSortColumn switch
            {
                0 => t => Path.GetFileName(t?.File?.FileName ?? string.Empty),
                1 => t => t?.File?.Username ?? string.Empty,
                2 => t => t?.ProgressPercent ?? 0.0,
                3 => t => string.IsNullOrWhiteSpace(t?.UiStatusText) ? GetStatusText(t?.Status ?? DownloadStatus.Queued) : t.UiStatusText,
                4 => t => t?.File?.SizeBytes ?? 0,
                _ => t => Path.GetFileName(t?.File?.FileName ?? string.Empty)
            };

            return lvDownloadsSortOrder == SortOrder.Descending
                ? tasks.OrderByDescending(keySelector)
                : tasks.OrderBy(keySelector);
        }
        
        /// <summary>
        /// Agrega resultados incrementalmente
        /// </summary>
        private void AddSearchResults(List<SearchResultItem> newItems)
        {
            // Throttling: solo actualizar si han pasado 500ms desde la última actualización
            var now = DateTime.Now;
            if ((now - lastUpdateTime).TotalMilliseconds < UPDATE_THROTTLE_MS)
            {
                return; // Saltar esta actualización para no saturar el UI thread
            }
            lastUpdateTime = now;
            
            SafeInvokeBlocking(() =>
            {
                // using (PerformanceMetrics.Instance.Track("AddSearchResults"))
                {
                    // Suspender redibujado durante actualización masiva
                    lvResults.BeginUpdate();
                    try
                    {
                        // Crear array de items para agregar en batch
                        var listItems = new ListViewItem[newItems.Count];
                        for (int i = 0; i < newItems.Count; i++)
                        {
                            var item = newItems[i];
                            var listItem = new ListViewItem(item.Filename);
                            listItem.SubItems.Add(item.Extension);
                            listItem.SubItems.Add(item.Username);
                            listItem.SubItems.Add(FormatSize(item.Size));
                            listItem.SubItems.Add(item.UploadSpeed > 0 ? $"{item.UploadSpeed / 1024:F0} KB/s" : "-");
                            listItem.SubItems.Add(item.FolderPath);
                            listItem.Tag = item;

                            try
                            {
                                listItem.ToolTipText = GetRankTooltipCached(item);
                            }
                            catch
                            {
                            }
                            
                            // Aplicar colores según calidad
                            if (item.Extension.ToLower() == ".flac")
                                listItem.ForeColor = Color.FromArgb(50, 255, 255);
                            else if (item.Size > 100 * 1024 * 1024)
                                listItem.ForeColor = Color.FromArgb(255, 80, 80);
                            
                            listItems[i] = listItem;
                        }
                        
                        // Agregar todos los items de una vez (más rápido que Add individual)
                        lvResults.Items.AddRange(listItems);
                        lblResultsCount.Text = $"{lvResults.Items.Count:N0} archivos";
                    }
                    finally
                    {
                        // Reanudar redibujado
                        lvResults.EndUpdate();
                    }

                    lvResults.Invalidate();
                    lvResults.Update();
                    lvResults.Refresh();
                }
            });
        }
        
        /// <summary>
        /// Limpia los resultados de búsqueda
