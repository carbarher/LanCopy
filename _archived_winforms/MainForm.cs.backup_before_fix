        private async Task ConnectToSoulseek()
        {
            var stackTrace = new System.Diagnostics.StackTrace(1, false);
            var callerMethod = stackTrace.GetFrame(0)?.GetMethod()?.Name ?? "Unknown";
            
            lock (this)
            {
                if (isConnecting)
                {
                    Log($"⚠️ Ya hay un intento de conexión en curso - ignorando llamada desde {callerMethod}");
                    return;
                }
                isConnecting = true;
            }
            
            Log($"🔄 ConnectToSoulseek llamado desde: {callerMethod}");
            
            if (client != null && client.State.HasFlag(SoulseekClientStates.Connected))
            {
                Log("Ya está conectado");
                isConnecting = false;
                return;
            }
            
            try
            {
                // CRÍTICO: Limpiar rate limiter y cancelar búsquedas ANTES de conectar
                Log("🧹 Limpiando estado antes de conectar...");
                try
                {
                    // Cancelar búsquedas automáticas
                    if (autoSearchRunning)
                    {
                        autoSearchCts?.Cancel();
                        autoSearchRunning = false;
                    }
                    
                    // Cancelar búsquedas manuales
                    searchCancellationTokenSource?.Cancel();
                    
                    // Detener timer de wishlist
                    if (wishlistSearchTimer != null && wishlistSearchTimer.Enabled)
                    {
                        wishlistSearchTimer.Stop();
                    }
                    
                    // Detener timer de métricas
                    if (metricsUpdateTimer != null && metricsUpdateTimer.Enabled)
                    {
                        metricsUpdateTimer.Stop();
                    }
                    
                    // Limpiar rate limiter
                    lock (rateLimiterLock)
                    {
                        searchRequestTimestamps.Clear();
                    }
                    
                    Log("✅ Estado limpiado - listo para conectar");
                }
                catch (Exception ex)
                {
                    Log($"⚠️ Error limpiando estado: {ex.Message}");
                }
                
                UpdateControlEnabled(btnConnect, false);
                UpdateControlText(lblStatus, "Conectando...");
                UpdateControl(lblStatus, c => c.ForeColor = Color.Orange);
                
                if (string.IsNullOrWhiteSpace(username))
                {
                    Log("❌ Error: Usuario vacío");
                    throw new Exception("El nombre de usuario no puede estar vacío");
                }
                if (string.IsNullOrWhiteSpace(password))
                {
                    Log("❌ Error: Contraseña vacía");
                    throw new Exception("La contraseña no puede estar vacía");
                }
                
                Log($"🔐 Intentando conectar como: {username}");
                
                int maxAttempts = 5;
                bool connected = false;
                
                for (int attempt = 1; attempt <= maxAttempts && !connected; attempt++)
                {
                    try
                    {
                        if (client != null)
                        {
                            try { client.Dispose(); } catch { }
                            client = null;
                        }
                        
                        int randomPort = new Random().Next(50000, 60000);
                        Log($"Intento {attempt}/{maxAttempts} - Puerto: {randomPort}");
                        
                        var options = new SoulseekClientOptions(
                            listenPort: randomPort,
                            enableDistributedNetwork: false,
                            enableListener: true,
                            autoAcknowledgePrivateMessages: false,
                            autoAcknowledgePrivilegeNotifications: false,
                            acceptPrivateRoomInvitations: false,
                            serverConnectionOptions: new ConnectionOptions(
                                connectTimeout: 120000,
                                inactivityTimeout: int.MaxValue
                            ),
                            peerConnectionOptions: new ConnectionOptions(
                                connectTimeout: 60000,
                                inactivityTimeout: 600000
                            ),
                            transferConnectionOptions: new ConnectionOptions(
                                connectTimeout: 60000,
                                inactivityTimeout: 600000
                            ),
                            userEndPointCache: null
                        );
                        
                        // CRÍTICO: Desconectar y limpiar cliente anterior para evitar event handlers duplicados
                        if (client != null)
                        {
                            try
                            {
                                client.Disconnect("Reconnecting");
                                client.Dispose();
                            }
                            catch { /* Ignorar errores de limpieza */ }
                        }
                        
                        client = new SoulseekClient(options);
                        RefreshSearchWorkflowInstance();
                        
                        // Suscribirse a eventos de cambio de estado para detección inmediata de desconexión
                        client.StateChanged += async (sender, args) =>
                        {
                            Log($"🔌 Estado cambió: {args.PreviousState} → {args.State}");
                            
                            // MEJORA #1: Loggear excepción si existe
                            if (args.Exception != null)
                            {
                                Log($"   └─ Razón: {args.Exception.Message}");
                            }
                            
                            if (args.State == SoulseekClientStates.Disconnected)
                            {
                                // CRÍTICO: Evitar múltiples reconexiones simultáneas
                                lock (this)
                                {
                                    if (isReconnecting || isConnecting)
                                    {
                                        Log("⏸️ Reconexión ya en curso - ignorando evento de desconexión");
                                        return;
                                    }
                                    isReconnecting = true;
                                }
                                
                                // MEJORA #1: Detectar tipo de desconexión
                                var disconnectReason = DetermineDisconnectReason(args.Exception);
                                Log($"❌ DESCONEXIÓN DETECTADA - Tipo: {disconnectReason}");
                                AutoLog($"❌ DESCONEXIÓN: {disconnectReason}");
                                
                                // MEJORA #4: Guardar sesión en historial
                                if (currentSession != null)
                                {
                                    currentSession.EndTime = DateTime.Now;
                                    currentSession.DisconnectReason = disconnectReason;
                                    currentSession.DisconnectMessage = args.Exception?.Message ?? "Desconexión desconocida";
                                    connectionHistory.Add(currentSession);
                                    SaveConnectionHistory();
                                    
                                    Log($"📊 Sesión duró: {currentSession.Duration.TotalMinutes:F1} min, Búsquedas: {currentSession.SearchesPerformed}");
                                }
                                
                                // MEJORA #2: Modo degradado
                                consecutiveDisconnects++;
                                if (consecutiveDisconnects >= 2)
                                {
                                    int newRateLimit = Math.Max(2, originalMaxSearchesPerMinute - (consecutiveDisconnects * 2));
                                    if (newRateLimit != maxSearchesPerMinute)
                                    {
                                        maxSearchesPerMinute = newRateLimit;
                                        Log($"🐌 MODO DEGRADADO: Rate limit reducido a {maxSearchesPerMinute}/min ({consecutiveDisconnects} desconexiones)");
                                        AutoLog($"⚠️ Sistema en modo degradado: {maxSearchesPerMinute}/min");
                                    }
                                }
                                
                                // PAUSA INTELIGENTE: Rastrear desconexiones frecuentes
                                lock (reconnectionHistory)
                                {
                                    reconnectionHistory.Add(DateTime.Now);
                                    
                                    // Limpiar desconexiones de hace más de 1 hora
                                    var oneHourAgo = DateTime.Now.AddHours(-1);
                                    reconnectionHistory.RemoveAll(d => d < oneHourAgo);
                                    
                                    // Si hay más de 2 desconexiones en la última hora, activar pausa
                                    if (reconnectionHistory.Count >= 2)
                                    {
                                        intelligentPauseActive = true;
                                        intelligentPauseUntil = DateTime.Now.AddMinutes(15);
                                        Log($"⏸️ PAUSA INTELIGENTE ACTIVADA: {reconnectionHistory.Count} desconexiones en 1h");
                                        Log($"⏸️ Sistema pausado hasta {intelligentPauseUntil:HH:mm:ss} (15 minutos)");
                                        AutoLog($"⏸️ PAUSA INTELIGENTE: Sistema pausado 15min por {reconnectionHistory.Count} desconexiones frecuentes");
                                    }
                                }
                                
                                // CRÍTICO: Detener TODAS las búsquedas y actividades
                                try
                                {
                                    // 1. Cancelar búsquedas automáticas
                                    if (autoSearchRunning)
                                    {
                                        Log("⏸️ Cancelando búsquedas automáticas...");
                                        autoSearchCts?.Cancel();
                                        autoSearchRunning = false;
                                    }
                                    
                                    // 2. Cancelar búsquedas manuales en progreso
                                    if (searchCancellationTokenSource != null)
                                    {
                                        Log("⏸️ Cancelando búsquedas manuales...");
                                        searchCancellationTokenSource?.Cancel();
                                    }
                                    
                                    // 3. Detener timer de wishlist (búsquedas automáticas en background)
                                    if (wishlistSearchTimer != null && wishlistSearchTimer.Enabled)
                                    {
                                        Log("⏸️ Deteniendo timer de wishlist...");
                                        wishlistSearchTimer.Stop();
                                    }
                                    
                                    // 3b. Detener otros timers para asegurar que NO hay actividad
                                    if (metricsUpdateTimer != null && metricsUpdateTimer.Enabled)
                                    {
                                        metricsUpdateTimer.Stop();
                                    }
                                    
                                    // 4. Limpiar rate limiter para dar oportunidad fresca
                                    Log("🔄 Limpiando rate limiter...");
                                    lock (rateLimiterLock)
                                    {
                                        searchRequestTimestamps.Clear();
                                    }
                                    
                                    Log("✅ Todas las búsquedas canceladas - sistema listo para reconectar");
                                    
                                    // MEJORA #9: Detener heartbeat
                                    StopHeartbeat();
                                }
                                catch (Exception ex)
                                {
                                    Log($"⚠️ Error cancelando actividades: {ex.Message}");
                                }
                                
                                // MEJORA #8: Verificar si hay ban permanente
                                _ = Task.Run(async () =>
                                {
                                    if (await IsPermanentBan())
                                    {
                                        Log("⚠️ Ban detectado - pausando reconexiones");
                                        return;
                                    }
                                });
                                
                                // MEJORA #6: Verificar si reconexion automatica esta activa
                                if (chkAutoReconnect != null && !chkAutoReconnect.Checked)
                                {
                                    Log("⏸️ Reconexión automática desactivada - esperando intervención manual");
                                    
                                    SafeInvoke(() =>
                                    {
                                        ShowNotification(
                                            "Desconexión detectada",
                                            $"Razón: {disconnectReason}\nClic en 'Conectar' para reconectar manualmente",
                                            ToolTipIcon.Warning
                                        );
                                    });
                                    
                                    lock (this) { isReconnecting = false; }
                                    return;
                                }
                                
                                // Reconectar con delay variable según tipo de desconexión
                                _ = Task.Run(async () =>
                                {
                                    try
                                    {
                                        // MEJORA #1: Delay adaptativo según tipo de desconexión
                                        int delayMs = 120000; // Default: 2 minutos
                                        
                                        switch (disconnectReason)
                                        {
                                            case DisconnectReason.Timeout:
                                                delayMs = 60000; // 1 minuto (puede ser transitorio)
                                                Log("⌛ Timeout detectado - esperando 1 minuto...");
                                                break;
                                                
                                            case DisconnectReason.ServerKick:
                                            case DisconnectReason.RateLimitExceeded:
                                                delayMs = 300000; // 5 minutos (ban o rate limit)
                                                maxSearchesPerMinute = Math.Max(4, maxSearchesPerMinute - 2);
                                                Log($"🚫 Kick/RateLimit - esperando 5min y reduciendo a {maxSearchesPerMinute}/min");
                                                break;
                                                
                                            case DisconnectReason.NetworkError:
                                                delayMs = 30000; // 30 segundos (problema local)
                                                Log("🌐 Error de red - esperando 30s...");
                                                break;
                                                
                                            default:
                                                Log("⌛ Esperando 2 minutos antes de reconectar...");
                                                break;
                                        }
                                        
                                        await Task.Delay(delayMs);
                                        
                                        // MEJORA #3: Verificar conectividad antes de reconectar
                                        Log("🔍 Verificando conectividad a Internet...");
                                        while (!await CheckInternetConnectivity())
                                        {
                                            Log("❌ Sin conexión a Internet - esperando 30s...");
                                            await Task.Delay(30000);
                                        }
                                        Log("✅ Conectividad verificada");
                                        
                                        await ReconnectAsync();
                                        
                                        // Reactivar timers después de reconectar exitosamente
                                        if (wishlistAutoSearchEnabled && wishlistSearchTimer != null)
                                        {
                                            Log("▶️ Reactivando timer de wishlist después de reconexión");
                                            wishlistSearchTimer.Start();
                                        }
                                        if (metricsUpdateTimer != null)
                                        {
                                            metricsUpdateTimer.Start();
                                        }
                                        
                                        // MEJORA #9: Reiniciar heartbeat
                                        StartHeartbeat();
                                        
                                        // MEJORA #2: Resetear consecutiveDisconnects si conexión estable
                                        lastStableConnection = DateTime.Now;
                                        Log($"✅ Reconexión exitosa - verificando estabilidad en 30min");
                                        
                                        // Verificar estabilidad después de 30 minutos
                                        _ = Task.Run(async () =>
                                        {
                                            await Task.Delay(1800000); // 30 minutos
                                            
                                            if (client?.State == SoulseekClientStates.Connected)
                                            {
                                                consecutiveDisconnects = 0;
                                                maxSearchesPerMinute = originalMaxSearchesPerMinute;
                                                consecutiveSuccessfulSessions++;
                                                
                                                Log($"✅ Conexión estable 30min - rate limit restaurado a {maxSearchesPerMinute}/min");
                                                AutoLog($"✅ Sistema estable - sesión exitosa #{consecutiveSuccessfulSessions}");
                                            }
                                        });
                                    }
                                    catch (Exception ex)
                                    {
                                        Log($"❌ Error en reconexión automática: {ex.Message}");
                                    }
                                    finally
                                    {
                                        lock (this)
                                        {
                                            isReconnecting = false;
                                        }
                                    }
                                });
                            }
                        };
                        
                        Log($"🔐 Iniciando ConnectAsync con usuario: {username} (longitud: {username.Length})");
                        Log($"🔐 Password longitud: {password?.Length ?? 0} caracteres");
                        Log($"⏱️  Timeout configurado: 180 segundos");
                        
                        using (var cts = new CancellationTokenSource(TimeSpan.FromSeconds(180)))
                        {
                            try
                            {
                                await client.ConnectAsync(username, password, cts.Token);
                                Log($"✅ ConnectAsync completado exitosamente");
                            }
                            catch (Exception ex)
                            {
                                Log($"❌ ConnectAsync falló: {ex.GetType().Name} - {ex.Message}");
                                if (ex.InnerException != null)
                                {
                                    Log($"   └─ InnerException: {ex.InnerException.Message}");
                                }
                                throw;
                            }
                        }
                        
                        Log($"✅ Conexión exitosa en puerto {randomPort}");
                        AutoLog($"✅ CONECTADO A SOULSEEK - Usuario: {username}");
                        
                        // Inicializar Bloom Filters para deduplicación ultra-rápida
                        if (useBloomFilterForDedup && RustCore.IsAvailable())
                        {
                            try
                            {
                                // Crear Bloom Filter para archivos descargados (100k capacidad, 1% FPP)
                                downloadedFilesBloomFilter = RustCore.BloomCreate(100000, 0.01);
                                
                                // Cargar archivos ya descargados
                                if (System.IO.Directory.Exists(downloadDir))
                                {
                                    var downloadedFiles = System.IO.Directory.GetFiles(downloadDir)
                                        .Select(f => Path.GetFileName(f))
                                        .ToList();
                                    
                                    if (downloadedFiles.Count > 0)
                                    {
                                        RustCore.BloomInsertBatch(downloadedFilesBloomFilter, downloadedFiles);
                                        Log($"✅ Bloom Filter inicializado: {downloadedFiles.Count} archivos cargados");
                                    }
                                }
                                
                                // Crear Bloom Filter para archivos procesados (se resetea en cada búsqueda)
                                processedFilesBloomFilter = RustCore.BloomCreate(100000, 0.01);
                                
                                Log("🦀 Bloom Filters activados (200x más rápido que HashSet)");
                                
                                // Inicializar cache CRC32 de forma asíncrona (no bloqueante)
                                _ = Task.Run(async () => await InitializeCRC32Cache());
                            }
                            catch (Exception ex)
                            {
                                Log($"⚠️ Error inicializando Bloom Filters: {ex.Message}. Usando HashSet normal.");
                                useBloomFilterForDedup = false;
                            }
                        }
                        
                        UpdateControlText(btnConnect, "Desconectar");
                        UpdateControlEnabled(btnConnect, true);
                        UpdateControlEnabled(btnSearch, true);
                        UpdateControlText(lblStatus, "Conectado");
                        UpdateControl(lblStatus, c => c.ForeColor = Color.FromArgb(0, 200, 0));
                        
                        // Reactivar timer de métricas después de conectar
                        if (metricsUpdateTimer != null)
                        {
                            metricsUpdateTimer.Start();
                        }
                        
                        // MEJORA #4: Iniciar nueva sesión de conexión
                        currentSession = new ConnectionSession
                        {
                            StartTime = DateTime.Now,
                            SearchesPerformed = 0,
                            DownloadsPerformed = 0
                        };
                        Log($"📊 Nueva sesión iniciada: {currentSession.StartTime:HH:mm:ss}");
                        
                        // MEJORA #9: Iniciar heartbeat para detectar conexiones zombies
                        StartHeartbeat();
                        
                        // MEJORA #5: Iniciar monitor de salud de conexión
                        _ = Task.Run(async () => await MonitorConnectionHealth());
                        
                        connected = true;
                    }
                    catch (Exception ex)
                    {
                        client?.Dispose();
                        client = null;
                        
                        if (attempt < maxAttempts)
                        {
                            Log($"❌ Intento {attempt} falló: {ex.Message}");
                            
                            if (ex.Message.Contains("Invalid credentials") || ex.Message.Contains("Login failed"))
                            {
                                Log("⚠️ Error de autenticación");
                                throw;
                            }
                            
                            // Delay exponencial MUY agresivo: 30s, 60s, 90s, 120s
                            // Esto es necesario porque Soulseek banea IPs con intentos rápidos
                            int delaySeconds = attempt * 30;
                            Log($"⏳ Esperando {delaySeconds}s antes del siguiente intento (evitar ban del servidor)...");
                            Log($"💡 TIP: Si todos los intentos fallan, espera 5-10 minutos antes de reiniciar");
                            await Task.Delay(delaySeconds * 1000);
                        }
                        else
                        {
                            Log($"❌ Error final de conexión: {ex.Message}");
                            UpdateControlText(btnConnect, "Conectar");
                            UpdateControlEnabled(btnConnect, true);
                            UpdateControlText(lblStatus, "Error de conexión");
                            MessageBox.Show($"Error de conexión: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                        }
                    }
                }
            }
            finally
            {
                isConnecting = false;
            }
        }

        private async Task ConnectAsync()
        {
            if (client != null && client.State.HasFlag(SoulseekClientStates.Connected))
            {
                // Desconectar
                client.Dispose();
                client = null;
                searchWorkflow = null;
                
                // Optimización #8: Limpiar pool de conexiones
                if (connectionPool != null)
                {
                    connectionPool.Dispose();
                    connectionPool = null;
                    AutoLog("🔌 Pool de conexiones cerrado");
                }
                
                if (btnConnect != null) btnConnect.Text = "Conectar";
                if (btnSearch != null) btnSearch.Enabled = false;
                if (lblStatus != null)
                {
                    lblStatus.Text = "Desconectado";
                    lblStatus.ForeColor = Color.Gray;
                }
                Log("Desconectado manualmente");
            }
            else
            {
                // Conectar
                await ConnectToSoulseek();
            }
        }
        
        private static DateTime lastReconnectTime = DateTime.MinValue;
        private static int reconnectCount = 0;
        private const int MAX_RECONNECT_PER_MINUTE = 3;
        
        private async Task ReconnectAsync()
        {
            // Rate limiting para reconexiones (máximo 3 por minuto)
            var timeSinceLastReconnect = (DateTime.Now - lastReconnectTime).TotalSeconds;
            
            if (timeSinceLastReconnect < 20 && reconnectCount >= MAX_RECONNECT_PER_MINUTE)
            {
                Log($"⏳ Reconexión rate limited - esperando {60 - timeSinceLastReconnect:F0}s");
                return;
            }
            
            // Resetear contador si pasó más de 1 minuto
            if (timeSinceLastReconnect >= 60)
            {
                reconnectCount = 0;
            }
            
            reconnectCount++;
            lastReconnectTime = DateTime.Now;
            
            Log($"🔄 Reconectando... (intento {reconnectCount}/{MAX_RECONNECT_PER_MINUTE})");
            
            try
            {
                await ConnectToSoulseek();
                Log("✅ Reconexión exitosa");
                AutoLog("✅ Reconexión exitosa");
                reconnectCount = 0; // Resetear en éxito
            }
            catch (Exception ex)
            {
                Log($"❌ Error en reconexión: {ex.Message}");
                
                // Si falló, esperar más tiempo antes del siguiente intento
                if (reconnectCount >= MAX_RECONNECT_PER_MINUTE)
                {
                    Log($"⏸️ Máximo de reconexiones alcanzado - esperando 1 minuto");
                }
            }
        }
        
        // MEJORA #1: Detectar tipo de desconexión
        private DisconnectReason DetermineDisconnectReason(Exception ex)
        {
            if (ex == null) return DisconnectReason.Unknown;
            
            var message = ex.Message?.ToLower() ?? "";
            var innerMessage = ex.InnerException?.Message?.ToLower() ?? "";
            var fullMessage = message + " " + innerMessage;
            
            if (fullMessage.Contains("timeout") || fullMessage.Contains("timed out"))
                return DisconnectReason.Timeout;
            
            if (fullMessage.Contains("kicked") || fullMessage.Contains("banned") || fullMessage.Contains("rejected"))
                return DisconnectReason.ServerKick;
            
            if (fullMessage.Contains("rate limit") || fullMessage.Contains("too many") || fullMessage.Contains("flood"))
                return DisconnectReason.RateLimitExceeded;
            
            if (fullMessage.Contains("authentication") || fullMessage.Contains("credentials") || fullMessage.Contains("login failed"))
                return DisconnectReason.AuthenticationFailed;
            
            if (fullMessage.Contains("network") || fullMessage.Contains("connection reset") || fullMessage.Contains("no route"))
                return DisconnectReason.NetworkError;
            
            return DisconnectReason.Unknown;
        }
        
