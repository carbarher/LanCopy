        private sealed class AlternativesCacheEntry
        {
            public required List<AutoSearchFileResult> Candidates { get; init; }
            public required DateTime ExpiresUtc { get; init; }
        }

        private readonly ConcurrentDictionary<string, AlternativesCacheEntry> alternativesCache = new ConcurrentDictionary<string, AlternativesCacheEntry>(StringComparer.OrdinalIgnoreCase);
        private readonly ConcurrentDictionary<string, Lazy<Task<List<AutoSearchFileResult>>>> alternativesInFlight = new ConcurrentDictionary<string, Lazy<Task<List<AutoSearchFileResult>>>>(StringComparer.OrdinalIgnoreCase);
        private static readonly TimeSpan AlternativesCacheTtl = TimeSpan.FromSeconds(90);
        private static readonly TimeSpan AlternativesNegativeCacheTtl = TimeSpan.FromSeconds(45);

        private static string BuildAlternativesCacheKey(AutoSearchFileResult file)
        {
            return $"{file.FileName}|{file.SizeBytes}";
        }

        private async Task<SearchAlternativesResult> SearchAlternativesAsync(DownloadTask failedTask)
        {
            if (failedTask?.File == null)
            {
                return new SearchAlternativesResult
                {
                    Success = false,
                    FailureReason = "Tarea inválida"
                };
            }

            var cacheKey = BuildAlternativesCacheKey(failedTask.File);
            if (alternativesCache.TryGetValue(cacheKey, out var cached) && cached.ExpiresUtc > DateTime.UtcNow)
            {
                var resultFromCache = BuildAlternativesResultFromCandidates(failedTask, cached.Candidates);
                if (resultFromCache != null)
                {
                    return resultFromCache;
                }
            }

            try
            {
                var lazy = alternativesInFlight.GetOrAdd(cacheKey, _ => new Lazy<Task<List<AutoSearchFileResult>>>(() => FetchAlternativesCandidatesAsync(failedTask)));
                List<AutoSearchFileResult> candidates;
                try
                {
                    candidates = await lazy.Value;
                }
                finally
                {
                    alternativesInFlight.TryRemove(cacheKey, out _);
                }

                alternativesCache[cacheKey] = new AlternativesCacheEntry
                {
                    Candidates = candidates,
                    ExpiresUtc = DateTime.UtcNow.Add(candidates.Count > 0 ? AlternativesCacheTtl : AlternativesNegativeCacheTtl)
                };

                var result = BuildAlternativesResultFromCandidates(failedTask, candidates);
                if (result != null)
                {
                    return result;
                }

                AutoLog($"❌ No se encontraron alternativas para: {failedTask.File.FileName}");
                return new SearchAlternativesResult
                {
                    Success = false,
                    FailureReason = "Sin alternativas disponibles"
                };
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error buscando proveedor alternativo: {ex.Message}");
                return new SearchAlternativesResult
                {
                    Success = false,
                    FailureReason = ex.Message
                };
            }
        }

        private SearchAlternativesResult? BuildAlternativesResultFromCandidates(DownloadTask failedTask, List<AutoSearchFileResult> candidates)
        {
            if (failedTask?.File == null)
            {
                return null;
            }

            if (candidates == null || candidates.Count == 0)
            {
                return null;
            }

            var filtered = candidates
                .Where(c => c != null)
                .Where(c => !string.IsNullOrWhiteSpace(c.Username))
                .Where(c => !c.Username.Equals(failedTask.File.Username, StringComparison.OrdinalIgnoreCase))
                .Where(c => c.FileName.Equals(failedTask.File.FileName, StringComparison.OrdinalIgnoreCase))
                .Where(c => Math.Abs(c.SizeBytes - failedTask.File.SizeBytes) < 1024 * 100)
                .Where(c =>
                {
                    lock (providerBlacklist)
                    {
                        if (providerBlacklist.TryGetValue(c.Username, out var data) &&
                            data.failures >= PROVIDER_BLACKLIST_THRESHOLD &&
                            (DateTime.Now - data.lastFail).TotalHours < PROVIDER_BLACKLIST_HOURS)
                        {
                            return false;
                        }
                    }
                    return true;
                })
                .ToList();

            if (filtered.Count == 0)
            {
                return null;
            }

            var best = filtered
                .OrderByDescending(c =>
                {
                    var stats = GetProviderStats(c.Username);
                    return stats != null ? stats.QualityScore : 0;
                })
                .ThenByDescending(c => c.SizeBytes)
                .First();

            AutoLog($"✅ Alternativa encontrada: {best.Username}");
            return new SearchAlternativesResult
            {
                Success = true,
                Alternative = best,
                Candidates = filtered
            };
        }

        private async Task<List<AutoSearchFileResult>> FetchAlternativesCandidatesAsync(DownloadTask failedTask)
        {
            if (failedTask?.File == null)
            {
                return new List<AutoSearchFileResult>();
            }

            AutoLog($"🔍 Buscando proveedor alternativo para: {failedTask.File.FileName}");
            await WaitForRateLimitAsync("alt-provider");

            var searchClient = client;
            if (searchClient == null)
            {
                return new List<AutoSearchFileResult>();
            }

            var searchResults = await searchClient.SearchAsync(
                SearchQuery.FromText(failedTask.File.FileName),
                options: new Soulseek.SearchOptions(
                    searchTimeout: 15000,
                    filterResponses: true,
                    minimumResponseFileCount: 1));

            var candidates = searchResults.Responses
                .SelectMany(response => response.Files.Select(file => new
                {
                    Response = response,
                    File = file
                }))
                .Where(item =>
                    item.File.Filename.Equals(failedTask.File.FileName, StringComparison.OrdinalIgnoreCase) &&
                    Math.Abs(item.File.Size - failedTask.File.SizeBytes) < 1024 * 100)
                .Select(item => new AutoSearchFileResult
                {
                    Author = failedTask.File.Author,
                    Username = item.Response.Username,
                    FileName = item.File.Filename,
                    Directory = Path.GetDirectoryName(item.File.Filename) ?? string.Empty,
                    SizeBytes = item.File.Size,
                    SizeReadable = FormatFileSize(item.File.Size),
                    IsSpanish = failedTask.File.IsSpanish,
                    IsDocument = failedTask.File.IsDocument,
                    Timestamp = DateTime.Now
                })
                .ToList();

            return candidates;
        }

