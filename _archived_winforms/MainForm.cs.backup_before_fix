        private void RecalculateDuplicateGroups(List<AuthorData> authorData)
        {
            var duplicates = new List<AuthorNormalizer.AuthorDuplicateGroup>();
            var duplicateMembers = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            var seenGroupKeys = new HashSet<string>(StringComparer.Ordinal);

            // 1. Agrupar por NormalizedName almacenado en BD para detectar duplicados exactos sin FFI
            var normalizedGroups = authorData
                .Where(a => !string.IsNullOrWhiteSpace(a.NormalizedName))
                .GroupBy(a => a.NormalizedName!, StringComparer.OrdinalIgnoreCase);

            foreach (var group in normalizedGroups)
            {
                var members = group
                    .Select(a => a.Name)
                    .Where(name => !string.IsNullOrWhiteSpace(name))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .OrderBy(name => name, StringComparer.OrdinalIgnoreCase)
                    .ToArray();

                if (members.Length < 2)
                {
                    continue;
                }

                var groupKey = string.Join("|", members);
                if (!seenGroupKeys.Add(groupKey))
                {
                    continue;
                }

                duplicates.Add(new AuthorNormalizer.AuthorDuplicateGroup
                {
                    NormalizedKey = group.Key,
                    Members = members
                });

                foreach (var member in members)
                {
                    duplicateMembers.Add(member);
                }
            }

            // 2. Enviar sólo candidatos restantes al motor Rust para similitud difusa
            var rustCandidates = authorData
                .Where(a => !duplicateMembers.Contains(a.Name))
                .Select(a => a.Name)
                .Where(name => !string.IsNullOrWhiteSpace(name))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (rustCandidates.Count > 1)
            {
                var fuzzyGroups = AuthorNormalizer.FindDuplicateGroups(rustCandidates);

                foreach (var group in fuzzyGroups)
                {
                    var members = group.Members
                        .Where(name => !string.IsNullOrWhiteSpace(name))
                        .Distinct(StringComparer.OrdinalIgnoreCase)
                        .OrderBy(name => name, StringComparer.OrdinalIgnoreCase)
                        .ToArray();

                    if (members.Length < 2)
                    {
                        continue;
                    }

                    var groupKey = string.Join("|", members);
                    if (!seenGroupKeys.Add(groupKey))
                    {
                        continue;
                    }

                    duplicates.Add(new AuthorNormalizer.AuthorDuplicateGroup
                    {
                        NormalizedKey = string.IsNullOrWhiteSpace(group.NormalizedKey)
                            ? AuthorNormalizer.Normalize(members[0])
                            : group.NormalizedKey,
                        Members = members
                    });

                    foreach (var member in members)
                    {
                        duplicateMembers.Add(member);
                    }
                }
            }

            duplicateAuthorGroups = duplicates
                .OrderByDescending(g => g.Members.Count)
                .ThenBy(g => g.NormalizedKey, StringComparer.OrdinalIgnoreCase)
                .ToList();

            duplicateAuthorTotalCount = duplicateAuthorGroups.Sum(group => group.Members.Count);

            foreach (var author in authorData)
            {
                author.IsPotentialDuplicate = duplicateMembers.Contains(author.Name);
            }

            SafeInvoke(UpdateAuthorCount);
        }

        private async Task MergeDuplicateGroupAsync(AuthorNormalizer.AuthorDuplicateGroup group)
        {
            if (group == null || group.Members.Count < 2)
            {
                return;
            }

            var canonicalName = group.Members
                .OrderByDescending(name => IsCanonicalAuthorName(name))
                .ThenBy(name => name.Length)
                .ThenBy(name => name, StringComparer.OrdinalIgnoreCase)
                .First();

            var namesToMerge = group.Members
                .Where(name => !string.Equals(name, canonicalName, StringComparison.OrdinalIgnoreCase))
                .ToList();

            if (namesToMerge.Count == 0)
            {
                return;
            }

            var confirmationMessage = "Se fusionarán los siguientes autores en '" + canonicalName + "':\n\n" + string.Join("\n", namesToMerge);
            var confirmResult = MessageBox.Show(confirmationMessage, "Confirmar fusión", MessageBoxButtons.YesNo, MessageBoxIcon.Question);
            if (confirmResult != DialogResult.Yes)
            {
                return;
            }

            try
            {
                foreach (var name in namesToMerge)
                {
                    if (authorIndex.TryGetValue(name, out var authorData))
                    {
                        authorData.Name = canonicalName;
                        authorData.IsPotentialDuplicate = false;
                        authorData.IsCanonical = IsCanonicalAuthorName(canonicalName);
                        authorData.NormalizedName = AuthorNormalizer.Normalize(canonicalName);
                        authorIndex.Remove(name);
                    }
                }

                await slskDatabase.BulkInsertAuthorsAsync(
                    new[] { canonicalName },
                    "Fusion",
                    IsCanonicalAuthorName,
                    author => author.StartsWith(canonicalName, StringComparison.OrdinalIgnoreCase) ? 100 : 0).ConfigureAwait(false);

                await DeleteAuthorsFromDatabaseAsync(namesToMerge).ConfigureAwait(false);

                await LoadAuthorsFromDatabaseAsync().ConfigureAwait(false);
                MessageBox.Show("Fusión completada.", "Duplicados", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error fusionando autores:\n{ex.Message}", "Duplicados", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
