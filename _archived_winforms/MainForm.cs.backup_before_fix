        private async Task PrewarmConnectionsIfNeeded(DownloadTask[] pendingTasks)
        {
            if (pendingTasks == null || pendingTasks.Length < MIN_QUEUE_FOR_PREWARM)
            {
                return;
            }

            if (client == null || !client.State.HasFlag(SoulseekClientStates.Connected))
            {
                return;
            }

            if ((DateTime.Now - lastPrewarmTime).TotalSeconds < PREWARM_COOLDOWN_SECONDS)
            {
                return;
            }

            if (!await prewarmSemaphore.WaitAsync(0))
            {
                return;
            }

            try
            {
                var candidateUsers = pendingTasks
                    .Where(t => t?.File != null && !string.IsNullOrWhiteSpace(t.File.Username))
                    .Select(t => t.File.Username)
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .Where(username =>
                    {
                        lock (prewarmLock)
                        {
                            return !prewarmedUsers.Contains(username);
                        }
                    })
                    .Take(2)
                    .ToList();

                if (candidateUsers.Count == 0)
                {
                    return;
                }

                bool anyAttempt = false;
                foreach (var username in candidateUsers)
                {
                    anyAttempt = true;
                    var warmed = await WarmupUserAsync(username);
                    if (!warmed)
                    {
                        continue;
                    }

                    lock (prewarmLock)
                    {
                        if (prewarmedUsers.Add(username))
                        {
                            prewarmedUsersOrder.Enqueue(username);
                        }

                        while (prewarmedUsersOrder.Count > MAX_PREWARM_USERS)
                        {
                            var removed = prewarmedUsersOrder.Dequeue();
                            prewarmedUsers.Remove(removed);
                        }
                    }
                }

                if (anyAttempt)
                {
                    lastPrewarmTime = DateTime.Now;
                }
            }
            finally
            {
                prewarmSemaphore.Release();
            }
        }

        private async Task<bool> WarmupUserAsync(string username)
        {
            if (string.IsNullOrWhiteSpace(username) || client == null)
            {
                return false;
            }

            try
            {
                using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(3));
                var userInfo = await GetUserInfoCachedAsync(username, requestTimeout: TimeSpan.FromSeconds(3), cancellationToken: cts.Token);
                if (userInfo == null)
                {
                    return false;
                }
                AutoLog($"🔥 Precalentamiento: {username} (Queue {userInfo.QueueLength})");
                return true;
            }
            catch (OperationCanceledException)
            {
                Log($"⚠️ Precalentamiento cancelado para {username} (timeout)");
            }
            catch (Exception ex)
            {
                Log($"⚠️ Precalentamiento fallido para {username}: {ex.Message}");
            }

            return false;
        }

        private void ReleasePrewarmedUser(string username)
        {
            if (string.IsNullOrWhiteSpace(username))
            {
                return;
            }

            lock (prewarmLock)
            {
                if (!prewarmedUsers.Remove(username))
                {
                    return;
                }

                if (prewarmedUsersOrder.Count > 0)
                {
                    var remaining = prewarmedUsersOrder
                        .Where(u => !string.Equals(u, username, StringComparison.OrdinalIgnoreCase))
                        .ToList();
                    prewarmedUsersOrder.Clear();
                    foreach (var user in remaining)
                    {
                        prewarmedUsersOrder.Enqueue(user);
                    }
                }
            }
        }

        private async Task SaveQueueSnapshotIfNeeded(IReadOnlyCollection<DownloadTask> pendingTasks)
        {
            if (pendingTasks == null || pendingTasks.Count == 0)
            {
                return;
            }

            var now = DateTime.Now;
            if ((now - lastQueueSnapshotTime).TotalMinutes < QUEUE_SNAPSHOT_INTERVAL_MINUTES &&
                Math.Abs(pendingTasks.Count - lastQueueSnapshotCount) < QUEUE_SNAPSHOT_MIN_DELTA)
            {
                return;
            }

            if (!await queueSnapshotSemaphore.WaitAsync(0))
            {
                return;
            }

            try
            {
                Directory.CreateDirectory(queueSnapshotsDir);

                var snapshotPayload = new
                {
                    capturedAt = now,
                    pendingCount = pendingTasks.Count,
                    items = pendingTasks.Select(t => new
                    {
                        FileName = t.File?.FileName,
                        Username = t.File?.Username,
                        SizeBytes = t.File?.SizeBytes,
                        Progress = t.ProgressPercent,
                        Retries = t.RetryCount,
                        Status = t.Status.ToString(),
                        Speed = t.SpeedMBps,
                        QueuePosition = t.QueuePosition
                    }).ToList()
                };

                var jsonBytes = JsonSerializer.SerializeToUtf8Bytes(snapshotPayload, new JsonSerializerOptions
                {
                    WriteIndented = false
                });

                var snapshotName = $"queue_snapshot_{now:yyyyMMdd_HHmmss}.json.br";
                var snapshotPath = Path.Combine(queueSnapshotsDir, snapshotName);

                using (var fileStream = new FileStream(snapshotPath, FileMode.Create, FileAccess.Write, FileShare.None))
                using (var brotli = new BrotliStream(fileStream, CompressionLevel.Fastest))
                {
                    await brotli.WriteAsync(jsonBytes, 0, jsonBytes.Length);
                }

                lastQueueSnapshotTime = now;
                lastQueueSnapshotCount = pendingTasks.Count;

                var retained = Directory.GetFiles(queueSnapshotsDir, "queue_snapshot_*.json.br")
                    .OrderByDescending(f => f)
                    .Skip(12)
                    .ToList();

                foreach (var path in retained)
                {
                    try
                    {
                        System.IO.File.Delete(path);
                    }
                    catch { }
                }

                Log($"🧊 Snapshot de cola guardado ({pendingTasks.Count} tareas)");
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error guardando snapshot de cola: {ex.Message}");
            }
            finally
            {
                queueSnapshotSemaphore.Release();
            }
        }

