        private void ClearAllDownloads()
        {
            // Mostrar ventana de confirmación en tono oscuro
            var result = ShowDarkDialog(
                "¿Vaciar toda la lista de descargas?\n\nEsto cancelará todas las descargas activas y eliminará todas las entradas de la lista.",
                "Confirmar vaciado",
                MessageBoxButtons.YesNo,
                "⚠️"
            );
            
            if (result == DialogResult.Yes)
            {
                int totalCount = downloadQueueService.Update(list =>
                {
                    foreach (var task in list)
                    {
                        if (task.Status == DownloadStatus.Downloading)
                        {
                            task.CancellationToken?.Cancel();
                        }
                    }

                    int count = list.Count;
                    list.Clear();
                    return count;
                });

                StopDownloadManager();

                // Limpiar la UI
                SafeInvoke(() =>
                {
                    if (lvDownloads == null)
                    {
                        return;
                    }

                    if (lvDownloads.VirtualMode)
                    {
                        lock (downloadVirtualLock)
                        {
                            downloadVirtualSnapshot = new List<DownloadTask>();
                            virtualDownloadsCache.Clear();
                        }
                        lvDownloads.VirtualListSize = 0;
                        lvDownloads.Invalidate();
                    }
                    else
                    {
                        lvDownloads.Items.Clear();
                    }
                });
                
                // Limpiar descargas activas
                activeDownloads.Clear();
                
                AutoLog($"🗑️ Lista de descargas vaciada: {totalCount} entrada(s) eliminada(s)");
                
                // Actualizar progreso
                UpdateProgressDisplay();

                MarkDownloadStatsDirty();
                ScheduleQueuePrioritization();
            }
        }
        
        private void PauseDownload()
        {
            int pausedCount = 0;
            
            StopDownloadManager();

            var pausedTasks = downloadQueueService.Update(list =>
            {
                var tasks = list
                    .Where(t => t.Status == DownloadStatus.Downloading || t.Status == DownloadStatus.Queued)
                    .ToList();

                foreach (var task in tasks)
                {
                    task.Status = DownloadStatus.Paused;
                    task.CancellationToken?.Cancel();
                }

                return tasks;
            });

            pausedCount = pausedTasks.Count;

            foreach (var task in pausedTasks)
            {
                UpdateDownloadUI(task, "⏸️ Pausado");
            }

            if (pausedCount > 0)
            {
                MarkDownloadStatsDirty();
                ScheduleQueuePrioritization();
            }
            
            if (pausedCount > 0)
            {
                AutoLog($"⏸️ {pausedCount} descarga(s) pausada(s)");
            }
            else
            {
                MessageBox.Show("No hay descargas activas para pausar", "Pausar descarga", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
        }
        
        private void ResumeDownload()
        {
            int resumedCount = 0;
            
            var resumedTasks = downloadQueueService.Update(list =>
            {
                var tasks = list.Where(t => t.Status == DownloadStatus.Paused).ToList();

                foreach (var task in tasks)
                {
                    task.Status = DownloadStatus.Queued;
                    task.CancellationToken = new CancellationTokenSource();
                }

                return tasks;
            });

            resumedCount = resumedTasks.Count;

            foreach (var task in resumedTasks)
            {
                UpdateDownloadUI(task, "⏳ Pendiente");
            }

            if (resumedCount > 0)
            {
                AutoLog($"▶️ {resumedCount} descarga(s) reanudada(s)");
                MarkDownloadStatsDirty();
                ScheduleQueuePrioritization();
                _ = Task.Run(async () => await StartDownloadManager());
            }
            else
            {
                var hasQueued = downloadQueueService.Update(list => list.Any(t => t.Status == DownloadStatus.Queued));
                if (hasQueued && !downloadManagerRunning)
                {
                    AutoLog("▶️ Iniciando gestor de descargas...");
                    _ = Task.Run(async () => await StartDownloadManager());
                    return;
                }

                MessageBox.Show("No hay descargas pausadas para reanudar", "Reanudar descarga", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
        }
        
