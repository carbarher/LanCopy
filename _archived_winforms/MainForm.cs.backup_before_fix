        private void UpdateQueuePositionInUI(SlskDown.Core.QueuePositionTracker.QueueInfo info)
        {
            if (info == null)
            {
                return;
            }

            List<DownloadTask> tasks;
            lock (downloadQueueLock)
            {
                tasks = downloadQueue
                    .Where(t => t?.File != null)
                    .Where(t => t.Status == DownloadStatus.Queued)
                    .Where(t => string.Equals(t.File.Username, info.Username, StringComparison.OrdinalIgnoreCase))
                    .Where(t => string.Equals(t.File.FileName, info.Filename, StringComparison.OrdinalIgnoreCase))
                    .ToList();
            }

            foreach (var task in tasks)
            {
                try
                {
                    task.QueuePosition = info.Position;
                    var status = $"{GetStatusText(task.Status)} - {info.DisplayText}";
                    task.UiStatusText = status;
                    EnqueueDownloadUiUpdate(task, status);
                }
                catch
                {
                }
            }
        }

        private async Task RequestQueuePositionAsync(DownloadTask task)
        {
            if (task?.File == null)
            {
                return;
            }

            var username = task.File.Username;
            var filename = task.File.FileName;
            if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(filename))
            {
                return;
            }

            try
            {
                queuePositionTracker?.TrackFile(username, filename);
            }
            catch
            {
            }

            try
            {
                if (queuePositionTracker != null && !queuePositionTracker.ShouldRequestPosition(username, filename))
                {
                    return;
                }

                using var timeoutCts = new CancellationTokenSource(TimeSpan.FromSeconds(3));
                var userInfo = await GetUserInfoCachedAsync(username, ttl: TimeSpan.FromSeconds(30), requestTimeout: TimeSpan.FromSeconds(3), cancellationToken: timeoutCts.Token);
                if (userInfo == null)
                {
                    return;
                }

                var estimatedPos = userInfo.HasFreeUploadSlot ? 0 : Math.Max(0, userInfo.QueueLength);

                try
                {
                    queuePositionTracker?.UpdatePosition(username, filename, estimatedPos);
                }
                catch
                {
                }

                try
                {
                    task.QueuePosition = estimatedPos;
                    var display = queuePositionTracker?.GetPosition(username, filename)?.DisplayText;
                    if (!string.IsNullOrWhiteSpace(display))
                    {
                        var status = $"{GetStatusText(task.Status)} - {display}";
                        task.UiStatusText = status;
                        EnqueueDownloadUiUpdate(task, status);
                    }
                }
                catch
                {
                }
            }
            catch
            {
            }
        }

