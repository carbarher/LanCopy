        private static string[] ResolveAllowedExtensions(string category)
        {
            if (string.IsNullOrWhiteSpace(category) || category.Equals("Todos", StringComparison.OrdinalIgnoreCase))
            {
                return Array.Empty<string>();
            }

            return category switch
            {
                "Libros/Docs" => new[] { ".pdf", ".epub", ".mobi", ".txt", ".doc", ".docx" },
                "Audiolibros" => new[] { ".mp3", ".m4b", ".aac", ".flac", ".ogg" },
                "Comics" => new[] { ".cbr", ".cbz", ".pdf" },
                _ => Array.Empty<string>()
            };
        }

