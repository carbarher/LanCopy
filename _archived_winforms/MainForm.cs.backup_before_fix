        private void EnsureStatsMonitor()
        {
            if (IsDisposed || Disposing)
            {
                return;
            }

            var existingTask = statsMonitorTask;
            if (existingTask != null && !existingTask.IsCompleted && !existingTask.IsFaulted)
            {
                return;
            }

            lock (statsSnapshotLock)
            {
                existingTask = statsMonitorTask;
                if (existingTask != null && !existingTask.IsCompleted && !existingTask.IsFaulted)
                {
                    return;
                }

                statsMonitorCts?.Cancel();
                statsMonitorCts?.Dispose();
                statsMonitorCts = new CancellationTokenSource();
                var token = statsMonitorCts.Token;

                statsMonitorTask = Task.Run(async () =>
                {
                    try
                    {
                        while (!token.IsCancellationRequested)
                        {
                            if (!statsDirty)
                            {
                                await Task.Delay(StatsRefreshIntervalMs, token);
                                continue;
                            }

                            statsDirty = false;
                            var snapshot = BuildDownloadStatsSnapshot();
                            lock (statsSnapshotLock)
                            {
                                latestStatsSnapshot = snapshot;
                            }

                            if ((DateTime.Now - lastStatsUiUpdate).TotalMilliseconds >= StatsRefreshIntervalMs)
                            {
                                SafeBeginInvoke(ApplyLatestStatsSnapshot);
                            }

                            await Task.Delay(StatsRefreshIntervalMs, token);
                        }
                    }
                    catch (OperationCanceledException)
                    {
                        // Detención esperada
                    }
                    catch (Exception ex)
                    {
                        AutoLog($"⚠️ Error monitor estadísticas descargas: {ex.Message}");
                    }
                }, token);
            }
        }

        private void StopStatsMonitor()
        {
            statsMonitorCts?.Cancel();
            statsMonitorCts?.Dispose();
            statsMonitorCts = null;
            statsMonitorTask = null;
        }

        private void MarkDownloadStatsDirty()
        {
            statsDirty = true;
            EnsureStatsMonitor();
        }

        private void RegisterDownloadError(string message)
        {
            if (string.IsNullOrWhiteSpace(message))
            {
                return;
            }

            recentDownloadErrors.Enqueue(message);
            if (recentDownloadErrors.Count > 10)
            {
                recentDownloadErrors.Dequeue();
            }

            if (message.IndexOf("disconnect", StringComparison.OrdinalIgnoreCase) >= 0 ||
                message.IndexOf("desconect", StringComparison.OrdinalIgnoreCase) >= 0)
            {
                HandleDisconnectPenalty();
            }

            MarkDownloadStatsDirty();
        }

        private void HandleDisconnectPenalty()
        {
            lock (this)
            {
                disconnectPenaltyVotes++;

                var cooldownElapsed = (DateTime.Now - lastDisconnectPenalty).TotalSeconds >= DISCONNECT_PENALTY_COOLDOWN_SECONDS;
                if (!cooldownElapsed && disconnectPenaltyVotes < DISCONNECT_PENALTY_VOTE_THRESHOLD)
                {
                    return;
                }

                if (disconnectPenaltyVotes < DISCONNECT_PENALTY_VOTE_THRESHOLD)
                {
                    return;
                }

                disconnectPenaltyVotes = 0;
                lastDisconnectPenalty = DateTime.Now;

                var newLimit = Math.Max(maxParallelDownloads - DISCONNECT_PARALLEL_STEP, DISCONNECT_PARALLEL_FLOOR);
                if (newLimit < maxParallelDownloads)
                {
                    Log("⚠️ Penalización por desconexiones: reduciendo descargas simultáneas");
                    CommitParallelDownloadLimit(newLimit);
                }
            }
        }

        private DownloadStatsSnapshot BuildDownloadStatsSnapshot()
        {
            int total = 0;
            int active = 0;
            int queued = 0;
            int paused = 0;
            int completed = 0;
            int failed = 0;
            int cancelled = 0;
            double totalSpeed = 0;

            downloadQueueService.WithQueueLock(list =>
            {
                total = list.Count;
                active = list.Count(t => t.Status == DownloadStatus.Downloading);
                queued = list.Count(t => t.Status == DownloadStatus.Queued || t.Status == DownloadStatus.GettingStatus);
                paused = list.Count(t => t.Status == DownloadStatus.Paused);
                completed = list.Count(t => t.Status == DownloadStatus.Completed);
                failed = list.Count(t => t.Status == DownloadStatus.Failed);
                cancelled = list.Count(t => t.Status == DownloadStatus.Cancelled);
                totalSpeed = list
                    .Where(t => t.Status == DownloadStatus.Downloading && t.SpeedMBps > 0)
                    .Sum(t => t.SpeedMBps);
            });

            double[] speedSeries;
            double movingAverage;

            lock (speedWindowLock)
            {
                var now = DateTime.Now;
                totalSpeedWindow.Enqueue((now, totalSpeed));

                while (totalSpeedWindow.Count > 0 && (now - totalSpeedWindow.Peek().timestamp).TotalSeconds > SpeedWindowSeconds)
                {
                    totalSpeedWindow.Dequeue();
                }

                speedSeries = totalSpeedWindow.Select(pair => Math.Max(0, pair.value)).ToArray();
                movingAverage = speedSeries.Length > 0 ? speedSeries.Average() : 0;
            }

            return new DownloadStatsSnapshot
            {
                TotalDownloads = total,
                ActiveDownloads = active,
                QueuedDownloads = queued,
                PausedDownloads = paused,
                CompletedDownloads = completed,
                FailedDownloads = failed,
                CancelledDownloads = cancelled,
                TotalSpeedMbps = totalSpeed,
                MovingAverageMbps = movingAverage,
                SpeedSeries = speedSeries,
                RecentErrors = recentDownloadErrors.ToList()
            };
        }

        private void ApplyLatestStatsSnapshot()
        {
            if (IsDisposed || Disposing)
            {
                return;
            }

            DownloadStatsSnapshot snapshot;
            lock (statsSnapshotLock)
            {
                snapshot = latestStatsSnapshot;
            }

            UpdateDownloadStatsUI(snapshot);
        }

        private void UpdateDownloadStatsUI(DownloadStatsSnapshot snapshot)
        {
            if (snapshot == null)
            {
                return;
            }

            lastStatsUiUpdate = DateTime.Now;

            if (lblDownloadStats != null && !lblDownloadStats.IsDisposed)
            {
                lblDownloadStats.Text = $"Total: {snapshot.TotalDownloads} | Completadas: {snapshot.CompletedDownloads} | Fallidas: {snapshot.FailedDownloads}";
            }

            if (lblDownloadSpeed != null && !lblDownloadSpeed.IsDisposed)
            {
                lblDownloadSpeed.Text = $"Velocidad total: {snapshot.TotalSpeedMbps:F2} MB/s | Media {SpeedWindowSeconds}s: {snapshot.MovingAverageMbps:F2} MB/s";
            }

            if (lblDownloadQueue != null && !lblDownloadQueue.IsDisposed)
            {
                lblDownloadQueue.Text = $"En cola: {snapshot.QueuedDownloads} | Activas: {snapshot.ActiveDownloads} | Pausadas: {snapshot.PausedDownloads}";
            }

            if (lblDownloadErrors != null && !lblDownloadErrors.IsDisposed)
            {
                if (snapshot.RecentErrors.Count > 0)
                {
                    var latest = snapshot.RecentErrors[^1];
