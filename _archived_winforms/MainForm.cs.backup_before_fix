        private string GetIncompleteDownloadPath(string targetPath, AutoSearchFileResult file)
        {
            try
            {
                var incompleteDir = downloadManagerConfig?.IncompleteDownloadsDirectory;
                if (string.IsNullOrWhiteSpace(incompleteDir))
                {
                    incompleteDir = Path.Combine(downloadDir ?? string.Empty, "incomplete");
                }

                if (string.IsNullOrWhiteSpace(incompleteDir))
                {
                    return targetPath;
                }

                Directory.CreateDirectory(incompleteDir);

                var originalName = Path.GetFileName(string.IsNullOrWhiteSpace(file?.FileName) ? targetPath : file.FileName);
                if (string.IsNullOrWhiteSpace(originalName))
                {
                    originalName = Path.GetFileName(targetPath);
                }

                var invalid = Path.GetInvalidFileNameChars();
                var safeName = new string(originalName.Select(ch => invalid.Contains(ch) ? '_' : ch).ToArray());
                if (string.IsNullOrWhiteSpace(safeName))
                {
                    safeName = "download.tmp";
                }

                var prefix = Guid.NewGuid().ToString("N");
                return Path.Combine(incompleteDir, $"{prefix}_{safeName}");
            }
            catch
            {
                return targetPath;
            }
        }

