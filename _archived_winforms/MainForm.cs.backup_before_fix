                        foreach (ListViewItem item in lvHistory.Items)
                        {
                            if (item.SubItems[1].Text == lastItem.FileName && 
                                item.SubItems[0].Text == lastItem.DownloadedAt.ToString("yyyy-MM-dd HH:mm:ss"))
                            {
                                exists = true;
                                break;
                            }
                        }
                        
                        // Si no existe, agregarlo al principio
                        if (!exists)
                        {
                            if (chkHistoryOnlySpanish != null && chkHistoryOnlySpanish.Checked && lastItem.IsSpanish != true)
                            {
                                return;
                            }

                            var listItem = new ListViewItem(lastItem.DownloadedAt.ToString("yyyy-MM-dd HH:mm:ss"));
                            listItem.SubItems.Add(lastItem.FileName);
                            listItem.SubItems.Add(lastItem.Author ?? "-");
                            listItem.SubItems.Add(lastItem.Username);
                            listItem.SubItems.Add(FormatFileSize(lastItem.SizeBytes));
                            listItem.SubItems.Add($"{lastItem.SpeedMBps:F2} MB/s");
                            listItem.SubItems.Add(lastItem.Status);
                            listItem.SubItems.Add(RenderSpanishFlag(lastItem));
                            
                            listItem.ForeColor = lastItem.Status == "Completed" ? Color.LightGreen : Color.Red;
                            
                            // Insertar al principio
                            lvHistory.Items.Insert(0, listItem);
                            
                            // Actualizar estadísticas
                            var completed = downloadHistory.Count(h => h.Status == "Completed");
                            var failed = downloadHistory.Count(h => h.Status == "Failed");
                            var totalSize = FormatFileSize(downloadHistory.Where(h => h.Status == "Completed").Sum(h => h.SizeBytes));
                            
                            // Buscar el label de estadísticas
                            var historyTab = tabControl?.TabPages.Cast<TabPage>().FirstOrDefault(t => t.Text.Contains("Historial"));
                            if (historyTab != null)
                            {
                                var lblStats = historyTab.Controls.OfType<TableLayoutPanel>().FirstOrDefault()
                                    ?.Controls.OfType<FlowLayoutPanel>().FirstOrDefault()
                                    ?.Controls.OfType<Label>().FirstOrDefault(l => l.Text.Contains("Total:"));
                                
                                if (lblStats != null)
                                {
                                    lblStats.Text = $"Total: {downloadHistory.Count} | Mostrando: {lvHistory.Items.Count} | ✅ {completed} | ❌ {failed} | 📦 {totalSize}";
                                }
                            }
                        }
                    }
                }
                finally
                {
                    lvHistory.EndUpdate();
                }
            });
        }

