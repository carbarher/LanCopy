        /// <summary>
        /// Maneja atajos de teclado globales
        /// </summary>
        protected override bool ProcessCmdKey(ref Message msg, Keys keyData)
        {
            try
            {
                // Ctrl+F - Buscar
                if (keyData == (Keys.Control | Keys.F))
                {
                    if (cmbSearch != null && tabControl.SelectedIndex == 0)
                    {
                        cmbSearch.Focus();
                        return true;
                    }
                }
                
                // Ctrl+D - Descargar seleccionados
                if (keyData == (Keys.Control | Keys.D))
                {
                    if (tabControl.SelectedIndex == 0 && lvResults.SelectedItems.Count > 0)
                    {
                        _ = DownloadMultipleAsync();
                        return true;
                    }
                }
                
                // Ctrl+P - Pausar/Reanudar
                if (keyData == (Keys.Control | Keys.P))
                {
                    if (downloadManagerRunning)
                    {
                        StopDownloadManager();
                        AutoLog("⏸️ Gestor de descargas pausado (Ctrl+P)");
                    }
                    else
                    {
                        _ = Task.Run(async () => await StartDownloadManager());
                        AutoLog("▶️ Gestor de descargas reanudado (Ctrl+P)");
                    }
                    return true;
                }
                
                // Ctrl+R - Reintentar fallos
                if (keyData == (Keys.Control | Keys.R))
                {
                    if (tabControl.SelectedIndex == 1)
                    {
                        _ = RetryDownload();
                        return true;
                    }
                }
                
                // F5 - Actualizar
                if (keyData == Keys.F5)
                {
                    if (tabControl.SelectedIndex == 2) // Tab de autores
                    {
                        RefreshAuthorsListView();
                        AutoLog("🔄 Lista de autores actualizada (F5)");
                        return true;
                    }
                }
                
                // Ctrl+L - Limpiar resultados
                if (keyData == (Keys.Control | Keys.L))
                {
                    if (tabControl.SelectedIndex == 0 && lvResults.Items.Count > 0)
                    {
                        lvResults.Items.Clear();
                        AutoLog("🗑️ Resultados limpiados (Ctrl+L)");
                        return true;
                    }
                }
                
                // Ctrl+S - Detener búsqueda
                if (keyData == (Keys.Control | Keys.S))
                {
                    if (searchCancellationTokenSource != null && !searchCancellationTokenSource.IsCancellationRequested)
                    {
                        searchCancellationTokenSource.Cancel();
                        AutoLog("⏹️ Búsqueda detenida (Ctrl+S)");
                        return true;
                    }
                }
                
                // Ctrl+O - Abrir carpeta de descargas
                if (keyData == (Keys.Control | Keys.O))
                {
                    if (System.IO.Directory.Exists(downloadDir))
                    {
                        Process.Start("explorer.exe", downloadDir);
                        return true;
                    }
                }
                
                // Ctrl+Shift+C - Conectar/Desconectar
                if (keyData == (Keys.Control | Keys.Shift | Keys.C))
                {
                    if (client != null && client.State == SoulseekClientStates.Connected)
                    {
                        client.Disconnect("User requested");
                        AutoLog("🔌 Desconectado (Ctrl+Shift+C)");
                    }
                    else
                    {
                        _ = ConnectButton_Click();
                        AutoLog("🔌 Conectando... (Ctrl+Shift+C)");
                    }
                    return true;
                }
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error procesando atajo de teclado: {ex.Message}");
            }
            
            return base.ProcessCmdKey(ref msg, keyData);
        }
        
