        private void EnqueueDownloadUiUpdate(DownloadTask task, string status)
        {
            try
            {
                if (task == null)
                {
                    return;
                }

                pendingDownloadUiStatuses[task] = status ?? string.Empty;
                downloadUiUpdateChannel.Writer.TryWrite(new DownloadEvent { Task = task });
            }
            catch
            {
            }
        }

        private void StartDownloadUiChannelConsumer()
        {
            if (downloadUiChannelStarted)
            {
                return;
            }

            downloadUiChannelStarted = true;
            downloadUiChannelCts = new CancellationTokenSource();
            var token = downloadUiChannelCts.Token;

            _ = Task.Run(async () =>
            {
                var reader = downloadUiUpdateChannel.Reader;
                try
                {
                    while (await reader.WaitToReadAsync(token).ConfigureAwait(false))
                    {
                        var unique = new HashSet<DownloadTask>();
                        while (reader.TryRead(out var ev))
                        {
                            var task = ev?.Task;
                            if (task != null)
                            {
                                unique.Add(task);
                            }
                        }

                        foreach (var task in unique)
                        {
                            if (pendingDownloadUiStatuses.TryGetValue(task, out var status))
                            {
                                UpdateDownloadUI(task, status);
                            }
                        }

                        await Task.Delay(25, token).ConfigureAwait(false);
                    }
                }
                catch (OperationCanceledException)
                {
                }
                catch
                {
                }
            }, token);
        }

        private void ScanAndOfferSanitizePlaintextCredentials()
        {
            if (string.IsNullOrWhiteSpace(dataDir) || !System.IO.Directory.Exists(dataDir))
            {
                return;
            }

            var candidates = new List<string>();
            var configPath = Path.Combine(dataDir, "config.json");
            if (System.IO.File.Exists(configPath))
            {
                candidates.Add(configPath);
            }

            var backupDir = Path.Combine(dataDir, "backups");
            if (System.IO.Directory.Exists(backupDir))
            {
                candidates.AddRange(System.IO.Directory.GetFiles(backupDir, "config_*.json"));
            }

            var flagged = new List<string>();
            foreach (var path in candidates)
            {
                if (FileHasPlaintextCredentials(path))
                {
                    flagged.Add(path);
                }
            }

            if (flagged.Count == 0)
            {
                return;
            }

            var preview = string.Join("\n", flagged
                .Take(10)
                .Select(p => "- " + Path.GetFileName(p)));
            var more = flagged.Count > 10 ? $"\n... y {flagged.Count - 10} más" : string.Empty;
            var message =
                "Se detectaron credenciales en texto plano en archivos de configuración/backups.\n\n" +
                "¿Quieres limpiarlas ahora? (Se creará un .bak antes de modificar)\n\n" +
                preview +
                more;

            var result = MessageBox.Show(
                message,
                "Seguridad",
                MessageBoxButtons.YesNo,
                MessageBoxIcon.Warning);

            if (result != DialogResult.Yes)
            {
                return;
            }

            var cleaned = 0;
            foreach (var path in flagged)
            {
                if (TrySanitizeConfigJsonFile(path))
                {
                    cleaned++;
                }
            }

            AutoLog($"🧽 Limpieza de credenciales en claro: {cleaned}/{flagged.Count} archivos");
        }

        private static bool FileHasPlaintextCredentials(string path)
        {
            try
            {
                var text = System.IO.File.ReadAllText(path);
                if (string.IsNullOrWhiteSpace(text))
                {
                    return false;
                }

                if (!text.Contains("\"password\"", StringComparison.OrdinalIgnoreCase) &&
                    !text.Contains("\"username\"", StringComparison.OrdinalIgnoreCase))
                {
                    return false;
                }

                var data = JsonSerializer.Deserialize<Dictionary<string, object>>(text);
                if (data == null)
                {
                    return false;
                }

                var user = TryGetString(data, "username");
                var pass = TryGetString(data, "password");
                return !string.IsNullOrWhiteSpace(user) || !string.IsNullOrWhiteSpace(pass);
            }
            catch
            {
                return false;
            }
        }

