                var canonicalOrder = CanonicalGutenbergAuthors;
                var canonicalIndex = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
                for (int i = 0; i < canonicalOrder.Length; i++)
                {
                    var key = CreateAuthorKey(canonicalOrder[i]);
                    if (!string.IsNullOrEmpty(key))
                    {
                        canonicalIndex[key] = i;
                    }
                }

                // Mapear todos los autores por clave normalizada
                var remainingAuthors = new List<string>(allAuthors);
                var orderedAuthors = new List<string>();

                foreach (var canonicalName in canonicalOrder)
                {
                    var canonicalKey = CreateAuthorKey(canonicalName);
                    if (string.IsNullOrEmpty(canonicalKey))
                    {
                        continue;
                    }

                    // Buscar coincidencias en remainingAuthors por clave
                    var matches = remainingAuthors
                        .Where(a => CreateAuthorKey(a) == canonicalKey)
                        .Distinct(StringComparer.OrdinalIgnoreCase)
                        .ToList();

                    if (matches.Count == 0)
                    {
                        continue;
                    }

                    orderedAuthors.AddRange(matches);

                    // Quitar los ya usados del pool restante
                    remainingAuthors = remainingAuthors
                        .Where(a => !matches.Contains(a, StringComparer.OrdinalIgnoreCase))
                        .ToList();
                }

                // Añadir el resto ordenados alfabéticamente
                remainingAuthors = remainingAuthors
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .OrderBy(a => a, StringComparer.OrdinalIgnoreCase)
                    .ToList();

                orderedAuthors.AddRange(remainingAuthors);

                // Índice persistente para continuar listas entre sesiones
                int nextIndex = configManager.GetValue("gutenbergAuthorIndex", 0);
                if (resetCanonicalIndex)
                {
                    nextIndex = 0;
                }
                if (nextIndex < 0) nextIndex = 0;
                if (nextIndex >= orderedAuthors.Count)
                {
                    AutoLog("ℹ️ No hay más autores nuevos en la lista canónica para generar.");
                    return;
                }

                var selectedAuthors = orderedAuthors
                    .Skip(nextIndex)
                    .Take(desiredCount)
                    .ToList();

                if (clearExisting)
                {
                    AutoLog("🧹 Borrando autores existentes antes de generar nueva lista...");
                    await slskDatabase.ClearAuthorsAsync().ConfigureAwait(false);
                }

                var modeDescription = clearExisting
                    ? (resetCanonicalIndex ? "lista nueva (desde inicio)" : "lista nueva (continuando orden)")
                    : "añadir a lista existente";

                AutoLog($"✨ Generando {selectedAuthors.Count:N0} autores ({modeDescription})...");
                await SaveAuthorsToDatabaseAsync(selectedAuthors, clearExisting ? "Generated.Reset" : "Generated.Append").ConfigureAwait(false);

                // Actualizar índice para próxima generación
                nextIndex += selectedAuthors.Count;
                if (nextIndex > orderedAuthors.Count)
                    nextIndex = orderedAuthors.Count;
                configManager.SetValue("gutenbergAuthorIndex", nextIndex);
                configManager.Save();

                // Recargar lista en memoria/UI
                await LoadAuthorsFromDatabaseAsync().ConfigureAwait(false);

                AutoLog($"✅ Generación de autores completada: {selectedAuthors.Count:N0} autores");
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error generando autores: {ex.Message}");
                MessageBox.Show(
                    $"Error generando autores:\n{ex.Message}",
                    "Error",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Error);
            }
        }

        private async Task SaveAuthorsToDatabaseAsync(IEnumerable<string> authorNames, string source)
        {
            if (slskDatabase == null)
            {
                return;
            }

            try
            {
                await slskDatabase.BulkInsertAuthorsAsync(
                    authorNames,
                    source,
                    isCanonicalFunc: IsCanonicalAuthorName,
                    priorityFunc: GetAuthorPriority
                ).ConfigureAwait(false);
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error guardando autores en base de datos: {ex.Message}");
            }
        }

        private static int GetAuthorPriority(string authorName)
        {
            if (string.IsNullOrWhiteSpace(authorName))
            {
                return 0;
            }

            var key = CreateAuthorKey(authorName);
            for (int i = 0; i < CanonicalAuthorKeyList.Length; i++)
            {
                if (CanonicalAuthorKeyList[i].Equals(key, StringComparison.OrdinalIgnoreCase))
                {
                    return CanonicalAuthorKeyList.Length - i;
                }
            }

            return 0;
        }

        private async Task DeleteAuthorsFromDatabaseAsync(IEnumerable<string> authorNames)
        {
            if (slskDatabase == null)
            {
                return;
            }

            try
            {
                const string sql = "DELETE FROM Authors WHERE Name = @Name";
                var parameters = authorNames
                    .Where(author => !string.IsNullOrWhiteSpace(author))
                    .Select(author => new { Name = author.Trim() })
                    .ToList();

                if (parameters.Count == 0)
                {
                    return;
                }

                await slskDatabase.ExecuteAsync(sql, parameters).ConfigureAwait(false);
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error eliminando autores en base de datos: {ex.Message}");
            }
        }
        
