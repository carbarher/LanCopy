                    ForeColor = Color.White,
                    Font = this.Font,
                    AutoSize = true,
                    AutoSizeMode = AutoSizeMode.GrowAndShrink,
                    Padding = new Padding(16)
                };

                var layout = new TableLayoutPanel
                {
                    Dock = DockStyle.Fill,
                    ColumnCount = 2,
                    RowCount = 2,
                    AutoSize = true,
                    AutoSizeMode = AutoSizeMode.GrowAndShrink
                };
                layout.ColumnStyles.Add(new ColumnStyle(SizeType.Absolute, 56));
                layout.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 100));

                var picture = new PictureBox
                {
                    Width = 48,
                    Height = 48,
                    SizeMode = PictureBoxSizeMode.CenterImage,
                    Anchor = AnchorStyles.Top,
                    Margin = new Padding(0, 6, 12, 0)
                };
                iconBitmap = GetSystemIconForMessageBox(icon).ToBitmap();
                picture.Image = iconBitmap;

                var label = new Label
                {
                    Text = message,
                    AutoSize = true,
                    MaximumSize = new Size(640, 0),
                    ForeColor = Color.White,
                    Margin = new Padding(0, 8, 0, 8)
                };

                var buttonsPanel = new FlowLayoutPanel
                {
                    Dock = DockStyle.Fill,
                    FlowDirection = FlowDirection.RightToLeft,
                    AutoSize = true,
                    AutoSizeMode = AutoSizeMode.GrowAndShrink,
                    WrapContents = false,
                    Margin = new Padding(0, 18, 0, 0)
                };

                var buttonsInOrder = new List<Button>();

                Button CreateButton(string text, DialogResult result, Color backColor)
                {
                    var btn = new Button
                    {
                        Text = text,
                        DialogResult = result,
                        AutoSize = true,
                        FlatStyle = FlatStyle.Flat,
                        BackColor = backColor,
                        ForeColor = Color.White,
                        Padding = new Padding(14, 6, 14, 6),
                        Margin = new Padding(8, 0, 0, 0)
                    };
                    btn.FlatAppearance.BorderSize = 0;
                    return btn;
                }

                var primary = Color.FromArgb(0, 122, 204);
                var neutral = Color.FromArgb(45, 45, 48);
                var danger = Color.FromArgb(150, 0, 0);

                string cancelText = "Cancelar";
                string retryText = "Reintentar";
                string ignoreText = "Ignorar";
                string abortText = "Abortar";

                switch (buttons)
                {
                    case MessageBoxButtons.OK:
                        buttonsInOrder.Add(CreateButton("OK", DialogResult.OK, primary));
                        break;
                    case MessageBoxButtons.OKCancel:
                        buttonsInOrder.Add(CreateButton("OK", DialogResult.OK, primary));
                        buttonsInOrder.Add(CreateButton(cancelText, DialogResult.Cancel, neutral));
                        break;
                    case MessageBoxButtons.YesNo:
                        buttonsInOrder.Add(CreateButton("Sí", DialogResult.Yes, primary));
                        buttonsInOrder.Add(CreateButton("No", DialogResult.No, neutral));
                        break;
                    case MessageBoxButtons.YesNoCancel:
                        buttonsInOrder.Add(CreateButton("Sí", DialogResult.Yes, primary));
                        buttonsInOrder.Add(CreateButton("No", DialogResult.No, neutral));
                        buttonsInOrder.Add(CreateButton(cancelText, DialogResult.Cancel, neutral));
                        break;
                    case MessageBoxButtons.RetryCancel:
                        buttonsInOrder.Add(CreateButton(retryText, DialogResult.Retry, primary));
                        buttonsInOrder.Add(CreateButton(cancelText, DialogResult.Cancel, neutral));
                        break;
                    case MessageBoxButtons.AbortRetryIgnore:
                        buttonsInOrder.Add(CreateButton(abortText, DialogResult.Abort, danger));
                        buttonsInOrder.Add(CreateButton(retryText, DialogResult.Retry, primary));
                        buttonsInOrder.Add(CreateButton(ignoreText, DialogResult.Ignore, neutral));
                        break;
                    default:
                        buttonsInOrder.Add(CreateButton("OK", DialogResult.OK, primary));
                        break;
                }

                foreach (var btn in buttonsInOrder.AsEnumerable().Reverse())
                {
                    buttonsPanel.Controls.Add(btn);
                }

                Button? GetDefaultButton()
                {
                    var defaultIndex = defaultButton switch
                    {
                        MessageBoxDefaultButton.Button2 => 1,
                        MessageBoxDefaultButton.Button3 => 2,
                        _ => 0
                    };
                    if (defaultIndex < 0 || defaultIndex >= buttonsInOrder.Count)
                    {
                        defaultIndex = 0;
                    }
                    return buttonsInOrder.Count > 0 ? buttonsInOrder[defaultIndex] : null;
                }

                Button? GetCancelButton()
                {
                    return buttonsInOrder.FirstOrDefault(b => b.DialogResult == DialogResult.Cancel)
                           ?? buttonsInOrder.FirstOrDefault(b => b.DialogResult == DialogResult.No)
                           ?? buttonsInOrder.FirstOrDefault(b => b.DialogResult == DialogResult.OK)
                           ?? buttonsInOrder.FirstOrDefault();
                }

                dialog.AcceptButton = GetDefaultButton();
                dialog.CancelButton = GetCancelButton();

                layout.Controls.Add(picture, 0, 0);
                layout.SetRowSpan(picture, 2);
                layout.Controls.Add(label, 1, 0);
                layout.Controls.Add(buttonsPanel, 1, 1);

                dialog.Controls.Add(layout);

                return dialog.ShowDialog(this);
            }
            finally
            {
                iconBitmap?.Dispose();
            }
        }

