            int topIndex = -1;
            string? topAuthorName = null;
            var selectedIndices = new List<int>();
            var selectedAuthorNames = new List<string>();
            
            try
            {
                if (lvAutoAuthors.TopItem != null)
                {
                    topIndex = lvAutoAuthors.TopItem.Index;
                    topAuthorName = lvAutoAuthors.TopItem.Text;
                }
                
                foreach (int index in lvAutoAuthors.SelectedIndices)
                {
                    selectedIndices.Add(index);
                    if (index >= 0 && index < lvAutoAuthors.Items.Count)
                    {
                        selectedAuthorNames.Add(lvAutoAuthors.Items[index].Text);
                    }
                }
            }
            catch { }
            
            lvAutoAuthors.BeginUpdate();
            lvAutoAuthors.Items.Clear();

            if (filteredAuthorsData.Count > 0)
            {
                var listItems = new ListViewItem[filteredAuthorsData.Count];
                for (int i = 0; i < filteredAuthorsData.Count; i++)
                {
                    var author = filteredAuthorsData[i];
                    var displayName = author.IsCanonical
                        ? $"{author.Name}  ⭐"
                        : author.Name;

                    var itemColor = author.ForeColor;
                    if (author.IsCanonical && (itemColor.IsEmpty || itemColor == Color.White || itemColor == Color.LightGray))
                    {
                        itemColor = Color.Gold;
                    }

                    var item = new ListViewItem(displayName)
                    {
                        ForeColor = itemColor,
                        Tag = author
                    };
                    item.SubItems.Add(author.FilesCount.ToString());

                    var statusText = author.Status ?? string.Empty;
                    if (author.IsCanonical)
                    {
                        statusText = string.IsNullOrWhiteSpace(statusText)
                            ? "⭐ Prioridad canónica"
                            : $"⭐ {statusText}";
                    }

                    item.SubItems.Add(statusText);
                    listItems[i] = item;
                }

                lvAutoAuthors.Items.AddRange(listItems);
            }

            lvAutoAuthors.EndUpdate();
            
            // Restaurar posición del scroll
            try
            {
                if (!string.IsNullOrEmpty(topAuthorName))
                {
                    for (int i = 0; i < lvAutoAuthors.Items.Count; i++)
                    {
                        if (string.Equals(lvAutoAuthors.Items[i].Text, topAuthorName, StringComparison.OrdinalIgnoreCase))
                        {
                            lvAutoAuthors.TopItem = lvAutoAuthors.Items[i];
                            topIndex = i;
                            break;
                        }
                    }
                }

                if (topIndex >= 0 && topIndex < lvAutoAuthors.Items.Count)
                {
                    lvAutoAuthors.TopItem = lvAutoAuthors.Items[topIndex];
                }
                
                // Restaurar selección
                if (selectedAuthorNames.Count > 0)
                {
                    foreach (var name in selectedAuthorNames)
                    {
                        for (int i = 0; i < lvAutoAuthors.Items.Count; i++)
                        {
                            if (string.Equals(lvAutoAuthors.Items[i].Text, name, StringComparison.OrdinalIgnoreCase))
                            {
                                lvAutoAuthors.Items[i].Selected = true;
                            }
                        }
                    }
                }
                else
                {
                    foreach (int index in selectedIndices)
                    {
                        if (index < lvAutoAuthors.Items.Count)
                        {
                            lvAutoAuthors.Items[index].Selected = true;
                        }
                    }
                }
            }
            catch { }
        }
        
