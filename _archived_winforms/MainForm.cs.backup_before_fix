        private async Task SearchMultipleTerms(List<string> terms)
        {
            try
            {
                // Crear nuevo CancellationTokenSource
                searchCancellationTokenSource?.Cancel();
                searchCancellationTokenSource = new System.Threading.CancellationTokenSource();
                
                if (btnSearch != null) btnSearch.Enabled = false;
                if (btnStopSearch != null) btnStopSearch.Enabled = true;
                if (lblStatus != null) lblStatus.Text = $"Buscando {terms.Count} términos...";
                if (lvResults != null) lvResults.Items.Clear();
                allResults.Clear();
                
                int totalFiles = 0;
                
                // Interpretar 0 como sin límite
                int actualResponseLimit = responseLimit == 0 ? int.MaxValue : responseLimit;
                int actualFileLimit = fileLimit == 0 ? int.MaxValue : fileLimit;
                int actualTimeout = searchTimeout == 0 ? int.MaxValue : searchTimeout * 1000;
                
                // Procesar términos en lotes paralelos según maxParallelSearches
                for (int i = 0; i < terms.Count; i += maxParallelSearches)
                {
                    var batch = terms.Skip(i).Take(maxParallelSearches).ToList();
                    Log($"📦 Procesando lote {(i/maxParallelSearches)+1}: {batch.Count} términos en paralelo");
                    
                    // Crear tareas de búsqueda para este lote
                    var searchTasks = batch.Select(async term =>
                    {
                        try
                        {
                            // Verificar si se canceló
                            searchCancellationTokenSource.Token.ThrowIfCancellationRequested();
                            
                            var startTime = DateTime.Now;
                            Log($"🔍 Iniciando: {term} (timeout: {actualTimeout/1000}s)");
                            
                            var searchOptions = new Soulseek.SearchOptions(
                                filterResponses: true,
                                maximumPeerQueueLength: actualResponseLimit,
                                searchTimeout: actualTimeout
                            );
                            
                            // ⚡ CRÍTICO: Aplicar rate limiter
                            await WaitForRateLimitAsync("manual");
                            
                            var searchResult = await client.SearchAsync(
                                SearchQuery.FromText(term), 
                                options: searchOptions
                            );
                            
                            var results = searchResult.Responses;
                            var elapsed = (DateTime.Now - startTime).TotalSeconds;
                            Log($"✅ {term}: {results.Count()} respuestas en {elapsed:F1}s");
                            
                            return (term, results);
                        }
                        catch (Exception ex)
                        {
                            Log($"❌ Error en {term}: {ex.Message}");
                            return (term, Enumerable.Empty<Soulseek.SearchResponse>());
                        }
                    }).ToList();
                    
                    // Esperar a que todas las búsquedas del lote terminen
                    var batchResults = await Task.WhenAll(searchTasks);
                    
                    // Procesar resultados de este lote
                    long minSizeBytes = numMinSize != null ? (long)(numMinSize.Value * 1024) : 0;
                    long maxSizeBytes = numMaxSize != null && numMaxSize.Value > 0 ? (long)(numMaxSize.Value * 1024) : long.MaxValue;
                    string extFilter = cmbExtension?.SelectedItem?.ToString();
                    
                    foreach (var (term, results) in batchResults)
                    {
                        foreach (var response in results)
                        {
                            // Verificar cancelación
                            searchCancellationTokenSource.Token.ThrowIfCancellationRequested();
                            
                            if (blacklist.Contains(response.Username))
                                continue;
                            
                            foreach (var file in response.Files.Take(500))
                            {
                                // Descartar archivos de tamaño 0
                                if (file.Size == 0)
                                    continue;
                                
                                if (minSizeBytes > 0 && file.Size < minSizeBytes)
                                    continue;
                                if (maxSizeBytes < long.MaxValue && file.Size > maxSizeBytes)
                                    continue;
                                
                                string fileExt = Path.GetExtension(file.Filename).ToLower();
                                if (!MatchesCategory(fileExt, extFilter))
                                    continue;
                                
                                // Filtro de idioma español
                                if (chkSpanishOnly != null && chkSpanishOnly.Checked)
                                {
                                    var fileName = Path.GetFileName(file.Filename ?? string.Empty);
                                    var detectionText = Path.GetFileNameWithoutExtension(fileName);
                                    if (string.IsNullOrWhiteSpace(detectionText))
                                    {
                                        detectionText = fileName;
                                    }

                                    if (!IsSpanishText(detectionText))
                                    {
                                        continue;
                                    }
                                }
                                
                                // Crear SearchResultItem
                                var searchItem = new SearchResultItem
                                {
                                    Username = response.Username,
                                    Filename = Path.GetFileName(file.Filename),
                                    Size = file.Size,
                                    Extension = fileExt,
                                    FolderPath = Path.GetDirectoryName(file.Filename) ?? "",
                                    UploadSpeed = response.UploadSpeed
                                };
                                allResults.Add(searchItem);
                                totalFiles++;
                                
                                // Actualizar contador cada 10 archivos (más inmediato)
                                if (totalFiles % 10 == 0)
                                {
                                    MarkSearchResultsDirty();
                                    SafeInvoke(() =>
                                    {
                                        if (lblResultsCount != null) lblResultsCount.Text = $"{totalFiles:N0} archivos...";
                                    });
                                }
                            }
                        }
                    }
                }
                
                // Actualizar Virtual ListView con todos los resultados
                lastUpdateTime = DateTime.MinValue;
                UpdateSearchResults(allResults);
                
                if (lblStatus != null) lblStatus.Text = $"{totalFiles} archivos encontrados ({terms.Count} búsquedas)";
                if (lblResultsCount != null) lblResultsCount.Text = $"{totalFiles} resultados";
                Log($"✅ Búsqueda múltiple completada: {totalFiles} archivos de {terms.Count} términos");
            }
            catch (OperationCanceledException)
            {
                if (lblStatus != null) lblStatus.Text = "Búsqueda múltiple cancelada";
                if (lblResultsCount != null) lblResultsCount.Text = $"{allResults.Count} resultados (cancelado)";
                Log("Búsqueda múltiple cancelada por el usuario");
            }
            catch (Exception ex)
            {
                RecordSearchError(); // MEJORA #5
                if (lblStatus != null) lblStatus.Text = $"Error: {ex.Message}";
                Log($"Error en búsqueda múltiple: {ex.Message}");
            }
            finally
            {
                if (btnSearch != null) btnSearch.Enabled = true;
                if (btnStopSearch != null) btnStopSearch.Enabled = false;
            }
        }
        
        /// <summary>
        /// Rate Limiter: Espera si se excede el límite de búsquedas por minuto
        /// CRÍTICO para evitar ban del servidor
        /// MEJORADO con alertas, estadísticas y modo pausa inteligente
        /// </summary>
        private async Task WaitForRateLimitAsync(string? context = null)
        {
            // CRÍTICO: Abortar inmediatamente si estamos reconectando
            // Esto evita que búsquedas pendientes interfieran con el login
            lock (this)
            {
                if (isReconnecting || isConnecting)
                {
                    throw new OperationCanceledException("Búsqueda abortada: reconexión en progreso");
                }
            }
            
            // MEJORA #9: Verificar si modo pausa inteligente está activo
            if (intelligentPauseActive && DateTime.Now < intelligentPauseUntil)
            {
                var pauseTime = (intelligentPauseUntil - DateTime.Now).TotalSeconds;
                Log($"⏸️ Modo pausa inteligente activo. Esperando {pauseTime:F0}s...");
                await Task.Delay((int)(pauseTime * 1000));
                intelligentPauseActive = false;
                Log("▶️ Reanudando operación normal");
            }

            var contextSuffix = string.IsNullOrWhiteSpace(context) ? string.Empty : $" [{context}]";
            
            await Task.Run(() =>
            {
                lock (rateLimiterLock)
                {
                    // MEJORA #4: Resetear estadísticas diarias
                    if (DateTime.Today > statsResetTime)
                    {
                        totalSearchesToday = 0;
                        manualSearchesToday = 0;
                        autoSearchesToday = 0;
                        purgeSearchesToday = 0;
                        rateLimitHitsToday = 0;
                        totalWaitTimeToday = TimeSpan.Zero;
                        statsResetTime = DateTime.Today;
                    }
                    
                    var now = DateTime.UtcNow;
                    var oneMinuteAgo = now.AddMinutes(-1);
                    
                    // Limpiar timestamps antiguos (más de 1 minuto)
                    while (searchRequestTimestamps.Count > 0 && searchRequestTimestamps.Peek() < oneMinuteAgo)
                    {
                        searchRequestTimestamps.Dequeue();
                    }
                    
                    int currentCount = searchRequestTimestamps.Count;
                    
                    // MEJORA #3: Alerta al 80% del límite
                    if (currentCount >= maxSearchesPerMinute * 0.8 && 
                        (DateTime.Now - lastRateLimitWarning).TotalSeconds > 60)
                    {
                        lastRateLimitWarning = DateTime.Now;
                        SafeInvoke(() =>
                        {
                            ShowNotification("⚠️ Rate Limit",
                                $"Has usado {currentCount}/{maxSearchesPerMinute} búsquedas ({currentCount * 100 / maxSearchesPerMinute}%)\n\nLa siguiente búsqueda puede requerir espera.",
                                ToolTipIcon.Warning);
                        });
                        Log($"⚠️ ADVERTENCIA: Rate limit al {currentCount * 100 / maxSearchesPerMinute}% ({currentCount}/{maxSearchesPerMinute})");
                    }
                    
                    // Si alcanzamos el límite, esperar hasta que podamos hacer otra búsqueda
                    if (currentCount >= maxSearchesPerMinute)
                    {
                        var oldestRequest = searchRequestTimestamps.Peek();
                        var waitUntil = oldestRequest.AddMinutes(1);
                        var waitTime = waitUntil - now;
                        
                        if (waitTime.TotalMilliseconds > 0)
                        {
                            // MEJORA #4: Registrar hit de rate limit
                            rateLimitHitsToday++;
                            
                            // REDUCCIÓN DE SPAM: Solo loggear esperas significativas (>0.5s)
                            // Y solo si han pasado >3 segundos desde el último log
                            var timeSinceLastLog = (DateTime.Now - lastRateLimitLog).TotalSeconds;
                            if (waitTime.TotalSeconds > 0.5 && timeSinceLastLog > 3)
                            {
                                Log($"⏳ Rate limit{contextSuffix} alcanzado ({currentCount}/{maxSearchesPerMinute} búsquedas/min). Esperando {waitTime.TotalSeconds:F1}s...");
                                lastRateLimitLog = DateTime.Now;
                            }
                            
                            // CRÍTICO: Dividir sleep en pequeños chunks para verificar reconexión
                            int totalWaitMs = (int)waitTime.TotalMilliseconds;
                            int chunkMs = 500; // Verificar cada 500ms
                            int elapsed = 0;
                            
                            while (elapsed < totalWaitMs)
                            {
                                // Verificar si estamos reconectando
                                lock (this)
                                {
                                    if (isReconnecting || isConnecting)
                                    {
                                        throw new OperationCanceledException("Búsqueda abortada durante espera: reconexión en progreso");
                                    }
                                }
                                
                                int sleepTime = Math.Min(chunkMs, totalWaitMs - elapsed);
                                Thread.Sleep(sleepTime);
                                elapsed += sleepTime;
                            }
                            
                            // MEJORA #4: Acumular tiempo de espera
                            totalWaitTimeToday += waitTime;
                        }
                        
                        // Limpiar después de esperar
                        now = DateTime.UtcNow;
                        oneMinuteAgo = now.AddMinutes(-1);
                        while (searchRequestTimestamps.Count > 0 && searchRequestTimestamps.Peek() < oneMinuteAgo)
                        {
                            searchRequestTimestamps.Dequeue();
                        }
                    }
                    
                    // Registrar esta búsqueda
                    searchRequestTimestamps.Enqueue(now);
                    
                    // MEJORA #4: Incrementar contador total
                    totalSearchesToday++;
                }
            });
        }
        
