        private static DialogResult ShowThemedOrSystem(
            IWin32Window? owner,
            string text,
            string? caption,
            MessageBoxButtons buttons,
            MessageBoxIcon icon,
            MessageBoxDefaultButton defaultButton)
        {
            var mainForm = ResolveMainForm(owner);
            var resolvedCaption = GetCaptionOrDefault(caption);
            var resolvedButtons = NormalizeButtons(buttons);
            var resolvedIcon = NormalizeIcon(icon);
            var resolvedDefault = NormalizeDefaultButton(defaultButton);

            if (mainForm == null)
            {
                return owner != null
                    ? System.Windows.Forms.MessageBox.Show(owner, text, resolvedCaption, resolvedButtons, resolvedIcon, resolvedDefault)
                    : System.Windows.Forms.MessageBox.Show(text, resolvedCaption, resolvedButtons, resolvedIcon, resolvedDefault);
            }

            if (mainForm.IsLightTheme())
            {
                return owner != null
                    ? System.Windows.Forms.MessageBox.Show(owner, text, resolvedCaption, resolvedButtons, resolvedIcon, resolvedDefault)
                    : System.Windows.Forms.MessageBox.Show(mainForm, text, resolvedCaption, resolvedButtons, resolvedIcon, resolvedDefault);
            }

            return mainForm.ShowThemedDialog(text, resolvedCaption, resolvedButtons, resolvedIcon, resolvedDefault);
        }

