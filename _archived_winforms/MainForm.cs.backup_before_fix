        private async Task StartTitleSearchFromTxtAsync()
        {
            if (autoSearchRunning || autoPurgeRunning)
            {
                AutoLog("⚠️ Ya hay un proceso automático en curso.");
                return;
            }

            if (client == null)
            {
                AutoLog("❌ Cliente no inicializado");
                MessageBox.Show("Error: Cliente no inicializado", "Búsqueda (TXT)", MessageBoxButtons.OK, MessageBoxIcon.Error);
                return;
            }

            bool isConnected = client.State.HasFlag(SoulseekClientStates.Connected) ||
                               client.State.HasFlag(SoulseekClientStates.LoggedIn);

            if (!isConnected)
            {
                AutoLog($"❌ No estás conectado a Soulseek (Estado: {client.State})");
                MessageBox.Show($"Debes estar conectado a Soulseek\nEstado actual: {client.State}", "Búsqueda (TXT)", MessageBoxButtons.OK, MessageBoxIcon.Error);
                return;
            }

            using var dialog = new OpenFileDialog
            {
                Filter = "Archivos de texto (*.txt)|*.txt|Todos los archivos (*.*)|*.*",
                Title = "Seleccionar TXT de obras/títulos"
            };

            if (dialog.ShowDialog(this) != DialogResult.OK)
            {
                return;
            }

            var filePath = dialog.FileName;

            SafeInvoke(() =>
            {
                if (realtimeGridUpdater == null)
                {
                    OpenDownloadsWindow();
                }
            });

            var (shouldResume, resumeTotalCount, resumeCompletedCount, resumeQueries) = await LoadTxtCheckpointIfExistsAsync(filePath);
            if (shouldResume)
            {
                try
                {
                    LoadAutoResultsFromJson();
                    realtimeGridUpdater?.Invoke();
                    lock (autoSearchResultsLock)
                    {
                        realtimeStatsUpdater?.Invoke(autoSearchResults.Count);
                    }
                }
                catch
                {
                }
            }

            int dedupeRemoved = 0;
            int noHitSkipped = 0;
            var noHitCache = LoadTxtNoHitCache();
            var nowUtc = DateTime.UtcNow;
            foreach (var key in noHitCache.Keys.ToList())
            {
                if ((nowUtc - noHitCache[key]).TotalDays > TXT_NOHIT_CACHE_DAYS)
                {
                    noHitCache.Remove(key);
                }
            }

            List<TitleSearchFromTxtService.TitleSearchQuery> queries;

            if (shouldResume)
            {
                queries = resumeQueries;
            }
            else
            {
                var noHitKeys = new HashSet<string>(noHitCache.Keys, StringComparer.Ordinal);
                var (deduped, removed, removedNoHit) = await Task.Run(() =>
                {
                    var seen = new HashSet<string>(StringComparer.Ordinal);
                    var dedupedLocal = new List<TitleSearchFromTxtService.TitleSearchQuery>();
                    var removedNoHitLocal = 0;
                    var totalParsed = 0;

                    foreach (var rawLine in File.ReadLines(filePath, Encoding.UTF8))
                    {
                        var q = ParseTitleSearchLine(rawLine);
                        if (string.IsNullOrWhiteSpace(q.Query))
                        {
                            continue;
                        }

                        totalParsed++;

                        var key = NormalizeTxtQueryKey(q.Query);
                        if (string.IsNullOrWhiteSpace(key))
                        {
                            continue;
                        }

                        if (noHitKeys.Contains(key))
                        {
                            removedNoHitLocal++;
                            continue;
                        }

                        if (seen.Add(key))
                        {
                            dedupedLocal.Add(q);
                        }
                    }

                    return (dedupedLocal, totalParsed - dedupedLocal.Count, removedNoHitLocal);
                }).ConfigureAwait(false);

                queries = deduped;
                dedupeRemoved = removed;
                noHitSkipped = removedNoHit;

                if (dedupeRemoved > 0)
                {
                    AutoLog($"🧹 TXT: deduplicación por clave normalizada: {dedupeRemoved:N0} consulta(s) omitida(s)");
                }

                if (noHitSkipped > 0)
                {
                    AutoLog($"🧊 TXT: caché sin-hits: {noHitSkipped:N0} consulta(s) saltada(s)");
                }
            }

            if (queries.Count == 0)
            {
                MessageBox.Show(
                    "El TXT está vacío o no contiene líneas válidas.\n\nFormato: 1 obra por línea. Opcional: 'Autor - Título' o 'Título by Autor'.",
                    "Búsqueda (TXT)",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Information);
                return;
            }

            LoadPurgeCache();
            var purgeRejectedGroups = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            var nowReject = DateTime.Now;
            foreach (var query in queries)
            {
                if (string.IsNullOrWhiteSpace(query.DisplayGroup))
                {
                    continue;
                }

                if (purgeCache.TryGetValue(query.DisplayGroup, out var cached))
                {
                    var age = nowReject - cached.lastCheck;
                    if (!cached.hasFiles && age.TotalDays < PURGE_CACHE_DAYS)
                    {
                        purgeRejectedGroups.Add(query.DisplayGroup);
                    }
                }
            }

            if (purgeRejectedGroups.Count > 0)
            {
                AutoLog($"⛔ Omitiendo {purgeRejectedGroups.Count} autor(es) rechazado(s) por purga en TXT");
                queries = queries
                    .Where(q => string.IsNullOrWhiteSpace(q.DisplayGroup) || !purgeRejectedGroups.Contains(q.DisplayGroup))
                    .ToList();
            }

            if (queries.Count == 0)
            {
                AutoLog("❌ No hay consultas para ejecutar (todas corresponden a autores rechazados por purga)");
                MessageBox.Show(
                    "No hay consultas disponibles para ejecutar.\n\nTodas corresponden a autores rechazados por la purga (sin archivos).",
                    "Búsqueda (TXT)",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Information);
                return;
            }

            autoSearchRunning = true;
            Interlocked.Exchange(ref txtSearchRunningFlag, 1);

            autoSearchCts?.Dispose();
            autoSearchCts = new CancellationTokenSource();
            var cancellationToken = autoSearchCts.Token;

            excludedAuthors.Clear();
            UpdateAutoControlsEnabled();

            AutoLog("");
            AutoLog("═══════════════════════════════════════");
            AutoLog("🚀 INICIANDO BÚSQUEDA (OBRAS DESDE TXT)");
            AutoLog($"📄 {queries.Count:N0} consulta(s) desde {Path.GetFileName(filePath)}");
            AutoLog("═══════════════════════════════════════");

            try
            {
                int currentParallelism = useAdaptiveParallelism
                    ? adaptiveAutoSearch.GetOptimalParallelism()
                    : maxParallelAutoSearches;

                bool enforceSpanish = chkAutoSpanishDocuments?.Checked != false;
                bool useBloom = useBloomFilterForDedup && downloadedFilesBloomFilter >= 0;
                int maxAcceptedPerQuery = 25;
                int maxResponsesPerQueryNoHit = 40;
                int maxResponsesPerQueryAfterHit = 15;
                int maxAcceptedTotal = instantDownload ? 1500 : 0;
                int globalStopTriggered = 0;

                var runner = new TitleSearchFromTxtService();

                int firstGridRefreshDone = 0;
                long lastGridRefreshTick = 0;

                var completedQueries = new ConcurrentDictionary<string, byte>(StringComparer.OrdinalIgnoreCase);
                var allQueries = queries.ToList();
                var totalQueriesCount = shouldResume && resumeTotalCount > 0 ? resumeTotalCount : allQueries.Count;
                var initialCompletedCount = shouldResume ? Math.Max(0, resumeCompletedCount) : 0;

                var dedupeSet = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                var dedupeLock = new object();

                TitleSearchFromTxtService.TitleSearchStats? latestStats = null;
                var lastLiveSummaryAt = 0;

                TitleSearchFromTxtService.TitleSearchStats? finalStats = null;

                finalStats = await runner.RunAsync(
                    queries,
                    client,
                    parallelism: currentParallelism,
                    minFileSizeKB: minFileSizeKB,
                    onlyNewFiles: onlyNewFilesInAutoSearch,
                    enforceSpanish: enforceSpanish,
                    useBloomFilter: useBloom,
                    maxAcceptedPerQuery: maxAcceptedPerQuery,
                    maxResponsesPerQueryNoHit: maxResponsesPerQueryNoHit,
                    maxResponsesPerQueryAfterHit: maxResponsesPerQueryAfterHit,
                    carbarherCacheLoaded: carbarherCacheLoaded,
                    shouldContinue: () => autoSearchRunning,
                    waitForRateLimitAsync: () => WaitForRateLimitAsync("txt"),
                    isBlacklistedUser: username => blacklist.Contains(username),
                    isDocumentFile: fileName => IsDocumentFile(fileName),
                    isSpanishText: text => IsSpanishText(text, allowRust: false),
                    bloomContainsDownloaded: fileName => downloadedFilesBloomFilter >= 0 && RustCore.BloomContains(downloadedFilesBloomFilter, fileName),
                    bloomContainsProcessed: fileName => processedFilesBloomFilter >= 0 && RustCore.BloomContains(processedFilesBloomFilter, fileName),
                    bloomInsertProcessed: fileName =>
                    {
                        if (processedFilesBloomFilter >= 0)
                        {
                            RustCore.BloomInsert(processedFilesBloomFilter, fileName);
                        }
                    },
                    carbarherContains: fileName => carbarherFilesCache.Contains(fileName),
                    isAlreadyDownloaded: fileName => IsAlreadyDownloaded(fileName, "", 0),
                    getDownloadPath: (fileName, author) => GetDownloadPath(fileName, author),
                    formatFileSize: bytes => FormatFileSize(bytes),
                    tryAddGlobalDedupeKey: key =>
                    {
                        lock (dedupeLock)
                        {
                            return dedupeSet.Add(key);
                        }
                    },
                    onAcceptedBatch: batch =>
                    {
                        if (!autoSearchRunning || cancellationToken.IsCancellationRequested)
                        {
                            return;
                        }

                        int count;
                        lock (autoSearchResultsLock)
                        {
                            foreach (var item in batch)
                            {
                                autoSearchResults.Add(item.File);
                            }
                            count = autoSearchResults.Count;
                        }

                        if (maxAcceptedTotal > 0 && count >= maxAcceptedTotal && System.Threading.Interlocked.Exchange(ref globalStopTriggered, 1) == 0)
                        {
                            AutoLog($"⏹️ TXT: límite global alcanzado ({count:N0} resultados). Deteniendo búsqueda...");
                            try { autoSearchCts?.Cancel(); } catch { }
                        }

                        if (count % 10 == 0)
                        {
                            realtimeStatsUpdater?.Invoke(count);
                        }

                        if (System.Threading.Interlocked.Exchange(ref firstGridRefreshDone, 1) == 0)
                        {
                            realtimeGridUpdater?.Invoke();
                            System.Threading.Interlocked.Exchange(ref lastGridRefreshTick, Environment.TickCount64);
                        }
                        else
                        {
                            var nowTick = Environment.TickCount64;
                            var prev = System.Threading.Interlocked.Read(ref lastGridRefreshTick);
                            if (nowTick - prev >= 700)
                            {
                                System.Threading.Interlocked.Exchange(ref lastGridRefreshTick, nowTick);
                                realtimeGridUpdater?.Invoke();
                            }
                        }

                        foreach (var item in batch)
                        {
                            SetCachedMetadata(item.MetadataKey, item.File);

                            if (instantDownload)
                            {
                                var newFile = item.File;
                                _ = Task.Run(async () =>
                                {
                                    try
                                    {
                                        string localPath = GetDownloadPath(newFile.FileName, newFile.Author);
                                        ListViewItem downloadItem = null;
                                        SafeInvoke(() =>
                                        {
                                            downloadItem = new ListViewItem(newFile.FileName);
                                            string usernameDisplay = premiumUsers.Contains(newFile.Username) ? $"⭐ {newFile.Username}" : newFile.Username;
                                            downloadItem.SubItems.Add(usernameDisplay);
                                            downloadItem.SubItems.Add("0%");
                                            downloadItem.SubItems.Add("⏳ En cola");
                                            downloadItem.SubItems.Add(newFile.SizeReadable);
                                            downloadItem.ForeColor = Color.LightGray;
                                            AddListViewItemPreservingScroll(lvDownloads, downloadItem);
                                        });

                                        AddToDownloadQueue(newFile, localPath, downloadItem, false);
                                    }
                                    catch (Exception ex)
                                    {
                                        AutoLog($"❌ Error agregando descarga inmediata: {ex.Message}");
                                    }
                                });
                            }
                        }
                    },
                    onQueryCompleted: (q, acceptedForQuery) =>
                    {
                        completedQueries.TryAdd(q.Query, 1);

                        if (!shouldResume && acceptedForQuery == 0)
                        {
                            var key = NormalizeTxtQueryKey(q.Query);
                            if (!string.IsNullOrWhiteSpace(key))
                            {
                                noHitCache[key] = DateTime.UtcNow;
                            }
                        }

                        var completedThisRun = completedQueries.Count;
                        var completedOverall = initialCompletedCount + completedThisRun;
                        if (completedOverall > 0 && completedOverall % 25 == 0)
                        {
                            _ = Task.Run(async () =>
                            {
                                try
                                {
                                    await SaveAutoResultsToJsonAsync().ConfigureAwait(false);
                                    var remaining = allQueries
                                        .Where(x => !completedQueries.ContainsKey(x.Query))
                                        .ToList();
                                    await SaveTxtCheckpointAsync(filePath, totalQueriesCount, completedOverall, remaining).ConfigureAwait(false);
                                }
                                catch
                                {
                                }
                            });
                        }
                    },
                    statsSnapshotCallback: stats =>
                    {
                        latestStats = stats;
                    },
                    progressCallback: (current, total) =>
                    {
                        var overallCurrent = initialCompletedCount + current;
                        var overallTotal = totalQueriesCount;

                        if (current % 10 == 0 || current == total)
                        {
                            AutoLog($"   Progreso TXT: {overallCurrent}/{overallTotal} ({(overallCurrent * 100.0 / Math.Max(1, overallTotal)):F0}%)");
                        }
                    },
                    cancellationToken: cancellationToken);

                try
                {
                    lock (autoSearchResultsLock)
                    {
                        realtimeStatsUpdater?.Invoke(autoSearchResults.Count);
                    }
                    realtimeGridUpdater?.Invoke();
                }
                catch
                {
                }

                lock (autoSearchResultsLock)
                {
                    if (autoSearchResults.Count > 0)
                    {
                        SaveAutoResultsToCsv();
                    }
                }

                DeleteTxtCheckpoint();

                _ = Task.Run(async () =>
                {
                    try { await SaveTxtNoHitCacheAsync(noHitCache).ConfigureAwait(false); } catch { }
                });

                AutoLog($"✅ Búsqueda TXT completada. Total resultados: {autoSearchResults.Count:N0}");

                if (finalStats != null)
                {
                    var skippedTotal =
                        finalStats.SkippedBlacklistedUsers +
                        finalStats.SkippedSizeZero +
                        finalStats.SkippedNoExtension +
                        finalStats.SkippedBelowMinSize +
                        finalStats.SkippedNotDocument +
                        finalStats.SkippedNotSpanish +
                        finalStats.SkippedBloomDownloaded +
                        finalStats.SkippedBloomProcessed +
                        finalStats.SkippedCarbarher +
                        finalStats.SkippedAlreadyDownloaded +
                        finalStats.SkippedOnlyNewLocalExists +
                        finalStats.SkippedGlobalDedupe;

                    AutoLog("═══════════════════════════════════════");
                    AutoLog("📊 RESUMEN DESCARTES (TXT)");
                    AutoLog($"   • Respuestas escaneadas: {finalStats.ScannedResponses:N0}");
                    AutoLog($"   • Archivos escaneados:   {finalStats.ScannedFiles:N0}");
                    AutoLog($"   • Aceptados:            {finalStats.AcceptedFiles:N0}");
                    AutoLog($"   • Descartados (total):  {skippedTotal:N0}");
                    AutoLog("   Motivos:");
                    AutoLog($"   • ⛔ blacklist usuario:        {finalStats.SkippedBlacklistedUsers:N0}");
                    AutoLog($"   • 0 bytes:                  {finalStats.SkippedSizeZero:N0}");
                    AutoLog($"   • sin extensión:            {finalStats.SkippedNoExtension:N0}");
                    AutoLog($"   • < minFileSizeKB:          {finalStats.SkippedBelowMinSize:N0}");
                    AutoLog($"   • no documento:             {finalStats.SkippedNotDocument:N0}");
                    AutoLog($"   • no español (filtro ON):   {finalStats.SkippedNotSpanish:N0}");
                    AutoLog($"   • bloom descargados:        {finalStats.SkippedBloomDownloaded:N0}");
                    AutoLog($"   • bloom procesados:         {finalStats.SkippedBloomProcessed:N0}");
                    AutoLog($"   • carbarher cache:          {finalStats.SkippedCarbarher:N0}");
                    AutoLog($"   • ya descargado (fallback): {finalStats.SkippedAlreadyDownloaded:N0}");
                    AutoLog($"   • solo nuevos (exists):     {finalStats.SkippedOnlyNewLocalExists:N0}");
                    AutoLog($"   • dedupe global (mismo):    {finalStats.SkippedGlobalDedupe:N0}");
                    AutoLog("═══════════════════════════════════════");
                }
            }
            catch (OperationCanceledException)
            {
                AutoLog("⏹️ Búsqueda TXT cancelada por el usuario");
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error en búsqueda TXT: {ex.Message}");
            }
            finally
            {
                autoSearchRunning = false;
                Interlocked.Exchange(ref txtSearchRunningFlag, 0);
                UpdateAutoControlsEnabled();
            }
        }
        
        private async Task StartAutomaticSearch()
        {
            if (IsTxtSearchRunning)
            {
                AutoLog("⚠️ Búsqueda automática bloqueada: hay una búsqueda TXT en curso");
                return;
            }

            var checkedAuthors = GetCheckedAuthorsFromVirtualList();

            // Si no hay autores marcados, usar todos los autores disponibles como fallback
            if (checkedAuthors.Length == 0)
            {
                AutoLog("ℹ️ No hay autores seleccionados explícitamente; usando todos los autores visibles");

                // Usar la lista filtrada si existe, si no, la lista completa
                var source = (filteredAuthorsData != null && filteredAuthorsData.Count > 0)
                    ? filteredAuthorsData
                    : allAuthorsData;

                if (source == null || source.Count == 0)
                {
                    AutoLog("❌ No hay autores disponibles para búsqueda automática");
                    MessageBox.Show("No hay autores cargados para ejecutar la búsqueda automática.", "Búsqueda Automática", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    return;
                }

                checkedAuthors = source
                    .Select(a => a.Name)
                    .Where(name => !string.IsNullOrWhiteSpace(name))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToArray();
            }
            
            if (client == null)
            {
                AutoLog("❌ Cliente no inicializado");
                MessageBox.Show("Error: Cliente no inicializado", "Búsqueda Automática", MessageBoxButtons.OK, MessageBoxIcon.Error);
                return;
            }
            
            // Verificar si está conectado (puede tener múltiples flags)
            bool isConnected = client.State.HasFlag(SoulseekClientStates.Connected) || 
                               client.State.HasFlag(SoulseekClientStates.LoggedIn);
            
            if (!isConnected)
            {
                AutoLog($"❌ No estás conectado a Soulseek (Estado: {client.State})");
                MessageBox.Show($"Debes estar conectado a Soulseek\nEstado actual: {client.State}", "Búsqueda Automática", MessageBoxButtons.OK, MessageBoxIcon.Error);
                return;
            }
            
            AutoLog($"✅ Conectado (Estado: {client.State})");
            
            var selectedAuthors = checkedAuthors.ToList();
            
            // OPTIMIZACIÓN #10: Cargar checkpoint si existe
            selectedAuthors = await LoadCheckpointIfExists(selectedAuthors);

            LoadPurgeCache();

            var purgeRejectedAuthors = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            var now = DateTime.Now;
            foreach (var author in selectedAuthors)
            {
                if (purgeCache.TryGetValue(author, out var cached))
                {
                    var age = now - cached.lastCheck;
                    if (!cached.hasFiles && age.TotalDays < PURGE_CACHE_DAYS)
                    {
                        purgeRejectedAuthors.Add(author);
                    }
                }
            }

            if (purgeRejectedAuthors.Count > 0)
            {
                AutoLog($"⛔ Omitiendo {purgeRejectedAuthors.Count} autor(es) rechazado(s) por purga");
                foreach (var author in purgeRejectedAuthors.Take(50))
                {
                    AutoLog($"   ⛔ {author} (purga: sin archivos)");
                }
                if (purgeRejectedAuthors.Count > 50)
                {
                    AutoLog($"   ... y {purgeRejectedAuthors.Count - 50} más");
                }

                selectedAuthors = selectedAuthors
                    .Where(author => !purgeRejectedAuthors.Contains(author))
                    .ToList();
            }

            if (selectedAuthors.Count == 0)
            {
                AutoLog("❌ No hay autores para búsqueda automática (todos fueron rechazados por purga o lista vacía)");
                MessageBox.Show(
                    "No hay autores disponibles para búsqueda automática.\n\nLa lista quedó vacía tras omitir autores rechazados por la purga.",
                    "Búsqueda Automática",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Information);
                return;
            }
            
            autoSearchRunning = true;

            autoSearchCts?.Dispose();
            autoSearchCts = new CancellationTokenSource();
            var cancellationToken = autoSearchCts.Token;
            
            // Limpiar lista de autores excluidos al iniciar nueva búsqueda
            excludedAuthors.Clear();

            UpdateAutoControlsEnabled();
            
            AutoLog("");
            AutoLog("═══════════════════════════════════════");
            AutoLog("🚀 INICIANDO BÚSQUEDA AUTOMÁTICA");
            AutoLog($"📚 {selectedAuthors.Count} autores seleccionados");
            AutoLog("═══════════════════════════════════════");
            
            // También mostrar en log principal
            Log($"🚀 Iniciando búsqueda automática de {selectedAuthors.Count} autores");
            
            int round = 1;
            bool anyResultsFound = true;
            int totalNewFilesThisRound = 0;
            var authorNoResultsCount = new Dictionary<string, int>();
            var authorUniqueFiles = new Dictionary<string, HashSet<string>>(); // Trackear archivos únicos por autor
            var globalUniqueFiles = new HashSet<string>(); // Todos los archivos únicos globales
            
            // Inicializar contador para cada autor y resetear contadores
            foreach (var author in selectedAuthors)
            {
                authorNoResultsCount[author] = 0;
                authorUniqueFiles[author] = new HashSet<string>();
                
                // Resetear columnas de archivos y estado
                if (InvokeRequired)
                {
                    Invoke(new Action(() => UpdateAuthorInList(author, 0, "Listo", true)));
                }
                else
                {
                    UpdateAuthorInList(author, 0, "Listo", true);
                }
            }
            
            try
            {
                while (anyResultsFound && autoSearchRunning)
                {
                    AutoLog("");
                    AutoLog($"🔄 ═══ RONDA {round} ═══");
                    
                    // Obtener paralelismo óptimo (adaptativo o fijo)
                    int currentParallelism = useAdaptiveParallelism 
                        ? adaptiveAutoSearch.GetOptimalParallelism() 
                        : maxParallelAutoSearches;
                    
                    AutoLog($"👥 Buscando {selectedAuthors.Count} autores en paralelo ({currentParallelism} simultáneos)...");
                    if (useAdaptiveParallelism)
                    {
                        AutoLog($"📊 {adaptiveAutoSearch.GetStatusSummary()}");
                    }
                    
                    anyResultsFound = false;
                    totalNewFilesThisRound = 0;
                    var authorsToRemove = new List<string>();
                    var roundStopwatch = System.Diagnostics.Stopwatch.StartNew();
                    
                    // OPTIMIZACIÓN #1: Búsqueda paralela masiva (adaptativa o configurable)
                    using (var semaphore = new SemaphoreSlim(currentParallelism, currentParallelism))
                    {
                        var processedInRound = 0;
                        var totalInRound = selectedAuthors.Count;
                        var tasks = selectedAuthors.ToList().Select(async author =>
                        {
                            await semaphore.WaitAsync(cancellationToken);
                            try
                            {
                                if (!autoSearchRunning || cancellationToken.IsCancellationRequested)
                                {
                                    return;
                                }
                            
                            // Verificar si el autor fue excluido durante la búsqueda
                            if (excludedAuthors.Contains(author))
                            {
                                AutoLog($"⛔ Autor excluido, saltando: {author}");
                                UpdateAuthorStatus(author, "⛔ Excluido");
                                return;
                            }
                            
                            // OPTIMIZACIÓN #8: Skip autores sin resultados después de 5 intentos
                            if (noResultsAuthors.Contains(author))
                            {
                                AutoLog($"⏭️ Autor sin resultados, saltando: {author}");
                                UpdateAuthorStatus(author, "⏭️ Sin resultados");
                                return;
                            }
                            
                            // OPTIMIZACIÓN #3: Verificar caché de búsquedas (24h)
                            if (authorSearchCache.TryGetValue(author, out var cachedSearch))
                            {
                                if ((DateTime.Now - cachedSearch.cached).TotalHours < AUTHOR_CACHE_HOURS)
                                {
                                    AutoLog($"💾 Usando caché para: {author} ({cachedSearch.files.Count} archivos)");
                                    
                                    lock (autoSearchResultsLock)
                                    {
                                        autoSearchResults.AddRange(cachedSearch.files);
                                    }
                                    
                                    UpdateAuthorStatus(author, $"💾 Caché ({cachedSearch.files.Count})");
                                    return;
                                }
                            }
                            
                            // Actualizar estado a "Buscando..."
                            if (InvokeRequired)
                            {
                                Invoke(new Action(() => UpdateAuthorStatus(author, "🔍 Buscando...")));
                            }
                            else
                            {
                                UpdateAuthorStatus(author, "🔍 Buscando...");
                            }

                            // Contadores por autor
                            int uniqueNewFiles = 0;
                            int totalFilesForAuthor = 0;
                            int rejectedFilesForAuthor = 0;
                            
                            try
                            {
                                // USAR MISMOS PARÁMETROS QUE PURGA (funciona bien)
                                var searchOptions = new Soulseek.SearchOptions(
                                    searchTimeout: 5000,              // 5s (igual que purga)
                                    maximumPeerQueueLength: 100,      // 100 (igual que purga) - CRÍTICO: antes era 5000
                                    filterResponses: true,            // Servidor filtra
                                    minimumResponseFileCount: 1,      // Solo con archivos
                                    minimumPeerUploadSpeed: 0
                                );
                                
                                // Búsqueda rápida: solo 1 búsqueda por autor para mayor velocidad
                                int searchIteration = 0;
                                int consecutiveEmptySearches = 0;
                                const int MAX_EMPTY_SEARCHES = 1;
                                
                                while (consecutiveEmptySearches < MAX_EMPTY_SEARCHES && autoSearchRunning && !cancellationToken.IsCancellationRequested)
                                {
                                    searchIteration++;
                                    
                                    // Verificar cancelación antes de buscar
                                    if (!autoSearchRunning || cancellationToken.IsCancellationRequested)
                                    {
                                        return;
                                    }
                                    
                                    // CRÍTICO: Aplicar rate limiting antes de cada búsqueda
                                    await WaitForRateLimitAsync("auto-author");
                                    
                                    // Optimización #8: Usar cliente del pool para evitar throttling
                                    var searchClient = client;
                                    var results = await searchClient.SearchAsync(
                                        SearchQuery.FromText(author),
                                        options: searchOptions,
                                        cancellationToken: cancellationToken
                                    );
                                    
                                    // Verificar cancelación después de buscar
                                    if (!autoSearchRunning || cancellationToken.IsCancellationRequested)
                                    {
                                        return;
                                    }
                                    
                                    int totalFiles = results.Responses.Sum(r => r.FileCount);
                                    int totalUsers = results.Responses.Count;
                                    int newFilesThisIteration = 0;
                                    
                                    foreach (var response in results.Responses)
                                {
                                        // Verificar cancelación en cada respuesta
                                        if (!autoSearchRunning || cancellationToken.IsCancellationRequested)
                                        {
                                            return;
                                        }
                                    // Filtrar usuarios de blacklist
                                    if (blacklist.Contains(response.Username))
                                        continue;
                                    
                                    foreach (var file in response.Files)
                                    {
                                        // Verificar cancelación cada 100 archivos
                                        if (!autoSearchRunning || cancellationToken.IsCancellationRequested)
                                        {
                                            return;
                                        }
                                        
                                        totalFilesForAuthor++;

                                        // Filtrar archivos de 0 bytes o sin extensión
                                        if (file.Size == 0)
                                        {
                                            rejectedFilesForAuthor++;
                                            continue;
                                        }

                                        string extension = Path.GetExtension(file.Filename);
                                        if (string.IsNullOrEmpty(extension))
                                        {
                                            rejectedFilesForAuthor++;
                                            continue;
                                        }

                                        // Filtrar por tamaño mínimo configurado
                                        if (minFileSizeKB > 0 && file.Size < (minFileSizeKB * 1024))
                                        {
                                            rejectedFilesForAuthor++;
                                            continue;
                                        }

                                        string fileName = Path.GetFileName(file.Filename ?? string.Empty);
                                        string detectionText = Path.GetFileNameWithoutExtension(fileName);
                                        if (string.IsNullOrWhiteSpace(detectionText))
                                        {
                                            detectionText = fileName;
                                        }

                                        // Verificar si es documento y español ANTES de agregar
                                        bool isDocument = IsDocumentFile(fileName);
                                        bool isSpanish = IsSpanishText(detectionText, allowRust: false);

                                        // Solo procesar documentos en español
                                        if (!isDocument)
                                        {
                                            rejectedFilesForAuthor++;
                                            continue;
                                        }

                                        bool enforceSpanish = chkAutoSpanishDocuments?.Checked != false;
                                        if (enforceSpanish && !isSpanish)
                                        {
                                            rejectedFilesForAuthor++;
                                            continue;
                                        }

                                        // OPTIMIZACIÓN RUST: Verificación ultra-rápida con Bloom Filter (200x más rápido)
                                        if (useBloomFilterForDedup && downloadedFilesBloomFilter >= 0)
                                        {
                                            // Verificar en Bloom Filter primero (0.001 ms)
                                            if (RustCore.BloomContains(downloadedFilesBloomFilter, fileName))
                                            {
                                                // Probablemente descargado - omitir (1% FPP aceptable)
                                                rejectedFilesForAuthor++;
                                                continue;
                                            }

                                            // Verificar duplicados en búsqueda actual
                                            if (processedFilesBloomFilter >= 0 && 
                                                RustCore.BloomContains(processedFilesBloomFilter, fileName))
                                            {
                                                // Ya procesado en esta búsqueda - omitir
                                                rejectedFilesForAuthor++;
                                                continue;
                                            }
                                        }

                                        // VERIFICAR SI YA EXISTE EN CARBARHER (cbh)
                                        if (carbarherCacheLoaded && carbarherFilesCache.Contains(fileName))
                                        {
                                            rejectedFilesForAuthor++;
                                            continue;
                                        }

                                        // VERIFICAR SI YA ESTÁ DESCARGADO (carpeta de descargas)
                                        // Esta verificación ahora es redundante con Bloom Filter, pero la dejamos como fallback
                                        if (IsAlreadyDownloaded(fileName, "", 0))
                                        {
                                            rejectedFilesForAuthor++;
                                            continue;
                                        }

                                        string fileKey = $"{file.Filename}|{file.Size}";
                                        if (!authorUniqueFiles[author].Contains(fileKey))
                                        {
                                            authorUniqueFiles[author].Add(fileKey);
                                            globalUniqueFiles.Add(fileKey);
                                            uniqueNewFiles++;
                                            newFilesThisIteration++;

                                            // OPTIMIZACIÓN RUST: Marcar como procesado en Bloom Filter
                                            if (useBloomFilterForDedup && processedFilesBloomFilter >= 0)
                                            {
                                                RustCore.BloomInsert(processedFilesBloomFilter, fileName);
                                            }

                                            // Guardar archivo en la lista de resultados
                                            // OPTIMIZACIÓN: Crear objeto fuera del lock
                                            var newFile = new AutoSearchFileResult
                                            {
                                                Author = author,
                                                Username = response.Username,
                                                FileName = Path.GetFileName(file.Filename),
                                                Directory = Path.GetDirectoryName(file.Filename) ?? "",
                                                SizeBytes = file.Size,
                                                SizeReadable = FormatFileSize(file.Size),
                                                IsSpanish = isSpanish,
                                                IsDocument = isDocument,
                                                Timestamp = DateTime.Now
                                            };

                                            // MEJORA #9: Filtro 'Solo Nuevos'
                                            if (onlyNewFilesInAutoSearch)
                                            {
                                                string localPath = GetDownloadPath(newFile.FileName, newFile.Author);
                                                if (System.IO.File.Exists(localPath))
                                                {
                                                    rejectedFilesForAuthor++;
                                                    continue; // Omitir archivos ya descargados
                                                }
                                            }

                                            // Lock corto: solo agregar
                                            lock (autoSearchResultsLock)
                                            {
                                                autoSearchResults.Add(newFile);
                                            }

                                            // Cachear metadatos fuera del lock
                                            SetCachedMetadata(fileKey, newFile);

                                            // DESCARGA INMEDIATA (estilo Nicotine+)
                                            if (instantDownload)
                                            {
                                                _ = Task.Run(async () =>
                                                {
                                                    try
                                                    {
                                                        string localPath = GetDownloadPath(newFile.FileName, newFile.Author);

                                                        // Crear ListViewItem para UI
                                                        ListViewItem downloadItem = null;
                                                        SafeInvoke(() =>
                                                        {
                                                            downloadItem = new ListViewItem(newFile.FileName);
                                                            string usernameDisplay = premiumUsers.Contains(newFile.Username) ? $"⭐ {newFile.Username}" : newFile.Username;
                                                            downloadItem.SubItems.Add(usernameDisplay);
                                                            downloadItem.SubItems.Add("0%");
                                                            downloadItem.SubItems.Add("⏳ En cola");
                                                            downloadItem.SubItems.Add(newFile.SizeReadable);
                                                            downloadItem.ForeColor = Color.LightGray;
                                                            AddListViewItemPreservingScroll(lvDownloads, downloadItem);
                                                        });

                                                        // Agregar a cola de descarga inmediatamente
                                                        AddToDownloadQueue(newFile, localPath, downloadItem, false);
                                                    }
                                                    catch (Exception ex)
                                                    {
                                                        AutoLog($"❌ Error agregando descarga inmediata: {ex.Message}");
                                                    }
                                                });
                                            }

                                            // Notificar actualización en tiempo real
                                            int count = autoSearchResults.Count;

                                            // OPTIMIZACIÓN #6: Deduplicar con Rust cada 1000 archivos
                                            if (count % DEDUPE_INTERVAL == 0 && SlskNativeInterop.IsAvailable)
                                            {
                                                var sw = System.Diagnostics.Stopwatch.StartNew();
                                                var deduplicated = SlskNativeInterop.DeduplicateFiles(
                                                    autoSearchResults.ToList(),
                                                    f => f.FileName,
                                                    f => f.Username,
                                                    f => f.SizeBytes,
                                                    username => (int)GetProviderScore(username)
                                                );
                                                autoSearchResults.Clear();
                                                autoSearchResults.AddRange(deduplicated);
                                                sw.Stop();
                                                AutoLog($"🦀 Deduplicación Rust en {sw.ElapsedMilliseconds}ms ({count} → {autoSearchResults.Count})");
                                            }

                                            // Actualizar estadísticas cada 10 archivos (rápido, no recarga grilla)
                                            if (count % 10 == 0)
                                            {
                                                realtimeStatsUpdater?.Invoke(count);
                                            }

                                            // Log cada 50 archivos
                                            if (count % 50 == 0)
                                            {
                                                secondaryLogger?.Invoke($"📊 {count:N0} archivos encontrados hasta ahora...");
                                            }

                                            // Actualizar grilla en tiempo real con throttling por tiempo
                                            if (realtimeGridUpdater != null)
                                            {
                                                var nowTick = Environment.TickCount64;
                                                var prev = System.Threading.Interlocked.Read(ref lastAutoSearchGridRefreshTick);
                                                if (nowTick - prev >= 700)
                                                {
                                                    System.Threading.Interlocked.Exchange(ref lastAutoSearchGridRefreshTick, nowTick);
                                                    realtimeGridUpdater?.Invoke();
                                                }
                                            }
                                        }
                                        else
                                        {
                                            rejectedFilesForAuthor++;
                                        }
                                    }
                                }

                                    // Controlar búsquedas vacías consecutivas
                                    if (newFilesThisIteration == 0)
                                    {
                                        consecutiveEmptySearches++;
                                    }
                                    else
                                    {
                                        consecutiveEmptySearches = 0;
                                    }

                                    // Pausa entre iteraciones (AUMENTADO de 500ms a 2s para evitar flood)
                                    if (consecutiveEmptySearches < MAX_EMPTY_SEARCHES)
                                    {
                                        await Task.Delay(2000, cancellationToken);
                                    }
                                }
                            }
                            catch (OperationCanceledException)
                            {
                                AutoLog($"⏹️ {author}: Búsqueda cancelada");
                                if (useAdaptiveParallelism)
                                    adaptiveAutoSearch.RecordResult(false); // Cancelación = fallo
                            }
                            catch (Exception ex)
                            {
                                AutoLog($"   ❌ {author}: Error - {ex.Message}");
                                if (useAdaptiveParallelism)
                                    adaptiveAutoSearch.RecordResult(false); // Error = fallo
                            }
                            finally
                            {
                                bool shouldPause = false;
                                int batchNumberLocal = 0;
                                int totalExpectedBatchesLocal = 0;

                                lock (authorNoResultsCount)
                                {
                                    processedInRound++;

                                    // OPTIMIZACIÓN #5: Guardado incremental cada 50 autores
                                    if (processedInRound % SAVE_INTERVAL == 0)
                                    {
                                        AutoLog($"💾 Guardando progreso ({processedInRound}/{totalInRound})...");
                                        _ = Task.Run(async () =>
                                        {
                                            await SaveAutoResultsToJsonAsync();
                                            await SaveProgressCheckpoint(processedInRound, selectedAuthors);
                                        });
                                    }

                                    // Log de progreso cada 10 autores
                                    if (processedInRound % 10 == 0)
                                    {
                                        var elapsed = roundStopwatch.Elapsed;
                                        var speed = processedInRound / elapsed.TotalSeconds;
                                        var remaining = totalInRound - processedInRound;
                                        var eta = TimeSpan.FromSeconds(remaining / speed);
                                        AutoLog($"   Progreso: {processedInRound}/{totalInRound} ({(processedInRound * 100.0 / totalInRound):F0}%) | ETA: {eta:mm\\:ss}");
                                    }

                                    // SOLUCIÓN 2,571 AUTORES: Pausas automáticas cada 500 autores
                                    authorsProcessedInCurrentBatch++;
                                    if (enableBatchPauses && authorsProcessedInCurrentBatch >= batchSize)
                                    {
                                        batchNumberLocal = (processedInRound / batchSize) + 1;
                                        totalExpectedBatchesLocal = (int)Math.Ceiling((double)totalInRound / batchSize);

                                        AutoLog("");
                                        AutoLog($" ═══ LOTE {batchNumberLocal}/{totalExpectedBatchesLocal} COMPLETADO ({batchSize} autores) ═══");

                                        // Si no es el último lote, hacer pausa
                                        if (processedInRound < totalInRound)
                                        {
                                            shouldPause = true;
                                            AutoLog($" PAUSA AUTOMÁTICA: {batchPauseDurationMinutes} minutos");
                                            AutoLog($"   Razón: Evitar flood del servidor (rate limit 100%)");
                                            AutoLog($"   Próximo lote: Autores {processedInRound + 1}-{Math.Min(processedInRound + batchSize, totalInRound)}");
                                            AutoLog($"   Tiempo estimado restante: {(totalExpectedBatchesLocal - batchNumberLocal) * (batchPauseDurationMinutes + 17)} min");

                                            lastBatchCompletedTime = DateTime.Now;
                                            authorsProcessedInCurrentBatch = 0;
                                        }
                                        else
                                        {
                                            AutoLog($" TODOS LOS LOTES COMPLETADOS ({totalExpectedBatchesLocal} lotes, {totalInRound} autores)");
                                        }

                                        authorsProcessedInCurrentBatch = 0; // Resetear contador
                                    }

                                    if (uniqueNewFiles > 0)
                                    {
                                        anyResultsFound = true;
                                        totalNewFilesThisRound += uniqueNewFiles;
                                        authorNoResultsCount[author] = 0; // Resetear contador
                                        int totalUniqueForAuthor = authorUniqueFiles[author].Count;

                                        // Registrar éxito en paralelismo adaptativo
                                        if (useAdaptiveParallelism)
                                            adaptiveAutoSearch.RecordResult(true);

                                        // OPTIMIZACIÓN #3: Guardar en caché de búsquedas
                                        var authorFiles = autoSearchResults
                                            .Where(f => f.Author.Equals(author, StringComparison.OrdinalIgnoreCase))
                                            .ToList();
                                        authorSearchCache[author] = (authorFiles, DateTime.Now);

                                        // Log siempre que encuentre archivos
                                        AutoLog($"   ✅ {author}: +{uniqueNewFiles} archivos (total: {totalUniqueForAuthor}) | Rechazados: {rejectedFilesForAuthor}/{totalFilesForAuthor}");

                                        // Actualizar columnas con total de archivos únicos del autor
                                        if (InvokeRequired)
                                        {
                                            Invoke(new Action(() => UpdateAuthorInList(author, totalUniqueForAuthor, "✅ Encontrado", false)));
                                        }
                                        else
                                        {
                                            UpdateAuthorInList(author, totalUniqueForAuthor, "✅ Encontrado", false);
                                        }
                                    }
                                    else
                                    {
                                        authorNoResultsCount[author]++;

                                        // OPTIMIZACIÓN #8: Añadir a blacklist después de 5 intentos
                                        if (authorNoResultsCount[author] >= 5)
                                        {
                                            noResultsAuthors.Add(author);
                                            AutoLog($"   ⛔ {author}: Sin resultados después de 5 intentos, añadido a blacklist");
                                            authorsToRemove.Add(author);
                                        }
                                        // Log solo si es la primera vez sin resultados
                                        if (authorNoResultsCount[author] == 1)
                                            AutoLog($"   ⚪ {author}: Sin resultados ({authorNoResultsCount[author]}/1) | Rechazados: {rejectedFilesForAuthor}/{totalFilesForAuthor}");
                                        
                                        // Actualizar estado
                                        if (InvokeRequired)
                                        {
                                            Invoke(new Action(() => UpdateAuthorStatus(author, $"⚪ Sin resultados ({authorNoResultsCount[author]}/1)")));
                                        }
                                        else
                                        {
                                            UpdateAuthorStatus(author, $"⚪ Sin resultados ({authorNoResultsCount[author]}/1)");
                                        }
                                        
                                        // Si lleva 1 ronda sin resultados, marcarlo para eliminar
                                        if (authorNoResultsCount[author] >= 1)
                                        {
                                            authorsToRemove.Add(author);
                                            AutoLog($"   🚫 {author} será eliminado (1 ronda sin resultados)");
                                            
                                            if (InvokeRequired)
                                            {
                                                Invoke(new Action(() => UpdateAuthorStatus(author, "🚫 Eliminado")));
                                            }
                                            else
                                            {
                                                UpdateAuthorStatus(author, "🚫 Eliminado");
                                            }
                                        }
                                    }
                                }
                                
                                // Ejecutar pausa FUERA del lock para evitar await en lock
                                if (shouldPause)
                                {
                                    // Pausa con countdown
                                    for (int i = batchPauseDurationMinutes; i > 0; i--)
                                    {
                                        if (!autoSearchRunning || cancellationToken.IsCancellationRequested)
                                        {
                                            AutoLog("⏹️ Búsqueda cancelada durante pausa");
                                            throw new OperationCanceledException("Búsqueda cancelada durante pausa");
                                        }
                                        
                                        AutoLog($"   Reanudando en {i} minuto(s)... (Puedes cancelar si quieres)");
                                        await Task.Delay(60000, cancellationToken); // 1 minuto
                                    }
                                    
                                    AutoLog("");
                                    AutoLog($"▶️ REANUDANDO BÚSQUEDAS - Lote {batchNumberLocal + 1}/{totalExpectedBatchesLocal}");
                                    AutoLog("");
                                }
                            }
                            }
                            finally
                            {
                                // Asegurar que el semaphore siempre se libere
                                semaphore.Release();
                            }
                        });
                        
                        try
                        {
                            await Task.WhenAll(tasks);
                        }
                        catch (OperationCanceledException)
                        {
                            AutoLog("⏹️ Búsqueda cancelada por el usuario");
                        }
                    } // Cerrar using del semaphore
                    
                    // Eliminar autores que llevan 1 ronda sin resultados
                    if (authorsToRemove.Count > 0)
                    {
                        AutoLog("");
                        AutoLog($"🗑️ Eliminando {authorsToRemove.Count} autor(es) inactivo(s):");
                        foreach (var author in authorsToRemove)
                        {
                            selectedAuthors.Remove(author);
                            authorNoResultsCount.Remove(author);
                            AutoLog($"   ❌ {author}");
                        }
                    }
                    
                    if (!anyResultsFound || selectedAuthors.Count == 0)
                    {
                        AutoLog("");
                        AutoLog("═══════════════════════════════════════");
                        if (selectedAuthors.Count == 0)
                        {
                            AutoLog($"✅ COMPLETADO - Todos los autores eliminados (sin resultados)");
                        }
                        else
                        {
                            AutoLog($"✅ COMPLETADO - Ningún autor devolvió resultados en ronda {round}");
                        }
                        AutoLog("═══════════════════════════════════════");
                    }
                    else
                    {
                        AutoLog("");
                        AutoLog($"📊 RESUMEN RONDA {round}:");
                        roundStopwatch.Stop();
                        AutoLog($"   📁 Archivos nuevos: {totalNewFilesThisRound}");
                        AutoLog($"   👥 Autores activos: {selectedAuthors.Count}");
                        AutoLog($"   ⏱️ Tiempo ronda: {roundStopwatch.Elapsed:mm\\:ss}");
                        AutoLog($"   ⚡ Velocidad: {(selectedAuthors.Count / roundStopwatch.Elapsed.TotalSeconds):F1} autores/seg");
                        
                        // También mostrar en log principal
                        Log($"📊 Ronda {round}: {totalNewFilesThisRound} archivos nuevos, {selectedAuthors.Count} autores activos");
                        
                        // Guardar resultados después de cada ronda
                        int totalResults;
                        lock (autoSearchResultsLock)
                        {
                            totalResults = autoSearchResults.Count;
                        }
                        if (totalResults > 0)
                        {
                            SaveAutoResultsToCsv();
                            AutoLog($"   💾 Total archivos guardados: {totalResults}");
                        }
                        
                        AutoLog($"   ▶️ Continuando con ronda {round + 1}...");
                        round++;
                    }
                }
            }
            finally
            {
                autoSearchRunning = false;
                UpdateAutoControlsEnabled();
                
                // OPTIMIZACIÓN #10: Eliminar checkpoint al finalizar
                DeleteCheckpoint();
                
                // Guardar resultados finales
                int finalCount;
                lock (autoSearchResultsLock)
                {
                    finalCount = autoSearchResults.Count;
                }
                if (finalCount > 0)
                {
                    SaveAutoResultsToCsv();
                    AutoLog("");
                    AutoLog($"💾 Guardado final: {finalCount} archivos únicos en {autoResultsCsvPath}");
                }
            }
        }
        
