        // Comparador personalizado para ListView (clase anidada)
        public class ListViewItemComparer : System.Collections.IComparer
        {
            private int col;
            private SortOrder order;
            private Func<ListViewItem, int, IComparable> customSortFunc;
            
            // Constructor original (2 argumentos) - para compatibilidad
            public ListViewItemComparer(int column, SortOrder order)
            {
                col = column;
                this.order = order;
                customSortFunc = null;
            }
            
            // Constructor mejorado (3 argumentos) - con función personalizada
            public ListViewItemComparer(int column, bool ascending, Func<ListViewItem, int, IComparable> sortFunc)
            {
                col = column;
                order = ascending ? SortOrder.Ascending : SortOrder.Descending;
                customSortFunc = sortFunc;
            }
            
            // Propiedades para actualizar dinámicamente
            public int ColumnIndex
            {
                get { return col; }
                set { col = value; }
            }
            
            public bool Ascending
            {
                get { return order == SortOrder.Ascending; }
                set { order = value ? SortOrder.Ascending : SortOrder.Descending; }
            }
            
            public int Compare(object x, object y)
            {
                int returnVal;
                
                var itemX = (ListViewItem)x;
                var itemY = (ListViewItem)y;
                
                // Si hay función personalizada, usarla
                if (customSortFunc != null)
                {
                    try
                    {
                        var valueX = customSortFunc(itemX, col);
                        var valueY = customSortFunc(itemY, col);
                        returnVal = valueX.CompareTo(valueY);
                    }
                    catch
                    {
                        // Fallback a comparación de texto
                        returnVal = String.Compare(itemX.SubItems[col].Text, itemY.SubItems[col].Text);
                    }
                }
                else
                {
                    // Comparación estándar
                    // Intentar comparar como números
                    if (double.TryParse(itemX.SubItems[col].Text.Replace(" KB", "").Replace(" MB", "").Replace("%", "").Replace(",", ""), out double numX) &&
                        double.TryParse(itemY.SubItems[col].Text.Replace(" KB", "").Replace(" MB", "").Replace("%", "").Replace(",", ""), out double numY))
                    {
                        returnVal = numX.CompareTo(numY);
                    }
                    else
                    {
                        // Comparar como texto
                        returnVal = String.Compare(itemX.SubItems[col].Text, itemY.SubItems[col].Text);
                    }
                }
                
                // Invertir si es descendente
                if (order == SortOrder.Descending)
                    returnVal *= -1;
                
                return returnVal;
            }
        }
        
