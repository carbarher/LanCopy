        private void InitializeQueuePositionTracker()
        {
            try
            {
                if (queuePositionTracker != null)
                {
                    return;
                }

                queuePositionTracker = new SlskDown.Core.QueuePositionTracker
                {
                    OnLog = msg =>
                    {
                        try
                        {
                            SafeLog(msg + "\n");
                        }
                        catch
