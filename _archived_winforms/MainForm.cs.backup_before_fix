        private sealed class UserInfoCacheEntry
        {
            public required UserInfo Value { get; init; }
            public required DateTime ExpiresUtc { get; init; }
        }

        private readonly ConcurrentDictionary<string, UserInfoCacheEntry> userInfoCache = new(StringComparer.OrdinalIgnoreCase);
        private readonly ConcurrentDictionary<string, Lazy<Task<UserInfo>>> userInfoInFlight = new(StringComparer.OrdinalIgnoreCase);
        private static readonly TimeSpan UserInfoDefaultTtl = TimeSpan.FromSeconds(30);

        private async Task<UserInfo?> GetUserInfoCachedAsync(
            string username,
            TimeSpan? ttl = null,
            TimeSpan? requestTimeout = null,
            CancellationToken cancellationToken = default)
        {
            if (string.IsNullOrWhiteSpace(username) || client == null)
            {
                return null;
            }

            var nowUtc = DateTime.UtcNow;
            if (userInfoCache.TryGetValue(username, out var cached) && cached.ExpiresUtc > nowUtc)
            {
                return cached.Value;
            }

            var effectiveTtl = ttl ?? UserInfoDefaultTtl;
            var effectiveTimeout = requestTimeout ?? TimeSpan.FromSeconds(4);

            Lazy<Task<UserInfo>> factory(string _) => new Lazy<Task<UserInfo>>(
                async () =>
                {
                    using var timeoutCts = new CancellationTokenSource(effectiveTimeout);
                    return await client.GetUserInfoAsync(username, timeoutCts.Token).ConfigureAwait(false);
                },
                LazyThreadSafetyMode.ExecutionAndPublication);

            var lazyTask = userInfoInFlight.GetOrAdd(username, factory);
            try
            {
                var result = await lazyTask.Value.WaitAsync(cancellationToken).ConfigureAwait(false);
                userInfoCache[username] = new UserInfoCacheEntry
                {
                    Value = result,
                    ExpiresUtc = DateTime.UtcNow.Add(effectiveTtl)
                };

                if (userInfoCache.Count > 3000)
                {
                    foreach (var kvp in userInfoCache)
                    {
                        if (kvp.Value.ExpiresUtc <= DateTime.UtcNow)
                        {
                            userInfoCache.TryRemove(kvp.Key, out _);
                        }
                    }
                }

                return result;
            }
            catch
            {
                return null;
            }
            finally
            {
                try
                {
                    userInfoInFlight.TryRemove(username, out _);
                }
                catch
                {
                }
            }
        }

