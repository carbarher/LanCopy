            lvHistory.ColumnWidthChanged += (s, e) => SaveConfig();
            lvHistory.ColumnReordered += (s, e) => SaveConfig();
            
            lvHistory.Columns.Add("Fecha/Hora", 150);
            lvHistory.Columns.Add("Archivo", 250);
            lvHistory.Columns.Add("Autor", 130);
            lvHistory.Columns.Add("Usuario", 100);
            lvHistory.Columns.Add("Tamaño", 80);
            lvHistory.Columns.Add("Velocidad", 90);
            lvHistory.Columns.Add("Estado", 100);
            lvHistory.Columns.Add("Español", 80);
            // Forzar restauración de layout después de crear columnas
            RestoreListViewLayout("lvHistory", lvHistory);
            
            // Panel de botones con FlowLayoutPanel
            var buttonPanel = new FlowLayoutPanel
            {
                Dock = DockStyle.Top,
                AutoSize = true,
                AutoSizeMode = AutoSizeMode.GrowAndShrink,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = true,
                BackColor = Color.FromArgb(35, 35, 35),
                Padding = new Padding(12, 12, 12, 10),
                Margin = new Padding(0, 0, 0, 12)
            };
            
            var btnRefresh = new Button
            {
                Text = "Actualizar",
                Size = new Size(120, 35),
                BackColor = Color.FromArgb(60, 60, 60),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Cursor = Cursors.Hand,
                Margin = new Padding(0, 0, 8, 0)
            };
            btnRefresh.FlatAppearance.BorderSize = 0;
            buttonPanel.Controls.Add(btnRefresh);
            
            var btnExportCsv = new Button
            {
                Text = "Exportar CSV",
                Size = new Size(130, 35),
                BackColor = Color.FromArgb(60, 60, 60),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Cursor = Cursors.Hand,
                Margin = new Padding(0, 0, 8, 0)
            };
            btnExportCsv.FlatAppearance.BorderSize = 0;
            buttonPanel.Controls.Add(btnExportCsv);
            
            var btnClearHistory = new Button
            {
                Text = "Sincronizar descargas",
                Size = new Size(200, 35),
                BackColor = Color.FromArgb(40, 80, 120),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Cursor = Cursors.Hand,
                Margin = new Padding(0, 0, 20, 0)
            };
            btnClearHistory.FlatAppearance.BorderSize = 0;
            var tooltip = new ToolTip();
            tooltip.SetToolTip(btnClearHistory, "Limpia historial y lo reconstruye desde archivos en disco");
            buttonPanel.Controls.Add(btnClearHistory);
            
            var lblStats = new Label
            {
                AutoSize = true,
                ForeColor = Color.LightBlue,
                Font = new Font("Segoe UI", 9),
                Margin = new Padding(0, 8, 20, 0)
            };
            buttonPanel.Controls.Add(lblStats);

            chkHistoryOnlySpanish = new CheckBox
            {
                Text = "Solo español",
                AutoSize = true,
                ForeColor = Color.LightGray,
                BackColor = Color.FromArgb(35, 35, 35),
                Margin = new Padding(0, 10, 20, 0)
            };
            buttonPanel.Controls.Add(chkHistoryOnlySpanish);
            
            var btnLoadMore = new Button
            {
                Text = "Cargar más",
                Size = new Size(120, 35),
                BackColor = Color.FromArgb(60, 60, 60),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Cursor = Cursors.Hand,
                Visible = false,
                Margin = new Padding(0)
            };
            btnLoadMore.FlatAppearance.BorderSize = 0;
            buttonPanel.Controls.Add(btnLoadMore);
            
            // Lazy loading: solo cargar últimos 500 registros por defecto
            int historyPageSize = 500;
            int historyCurrentPage = 0;
            
            // Método para cargar historial con lazy loading
            Action<bool> loadHistory = (loadAll) =>
            {
                lvHistory.BeginUpdate();
                try
                {
                    if (loadAll)
                    {
                        lvHistory.Items.Clear();
                        historyCurrentPage = 0;
                    }
                    
                    lock (downloadHistoryLock)
                    {
                        var orderedHistory = downloadHistory.OrderByDescending(h => h.DownloadedAt).ToList();
                        int skip = historyCurrentPage * historyPageSize;
                        var pageItems = orderedHistory.Skip(skip).Take(historyPageSize).ToList();
                        
                        foreach (var item in pageItems)
                        {
                            if (chkHistoryOnlySpanish.Checked && item.IsSpanish != true)
                            {
                                continue;
                            }

                            var listItem = new ListViewItem(item.DownloadedAt.ToString("yyyy-MM-dd HH:mm:ss"));
                            listItem.SubItems.Add(item.FileName);
                            listItem.SubItems.Add(item.Author);
                            listItem.SubItems.Add(item.Username);
                            listItem.SubItems.Add(FormatFileSize(item.SizeBytes));
                            listItem.SubItems.Add($"{item.SpeedMBps:F2} MB/s");
                            listItem.SubItems.Add(item.Status);
                            listItem.SubItems.Add(RenderSpanishFlag(item));
                            
                            listItem.ForeColor = item.Status == "Completed" ? Color.LightGreen : Color.Red;
                            lvHistory.Items.Add(listItem);
                        }
                        
                        historyCurrentPage++;
                        
                        // Mostrar botón "Cargar más" si hay más registros
                        btnLoadMore.Visible = (skip + historyPageSize) < orderedHistory.Count;
                        
                        var completed = downloadHistory.Count(h => h.Status == "Completed");
                        var failed = downloadHistory.Count(h => h.Status == "Failed");
                        var totalSize = FormatFileSize(downloadHistory.Where(h => h.Status == "Completed").Sum(h => h.SizeBytes));
                        
                        lblStats.Text = $"Total: {downloadHistory.Count} | Mostrando: {lvHistory.Items.Count} | ✅ {completed} | ❌ {failed} | 📦 {totalSize}";
                    }
                }
                finally
                {
                    lvHistory.EndUpdate();
                }
            };
            
            // Event handlers
            btnRefresh.Click += (s, e) => loadHistory(true);
            btnLoadMore.Click += (s, e) => loadHistory(false);
            chkHistoryOnlySpanish.CheckedChanged += (s, e) => loadHistory(true);
            
            btnExportCsv.Click += (s, e) =>
            {
                try
                {
                    var saveDialog = new SaveFileDialog
                    {
                        Filter = "CSV files (*.csv)|*.csv",
                        FileName = $"historial_descargas_{DateTime.Now:yyyyMMdd_HHmmss}.csv",
                        DefaultExt = "csv"
                    };
                    
                    if (saveDialog.ShowDialog() == DialogResult.OK)
                    {
                        var sb = new StringBuilder();
                        sb.AppendLine("Fecha/Hora,Archivo,Autor,Usuario,TamañoBytes,Velocidad MB/s,Estado");
                        
                        lock (downloadHistoryLock)
                        {
                            foreach (var item in downloadHistory.OrderByDescending(h => h.DownloadedAt))
                            {
                                sb.AppendLine($"{item.DownloadedAt:yyyy-MM-dd HH:mm:ss},{item.FileName},{item.Author},{item.Username},{item.SizeBytes},{item.SpeedMBps:F2},{item.Status}");
                            }
                        }
                        
                        System.IO.File.WriteAllText(saveDialog.FileName, sb.ToString(), Encoding.UTF8);
                        MessageBox.Show($"Historial exportado a:\n{saveDialog.FileName}", "Exportación exitosa", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    }
                }
                catch (Exception ex)
                {
                    MessageBox.Show($"Error al exportar: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            };
            
            btnClearHistory.Click += (s, e) =>
            {
                var result = MessageBox.Show(
                    "¿Sincronizar historial con carpeta de descargas?\n\n" +
                    "Esto eliminará el historial actual y lo reconstruirá desde los archivos que realmente existen en disco.\n\n" +
                    "• Archivos que ya no existan → eliminados del historial\n" +
                    "• Archivos que existan → agregados al historial\n\n" +
                    "¿Continuar?",
                    "Sincronizar con Disco",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Question);
                
                if (result == DialogResult.Yes)
                {
                    try
                    {
                        AutoLog("🔄 Iniciando sincronización con disco...");
                        
                        // 1. Limpiar historial en memoria
                        lock (downloadHistoryLock)
                        {
                            downloadHistory.Clear();
                            downloadHistoryCache.Clear();
                        }
                        
                        AutoLog("   ✅ Memoria limpiada");
                        
                        // 2. Limpiar y recrear Bloom Filter
                        if (useBloomFilterForDedup && downloadedFilesBloomFilter >= 0)
                        {
                            try
                            {
                                downloadedFilesBloomFilter = RustCore.BloomCreate(100000, 0.01);
                                AutoLog("   ✅ Bloom Filter recreado");
                            }
                            catch (Exception ex)
                            {
                                AutoLog($"   ⚠️ Error recreando Bloom Filter: {ex.Message}");
                            }
                        }
                        
                        // 3. Re-escanear carpeta física
                        AutoLog("   📂 Escaneando carpeta de descargas...");
                        ScanDownloadFolderToHistory(AutoLog);
                        
                        // 4. Guardar nuevo JSON
                        SaveDownloadHistory();
                        AutoLog("   💾 Historial guardado en JSON");
                        
                        // 5. Recargar Bloom Filter con archivos encontrados
                        if (useBloomFilterForDedup && downloadedFilesBloomFilter >= 0)
                        {
                            try
                            {
                                lock (downloadHistoryLock)
                                {
                                    var fileNames = downloadHistory.Select(h => h.FileName).ToList();
                                    if (fileNames.Count > 0)
                                    {
                                        RustCore.BloomInsertBatch(downloadedFilesBloomFilter, fileNames);
                                        AutoLog($"   🦀 Bloom Filter actualizado con {fileNames.Count} archivos");
                                    }
                                }
                            }
                            catch (Exception ex)
                            {
                                AutoLog($"   ⚠️ Error actualizando Bloom Filter: {ex.Message}");
                            }
                        }
                        
                        // 6. Actualizar UI
                        loadHistory(true);
                        
                        int totalFiles = 0;
                        lock (downloadHistoryLock)
                        {
                            totalFiles = downloadHistory.Count;
                        }
                        
                        AutoLog($"✅ Sincronización completada: {totalFiles} archivos en historial");
                        
                        MessageBox.Show(
                            $"Sincronización completada exitosamente.\n\n" +
                            $"📁 Archivos encontrados en disco: {totalFiles:N0}\n" +
                            $"💾 Historial actualizado y guardado\n" +
                            $"🦀 Bloom Filter sincronizado",
                            "Sincronización Completada",
                            MessageBoxButtons.OK,
                            MessageBoxIcon.Information);
                    }
                    catch (Exception ex)
                    {
                        AutoLog($"❌ Error durante sincronización: {ex.Message}");
                        MessageBox.Show(
                            $"Error durante la sincronización:\n\n{ex.Message}",
                            "Error",
                            MessageBoxButtons.OK,
                            MessageBoxIcon.Error);
                    }
                }
            };
            
            historyLayout.Controls.Add(buttonPanel, 0, 0);
            historyLayout.Controls.Add(lvHistory, 0, 1);
            historyTab.Controls.Add(historyLayout);
            
            // Cargar historial inicial (solo primeros 500)
            loadHistory(true);
            
            return historyTab;
        }
        
