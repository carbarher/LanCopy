        private DownloadTask GetFocusedDownloadTask()
        {
            try
            {
                var listView = lvDownloads;
                if (listView == null)
                {
                    return null;
                }

                var focused = listView.FocusedItem;
                if (focused == null)
                {
                    return null;
                }

                if (listView.VirtualMode)
                {
                    var idx = focused.Index;
                    lock (downloadVirtualLock)
                    {
                        return idx >= 0 && idx < downloadVirtualSnapshot.Count ? downloadVirtualSnapshot[idx] : null;
                    }
                }

                return focused.Tag as DownloadTask;
            }
            catch
            {
                return null;
            }
        }
        
        private void CancelSelectedDownload()
        {
            var focusedTask = GetFocusedDownloadTask();

            if (focusedTask != null)
            {
                var result = MessageBox.Show(
                    $"¿Cancelar descarga de:\n{focusedTask.File.FileName}?",
                    "Confirmar Cancelación",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Warning);

                if (result != DialogResult.Yes)
                {
                    return;
                }

                bool cancelled = downloadQueueService.Update(list =>
                {
                    if (!list.Contains(focusedTask))
                    {
                        return false;
                    }

                    focusedTask.Status = DownloadStatus.Cancelled;
                    focusedTask.CancellationToken?.Cancel();
                    return true;
                });

                if (cancelled)
                {
                    UpdateDownloadUI(focusedTask, "❌ Cancelado");
                    SafeLog($"❌ Descarga cancelada: {focusedTask.File.FileName}");
                    MarkDownloadStatsDirty();
                    ScheduleQueuePrioritization();
                }

                return;
            }

            var candidateCount = downloadQueueService.Update(list =>
                list.Count(t => t.Status == DownloadStatus.Downloading || t.Status == DownloadStatus.Queued || t.Status == DownloadStatus.Paused));

            if (candidateCount <= 0)
            {
                MessageBox.Show(
                    "No hay descargas para cancelar.",
                    "Cancelar",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Information);
                return;
            }

            var cancelAll = MessageBox.Show(
                $"No hay una descarga en foco.\n\n¿Cancelar todas las descargas pendientes/activas? ({candidateCount})",
                "Confirmar Cancelación",
                MessageBoxButtons.YesNo,
                MessageBoxIcon.Warning);

            if (cancelAll != DialogResult.Yes)
            {
                return;
            }

            StopDownloadManager();

            var cancelledTasks = downloadQueueService.Update(list =>
            {
                var tasks = list
                    .Where(t => t.Status == DownloadStatus.Downloading || t.Status == DownloadStatus.Queued || t.Status == DownloadStatus.Paused)
                    .ToList();

                foreach (var t in tasks)
                {
                    t.Status = DownloadStatus.Cancelled;
                    t.CancellationToken?.Cancel();
                }

                return tasks;
            });

            foreach (var t in cancelledTasks)
            {
                UpdateDownloadUI(t, "❌ Cancelado");
            }

            MarkDownloadStatsDirty();
            ScheduleQueuePrioritization();
        }
        
