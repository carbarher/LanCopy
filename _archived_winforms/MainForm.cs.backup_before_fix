        private void UpdateColumnHeaders(ListView listView, int sortColumn, SortOrder sortOrder)
        {
            if (listView == null || listView.Columns.Count == 0)
                return;
            
            // Obtener nombres originales de columnas según el ListView
            string[] columnNames = null;
            
            if (listView == lvResults)
