        private void OnStartQueueClick(object sender, EventArgs e)
        {
            try
            {
                var resumedTasks = downloadQueueService.Update(list =>
                {
                    var tasks = list.Where(t => t.Status == DownloadStatus.Paused).ToList();
                    foreach (var task in tasks)
                    {
                        task.Status = DownloadStatus.Queued;
                    }
                    return tasks;
                });

                int resumed = resumedTasks.Count;

                foreach (var task in resumedTasks)
                {
                    UpdateDownloadUI(task, "⏳ En cola");
                }

                if (resumed > 0)
                {
                    AutoLog($"▶️ {resumed} descarga(s) reanudada(s)");
                    ShowDarkDialog(
                        $"✅ Se reanudaron {resumed} descarga(s).\n\nLas descargas comenzarán automáticamente según la capacidad disponible.",
                        "Cola Iniciada",
                        MessageBoxButtons.OK,
                        "✅");
                }
                else
                {
                    ShowDarkDialog(
                        "No hay descargas pausadas para reanudar.",
                        "Cola Iniciada",
                        MessageBoxButtons.OK,
                        "ℹ️");
                }
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error al iniciar cola: {ex.Message}");
                ShowDarkDialog($"Error al iniciar cola:\n{ex.Message}", "Error", MessageBoxButtons.OK, "❌");
            }
        }

        private void OnClearQueueClick(object sender, EventArgs e)
        {
            try
            {
                (int totalTasks, int completedTasks) = downloadQueueService.WithQueueLock(list =>
                {
                    int total = list.Count;
                    int completed = list.Count(t => t.Status == DownloadStatus.Completed);
                    return (total, completed);
                });

                var result = ShowDarkDialog(
                    $"⚠️ ADVERTENCIA: Esta acción eliminará TODA la cola de descargas.\n\n" +
                    $"📊 Estado actual:\n" +
                    $"   • Total de tareas: {totalTasks}\n" +
                    $"   • Completadas: {completedTasks}\n" +
                    $"   • Pendientes/En progreso: {totalTasks - completedTasks}\n\n" +
                    $"🛑 Se cancelarán todas las descargas activas.\n" +
                    $"🗑️ Se eliminarán todas las tareas de la cola.\n" +
                    $"💾 Se borrará el archivo download_queue.json.\n\n" +
                    $"Esta acción NO se puede deshacer.\n\n" +
                    $"¿Estás seguro de que quieres continuar?",
                    "Eliminar Cola de Descargas",
                    MessageBoxButtons.YesNo,
                    "⚠️");

                if (result == DialogResult.Yes)
                {
                    downloadQueueService.Update(list =>
                    {
                        foreach (var task in list)
                        {
                            if (task.Status == DownloadStatus.Downloading)
                            {
                                task.CancellationToken?.Cancel();
                            }
                        }

                        list.Clear();
                    });

                    SafeInvoke(() =>
                    {
                        if (lvDownloads == null)
                        {
                            return;
                        }

                        if (lvDownloads.VirtualMode)
                        {
                            lock (downloadVirtualLock)
                            {
                                downloadVirtualSnapshot = new List<DownloadTask>();
                                virtualDownloadsCache.Clear();
                            }
                            lvDownloads.VirtualListSize = 0;
                            lvDownloads.Invalidate();
                        }
                        else
                        {
                            lvDownloads.Items.Clear();
                        }
                    });

                    var queueFile = Path.Combine(dataDir, "download_queue.json");
                    var queueFileGz = queueFile + ".gz";

                    if (System.IO.File.Exists(queueFile))
                    {
                        System.IO.File.Delete(queueFile);
                        AutoLog($"🗑️ Eliminado: download_queue.json");
                    }

                    if (System.IO.File.Exists(queueFileGz))
                    {
                        System.IO.File.Delete(queueFileGz);
                        AutoLog($"🗑️ Eliminado: download_queue.json.gz");
                    }

                    AutoLog($"🗑️ Cola de descargas eliminada completamente ({totalTasks} tareas)");

                    ShowDarkDialog(
                        $"✅ Cola de descargas eliminada.\n\n" +
                        $"Se eliminaron {totalTasks} tarea(s).\n" +
                        $"Todas las descargas activas fueron canceladas.",
                        "Cola Eliminada",
                        MessageBoxButtons.OK,
                        "✅");
                }
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error al eliminar cola: {ex.Message}");
                ShowDarkDialog($"Error al eliminar cola:\n{ex.Message}", "Error", MessageBoxButtons.OK, "❌");
            }
        }

        private async void OnResetAllClick(object sender, EventArgs e)
        {
            var result = ShowDarkDialog(
                "⚠️ ADVERTENCIA: Esta acción:\n\n" +
                "🛑 DETENDRÁ todas las descargas activas\n" +
                "🗑️ ELIMINARÁ COMPLETAMENTE:\n\n" +
                "📁 Archivos:\n" +
                "• Base de datos SQLite completa\n" +
                "• Todos los archivos de caché (búsqueda, Calibre, países, batch)\n" +
                "• Resultados de búsqueda automática (CSV y JSON)\n" +
                "• Historial de descargas y cola de descargas\n" +
                "• Estadísticas y progreso de purga/checkpoints\n" +
                "• Favoritos y búsquedas recientes\n" +
                "• Blacklist de usuarios y autores\n" +
                "• Watchlist, Wishlist y lista Premium\n" +
                "• Lista de autores y circuit breakers\n" +
                "• Todos los archivos de logs\n\n" +
                "💾 Memoria:\n" +
                "• Todas las cachés en RAM (metadata, deduplicación, etc.)\n" +
                "• Contadores y métricas (búsquedas, descargas, etc.)\n" +
                "• Historial de velocidad y latencia\n" +
                "• Índices de autores y archivos\n\n" +
                "✅ Se conservará únicamente:\n" +
                "• Configuración de usuario/contraseña\n" +
                "• Carpeta de descargas (archivos descargados)\n\n" +
                "¿Estás seguro de que quieres continuar?",
                "Reset Completo",
                MessageBoxButtons.YesNo,
                "⚠️");

            if (result == DialogResult.Yes)
            {
                try
                {
                    AutoLog("═══════════════════════════════════════");
                    AutoLog("🔥 INICIANDO RESET COMPLETO");
                    AutoLog("═══════════════════════════════════════");

                    var filesToDelete = new[]
                    {
                        Path.Combine(dataDir, "search_cache.json"),
                        calibreCacheFile,
                        countryCachePath,
                        progressPath,
                        dbPath,
                        autoResultsCsvPath,
                        autoSearchResultsJsonPath,
                        downloadHistoryPath,
                        statsPath,
                        Path.Combine(dataDir, "purge_progress.json"),
                        favoritesPath,
                        historyPath,
                        BlacklistAuthorsFilePath,
                        blacklistPath,
                        watchlistPath,
                        wishlistPath,
                        downloadQueuePath,
                        premiumUsersPath,
                        checkpointPath,
                        Path.Combine(dataDir, "circuit_breakers.json")
                    };

                    int deleted = 0;
                    long totalSize = 0;

                    foreach (var path in filesToDelete)
                    {
                        try
                        {
                            if (System.IO.File.Exists(path))
                            {
                                var size = new FileInfo(path).Length;
                                System.IO.File.Delete(path);
                                deleted++;
                                totalSize += size;
                                AutoLog($"   ✅ Eliminado: {Path.GetFileName(path)} ({FormatFileSize(size)})");
                            }
                        }
                        catch (Exception ex)
                        {
                            AutoLog($"   ❌ Error eliminando {Path.GetFileName(path)}: {ex.Message}");
                        }
                    }

                    // Limpiar carpeta de logs
                    try
                    {
                        if (System.IO.Directory.Exists(logDir))
                        {
                            var logFiles = System.IO.Directory.GetFiles(logDir);
                            foreach (var logFile in logFiles)
                            {
                                try
                                {
                                    var size = new FileInfo(logFile).Length;
                                    System.IO.File.Delete(logFile);
                                    deleted++;
                                    totalSize += size;
                                    AutoLog($"   ✅ Eliminado log: {Path.GetFileName(logFile)}");
                                }
                                catch { }
                            }
                        }
                    }
                    catch (Exception ex)
                    {
                        AutoLog($"   ⚠️ Error limpiando logs: {ex.Message}");
                    }

                    downloadManagerRunning = false;
                    await Task.Delay(1000);

                    downloadQueueService.Update(list =>
                    {
                        foreach (var task in list)
                        {
                            try { task.CancellationToken?.Cancel(); } catch { }
                        }
                    });

                    try
                    {
                        dbConnection?.Close();
                        dbConnection?.Dispose();
                        dbConnection = null;
                    }
                    catch { }

                    // Limpiar colecciones con locks
                    lock (autoSearchResultsLock) { autoSearchResults.Clear(); }
                    downloadQueueService.Update(list => list.Clear());
