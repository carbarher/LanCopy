        private double GetProviderScore(string username)
        {
            if (string.IsNullOrWhiteSpace(username))
            {
                return 0;
            }

            var stats = GetProviderStats(username);
            if (stats == null)
            {
                return 0;
            }

            double speedScore = Math.Min(stats.AverageSpeed / 2.0, 20.0);
            double successScore = stats.SuccessRate * 0.25;
            double volumeScore = Math.Min(stats.TotalDownloads / 5.0, 15.0);

            return speedScore + successScore + volumeScore;
        }

        private int GetDeterministicProviderScoreInt(string username)
        {
            if (string.IsNullOrWhiteSpace(username))
            {
                return 0;
            }

            var trimmed = username.Trim();

            if (providerScoreCache.TryGetValue(trimmed, out var cached))
            {
                return cached;
            }

            // Premium: boost fuerte y estable.
            int premiumBoost = 0;
            try
            {
                if (premiumUsers != null && premiumUsers.Contains(trimmed))
                {
                    premiumBoost = 1000;
                }
            }
            catch
            {
            }

            var stats = GetProviderStats(trimmed);
            if (stats == null)
            {
                return premiumBoost;
            }

            // Base (estable): calidad + velocidad + tasa de éxito + volumen.
            // Se mantiene int para evitar ruido por double y facilitar comparaciones en Rust.
            int quality = (int)Math.Round(stats.QualityScore);
            int speed = (int)Math.Round(Math.Min(stats.AverageSpeed, 50.0) * 10.0); // 0..500
            int success = (int)Math.Round(Math.Min(100.0, stats.SuccessRate) * 5.0); // 0..500
            int volume = (int)Math.Round(Math.Min(stats.TotalDownloads, 100) * 2.0); // 0..200

            int adaptive = 0;
            try
            {
                lock (providerStatsLock)
                {
                    if (adaptiveProviderMetrics.TryGetValue(trimmed, out var metric))
                    {
                        // Sin decay por tiempo para mantener determinismo.
                        adaptive = (int)Math.Round(Math.Min(metric.MovingAverageSpeed, ADAPTIVE_SPEED_CAP_MBPS) * 50.0);
                        adaptive -= (int)Math.Round(Math.Min(metric.FailurePenalty, ADAPTIVE_MAX_SCORE) * 10.0);
                    }
                }
            }
            catch
            {
            }

            var score = premiumBoost + quality + speed + success + volume + adaptive;
            providerScoreCache.Add(trimmed, score);
            return score;
        }

        private double GetAdaptiveThroughputScore(string username)
        {
            if (string.IsNullOrWhiteSpace(username))
            {
                return 0;
            }

            lock (providerStatsLock)
            {
                if (!adaptiveProviderMetrics.TryGetValue(username, out var metric))
                {
                    return 0;
                }

                var now = DateTime.Now;
                var age = now - metric.LastUpdate;
                if (age > ADAPTIVE_METRIC_EXPIRATION)
                {
                    adaptiveProviderMetrics.Remove(username);
                    return 0;
                }

                double decayFactor = age.TotalMinutes <= 0
                    ? 1.0
                    : Math.Exp(-age.TotalMinutes / Math.Max(1.0, ADAPTIVE_DECAY_WINDOW_MINUTES));

                double speedScore = Math.Min(metric.MovingAverageSpeed, ADAPTIVE_SPEED_CAP_MBPS) * ADAPTIVE_SPEED_WEIGHT;
                double score = (speedScore - metric.FailurePenalty) * decayFactor;

                return Math.Max(-ADAPTIVE_MAX_SCORE, Math.Min(ADAPTIVE_MAX_SCORE, score));
            }
        }

        private void UpdateAdaptiveProviderMetricsLocked(string username, bool success, double speedMBps)
        {
            if (string.IsNullOrWhiteSpace(username))
            {
                return;
            }

            if (!adaptiveProviderMetrics.TryGetValue(username, out var metric))
            {
                metric = new AdaptiveProviderMetric();
                adaptiveProviderMetrics[username] = metric;
            }

            metric.LastUpdate = DateTime.Now;

            if (success && speedMBps > 0)
            {
                metric.MovingAverageSpeed = metric.Samples == 0
                    ? speedMBps
                    : (metric.MovingAverageSpeed * (1 - ADAPTIVE_ALPHA)) + (speedMBps * ADAPTIVE_ALPHA);
                metric.Samples = Math.Min(metric.Samples + 1, 500);
                metric.FailurePenalty = Math.Max(0, metric.FailurePenalty - ADAPTIVE_FAILURE_RECOVERY);
            }
            else
            {
                metric.FailurePenalty = Math.Min(metric.FailurePenalty + ADAPTIVE_FAILURE_STEP, ADAPTIVE_MAX_SCORE);
                metric.MovingAverageSpeed *= 0.7;

                if (metric.MovingAverageSpeed < 0.01)
                {
                    metric.MovingAverageSpeed = 0;
                    metric.Samples = 0;
                }
            }
        }

        private void PruneStaleAdaptiveMetricsLocked()
        {
            if (adaptiveProviderMetrics.Count == 0)
            {
                return;
            }

            var now = DateTime.Now;
            var staleKeys = adaptiveProviderMetrics
                .Where(kv => now - kv.Value.LastUpdate > ADAPTIVE_METRIC_EXPIRATION)
                .Select(kv => kv.Key)
                .ToList();

            if (staleKeys.Count == 0)
            {
                return;
            }

            foreach (var key in staleKeys)
            {
                adaptiveProviderMetrics.Remove(key);
            }
        }

        private async Task<bool> ShouldSkipDownloadDuplicate(AutoSearchFileResult file)
        {
            try
            {
                // 1. Verificación rápida: Ya descargado según historial
                if (IsAlreadyDownloaded(file.FileName, file.Username, file.SizeBytes))
                {
                    return true;
                }
                
                // 2. Buscar archivos con mismo nombre en disco
                var downloadPath = txtDownloadDir?.Text ?? 
                    Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments), "SlskDown");
                
                if (!System.IO.Directory.Exists(downloadPath))
                    return false;
                
                var existingFiles = System.IO.Directory.GetFiles(downloadPath, file.FileName, SearchOption.AllDirectories);
                
                if (!existingFiles.Any())
                    return false;
                
                // 3. Verificar por hash (ultra-rápido con Rust)
                foreach (var existingFile in existingFiles)
                {
                    try
                    {
                        var fileInfo = new FileInfo(existingFile);
                        
                        // Si el tamaño es diferente, no es duplicado
                        if (Math.Abs(fileInfo.Length - file.SizeBytes) > 1024) // Tolerancia de 1KB
                            continue;
                        
                        // Calcular hash del archivo existente
                        string existingHash = await GetFileHashAsync(existingFile);
                        if (string.IsNullOrEmpty(existingHash))
                        {
                            continue;
                        }
                        
                        // Buscar en historial si ya tenemos este hash
                        bool hashExists = false;
                        lock (downloadHistoryLock)
                        {
                            hashExists = downloadHistory.Any(h => 
                                h.Hash == existingHash && 
                                !string.IsNullOrEmpty(h.Hash)
                            );
                        }
                        
                        if (hashExists)
                        {
                            AutoLog($"🔍 Hash duplicado encontrado: {file.FileName}");
                            return true; // Es duplicado
                        }
                    }
                    catch (Exception ex)
                    {
                        AutoLog($"⚠️ Error verificando hash de {Path.GetFileName(existingFile)}: {ex.Message}");
                    }
                }
                
                return false; // No es duplicado
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error en verificación de duplicados: {ex.Message}");
                return false; // En caso de error, permitir descarga
            }
        }
        
        private string RenameToLibreFormat(string filePath, string author)
        {
            try
            {
                // Extensiones de ebooks soportadas
                string[] ebookExtensions = { ".epub", ".mobi", ".azw", ".azw3", ".pdf", ".fb2", ".lit", ".prc", ".djvu", ".cbr", ".cbz" };
                
                string extension = Path.GetExtension(filePath).ToLower();
                if (!ebookExtensions.Contains(extension))
                {
                    return filePath;
                }
                
                string fileName = Path.GetFileNameWithoutExtension(filePath);
                string directory = Path.GetDirectoryName(filePath);
                
                // Limpiar nombre del archivo
                string cleanTitle = CleanFileName(fileName);
                
                // Limpiar nombre del autor
                string cleanAuthor = CleanAuthorName(author);
                
                // Formato Calibre: "Título - Autor.ext"
                string newFileName = $"{cleanTitle} - {cleanAuthor}{extension}";
                string newFilePath = Path.Combine(directory, newFileName);
                
                // Evitar sobrescribir si ya existe
                if (System.IO.File.Exists(newFilePath))
                {
                    AutoLog($"⚠️ El archivo ya existe: {newFileName}");
                    return filePath;
                }
                
                // Renombrar archivo
                System.IO.File.Move(filePath, newFilePath);
                AutoLog($"📚 Renombrado a formato Calibre: {newFileName}");
                return newFilePath;
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error renombrando archivo: {ex.Message}");
                return filePath;
            }
        }

        private string MoveNonSpanishDownloadedFile(string filePath)
