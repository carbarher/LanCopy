        private void FlushPendingUiUpdates()
        {
            if (isShuttingDown || IsDisposed || Disposing)
            {
                return;
            }

            var hadWork = searchResultsDirty || downloadsDirty;

            if (searchResultsDirty)
            {
                var now = DateTime.Now;
                if ((now - lastUpdateTime).TotalMilliseconds >= UPDATE_THROTTLE_MS)
                {
                    searchResultsDirty = false;
                    try
                    {
                        UpdateSearchResults(allResults?.ToList() ?? new List<SearchResultItem>());
                    }
                    catch
                    {
                    }
                }
            }

            if (downloadsDirty)
            {
                downloadsDirty = false;
                try
                {
                    if (lvDownloads != null && !lvDownloads.IsDisposed)
                    {
                        UpdateDownloadListView();
                    }
                }
                catch
                {
                }
            }

            try
            {
                if (uiRefreshTimer != null)
                {
                    var desired = hadWork ? UI_REFRESH_BUSY_MS : UI_REFRESH_IDLE_MS;
                    if (uiRefreshTimer.Interval != desired)
                    {
                        uiRefreshTimer.Interval = desired;
                    }
                }
            }
            catch
            {
            }
        }

