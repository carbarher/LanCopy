                if (splitContainer.Width <= 0)
                    return;

                var available = splitContainer.Width;
                var minLeft = splitContainer.Panel1MinSize;
                const int desiredRightMin = 320;

                var desired = Math.Max(minLeft, available / 2);
                var maxAllowed = available - desiredRightMin;
                if (maxAllowed < minLeft)
                    maxAllowed = available - 80; // permitir más espacio cuando la ventana es estrecha
                desired = Math.Min(desired, Math.Max(minLeft, maxAllowed));

                var maxSplitter = splitContainer.Width - splitContainer.Panel2MinSize;
                if (maxSplitter < minLeft)
                {
                    return;
                }

                desired = Math.Max(minLeft, Math.Min(desired, maxSplitter));

                try
                {
                    splitContainer.SplitterDistance = desired;
                }
                catch
                {
                }
            }

            parent.HandleCreated += (_, _) => AdjustAutoSplit();
            parent.Resize += (_, _) => AdjustAutoSplit();
            splitContainer.SizeChanged += (_, _) => AdjustAutoSplit();

            // Cargar autores al iniciar
            _ = LoadAuthorsFromDatabaseAsync();
            
            // Inicializar estado de botones
            UpdateAutoControlsEnabled();
            RefreshAutoSummary();
        }
        
        private async Task LoadAuthorsFromDatabaseAsync(bool ensureReady = true)
        {
            bool wasReady = authorsDatabaseReady;
            if (ensureReady)
            {
                await EnsureAuthorsDatabaseReadyAsync().ConfigureAwait(false);
                if (!wasReady && authorsDatabaseReady)
                {
                    return;
                }
            }

            if (slskDatabase == null)
            {
                return;
            }

            try
            {
                int countInDb = 0;
                try
                {
                    countInDb = await slskDatabase.GetAuthorCountAsync().ConfigureAwait(false);
                }
                catch
                {
                }

                await slskDatabase.EnsureNormalizedNamesAsync().ConfigureAwait(false);
                var authorRows = await slskDatabase.GetAuthorsWithNormalizedAsync().ConfigureAwait(false);
                var authorNames = authorRows.Select(row => row.Name).ToList();

                ResetCanonicalCaches();

                var numericAuthors = authorNames
                    .Where(IsNumericAuthor)
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToList();

                if (numericAuthors.Count > 0)
                {
                    await DeleteAuthorsFromDatabaseAsync(numericAuthors).ConfigureAwait(false);
                    authorNames = authorNames
                        .Where(name => !IsNumericAuthor(name))
                        .ToList();

                    AutoLog($"🧹 Eliminados {numericAuthors.Count:N0} autores numéricos al cargar desde la base de datos");
                }

                List<string> ordered;
                HashSet<string>? canonicalMatchesSet = null;

                var rustCanonicalMatches = SlskDownCore.FindCanonicalAuthors(authorNames, CanonicalGutenbergAuthors);

                if (rustCanonicalMatches.Count > 0)
                {
                    ordered = new List<string>(authorNames.Count);
                    canonicalMatchesSet = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                    var addedNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

                    var matchesByCanonical = rustCanonicalMatches
                        .GroupBy(match => match.CanonicalIndex)
                        .OrderBy(group => group.Key);

                    foreach (var group in matchesByCanonical)
                    {
                        foreach (var match in group.OrderBy(m => m.Index))
                        {
                            if (match.Index < 0 || match.Index >= authorNames.Count)
                            {
                                continue;
                            }

                            var name = authorNames[match.Index];
                            if (addedNames.Add(name))
                            {
                                ordered.Add(name);
                                canonicalMatchesSet.Add(name);
                            }
                        }
                    }

                    foreach (var name in authorNames.Where(name => addedNames.Add(name)).OrderBy(name => name, StringComparer.OrdinalIgnoreCase))
                    {
                        ordered.Add(name);
                    }
                }
                else
                {
                    // Fallback a ordenamiento y matching manual en C#
                    var canonicalOrder = CanonicalGutenbergAuthors;
                    var remainingEntries = new List<(string Name, string Key, HashSet<string> Tokens)>();
                    var entriesWithoutKey = new List<string>();

                    foreach (var name in authorNames)
                    {
                        var key = CreateAuthorKey(name);
                        if (string.IsNullOrWhiteSpace(key))
                        {
                            entriesWithoutKey.Add(name);
                            continue;
                        }

                        var tokens = new HashSet<string>(
                            key.Split(' ', StringSplitOptions.RemoveEmptyEntries),
                            StringComparer.OrdinalIgnoreCase);

                        remainingEntries.Add((name, key, tokens));
                    }

                    ordered = new List<string>();

                    foreach (var canonicalName in canonicalOrder)
                    {
                        var canonicalKey = CreateAuthorKey(canonicalName);
                        if (string.IsNullOrEmpty(canonicalKey))
                            continue;

                        var canonicalTokens = canonicalKey.Split(' ', StringSplitOptions.RemoveEmptyEntries);

                        var matches = remainingEntries
                            .Where(entry => AreAuthorKeysEquivalent(canonicalKey, canonicalTokens, entry.Key, entry.Tokens))
                            .ToList();

                        if (matches.Count == 0)
                            continue;

                        ordered.AddRange(matches.Select(entry => entry.Name));

                        remainingEntries.RemoveAll(entry => AreAuthorKeysEquivalent(canonicalKey, canonicalTokens, entry.Key, entry.Tokens));
                    }

                    var remaining = remainingEntries
                        .Select(entry => entry.Name)
                        .Distinct(StringComparer.OrdinalIgnoreCase)
                        .OrderBy(a => a, StringComparer.OrdinalIgnoreCase)
                        .ToList();

                    if (entriesWithoutKey.Count > 0)
                    {
                        remaining.AddRange(entriesWithoutKey);
                    }

                    ordered.AddRange(remaining);
                }

                authors = new HashSet<string>(ordered, StringComparer.OrdinalIgnoreCase);

                var rowLookup = authorRows.ToDictionary(r => r.Name, r => r, StringComparer.OrdinalIgnoreCase);

                var authorData = ordered
                    .Select(name =>
                    {
                        var hasRow = rowLookup.TryGetValue(name, out var row);
                        var isCanon = canonicalMatchesSet != null
                            ? canonicalMatchesSet.Contains(name)
                            : IsCanonicalAuthorName(name);

                        canonicalMatchCache[name] = isCanon;

                        Color foreColor;
                        if (isCanon)
                        {
                            foreColor = canonicalColorCache.GetOrAdd(name, _ => Color.Gold);
                        }
                        else
                        {
                            canonicalColorCache.TryRemove(name, out _);
                            foreColor = Color.White;
                        }

                        return new AuthorData
                        {
                            Name = name,
                            IsCanonical = isCanon,
                            NormalizedName = hasRow ? row.NormalizedName : null,
                            ForeColor = foreColor
                        };
                    })
                    .ToList();

                RecalculateDuplicateGroups(authorData);

                SafeInvoke(() =>
                {
                    allAuthorsData = authorData;
                    filteredAuthorsData = new List<AuthorData>(authorData);
                    authorIndex = authorData.ToDictionary(a => a.Name, StringComparer.OrdinalIgnoreCase);

                    RefreshAuthorsListView();
                    UpdateAuthorCount();
                });

                AutoLog($"📊 Cargados {authorNames.Count:N0} autores desde base de datos (count_db={countInDb:N0})");
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error cargando autores: {ex.Message}");
            }
        }

        private async Task DeleteSelectedAuthors()
        {
            var checkedAuthors = filteredAuthorsData.Where(a => a.IsChecked).ToList();
            
            if (checkedAuthors.Count == 0)
            {
                AutoLog("⚠️ No hay autores seleccionados para borrar");
                return;
            }
            
            var count = checkedAuthors.Count;
            var result = MessageBox.Show(
                $"¿Borrar {count} autor(es) seleccionado(s)?",
                "Confirmar borrado",
