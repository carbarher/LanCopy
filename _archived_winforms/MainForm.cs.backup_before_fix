                }
                else
                {
                    lblDownloadErrors.Text = "Errores recientes: 0";
                }
            }

            if (downloadSpeedSparkline != null && !downloadSpeedSparkline.IsDisposed)
            {
                downloadSpeedSparkline.SetSamples(snapshot.SpeedSeries ?? Array.Empty<double>());
            }

            if (lblSpeedWindowInfo != null && !lblSpeedWindowInfo.IsDisposed)
            {
                var label = $"Media móvil {SpeedWindowSeconds}s";
                if (snapshot.MovingAverageMbps > 0)
                {
