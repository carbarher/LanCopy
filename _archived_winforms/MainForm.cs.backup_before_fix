        /// <summary>
        /// Procesa resultados de búsqueda con optimizaciones Rust
        /// Aplica: Filtrado paralelo, Deduplicación y Ordenamiento
        /// </summary>
        private List<SearchResultItem> ProcessSearchResultsWithRust(List<SearchResultItem> results)
        {
            if (results == null || results.Count == 0)
                return results;
            
            var sw = System.Diagnostics.Stopwatch.StartNew();
            var originalCount = results.Count;
            var cfg = SearchFilterRules.LoadFromDataDir(dataDir);
            results = SearchFilterRules.ApplyPostFilters(results, cfg);

            var spanishOnly = (chkSpanishOnly?.Checked ?? false) || cfg.SpanishOnly;
            var minSize = cfg.MinSize ?? 0;
            var maxSize = cfg.MaxSize ?? long.MaxValue;
            var extensions = cfg.Extensions;
            var qualityFilterEnabled = chkQualityFilter?.Checked ?? false;
            var minQuality = cfg.MinQuality ?? (qualityFilterEnabled ? 60 : 0);
            if (qualityFilterEnabled && numMinQuality != null)
            {
                minQuality = (int)numMinQuality.Value;
            }
            
            try
            {
                var usedSinglePass = ProcessSearchResultsSinglePassNativeInPlace(
                    results,
                    minSize: minSize,
                    maxSize: maxSize,
                    extensions: extensions,
                    spanishOnly: spanishOnly,
                    minQuality: minQuality);

                if (!usedSinglePass)
                {
                // 1. Filtrado paralelo (si >5K resultados)
                if (results.Count > 5000)
                {
                    var beforeFilter = results.Count;
                    results = FilterResultsOptimized(
                        results,
                        minSize: minSize, // Sin filtro de tamaño mínimo por ahora
                        maxSize: maxSize,
                        extensions: extensions, // Usar todas las extensiones
                        spanishOnly: spanishOnly,
                        minQuality: minQuality
                    );

                    var afterFilter = results.Count;
                    var removed = Math.Max(0, beforeFilter - afterFilter);
                    obsFilterDiscarded += removed;
                }
                
                // 2. Deduplicación (si >10K resultados)
                if (results.Count > 10000)
                {
                    var beforeDedupe = results.Count;
                    results = DeduplicateResultsOptimized(results);
                    var afterDedupe = results.Count;
                    var removed = Math.Max(0, beforeDedupe - afterDedupe);
                    obsDedupeDiscarded += removed;
                }
                
                // 3. Ordenamiento (si >1K resultados)
                if (results.Count > 1000)
                {
                    results = SortSearchResultsOptimized(results);
                }
                }
                
                sw.Stop();

                var pipelineBin = GetPipelineBin(originalCount);
                if (usedSinglePass)
                {
                    PerformanceTracker.Instance.Track($"pipeline.singlepass_total.{pipelineBin}", sw.ElapsedMilliseconds);
                }
                else
                {
                    PerformanceTracker.Instance.Track($"pipeline.staged_total.{pipelineBin}", sw.ElapsedMilliseconds);
                }

                obsProcessCalls++;
                obsProcessTotalMs += sw.ElapsedMilliseconds;
                obsProcessTotalItemsIn += originalCount;
                obsProcessTotalItemsOut += results.Count;
                if (sw.ElapsedMilliseconds > 0)
                {
                    obsLastItemsPerSec = originalCount * 1000.0 / sw.ElapsedMilliseconds;
                }

                if (originalCount <= 1000)
                {
                    obsBinLe1k++;
                }
                else if (originalCount <= 5000)
                {
                    obsBinLe5k++;
                }
                else if (originalCount <= 10000)
                {
                    obsBinLe10k++;
                }
                else if (originalCount <= 50000)
                {
                    obsBinLe50k++;
                }
                else
                {
                    obsBinGt50k++;
                }

                PerformanceTracker.Instance.Track("pipeline.search_process", sw.ElapsedMilliseconds);
                
                if (results.Count != originalCount || sw.ElapsedMilliseconds > 10)
                {
                    Log($"🦀 Rust: Procesamiento completo {originalCount:N0} → {results.Count:N0} en {sw.ElapsedMilliseconds}ms");
                }
                
                // Actualizar estadísticas
                UpdateRustStats();
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error procesando con Rust: {ex.Message}");
            }
            
            return results;
        }
        
