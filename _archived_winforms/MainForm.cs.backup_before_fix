                UpdateAuthorCount();
            });

            AutoLog($"🗑️ Borrados {count} autor(es)");
        }

        private static string NormalizeAuthorName(string rawAuthor)
        {
            if (string.IsNullOrWhiteSpace(rawAuthor))
            {
                return string.Empty;
            }

            var trimmed = rawAuthor.Trim();
            if (trimmed.Length == 0)
            {
                return string.Empty;
            }

            // Normalizar espacios múltiples a uno
            var normalizedSpaces = Regex.Replace(trimmed, "\\s+", " ");

            // Convertir "Apellido, Nombre" en "Nombre Apellido" para unificar claves
            if (normalizedSpaces.Contains(","))
            {
                var parts = normalizedSpaces.Split(new[] { ',' }, 2);
                var lastPart = parts[0].Trim();
                var firstPart = parts.Length > 1 ? parts[1].Trim() : string.Empty;

                if (!string.IsNullOrEmpty(firstPart))
                {
                    normalizedSpaces = string.Join(" ", firstPart, lastPart).Trim();
                }
            }

            // Capitalizar palabras
            var titled = CultureInfo.CurrentCulture.TextInfo.ToTitleCase(normalizedSpaces.ToLowerInvariant());

            return titled;
        }

        private static string CreateAuthorKey(string authorName)
        {
            if (string.IsNullOrWhiteSpace(authorName))
            {
                return string.Empty;
            }

            var normalized = NormalizeAuthorName(authorName);
            return CanonicalizeAuthorKey(normalized);
        }

        private static bool IsCanonicalAuthorName(string authorName)
        {
            if (string.IsNullOrWhiteSpace(authorName))
            {
                return false;
            }

            var key = CreateAuthorKey(authorName);
            if (string.IsNullOrEmpty(key))
            {
                return false;
            }

            if (CanonicalAuthorKeys.Contains(key))
            {
                return true;
            }

            var tokens = key.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            var tokenSet = new HashSet<string>(tokens, StringComparer.OrdinalIgnoreCase);

            foreach (var canonicalKey in CanonicalAuthorKeyList)
            {
                var canonicalTokens = canonicalKey.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                if (AreAuthorKeysEquivalent(canonicalKey, canonicalTokens, key, tokenSet))
                {
                    return true;
                }
            }

            return false;
        }

        private static bool AreAuthorKeysEquivalent(
            string canonicalKey,
            IReadOnlyList<string> canonicalTokens,
            string candidateKey,
            ISet<string> candidateTokens)
        {
            if (string.IsNullOrWhiteSpace(canonicalKey) || string.IsNullOrWhiteSpace(candidateKey))
            {
                return false;
            }

            if (canonicalKey.Equals(candidateKey, StringComparison.OrdinalIgnoreCase))
            {
                return true;
            }

            if (candidateKey.IndexOf(canonicalKey, StringComparison.OrdinalIgnoreCase) >= 0 ||
                canonicalKey.IndexOf(candidateKey, StringComparison.OrdinalIgnoreCase) >= 0)
            {
                return true;
            }

            if (canonicalTokens.Count == 0 || candidateTokens.Count == 0)
            {
                return false;
            }

            var meaningfulTokens = canonicalTokens.Where(token => token.Length > 2).ToArray();
            if (meaningfulTokens.Length == 0)
            {
                meaningfulTokens = canonicalTokens.ToArray();
            }

            return meaningfulTokens.All(candidateTokens.Contains);
        }

        private static bool IsNumericAuthor(string? authorName)
        {
            if (string.IsNullOrWhiteSpace(authorName))
            {
                return true;
            }

            var cleaned = Regex.Replace(authorName, "[\\s\\p{P}]+", string.Empty);
            return cleaned.Length > 0 && cleaned.All(char.IsDigit);
        }
        
        private async Task DownloadSelectedAuthorsFiles()
        {
            var checkedAuthors = filteredAuthorsData.Where(a => a.IsChecked).ToList();
            
            if (checkedAuthors.Count == 0)
            {
                var source = (filteredAuthorsData != null && filteredAuthorsData.Count > 0)
                    ? filteredAuthorsData
                    : allAuthorsData;

                if (source == null || source.Count == 0)
                {
                    AutoLog("❌ No hay autores disponibles para descargar");
                    MessageBox.Show(
                        "No hay autores cargados para descargar.",
                        "Descarga",
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Warning
                    );
                    return;
                }

                checkedAuthors = source.ToList();
            }
            
            // Obtener archivos de los autores seleccionados (con filtros aplicados)
            List<AutoSearchFileResult> filesToDownload;
            int totalFilesBeforeFilters;
            int totalFilesAfterFilters;
            int filteredByGarbage = 0;
            int filteredByDocument = 0;
            int filteredByLanguage = 0;
            int filteredByBlacklist = 0;
            
            bool checkSpanish = chkAutoSpanishDocuments?.Checked ?? false;
            
            lock (autoSearchResultsLock)
            {
                var allFiles = autoSearchResults
                    .Where(f => checkedAuthors.Any(a => a.Name.Equals(f.Author, StringComparison.OrdinalIgnoreCase)))
                    .ToList();
                
                totalFilesBeforeFilters = allFiles.Count;
                
                // Aplicar filtros (igual que en la búsqueda automática)
                var filteredFiles = new List<AutoSearchFileResult>();
                
                foreach (var file in allFiles)
                {
                    // Filtro 1: Tamaño > 0
                    if (file.SizeBytes == 0) continue;
                    
                    // Filtro 2: No debe ser archivo basura
                    if (IsGarbageFile(file.FileName))
                    {
                        filteredByGarbage++;
                        continue;
                    }
                    
                    // Filtro 3: Debe ser documento
                    if (!IsDocumentFile(file.FileName))
                    {
                        filteredByDocument++;
                        continue;
                    }
                    
                    // Filtro 4: Idioma español (si está activado)
                    if (checkSpanish && !IsSpanishText(file.FileName))
                    {
                        filteredByLanguage++;
                        continue;
                    }
                    
                    // Filtro 5: No debe estar blacklisteado
                    if (IsFileBlacklisted(file.FileName, file.Username))
                    {
                        filteredByBlacklist++;
                        continue;
                    }
                    
                    filteredFiles.Add(file);
                }
                
                totalFilesAfterFilters = filteredFiles.Count;
                
                // Eliminar duplicados por nombre de archivo (mantener el de mejor proveedor)
                filesToDownload = filteredFiles
                    .GroupBy(f => f.FileName, StringComparer.OrdinalIgnoreCase)
                    .Select(g => g.OrderByDescending(f => GetProviderScore(f.Username)).First())
                    .ToList();
            }
            
            if (filesToDownload.Count == 0)
            {
                AutoLog($"⚠️ No hay archivos disponibles para los {checkedAuthors.Count} autor(es) seleccionado(s)");
                MessageBox.Show(
                    $"No se encontraron archivos para los autores seleccionados.\n\nEjecuta una búsqueda automática primero.",
                    "Sin archivos",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Information
                );
                return;
            }
            
            var downloadPath = txtDownloadDir?.Text ?? Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments), "SlskDown");
            
            // Contar archivos existentes vs nuevos
            int existingFiles = 0;
            int newFiles = 0;
            foreach (var file in filesToDownload)
            {
                var fullPath = GetDownloadPath(file.FileName, file.Author);
                if (IsFileDownloaded(fullPath))
                    existingFiles++;
                else
                    newFiles++;
            }
            
            if (newFiles == 0)
            {
                MessageBox.Show(
                    $"Todos los archivos ({existingFiles}) ya están descargados.\n\nUsa el botón '🔄 Redescargar' si quieres descargarlos de nuevo.",
                    "Archivos existentes",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Information
                );
                AutoLog($"⚠️ {existingFiles} archivo(s) ya descargado(s), omitidos");
                return;
            }
            
            string message = existingFiles == 0
                ? $"¿Descargar {newFiles} archivo(s) de {checkedAuthors.Count} autor(es)?"
                : $"¿Descargar {newFiles} archivo(s) nuevo(s) de {checkedAuthors.Count} autor(es)?\n({existingFiles} ya descargado(s) serán omitidos)";
            
            var result = MessageBox.Show(message, "Confirmar descarga", MessageBoxButtons.YesNo, MessageBoxIcon.Question);
            
            if (result == DialogResult.Yes)
            {
                AutoLog("═══════════════════════════════════════");
                AutoLog("📥 INICIANDO DESCARGA DE AUTORES SELECCIONADOS");
                AutoLog($"📊 Autores: {checkedAuthors.Count}");
                AutoLog($"📄 Archivos totales encontrados: {totalFilesBeforeFilters}");
                
                // Mostrar estadísticas de filtrado
                if (totalFilesBeforeFilters > totalFilesAfterFilters)
                {
                    AutoLog($"🔍 Filtros aplicados:");
                    if (filteredByGarbage > 0)
                        AutoLog($"   🗑️ Archivos basura: {filteredByGarbage}");
                    if (filteredByDocument > 0)
                        AutoLog($"   📋 No documentos: {filteredByDocument}");
                    if (filteredByLanguage > 0)
                        AutoLog($"   🌍 Otros idiomas: {filteredByLanguage}");
                    if (filteredByBlacklist > 0)
                        AutoLog($"   🚫 Blacklisteados: {filteredByBlacklist}");
                    AutoLog($"   ✅ Archivos válidos: {totalFilesAfterFilters}");
                }
                
                // Mostrar duplicados eliminados
                int duplicatesRemoved = totalFilesAfterFilters - filesToDownload.Count;
                if (duplicatesRemoved > 0)
                {
                    AutoLog($"   🔄 Duplicados eliminados: {duplicatesRemoved}");
                }
                
                AutoLog($"📄 Archivos únicos a procesar: {filesToDownload.Count}");
                AutoLog($"   • Nuevos a descargar: {newFiles}");
                AutoLog($"   • Ya descargados (omitidos): {existingFiles}");
                AutoLog($"📁 Destino: {downloadPath}");
                AutoLog("═══════════════════════════════════════");
                
                // Crear directorio si no existe
                if (!System.IO.Directory.Exists(downloadPath))
                {
                    System.IO.Directory.CreateDirectory(downloadPath);
                    AutoLog($"📂 Carpeta creada: {downloadPath}");
                }
                
                int added = 0;
                int skipped = 0;
                
                foreach (var file in filesToDownload)
                {
                    var fullPath = GetDownloadPath(file.FileName, file.Author);
                    
                    if (IsFileDownloaded(fullPath))
                    {
                        skipped++;
                    }
                    else
                    {
                        // Crear ListViewItem para la grilla de descargas
                        ListViewItem downloadItem = null;
                        SafeInvoke(() =>
                        {
                            downloadItem = new ListViewItem(file.FileName);
                            // Agregar indicador premium al username
                            string usernameDisplay = premiumUsers.Contains(file.Username) ? $"⭐ {file.Username}" : file.Username;
                            downloadItem.SubItems.Add(usernameDisplay);
                            downloadItem.SubItems.Add("0%");
                            downloadItem.SubItems.Add("⏳ En cola");
                            downloadItem.SubItems.Add(file.SizeReadable);
                            downloadItem.Tag = file;
                            AddListViewItemPreservingScroll(lvDownloads, downloadItem);
                        });
                        
                        AddToDownloadQueue(file, fullPath, downloadItem);
                        added++;
                    }
                }
                
                AutoLog($"✅ {added} archivo(s) agregado(s) a la cola de descargas");
                if (skipped > 0)
                    AutoLog($"⏭️ {skipped} archivo(s) omitido(s) (ya descargados)");
                AutoLog("═══════════════════════════════════════");
                
                // Cambiar a pestaña de descargas
                if (added > 0)
                {
                    SafeInvoke(() =>
                    {
                        var tabControl = (TabControl)this.Controls.Find("tabControl", true).FirstOrDefault();
                        if (tabControl != null)
                        {
                            for (int i = 0; i < tabControl.TabPages.Count; i++)
                            {
                                if (tabControl.TabPages[i].Text.Contains("Descargas"))
                                {
                                    tabControl.SelectedIndex = i;
                                }
                            }
                        }
                    });
                }
            }
        }
        
        private void AutoLog(string message)
        {
            if (txtAutoLog != null && !IsAutoLogDownloadRelated(message))
            {
                var timestamp = DateTime.Now.ToString("HH:mm:ss");
                var connectionStatus = (client != null && client.State.HasFlag(SoulseekClientStates.Connected)) ? "S" : "N";
                var line = $"[{timestamp}][{connectionStatus}] {message}\r\n";

                void AppendAndTrim()
                {
                    txtAutoLog.AppendText(line);
                    try
                    {
                        if (txtAutoLog.TextLength > LOG_UI_MAX_CHARS)
                        {
                            txtAutoLog.Text = txtAutoLog.Text.Substring(Math.Max(0, txtAutoLog.TextLength - LOG_UI_TRIM_TO_CHARS));
                        }
                    }
                    catch
                    {
                    }
                }

                // Asegurar que la actualización del TextBox se hace en el hilo de UI
                if (InvokeRequired)
                {
                    try
                    {
                        BeginInvoke((Action)(() => AppendAndTrim()));
                    }
                    catch (ObjectDisposedException)
                    {
                        // Ignorar si el formulario ya está cerrado
                    }
                    catch (InvalidOperationException)
                    {
                        // Ignorar si el control ya no es válido
                    }
                }
                else
                {
                    AppendAndTrim();
                }
            }
            
            // También escribir en logger secundario si existe (ventana de descargas)
            secondaryLogger?.Invoke(message);
        }

        private static bool IsAutoLogDownloadRelated(string message)
        {
            if (string.IsNullOrWhiteSpace(message))
            {
                return false;
            }

            var m = message.ToLowerInvariant();

            if (m.Contains("carpeta de descargas")
                || m.Contains("escaneando carpeta de descargas")
                || m.Contains("analizando carpeta de descargas"))
            {
                return false;
            }

            if (m.Contains("gestor de descargas")
                || m.Contains("cola de descargas")
                || m.Contains("en cola")
                || m.Contains("queued")
                || m.Contains("download")
                || m.Contains("descargar")
                || m.Contains("descarga"))
            {
                return true;
            }

            return false;
        }

        private void AutoLogThrottled(string message, int minIntervalMs = 1000)
        {
            var nowUtc = DateTime.UtcNow;
            string? skippedMessage = null;

            lock (throttledAutoLogLock)
            {
                if ((nowUtc - lastThrottledAutoLogUtc).TotalMilliseconds < minIntervalMs)
                {
                    throttledAutoLogSuppressed++;
                    return;
                }

                lastThrottledAutoLogUtc = nowUtc;

                if (throttledAutoLogSuppressed > 0)
                {
                    skippedMessage = $"... ({throttledAutoLogSuppressed} mensajes omitidos)";
                    throttledAutoLogSuppressed = 0;
                }
            }

            if (!string.IsNullOrWhiteSpace(skippedMessage))
            {
                AutoLog(skippedMessage);
            }

            AutoLog(message);
        }
        
