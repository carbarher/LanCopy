        private void ScheduleAutoConnectOnStartup()
        {
            try
            {
                ReloadCredentialsIfMissing();

                var hasUser = !string.IsNullOrWhiteSpace(username);
                var hasPass = !string.IsNullOrWhiteSpace(password);

                SafeLog($"🔍 Auto-connect startup: autoConnect={autoConnect}, username_len={(username?.Length ?? 0)}, password_len={(password?.Length ?? 0)}\n");

                if (!autoConnect)
                {
                    return;
                }

                if (!hasUser || !hasPass)
                {
                    SafeLog("⚠️ Auto-connect: credenciales faltantes (configúralas en Configuración)\n");
                    return;
                }

                // Evitar spam si el form se re-carga o se llama múltiples veces
                var now = DateTime.UtcNow;
                if ((now - lastAutoConnectAttempt) < TimeSpan.FromSeconds(10))
                {
                    return;
                }
                lastAutoConnectAttempt = now;

                if (autoConnectTimer == null)
                {
                    autoConnectTimer = new System.Windows.Forms.Timer();
                }

                autoConnectTimer.Stop();
                autoConnectTimer.Interval = 2000;
                autoConnectTimer.Tick -= AutoConnectTimer_Tick;
                autoConnectTimer.Tick += AutoConnectTimer_Tick;
                autoConnectTimer.Start();
                SafeLog("⏰ Auto-connect: timer iniciado (2s)\n");
            }
            catch (Exception ex)
            {
                SafeLog($"⚠️ Auto-connect: error programando auto-conexión: {ex.Message}\n");
            }
        }

        private async void AutoConnectTimer_Tick(object sender, EventArgs e)
        {
            autoConnectTimer?.Stop();

            lock (this)
            {
                if (isConnecting || isReconnecting)
                {
                    SafeLog("⚠️ Auto-connect cancelado: ya hay un intento en curso\n");
                    return;
                }
            }

            try
            {
                SafeLog("🚀 Auto-connect: iniciando ConnectToSoulseek()\n");
                await ConnectToSoulseek();
            }
            catch (Exception ex)
            {
                SafeLog($"❌ Auto-connect falló: {ex.GetType().Name} - {ex.Message}\n");
            }
        }
        
