        // MEJORA #5: Monitor de salud de conexión
        private async Task MonitorConnectionHealth()
        {
            try
            {
                Log("🏥 Monitor de salud iniciado");
                
                while (client?.State == SoulseekClientStates.Connected)
                {
                    await Task.Delay(60000); // Verificar cada minuto
                    
                    if (client?.State != SoulseekClientStates.Connected)
                        break;
                    
                    // 1. Verificar tasa de errores de búsqueda
                    var errorRate = GetSearchErrorRate();
                    if (errorRate > 0.3 && (searchErrorCount + searchSuccessCount) > 10) // >30% errores, mínimo 10 búsquedas
                    {
                        Log($"⚠️ ADVERTENCIA: Alta tasa de errores ({errorRate:P0})");
                        
                        // Reducir rate limit preventivamente
                        int oldLimit = maxSearchesPerMinute;
                        maxSearchesPerMinute = Math.Max(4, maxSearchesPerMinute - 2);
                        
                        if (maxSearchesPerMinute != oldLimit)
                        {
                            Log($"🐌 Rate limit reducido preventivamente: {oldLimit} → {maxSearchesPerMinute}/min");
                            
                            SafeInvoke(() =>
                            {
                                ShowNotification(
                                    "Conexión Inestable",
                                    $"Tasa de errores: {errorRate:P0}\nReduciendo actividad automáticamente",
                                    ToolTipIcon.Warning
                                );
                            });
                        }
                    }
                    
                    // 2. Verificar latencia (si hay monitor de calidad)
                    try
                    {
                        if (connectionMonitor != null)
                        {
                            var latency = await connectionMonitor.GetLatency("8.8.8.8");
                            if (latency > 5000) // >5 segundos
                            {
                                Log($"⚠️ ADVERTENCIA: Alta latencia detectada ({latency}ms)");
                            }
                        }
                    }
                    catch { }
                    
                    // 3. Verificar duración de sesión actual
                    if (currentSession != null)
                    {
                        var duration = DateTime.Now - currentSession.StartTime;
                        
                        // Felicitar por sesiones largas
                        if (duration.TotalHours >= 1 && duration.TotalHours < 1.05) // Primera hora
                        {
                            Log($"🎉 Sesión estable: {duration.TotalMinutes:F0} minutos");
                            AutoLog($"✅ Sesión estable: {duration.TotalHours:F1}h, Búsquedas: {currentSession.SearchesPerformed}");
                        }
                    }
                }
                
                Log("🏥 Monitor de salud detenido (desconexión)");
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error en monitor de salud: {ex.Message}");
            }
        }
        
        private (int totalFiles, int processedResponses, int processedFiles, int filteredBySize, int filteredByExt, int filteredBySpanish, int filteredByBlacklist) 
            ProcessAndDisplayResults(List<Soulseek.SearchResponse> responses, long minSizeBytes, long maxSizeBytes, string extFilter,
            int totalFiles, int processedResponses, int processedFiles,
            int filteredBySize, int filteredByExt, int filteredBySpanish, int filteredByBlacklist)
        {
            var candidateItems = new List<SearchResultItem>();

            foreach (var response in responses)
            {
                processedResponses++;

                if (blacklist.Contains(response.Username))
                {
                    filteredByBlacklist++;
                    continue;
                }

                foreach (var file in response.Files.Take(500))
                {
                    processedFiles++;

                    if (file.Size <= 0)
                    {
                        filteredBySize++;
                        continue;
                    }

                    var fileExt = Path.GetExtension(file.Filename);
                    if (string.IsNullOrWhiteSpace(fileExt))
                    {
                        filteredByExt++;
                        continue;
                    }

                    fileExt = fileExt.ToLowerInvariant();

                    candidateItems.Add(new SearchResultItem
                    {
                        Username = response.Username,
                        Filename = Path.GetFileName(file.Filename),
                        Size = file.Size,
                        Extension = fileExt,
                        FolderPath = Path.GetDirectoryName(file.Filename) ?? string.Empty,
                        UploadSpeed = response.UploadSpeed
                    });
                }
            }

            if (candidateItems.Count > 0)
            {
                var (filteredItems, stats) = FilterSearchItemsWithRust(
                    candidateItems,
                    minSizeBytes,
                    maxSizeBytes,
                    extFilter,
                    chkSpanishOnly?.Checked ?? false);

                filteredBySize += stats.FilteredBySize;
                filteredByExt += stats.FilteredByExtension;
                filteredBySpanish += stats.FilteredBySpanish;

                allResults.AddRange(filteredItems);
                totalFiles += stats.Passed;
            }

            // Actualizar Virtual ListView
            MarkSearchResultsDirty();
            SafeInvoke(() => lblStatus.Text = $"Buscando... {totalFiles:N0} encontrados");

            return (totalFiles, processedResponses, processedFiles, filteredBySize, filteredByExt, filteredBySpanish, filteredByBlacklist);
        }

        private async Task SearchAsync()
        {
            if (string.IsNullOrWhiteSpace(cmbSearch?.Text))
            {
                return;
            }

            var searchText = string.Empty;
            SafeInvokeBlocking(() => searchText = cmbSearch.Text);

            if (!string.IsNullOrWhiteSpace(searchText) && !searchHistory.Contains(searchText))
            {
                searchHistory.Insert(0, searchText);
                if (searchHistory.Count > 20)
                {
                    searchHistory.RemoveAt(20);
                }

                SafeInvoke(() =>
                {
                    cmbSearch.BeginUpdate();
                    try
                    {
                        cmbSearch.Items.Clear();
                        cmbSearch.Items.AddRange(searchHistory.ToArray());
                    }
                    finally
                    {
                        cmbSearch.EndUpdate();
                    }
                });

                SaveSearchHistory();
            }

            var searchTerms = searchText.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries)
                .Select(t => t.Trim())
                .Where(t => !string.IsNullOrWhiteSpace(t))
                .ToList();

            if (searchTerms.Count > 1)
            {
                Log($"Búsqueda múltiple: {searchTerms.Count} términos (máx {maxParallelSearches} simultáneos)");
                await SearchMultipleTerms(searchTerms);
                return;
            }

            if (!EnsureClientReady())
            {
                return;
            }

            var debounceKey = Regex.Replace(searchText.Trim(), "\\s+", " ");
            var nowUtc = DateTime.UtcNow;
            lock (searchDebounceLock)
            {
                if (string.Equals(lastSearchDebounceKey, debounceKey, StringComparison.OrdinalIgnoreCase))
                {
                    if (isSearchRunning)
                    {
                        return;
                    }

                    if ((nowUtc - lastSearchDebounceStartedUtc).TotalMilliseconds < SEARCH_DEBOUNCE_MS)
                    {
                        return;
                    }
                }

                lastSearchDebounceKey = debounceKey;
                lastSearchDebounceStartedUtc = nowUtc;
                isSearchRunning = true;
            }

            totalSearches++;

            var searchVariants = await BuildSearchVariantsAsync(searchText);
            if (searchVariants.Count == 0)
            {
                searchVariants.Add(searchText);
            }

            try
            {
                PrepareUiForSearch();

                searchCancellationTokenSource?.Cancel();
                searchCancellationTokenSource = new CancellationTokenSource();
                var token = searchCancellationTokenSource.Token;

                var requestTasks = searchVariants
                    .Select(variant => Task.Run(() => (Variant: variant, Request: BuildSearchWorkflowRequest(variant)), token))
                    .ToList();

                await Task.WhenAll(requestTasks);

                SearchWorkflowRequest? lastRequest = null;
                SearchWorkflowResult? lastResult = null;
                bool foundResults = false;

                foreach (var task in requestTasks)
                {
                    token.ThrowIfCancellationRequested();
                    var (variant, request) = task.Result;

                    if (request == null)
                    {
                        continue;
                    }

                    if (searchWorkflow == null)
                    {
                        Log("⚠️ searchWorkflow no inicializado. Reintentando instanciación...");
                        RefreshSearchWorkflowInstance();
                    }

                    if (searchWorkflow == null)
                    {
                        throw new InvalidOperationException("SearchWorkflow no está disponible.");
                    }

                    try
                    {
                        if (!string.Equals(variant, searchText, StringComparison.OrdinalIgnoreCase))
                        {
                            Log($"🔁 Probando variación: {variant}");
                        }

                        var result = await searchWorkflow.ExecuteAsync(request, token);

                        lastRequest = request;
                        lastResult = result;

                        if (result.Items != null && result.Items.Count > 0)
                        {
                            if (!string.Equals(variant, searchText, StringComparison.OrdinalIgnoreCase))
                            {
                                AutoLog($"✅ Variación '{variant}' produjo {result.Items.Count:N0} resultados (original: '{searchText}')");
                                SafeInvoke(() =>
                                {
                                    if (lblStatus != null)
                                    {
                                        lblStatus.Text = $"Resultados para variación: {variant}";
                                    }
                                });
                            }

                            HandleSearchWorkflowResult(request, result, variant);
                            foundResults = true;
                            break;
                        }

                        Log($"ℹ️ Sin resultados para '{variant}'");
                    }
                    catch (OperationCanceledException)
                    {
                        throw;
                    }
                    catch (Exception ex)
                    {
                        RecordSearchError();
                        Log($"⚠️ Error en búsqueda '{variant}': {ex.Message}");
                        SafeInvoke(() =>
                        {
                            if (lblStatus != null)
                            {
                                lblStatus.Text = $"Error: {ex.Message}";
                            }
                        });
                        return;
                    }
                }

                if (!foundResults)
                {
                    if (lastRequest != null && lastResult != null)
                    {
                        HandleSearchWorkflowResult(lastRequest, lastResult, searchText);
                    }

                    await ShowFuzzySuggestionsAsync(searchText);
                }
            }
            catch (OperationCanceledException)
            {
                HandleSearchCancellation();
            }
            catch (Exception ex)
            {
                RecordSearchError();
                Log($"⚠️ Error en búsqueda '{searchText}': {ex.Message}");
                SafeInvoke(() =>
                {
                    if (lblStatus != null)
                    {
                        lblStatus.Text = $"Error: {ex.Message}";
                    }
                });
            }
            finally
            {
                lock (searchDebounceLock)
                {
                    if (string.Equals(lastSearchDebounceKey, debounceKey, StringComparison.OrdinalIgnoreCase))
                    {
                        isSearchRunning = false;
                    }
                }

                SafeInvoke(() =>
                {
                    if (btnSearch != null)
                    {
                        btnSearch.Enabled = true;
                    }

                    if (btnStopSearch != null)
                    {
                        btnStopSearch.Enabled = false;
                    }
                });
            }
        }

        private async Task<List<string>> BuildSearchVariantsAsync(string query)
        {
            var variants = new List<string>();
            if (string.IsNullOrWhiteSpace(query))
            {
                return variants;
            }

            if (SearchVariantCache.TryGetValue(query, out var cached) && (DateTime.UtcNow - cached.CachedAt) <= SearchVariantCacheTtl)
            {
                return new List<string>(cached.Variants);
            }

            var unique = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

            void AddVariant(string? value)
            {
                if (string.IsNullOrWhiteSpace(value))
                {
                    return;
                }

                var cleaned = Regex.Replace(value.Trim(), "\\s+", " ");
                if (cleaned.Length == 0)
                {
                    return;
                }

                if (unique.Add(cleaned))
                {
                    variants.Add(cleaned);
                }
            }

            AddVariant(query);

            var normalizedSpaces = Regex.Replace(query, "\\s+", " ").Trim();
            if (!string.Equals(normalizedSpaces, query, StringComparison.OrdinalIgnoreCase))
            {
                AddVariant(normalizedSpaces);
            }

            var withoutPunctuation = Regex.Replace(normalizedSpaces, "[\\p{P}]+", " ").Trim();
            if (!string.Equals(withoutPunctuation, normalizedSpaces, StringComparison.OrdinalIgnoreCase))
            {
                AddVariant(withoutPunctuation);
            }

            var accentless = RemoveAccents(normalizedSpaces);
            if (!string.Equals(accentless, normalizedSpaces, StringComparison.OrdinalIgnoreCase))
            {
                AddVariant(accentless);
            }

            string titlePart = normalizedSpaces;
            string authorPart = string.Empty;

            if (normalizedSpaces.Contains("-"))
            {
                var parts = normalizedSpaces.Split(new[] { '-' }, 2);
                var left = parts[0].Trim();
                var right = parts.Length > 1 ? parts[1].Trim() : string.Empty;
                if (!string.IsNullOrEmpty(left) && !string.IsNullOrEmpty(right))
                {
                    authorPart = left;
                    titlePart = right;
                    AddVariant($"{right} {left}");
                    AddVariant($"{left} {right}");
                    AddVariant(right);
                    AddVariant(left);
                }
            }
            else
            {
                var byIndex = normalizedSpaces.IndexOf(" by ", StringComparison.OrdinalIgnoreCase);
                if (byIndex >= 0)
                {
                    var before = normalizedSpaces.Substring(0, byIndex).Trim();
                    var after = normalizedSpaces.Substring(byIndex + 4).Trim();
                    if (!string.IsNullOrEmpty(before) && !string.IsNullOrEmpty(after))
                    {
                        titlePart = before;
                        authorPart = after;
                        AddVariant($"{after} {before}");
                        AddVariant($"{before} {after}");
                    }
                }
            }

            try
            {
                var generated = await Task.Run(() => SlskDownCore.GenerateSearchVariations(titlePart, authorPart)).ConfigureAwait(false);
                foreach (var variation in generated)
                {
                    if (unique.Count >= 10)
                    {
                        break;
                    }

                    AddVariant(variation);
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error generando variaciones Rust: {ex.Message}");
            }

            if (variants.Count > 6)
            {
                variants = variants.Take(6).ToList();
            }

            SearchVariantCache[query] = new CachedSearchVariantsEntry(new List<string>(variants), DateTime.UtcNow);

            return variants;
        }

        private async Task ShowFuzzySuggestionsAsync(string originalQuery)
        {
            if (string.IsNullOrWhiteSpace(originalQuery))
            {
                return;
            }

            if (FuzzySuggestionCache.TryGetValue(originalQuery, out var cached) && (DateTime.UtcNow - cached.CachedAt) <= FuzzySuggestionCacheTtl)
            {
                RenderFuzzySuggestions(cached.Suggestions);
                return;
            }

            var candidates = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

            if (allAuthorsData != null)
            {
                foreach (var author in allAuthorsData)
                {
                    if (!string.IsNullOrEmpty(author.Name))
                    {
                        candidates.Add(author.Name);
                    }
                }
            }

            if (watchlist != null)
            {
                foreach (var entry in watchlist)
                {
                    if (!string.IsNullOrWhiteSpace(entry))
                    {
                        candidates.Add(entry);
                    }
                }
            }

            foreach (var term in searchHistory)
            {
                candidates.Add(term);
            }

            if (candidates.Count == 0)
            {
                return;
            }

            try
            {
                var suggestions = await Task.Run(() => SlskDownCore.FuzzySearch(originalQuery, candidates, 0.72)
                    .OrderByDescending(s => s.Similarity)
                    .Take(5)
                    .ToList()).ConfigureAwait(false);

                if (suggestions.Count == 0)
                {
                    return;
                }

                FuzzySuggestionCache[originalQuery] = new CachedFuzzySuggestionsEntry(suggestions, DateTime.UtcNow);
                RenderFuzzySuggestions(suggestions);
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error generando sugerencias fuzzy: {ex.Message}");
            }
        }

        private void RenderFuzzySuggestions(IReadOnlyList<(string Candidate, double Similarity)> suggestions)
        {
            if (suggestions == null || suggestions.Count == 0)
            {
                return;
            }

            var culture = CultureInfo.CurrentCulture;
            var logText = string.Join(", ", suggestions.Select(s => $"{s.Candidate} ({s.Similarity.ToString("P0", culture)})"));
            AutoLog($"💡 Sugerencias de búsqueda: {logText}");

            SafeInvoke(() =>
            {
                if (lblStatus != null)
                {
                    var statusText = string.Join(" • ", suggestions.Select(s => s.Candidate));
                    lblStatus.Text = $"Sin resultados. Intenta con: {statusText}";
                }
            });
        }

        private SearchWorkflowRequest? BuildSearchWorkflowRequest(string query)
        {
            if (string.IsNullOrWhiteSpace(query))
            {
                return null;
            }

            var timeoutSeconds = searchTimeout <= 0 ? int.MaxValue : searchTimeout;
            var responseLimitValue = responseLimit <= 0 ? int.MaxValue : responseLimit;
            var fileLimitValue = fileLimit <= 0 ? int.MaxValue : fileLimit;

            var minSizeBytes = numMinSize != null ? (long)(numMinSize.Value * 1024) : 0;
            var maxSizeBytes = numMaxSize != null && numMaxSize.Value > 0 ? (long)(numMaxSize.Value * 1024) : long.MaxValue;
            var extensionSelection = cmbExtension?.SelectedItem?.ToString() ?? "Todos";
            var allowedExtensions = ResolveAllowedExtensions(extensionSelection);
            var spanishOnly = chkSpanishOnly?.Checked ?? false;

            Func<Soulseek.File, bool>? blacklistPredicate = null;
            if (carbarherCacheLoaded)
            {
                blacklistPredicate = file => carbarherFilesCache.Contains(Path.GetFileName(file.Filename));
            }

            var garbagePredicate = new Func<string, bool>(IsGarbageFile);
            var extensionPredicate = new Func<string, bool>(ext => MatchesCategory(ext, extensionSelection));
            var spanishHeuristic = spanishOnly
                ? new Func<string, bool>(text => IsSpanishText(text))
                : null;

            var filters = new SearchFilterContext
            {
                MinSizeBytes = minSizeBytes > 0 ? minSizeBytes : null,
                MaxSizeBytes = maxSizeBytes < long.MaxValue ? maxSizeBytes : null,
                AllowedExtensions = allowedExtensions,
                SpanishOnly = spanishOnly,
                BlacklistedUsers = blacklist,
                BlacklistFilePredicate = blacklistPredicate,
                GarbageFilePredicate = garbagePredicate,
                SpanishHeuristic = spanishHeuristic,
                ExtensionPredicate = extensionPredicate,
                ExtensionCategory = extensionSelection
            };

            return new SearchWorkflowRequest
            {
                Query = query,
                Timeout = TimeSpan.FromSeconds(timeoutSeconds),
                ResponseLimit = responseLimitValue,
                FileLimit = fileLimitValue,
                ContinuousMode = continuousSearch,
                ContinuousInterval = TimeSpan.FromSeconds(2),
                ContinuousEmptyThreshold = 3,
                UseCache = true,
                Filters = filters
            };
        }

        private void HandleSearchWorkflowResult(SearchWorkflowRequest request, SearchWorkflowResult result, string usedQuery)
        {
            allResults = result.Items?.ToList() ?? new List<SearchResultItem>();

            if (result.FromCache)
            {
                Log($"💾 Resultados obtenidos desde caché ({allResults.Count:N0}) para '{request.Query}'");
            }

            allResults = ProcessSearchResultsWithRust(allResults);

            try
            {
                if (allResults.Count == 0 && result.Stats != null && result.Stats.FilesProcessed > 0)
                {
                    var filters = request?.Filters;
                    var extensionsCount = filters?.AllowedExtensions?.Count ?? 0;
                    var blacklistedUsersCount = filters?.BlacklistedUsers?.Count ?? 0;
                    var minSize = filters?.MinSizeBytes?.ToString() ?? "(none)";
                    var maxSize = filters?.MaxSizeBytes?.ToString() ?? "(none)";
                    var category = filters?.ExtensionCategory ?? "(null)";
                    var spanishOnly = filters?.SpanishOnly ?? false;

                    Log(
                        $"⚠️ Búsqueda '{request?.Query}' terminó con 0 resultados tras filtrar. " +
                        $"Procesados: files={result.Stats.FilesProcessed:N0}, responses={result.Stats.ResponsesProcessed:N0}. " +
                        $"Filtrados: size={result.Stats.FilesFilteredBySize:N0}, ext={result.Stats.FilesFilteredByExtension:N0}, " +
                        $"spanish={result.Stats.FilesFilteredBySpanish:N0}, blacklist={result.Stats.FilesFilteredByBlacklist:N0}. " +
                        $"Filtros activos: spanishOnly={spanishOnly}, category='{category}', allowedExt={extensionsCount}, " +
                        $"minSize={minSize}, maxSize={maxSize}, blacklistedUsers={blacklistedUsersCount}."
                    );

                    SafeInvoke(() =>
                    {
                        if (lblStatus != null)
                        {
                            lblStatus.Text = "0 resultados (revisar filtros: español/extensiones/tamaño)";
                        }
                    });
                }
            }
            catch
            {
            }

            try
            {
                if (allResults.Count > 0)
                {
                    var resultKeyLookup = new Dictionary<string, SearchResultItem>(StringComparer.OrdinalIgnoreCase);
                    var scoreItems = new List<SlskDownCore.SearchScoreItem>(allResults.Count);

                    foreach (var item in allResults)
                    {
                        var key = BuildSearchResultKey(item);
                        resultKeyLookup[key] = item;

                        var previousScore = canonicalPriorityScore.TryGetValue(key, out var cachedScore)
                            ? cachedScore
                            : 0d;

                        var author = item.Author ?? string.Empty;
                        var isCanonical = false;

                        if (author.Length > 0)
                        {
                            if (!canonicalMatchCache.TryGetValue(author, out isCanonical))
                            {
                                isCanonical = IsCanonicalAuthorName(author);
                                canonicalMatchCache[author] = isCanonical;
                            }
                        }

                        scoreItems.Add(new SlskDownCore.SearchScoreItem
                        {
                            Key = key,
                            Filename = item.Filename ?? string.Empty,
                            Extension = Path.GetExtension(item.Filename ?? string.Empty) ?? string.Empty,
                            Author = author,
                            Provider = item.Username ?? string.Empty,
                            Size = item.Size,
                            IsCanonical = isCanonical,
                            PreviousScore = previousScore
                        });
                    }

                    var ranked = SlskDownCore.ScoreSearchResults(usedQuery, scoreItems);
                    if (ranked != null && ranked.Count > 0)
                    {
                        var rankedItems = new List<SearchResultItem>(allResults.Count);

                        foreach (var scored in ranked.OrderByDescending(r => r.Score))
                        {
                            if (!resultKeyLookup.TryGetValue(scored.Key, out var match))
                            {
                                continue;
                            }

                            match.RelevanceScore = scored.Score;
                            canonicalPriorityScore[scored.Key] = scored.Score;
                            rankedItems.Add(match);
                            resultKeyLookup.Remove(scored.Key);
                        }

                        if (resultKeyLookup.Count > 0)
                        {
                            rankedItems.AddRange(resultKeyLookup.Values);
                        }

                        allResults = rankedItems;
                    }
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error aplicando ranking Rust: {ex.Message}");
            }

            var countSuffix = result.FromCache ? "resultados (caché)" : "resultados";
            DisplaySearchResults(allResults, $"{allResults.Count:N0} archivos encontrados", countSuffix);

            if (result.Stats != null)
            {
                LogSearchStats(result);
            }

            if (!searchStats.ContainsKey(request.Query))
            {
                searchStats[request.Query] = 0;
            }

            searchStats[request.Query]++;
            SaveStats();
        }

        private static string BuildSearchResultKey(SearchResultItem item)
        {
            var filename = item?.Filename ?? string.Empty;
            var provider = item?.Username ?? string.Empty;
            return string.Create(provider.Length + filename.Length + 1, (provider, filename), static (span, state) =>
            {
                var (prov, file) = state;
                prov.AsSpan().CopyTo(span);
                span[prov.Length] = '|';
                file.AsSpan().CopyTo(span[(prov.Length + 1)..]);
            });
        }

