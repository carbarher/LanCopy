        private async Task RetryDownload()
        {
            int retriedCount = 0;
            var tasksToRetry = new List<DownloadTask>();

            try
            {
                SafeInvoke(() =>
                {
                    if (lvDownloads == null)
                    {
                        return;
                    }

                    foreach (int selectedIndex in lvDownloads.SelectedIndices)
                    {
                        DownloadTask selectedTask = null;
                        if (lvDownloads.VirtualMode)
                        {
                            lock (downloadVirtualLock)
                            {
                                if (selectedIndex >= 0 && selectedIndex < downloadVirtualSnapshot.Count)
                                {
                                    selectedTask = downloadVirtualSnapshot[selectedIndex];
                                }
                            }
                        }
                        else
                        {
                            if (selectedIndex >= 0 && selectedIndex < lvDownloads.Items.Count)
                            {
                                selectedTask = lvDownloads.Items[selectedIndex].Tag as DownloadTask;
                            }
                        }

                        if (selectedTask != null && selectedTask.Status == DownloadStatus.Failed)
                        {
                            tasksToRetry.Add(selectedTask);
                        }
                    }
                });

                if (tasksToRetry.Count == 0)
                {
                    tasksToRetry = downloadQueueService.Update(list =>
                        list.Where(t => t.Status == DownloadStatus.Failed).ToList());
                }

                if (tasksToRetry.Count == 0)
                {
                    MessageBox.Show(
                        "No se encontraron descargas fallidas para reintentar",
                        "Reintentar",
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Information);
                    return;
                }

                Log($"🔄 Reintentando {tasksToRetry.Count} descarga(s)");

                var tasksToUpdate = new List<(DownloadTask task, string status)>();

                foreach (var task in tasksToRetry)
                {
                    if (task == null)
                    {
                        continue;
                    }

                    CancellationTokenSource previousCts = null;
                    lock (downloadQueueLock)
                    {
                        previousCts = task.CancellationToken;
                        task.CancellationToken = null;
                        task.Status = DownloadStatus.Queued;
                        task.ProgressPercent = 0;
                        task.BytesDownloaded = 0;
                        task.SpeedMBps = 0;
                        task.ErrorMessage = null;
                        task.IsScheduled = false;
                        task.ScheduledAt = null;
                        task.AssignedWorkerId = null;
                        task.StartTime = null;
                        task.EndTime = null;
                        task.StartedAt = null;
                        task.CompletedAt = null;
                    }

                    try
                    {
                        previousCts?.Cancel();
                    }
                    catch
                    {
                    }
                    finally
                    {
                        previousCts?.Dispose();
                    }

                    retriedCount++;
                    tasksToUpdate.Add((task, "⏳ En cola..."));
                }

                foreach (var update in tasksToUpdate)
                {
                    UpdateDownloadUI(update.task, update.status);
                }

                if (!downloadManagerRunning)
                {
                    _ = Task.Run(async () => await StartDownloadManager());
                }
                else
                {
                    EnsureDownloadWorkers();
                }

                await Task.Yield();
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error en RetryDownload: {ex.Message}");
            }
        }
        
