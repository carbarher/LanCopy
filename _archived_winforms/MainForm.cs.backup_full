        private async Task ConnectButton_Click()
        {
            try
            {
                if (client != null && client.State.HasFlag(SoulseekClientStates.Connected))
                {
                    // Desconectar
                    StopKeepAliveTimer();
                    client.Disconnect();
                    SafeInvoke(() =>
                    {
                        btnConnect.Text = "🔌 Conectar";
                        btnConnect.BackColor = Color.FromArgb(0, 120, 215);
                        UpdateNetworkStatusLabel();
                        btnSearch.Enabled = false;
                    });
                }
                else
                {
                    // Conectar
                    await ConnectAsync();
                }
            }
            catch (Exception ex)
            {
                SafeLog($"Error en ConnectButton_Click: {ex.Message}\n");
                
                // Activar reconexión automática si está habilitada
                if (autoReconnect && !isReconnecting)
                {
                    Log("🔄 Activando reconexión automática después de fallo...");
                    // MEJORA #26: Eliminar Task.Run redundante
                    _ = CheckAndReconnect();
                }
            }
        }
        
        private void SearchButton_Click(object sender, EventArgs e)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(cmbSearch.Text))
                {
                    DarkMessageBox.Show("Ingresa un término de búsqueda", "Búsqueda", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    return;
                }
                
                // Agregar al historial de búsquedas
                AddToSearchHistory(cmbSearch.Text.Trim());
                
                _ = SearchAsync();
            }
            catch (Exception ex)
            {
                SafeLog($"Error en SearchButton_Click: {ex.Message}\n");
            }
        }
        
        private void StopSearchButton_Click(object sender, EventArgs e)
        {
            try
            {
                StopSearch();
            }
            catch (Exception ex)
            {
                SafeLog($"Error en StopSearchButton_Click: {ex.Message}\n");
            }
        }
        
        private async void DownloadSelected()
        {
            try
            {
                if (lvResults.SelectedItems.Count == 0)
                {
                    Log("⚠️ No hay archivos seleccionados para descargar");
                    return;
                }
                
                foreach (ListViewItem selectedItem in lvResults.SelectedItems)
                {
                    var result = selectedItem.Tag as SearchResultItem;
                    if (result == null) continue;
                    
                    var fullFilename = Path.Combine(result.FolderPath, result.Filename);
                    var localPath = Path.Combine(downloadDir, result.Filename);
                    
                    System.IO.Directory.CreateDirectory(downloadDir);
                    
                    // Agregar a lista de descargas
                    var downloadItem = new ListViewItem(result.Filename);
                    downloadItem.SubItems.Add(result.Username);
                    downloadItem.SubItems.Add("0%");
                    downloadItem.SubItems.Add("Descargando...");
                    downloadItem.SubItems.Add(FormatSize(result.Size));
                    downloadItem.SubItems.Add(GetMetadataStatusSync(result.Filename));
                    AddItemWithAutoScroll(lvDownloads, downloadItem);
                    
                    Log($"📥 Descargando desde {result.Network}: {result.Filename} de {result.Username}");
                    
                    // Determinar el cliente correcto según la red de origen
                    SoulseekClient downloadClient = client; // Por defecto Soulseek
                    
                    if (!string.IsNullOrEmpty(result.Network) && result.Network != "Soulseek")
                    {
                        if (_networkOrchestrator != null)
                        {
                            var networkClient = _networkOrchestrator.GetClient(result.Network);
                            if (networkClient is SlskDown.Core.SoulseekClientAdapter adapter)
                            {
                                downloadClient = adapter.GetUnderlyingClient();
                            }
                            else if (networkClient != null)
                            {
                                Log($"⚠️ Descarga desde {result.Network} no soportada");
                                continue;
                            }
                        }
                    }
                    
                    // Iniciar descarga en background
                    _ = Task.Run(async () =>
                    {
                        try
                        {
                            await downloadClient.DownloadAsync(
                                result.Username, 
                                fullFilename, 
                                () => Task.FromResult<Stream>(new FileStream(localPath, FileMode.Create)), 
                                result.Size,
                                options: new TransferOptions(
                                    progressUpdated: (args) =>
                                    {
                                        var percent = (int)((args.Transfer.BytesTransferred / (double)result.Size) * 100);
                                        SafeInvoke(() =>
                                        {
                                            downloadItem.SubItems[2].Text = $"{percent}%";
                                            downloadItem.SubItems[3].Text = $"Descargando... {FormatSize(args.Transfer.BytesTransferred)} / {FormatSize(result.Size)}";
                                        });
                                    }
                                )
                            );
                            
                            SafeInvoke(() =>
                            {
                                downloadItem.SubItems[2].Text = "100%";
                                downloadItem.SubItems[3].Text = "✓ Completado";
                                downloadItem.ForeColor = Color.LimeGreen;
                            });
                            
                            Log($"✅ Descarga completada: {result.Filename}");
                        }
                        catch (Exception ex)
                        {
                            SafeInvoke(() =>
                            {
                                downloadItem.SubItems[3].Text = $"❌ Error: {ex.Message}";
                                downloadItem.ForeColor = Color.Red;
                            });
                            Log($"❌ Error descargando {result.Filename}: {ex.Message}");
                            var reconnected = await HandleDisconnectAsync("download error");
                            if (reconnected)
                            {
                                try
                                {
                                    await downloadClient.DownloadAsync(
                                        result.Username,
                                        fullFilename,
                                        () => Task.FromResult<Stream>(new FileStream(localPath, FileMode.Create)),
                                        result.Size,
                                        options: new TransferOptions(
                                            progressUpdated: (args) =>
                                            {
                                                var percent = (int)((args.Transfer.BytesTransferred / (double)result.Size) * 100);
                                                SafeInvoke(() =>
                                                {
                                                    downloadItem.SubItems[2].Text = $"{percent}%";
                                                    downloadItem.SubItems[3].Text = $"Descargando... {FormatSize(args.Transfer.BytesTransferred)} / {FormatSize(result.Size)}";
                                                });
                                            }
                                        )
                                    );
                                    SafeInvoke(() =>
                                    {
                                        downloadItem.SubItems[2].Text = "100%";
                                        downloadItem.SubItems[3].Text = "✓ Completado";
                                        downloadItem.ForeColor = Color.LimeGreen;
                                    });
                                    Log($"✅ Descarga completada tras reconexión: {result.Filename}");
                                }
                                catch (Exception ex2)
                                {
                                    SafeInvoke(() =>
                                    {
                                        downloadItem.SubItems[3].Text = $"❌ Error tras reconexión: {ex2.Message}";
                                        downloadItem.ForeColor = Color.Red;
                                    });
                                    Log($"❌ Error descargando tras reconexión {result.Filename}: {ex2.Message}");
                                }
                            }
                        }
                    });
                }
                
                // Cambiar a pestaña de descargas
                tabControl.SelectedIndex = 1;
            }
            catch (Exception ex)
            {
                SafeLog($"Error en DownloadSelected: {ex.Message}\n");
            }
        }
        
