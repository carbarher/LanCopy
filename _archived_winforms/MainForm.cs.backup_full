        // === PALETA DE COLORES MEJORADA ===
        private static class UIColors
        {
            // Colores de estado para autores
            public static readonly Color AuthorReady = Color.FromArgb(200, 200, 200);        // Gris claro - Listo
            public static readonly Color AuthorSearching = Color.FromArgb(100, 180, 255);   // Azul claro - Buscando
            public static readonly Color AuthorSuccess = Color.FromArgb(100, 255, 150);     // Verde brillante - Con archivos
            public static readonly Color AuthorNoResults = Color.FromArgb(255, 180, 100);   // Naranja - Sin resultados
            public static readonly Color AuthorError = Color.FromArgb(255, 100, 100);       // Rojo claro - Error
            public static readonly Color AuthorDownloading = Color.FromArgb(255, 220, 100); // Amarillo - Descargando
            public static readonly Color AuthorCompleted = Color.FromArgb(150, 255, 200);   // Verde agua - Completado
            
            // Colores de estado para descargas
            public static readonly Color DownloadActive = Color.FromArgb(100, 200, 255);    // Azul - Activa
            public static readonly Color DownloadPaused = Color.FromArgb(255, 200, 100);    // Naranja - Pausada
            public static readonly Color DownloadCompleted = Color.FromArgb(100, 255, 150); // Verde - Completada
            public static readonly Color DownloadFailed = Color.FromArgb(255, 120, 120);    // Rojo - Fallida
            public static readonly Color DownloadQueued = Color.FromArgb(200, 200, 200);    // Gris - En cola
            
            // Colores de archivos
            public static readonly Color FileSpanish = Color.FromArgb(150, 255, 150);       // Verde claro - Español
            public static readonly Color FileNonSpanish = Color.FromArgb(200, 200, 200);    // Gris - No español
            public static readonly Color FileDocument = Color.FromArgb(100, 180, 255);      // Azul - Documento
            public static readonly Color FileCorrupt = Color.FromArgb(255, 100, 100);       // Rojo - Corrupto
            
            // Colores de salud/estado
            public static readonly Color HealthGood = Color.FromArgb(100, 255, 150);        // Verde - Bueno (>70%)
            public static readonly Color HealthWarning = Color.FromArgb(255, 220, 100);     // Amarillo - Advertencia (50-70%)
            public static readonly Color HealthBad = Color.FromArgb(255, 120, 120);         // Rojo - Malo (<50%)
            
            // MEJORA #5: Método helper para obtener color según estado
            // MEJORA #14: Usar IndexOf para evitar allocaciones de ToLower()
            public static Color GetStatusColor(string status)
            {
                if (string.IsNullOrEmpty(status)) return AuthorReady;
                
                var cmp = StringComparison.OrdinalIgnoreCase;
                if (status.IndexOf("buscando", cmp) >= 0 || status.IndexOf("searching", cmp) >= 0) return AuthorSearching;
                if (status.IndexOf("descargando", cmp) >= 0 || status.IndexOf("downloading", cmp) >= 0) return AuthorDownloading;
                if (status.IndexOf("completado", cmp) >= 0 || status.IndexOf("completed", cmp) >= 0) return AuthorCompleted;
                if (status.IndexOf("sin resultado", cmp) >= 0 || status.IndexOf("no result", cmp) >= 0) return AuthorNoResults;
                if (status.IndexOf("error", cmp) >= 0 || status.IndexOf("fallo", cmp) >= 0 || status.IndexOf("fail", cmp) >= 0) return AuthorError;
                if (status.IndexOf("archivos", cmp) >= 0 && status.IndexOf("0 archivos", cmp) < 0) return AuthorSuccess;
                
                return AuthorReady;
            }
            
            // MEJORA #5 & #14: Método helper para obtener icono según estado (optimizado)
            public static string GetStatusIcon(string status)
            {
                if (string.IsNullOrEmpty(status)) return "⏸️";
                
                var cmp = StringComparison.OrdinalIgnoreCase;
                if (status.IndexOf("buscando", cmp) >= 0 || status.IndexOf("searching", cmp) >= 0) return "🔍";
                if (status.IndexOf("descargando", cmp) >= 0 || status.IndexOf("downloading", cmp) >= 0 || status.IndexOf("en cola", cmp) >= 0) return "⬇️";
                if (status.IndexOf("completado", cmp) >= 0 || status.IndexOf("completed", cmp) >= 0) return "✅";
                if (status.IndexOf("válido", cmp) >= 0) return "✅";
                if (status.IndexOf("sin resultado", cmp) >= 0 || status.IndexOf("no result", cmp) >= 0) return "⚠️";
                if (status.IndexOf("eliminado", cmp) >= 0) return "❌";
                if (status.IndexOf("error", cmp) >= 0 || status.IndexOf("fallo", cmp) >= 0 || status.IndexOf("fail", cmp) >= 0) return "❌";
                if (status.IndexOf("cancelado", cmp) >= 0) return "⏹️";
                if (status.IndexOf("pendiente", cmp) >= 0 || status.IndexOf("pending", cmp) >= 0) return "⏳";
                
                return "📄";
            }
        }

