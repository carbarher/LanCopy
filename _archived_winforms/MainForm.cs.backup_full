        private void CleanupDisconnectedPoolClients()
        {
            if (clientPool == null || clientPool.Count == 0)
                return;

            var removed = 0;
            for (var i = clientPool.Count - 1; i >= 0; i--)
            {
                var poolClient = clientPool[i];
                if (poolClient == null || poolClient.State == SoulseekClientStates.Disconnected)
                {
                    try { poolClient?.Dispose(); }
                    catch (Exception disposeEx) { AutoLog($"⚠️ Error eliminando cliente desconectado del pool: {disposeEx.Message}"); }

                    clientPool.RemoveAt(i);
                    removed++;
                }
            }

            if (removed > 0)
            {
                currentClientIndex = Math.Min(currentClientIndex, Math.Max(0, clientPool.Count - 1));
                AutoLog($"🧹 {removed} clientes desconectados eliminados del pool (restan {clientPool.Count})");
            }
        }

        private void PauseAutoTuningDuringIncident(TimeSpan waitDuration)
        {
            EnsureAutoTuningState(true);

            if (useAutoTuning)
            {
                var waitSeconds = waitDuration.TotalSeconds;
                if (waitSeconds >= 30)
                {
                    AutoLog($"🛑 Auto-Tuning pausado durante incidentes de conexión (espera {waitSeconds:F0}s)");
                }
                else
                {
                    AutoLog("🛑 Auto-Tuning pausado durante incidentes de conexión");
                }
            }
        }

        private void ScheduleReconnectRetry(TimeSpan waitDuration)
        {
            Interlocked.Increment(ref scheduledReconnectsCount);
            Log($"🗓️ Reintentando conexión en {waitDuration.TotalSeconds:F0}s (#{scheduledReconnectsCount})");
            _ = Task.Run(async () =>
            {
                try
                {
                    await PauseConnectionMonitorsAsync(waitDuration).ConfigureAwait(false);
                }
                finally
                {
                    lock (this)
                    {
                        isReconnectCoolingDown = false;
                        lastReconnectWarningLog = DateTime.MinValue;
                    }
                }

                try
                {
                    await CheckAndReconnect().ConfigureAwait(false);
                }
                catch (Exception retryEx)
                {
                    Log($"⚠️ Error programando reconexión: {retryEx.Message}");
                }
            });
        }
        
