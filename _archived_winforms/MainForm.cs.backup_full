        private Label lblAutoSummaryStatus;
        private Button btnStartAuto;
        private Button btnStopAuto;
        private string lastAuthorsFilePath = ""; // Ruta del archivo de autores para pestaña Auto
        private string lastVaciarAuthorsFilePath = ""; // Ruta del archivo de autores para pestaña Vaciar
        private Action<string> secondaryLogger = null; // Logger secundario para ventana de descargas
        private Action realtimeGridUpdater = null; // Callback para actualizar grilla en tiempo real
        private Action<int> realtimeStatsUpdater = null; // Callback para actualizar solo estadísticas
        private ListView lvVaciarAuthors;
        private Action vaciarGridRefresher = null;
        
        // Sistema de carga incremental (100 autores por lote) - SIN CARGAR TODO EN MEMORIA
        private int currentLineIndex = 0; // Línea actual del archivo
        private int totalLinesInFile = 0; // Total de líneas en el archivo
        private const int INCREMENTAL_BATCH_SIZE = 100; // Tamaño de cada lote
        private string incrementalSourceFile = ""; // Archivo fuente original
        private string incrementalTempFile = ""; // Archivo temporal con autores no purgados
        
        // Enum para el modo de gestión
        private enum AuthorManagementMode
        {
            Purge,
            Download
        }
        
        private AuthorManagementMode currentManagementMode = AuthorManagementMode.Purge;
        
        /// <summary>
        /// Pestaña unificada que fusiona "Automático" y "Vaciar"
        /// </summary>
        private void CreateAuthorManagementTab(TabPage parent)
        {
            parent.BackColor = Color.FromArgb(18, 18, 18);

            // Layout principal: 1 columna, 3 filas (header, content, footer)
            var mainLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 1,
                RowCount = 3,
                BackColor = Color.FromArgb(18, 18, 18),
                Padding = new Padding(6),
                Margin = new Padding(0),
                CellBorderStyle = TableLayoutPanelCellBorderStyle.None
            };
            mainLayout.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 100f));
            mainLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize)); // Header: se adapta al contenido
            mainLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100f)); // Content
            mainLayout.RowStyles.Add(new RowStyle(SizeType.Absolute, 60)); // Footer: altura extra para que el texto no quede cortado

            // === HEADER: TÍTULO + MODO + STATS ===
            var headerPanel = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                RowCount = 2,
                ColumnCount = 1,
                BackColor = Color.FromArgb(25, 25, 28),
                Padding = new Padding(10, 8, 10, 8),
                Margin = new Padding(0),
                AutoSize = true,
                AutoSizeMode = AutoSizeMode.GrowAndShrink,
                CellBorderStyle = TableLayoutPanelCellBorderStyle.None
            };
            headerPanel.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 100f));
            headerPanel.RowStyles.Add(new RowStyle(SizeType.AutoSize)); // Fila superior: autosize
            headerPanel.RowStyles.Add(new RowStyle(SizeType.AutoSize)); // Fila inferior: autosize

            // Panel para título y modos (fila superior)
            var titleModePanel = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = false,
                BackColor = Color.Transparent,
                Padding = new Padding(0, 2, 0, 0),
                Margin = new Padding(0),
                AutoSize = true,
                AutoSizeMode = AutoSizeMode.GrowAndShrink
            };

            var lblTitle = new Label
            {
                Text = "🤖 AUTOMÁTICO",
                AutoSize = true,
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 11, FontStyle.Bold),
                Margin = new Padding(0, 4, 16, 0)
            };
            titleModePanel.Controls.Add(lblTitle);
            // Declarar la función de configuración de botones
            Action updateButtonsForMode = null;

            // Controles de filtro globales en Automático
            chkAutoSpanishDocuments = new CheckBox
            {
                Text = "🇪🇸 Solo español",
                AutoSize = true,
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9, FontStyle.Bold),
                Checked = true,
                Margin = new Padding(12, 4, 0, 0),
                FlatStyle = FlatStyle.Flat,
                UseVisualStyleBackColor = false
            };
            chkAutoSpanishDocuments.CheckedChanged += (s, e) =>
            {
                if (chkAutoSpanishDocuments.Checked)
                    AutoLog("🇪🇸 Filtro de idioma ACTIVADO - Solo documentos en español");
                else
                    AutoLog("🌍 Filtro de idioma DESACTIVADO - Todos los idiomas");
                SaveUiPreferences();
            };
            
            chkPreciseMode = new CheckBox
            {
                Text = "🎯 Modo Preciso",
                AutoSize = true,
                ForeColor = Color.FromArgb(180, 180, 185),
                Font = new Font("Segoe UI", 9),
                Checked = false,
                Margin = new Padding(12, 4, 0, 0),
                FlatStyle = FlatStyle.Flat,
                UseVisualStyleBackColor = false
            };
            chkPreciseMode.CheckedChanged += (s, e) =>
            {
                preciseLanguageMode = chkPreciseMode.Checked;
                if (preciseLanguageMode)
                    AutoLog("🎯 Modo PRECISO activado - Verificará contenido de archivos neutrales (más lento pero más preciso)");
                else
                    AutoLog("🚀 Modo RÁPIDO activado - Solo verificará títulos (más rápido, puede aceptar algunos no-españoles)");
                SaveUiPreferences();
            };
            
            var chkTurboMode = new CheckBox
            {
                Text = "⚡ Modo Turbo (5x más rápido)",
                AutoSize = true,
                ForeColor = Color.FromArgb(255, 200, 0),
                Font = new Font("Segoe UI", 9, FontStyle.Bold),
                Checked = false,
                Margin = new Padding(12, 4, 0, 0),
                FlatStyle = FlatStyle.Flat,
                UseVisualStyleBackColor = false
            };
            var turboToolTip = new ToolTip();
            turboToolTip.SetToolTip(chkTurboMode, "Procesa 2 autores simultáneamente con caché.\n2x más rápido, optimizado para evitar desconexiones.");
            chkTurboMode.CheckedChanged += (s, e) =>
            {
                purgeBatchSize = chkTurboMode.Checked ? 2 : 1;
                if (chkTurboMode.Checked)
                    AutoLog("⚡ MODO TURBO activado - Procesamiento paralelo 2x (2 autores simultáneos)");
                else
                    AutoLog("🐢 Modo normal activado - Procesamiento secuencial (1 autor a la vez)");
                SaveUiPreferences();
            };

            var lblMinKB = new Label
            {
                Text = "Min KB:",
                AutoSize = true,
                ForeColor = Color.FromArgb(180, 180, 185),
                Font = new Font("Segoe UI", 10),
                Margin = new Padding(12, 6, 4, 0)
            };
            var numMinKB = new NumericUpDown
            {
                Minimum = 0,
                Maximum = 102400,
                Value = 200,
                Increment = 50,
                Width = 90,
                BackColor = Color.FromArgb(50, 50, 55),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                BorderStyle = BorderStyle.FixedSingle,
                Margin = new Padding(0, 6, 8, 0)
            };
            numMinKB.Value = autoMinSearchSizeKB;
            numMinKB.ValueChanged += (s, e) =>
            {
                autoMinSearchSizeKB = (int)numMinKB.Value;
                AutoLog($"📏 Tamaño mínimo para 'Buscar': {autoMinSearchSizeKB} KB");
                SaveUiPreferences();
            };

            // Panel para stats (fila inferior)
            var statsPanel = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = false,
                BackColor = Color.Transparent,
                Padding = new Padding(0),
                Margin = new Padding(0),
                AutoSize = true,
                AutoSizeMode = AutoSizeMode.GrowAndShrink
            };

            // Stats en el header
            lblAutoSummaryCounts = new Label
            {
                AutoSize = true,
                ForeColor = Color.FromArgb(180, 180, 180),
                Font = new Font("Segoe UI", 8.5f, FontStyle.Bold),
                Text = "Autores: 0 | Seleccionados: 0",
                Margin = new Padding(0, 4, 12, 0)
            };
            statsPanel.Controls.Add(lblAutoSummaryCounts);

            lblAutoSummaryStatus = new Label
            {
                AutoSize = true,
                ForeColor = Color.FromArgb(150, 150, 150),
                Font = new Font("Segoe UI", 8.5f),
                Text = "Estado: En espera",
                Margin = new Padding(0, 4, 0, 0)
            };
            statsPanel.Controls.Add(lblAutoSummaryStatus);

            // Agregar paneles al header
            headerPanel.Controls.Add(titleModePanel, 0, 0);
            headerPanel.Controls.Add(statsPanel, 0, 1);

            mainLayout.Controls.Add(headerPanel, 0, 0);

            // === CONTENIDO: LAYOUT 2 COLUMNAS (izquierda: autores, derecha: log) ===
            var contentLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 3,
                RowCount = 1,
                BackColor = Color.FromArgb(18, 18, 18),
                Margin = new Padding(0),
                Padding = new Padding(0),
                CellBorderStyle = TableLayoutPanelCellBorderStyle.None
            };
            contentLayout.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 55f));
            contentLayout.ColumnStyles.Add(new ColumnStyle(SizeType.Absolute, 6f));
            contentLayout.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 45f));
            contentLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100f));

            // === PANEL IZQUIERDO: LISTADO DE AUTORES ===
            var leftPanel = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                BackColor = Color.FromArgb(18, 18, 18),
                RowCount = 2,
                ColumnCount = 1,
                Padding = new Padding(0),
                Margin = new Padding(0)
            };
            leftPanel.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 100f));
            leftPanel.RowStyles.Add(new RowStyle(SizeType.AutoSize)); // Botones: se adapta al contenido
            leftPanel.RowStyles.Add(new RowStyle(SizeType.Percent, 100f));  // ListView - MAXIMIZADO

            // Eliminado: barra de búsqueda de autores en Automático

            // ListView compartido (fusiona lvAutoAuthors y lvVaciarAuthors)
            lvAutoAuthors = new ListView
            {
                Dock = DockStyle.Fill,
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.White,
                View = View.Details,
                FullRowSelect = true,
                GridLines = true,
                CheckBoxes = true,
                Font = new Font("Segoe UI", 9),
                HeaderStyle = ColumnHeaderStyle.Clickable,
                Margin = new Padding(0),
                OwnerDraw = true,  // Necesario para tema oscuro
                ShowItemToolTips = true
            };
            
            // Eventos de dibujado personalizado para tema oscuro
            lvAutoAuthors.DrawColumnHeader += ListView_DrawColumnHeader;
            lvAutoAuthors.DrawItem += LvAutoAuthors_DrawItem;
            lvAutoAuthors.DrawSubItem += LvAutoAuthors_DrawSubItem;

            lvAutoAuthors.Columns.Add("Autor", -2);
            lvAutoAuthors.Columns.Add("Archivos", -2);
            lvAutoAuthors.Columns.Add("Estado", -2);
            lvAutoAuthors.Columns.Add("Última búsqueda", -2);
            lvAutoAuthors.Columns.Add("Procesado", -2);
            lvAutoAuthors.SizeChanged += (s, e) => {
                if (lvAutoAuthors.Columns.Count >= 4) {
                    int w = lvAutoAuthors.ClientSize.Width - 25; // Restar espacio para checkbox
                    lvAutoAuthors.Columns[0].Width = (int)(w * 0.28);
                    lvAutoAuthors.Columns[1].Width = (int)(w * 0.12);
                    lvAutoAuthors.Columns[2].Width = (int)(w * 0.28);
                    lvAutoAuthors.Columns[3].Width = (int)(w * 0.18);
                    if (lvAutoAuthors.Columns.Count > 4)
                        lvAutoAuthors.Columns[4].Width = (int)(w * 0.14);
                }
            };

            // Configurar persistencia de ancho de columnas ANTES de agregar al panel
            SetupColumnWidthPersistence(lvAutoAuthors, "lvAutoAuthors");

            // Double buffering
            typeof(Control).GetProperty("DoubleBuffered",
                System.Reflection.BindingFlags.NonPublic | System.Reflection.BindingFlags.Instance)
                ?.SetValue(lvAutoAuthors, true, null);

            lvAutoAuthors.ColumnClick += LvAutoAuthors_ColumnClick;

            // Sincronizar checkbox
            lvAutoAuthors.ItemCheck += (s, e) =>
            {
                if (isRefreshingAuthors) return;

                if (e.Index >= 0 && e.Index < filteredAuthorsData.Count)
                {
                    var author = filteredAuthorsData[e.Index];
                    author.IsChecked = (e.NewValue == CheckState.Checked);
                }
            };

            // Menú contextual (solo ver archivos)
            var authorsContextMenu = new ContextMenuStrip
            {
                BackColor = Color.FromArgb(40, 40, 40),
                ForeColor = Color.White
            };

            var menuViewFiles = new ToolStripMenuItem("📄 Ver archivos del autor");
            menuViewFiles.Click += (s, e) => 
            {
                AutoLog("🖱️ Menú contextual: Ver archivos del autor clickeado");
                ViewAuthorUniqueFiles();
            };
            authorsContextMenu.Items.Add(menuViewFiles);
            authorsContextMenu.ShowItemToolTips = true;
            menuViewFiles.ToolTipText = "Ver todos los archivos encontrados de este autor";
            lvAutoAuthors.ContextMenuStrip = authorsContextMenu;
            leftPanel.Controls.Add(lvAutoAuthors, 0, 1);

            // === PANEL DE BOTONES DINÁMICO ===
            var buttonPanel = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                AutoSize = true,
                AutoSizeMode = AutoSizeMode.GrowAndShrink,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = true,
                BackColor = Color.FromArgb(25, 25, 28),
                Padding = new Padding(10, 10, 10, 10),
                Margin = new Padding(0, 2, 0, 0),
                AutoScroll = false
            };

            // Crear todos los botones (se agregarán dinámicamente según el modo)
            
            // Botones de Modo Descarga
            var btnRefresh = CreateButton("🔄 Actualizar", Color.FromArgb(60, 60, 60));
            btnRefresh.Click += (s, e) => 
            {
                // Forzar actualización ignorando throttling
                lastAuthorsRefresh = DateTime.MinValue;
                RefreshAuthorsListView();
            };

            var btnDownload = CreateButton("⬇️ Descargar", Color.FromArgb(60, 60, 60));
            btnDownload.Click += async (s, e) => await DownloadSelectedAuthorsAsync();

            var btnVerify = CreateButton("✅ Verificar", Color.FromArgb(60, 60, 60));
            btnVerify.Click += (s, e) => VerifyDownloadedFiles();

            var btnOpenFolder = CreateButton("📂 Descargados", Color.FromArgb(60, 60, 60));
            btnOpenFolder.Click += (s, e) => OpenDownloadFolder();

            // Botones de Modo Purga
            var btnLoadList = CreateButton("📂 Cargar Lista", Color.FromArgb(60, 60, 60));
            btnLoadList.Click += async (s, e) => await LoadAuthorsListAsync();

            var btnStartPurge = CreateButton("🔎 Buscar", Color.FromArgb(60, 60, 60));
            btnStartPurge.Click += async (s, e) => await StartPurgeProcessAsync();

            var btnSaveAuthors = CreateButton("💾 Guardar Autores", Color.FromArgb(60, 60, 60));
            btnSaveAuthors.Click += (s, e) => SaveAuthorsWithFiles();

            var btnPurgeQuick = CreateButton("🔍 Purgar", Color.FromArgb(180, 100, 0));
            btnPurgeQuick.Click += async (s, e) => await PurgeAuthorsWithoutFiles();

            // Control del proceso: Pausar/Reanudar/Cancelar purga
            var btnPausePurge = CreateButton("⏸️ Pausar", Color.FromArgb(60, 60, 60));
            btnPausePurge.Click += (s, e) => { autoPurgeUserPaused = true; if (lblPurgeProgress != null) lblPurgeProgress.Text = "⏸️ Purga en pausa"; };
            var btnResumePurge = CreateButton("▶️ Reanudar", Color.FromArgb(60, 60, 60));
            btnResumePurge.Click += (s, e) => { autoPurgeUserPaused = false; if (lblPurgeProgress != null) lblPurgeProgress.Text = "▶️ Reanudando..."; };
            var btnCancelPurge = CreateButton("⏹️ Cancelar", Color.FromArgb(60, 60, 60));
            btnCancelPurge.Click += (s, e) => { try { autoSearchCts?.Cancel(); } catch { } };

            // Selección masiva (heredado de "Vaciado")
            var btnSelectAll = CreateButton("☑️ Sel.Todo", Color.FromArgb(60, 60, 60));
            btnSelectAll.Click += (s, e) =>
            {
                foreach (var author in filteredAuthorsData) author.IsChecked = true;
                RefreshAuthorsListView();
                UpdateAuthorCount();
            };

            var btnDeselectAll = CreateButton("☐ Desel.Todo", Color.FromArgb(60, 60, 60));
            btnDeselectAll.Click += (s, e) =>
            {
                foreach (var author in filteredAuthorsData) author.IsChecked = false;
                RefreshAuthorsListView();
                UpdateAuthorCount();
            };

            // Selección inteligente
            var btnSelectPending = CreateButton("⏳ Sel.No buscados", Color.FromArgb(60, 60, 60));
            btnSelectPending.Click += (s, e) =>
            {
                foreach (var a in filteredAuthorsData) a.IsChecked = string.IsNullOrEmpty(a.Status);
                RefreshAuthorsListView();
                UpdateAuthorCount();
            };
            var btnSelectWithResults = CreateButton("✅ Sel.Con resultados", Color.FromArgb(60, 60, 60));
            btnSelectWithResults.Click += (s, e) =>
            {
                foreach (var a in filteredAuthorsData) a.IsChecked = (a.FilesCount > 0);
                RefreshAuthorsListView();
                UpdateAuthorCount();
            };
            
            var btnSelectProcessed = CreateButton("✅ Sel.Procesados", Color.FromArgb(60, 60, 60));
            btnSelectProcessed.Click += (s, e) =>
            {
                foreach (var a in filteredAuthorsData) a.IsChecked = a.IsProcessed;
                RefreshAuthorsListView();
                UpdateAuthorCount();
            };
            
            var btnSelectNotProcessed = CreateButton("⏳ Sel.No procesados", Color.FromArgb(60, 60, 60));
            btnSelectNotProcessed.Click += (s, e) =>
            {
                foreach (var a in filteredAuthorsData) a.IsChecked = !a.IsProcessed;
                RefreshAuthorsListView();
                UpdateAuthorCount();
            };

            // Controles de filtro (heredados de "Vaciado")
            var lblFilterAuthors = new Label
            {
                Text = "🔎",
                AutoSize = true,
                ForeColor = Color.White,
                Margin = new Padding(12, 6, 4, 0)
            };
            var txtFilterAuthors = new TextBox
            {
                Width = 160,
                BackColor = Color.FromArgb(50, 50, 50),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                BorderStyle = BorderStyle.FixedSingle
            };
            txtFilterAuthors.TextChanged += (s, e) => FilterAuthors(txtFilterAuthors.Text);

            var chkPendingOnlyAuto = new CheckBox
            {
                Text = "⏳ Aún no buscados",
                AutoSize = true,
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                Margin = new Padding(12, 4, 0, 0)
            };
            chkPendingOnlyAuto.CheckedChanged += (s, e) => { pendingOnlyFilter = chkPendingOnlyAuto.Checked; SaveUiPreferences(); FilterAuthors(txtFilterAuthors.Text); };

            // Excluir ya descargados (visible, afecta búsqueda manual)
            chkExcludeDownloaded = new CheckBox
            {
                Text = "Excluir ya descargados",
                AutoSize = true,
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                Margin = new Padding(12, 4, 0, 0)
            };
            chkExcludeDownloaded.CheckedChanged += (s, e) => { SaveUiPreferences(); };

            // Controles de descarga (stubs por ahora)
            var btnRetry = CreateButton("🔄 Reintentar", Color.FromArgb(60, 60, 60));
            btnRetry.Click += (s, e) => RetryNotDownloaded();
            var btnStopDownload = CreateButton("⏸️ Detener", Color.FromArgb(60, 60, 60));
            btnStopDownload.Click += (s, e) => { PauseAllDownloads(); AutoLog("⏸️ Todas las descargas pausadas"); };
            
            var btnShowFilterStats = CreateButton("📊 Estadísticas", Color.FromArgb(60, 60, 60));
            btnShowFilterStats.Click += (s, e) => ShowLanguageStatsWindow();

            // Implementar la función ahora que todas las variables están declaradas
            updateButtonsForMode = () =>
            {
                // Limpiar todos los botones
                buttonPanel.Controls.Clear();
                // Mostrar todas las opciones, independientemente del modo

                // Grupo Purga (Automático)
                buttonPanel.Controls.Add(btnLoadList);
                buttonPanel.Controls.Add(btnRefresh); // Compartido
                buttonPanel.Controls.Add(btnStartPurge);
                buttonPanel.Controls.Add(btnPurgeQuick);
                buttonPanel.Controls.Add(btnSaveAuthors);

                // Grupo Descarga (Manual) - sin duplicar 'Actualizar'
                buttonPanel.Controls.Add(btnDownload);
                buttonPanel.Controls.Add(btnVerify);
                buttonPanel.Controls.Add(btnOpenFolder);
                buttonPanel.Controls.Add(btnRetry);
                buttonPanel.Controls.Add(btnStopDownload);
                
                // Botones de selección
                buttonPanel.Controls.Add(btnSelectAll);
                buttonPanel.Controls.Add(btnDeselectAll);
                buttonPanel.Controls.Add(btnSelectPending);
                buttonPanel.Controls.Add(btnSelectWithResults);
                buttonPanel.Controls.Add(btnSelectProcessed);
                buttonPanel.Controls.Add(btnSelectNotProcessed);

                // Filtros al final de la barra
                buttonPanel.Controls.Add(lblFilterAuthors);
                buttonPanel.Controls.Add(txtFilterAuthors);
                buttonPanel.Controls.Add(chkPendingOnlyAuto);
                buttonPanel.Controls.Add(chkAutoSpanishDocuments);
                buttonPanel.Controls.Add(chkPreciseMode);
                buttonPanel.Controls.Add(chkTurboMode);
                buttonPanel.Controls.Add(lblMinKB);
                buttonPanel.Controls.Add(numMinKB);
                buttonPanel.Controls.Add(btnShowFilterStats);

                // Forzar actualización del panel
                buttonPanel.Invalidate();
                buttonPanel.Update();
            };

            // Agregar el panel de botones al contenedor PRIMERO
            leftPanel.Controls.Add(buttonPanel, 0, 0);

            // Luego inicializar botones para modo actual
            currentManagementMode = AuthorManagementMode.Purge; // Asegurar modo inicial
            updateButtonsForMode();
            contentLayout.Controls.Add(leftPanel, 0, 0);
            // Separador visual entre columnas
            var contentSeparator = new Panel
            {
                Dock = DockStyle.Fill,
                BackColor = Color.FromArgb(35, 35, 38)
            };
            contentLayout.Controls.Add(contentSeparator, 1, 0);

            // === PANEL DERECHO: LOG (con TableLayoutPanel para evitar solapamientos) ===
            var rightPanel = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                BackColor = Color.FromArgb(18, 18, 18),
                RowCount = 2,
                ColumnCount = 1,
                Padding = new Padding(0),
                Margin = new Padding(0),
                CellBorderStyle = TableLayoutPanelCellBorderStyle.None
            };
            rightPanel.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 100f));
            rightPanel.RowStyles.Add(new RowStyle(SizeType.AutoSize));  // Header del log
            rightPanel.RowStyles.Add(new RowStyle(SizeType.Percent, 100f));  // TextBox - MAXIMIZADO

            var logHeader = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                AutoSize = true,
                AutoSizeMode = AutoSizeMode.GrowAndShrink,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = false,
                BackColor = Color.FromArgb(25, 25, 28),
                Padding = new Padding(0, 6, 0, 6),
                Margin = new Padding(0)
            };

            var lblLog = new Label
            {
                Text = "📋 LOG",
                AutoSize = true,
                ForeColor = Color.FromArgb(180, 180, 180),
                Font = new Font("Segoe UI", 10, FontStyle.Bold),
                Margin = new Padding(0, 2, 8, 0)
            };
            logHeader.Controls.Add(lblLog);

            var btnClearLog = new Button
            {
                Text = "🗑️ Limpiar",
                AutoSize = true,
                BackColor = Color.FromArgb(60, 60, 60),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 9),
                Padding = new Padding(8, 4, 8, 4),
                Margin = new Padding(6, 0, 0, 0),
                Cursor = Cursors.Hand
            };
            btnClearLog.FlatAppearance.BorderSize = 0;
            btnClearLog.Click += (s, e) => txtAutoLog.Clear();
            logHeader.Controls.Add(btnClearLog);

            var btnCopyLog = new Button
            {
                Text = "📋 Copiar",
                AutoSize = true,
                BackColor = Color.FromArgb(60, 60, 60),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 9),
                Padding = new Padding(8, 4, 8, 4),
                Margin = new Padding(6, 0, 0, 0),
                Cursor = Cursors.Hand
            };
            btnCopyLog.FlatAppearance.BorderSize = 0;
            btnCopyLog.Click += (s, e) => { try { Clipboard.SetText(txtAutoLog.Text ?? ""); } catch { } };
            logHeader.Controls.Add(btnCopyLog);

            rightPanel.Controls.Add(logHeader, 0, 0);

            txtAutoLog = new TextBox
            {
                Dock = DockStyle.Fill,
                Multiline = true,
                ReadOnly = true,
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.LightGray,
                Font = new Font("Consolas", 9),
                ScrollBars = ScrollBars.Both,
                BorderStyle = BorderStyle.None,
                WordWrap = false,
                Margin = new Padding(0)
            };
            rightPanel.Controls.Add(txtAutoLog, 0, 1);
            // Agregar panel derecho y contenido principal
