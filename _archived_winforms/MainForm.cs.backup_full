            {
                Dock = DockStyle.Fill,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = false,
                BackColor = Color.FromArgb(30, 30, 30),
                Padding = new Padding(8, 4, 8, 4),
                Margin = new Padding(0)
            };

            var chkDocs = new CheckBox
            {
                Text = "📄 Solo documentos",
                AutoSize = true,
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 8),
                Checked = true,
                Margin = new Padding(0, 2, 15, 0)
            };
            row3Panel.Controls.Add(chkDocs);

            var chkPendingOnly = new CheckBox
            {
                Text = "⏳ Solo pendientes",
                AutoSize = true,
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 8),
                Checked = false,
                Margin = new Padding(0, 2, 15, 0)
            };
            row3Panel.Controls.Add(chkPendingOnly);

            // Búsqueda y filtro de tamaño
            var lblSearchVaciar = new Label
            {
                Text = "🔍",
                AutoSize = true,
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                Margin = new Padding(0, 2, 3, 0)
            };
            row3Panel.Controls.Add(lblSearchVaciar);
            
            var txtSearchVaciar = new TextBox
            {
                Width = 140,
                Height = 20,
                BackColor = Color.FromArgb(50, 50, 50),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 8),
                BorderStyle = BorderStyle.FixedSingle,
                Margin = new Padding(0, 0, 10, 0)
            };
            row3Panel.Controls.Add(txtSearchVaciar);
            
            var lblMinSize = new Label
            {
                Text = "📏",
                AutoSize = true,
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 8),
                Margin = new Padding(0, 2, 2, 0)
            };
            row3Panel.Controls.Add(lblMinSize);

            var numMinSizeKB = new NumericUpDown
            {
                Width = 75,
                Height = 20,
                Minimum = 0,
                Maximum = 1000000,
                Value = 0,
                Increment = 100,
                BackColor = Color.FromArgb(50, 50, 50),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 8),
                Margin = new Padding(0)
            };
            row3Panel.Controls.Add(numMinSizeKB);

            topLeftPanel.Controls.Add(row3Panel, 0, 2);

            mainLayout.Controls.Add(topLeftPanel, 0, 0);

            // Panel superior derecho - log de descargas
            var rightLogLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 1,
                RowCount = 2,
                BackColor = Color.FromArgb(30, 30, 30),
                Padding = new Padding(6)
            };
            rightLogLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize));
            rightLogLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100f));

            var lblLogTitle = new Label
            {
                Text = "📋 Log de Descargas",
                AutoSize = true,
                Font = new Font("Segoe UI", 10, FontStyle.Bold),
                ForeColor = Color.White,
                Margin = new Padding(0, 0, 0, 8)
            };
            rightLogLayout.Controls.Add(lblLogTitle, 0, 0);

            var logContainer = new Panel
            {
                Dock = DockStyle.Fill,
                BackColor = Color.FromArgb(20, 20, 20),
                Padding = new Padding(2)
            };
            rightLogLayout.Controls.Add(logContainer, 0, 1);

            mainLayout.Controls.Add(rightLogLayout, 1, 0);
            mainLayout.SetRowSpan(rightLogLayout, 2);  // Ocupa filas 0 y 1 (botones + grilla)

            SafeLog( "CreateVaciarTab: Creando gridContainer\n");
            // Container para grilla
            var gridContainer = new Panel
            {
                Dock = DockStyle.Fill,
                BackColor = Color.FromArgb(18, 18, 18)
            };
            SafeLog( "CreateVaciarTab: gridContainer creado\n");

            SafeLog( "CreateVaciarTab: Creando ListView\n");
            // ListView para mostrar autores (igual que en Automático)
            lvVaciarAuthors = new ListView
            {
                Dock = DockStyle.Fill,
                View = View.Details,
                FullRowSelect = true,
                GridLines = true,
                CheckBoxes = true,
                VirtualMode = false,  // Explícitamente desactivar VirtualMode
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                HeaderStyle = ColumnHeaderStyle.Clickable
            };
            SafeLog( "CreateVaciarTab: ListView creado\n");

            SafeLog( "CreateVaciarTab: Agregando columnas\n");
            lvVaciarAuthors.Columns.Add("Autor", 200);
            lvVaciarAuthors.Columns.Add("Archivos", 90);
            lvVaciarAuthors.Columns.Add("Estado", 160);
            SafeLog( "CreateVaciarTab: Columnas agregadas\n");

            // Variables para ordenamiento
            int sortColumnIndex = -1;
            bool sortAscending = true;

            // Helper para actualizar encabezados con indicadores visuales
            Action<ListView, int, bool> UpdateColumnHeaders = (lv, sortCol, ascending) =>
            {
                string[] columnNames = { "Autor", "Archivos", "Estado" };
                for (int i = 0; i < lv.Columns.Count; i++)
                {
                    string header = columnNames[i];
                    if (i == sortCol)
                    {
                        header += ascending ? " ▲" : " ▼";
                    }
                    lv.Columns[i].Text = header;
                }
            };

            SafeLog( "CreateVaciarTab: Registrando ColumnClick\n");
            // Event handler para ordenar al hacer clic en columnas
            lvVaciarAuthors.ColumnClick += (s, e) =>
            {
                if (e.Column == sortColumnIndex)
                {
                    sortAscending = !sortAscending;
                }
                else
                {
                    sortColumnIndex = e.Column;
                    sortAscending = true;
                }

                // Ordenar items
                var items = lvVaciarAuthors.Items.Cast<ListViewItem>().ToList();
                items.Sort((a, b) =>
                {
                    int result = 0;
                    switch (sortColumnIndex)
                    {
                        case 0: // Autor
                            result = string.Compare(a.Text, b.Text, StringComparison.OrdinalIgnoreCase);
                            break;
                        case 1: // Archivos (número)
                            result = int.Parse(a.SubItems[1].Text).CompareTo(int.Parse(b.SubItems[1].Text));
                            break;
                        case 2: // Estado
                            result = string.Compare(a.SubItems[2].Text, b.SubItems[2].Text, StringComparison.OrdinalIgnoreCase);
                            break;
                    }
                    return sortAscending ? result : -result;
                });

                lvVaciarAuthors.BeginUpdate();
                lvVaciarAuthors.Items.Clear();
                lvVaciarAuthors.Items.AddRange(items.ToArray());
                lvVaciarAuthors.EndUpdate();

                UpdateColumnHeaders(lvVaciarAuthors, sortColumnIndex, sortAscending);
            };
            SafeLog( "CreateVaciarTab: ColumnClick registrado\n");

            // Click izquierdo alterna selección directamente
            lvVaciarAuthors.MouseClick += (s, e) =>
            {
                if (e.Button == MouseButtons.Left)
                {
                    var hitTest = lvVaciarAuthors.HitTest(e.Location);
                    if (hitTest.Item != null)
                    {
                        hitTest.Item.Checked = !hitTest.Item.Checked;
                        Log($"🔄 [Vaciar] Autor '{hitTest.Item.Text}' {(hitTest.Item.Checked ? "seleccionado" : "deseleccionado")}");
                    }
                }
            };

            SafeLog( "CreateVaciarTab: Agregando controles al layout\n");
            gridContainer.Controls.Add(lvVaciarAuthors);
            mainLayout.Controls.Add(gridContainer, 0, 1);
            SafeLog( "CreateVaciarTab: Controles agregados\n");

            SafeLog( "CreateVaciarTab: Creando txtDownloadLog\n");
            // TextBox de log en el lado derecho
            var txtDownloadLog = new TextBox
            {
                Dock = DockStyle.Fill,
                Multiline = true,
                ReadOnly = true,
                BackColor = Color.FromArgb(20, 20, 20),
                ForeColor = Color.LightGray,
                Font = new Font("Consolas", 8),
                ScrollBars = ScrollBars.Both,
                WordWrap = false
            };
            logContainer.Controls.Add(txtDownloadLog);
            SafeLog( "CreateVaciarTab: txtDownloadLog agregado\n");

            // Helper para agregar mensajes al log
            SafeLog( "CreateVaciarTab: Definiendo LogDownload\n");
            const int MAX_LOG_LINES = 500;
            Action<string> LogDownload = (msg) =>
            {
                Action appendLog = () =>
                {
                    txtDownloadLog.AppendText($"[{DateTime.Now:HH:mm:ss}] {msg}{Environment.NewLine}");
                    
                    var lines = txtDownloadLog.Lines;
                    if (lines.Length > MAX_LOG_LINES)
                    {
                        var newLines = lines.Skip(lines.Length - MAX_LOG_LINES).ToArray();
                        txtDownloadLog.Lines = newLines;
                        txtDownloadLog.SelectionStart = txtDownloadLog.Text.Length;
                        txtDownloadLog.ScrollToCaret();
                    }
                };
                
                try
                {
                    // MEJORA #40: Usar BeginInvoke en lugar de Invoke para no bloquear
                    if (txtDownloadLog.InvokeRequired)
                        txtDownloadLog.BeginInvoke(appendLog);
                    else
                        appendLog();
                }
                catch (ObjectDisposedException) { }
                catch (InvalidOperationException) { }
            };
            SafeLog( "CreateVaciarTab: LogDownload definido\n");

            SafeLog( "CreateVaciarTab: Creando bottomPanel\n");
            // Panel inferior con estadísticas
            var bottomPanel = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 2,
                BackColor = Color.FromArgb(30, 30, 30),
                Padding = new Padding(12, 8, 12, 8)
            };
            bottomPanel.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 60f));
            bottomPanel.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 40f));

            var lblStats = new Label
            {
                Text = "Total: 0 archivos",
                AutoSize = true,
                Font = new Font("Segoe UI", 10, FontStyle.Bold),
                ForeColor = Color.White,
                Margin = new Padding(0, 2, 0, 0)
            };
            bottomPanel.Controls.Add(lblStats, 0, 0);

            // Panel de estadísticas en tiempo real (lado derecho)
            lblRealtimeStats = new Label
            {
                Text = "📊 Estadísticas: Esperando...",
                AutoSize = true,
                Font = new Font("Segoe UI", 9),
                ForeColor = Color.LightGray,
                TextAlign = ContentAlignment.MiddleRight,
                Anchor = AnchorStyles.Right,
                Margin = new Padding(0, 4, 0, 0)
            };
            bottomPanel.Controls.Add(lblRealtimeStats, 1, 0);
            
            // Timer para actualizar estadísticas cada segundo
            if (statsUpdateTimer == null)
            {
                statsUpdateTimer = new System.Windows.Forms.Timer();
                statsUpdateTimer.Interval = 1000; // 1 segundo
                statsUpdateTimer.Tick += (s, e) => UpdateRealtimeStats();
                statsUpdateTimer.Start();
            }
            
            // Timer para batch UI updates de descargas
            if (downloadUIBatchTimer == null)
            {
                downloadUIBatchTimer = new System.Windows.Forms.Timer();
                downloadUIBatchTimer.Interval = DOWNLOAD_UI_BATCH_INTERVAL_MS;
                downloadUIBatchTimer.Tick += (s, e) => ProcessDownloadUIBatch();
                downloadUIBatchTimer.Start();
            }
            
            SafeLog( "CreateVaciarTab: lblStats agregado\n");

            mainLayout.Controls.Add(bottomPanel, 0, 2);
            mainLayout.SetColumnSpan(bottomPanel, 2);
            SafeLog( "CreateVaciarTab: bottomPanel agregado\n");

            SafeLog( "CreateVaciarTab: Definiendo loadData\n");
            // Cargar datos con filtros (OPTIMIZADO)
            Action<string> loadData = (filterText) =>
            {
                lvVaciarAuthors.BeginUpdate();
                try
                {
                    lvVaciarAuthors.Items.Clear();

                    // Si filteredAuthorsData está vacía, llenarla desde autoSearchResults
                    if (filteredAuthorsData.Count == 0)
                    {
                        lock (autoSearchResultsLock)
                        {
                            if (autoSearchResults.Count > 0)
                            {
                                // Agrupar TODOS los autores primero
                                var authorGroups = autoSearchResults
                                    .GroupBy(f => f.Author)
                                    .Select(g =>
                                    {
                                        var allFiles = g.ToList();
                                        var uniqueFiles = allFiles
                                            .GroupBy(f => f.FileName, StringComparer.OrdinalIgnoreCase)
                                            .Select(fg => fg.First())
                                            .ToList();
                                        
                                        // Calcular archivos descargados
                                        var downloadedFiles = uniqueFiles
                                            .Where(f => IsFileDownloaded(GetDownloadPath(f.FileName, f.Author)))
                                            .ToList();
                                        
                                        // Calcular archivos pendientes
                                        var pendingFiles = uniqueFiles
                                            .Where(f => !carbarherCacheLoaded || !carbarherFilesCache.Contains(f.FileName))
                                            .Where(f => !IsAlreadyDownloaded(f.FileName, "", 0))
                                            .ToList();
                                        
                                        // Calcular tamaños
                                        long totalSize = uniqueFiles.Sum(f => f.SizeBytes);
                                        long downloadedSize = downloadedFiles.Sum(f => f.SizeBytes);
                                        
                                        // Contar proveedores únicos
                                        int providers = allFiles.Select(f => f.Username).Distinct().Count();
                                        
                                        // Obtener última fecha de descarga
                                        DateTime? lastDownload = null;
                                        try
                                        {
                                            var authorFolder = Path.Combine(downloadDir, g.Key);
                                            if (System.IO.Directory.Exists(authorFolder))
                                            {
                                                var files = System.IO.Directory.GetFiles(authorFolder);
                                                if (files.Length > 0)
                                                {
                                                    lastDownload = files.Max(f => System.IO.File.GetLastWriteTime(f));
                                                }
                                            }
                                        }
                                        catch { }
                                        
                                        return new AuthorData
                                        {
                                            Name = g.Key,
                                            FilesCount = pendingFiles.Count,
                                            DownloadedCount = downloadedFiles.Count,
                                            TotalSizeBytes = totalSize,
                                            DownloadedSizeBytes = downloadedSize,
                                            ProvidersCount = providers,
                                            LastDownloadDate = lastDownload,
                                            Status = "Listo",
                                            ForeColor = Color.White,
                                            IsChecked = false
                                        };
                                    })
                                    .ToList();
                                
                                filteredAuthorsData.Clear();
                                filteredAuthorsData.AddRange(authorGroups);
                                
                                var authorsWithFiles = authorGroups.Count(a => a.FilesCount > 0);
                                var pendingFiles = authorGroups.Sum(a => a.FilesCount);
                                LogDownload($"📊 Cargados {filteredAuthorsData.Count:N0} autores ({authorsWithFiles:N0} con archivos pendientes, {pendingFiles:N0} archivos totales)");
                            }
                        }
                    }

                    // Reutilizar los datos filtrados de la pestaña Automático
                    var authorsToShow = filteredAuthorsData.AsEnumerable();
                    
                    // Aplicar filtro de búsqueda si hay texto
                    if (!string.IsNullOrWhiteSpace(filterText))
                    {
                        var filter = filterText.ToLowerInvariant();
                        authorsToShow = authorsToShow.Where(a => a.Name.ToLowerInvariant().Contains(filter));
                    }
                    
                    var items = authorsToShow
                        .OrderBy(a => a.Name)
                        .Select(author =>
                        {
                            var item = new ListViewItem(author.Name)
                            {
                                ForeColor = author.ForeColor,
                                Checked = author.IsChecked,
                                Tag = author
                            };
                            
                            // Archivos (igual que en Automático)
                            item.SubItems.Add(author.FilesCount.ToString());
                            
                            // Estado (igual que en Automático)
                            item.SubItems.Add(author.Status ?? "");
                            
                            return item;
                        })
                        .ToArray();

                    lvVaciarAuthors.Items.AddRange(items);

                    int totalAuthors = filteredAuthorsData.Count;
                    int totalFiles = filteredAuthorsData.Sum(a => a.FilesCount);
                    lblStats.Text = $"Autores: {totalAuthors:N0} | Total archivos: {totalFiles:N0}";
                }
                finally
                {
                    lvVaciarAuthors.EndUpdate();
                }
            };

            // Refrescar grilla cuando cambia estado en Automático
            vaciarGridRefresher = () => loadData("");

            Action loadDataLegacy = () =>
            {
                lvVaciarAuthors.BeginUpdate();
                try
                {
                    loadData("");
                }
                finally
                {
                    lvVaciarAuthors.EndUpdate();
                }
            };

            // Wire up filter events after loadData is defined
            chkDocs.CheckedChanged += (s, e) => loadData(txtSearchVaciar.Text);
            chkPendingOnly.CheckedChanged += (s, e) => loadData(txtSearchVaciar.Text);

            SafeLog( "CreateVaciarTab: loadData definido\n");
            
            // Menú contextual para click derecho (DESPUÉS de loadData y LogDownload)
            var contextMenu = new ContextMenuStrip
            {
                BackColor = Color.FromArgb(40, 40, 40),
                ForeColor = Color.White
            };
            
            var menuViewFiles = new ToolStripMenuItem("📄 Ver archivos del autor");
            menuViewFiles.Click += (s, e) =>
            {
                if (lvVaciarAuthors.SelectedItems.Count > 0)
                {
                    var selectedItem = lvVaciarAuthors.SelectedItems[0];
                    var authorData = (AuthorData)selectedItem.Tag;
                    string authorName = authorData.Name;
                    
                    // Obtener archivos del autor desde autoSearchResults
                    List<AutoSearchFileResult> allFiles;
                    lock (autoSearchResultsLock)
                    {
                        allFiles = autoSearchResults
                            .Where(f => f.Author.Equals(authorName, StringComparison.OrdinalIgnoreCase))
                            // FILTRAR archivos ya descargados en carbarher
                            .Where(f => !carbarherCacheLoaded || !carbarherFilesCache.Contains(f.FileName))
                            // FILTRAR archivos ya descargados en carpeta de descargas
                            .Where(f => !IsAlreadyDownloaded(f.FileName, "", 0))
                            .ToList();
                    }
                    
                    // Eliminar duplicados por nombre de archivo (mantener el de mejor proveedor)
                    // Usar Rust si está disponible (20x más rápido), sino LINQ
                    List<AutoSearchFileResult> files;
                    if (SlskNativeInterop.IsAvailable && allFiles.Count > 100)
                    {
                        files = SlskNativeInterop.DeduplicateFiles(
                            allFiles,
                            f => f.FileName,
                            f => f.Username,
                            f => f.SizeBytes,
                            username => (int)GetProviderScore(username)
                        );
                    }
                    else
                    {
                        files = allFiles
                            .GroupBy(f => f.FileName, StringComparer.OrdinalIgnoreCase)
                            .Select(g => g.OrderByDescending(f => GetProviderScore(f.Username)).First())
                            .ToList();
                    }
                    
                    Log($"📄 [Vaciar] Mostrando archivos únicos de '{authorName}' ({files.Count} únicos de {allFiles.Count} totales, filtrados por carbarher + descargas)");
                    
                    // Crear ventana para mostrar archivos
                    var filesForm = new Form
                    {
                        Text = $"Archivos de {authorName} ({files.Count} archivos únicos)",
                        BackColor = Color.FromArgb(25, 25, 25),
                        ForeColor = Color.White,
                        StartPosition = FormStartPosition.CenterParent,
                        Size = new Size(1600, 900),
                        MinimumSize = new Size(1200, 700)
                    };

                    var filesLayout = new TableLayoutPanel
                    {
                        Dock = DockStyle.Fill,
                        ColumnCount = 1,
                        RowCount = 2,
                        BackColor = Color.FromArgb(25, 25, 25),
                        Padding = new Padding(18, 16, 18, 12)
                    };
                    filesLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize));
                    filesLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100f));

                    var controlsFlow = new FlowLayoutPanel
                    {
                        Dock = DockStyle.Fill,
                        AutoSize = true,
                        FlowDirection = FlowDirection.LeftToRight,
                        WrapContents = true,
                        BackColor = Color.FromArgb(35, 35, 35),
                        Padding = new Padding(12, 8, 12, 8),
                        Margin = new Padding(0, 0, 0, 12)
                    };

                    var lblSummary = new Label
                    {
                        AutoSize = true,
                        ForeColor = Color.LightBlue,
                        Font = new Font("Segoe UI", 9, FontStyle.Bold),
                        Margin = new Padding(0, 6, 16, 0)
                    };
                    controlsFlow.Controls.Add(lblSummary);

                    var lblFilter = new Label
                    {
                        Text = "🔎 Filtrar:",
                        AutoSize = true,
                        ForeColor = Color.White,
                        Font = new Font("Segoe UI", 9),
                        Margin = new Padding(0, 6, 8, 0)
                    };
                    controlsFlow.Controls.Add(lblFilter);

                    var txtFilter = new TextBox
                    {
                        Width = 260,
                        BackColor = Color.FromArgb(45, 45, 45),
                        ForeColor = Color.White,
                        Font = new Font("Segoe UI", 9),
                        Margin = new Padding(0, 2, 0, 0)
                    };
                    controlsFlow.Controls.Add(txtFilter);

                    var lvAuthorFiles = new ListView
                    {
                        Dock = DockStyle.Fill,
                        View = View.Details,
                        FullRowSelect = true,
                        GridLines = true,
                        BackColor = Color.FromArgb(30, 30, 30),
                        ForeColor = Color.White,
                        Font = new Font("Segoe UI", 9),
                        HeaderStyle = ColumnHeaderStyle.Clickable
                    };

                    lvAuthorFiles.Columns.Add("Archivo", 420);
                    lvAuthorFiles.Columns.Add("Tamaño", 110);
                    lvAuthorFiles.Columns.Add("Usuario", 170);
                    lvAuthorFiles.Columns.Add("Extensión", 110);

                    int sortCol = 0;
                    bool sortAsc = true;
                    string currentFilter = string.Empty;

                    Action updateHeaders = () =>
                    {
                        string[] colNames = { "Archivo", "Tamaño", "Usuario", "Extensión" };
                        for (int i = 0; i < lvAuthorFiles.Columns.Count; i++)
                        {
                            string header = colNames[i];
                            if (i == sortCol)
                            {
                                header += sortAsc ? " ▲" : " ▼";
                            }
                            lvAuthorFiles.Columns[i].Text = header;
                        }
                    };

                    Action refreshList = () =>
                    {
                        lvAuthorFiles.BeginUpdate();
                        try
                        {
                            lvAuthorFiles.Items.Clear();

                            var filteredList = files
                                .Where(f => string.IsNullOrEmpty(currentFilter) ||
                                    f.FileName.Contains(currentFilter, StringComparison.OrdinalIgnoreCase) ||
                                    f.Username.Contains(currentFilter, StringComparison.OrdinalIgnoreCase) ||
                                    (!string.IsNullOrEmpty(f.Directory) && f.Directory.Contains(currentFilter, StringComparison.OrdinalIgnoreCase)))
                                .ToList();

                            IEnumerable<AutoSearchFileResult> sortedList = sortCol switch
                            {
                                0 => sortAsc ? filteredList.OrderBy(f => f.FileName) : filteredList.OrderByDescending(f => f.FileName),
                                1 => sortAsc ? filteredList.OrderBy(f => f.SizeBytes) : filteredList.OrderByDescending(f => f.SizeBytes),
                                2 => sortAsc ? filteredList.OrderBy(f => f.Username) : filteredList.OrderByDescending(f => f.Username),
                                3 => sortAsc ? filteredList.OrderBy(f => Path.GetExtension(f.FileName)) : filteredList.OrderByDescending(f => Path.GetExtension(f.FileName)),
                                _ => filteredList.OrderBy(f => f.FileName)
                            };

                            foreach (var file in sortedList)
                            {
                                var item = new ListViewItem(file.FileName);
                                item.SubItems.Add(file.SizeReadable);
                                item.SubItems.Add(file.Username);

                                string extension = Path.GetExtension(file.FileName);
                                if (!string.IsNullOrEmpty(extension) && extension.StartsWith("."))
                                {
                                    extension = extension[1..].ToUpperInvariant();
                                }
                                else if (string.IsNullOrEmpty(extension))
                                {
                                    extension = "(sin ext)";
                                }
                                item.SubItems.Add(extension);

                                item.Tag = file;
                                lvAuthorFiles.Items.Add(item);
                            }

                            lblSummary.Text = $"Mostrando {filteredList.Count} archivos de {files.Count} totales";
                        }
                        finally
                        {
                            lvAuthorFiles.EndUpdate();
                        }
                    };

                    txtFilter.TextChanged += (s, e) =>
                    {
                        currentFilter = txtFilter.Text;
                        refreshList();
                    };

                    lvAuthorFiles.ColumnClick += (sender, args) =>
                    {
                        if (args.Column == sortCol)
                        {
                            sortAsc = !sortAsc;
                        }
                        else
                        {
                            sortCol = args.Column;
                            sortAsc = true;
                        }
                        updateHeaders();
                        refreshList();
                    };

                    filesLayout.Controls.Add(controlsFlow, 0, 0);
                    filesLayout.Controls.Add(lvAuthorFiles, 0, 1);

                    filesForm.Controls.Add(filesLayout);

                    refreshList();
                    updateHeaders();

                    filesForm.ShowDialog();
                }
            };
            contextMenu.Items.Add(menuViewFiles);
            
            var menuDeleteAuthor = new ToolStripMenuItem("🗑️ Eliminar autor");
            menuDeleteAuthor.Click += (s, e) =>
            {
                if (lvVaciarAuthors.SelectedItems.Count > 0)
                {
                    var selectedItems = lvVaciarAuthors.SelectedItems.Cast<ListViewItem>().ToList();
                    var authorNames = string.Join(", ", selectedItems.Select(i => i.Text));
                    
                    var result = MessageBox.Show(
                        $"¿Eliminar {selectedItems.Count} autor(es)?\n\n{authorNames}\n\nEsto eliminará todos sus archivos de la lista y los excluirá de búsquedas activas.",
                        "Confirmar eliminación",
                        MessageBoxButtons.YesNo,
                        MessageBoxIcon.Warning
                    );
                    
                    if (result == DialogResult.Yes)
                    {
                        Log($"🗑️ [Vaciar] Eliminando {selectedItems.Count} autor(es): {authorNames}");
                        
                        // Obtener lista de autores y archivos a eliminar
                        var authorsToExclude = new List<string>();
                        var filesToRemove = new List<AutoSearchFileResult>();
                        
                        foreach (var item in selectedItems)
                        {
                            var authorData = (AuthorData)item.Tag;
                            string authorName = authorData.Name;
                            authorsToExclude.Add(authorName);
                            
                            // Obtener archivos del autor desde autoSearchResults
                            lock (autoSearchResultsLock)
                            {
                                var files = autoSearchResults
                                    .Where(f => f.Author.Equals(authorName, StringComparison.OrdinalIgnoreCase))
                                    .ToList();
                                filesToRemove.AddRange(files);
                            }
                        }
                        
                        // Agregar a blacklist permanente y lista de excluidos
                        foreach (var author in authorsToExclude)
                        {
                            // Agregar a blacklist para que no reaparezca
                            AddToBlacklist(author);
                            Log($"   ⛔ Autor agregado a blacklist: {author}");
                            
                            // Agregar a lista de excluidos (afecta búsquedas activas)
                            excludedAuthors.Add(author);
                            Log($"   ⛔ Autor excluido de búsquedas activas: {author}");
                        }
                        
                        // Eliminar de autoSearchResults
                        lock (autoSearchResultsLock)
                        {
                            autoSearchResults.RemoveAll(f => filesToRemove.Contains(f));
                        }
                        
                        // Recargar grilla
                        loadData("");
                        
                        // Guardar CSV actualizado sin los autores eliminados
                        SaveAutoResultsToCsv();
                        
                        LogDownload($"🗑️ Eliminados {selectedItems.Count} autor(es) ({filesToRemove.Count} archivos)");
                        LogDownload($"⛔ {authorsToExclude.Count} autor(es) excluidos de búsquedas activas");
                        LogDownload($"💾 CSV actualizado - autores eliminados del archivo");
                    }
                }
            };
            contextMenu.Items.Add(menuDeleteAuthor);
            
            lvVaciarAuthors.ContextMenuStrip = contextMenu;
            SafeLog( "CreateVaciarTab: Menú contextual configurado\n");
            
            // Cargar cachés en paralelo (DIFERIDO para no bloquear el arranque)
            // NO pasar LogDownload aquí porque causa deadlock durante la inicialización
            Task.Run(async () => 
            {
                await Task.Delay(1000); // Esperar a que el form esté completamente inicializado
                try
                {
                    LogDownload("⏳ Iniciando escaneo de carpetas en paralelo...");
                    var sw = System.Diagnostics.Stopwatch.StartNew();
                    
                    // Ejecutar ambos escaneos en paralelo
                    await Task.WhenAll(
                        Task.Run(() => ScanDownloadFolderToHistory(LogDownload)),
                        Task.Run(() => LoadCarbarherCache(LogDownload))
                    );
                    
                    sw.Stop();
                    LogDownload($"✅ Cachés cargados en {sw.ElapsedMilliseconds}ms ({sw.Elapsed.TotalSeconds:F1}s)");
                }
                catch (Exception ex)
                {
                    LogDownload($"⚠️ Error cargando cachés: {ex.Message}");
                }
            });
            
            SafeLog( "CreateVaciarTab: Llamando loadData(\"\")\n");
            // COMENTADO: loadData hace operaciones pesadas de I/O que bloquean el UI thread
            // Se cargará automáticamente cuando el usuario abra la pestaña
            // loadData("");
            SafeLog( "CreateVaciarTab: loadData(\"\") omitido (se cargará al abrir tab)\n");
            
            // NO llamar LogDownload durante la inicialización - causa deadlock
            // Programar el mensaje para después de que el form esté completamente cargado
            // LogDownload("✅ Pestaña Vaciar iniciada");
            
            // En su lugar, programar el mensaje para después de que el form esté completamente cargado
            Task.Run(async () => 
            {
                await Task.Delay(500); // Esperar a que el form esté completamente inicializado
                LogDownload("✅ Pestaña Vaciar iniciada");
            });
            
            SafeLog( "CreateVaciarTab: Inicialización básica completada\n");

            SafeLog( "CreateVaciarTab: Registrando event handlers de filtros\n");
            // Event handlers para filtros
            numMinSizeKB.ValueChanged += (s, e) => { loadData(""); LogDownload($"📏 Tamaño mínimo: {numMinSizeKB.Value:N0} KB"); };
            
            // Búsqueda incremental
            txtSearchVaciar.TextChanged += (s, e) =>
            {
                loadData(txtSearchVaciar.Text);
            };
            
            SafeLog( "CreateVaciarTab: Event handlers de filtros registrados\n");

            // Event handler para verificar y actualizar conteo de archivos filtrados
            btnVerifyIntegrity.Click += async (s, e) =>
            {
                try
                {
                    Log("✅ [Vaciar] Botón 'Verificar' pulsado");
                    LogDownload("════════════════════════════════════");
                    LogDownload("✅ VERIFICANDO ARCHIVOS Y USUARIOS");
                    LogDownload("════════════════════════════════════");
                    
                    btnVerifyIntegrity.Enabled = false;
                    
                    if (client == null || !client.State.HasFlag(SoulseekClientStates.Connected))
                    {
                        LogDownload("❌ No conectado");
                        DarkMessageBox.Show("Debes estar conectado a Soulseek.", "No conectado", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                        btnVerifyIntegrity.Enabled = true;
                        return;
                    }
                    
                    int totalFiles = 0;
                    int filteredFiles = 0;
                    int authorsWithFiles = 0;
                    int totalUsersWithoutSlots = 0;
                    var minSizeKB = (int)numMinSizeKB.Value;
                    var usersWithoutSlots = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                    
                    // Paso 1: Verificar slots libres de todos los usuarios únicos
                    LogDownload("🔍 Verificando slots libres de usuarios...");
                    HashSet<string> uniqueUsers;
                    lock (autoSearchResultsLock)
                    {
                        // MEJORA #39: ToHashSet ya elimina duplicados, no necesita Distinct()
                        uniqueUsers = autoSearchResults.Select(f => f.Username).ToHashSet(StringComparer.OrdinalIgnoreCase);
                    }
                    
                    int usersChecked = 0;
                    foreach (var username in uniqueUsers)
                    {
                        try
                        {
                            using var timeoutCts = new CancellationTokenSource(TimeSpan.FromSeconds(3));
                            var userInfo = await client.GetUserInfoAsync(username, timeoutCts.Token);
                            
                            if (!userInfo.HasFreeUploadSlot && userInfo.QueueLength >= 10)
                            {
                                usersWithoutSlots.Add(username);
                                totalUsersWithoutSlots++;
                            }
                            usersChecked++;
                            
                            if (usersChecked % 10 == 0)
                            {
                                LogDownload($"   Verificados: {usersChecked}/{uniqueUsers.Count} usuarios");
                            }
                        }
                        catch
                        {
                            // Si falla la verificación, continuar de todos modos
                        }
                    }
                    
                    LogDownload($"✅ Verificación completada: {usersChecked} usuarios");
                    if (totalUsersWithoutSlots > 0)
                    {
                        LogDownload($"⏸️ {totalUsersWithoutSlots} usuarios sin slots libres detectados");
                    }
                    
                    // Paso 2: Filtrar archivos
                    lock (autoSearchResultsLock)
                    {
                        totalFiles = autoSearchResults.Count;
                        
                        // ELIMINAR archivos que NO pasan los filtros
                        var validFiles = autoSearchResults.Where(f =>
                        {
                            // Filtro 0: Usuarios sin slots libres
                            if (usersWithoutSlots.Contains(f.Username))
                                return false;
                            
                            // Filtro 1: Blacklist de usuarios
                            if (blacklist.Contains(f.Username))
                                return false;
                            
                            // Filtro 2: Tamaño mínimo
                            if (minSizeKB > 0 && f.SizeBytes < (minSizeKB * 1024))
                                return false;
                            
                            // Filtro 3: Idioma español
                            if (!IsSpanishText(f.FileName))
                                return false;
                            
                            // Filtro 4: Tipo de documento
                            if (!IsDocumentFile(f.FileName))
                                return false;
                            
                            // Filtro 5: Ya descargado (en carbarher)
                            if (carbarherCacheLoaded && carbarherFilesCache.Contains(f.FileName))
                                return false;
                            
                            // Filtro 6: Ya descargado (en carpeta de descargas)
                            if (IsAlreadyDownloaded(f.FileName, "", 0))
                                return false;
                            
                            return true;
                        }).ToList();
                        
                        filteredFiles = validFiles.Count;
                        
                        // Reemplazar lista con solo archivos válidos
                        autoSearchResults.Clear();
                        autoSearchResults.AddRange(validFiles);
                        
                        // Contar autores con archivos válidos
                        authorsWithFiles = autoSearchResults
                            .GroupBy(f => f.Author)
                            .Count();
                    }
                    
                    var excludedFiles = totalFiles - filteredFiles;
                    LogDownload($"📊 Archivos totales: {totalFiles:N0}");
                    LogDownload($"✅ Archivos válidos: {filteredFiles:N0}");
                    LogDownload($"⚠️ Archivos filtrados: {excludedFiles:N0}");
                    LogDownload($"👥 Autores con archivos válidos: {authorsWithFiles:N0}");
                    LogDownload("════════════════════════════════════");
                    
                    // Actualizar contadores de archivos por autor sin eliminar autores
                    lock (autoSearchResultsLock)
                    {
                        var authorFileCounts = autoSearchResults
                            .GroupBy(f => f.Author)
                            .ToDictionary(g => g.Key, g => g.Count());
                        
                        // Actualizar contadores en allAuthorsData y filteredAuthorsData
                        foreach (var author in allAuthorsData)
                        {
                            if (authorFileCounts.TryGetValue(author.Name, out int count))
                            {
                                author.FilesCount = count;
                                author.Status = $"{count} archivo(s) válido(s)";
                            }
                            else
                            {
                                author.FilesCount = 0;
                                author.Status = "Sin archivos válidos";
                            }
                        }
                    }
                    
                    // Refrescar la vista sin eliminar autores
                    if (lvAutoAuthors != null)
                    {
                        RefreshAuthorsListView();
                        UpdateAuthorCount();
                    }
                    
                    // Refrescar la grilla de Vaciar
                    loadData("");
                    
                    var notificationMsg = $"✅ {filteredFiles:N0} archivos válidos\n" +
                        $"⚠️ {excludedFiles:N0} archivos filtrados\n" +
                        $"👥 {authorsWithFiles:N0} autores con archivos";
                    
                    if (totalUsersWithoutSlots > 0)
                    {
                        notificationMsg += $"\n⏸️ {totalUsersWithoutSlots} usuarios sin slots eliminados";
                    }
                    
                    // Verificación completada registrada en log
                }
                catch (Exception ex)
                {
                    LogDownload($"❌ Error en verificación: {ex.Message}");
                    LogDownload("════════════════════════════════════");
                }
                finally
                {
                    btnVerifyIntegrity.Enabled = true;
                }
            };
            
            // Event handler para dashboard de estadísticas en tiempo real
            btnDashboard.Click += (s, e) =>
            {
                try
                {
                    Log("📊 [Vaciar] Botón 'Dashboard' pulsado");
                    
                    var dashboardForm = new Form
                    {
                        Text = "📊 Dashboard de Estadísticas en Tiempo Real",
                        Size = new Size(900, 700),
                        BackColor = Color.FromArgb(20, 20, 20),
                        ForeColor = Color.White,
                        StartPosition = FormStartPosition.CenterScreen,
                        FormBorderStyle = FormBorderStyle.Sizable,
                        MinimumSize = new Size(700, 500)
                    };
                    
                    var mainPanel = new Panel
                    {
                        Dock = DockStyle.Fill,
                        Padding = new Padding(20),
                        AutoScroll = true
                    };
                    
                    var lblStats = new Label
                    {
                        Dock = DockStyle.Fill,
                        Font = new Font("Consolas", 10),
                        TextAlign = ContentAlignment.TopLeft,
                        AutoSize = false
                    };
                    
                    mainPanel.Controls.Add(lblStats);
                    dashboardForm.Controls.Add(mainPanel);
                    
                    // Método para actualizar estadísticas
                    Action updateStats = () =>
                    {
                        try
                        {
                            // MEJORA #30: Usar pool de StringBuilder
                            var stats = GetStringBuilder();
                            
                            stats.AppendLine("═══════════════════════════════════════════════════════════════");
                            stats.AppendLine("📊 DASHBOARD DE ESTADÍSTICAS - ACTUALIZACIÓN EN TIEMPO REAL");
                            stats.AppendLine("═══════════════════════════════════════════════════════════════");
                            stats.AppendLine();
                            
                            // SECCIÓN 1: Biblioteca General
                            stats.AppendLine("📚 BIBLIOTECA GENERAL");
                            stats.AppendLine("─────────────────────────────────────────────────────────────");
                            
                            int totalFiles = 0;
                            long totalSize = 0;
                            int withHash = 0;
                            
                            lock (downloadHistoryLock)
                            {
                                totalFiles = downloadHistory.Count;
                                totalSize = downloadHistory.Sum(h => h.SizeBytes);
                                withHash = downloadHistory.Count(h => !string.IsNullOrEmpty(h.Hash));
                            }
                            
                            stats.AppendLine($"   📁 Total de archivos: {totalFiles:N0}");
                            stats.AppendLine($"   💾 Espacio total: {FormatFileSize(totalSize)}");
                            stats.AppendLine($"   🔐 Con hash BLAKE3: {withHash:N0} ({(totalFiles > 0 ? (withHash * 100.0 / totalFiles) : 0):F1}%)");
                            stats.AppendLine($"   ⚠️ Sin hash: {totalFiles - withHash:N0}");
                            stats.AppendLine();
                            
                            // SECCIÓN 2: Descargas Recientes
                            stats.AppendLine("📥 DESCARGAS RECIENTES");
                            stats.AppendLine("─────────────────────────────────────────────────────────────");
                            
                            var last24h = 0;
                            var last7days = 0;
                            var last30days = 0;
                            
                            lock (downloadHistoryLock)
                            {
                                var now = DateTime.Now;
                                last24h = downloadHistory.Count(h => (now - h.DownloadedAt).TotalHours < 24);
                                last7days = downloadHistory.Count(h => (now - h.DownloadedAt).TotalDays < 7);
                                last30days = downloadHistory.Count(h => (now - h.DownloadedAt).TotalDays < 30);
                            }
                            
                            stats.AppendLine($"   Últimas 24 horas: {last24h:N0} archivos");
                            stats.AppendLine($"   Últimos 7 días: {last7days:N0} archivos");
                            stats.AppendLine($"   Últimos 30 días: {last30days:N0} archivos");
                            stats.AppendLine();
                            
                            // SECCIÓN 3: Velocidades
                            stats.AppendLine("⚡ VELOCIDADES DE DESCARGA");
                            stats.AppendLine("─────────────────────────────────────────────────────────────");
                            
                            double avgSpeed = 0;
                            double maxSpeed = 0;
                            double minSpeed = 0;
                            
                            lock (downloadHistoryLock)
                            {
                                var speedsData = downloadHistory.Where(h => h.SpeedMBps > 0).ToList();
                                if (speedsData.Any())
                                {
                                    avgSpeed = speedsData.Average(h => h.SpeedMBps);
                                    maxSpeed = speedsData.Max(h => h.SpeedMBps);
                                    minSpeed = speedsData.Min(h => h.SpeedMBps);
                                }
                            }
                            
                            stats.AppendLine($"   Promedio: {avgSpeed:F2} MB/s");
                            stats.AppendLine($"   Máxima: {maxSpeed:F2} MB/s");
                            stats.AppendLine($"   Mínima: {minSpeed:F2} MB/s");
                            stats.AppendLine();
                            
                            // SECCIÓN 4: Top Proveedores
                            stats.AppendLine("🏆 TOP 10 PROVEEDORES");
                            stats.AppendLine("─────────────────────────────────────────────────────────────");
                            
                            lock (downloadHistoryLock)
                            {
                                var topProviders = downloadHistory
                                    .GroupBy(h => h.Username)
                                    .Select(g => new
                                    {
                                        Username = g.Key,
                                        Count = g.Count(),
                                        TotalSize = g.Sum(h => h.SizeBytes),
                                        AvgSpeed = g.Where(h => h.SpeedMBps > 0).Average(h => (double?)h.SpeedMBps) ?? 0
                                    })
                                    .OrderByDescending(p => p.Count)
                                    .Take(10);
                                
                                int rank = 1;
                                foreach (var provider in topProviders)
                                {
                                    stats.AppendLine($"   {rank++}. {provider.Username}");
                                    stats.AppendLine($"      Archivos: {provider.Count:N0} | " +
                                        $"Total: {FormatFileSize(provider.TotalSize)} | " +
                                        $"Vel. prom: {provider.AvgSpeed:F2} MB/s");
                                }
                            }
                            stats.AppendLine();
                            
                            // SECCIÓN 5: Cola de Descargas Actual
                            stats.AppendLine("📋 COLA DE DESCARGAS ACTUAL");
                            stats.AppendLine("─────────────────────────────────────────────────────────────");
                            
                            // MEJORA FASE 1.3: ReadLock para Count
                            (int queueCount, int activeDownloads) = ReadLocked(downloadQueueLock, () =>
                                (downloadQueue.Count, 
                                 downloadQueue.Count(t => t.Status == DownloadStatus.Downloading)));
                            
                            stats.AppendLine($"   En cola: {queueCount:N0} archivos");
                            stats.AppendLine($"   Descargando ahora: {activeDownloads} archivos");
                            stats.AppendLine($"   Pendientes: {queueCount - activeDownloads} archivos");
                            stats.AppendLine();
                            
                            // SECCIÓN 6: Extensiones Más Comunes
                            stats.AppendLine("📄 EXTENSIONES MÁS COMUNES");
                            stats.AppendLine("─────────────────────────────────────────────────────────────");
                            
                            lock (downloadHistoryLock)
                            {
                                var topExtensions = downloadHistory
                                    .GroupBy(h => Path.GetExtension(h.FileName).ToLower())
                                    .Select(g => new { Extension = g.Key, Count = g.Count() })
                                    .OrderByDescending(e => e.Count)
                                    .Take(10);
                                
                                foreach (var ext in topExtensions)
                                {
                                    var extName = string.IsNullOrEmpty(ext.Extension) ? "(sin extensión)" : ext.Extension;
                                    stats.AppendLine($"   {extName}: {ext.Count:N0} archivos");
                                }
                            }
                            stats.AppendLine();
                            
                            // SECCIÓN 7: Información del Sistema
                            stats.AppendLine("💻 INFORMACIÓN DEL SISTEMA");
                            stats.AppendLine("─────────────────────────────────────────────────────────────");
                            stats.AppendLine($"   Hora actual: {DateTime.Now:yyyy-MM-dd HH:mm:ss}");
                            stats.AppendLine($"   Uptime de la app: {(DateTime.Now - Process.GetCurrentProcess().StartTime):hh\\:mm\\:ss}");
                            stats.AppendLine($"   Uso de memoria: {FormatFileSize(Process.GetCurrentProcess().WorkingSet64)}");
                            stats.AppendLine();
                            
                            stats.AppendLine("═══════════════════════════════════════════════════════════════");
                            stats.AppendLine("🔄 Actualización automática cada 1 segundo");
                            stats.AppendLine("═══════════════════════════════════════════════════════════════");
                            
                            lblStats.Text = stats.ToString();
                        }
                        catch (Exception ex)
                        {
                            lblStats.Text = $"❌ Error actualizando dashboard: {ex.Message}";
                        }
                    };
                    
                    // Timer para actualizar cada segundo
                    var updateTimer = new System.Windows.Forms.Timer { Interval = 1000 };
                    updateTimer.Tick += (ts, te) => updateStats();
                    
                    // Actualizar inmediatamente
                    updateStats();
                    
                    // Iniciar timer
                    updateTimer.Start();
                    
                    // Detener timer al cerrar
                    dashboardForm.FormClosed += (fs, fe) =>
                    {
                        updateTimer.Stop();
                        updateTimer.Dispose();
                        Log("📊 Dashboard cerrado");
                    };
                    
                    dashboardForm.Show();
                    Log("📊 Dashboard abierto");
                }
                catch (Exception ex)
                {
                    Log($"❌ Error abriendo dashboard: {ex.Message}");
                    DarkMessageBox.Show($"Error abriendo dashboard: {ex.Message}", "Error", 
                        MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            };

            // Mensaje inicial en el log (sin carga automática para evitar race conditions)
            LogDownload("═══════════════════════════════════════════════════");
            LogDownload("📥 TAB VACIAR - Listo para usar");
            LogDownload("═══════════════════════════════════════════════════");
            LogDownload("💡 Presiona '🔄 Actualizar' para cargar los datos");
            LogDownload("═══════════════════════════════════════════════════");

            // Event handler para siguiente autor (búsqueda exhaustiva)
            btnNextAuthor.Click += async (s, e) =>
            {
                try
                {
                    Log("🔄 [Vaciar] Botón 'Actualizar' pulsado");
                    if (currentAuthorIndex >= authorsList.Count)
                    {
                        LogDownload("✅ TODOS LOS AUTORES PROCESADOS");
                        btnNextAuthor.Enabled = false;
                        return;
                    }

                    string currentAuthor = authorsList[currentAuthorIndex];
                    
                    // Verificar si el autor fue excluido
                    if (excludedAuthors.Contains(currentAuthor))
                    {
                        LogDownload($"⛔ Autor excluido, saltando: {currentAuthor}");
                        currentAuthorIndex++;
                        
                        // Continuar con el siguiente autor
                        if (currentAuthorIndex < authorsList.Count)
                        {
                            btnNextAuthor.Text = $"🔄 Actualizar ({currentAuthorIndex + 1}/{authorsList.Count})";
                            await Task.Delay(100);
                            btnNextAuthor.PerformClick();
                        }
                        else
                        {
                            btnNextAuthor.Text = "✅ Completado";
                            btnNextAuthor.Enabled = false;
                            LogDownload("✅ TODOS LOS AUTORES PROCESADOS");
                        }
                        return;
                    }
                    
                    Log($"🔍 [Vaciar] Procesando autor {currentAuthorIndex + 1}/{authorsList.Count}: {currentAuthor}");
                    LogDownload("════════════════════════════════════");
                    LogDownload($"🔍 AUTOR {currentAuthorIndex + 1}/{authorsList.Count}: {currentAuthor}");
                    LogDownload("════════════════════════════════════");

                    if (client == null || !client.State.HasFlag(SoulseekClientStates.Connected))
                    {
                        LogDownload("❌ No conectado");
                        DarkMessageBox.Show("Debes estar conectado a Soulseek.", "No conectado", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                        return;
                    }

                    var searchStart = DateTime.Now;
                    
                    int totalNewFiles = 0;
                    int totalCarbarherDuplicates = 0;
                    int totalNonDocuments = 0;
                    int totalNonSpanish = 0;
                    int totalAlreadyDownloaded = 0;
                    int totalUsersWithoutSlots = 0;
                    int searchIteration = 0;
                    int consecutiveEmptySearches = 0;
                    const int MAX_EMPTY_SEARCHES = 3; // Reintentar hasta 3 veces
                    
                    var seenFiles = new HashSet<string>(5000); // Pre-allocar para ~5k archivos por búsqueda
                    var usersWithoutSlots = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                    
                    while (consecutiveEmptySearches < MAX_EMPTY_SEARCHES)
                    {
                        searchIteration++;
                        LogDownload($"🔄 Búsqueda #{searchIteration}...");
                        
                        var searchResponse = await client.SearchAsync(SearchQuery.FromText(currentAuthor));
                        lastActivityTime = DateTime.UtcNow; // Sticky session
                        int totalUsers = searchResponse.Responses.Count;
                        
                        var timestamp = DateTime.Now;
                        var newFilesToAdd = new List<AutoSearchFileResult>(1000); // Pre-allocate
                        int newFilesThisIteration = 0;
                        int carbarherDuplicatesThisIteration = 0;
                        int nonDocumentsThisIteration = 0;
                        int nonSpanishThisIteration = 0;
                        // Verificar slots libres de usuarios y filtrar los que no tienen
                        var usersToCheck = searchResponse.Responses
                            .Where(r => !r.Username.Equals("carbarher", StringComparison.OrdinalIgnoreCase))
                            .Where(r => !usersWithoutSlots.Contains(r.Username))
                            .Select(r => r.Username)
                            .Distinct()
                            .ToList();
                        
                        int usersWithoutSlotsThisIteration = 0;
                        foreach (var username in usersToCheck)
                        {
                            try
                            {
                                using var timeoutCts = new CancellationTokenSource(TimeSpan.FromSeconds(3));
                                var userInfo = await client.GetUserInfoAsync(username, timeoutCts.Token);
                                
                                if (!userInfo.HasFreeUploadSlot && userInfo.QueueLength >= 10)
                                {
                                    usersWithoutSlots.Add(username);
                                    usersWithoutSlotsThisIteration++;
                                    totalUsersWithoutSlots++;
                                }
                            }
                            catch
                            {
                                // Si falla la verificación, continuar de todos modos
                            }
                        }
                        
                        if (usersWithoutSlotsThisIteration > 0)
                        {
                            LogDownload($"   ⏸️ {usersWithoutSlotsThisIteration} usuarios sin slots libres eliminados");
                        }
                        
                        // Procesar respuestas en paralelo para mejor rendimiento
                        var allFiles = searchResponse.Responses
                            .Where(r => !r.Username.Equals("carbarher", StringComparison.OrdinalIgnoreCase))
                            .Where(r => !usersWithoutSlots.Contains(r.Username))
                            .SelectMany(r => r.Files.Select(f => new { Response = r, File = f }))
                            .Where(item => item.File.Size > 0) // Filtrar archivos de 0 bytes
                            .Where(item => minFileSizeKB == 0 || item.File.Size >= (minFileSizeKB * 1024)) // Filtrar por tamaño mínimo
                            .AsParallel()
                            .WithDegreeOfParallelism(Environment.ProcessorCount)
                            .Select(item =>
                            {
                                // Filtrar archivos sin extensión
                                string extension = Path.GetExtension(item.File.Filename);
                                if (string.IsNullOrEmpty(extension))
                                    return null;
                                
                                // MEJORA #23: Usar interpolación para mejor rendimiento
                                var fileKey = $"{item.Response.Username}|{item.File.Filename}|{item.File.Size}";
                                
                                var filenameLower = item.File.Filename.ToLowerInvariant();
                                
                                // Usar IndexOf con StringComparison para mejor rendimiento
                                bool isSpanish = filenameLower.IndexOf("spanish", StringComparison.Ordinal) >= 0 || 
                                               filenameLower.IndexOf("español", StringComparison.Ordinal) >= 0 ||
                                               filenameLower.IndexOf("castellano", StringComparison.Ordinal) >= 0;
                                
                                bool isDocument = filenameLower.EndsWith(".pdf") ||
                                                filenameLower.EndsWith(".epub") ||
                                                filenameLower.EndsWith(".mobi");

                                string fileName = Path.GetFileName(item.File.Filename);
                                string directory = Path.GetDirectoryName(item.File.Filename) ?? "";

                                return new
                                {
                                    FileKey = fileKey,
                                    FileName = fileName,
                                    Directory = directory,
                                    Username = item.Response.Username,
                                    Size = item.File.Size,
                                    IsSpanish = isSpanish,
                                    IsDocument = isDocument
                                };
                            })
                            .Where(item => item != null) // Filtrar nulos (archivos sin extensión)
                            .ToList();
                        
                        // Procesar resultados secuencialmente para mantener thread-safety
                        foreach (var item in allFiles)
                        {
                            if (seenFiles.Contains(item.FileKey))
                                continue;
                            
                            seenFiles.Add(item.FileKey);
                            
                            // Contar archivos filtrados
                            if (!item.IsDocument)
                            {
                                nonDocumentsThisIteration++;
                                totalNonDocuments++;
                                continue;
                            }
                            
                            if (!item.IsSpanish)
                            {
                                nonSpanishThisIteration++;
                                totalNonSpanish++;
                                continue;
                            }

                            // Verificar si ya existe en cbh
                            if (carbarherCacheLoaded && carbarherFilesCache.Contains(item.FileName))
                            {
                                carbarherDuplicatesThisIteration++;
                                totalCarbarherDuplicates++;
                                continue;
                            }
                            
                            // Verificar si ya fue descargado - OMITIR si ya existe
                            bool alreadyDownloaded = IsAlreadyDownloaded(item.FileName, item.Username, item.Size);
                            
                            if (alreadyDownloaded)
                            {
                                totalAlreadyDownloaded++;
                                continue; // ⚠️ OMITIR archivos ya descargados
                            }

                            newFilesToAdd.Add(new AutoSearchFileResult
                            {
                                Author = currentAuthor,
                                Username = item.Username,
                                FileName = item.FileName,
                                Directory = item.Directory,
                                SizeBytes = item.Size,
                                SizeReadable = FormatFileSize(item.Size),
                                IsSpanish = item.IsSpanish,
                                IsDocument = true,
                                Timestamp = timestamp
                            });
                            newFilesThisIteration++;
                            totalNewFiles++;
                        }
                        
                        if (newFilesToAdd.Count > 0)
                        {
                            lock (autoSearchResultsLock)
                            {
                                autoSearchResults.AddRange(newFilesToAdd);
                            }
                        }
                        
                        LogDownload($"   📊 {totalUsers} usr, {newFilesThisIteration} nuevos");
                        if (nonDocumentsThisIteration > 0 || nonSpanishThisIteration > 0 || carbarherDuplicatesThisIteration > 0)
                        {
                            var filters = new List<string>();
                            if (nonDocumentsThisIteration > 0) filters.Add($"{nonDocumentsThisIteration} no-doc");
                            if (nonSpanishThisIteration > 0) filters.Add($"{nonSpanishThisIteration} no-es");
                            if (carbarherDuplicatesThisIteration > 0) filters.Add($"{carbarherDuplicatesThisIteration} cbh");
                            LogDownload($"      ↳ {string.Join(", ", filters)}");
                        }
                        
                        if (newFilesThisIteration == 0)
                        {
                            consecutiveEmptySearches++;
                            LogDownload($"   ⚠️ Sin resultados nuevos ({consecutiveEmptySearches}/{MAX_EMPTY_SEARCHES})");
                        }
                        else
                        {
                            consecutiveEmptySearches = 0;
                            if (searchIteration % 2 == 0)
                            {
                                ClearFileCache();
                                loadData("");
                            }
                        }
                        
                        await Task.Delay(500);
                    }

                    var searchDuration = (DateTime.Now - searchStart).TotalSeconds;
                    LogDownload($"✅ COMPLETADO en {searchDuration:F1}s");
                    LogDownload($"   {totalNewFiles} archivos encontrados ({searchIteration} búsquedas)");
                    
                    var summary = new List<string>();
                    if (totalNonDocuments > 0) summary.Add($"{totalNonDocuments} no-doc");
                    if (totalNonSpanish > 0) summary.Add($"{totalNonSpanish} no-es");
                    if (totalCarbarherDuplicates > 0) summary.Add($"{totalCarbarherDuplicates} cbh");
                    if (totalAlreadyDownloaded > 0) summary.Add($"{totalAlreadyDownloaded} ya descargados");
                    if (totalUsersWithoutSlots > 0) summary.Add($"{totalUsersWithoutSlots} usuarios sin slots");
                    
                    if (summary.Count > 0)
                        LogDownload($"   Filtrados: {string.Join(", ", summary)}");
                    
                    if (totalAlreadyDownloaded > 0)
                        LogDownload($"   💾 {totalAlreadyDownloaded} archivos marcados como duplicados (ya descargados)");
                    
                    LogDownload("════════════════════════════════════");
                    
                    // Limpiar caché de archivos antes de actualizar grilla
                    ClearFileCache();
                    loadData("");

                    currentAuthorIndex++;
                    
                    if (currentAuthorIndex < authorsList.Count)
                    {
                        btnNextAuthor.Text = $"🔄 Actualizar ({currentAuthorIndex + 1}/{authorsList.Count})";
                        LogDownload("═══════════════════════════════════════════════════");
                        
                        // Continuar automáticamente con el siguiente autor
                        await Task.Delay(100); // Pequeña pausa para que se vea el log
                        btnNextAuthor.PerformClick();
                    }
                    else
                    {
                        btnNextAuthor.Text = "✅ Completado";
                        btnNextAuthor.Enabled = false;
                        LogDownload("═══════════════════════════════════════════════════");
                        LogDownload("🎉 TODOS LOS AUTORES PROCESADOS");
                        
                        // Notificación de finalización
                        ShowNotification("Búsqueda Completada", 
                            $"Se procesaron {authorsList.Count} autores. Total archivos: {totalNewFiles}", 
                            ToolTipIcon.Info);
                    }
                }
                catch (Exception ex)
                {
                    LogDownload($"❌ ERROR: {ex.Message}");
                    DarkMessageBox.Show($"Error al buscar autor: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            };

            // Event handler para cargar autores
            btnLoadAuthors.Click += async (s, e) => await LoadAuthorsListAsync();

            // Event handlers para selección
            btnSelectAll.Click += (s, e) =>
            {
                Log("☑️ [Vaciar] Botón 'Seleccionar Todo' pulsado");
                lvVaciarAuthors.BeginUpdate();
                foreach (ListViewItem item in lvVaciarAuthors.Items)
                {
                    item.Checked = true;
                }
                lvVaciarAuthors.EndUpdate();
                
                int totalCount = lvVaciarAuthors.Items.Count;
                LogDownload($"☑️ Seleccionados todos los autores ({totalCount:N0})");
            };

            btnDeselectAll.Click += (s, e) =>
            {
                Log("☐ [Vaciar] Botón 'Deseleccionar Todo' pulsado");
                lvVaciarAuthors.BeginUpdate();
                foreach (ListViewItem item in lvVaciarAuthors.Items)
                {
                    item.Checked = false;
                }
                lvVaciarAuthors.EndUpdate();
                
                LogDownload($"☐ Deseleccionados todos los autores");
            };

            // Event handlers para otros botones
            btnDownloadSelected.Click += async (s, e) =>
            {
                Log("⬇️ [Vaciar] Botón 'Descargar' pulsado");
                var selectedAuthors = lvVaciarAuthors.CheckedItems.Cast<ListViewItem>().ToList();

                if (selectedAuthors.Count == 0)
                {
                    Log("⚠️ [Vaciar] No hay autores seleccionados");
                    MessageBox.Show("No hay autores seleccionados.\n\nMarca los autores que deseas descargar.", "Sin selección", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    return;
                }

                var downloadPath = txtDownloadDir?.Text ?? Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments), "SlskDown");
                int totalFiles = 0;
                int skippedDuplicates = 0;
                
                // PASO 1: Recopilar SOLO los archivos FILTRADOS de los autores seleccionados
                // (solo autores visibles en la grilla después de aplicar filtros)
                List<AutoSearchFileResult> allFilesFromAllAuthors = new List<AutoSearchFileResult>();
                
                // Obtener lista de autores visibles en la grilla (después de filtros)
                HashSet<string> visibleAuthors = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                SafeInvoke(() =>
                {
                    foreach (ListViewItem item in lvVaciarAuthors.Items)
                    {
                        var authorData = (AuthorData)item.Tag;
                        visibleAuthors.Add(authorData.Name);
                    }
                });
                
                Log($"📋 [Vaciar] Autores visibles después de filtros: {visibleAuthors.Count}");
                
                foreach (var authorItem in selectedAuthors)
                {
                    var authorData = (AuthorData)authorItem.Tag;
                    
                    // Solo procesar si el autor está visible (no filtrado)
                    if (!visibleAuthors.Contains(authorData.Name))
                    {
                        Log($"⏭️ [Vaciar] Autor '{authorData.Name}' omitido (filtrado)");
                        continue;
                    }
                    
                    lock (autoSearchResultsLock)
                    {
                        var authorFiles = autoSearchResults.Where(f => f.Author.Equals(authorData.Name, StringComparison.OrdinalIgnoreCase)).ToList();
                        allFilesFromAllAuthors.AddRange(authorFiles);
                    }
                }
                
                Log($"📦 [Vaciar] Total de archivos recopilados de {selectedAuthors.Count} autores: {allFilesFromAllAuthors.Count}");
                
                // PASO 2: Deduplicar GLOBALMENTE (entre todos los autores)
                List<AutoSearchFileResult> uniqueFiles;
                if (SlskNativeInterop.IsAvailable && allFilesFromAllAuthors.Count > 100)
                {
                    Log($"🦀 [Rust] Deduplicando {allFilesFromAllAuthors.Count} archivos globalmente con Rust...");
                    var sw = System.Diagnostics.Stopwatch.StartNew();
                    uniqueFiles = SlskNativeInterop.DeduplicateFiles(
                        allFilesFromAllAuthors,
                        f => f.FileName,
                        f => f.Username,
                        f => f.SizeBytes,
                        username => (int)GetProviderScore(username)
                    );
                    sw.Stop();
                    Log($"✅ [Rust] Deduplicación completada en {sw.ElapsedMilliseconds}ms ({allFilesFromAllAuthors.Count} → {uniqueFiles.Count} únicos)");
                }
                else
                {
                    var reason = !SlskNativeInterop.IsAvailable ? "Rust no disponible" : $"Lista pequeña ({allFilesFromAllAuthors.Count} archivos)";
                    Log($"⚙️ [C#] Deduplicando globalmente con LINQ ({reason})");
                    uniqueFiles = allFilesFromAllAuthors
                        .GroupBy(f => f.FileName, StringComparer.OrdinalIgnoreCase)
                        .Select(g => g.OrderByDescending(f => GetProviderScore(f.Username)).First())
                        .ToList();
                    Log($"✅ [C#] Deduplicación completada ({allFilesFromAllAuthors.Count} → {uniqueFiles.Count} únicos)");
                }
                
                // PASO 3: Agregar archivos únicos a la cola de descargas
                foreach (var file in uniqueFiles)
                {
                    var localPath = GetDownloadPath(downloadPath, file.FileName, file.Author);
                    
                    // Verificar duplicados por hash antes de agregar
                    if (await ShouldSkipDownloadDuplicate(file))
                    {
                        skippedDuplicates++;
                        continue;
                    }
                    
                    // Solo agregar si no está ya descargado
                    if (!System.IO.File.Exists(localPath))
                    {
                        // Crear ListViewItem para la grilla de descargas
                        ListViewItem downloadItem = null;
                        SafeInvoke(() =>
                        {
                            downloadItem = new ListViewItem(file.FileName);
                            // Agregar indicador premium al username
                            string usernameDisplay = premiumUsers.Contains(file.Username) ? $"⭐ {file.Username}" : file.Username;
                            downloadItem.SubItems.Add(usernameDisplay);
                            downloadItem.SubItems.Add("0%");
                            downloadItem.SubItems.Add("⏳ En cola");
                            downloadItem.SubItems.Add(file.SizeReadable);
                            downloadItem.SubItems.Add(GetMetadataStatusSync(file.FileName));
                            downloadItem.ForeColor = Color.LightGray;
                            lvDownloads.Items.Add(downloadItem);
                        });
                        
                        AddToDownloadQueue(file, localPath, downloadItem, false);
                        totalFiles++;
                    }
                }

                // Log detallado por autor
                Log($"📊 [Vaciar] Desglose por autor:");
                foreach (ListViewItem authorItem in lvVaciarAuthors.CheckedItems)
                {
                    var authorData = (AuthorData)authorItem.Tag;
                    int authorFileCount = 0;
                    lock (autoSearchResultsLock)
                    {
                        authorFileCount = autoSearchResults.Count(f => f.Author.Equals(authorData.Name, StringComparison.OrdinalIgnoreCase));
                    }
                    Log($"   • {authorData.Name}: {authorFileCount} archivos");
                }
                
                var message = $"{totalFiles} archivos agregados a la cola de descargas\n\nAutores: {selectedAuthors.Count}";
                if (skippedDuplicates > 0)
                {
                    message += $"\n⚠️ Duplicados omitidos: {skippedDuplicates}";
                }
                
                Log($"✅ [Vaciar] TOTAL: {totalFiles} archivos agregados, {skippedDuplicates} duplicados omitidos");
                LogDownload($"✅ {totalFiles} archivos agregados, {skippedDuplicates} duplicados omitidos");
                MessageBox.Show(message, "Descarga iniciada", MessageBoxButtons.OK, MessageBoxIcon.Information);
                
                // Cambiar a pestaña de descargas para ver el progreso
                if (totalFiles > 0)
                {
                    SafeInvoke(() => tabControl.SelectedIndex = 1);
                }
            };

            btnOpenFolder.Click += (s, e) =>
            {
                Log("📂 [Vaciar] Botón 'Abrir Carpeta' pulsado");
                var downloadPath = txtDownloadDir?.Text ?? Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments), "SlskDown");
                if (System.IO.Directory.Exists(downloadPath))
                {
                    Process.Start("explorer.exe", downloadPath);
                    LogDownload($"📂 Abriendo carpeta: {downloadPath}");
                }
            };

            btnRedownload.Click += async (s, e) =>
            {
                Log("🔄 [Vaciar] Botón 'Redescargar' pulsado");
                
                var selectedAuthors = lvVaciarAuthors.CheckedItems.Cast<ListViewItem>().ToList();
                if (selectedAuthors.Count == 0)
                {
                    LogDownload("⚠️ No hay autores seleccionados para redescargar");
                    MessageBox.Show("Marca los autores cuyas descargas deseas redescargar.", "Sin selección", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    return;
                }
                
                var result = MessageBox.Show(
                    $"¿Redescargar archivos de {selectedAuthors.Count} autor(es)?\n\nEsto volverá a descargar TODOS los archivos, incluso los ya descargados.",
                    "Confirmar redescargar",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Question
                );
                
                if (result == DialogResult.Yes)
                {
                    LogDownload("════════════════════════════════════");
                    LogDownload("🔄 REDESCARGANDO ARCHIVOS");
                    LogDownload("════════════════════════════════════");
                    
                    var downloadPath = txtDownloadDir?.Text ?? Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments), "SlskDown");
                    int totalFiles = 0;
                    
                    foreach (var authorItem in selectedAuthors)
                    {
                        var authorData = (AuthorData)authorItem.Tag;
                        List<AutoSearchFileResult> files;
                        
                        lock (autoSearchResultsLock)
                        {
                            files = autoSearchResults.Where(f => f.Author.Equals(authorData.Name, StringComparison.OrdinalIgnoreCase)).ToList();
                        }
                        
                        LogDownload($"📚 Autor: {authorData.Name} ({files.Count} archivos)");
                        
                        foreach (var file in files)
                        {
                            var localPath = GetDownloadPath(downloadPath, file.FileName, authorData.Name);
                            
                            // Eliminar archivo existente si existe
                            if (System.IO.File.Exists(localPath))
                            {
                                try
                                {
                                    System.IO.File.Delete(localPath);
                                    LogDownload($"  🗑️ Eliminado: {file.FileName}");
                                }
                                catch (Exception ex)
                                {
                                    LogDownload($"  ❌ Error eliminando {file.FileName}: {ex.Message}");
                                    continue;
                                }
                            }
                            
                            // Crear ListViewItem para la grilla de descargas
                            ListViewItem downloadItem = null;
                            SafeInvoke(() =>
                            {
                                downloadItem = new ListViewItem(file.FileName);
                                // Agregar indicador premium al username
                                string usernameDisplay = premiumUsers.Contains(file.Username) ? $"⭐ {file.Username}" : file.Username;
                                downloadItem.SubItems.Add(usernameDisplay);
                                downloadItem.SubItems.Add("0%");
                                downloadItem.SubItems.Add("🔄 Recomenzando");
                                downloadItem.SubItems.Add(file.SizeReadable);
                                downloadItem.SubItems.Add(GetMetadataStatusSync(file.FileName));
                                downloadItem.ForeColor = Color.Orange;
                                lvDownloads.Items.Add(downloadItem);
                            });
                            
                            AddToDownloadQueue(file, localPath, downloadItem, true);
                            totalFiles++;
                            await Task.Delay(10); // Pequeña pausa para no saturar
                        }
                    }
                    
                    Log($"🔄 [Vaciar] {totalFiles} archivos de {selectedAuthors.Count} autores recomenzados");
                    LogDownload($"✅ {totalFiles} archivos agregados a la cola para recomenzar");
                    MessageBox.Show($"{totalFiles} archivos agregados a la cola\n\nAutores: {selectedAuthors.Count}", "Descargas recomenzadas", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    
                    // Cambiar a pestaña de descargas para ver el progreso
                    if (totalFiles > 0)
                    {
                        SafeInvoke(() => tabControl.SelectedIndex = 1);
                    }
                }
            };

            btnStopDownload.Click += (s, e) =>
            {
                Log("⏸️ [Vaciar] Botón 'Detener' pulsado");
                
                var result = MessageBox.Show(
                    "¿Pausar todas las descargas en curso?",
                    "Confirmar pausa",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Question
                );
                
                if (result == DialogResult.Yes)
                {
                    PauseAllDownloads();
                    LogDownload("⏸️ Todas las descargas pausadas");
                    Log("⏸️ [Vaciar] Todas las descargas pausadas");
                }
            };

            btnResumeDownload.Click += (s, e) =>
            {
                Log("▶️ [Vaciar] Botón 'Continuar' pulsado");
                
                ResumeAllDownloads();
                LogDownload("▶️ Descargas reanudadas");
                Log("▶️ [Vaciar] Descargas reanudadas");

                if (downloadManager != null)
                {
                    downloadManager.Start();
                    LogDownload($"📈 Gestor activo: {(downloadManager.IsRunning ? "SÍ ✅" : "NO ❌")}");
                }
                else
                {
                    LogDownload("⚠️ Gestor no disponible, ejecutando descargas en modo legacy");
                }
            };
            
            // BOTÓN DE DIAGNÓSTICO: Forzar procesamiento de cola
            var btnForceQueue = new Button
            {
                Text = "🔧 Forzar Cola",
                Size = new Size(120, 30),
                BackColor = Color.FromArgb(255, 140, 0),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 9, FontStyle.Bold),
                Cursor = Cursors.Hand
            };
            btnForceQueue.FlatAppearance.BorderSize = 0;
            btnForceQueue.Click += async (s, e) =>
            {
                Log("🔧 [Diagnóstico] Forzando procesamiento de cola");
                
                // MEJORA FASE 1.3: ReadLock para Count
                (int pending, int downloading, int paused, int failed, int completed) = 
                    ReadLocked(downloadQueueLock, () =>
                    (
                        downloadQueue.Count(t => t.Status == DownloadStatus.Queued),
                        downloadQueue.Count(t => t.Status == DownloadStatus.Downloading),
                        downloadQueue.Count(t => t.Status == DownloadStatus.Paused),
                        downloadQueue.Count(t => t.Status == DownloadStatus.Failed),
                        downloadQueue.Count(t => t.Status == DownloadStatus.Completed)
                    ));
                
                LogDownload("═══════════════════════════════════════════════════");
                LogDownload("🔧 DIAGNÓSTICO DE COLA DE DESCARGAS");
                LogDownload("═══════════════════════════════════════════════════");
                LogDownload($"📊 Estado de la cola:");
                LogDownload($"   ⏳ Pendientes: {pending}");
                LogDownload($"   ⬇️ Descargando: {downloading}");
                LogDownload($"   ⏸️ Pausadas: {paused}");
                LogDownload($"   ❌ Fallidas: {failed}");
                LogDownload($"   ✅ Completadas: {completed}");
                bool managerRunning = downloadManager?.IsRunning ?? false;
                LogDownload($"📈 Gestor activo: {(managerRunning ? "SÍ ✅" : "NO ❌")}");
                LogDownload($"🔢 Límite simultáneas: {maxSimultaneousDownloads}");
                LogDownload($"🎯 Slots disponibles: {maxSimultaneousDownloads - downloading}");
                
                // Forzar reinicio del gestor
                if (!managerRunning && downloadManager != null)
                {
                    LogDownload("🔄 Reiniciando gestor de descargas...");
                    downloadManager.Start();
                    await Task.Delay(500);
                    managerRunning = true;
                }
                
                // Forzar procesamiento de tareas pendientes
                if (pending > 0)
                {
                    LogDownload($"🚀 Forzando procesamiento de {Math.Min(pending, maxSimultaneousDownloads - downloading)} tareas...");
                    
                    // MEJORA FASE 1.3: ReadLock para snapshot de solo lectura
                    var tasksToForce = ReadLocked(downloadQueueLock, () =>
                        downloadQueue
                            .Where(t => t.Status == DownloadStatus.Queued)
                            .Take(maxSimultaneousDownloads - downloading)
                            .ToArray());
                    
                    foreach (var task in tasksToForce)
                    {
                        LogDownload($"   ▶️ Iniciando: {task.File.FileName}");
                        // MEJORA #26: Eliminar Task.Run redundante
                        _ = ProcessDownload(task);
                    }
                }
                
                LogDownload("✅ Diagnóstico completado");
                LogDownload("═══════════════════════════════════════════════════");
            };
            topLeftPanel.Controls.Add(btnForceQueue);
            
            SafeLog( "CreateVaciarTab: Agregando mainLayout al parent\n");
            parent.Controls.Add(mainLayout);
            SafeLog( "CreateVaciarTab: Completado\n");
        }
        
        // FIN CreateVaciarTab (deprecated)
        
        private void CreateAutomTab(TabPage parent)
        {
            // FORZAR LIMPIEZA: eliminar todos los controles existentes
            parent.Controls.Clear();
            parent.SuspendLayout();
            
            // Reutilizar la pestaña unificada con toda la funcionalidad (Purga/Descarga, log, filtros, persistencia)
            CreateAuthorManagementTab(parent);
            
            parent.ResumeLayout(true);
            parent.PerformLayout();
        }
        
        private void CreateWishlistTab(TabPage parent)
        {
            parent.BackColor = Color.FromArgb(18, 18, 18);
            var mainPanel = new Panel { Dock = DockStyle.Fill, Padding = new Padding(10), BackColor = Color.FromArgb(18, 18, 18) };
            
            // Panel superior con controles
            var topPanel = new FlowLayoutPanel
            {
                Dock = DockStyle.Top,
                Height = 80,
                BackColor = Color.FromArgb(30, 30, 30),
                Padding = new Padding(10),
                FlowDirection = FlowDirection.LeftToRight
            };
            
            // Botón Agregar
            var btnAdd = new Button
            {
                Text = "➕ Agregar",
                Size = new Size(120, 35),
                BackColor = Color.FromArgb(0, 150, 0),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 9, FontStyle.Bold),
                Cursor = Cursors.Hand
            };
            btnAdd.FlatAppearance.BorderSize = 0;
            btnAdd.Click += (s, e) => AddToWishlist();
            
            // Botón Eliminar
            var btnRemove = new Button
            {
                Text = "🗑️ Eliminar",
                Size = new Size(120, 35),
                BackColor = Color.FromArgb(180, 50, 50),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 9, FontStyle.Bold),
                Cursor = Cursors.Hand
            };
            btnRemove.FlatAppearance.BorderSize = 0;
            btnRemove.Click += (s, e) => RemoveFromWishlist();
            
            // Botón Buscar Ahora
            var btnSearchNow = new Button
            {
                Text = "🔍 Buscar Ahora",
                Size = new Size(140, 35),
                BackColor = Color.FromArgb(0, 120, 215),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 9, FontStyle.Bold),
                Cursor = Cursors.Hand
            };
            btnSearchNow.FlatAppearance.BorderSize = 0;
            btnSearchNow.Click += async (s, e) => await SearchWishlistItems();
            
            // Checkbox Auto-búsqueda
            var chkAutoSearch = new CheckBox
            {
                Text = "🔄 Búsqueda automática",
                Checked = wishlistAutoSearchEnabled,
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9, FontStyle.Bold),
                AutoSize = true,
                Margin = new Padding(10, 10, 0, 0)
            };
            chkAutoSearch.CheckedChanged += (s, e) =>
            {
                wishlistAutoSearchEnabled = chkAutoSearch.Checked;
                if (wishlistAutoSearchEnabled)
                {
                    StartWishlistTimer();
                    Log("✅ Búsqueda automática de wishlist activada");
                }
                else
                {
                    StopWishlistTimer();
                    Log("⏸️ Búsqueda automática de wishlist desactivada");
                }
            };
            
            // TextBox de búsqueda incremental
            var txtWishlistSearch = new TextBox
            {
                Size = new Size(200, 25),
                BackColor = Color.FromArgb(50, 50, 50),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                PlaceholderText = "🔍 Filtrar...",
                Margin = new Padding(10, 5, 0, 0)
            };
            
            topPanel.Controls.Add(btnAdd);
            topPanel.Controls.Add(btnRemove);
            topPanel.Controls.Add(btnSearchNow);
            topPanel.Controls.Add(chkAutoSearch);
            topPanel.Controls.Add(txtWishlistSearch);
            
            // ListView para mostrar items de wishlist
            var lvWishlist = new ListView
            {
                Dock = DockStyle.Fill,
                View = View.Details,
                FullRowSelect = true,
                GridLines = true,
                VirtualMode = false,
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                BorderStyle = BorderStyle.None
            };
            
            lvWishlist.Columns.Add("Término de Búsqueda", 250);
            lvWishlist.Columns.Add("Autor", 150);
            lvWishlist.Columns.Add("Agregado", 120);
            lvWishlist.Columns.Add("Última Búsqueda", 120);
            lvWishlist.Columns.Add("Encontrados", 80);
            lvWishlist.Columns.Add("Auto", 60);
            lvWishlist.Columns.Add("Notas", 200);
            
            // Cargar wishlist
            LoadWishlist();
            RefreshWishlistUI(lvWishlist, "");
            
            // Búsqueda incremental
            txtWishlistSearch.TextChanged += (s, e) =>
            {
                RefreshWishlistUI(lvWishlist, txtWishlistSearch.Text);
            };
            
            // Guardar referencia al ListView
            lvWishlist.Tag = "wishlistView";
            
            mainPanel.Controls.Add(lvWishlist);
            mainPanel.Controls.Add(topPanel);
            parent.Controls.Add(mainPanel);
            
            // Iniciar timer si está habilitado
            if (wishlistAutoSearchEnabled)
            {
                StartWishlistTimer();
            }
        }

        private void CreateSeriesTab(TabPage parent)
        {
            parent.BackColor = Color.FromArgb(18, 18, 18);
            
            var mainLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 1,
                RowCount = 3,
                Padding = new Padding(10),
                BackColor = Color.FromArgb(18, 18, 18)
            };
            mainLayout.RowStyles.Add(new RowStyle(SizeType.Absolute, 60)); // Botones
            mainLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100)); // Lista de series
            mainLayout.RowStyles.Add(new RowStyle(SizeType.Absolute, 150)); // Log
            
            // Panel de botones
            var btnPanel = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                FlowDirection = FlowDirection.LeftToRight,
                BackColor = Color.FromArgb(30, 30, 30),
                Padding = new Padding(5)
            };
            
            var btnScanLibrary = CreateButton("🔍 Escanear Biblioteca", Color.FromArgb(0, 120, 215));
            var btnSearchMissing = CreateButton("🔎 Buscar Faltantes", Color.FromArgb(0, 150, 0));
            var btnRefresh = CreateButton("🔄 Actualizar", Color.FromArgb(100, 100, 100));
            var btnExport = CreateButton("💾 Exportar", Color.FromArgb(150, 100, 0));
            
            btnPanel.Controls.Add(btnScanLibrary);
            btnPanel.Controls.Add(btnSearchMissing);
            btnPanel.Controls.Add(btnRefresh);
            btnPanel.Controls.Add(btnExport);
            
            mainLayout.Controls.Add(btnPanel, 0, 0);
            
            // ListView para mostrar series
            var lvSeries = new ListView
            {
                Dock = DockStyle.Fill,
                View = View.Details,
                FullRowSelect = true,
                GridLines = true,
                VirtualMode = false,
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                BorderStyle = BorderStyle.None,
                CheckBoxes = true
            };
            
            lvSeries.Columns.Add("Serie", 300);
            lvSeries.Columns.Add("Autor", 150);
            lvSeries.Columns.Add("Progreso", 100);
            lvSeries.Columns.Add("Faltantes", 80);
            lvSeries.Columns.Add("Estado", 100);
            
            mainLayout.Controls.Add(lvSeries, 0, 1);
            
            // TextBox de log
            var txtSeriesLog = new TextBox
            {
                Dock = DockStyle.Fill,
                Multiline = true,
                ReadOnly = true,
                BackColor = Color.FromArgb(20, 20, 20),
                ForeColor = Color.LightGray,
                Font = new Font("Consolas", 9),
                BorderStyle = BorderStyle.None,
                ScrollBars = ScrollBars.Vertical
            };
            
            mainLayout.Controls.Add(txtSeriesLog, 0, 2);
            
            // Helper para log
            void LogSeries(string message)
            {
                SafeInvoke(() =>
                {
                    txtSeriesLog.AppendText($"[{DateTime.Now:HH:mm:ss}] {message}\r\n");
                    txtSeriesLog.SelectionStart = txtSeriesLog.Text.Length;
                    txtSeriesLog.ScrollToCaret();
                });
            }
            
            // Evento: Escanear biblioteca
            btnScanLibrary.Click += async (s, e) =>
            {
                try
                {
                    btnScanLibrary.Enabled = false;
                    LogSeries("🔍 Escaneando biblioteca...");
                    
                    // Obtener todos los archivos descargados
                    var downloadedFiles = new List<string>();
                    
                    // MEJORA NICOTINE+: Usar DirectoryExistsCached
                    if (DirectoryExistsCached(downloadDir))
                    {
                        var files = System.IO.Directory.GetFiles(downloadDir, "*.*", SearchOption.AllDirectories)
                            .Where(f => f.EndsWith(".epub", StringComparison.OrdinalIgnoreCase) ||
                                       f.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) ||
                                       f.EndsWith(".mobi", StringComparison.OrdinalIgnoreCase))
                            .Select(f => Path.GetFileName(f))
                            .ToList();
                        
                        downloadedFiles.AddRange(files);
                    }
                    
                    LogSeries($"📚 Encontrados {downloadedFiles.Count} libros");
                    
                    // Detectar series
                    var seriesList = SeriesDetector.DetectSeries(downloadedFiles);
                    
                    LogSeries($"📊 Detectadas {seriesList.Count} series");
                    
                    // Actualizar ListView
                    lvSeries.Items.Clear();
                    
                    foreach (var series in seriesList)
                    {
                        var item = new ListViewItem(series.SeriesName);
                        item.SubItems.Add(series.Author);
                        item.SubItems.Add($"{series.DownloadedBooks}/{series.TotalBooks} ({series.CompletionPercentage:F0}%)");
                        item.SubItems.Add(series.MissingNumbers.Count.ToString());
                        item.SubItems.Add(series.IsComplete ? "✅ Completa" : "⚠️ Incompleta");
                        item.Tag = series;
                        
                        // Marcar incompletas con color de advertencia
                        if (!series.IsComplete)
                        {
                            item.ForeColor = UIColors.HealthWarning;
                        }
                        
                        lvSeries.Items.Add(item);
                    }
                    
                    LogSeries($"✅ Escaneo completado");
                    
                    // Mostrar resumen
                    var incomplete = seriesList.Count(s => !s.IsComplete);
                    if (incomplete > 0)
                    {
                        LogSeries($"⚠️ {incomplete} series incompletas encontradas");
                    }
                }
                catch (Exception ex)
                {
                    LogSeries($"❌ Error: {ex.Message}");
                }
                finally
                {
                    btnScanLibrary.Enabled = true;
                }
            };
            
            // Evento: Buscar faltantes
            btnSearchMissing.Click += async (s, e) =>
            {
                try
                {
                    var checkedSeries = lvSeries.CheckedItems.Cast<ListViewItem>()
                        .Select(i => i.Tag as SeriesDetector.SeriesInfo)
                        .Where(s => s != null && !s.IsComplete)
                        .ToList();
                    
                    if (checkedSeries.Count == 0)
                    {
                        LogSeries("⚠️ Selecciona series incompletas para buscar");
                        return;
                    }
                    
                    btnSearchMissing.Enabled = false;
                    LogSeries($"🔎 Buscando libros faltantes de {checkedSeries.Count} series...");
                    
                    foreach (var series in checkedSeries)
                    {
                        LogSeries($"📖 Serie: {series.SeriesName} - Faltan: {string.Join(", ", series.MissingNumbers)}");
                        
                        var searchTerms = SeriesDetector.GenerateSearchTerms(series);
                        
                        foreach (var term in searchTerms.Take(3)) // Limitar a 3 búsquedas por serie
                        {
                            LogSeries($"   🔍 Buscando: {term}");
                            
                            // Agregar a la cola de búsqueda
                            // SafeInvoke(() =>
                            // {
                            //     if (txtSearch != null)
                            //     {
                            //         txtSearch.Text = term;
                            //     }
                            // });
                            
                            await Task.Delay(500); // Pequeña pausa entre búsquedas
                        }
                    }
                    
                    LogSeries($"✅ Búsqueda completada");
                }
                catch (Exception ex)
                {
                    LogSeries($"❌ Error: {ex.Message}");
                }
                finally
                {
                    btnSearchMissing.Enabled = true;
                }
            };
            
            // Evento: Actualizar
            btnRefresh.Click += (s, e) =>
            {
                btnScanLibrary.PerformClick();
            };
            
            // Evento: Exportar
            btnExport.Click += (s, e) =>
            {
                try
                {
                    var seriesList = lvSeries.Items.Cast<ListViewItem>()
                        .Select(i => i.Tag as SeriesDetector.SeriesInfo)
                        .Where(s => s != null)
                        .ToList();
                    
                    if (seriesList.Count == 0)
                    {
                        LogSeries("⚠️ No hay series para exportar");
                        return;
                    }
                    
                    var exportPath = Path.Combine(dataDir, "series_report.txt");
                    var lines = new List<string>();
                    
                    lines.Add("═══════════════════════════════════════════════════════");
                    lines.Add($"REPORTE DE SERIES - {DateTime.Now:dd/MM/yyyy HH:mm}");
                    lines.Add("═══════════════════════════════════════════════════════");
                    lines.Add("");
                    
                    foreach (var series in seriesList.OrderBy(s => s.Author).ThenBy(s => s.SeriesName))
                    {
                        lines.Add(SeriesDetector.FormatSeriesInfo(series));
                        
                        if (!series.IsComplete)
                        {
                            lines.Add($"  → Términos de búsqueda:");
                            var terms = SeriesDetector.GenerateSearchTerms(series);
                            foreach (var term in terms.Take(3))
                            {
                                lines.Add($"     • {term}");
                            }
                        }
                        
                        lines.Add("");
                    }
                    
                    System.IO.File.WriteAllLines(exportPath, lines);
                    LogSeries($"💾 Reporte exportado: {exportPath}");
                    
                    System.Diagnostics.Process.Start("notepad.exe", exportPath);
                }
                catch (Exception ex)
                {
                    LogSeries($"❌ Error exportando: {ex.Message}");
                }
            };
            
            parent.Controls.Add(mainLayout);
            
            LogSeries("📚 Pestaña de Series lista");
            LogSeries("💡 Haz clic en 'Escanear Biblioteca' para comenzar");
        }

        private async Task StartDownloadManager()
        {
            if (downloadManagerRunning) return;
            
            downloadManagerRunning = true;
            int saveCounter = 0;
            
            while (downloadManagerRunning)
            {
                DownloadTask[] tasksToProcess;
                DownloadTask[] stuckTasks;
                DownloadTask[] failedTasksToRetry;
                DownloadTask[] candidateFailed;
                List<DownloadTask> oldFailures;
                
                // MEJORA FASE 1.3: ReadLock para clasificación, WriteLock para Remove
                (int activeDownloads, List<DownloadTask> pendingList, List<DownloadTask> stuckList, 
                 List<DownloadTask> oldFailuresList, List<DownloadTask> candidateFailedList) = 
                    ReadLocked(downloadQueueLock, () =>
                {
                    int activeDownloads = 0;
                    var pendingList = new List<DownloadTask>(32);
                    var stuckList = new List<DownloadTask>(8);
                    var oldFailuresList = new List<DownloadTask>(8);
                    var candidateFailedList = new List<DownloadTask>(16);
                    var now = DateTime.Now;
                    
                    // Una sola iteración para clasificar todas las tareas
                    foreach (var task in downloadQueue)
                    {
                        switch (task.Status)
                        {
                            case DownloadStatus.Downloading:
                                activeDownloads++;
                                // Detectar atascadas (>60s en 0%)
                                if (task.ProgressPercent == 0 && task.StartTime.HasValue && (now - task.StartTime.Value).TotalSeconds > 60)
                                    stuckList.Add(task);
                                break;
                                
                            case DownloadStatus.Queued:
                                pendingList.Add(task);
                                break;
                                
                            case DownloadStatus.Failed:
                                // Auto-limpieza de fallidos antiguos (>7 días)
                                if (!task.AutoRetryEnabled && task.FinalFailureTime.HasValue &&
                                    (now - task.FinalFailureTime.Value).TotalDays > 7)
                                {
                                    oldFailuresList.Add(task);
                                }
                                // Candidatos para reintentar
                                else if (task.AutoRetryEnabled && task.RetryCount < task.MaxRetries)
                                {
                                    candidateFailedList.Add(task);
                                }
                                break;
                        }
                    }
                    
                    return (activeDownloads, pendingList, stuckList, oldFailuresList, candidateFailedList);
                });
                
                // Limpiar fallidos antiguos con WriteLock
                oldFailures = oldFailuresList;
                foreach (var task in oldFailures)
                {
                    WriteLocked(downloadQueueLock, () => downloadQueue.Remove(task));
                }
                
                // Ordenar pendientes por tiempo de inicio
                pendingList.Sort((a, b) => Nullable.Compare(a.StartTime, b.StartTime));
                
                var slotsAvailable = maxSimultaneousDownloads - activeDownloads;
                tasksToProcess = pendingList.Take(slotsAvailable).ToArray();
                stuckTasks = stuckList.ToArray();
                
                // Ya tenemos candidateFailedList de la iteración anterior
                candidateFailed = candidateFailedList.ToArray();
                
                // Filtrar fallidas FUERA del lock principal
                failedTasksToRetry = candidateFailed.Where(t =>
                    {
                        // Verificar límite global de intentos
                        string fileKey = $"{t.File.FileName}_{t.File.Username}";
                        if (downloadRetryCount.TryGetValue(fileKey, out int attempts) && attempts >= MAX_TOTAL_ATTEMPTS)
                        {
                            t.AutoRetryEnabled = false;
                            t.FinalFailureTime = DateTime.Now;
                            return false;
                        }
                        
                        // MEJORA #4: Aplicar backoff exponencial inteligente con jitter
                        if (t.LastRetryTime.HasValue)
                        {
                            int retryDelay = GetRetryDelay(t.RetryCount, t.ErrorMessage);
                            if ((DateTime.Now - t.LastRetryTime.Value).TotalSeconds <= retryDelay)
                            {
                                return false;
                            }
                        }
                        
                        // MEJORA #4: No reintentar errores no recuperables
                        if (!string.IsNullOrEmpty(t.ErrorMessage) && !IsRecoverableError(t.ErrorMessage))
                        {
                            AutoLog($"⛔ Error no recuperable para {t.File.FileName}: {t.ErrorMessage}");
                            return false;
                        }
                        
                        // Verificar si el proveedor está en blacklist temporal
                        bool isBlacklisted = false;
                        if (providerBlacklist.TryGetValue(t.File.Username, out var data))
                        {
                            isBlacklisted = data.failures >= PROVIDER_BLACKLIST_THRESHOLD && 
                                (DateTime.Now - data.lastFail).TotalHours < PROVIDER_BLACKLIST_HOURS;
                        }
                        
                        if (isBlacklisted)
                        {
                            // Proveedor en blacklist, buscar alternativa en lugar de reintentar
                            // TODO: Descomentar cuando se corrija API
                            // if (t.RetryCount == 0) // Solo buscar alternativa una vez
                            // {
                            //     _ = Task.Run(async () => await TryFindAlternativeProvider(t));
                            // }
                            return false;
                        }
                        
                        return true;
                    })
                    .OrderBy(t => t.File.SizeBytes) // Pequeños primero
                    .ToArray();
                
                // Log fuera del lock
                foreach (var task in oldFailures)
                {
                    AutoLog($"🗑️ Limpiado fallo antiguo (>7 días): {task.File.FileName}");
                }
                
                // Cancelar descargas atascadas y marcar para reintento
                foreach (var stuckTask in stuckTasks)
                {
                    AutoLog($"⚠️ Descarga atascada detectada: {stuckTask.File.FileName}");
                    stuckTask.CancellationToken?.Cancel();
                    stuckTask.Status = DownloadStatus.Failed;
                    stuckTask.ErrorMessage = "Timeout: Sin progreso en 60 segundos";
                    stuckTask.RetryCount++;
                    stuckTask.LastRetryTime = DateTime.Now;
                    
                    if (stuckTask.RetryCount < stuckTask.MaxRetries)
                    {
                        UpdateDownloadUI(stuckTask, $"🔄 Reintentando ({stuckTask.RetryCount}/{stuckTask.MaxRetries})...");
                        AutoLog($"🔄 Reintento automático {stuckTask.RetryCount}/{stuckTask.MaxRetries}: {stuckTask.File.FileName}");
                    }
                    else
                    {
                        UpdateDownloadUI(stuckTask, "❌ Timeout (máx. reintentos)");
                        AutoLog($"❌ Máximo de reintentos alcanzado: {stuckTask.File.FileName}");
                        // Buscar proveedor alternativo
                        // TODO: Descomentar cuando se corrija API
                        // _ = Task.Run(async () => await TryFindAlternativeProvider(stuckTask));
                    }
                }
                
                // Reintentar descargas fallidas automáticamente
                foreach (var failedTask in failedTasksToRetry)
                {
                    failedTask.Status = DownloadStatus.Queued;
                    failedTask.RetryCount++;
                    failedTask.LastRetryTime = DateTime.Now;
                    failedTask.BytesDownloaded = 0;
                    failedTask.ProgressPercent = 0;
                    
                    UpdateDownloadUI(failedTask, $"🔄 Reintento {failedTask.RetryCount}/{failedTask.MaxRetries}...");
                    AutoLog($"🔄 Reintento automático {failedTask.RetryCount}/{failedTask.MaxRetries}: {failedTask.File.FileName}");
                }

                // MEJORA: Agregar delay entre descargas para evitar saturación
                foreach (var task in tasksToProcess)
                {
                    // MEJORA #26: Eliminar Task.Run redundante
                    _ = ProcessDownload(task);
                    
                    // Delay de 2 segundos entre cada descarga para no saturar la conexión
                    if (tasksToProcess.Length > 1)
                    {
                        await Task.Delay(2000);
                    }
                }

                // Guardar cola cada 30 segundos (60 iteraciones * 500ms)
                saveCounter++;
                if (saveCounter >= 60)
                {
                    if (downloadManager != null)
                    {
                        _ = downloadManager.SaveQueueAsync();
                    }
                    saveCounter = 0;
                }
                
                // Actualizar estadísticas cada 10 iteraciones (5 segundos)
                if (saveCounter % 10 == 0)
                {
                    UpdateDownloadStats();
                }
                
                // AUTO-THROTTLING: Restaurar concurrencia después de 10 minutos sin desconexiones
                if (autoThrottlingActive && (DateTime.Now - lastDisconnectionTime).TotalMinutes >= 10)
                {
                    autoThrottlingActive = false;
                    maxSimultaneousDownloads = originalMaxSimultaneousDownloads;
                    consecutiveDisconnections = 0;
                    AutoLog($"✅ AUTO-THROTTLING DESACTIVADO: Restaurando a {maxSimultaneousDownloads} descargas simultáneas");
                    AutoLog($"💡 10 minutos sin desconexiones - conexión estable");
                }

                await Task.Delay(500);
            }
        }

        private async Task ProcessDownload(DownloadTask task)
        {
            // Esperar mientras esté pausado por desconexión
            bool wasWaiting = false;
            while (downloadsPausedByDisconnection)
            {
                if (!wasWaiting)
                {
                    AutoLog($"⏸️ Descarga en espera por desconexión: {task.File.FileName}");
                    wasWaiting = true;
                }
                
                await Task.Delay(1000);
                
                // Si se canceló mientras esperaba, salir
                if (task.CancellationToken?.IsCancellationRequested == true)
                {
                    AutoLog($"⏹️ Descarga cancelada durante espera: {task.File.FileName}");
                    return;
                }
            }
            
            if (wasWaiting)
            {
                AutoLog($"▶️ Reanudando descarga: {task.File.FileName}");
            }
            
            task.Status = DownloadStatus.Downloading;
            task.StartTime = DateTime.Now;
            task.CancellationToken = new CancellationTokenSource();
            
            // MEJORA NICOTINE+: Publicar evento de inicio de descarga
            _eventBus?.Publish(SystemEvents.DownloadStarted, new
            {
                FileName = task.File.FileName,
                Author = task.File.Author,
                Username = task.File.Username,
                SizeBytes = task.File.SizeBytes,
                Timestamp = DateTime.UtcNow
            });
            
            // Búsqueda proactiva de múltiples fuentes (#5)
            if (!task.IsMultiSource && task.RetryCount == 0)
            {
                try
                {
                    var sources = await FindMultipleSources(task.File, maxSources: 3);
                    if (sources.Count > 1)
                    {
                        task.IsMultiSource = true;
                        task.AlternativeSources = sources;
                        AutoLog($"🚀 {sources.Count} fuentes encontradas, usando multi-source para: {task.File.FileName}");
                    }
                }
                catch (Exception ex)
                {
                    AutoLog($"⚠️ No se pudieron buscar fuentes múltiples: {ex.Message}");
                }
            }
            
            // Si hay múltiples fuentes, usar descarga multi-source
            if (task.IsMultiSource && task.AlternativeSources.Count > 1)
            {
                AutoLog($"🚀 Iniciando descarga multi-source: {task.File.FileName}");
                await DownloadMultiSource(task);
                return;
            }

            // Verificar si hay descarga parcial existente
            long startPosition = 0;
            if (System.IO.File.Exists(task.LocalPath))
            {
                var fileInfo = new FileInfo(task.LocalPath);
                if (fileInfo.Length > 0 && fileInfo.Length < task.File.SizeBytes)
                {
                    startPosition = fileInfo.Length;
                    task.BytesDownloaded = startPosition;
                    task.ProgressPercent = (double)startPosition / task.File.SizeBytes * 100;
                    AutoLog($"📥 Reanudando descarga desde {FormatFileSize(startPosition)}: {task.File.FileName}");
                }
            }

            UpdateDownloadUI(task, $"🔵 Descargando desde {task.File.Network}... {task.ProgressPercent:F1}%");

            try
            {
                // Determinar el cliente correcto según la red de origen
                SoulseekClient downloadClient = client; // Por defecto Soulseek
                
                if (!string.IsNullOrEmpty(task.File.Network) && task.File.Network != "Soulseek")
                {
                    if (_networkOrchestrator != null)
                    {
                        var networkClient = _networkOrchestrator.GetClient(task.File.Network);
                        if (networkClient is SlskDown.Core.SoulseekClientAdapter adapter)
                        {
                            downloadClient = adapter.GetUnderlyingClient();
                            AutoLog($"🌐 Usando cliente de red: {task.File.Network}");
                        }
                        else if (networkClient != null)
                        {
                            task.Status = DownloadStatus.Failed;
                            task.ErrorMessage = $"Red {task.File.Network} no soportada";
                            UpdateDownloadUI(task, $"❌ Red {task.File.Network} no soportada");
                            AutoLog($"⚠️ Descarga desde {task.File.Network} no implementada");
                            return;
                        }
                    }
                }
                
                // Verificar disponibilidad del usuario antes de descargar (con timeout)
                try
                {
                    using var timeoutCts = new CancellationTokenSource(TimeSpan.FromSeconds(5));
                    var userInfo = await downloadClient.GetUserInfoAsync(task.File.Username, timeoutCts.Token);
                    if (userInfo.HasFreeUploadSlot || userInfo.QueueLength < 10)
                    {
                        AutoLog($"✅ Usuario {task.File.Username} disponible (Queue: {userInfo.QueueLength})");
                    }
                    else
                    {
                        AutoLog($"⚠️ Usuario {task.File.Username} ocupado (Queue: {userInfo.QueueLength})");
                    }
                }
                catch (OperationCanceledException)
                {
                    AutoLog($"⏱️ Timeout verificando disponibilidad de {task.File.Username}");
                }
                catch
                {
                    // Si falla la verificación, continuar de todos modos
                }
                
                var remotePath = Path.Combine(task.File.Directory, task.File.FileName).Replace("/", "\\");
                
                // Registrar inicio de descarga en métricas
                sessionMetrics?.RecordDownloadStarted();
                
                // MEJORA #1: Notificar actividad al health check
                healthCheckService?.NotifyActivity();
                
                // MEJORA #4: Crear política de reintentos adaptativa basada en fallos previos
                var retryPolicy = SlskDown.Core.DownloadRetryPolicy.CreateAdaptive(task.RetryCount);
                
                // Optimización #19: Streaming con backpressure (20-30% menos memoria)
                // MEJORA #4: Envolver descarga con retry policy inteligente
                await retryPolicy.ExecuteAsync(
                    async (attemptNumber) =>
                    {
                        if (attemptNumber > 0)
                        {
                            AutoLog($"🔄 Reintento #{attemptNumber + 1} para: {task.File.FileName}");
                            UpdateDownloadUI(task, $"🔄 Reintento #{attemptNumber + 1}");
                        }
                        
                        await downloadClient.DownloadAsync(
                            task.File.Username,
                            remotePath,
                            () => Task.FromResult<Stream>(new FileStream(
                                task.LocalPath, 
                                FileMode.OpenOrCreate,
                                FileAccess.Write,
                                FileShare.None,
                                bufferSize: 81920, // 80KB buffer (óptimo para streaming)
                                useAsync: true
                            )),
                            task.File.SizeBytes,
                            startOffset: startPosition,
                            cancellationToken: task.CancellationToken.Token,
                            options: new TransferOptions(
                                stateChanged: (args) =>
                                {
                                    if (args.Transfer.State.HasFlag(TransferStates.InProgress))
                                    {
                                        task.BytesDownloaded = startPosition + args.Transfer.BytesTransferred;
                                        task.ProgressPercent = (double)task.BytesDownloaded / task.File.SizeBytes * 100;
                                        task.SpeedMBps = args.Transfer.AverageSpeed / 1024.0 / 1024.0;
                                        task.LastSpeedMeasurement = args.Transfer.AverageSpeed; // En bytes/s para el gráfico
                                        
                                        var status = $"🔵 {task.ProgressPercent:F1}% - {task.SpeedMBps:F2} MB/s";
                                        UpdateDownloadUI(task, status);
                                    }
                                },
                                progressUpdated: (args) =>
                                {
                                    task.BytesDownloaded = startPosition + args.Transfer.BytesTransferred;
                                    task.ProgressPercent = (double)task.BytesDownloaded / task.File.SizeBytes * 100;
                                    
                                    var elapsed = (DateTime.Now - task.StartTime.Value).TotalSeconds;
                                    if (elapsed > 0)
                                    {
                                        task.SpeedMBps = (task.BytesDownloaded / elapsed) / 1024.0 / 1024.0;
                                    }
                                    
                                    // Verificar si la descarga es muy lenta y buscar alternativa
                                    // MEJORA #26: Eliminar Task.Run redundante
                                    _ = CheckSlowDownloadAndFindAlternative(task);
                                }
                            )
                        );
                        
                        return true; // Descarga exitosa
                    },
                    shouldRetry: SlskDown.Core.DownloadRetryPolicy.IsRetryableError,
                    onRetry: (attemptNum, delay, ex) =>
                    {
                        AutoLog($"⏳ Esperando {delay.TotalSeconds:F1}s antes del reintento #{attemptNum} (Error: {ex.Message})");
                        UpdateDownloadUI(task, $"⏳ Reintentando en {delay.TotalSeconds:F0}s...");
                    },
                    cancellationToken: task.CancellationToken.Token
                );

                lastActivityTime = DateTime.UtcNow; // Sticky session
                task.Status = DownloadStatus.Completed;
                task.EndTime = DateTime.Now;
                task.ProgressPercent = 100;
                
                // MEJORA NICOTINE+: Marcar descarga como completada en UserQueueManager
                _userQueueManager?.MarkCompleted(task.File.Username);
                
                // MEJORA #42: Registrar en detector de duplicados
                if (duplicateDetector != null)
                {
                    duplicateDetector.RegisterDownload(task.File.FileName, task.File.SizeBytes, task.LocalPath);
                }
                
                // MEJORA #43: Verificar integridad del archivo descargado
                if (integrityChecker != null)
                {
                    try
                    {
                        var (isValid, reason) = await integrityChecker.VerifyFileBasicIntegrityAsync(task.LocalPath);
                        if (!isValid)
                        {
                            AutoLog($"⚠️ Archivo corrupto detectado: {task.File.FileName} - {reason}");
                            task.Status = DownloadStatus.Corrupted; // MEJORA #16: Estado específico para corruptos
                            
                            // MEJORA: Notificar archivo corrupto
                            try { notificationService?.NotifyCorruptedFiles(1); } catch { }
                            task.ErrorMessage = $"Corrupto: {reason}";
                            UpdateDownloadUI(task, $"🔴 Corrupto: {reason}");
                            
                            // Eliminar archivo corrupto
                            try
                            {
                                System.IO.File.Delete(task.LocalPath);
                                AutoLog($"🗑️ Archivo corrupto eliminado: {task.File.FileName}");
                            }
                            catch { }
                            
                            // Reintento automático si no se ha excedido el límite
                            const int MAX_CORRUPTION_RETRIES = 2;
                            if (task.RetryCount < MAX_CORRUPTION_RETRIES)
                            {
                                task.RetryCount++;
                                task.Status = DownloadStatus.Queued;
                                task.LastRetryTime = DateTime.Now;
                                AutoLog($"🔄 Reintentando descarga corrupta ({task.RetryCount}/{MAX_CORRUPTION_RETRIES}): {task.File.FileName}");
                                UpdateDownloadUI(task, $"🔄 Reintentando ({task.RetryCount}/{MAX_CORRUPTION_RETRIES})");
                                
                                // Registrar métrica de fallo
                                sessionMetrics?.RecordDownloadFailed();
                                
                                // Volver a encolar para reintento
                                await Task.Delay(2000); // Esperar 2 segundos antes de reintentar
                                _ = Task.Run(() => ProcessDownload(task));
                            }
                            else
                            {
                                AutoLog($"❌ Descarga corrupta después de {MAX_CORRUPTION_RETRIES} intentos: {task.File.FileName}");
                                task.Status = DownloadStatus.Failed;
                                task.ErrorMessage = $"Corrupto después de {MAX_CORRUPTION_RETRIES} intentos: {reason}";
                                UpdateDownloadUI(task, $"❌ Fallo: Corrupto");
                                
                                // Registrar métrica de fallo
                                sessionMetrics?.RecordDownloadFailed();
                            }
                            
                            return;
                        }
                        else
                        {
                            // MEJORA #16: Calcular y mostrar checksum SHA256 completo
                            try
                            {
                                var checksum = await integrityChecker.CalculateChecksumAsync(task.LocalPath);
                                if (!string.IsNullOrEmpty(checksum))
                                {
                                    AutoLog($"✅ Integridad verificada: {task.File.FileName}");
                                    AutoLog($"   🔐 SHA256: {checksum.Substring(0, 16)}...{checksum.Substring(checksum.Length - 16)}");
                                    
                                    // Guardar checksum en metadata del archivo (opcional)
                                    task.Checksum = checksum;
                                }
                                else
                                {
                                    AutoLog($"✅ Integridad básica verificada: {task.File.FileName}");
                                }
                            }
                            catch
                            {
                                // Si falla el checksum, continuar (ya pasó la verificación básica)
                                AutoLog($"✅ Integridad básica verificada: {task.File.FileName}");
                            }
                        }
                    }
                    catch (Exception ex)
                    {
                        AutoLog($"⚠️ Error verificando integridad: {ex.Message}");
                    }
                }
                
                // REFACTORIZACIÓN: Registrar en StatisticsManager
                if (statisticsManager != null && task.StartTime != null)
                {
                    var duration = DateTime.Now - task.StartTime.Value;
                    statisticsManager.RecordDownload(true, task.File.SizeBytes, duration);
                    statisticsManager.RecordProviderSuccess(task.File.Username, task.File.SizeBytes, duration);
                    statisticsManager.AddToHistory(new DownloadHistory
                    {
                        FileName = task.File.FileName,
                        Author = task.File.Author,
                        SizeBytes = task.File.SizeBytes,
                        Username = task.File.Username,
                        CompletedAt = DateTime.Now
                    });
                }
                
                // Registrar métrica de descarga exitosa
                sessionMetrics?.RecordDownloadCompleted(task.File.SizeBytes, task.SpeedMBps * 1024);
                
                // Velocidad adaptativa: registrar velocidad y ajustar descargas paralelas
                if (adaptiveSpeed && task.SpeedMBps > 0)
                {
                    UpdateAdaptiveSpeed(task.SpeedMBps);
                }
                
                // Invalidar caché del archivo descargado
                InvalidateFileCache(task.LocalPath);
                
                // Verificar integridad con hash BLAKE3 (ultra-rápido)
                string fileHash = null;
                try
                {
                    // Verificar que el archivo existe y la ruta es válida
                    if (!string.IsNullOrEmpty(task.LocalPath) && System.IO.File.Exists(task.LocalPath))
                    {
                        fileHash = SlskDownCore.HashFileBlake3(task.LocalPath);
                        
                        if (!string.IsNullOrEmpty(fileHash))
                        {
                            // MEJORA #31: Usar indexador de rango en lugar de Substring
                            AutoLog($"🔐 Hash verificado: {fileHash[..16]}...");
                            
                            // Optimización #15: Verificar duplicados y crear hardlink si existe
                            var existingPath = CheckDuplicateFile(task.LocalPath, fileHash);
                            if (existingPath != null)
                            {
                                // Archivo duplicado encontrado, crear hardlink
                                var fileInfo = new FileInfo(task.LocalPath);
                                var savedSpace = fileInfo.Length;
                                
                                System.IO.File.Delete(task.LocalPath);
                                CreateHardLink(existingPath, task.LocalPath);
                                
                                AutoLog($"💾 Espacio ahorrado: {FormatFileSize(savedSpace)}");
                            }
                        }
                    }
                    else
                    {
                        AutoLog($"⚠️ No se puede calcular hash: archivo no existe o ruta inválida");
                    }
                }
                catch (Exception hashEx)
                {
                    AutoLog($"⚠️ No se pudo calcular hash: {hashEx.Message}");
                }
                
                // Renombrar a formato Calibre si es un ebook
                RenameToLibreFormat(task.LocalPath, task.File.Author);
                
                // Notificación de descarga completada
                ShowNotification("Descarga completada", 
                    $"✅ {task.File.FileName}\n\nTamaño: {task.File.SizeReadable} | Velocidad: {task.SpeedMBps:F2} MB/s", 
                    ToolTipIcon.Info);
                
                // Registrar en historial con hash para verificación futura
                // OPTIMIZACIÓN: Usar sistema híbrido (RAM + SQLite)
                _ = AddToDownloadHistoryAsync(new DownloadHistory
                {
                    FileName = task.File.FileName,
                    Author = task.File.Author,
                    Username = task.File.Username,
                    SizeBytes = task.File.SizeBytes,
                    DownloadedAt = DateTime.Now,
                    Status = "Completed",
                    SpeedMBps = task.SpeedMBps,
                    Hash = fileHash // BLAKE3 hash for integrity verification
                });
                
                // Actualizar estadísticas de proveedor (optimizado con batch writes)
                _ = UpdateProviderStatsOptimizedAsync(
                    username: task.File.Username,
                    success: true,
                    speedMBps: task.SpeedMBps,
                    bytes: task.File.SizeBytes
                );
                
                // Actualizar estadísticas en base de datos SQLite
                _ = Task.Run(async () =>
                {
                    try
                    {
                        if (database != null)
                        {
                            await database.UpdateSourceStatsAsync(
                                username: task.File.Username,
                                success: true,
                                speed: task.SpeedMBps,
                                disconnected: false
                            );
                        }
                    }
                    catch (Exception ex)
                    {
                        SafeBeginInvoke(() => Log($"⚠️ Error guardando en DB: {ex.Message}"));
                    }
                });
                
                // Actualizar vista del historial automáticamente
                RefreshHistoryView(true);

                // Actualizar estadísticas
                statistics.TotalFilesDownloaded++;
                statistics.TotalBytesDownloaded += task.File.SizeBytes;
                var downloadTime = task.StartTime.HasValue ? (task.EndTime.Value - task.StartTime.Value).TotalSeconds : 0;
                if (downloadTime > 0)
                {
                    var totalTime = statistics.TotalDownloadTime.TotalSeconds + downloadTime;
                    statistics.TotalDownloadTime = TimeSpan.FromSeconds(totalTime);
                    statistics.AverageDownloadSpeed = (statistics.TotalBytesDownloaded / totalTime) / 1024.0 / 1024.0;
                }

                downloadManager?.ApplyQueuePrioritization();
                
                // MEJORA NICOTINE+: Marcar descarga como completada en UserQueueManager
                _userQueueManager?.MarkCompleted(task.File.Username);

                return;
            }
            catch (OperationCanceledException)
            {
                // Solo marcar como cancelado si no fue marcado como fallido previamente
                // (las cancelaciones automáticas por lentitud ya están marcadas como Failed)
                if (task.Status != DownloadStatus.Failed)
                {
                    // MEJORA #16: Verificar si hay archivo parcial
                    bool hasPartialFile = System.IO.File.Exists(task.LocalPath);
                    if (hasPartialFile && task.ProgressPercent > 0 && task.ProgressPercent < 100)
                    {
                        task.Status = DownloadStatus.Incomplete; // Marcar como incompleto
                        UpdateDownloadUI(task, $"🟠 Incompleto ({task.ProgressPercent:F1}%)");
                        AutoLog($"🟠 Descarga incompleta: {task.File.FileName} ({task.ProgressPercent:F1}%)");
                    }
                    else
                    {
                        task.Status = DownloadStatus.Cancelled;
                        UpdateDownloadUI(task, "⏹️ Cancelado");
                        AutoLog($"⏹️ Descarga cancelada manualmente: {task.File.FileName}");
                    }
                    
                    task.EndTime = DateTime.Now;
                    
                    // Eliminar archivo incompleto
                    DeleteIncompleteFile(task.LocalPath, "cancelada");
                }
                else
                {
                    // Ya fue marcado como Failed (cancelación automática)
                    AutoLog($"⚠️ Descarga interrumpida (reintento automático): {task.File.FileName}");
                }
            }
            catch (Exception ex)
            {
                // MEJORA #16: Verificar si hay archivo parcial para marcarlo como incompleto
                bool hasPartialFile = System.IO.File.Exists(task.LocalPath);
                if (hasPartialFile && task.ProgressPercent > 0 && task.ProgressPercent < 100)
                {
                    task.Status = DownloadStatus.Incomplete;
                }
                else
                {
                    task.Status = DownloadStatus.Failed;
                }
                
                task.EndTime = DateTime.Now;
                task.ErrorMessage = ex.Message;
                task.LastRetryTime = DateTime.Now;
                
                // MEJORA NICOTINE+: Publicar evento de descarga fallida
                _eventBus?.Publish(SystemEvents.DownloadFailed, new
                {
                    FileName = task.File.FileName,
                    Author = task.File.Author,
                    Username = task.File.Username,
                    Reason = ex.Message,
                    RetryCount = task.RetryCount,
                    WillRetry = task.AutoRetryEnabled && task.RetryCount < task.MaxRetries,
                    Timestamp = DateTime.UtcNow
                });
                
                // MEJORA NICOTINE+: Marcar usuario como fallido en UserQueueManager
                _userQueueManager?.MarkFailed(task.File.Username);
                
                // REFACTORIZACIÓN: Registrar fallo en StatisticsManager
                if (statisticsManager != null)
                {
                    statisticsManager.RecordDownload(false, 0, null);
                    statisticsManager.RecordProviderFailure(task.File.Username);
                }
                
                // MEJORA #1: Detección agresiva de usuarios offline
                if (ex.Message.Contains("appears to be offline", StringComparison.OrdinalIgnoreCase))
                {
                    providerBlacklist[task.File.Username] = (PROVIDER_BLACKLIST_THRESHOLD, DateTime.Now);
                    AutoLog($"⛔ Usuario {task.File.Username} offline detectado, blacklist inmediata");
                    
                    // Buscar proveedor alternativo inmediatamente
                    // TODO: Descomentar cuando se corrija API
                    // _ = Task.Run(async () => await TryFindAlternativeProvider(task));
                }
                
                // MEJORA: Detectar desconexión del cliente y guardar checkpoint
                if (client == null || 
                    !client.State.HasFlag(SoulseekClientStates.Connected) || 
                    !client.State.HasFlag(SoulseekClientStates.LoggedIn))
                {
                    AutoLog($"🔌 Desconexión detectada durante descarga de: {task.File.FileName}");
                    downloadsPausedByDisconnection = true;
                    
                    // Guardar checkpoint inmediatamente
                    _ = Task.Run(async () =>
                    {
                        try
                        {
                            await downloadManager?.SaveQueueAsync();
                            AutoLog("💾 Checkpoint de descargas guardado por desconexión");
                        }
                        catch (Exception saveEx)
                        {
                            AutoLog($"❌ Error guardando checkpoint: {saveEx.Message}");
                        }
                    });
                }
                
                // Modo agresivo para archivos difíciles (#7)
                if (task.RetryCount >= 2)
                {
                    task.MaxRetries = 5; // Más reintentos
                    AutoLog($"🔥 Modo agresivo activado para: {task.File.FileName}");
                }
                
                // MEJORA #4: Determinar si se reintentará automáticamente
                bool shouldRetry = task.AutoRetryEnabled && 
                                  task.RetryCount < task.MaxRetries && 
                                  IsRecoverableError(ex.Message);
                
                if (shouldRetry)
                {
                    // MEJORA #4: Mostrar tiempo de espera con backoff exponencial inteligente
                    int retryDelay = GetRetryDelay(task.RetryCount, ex.Message);
                    UpdateDownloadUI(task, $"🔄 Error (reintento {task.RetryCount + 1}/{task.MaxRetries} en {retryDelay}s)");
                    AutoLog($"❌ Error: {task.File.FileName} - {ex.Message} (reintento {task.RetryCount + 1}/{task.MaxRetries} en {retryDelay}s)");
                }
                else if (!IsRecoverableError(ex.Message))
                {
                    task.FinalFailureTime = DateTime.Now;
                    UpdateDownloadUI(task, $"⛔ Error no recuperable: {ex.Message}");
                    AutoLog($"⛔ Error no recuperable: {task.File.FileName} - {ex.Message}");
                    
                    // Eliminar archivo incompleto
                    DeleteIncompleteFile(task.LocalPath, "error no recuperable");
                }
                else
                {
                    task.FinalFailureTime = DateTime.Now; // Marcar fallo definitivo (#1)
                    UpdateDownloadUI(task, $"❌ Error: {ex.Message}");
                    AutoLog($"❌ Fallo definitivo: {task.File.FileName} - {ex.Message}");
                    
                    // Eliminar archivo incompleto en fallo definitivo
                    DeleteIncompleteFile(task.LocalPath, "fallida");
                    
                    // Notificación consolidada (#9)
                    ShowNotification("Descarga fallida", 
                        $"❌ {task.File.FileName}\n\nError: {ex.Message}\n\nReintentos: {task.MaxRetries}", 
                        ToolTipIcon.Error);
                    
                    // Intentar buscar proveedor alternativo solo después de agotar reintentos
                    // TODO: Descomentar cuando se corrija API
                    // _ = Task.Run(async () => await TryFindAlternativeProvider(task));
                }
                
                // Actualizar estadísticas del proveedor (fallo) y blacklist temporal (#8)
                UpdateProviderStats(task.File.Username, false, 0, 0);
                SaveProviderStatsToDatabase();
                
                // Actualizar score en SQLite
                _ = Task.Run(async () =>
                {
                    try
                    {
                        if (database != null)
                        {
                            await database.UpdateSourceStatsAsync(
                                username: task.File.Username,
                                success: false,
                                speed: 0,
                                disconnected: ex.Message.Contains("offline", StringComparison.OrdinalIgnoreCase)
                            );
                        }
                    }
                    catch { }
                });
                
                // Agregar a blacklist temporal si falla repetidamente
                providerBlacklist.AddOrUpdate(
                    task.File.Username,
                    (1, DateTime.Now),
                    (key, existing) => (existing.failures + 1, DateTime.Now)
                );
                
                if (providerBlacklist.TryGetValue(task.File.Username, out var updatedData) && 
                    updatedData.failures >= PROVIDER_BLACKLIST_THRESHOLD)
                {
                    AutoLog($"⛔ Usuario {task.File.Username} agregado a blacklist temporal ({updatedData.failures} fallos)");
                }
            }
            finally
            {
                downloadManager?.ApplyQueuePrioritization();
            }
        }
        
        private async Task SearchFailedInOtherUsers()
        {
            try
            {
                // MEJORA FASE 1.3: ReadLock para snapshot de solo lectura
                var failedTasks = ReadLocked(downloadQueueLock, () =>
                    downloadQueue.Where(t => t.Status == DownloadStatus.Failed).ToList());
                
                if (failedTasks.Count == 0)
                {
                    MessageBox.Show("No hay archivos fallidos para buscar.", "Sin archivos fallidos", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    return;
                }
                
                var result = MessageBox.Show(
                    $"Se buscarán {failedTasks.Count} archivo(s) fallido(s) en otros usuarios.\n\n" +
                    "Esta operación puede tardar varios minutos.\n\n" +
                    "¿Deseas continuar?",
                    "Buscar en Otros Usuarios",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Question
                );
                
                if (result != DialogResult.Yes)
                    return;
                
                Log($"🔍 Iniciando búsqueda de {failedTasks.Count} archivo(s) fallido(s) en otros usuarios...");
                
                int foundCount = 0;
                int notFoundCount = 0;
                int errorCount = 0;
                
                foreach (var task in failedTasks)
                {
                    try
                    {
                        Log($"🔍 Buscando: {task.File.FileName}");
                        UpdateDownloadUI(task, "🔍 Buscando en otros usuarios...");
                        
                        // Usar cliente del pool para búsqueda
                        var searchClient = GetClientFromPool();
                        var searchResults = await searchClient.SearchAsync(
                            SearchQuery.FromText(task.File.FileName),
                            options: new Soulseek.SearchOptions(
                                searchTimeout: 20000,
                                filterResponses: true,
                                minimumResponseFileCount: 1
                            )
                        );
                        
                        // MEJORA #3: Buscar proveedores alternativos excluyendo blacklist
                        var alternatives = searchResults.Responses
                            .Where(r => 
                            {
                                // Excluir proveedor original
                                if (r.Username.Equals(task.File.Username, StringComparison.OrdinalIgnoreCase))
                                    return false;
                                
                                // Excluir proveedores en blacklist temporal
                                if (providerBlacklist.TryGetValue(r.Username, out var data))
                                {
                                    if (data.failures >= PROVIDER_BLACKLIST_THRESHOLD && 
                                        (DateTime.Now - data.lastFail).TotalHours < PROVIDER_BLACKLIST_HOURS)
                                    {
                                        return false;
                                    }
                                }
                                
                                return true;
                            })
                            .SelectMany(r => r.Files.Select(f => new { Response = r, File = f }))
                            .Where(item => 
                                item.File.Filename.Equals(task.File.FileName, StringComparison.OrdinalIgnoreCase) &&
                                Math.Abs(item.File.Size - task.File.SizeBytes) < 1024 * 100) // Tolerancia de 100KB
                            .OrderByDescending(item =>
                            {
                                var stats = GetProviderStats(item.Response.Username);
                                return stats != null ? stats.QualityScore : item.File.Size / 1024.0 / 1024.0;
                            })
                            .ToList();
                        
                        if (alternatives.Count > 0)
                        {
                            var alternative = alternatives.First();
                            Log($"✅ Encontrado en: {alternative.Response.Username} ({alternatives.Count} alternativa(s))");
                            
                            // Crear nuevo AutoSearchFileResult con el proveedor alternativo
                            var newFile = new AutoSearchFileResult
                            {
                                FileName = task.File.FileName,
                                Author = task.File.Author,
                                Username = alternative.Response.Username,
                                Directory = alternative.File.Filename.Contains("\\") ? 
                                    alternative.File.Filename.Substring(0, alternative.File.Filename.LastIndexOf("\\")) : "",
                                SizeBytes = alternative.File.Size,
                                SizeReadable = FormatFileSize(alternative.File.Size),
                                IsSpanish = task.File.IsSpanish,
                                IsDocument = task.File.IsDocument,
                                Timestamp = DateTime.Now
                            };
                            
                            // Actualizar la tarea con el nuevo proveedor
                            task.File = newFile;
                            task.Status = DownloadStatus.Queued;
                            task.RetryCount = 0;
                            task.ErrorMessage = null;
                            task.FinalFailureTime = null;
                            task.LastRetryTime = null;
                            
                            UpdateDownloadUI(task, $"⏳ En cola (nuevo: {alternative.Response.Username})");
                            foundCount++;
                        }
                        else
                        {
                            Log($"❌ No se encontraron alternativas para: {task.File.FileName}");
                            UpdateDownloadUI(task, "❌ Sin alternativas disponibles");
                            notFoundCount++;
                        }
                        
                        // Pequeña pausa entre búsquedas
                        await Task.Delay(500);
                    }
                    catch (Exception ex)
                    {
                        Log($"❌ Error buscando {task.File.FileName}: {ex.Message}");
                        errorCount++;
                    }
                }
                
                var summary = $"Búsqueda completada:\n\n" +
                             $"✅ Encontrados: {foundCount}\n" +
                             $"❌ No encontrados: {notFoundCount}\n" +
                             $"⚠️ Errores: {errorCount}\n\n" +
                             $"Los archivos encontrados se agregarán a la cola de descargas.";
                
                Log($"✅ {summary.Replace("\n", " ")}");
                MessageBox.Show(summary, "Búsqueda Completada", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                Log($"❌ Error en SearchFailedInOtherUsers: {ex.Message}");
                MessageBox.Show($"Error buscando archivos:\n{ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
