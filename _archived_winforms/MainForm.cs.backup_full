            var queueSection = CreateConfigSectionPanel("📥 COLA");
            
            var queueButtons = new FlowLayoutPanel
            {
                AutoSize = true,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = false,
                Margin = new Padding(0, 0, 0, 8)
            };
            
            var btnStart = CreateButton("▶️ Iniciar", Color.FromArgb(16, 185, 129), OnStartQueueClick);
            btnStart.Width = 130;
            var btnClear = CreateButton("🗑️ Limpiar", Color.FromArgb(220, 38, 38), OnClearQueueClick);
            btnClear.Width = 130;
            
            queueButtons.Controls.Add(btnStart);
            queueButtons.Controls.Add(btnClear);
            queueSection.Controls.Add(queueButtons);
            
            var strategyPanel = new FlowLayoutPanel
            {
                AutoSize = true,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = false,
                Margin = new Padding(0, 0, 0, 8)
            };

            strategyPanel.Controls.Add(CreateLabel("Prioridad:"));

            var strategyItems = new List<(QueuePrioritizationStrategy strategy, string text)>
            {
                (QueuePrioritizationStrategy.Manual, "Manual"),
                (QueuePrioritizationStrategy.FastestFirst, "Más rápidos"),
                (QueuePrioritizationStrategy.SmallestFirst, "Archivos pequeños"),
                (QueuePrioritizationStrategy.LargestFirst, "Archivos grandes"),
                (QueuePrioritizationStrategy.Balanced, "Balanceado")
            };

            var cmbQueueStrategy = new ComboBox
            {
                DropDownStyle = ComboBoxStyle.DropDownList,
                Width = 170,
                BackColor = Color.FromArgb(40, 40, 45),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat
            };

            foreach (var (strategy, text) in strategyItems)
            {
                cmbQueueStrategy.Items.Add(new ComboBoxItem<QueuePrioritizationStrategy>(text, strategy));
            }

            int selectedIndex = strategyItems.FindIndex(i => i.strategy == queueStrategy);
            cmbQueueStrategy.SelectedIndex = selectedIndex >= 0 ? selectedIndex : 0;

            cmbQueueStrategy.SelectedIndexChanged += (s, e) =>
            {
                if (cmbQueueStrategy.SelectedItem is ComboBoxItem<QueuePrioritizationStrategy> item)
                {
                    queueStrategy = item.Value;
                    SaveConfig();

                    if (downloadManager != null)
                    {
                        downloadManager.QueueStrategy = queueStrategy;
                        downloadManager.ApplyQueuePrioritization();
                    }

                    UpdateDownloadListView();
                }
            };

            strategyPanel.Controls.Add(cmbQueueStrategy);
            queueSection.Controls.Add(strategyPanel);

            var btnReset = CreateButton("🔥 RESET TOTAL", Color.FromArgb(180, 40, 40), OnResetAllClick);
            btnReset.Width = 180;
            queueSection.Controls.Add(btnReset);
            
            rightColumn.Controls.Add(queueSection);

