            { 
                _useWishlistSearch = ((CheckBox)s).Checked; 
                SaveConfig();
                
                if (_useWishlistSearch)
                {
                    Log("✅ WishlistSearch activado - búsquedas pasivas cada 2-12 min");
                    Log("💡 Ventajas: 90% menos carga, sin rate limiting, sin riesgo de ban");
                }
                else
                {
                    Log("⚠️ WishlistSearch desactivado - usando búsquedas activas");
                    Log("⚠️ Advertencia: Mayor riesgo de rate limiting y ban");
                }
            });
            chkWishlistSearch.ForeColor = Color.LightGreen;
            chkWishlistSearch.Font = new Font("Segoe UI", 9, FontStyle.Bold);
            protocolSection.Controls.Add(chkWishlistSearch);
            
            // Info del intervalo
