        private int maxTotalAttempts = 15; // Límite absoluto de intentos totales por archivo
        private ConcurrentDictionary<string, int> downloadRetryCount = new ConcurrentDictionary<string, int>(); // Contador de reintentos por archivo (thread-safe)
        
