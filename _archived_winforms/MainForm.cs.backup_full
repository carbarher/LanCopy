                    }
                }
            }
            catch (Exception ex)
            {
                SafeLog($"Error en DownloadAll: {ex.Message}\n");
            }
        }
        
        private void CancelAllDownloads()
        {
            var result = DarkMessageBox.Show("¿Cancelar TODAS las descargas activas?\n\nEsto cancelará todas las descargas en curso y pendientes.", 
                "Confirmar Cancelación Masiva", MessageBoxButtons.YesNo, MessageBoxIcon.Warning);
            
            if (result == DialogResult.Yes)
            {
                try
                {
                    int cancelledCount = 0;

                    if (downloadManager != null)
                    {
                        var snapshot = downloadManager.GetQueueSnapshot();
                        foreach (var task in snapshot.Where(t =>
                            t.Status == DownloadStatus.Downloading ||
                            t.Status == DownloadStatus.Queued ||
                            t.Status == DownloadStatus.Paused))
                        {
                            if (downloadManager.CancelTask(task))
                            {
                                cancelledCount++;
                            }
                        }
                    }
                    else
                    {
                        // MEJORA FASE 1.3: WriteLock para modificar tareas
                        var activeTasks = ReadLocked(downloadQueueLock, () =>
                            downloadQueue
                                .Where(t => t.Status == DownloadStatus.Downloading ||
                                           t.Status == DownloadStatus.Queued ||
                                           t.Status == DownloadStatus.Paused)
                                .ToList());

                        foreach (var task in activeTasks)
                        {
                            WriteLocked(downloadQueueLock, () =>
                            {
                                task.Status = DownloadStatus.Cancelled;
                                task.CancellationToken?.Cancel();
                            });
                            UpdateDownloadUI(task, "❌ Cancelado");
                            cancelledCount++;
                        }
                    }

                    SafeLog($"❌ Canceladas {cancelledCount} descargas");
                    UpdateProgressDisplay();
                    
                    if (cancelledCount > 0)
                    {
                        DarkMessageBox.Show($"Se cancelaron {cancelledCount} descargas", 
                            "Cancelación Completa", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    }
                }
                catch (Exception ex)
                {
                    SafeLog($"❌ Error cancelando descargas: {ex.Message}");
                    DarkMessageBox.Show($"Error al cancelar descargas: {ex.Message}", 
                        "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            }

            RefreshAutoSummary();
        }

        private void RefreshAutoSummary()
        {
            if (!IsHandleCreated)
                return;

            if (InvokeRequired)
            {
                SafeBeginInvoke(() => RefreshAutoSummary());
                return;
            }

            if (lblAutoSummaryCounts != null)
            {
                int totalAuthors = allAuthorsData?.Count ?? 0;
                int selectedAuthors = 0;
                
                // Validar que filteredAuthorsData no sea null antes de contar
                if (filteredAuthorsData != null)
                {
                    try
                    {
                        selectedAuthors = filteredAuthorsData.Count(a => a != null && a.IsChecked);
                    }
                    catch
                    {
                        selectedAuthors = 0;
                    }
                }
                
                lblAutoSummaryCounts.Text = $"Autores cargados: {totalAuthors:N0} | Seleccionados: {selectedAuthors:N0}";
            }

            if (lblAutoSummaryStatus != null)
            {
                string statusText = "Estado: En espera";
                if (autoPurgeRunning)
                    statusText = "Estado: Búsqueda en curso";
                else if (autoSearchRunning)
                    statusText = "Estado: Búsqueda automática";

                lblAutoSummaryStatus.Text = statusText;
            }
        }
        
        private void ClearCompletedDownloads()
        {
            try
            {
                int removedCount = 0;

                if (downloadManager != null)
                {
                    var removedTasks = downloadManager.ClearCompletedTasks();
                    foreach (var task in removedTasks)
                    {
                        removedCount++;
                        SafeInvoke(() =>
                        {
                            if (task.ListViewItem != null && lvDownloads.Items.Contains(task.ListViewItem))
                            {
                                lvDownloads.Items.Remove(task.ListViewItem);
                            }
                        });
                    }
                }
                else
                {
                    // MEJORA FASE 1.3: ReadLock para snapshot, WriteLock para modificar
                    var completedTasks = ReadLocked(downloadQueueLock, () =>
                        downloadQueue
                            .Where(t => t.Status == DownloadStatus.Completed || t.Status == DownloadStatus.Cancelled)
                            .ToList());

                    foreach (var task in completedTasks)
                    {
                        WriteLocked(downloadQueueLock, () => downloadQueue.Remove(task));

                        SafeInvoke(() =>
                        {
                            if (task.ListViewItem != null && lvDownloads.Items.Contains(task.ListViewItem))
                            {
                                lvDownloads.Items.Remove(task.ListViewItem);
                            }
                        });

                        removedCount++;
                    }
                }

                if (removedCount > 0)
                {
                    SafeLog($"🗑️ Limpiadas {removedCount} descargas completadas/canceladas");
                    UpdateProgressDisplay();
                }
                else
                {
                    Log("⚠️ No hay descargas completadas para limpiar");
                }
            }
            catch (Exception ex)
            {
                SafeLog($"❌ Error limpiando descargas: {ex.Message}");
            }
        }
        
        // REFACTORIZACIÓN: Helper para obtener tarea seleccionada (elimina código duplicado)
        private DownloadTask GetSelectedDownloadTask()
        {
            if (lvDownloads.SelectedItems.Count == 0)
            {
                Log("⚠️ Selecciona una descarga primero");
                return null;
            }
            
            return lvDownloads.SelectedItems[0].Tag as DownloadTask;
        }

        private List<DownloadTask> GetSelectedDownloadTasks()
        {
            return lvDownloads.SelectedItems
                .Cast<ListViewItem>()
                .Select(item => item.Tag as DownloadTask)
                .Where(task => task != null)
                .ToList();
        }
        
        private void PauseSelectedDownload()
        {
            PauseDownload();
        }
        
        private void ResumeSelectedDownload()
        {
            ResumeDownload();
        }
        
        private void CancelSelectedDownload()
        {
            if (lvDownloads.SelectedItems.Count == 0)
                return;

            var tasks = GetSelectedDownloadTasks();
            if (tasks.Count == 0)
            {
                DarkMessageBox.Show("Las descargas seleccionadas no forman parte de la cola.", "Cancelar descarga", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            string message = tasks.Count == 1
                ? $"¿Cancelar descarga de:\n{tasks[0].File.FileName}?"
                : $"¿Cancelar {tasks.Count} descargas seleccionadas?";

            var result = DarkMessageBox.Show(message,
                "Confirmar Cancelación", MessageBoxButtons.YesNo, MessageBoxIcon.Warning);

            if (result == DialogResult.Yes)
            {
                CancelDownload();
            }
        }
        
        private void OpenDownloadFolder()
        {
            try
            {
                if (System.IO.Directory.Exists(downloadDir))
                {
                    System.Diagnostics.Process.Start("explorer.exe", downloadDir);
                }
                else
                {
                    DarkMessageBox.Show("La carpeta de descargas no existe", "Error", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                }
            }
            catch (Exception ex)
            {
                SafeLog($"Error al abrir carpeta: {ex.Message}\n");
            }
        }
        
        private Button CreateFilterButton(string text, bool isActive)
        {
            var button = new Button
            {
                Text = text,
                Size = new Size(140, 30),
                BackColor = isActive ? Color.FromArgb(0, 120, 215) : Color.FromArgb(50, 50, 50),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 9),
                Cursor = Cursors.Hand,
                Margin = new Padding(2)
            };

            button.FlatAppearance.BorderSize = 0;
            return button;
        }

        private void CreateConfigTab(TabPage parent)
        {
            parent.BackColor = Color.FromArgb(18, 18, 18);

            var scrollPanel = new Panel
            {
                Dock = DockStyle.Fill,
                AutoScroll = true,
                BackColor = Color.FromArgb(18, 18, 18),
                Padding = new Padding(24)
            };

            var mainLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Top,
                AutoSize = true,
                ColumnCount = 2,
                BackColor = Color.FromArgb(18, 18, 18),
                Padding = new Padding(0)
            };
            mainLayout.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 50f));
            mainLayout.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 50f));

            var leftColumn = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                FlowDirection = FlowDirection.TopDown,
                WrapContents = false,
                AutoSize = true,
                MinimumSize = new Size(320, 0),
                BackColor = Color.FromArgb(18, 18, 18),
                Padding = new Padding(0, 0, 20, 0)
            };

            var lblTitle = new Label
            {
                Text = "⚙️ Configuración",
                AutoSize = true,
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 18, FontStyle.Bold),
                Margin = new Padding(0, 0, 0, 30)
            };
            leftColumn.Controls.Add(lblTitle);

            // === SECCIÓN CUENTA ===
            var accountSection = CreateConfigSectionPanel("👤 CUENTA SOULSEEK");
            
