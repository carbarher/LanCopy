        private void SaveFavorites()
        {
            try
            {
                System.IO.File.WriteAllText(favoritesPath, JsonSerializer.Serialize(favorites));
            }
            catch (Exception ex)
            {
                Log($"Error al guardar favoritos: {ex.Message}");
            }
        }
        
        private void LoadFavorites()
        {
            try
            {
                if (System.IO.File.Exists(favoritesPath))
                {
                    favorites = JsonSerializer.Deserialize<List<string>>(System.IO.File.ReadAllText(favoritesPath)) ?? new List<string>();
                    LoadFavoritesCombo();
                }
            }
            catch (Exception ex)
            {
                Log($"Error al cargar favoritos: {ex.Message}");
            }
        }
        
        private void SaveSearchHistory()
        {
            try
            {
                if (searchHistory.Count == 0)
                {
                    if (System.IO.File.Exists(historyPath))
                    {
                        System.IO.File.Delete(historyPath);
                    }
                    return;
                }
                System.IO.File.WriteAllText(historyPath, JsonSerializer.Serialize(searchHistory));
            }
            catch
            {
                // Ignorar errores silenciosamente
            }
        }

        private void LoadSearchHistorySafely()
        {
            try
            {
                LoadSearchHistory();
            }
            catch (Exception ex)
            {
                Log($"Error inesperado al cargar historial de búsqueda: {ex.Message}");
            }
        }

        private void ClearSearchHistoryCombo()
        {
            SafeInvoke(() =>
            {
                if (searchHistory.Count == 0)
                {
                    Log("⚠️ No hay historial de búsquedas para limpiar");
                    return;
                }

                var result = DarkMessageBox.Show(
                    "¿Seguro que deseas borrar todo el historial de búsquedas?",
                    "Historial de Búsquedas",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Warning);

                if (result != DialogResult.Yes)
                {
                    return;
                }

                searchHistory.Clear();
                if (cmbSearch != null)
                {
                    cmbSearch.Items.Clear();
                    cmbSearch.Text = string.Empty;
                }

                try
                {
                    if (System.IO.File.Exists(historyPath))
                    {
                        System.IO.File.Delete(historyPath);
                    }
                }
                catch (Exception ex)
                {
                    Log($"Error al eliminar historial de búsquedas: {ex.Message}");
                }

                Log("✅ Historial de búsquedas eliminado");
            });
        }
        
        private void CreateBlacklistTab(TabPage parent)
        {
            parent.BackColor = Color.FromArgb(18, 18, 18);
            
            var mainLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 2,
                RowCount = 3,
                BackColor = Color.FromArgb(18, 18, 18),
                Padding = new Padding(20)
            };
            mainLayout.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 60f));
            mainLayout.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 40f));
            mainLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize)); // Título
            mainLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize)); // Info
            mainLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100f)); // Contenido
            
            // Título
            var lblTitle = new Label 
            { 
                Text = "🚫 Lista Negra de Usuarios", 
                AutoSize = true,
                ForeColor = Color.White, 
                Font = new Font("Segoe UI", 14, FontStyle.Bold),
                Margin = new Padding(0, 0, 0, 10)
            };
            mainLayout.Controls.Add(lblTitle, 0, 0);
            mainLayout.SetColumnSpan(lblTitle, 2);
            
            // Info
            var lblInfo = new Label 
            { 
                Text = "Los usuarios bloqueados no aparecerán en los resultados de búsqueda.", 
                AutoSize = true,
                ForeColor = Color.LightGray,
                Margin = new Padding(0, 0, 0, 20)
            };
            mainLayout.Controls.Add(lblInfo, 0, 1);
            mainLayout.SetColumnSpan(lblInfo, 2);
            
            // ListBox de usuarios
            var lstBlacklist = new ListBox 
            { 
                Dock = DockStyle.Fill,
                BackColor = Color.FromArgb(45, 45, 45), 
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 10),
                BorderStyle = BorderStyle.FixedSingle,
                Margin = new Padding(0, 0, 12, 0)
            };
            lstBlacklist.Items.AddRange(blacklist.ToArray());
            mainLayout.Controls.Add(lstBlacklist, 0, 2);
            
            // Panel de controles (derecha)
            var controlsLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 1,
                BackColor = Color.FromArgb(18, 18, 18),
                Padding = new Padding(8, 0, 0, 0)
            };
            controlsLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize));
            controlsLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize));
            controlsLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize));
            controlsLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize));
            controlsLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100f));

            var inputLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Top,
                ColumnCount = 1,
                AutoSize = true,
                BackColor = Color.FromArgb(18, 18, 18),
                Margin = new Padding(0, 0, 0, 12)
            };
            inputLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize));
            inputLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize));

            var lblUser = new Label
            {
                Text = "Usuario a bloquear",
                AutoSize = true,
                ForeColor = Color.LightGray,
                Font = new Font("Segoe UI", 9),
                Margin = new Padding(0, 0, 0, 6)
            };
            inputLayout.Controls.Add(lblUser, 0, 0);

            var txtUser = new TextBox 
            { 
                Dock = DockStyle.Top,
                BackColor = Color.FromArgb(60, 60, 60), 
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 10)
            };
            inputLayout.Controls.Add(txtUser, 0, 1);

            controlsLayout.Controls.Add(inputLayout, 0, 0);

            Button CreateBlacklistButton(string text, Color backColor, Padding? margin = null)
            {
                return new Button
                {
                    Text = text,
                    AutoSize = true,
                    Dock = DockStyle.Top,
                    BackColor = backColor,
                    ForeColor = Color.White,
                    FlatStyle = FlatStyle.Flat,
                    Font = new Font("Segoe UI", 10),
                    Margin = margin ?? new Padding(0, 0, 0, 8)
                };
            }

            var btnAdd = CreateBlacklistButton("➕ Agregar", Color.FromArgb(60, 60, 60));
            btnAdd.FlatAppearance.BorderSize = 0;
            btnAdd.Click += (s, e) =>
            {
                if (!string.IsNullOrWhiteSpace(txtUser.Text) && !blacklist.Contains(txtUser.Text))
                {
                    blacklist.Add(txtUser.Text);
                    lstBlacklist.Items.Add(txtUser.Text);
                    SaveBlacklist();
                    txtUser.Clear();
                }
            };
            controlsLayout.Controls.Add(btnAdd, 0, 1);

            var btnRemove = CreateBlacklistButton("❌ Eliminar", Color.FromArgb(60, 60, 60));
            btnRemove.FlatAppearance.BorderSize = 0;
            btnRemove.Click += (s, e) =>
            {
                if (lstBlacklist.SelectedItem != null)
                {
                    blacklist.Remove(lstBlacklist.SelectedItem.ToString());
                    lstBlacklist.Items.Remove(lstBlacklist.SelectedItem);
                    SaveBlacklist();
                }
            };
            controlsLayout.Controls.Add(btnRemove, 0, 2);

            var btnClear = CreateBlacklistButton("🗑️ Limpiar todo", Color.FromArgb(60, 60, 60), new Padding(0, 0, 0, 0));
            btnClear.FlatAppearance.BorderSize = 0;
            btnClear.Click += (s, e) =>
            {
                if (DarkMessageBox.Show("¿Eliminar todos los usuarios de la lista negra?", "Confirmar", MessageBoxButtons.YesNo, MessageBoxIcon.Question) == DialogResult.Yes)
                {
                    blacklist.Clear();
                    lstBlacklist.Items.Clear();
                    SaveBlacklist();
                }
            };
            controlsLayout.Controls.Add(btnClear, 0, 3);

            mainLayout.Controls.Add(controlsLayout, 1, 2);
            var tipsBlacklist = GetToolTip();
            tipsBlacklist.SetToolTip(lblTitle, "Usuarios bloqueados");
            tipsBlacklist.SetToolTip(lblInfo, "Estos usuarios serán ignorados en búsquedas y cola");
            tipsBlacklist.SetToolTip(lstBlacklist, "Usuarios actualmente bloqueados");
            tipsBlacklist.SetToolTip(txtUser, "Usuario a agregar a la lista negra");
            tipsBlacklist.SetToolTip(btnAdd, "Agregar usuario a la lista negra");
            tipsBlacklist.SetToolTip(btnRemove, "Eliminar usuario seleccionado de la lista negra");
            tipsBlacklist.SetToolTip(btnClear, "Vaciar por completo la lista negra");
            parent.Controls.Add(mainLayout);
        }
        
        private void BlacklistSelectedUser()
        {
            if (lvResults.SelectedItems.Count == 0)
                return;
            
            dynamic result = lvResults.SelectedItems[0].Tag;
            string username = (string)result.Username;
            
            if (!blacklist.Contains(username))
            {
                blacklist.Add(username);
                SaveBlacklist();
                Log($"⛔ Usuario '{username}' agregado a la lista negra");
            }
        }
        
        private void CancelDownload()
        {
            if (lvDownloads.SelectedItems.Count == 0)
                return;

            int cancelledByManager = 0;
            int cancelledManual = 0;

            var selectedItems = lvDownloads.SelectedItems.Cast<ListViewItem>().ToList();

            if (downloadManager != null)
            {
                foreach (var item in selectedItems)
                {
                    if (item.Tag is DownloadTask task)
                    {
                        if (downloadManager.CancelTask(task, removeFromQueue: true))
                        {
                            cancelledByManager++;
                            SafeInvoke(() =>
                            {
                                if (task.ListViewItem != null && lvDownloads.Items.Contains(task.ListViewItem))
                                {
                                    lvDownloads.Items.Remove(task.ListViewItem);
                                }
                                else if (lvDownloads.Items.Contains(item))
                                {
                                    lvDownloads.Items.Remove(item);
                                }
                            });
                        }
                    }
                }
            }

            foreach (var item in selectedItems)
            {
                var fileName = item.Text;
                if (activeDownloads.TryGetValue(fileName, out var cts))
                {
                    try { cts.Cancel(); } catch { }
                    // MEJORA FASE 1.2: TryRemove thread-safe
                    activeDownloads.TryRemove(fileName, out _);
                    cancelledManual++;
                    SafeInvoke(() => item.SubItems[3].Text = "⏹️ Cancelando...");
                }
            }

            if (cancelledByManager > 0)
            {
                AutoLog($"❌ {cancelledByManager} descarga(s) cancelada(s)");
            }
            else if (cancelledManual > 0)
            {
                AutoLog($"⏹️ {cancelledManual} descarga(s) manual(es) cancelada(s)");
            }
            else
            {
                DarkMessageBox.Show("No se pudo cancelar ninguna descarga seleccionada", "Cancelar descarga", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
        }

        private void PauseDownload()
        {
            if (lvDownloads.SelectedItems.Count == 0)
                return;

            if (downloadManager == null)
            {
                DarkMessageBox.Show("La pausa requiere el Download Manager refactorizado.", "Pausar descarga", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            var tasks = GetSelectedDownloadTasks();
            if (tasks.Count == 0)
            {
                DarkMessageBox.Show("Las descargas seleccionadas no forman parte de la cola.", "Pausar descarga", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            int pausedCount = 0;
            foreach (var task in tasks)
            {
                if (downloadManager.PauseTask(task))
                {
                    pausedCount++;
                }
            }

            if (pausedCount > 0)
            {
                AutoLog($"⏸️ {pausedCount} descarga(s) pausada(s)");
            }
            else
            {
                DarkMessageBox.Show("Solo se pueden pausar descargas activas o en cola.", "Pausar descarga", MessageBoxButtons.OK, MessageBoxIcon.Warning);
            }
        }

        private void ResumeDownload()
        {
            if (lvDownloads.SelectedItems.Count == 0)
                return;

            if (downloadManager == null)
            {
                DarkMessageBox.Show("La reanudación requiere el Download Manager refactorizado.", "Reanudar descarga", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            var tasks = GetSelectedDownloadTasks();
            if (tasks.Count == 0)
            {
                DarkMessageBox.Show("Las descargas seleccionadas no forman parte de la cola.", "Reanudar descarga", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            int resumedCount = 0;
            foreach (var task in tasks)
            {
                if (downloadManager.ResumeTask(task))
                {
                    resumedCount++;
                }
            }

            if (resumedCount > 0)
            {
                AutoLog($"▶️ {resumedCount} descarga(s) reanudada(s)");
                downloadManager.Start();
            }
            else
            {
                DarkMessageBox.Show("Solo se pueden reanudar descargas pausadas.", "Reanudar descarga", MessageBoxButtons.OK, MessageBoxIcon.Warning);
            }
        }
        
        
        private void AddUserToPremiumList()
        {
            var task = GetSelectedDownloadTask();
            if (task == null) return;
            
            string username = task.File.Username;
            
            if (premiumUsers.Contains(username))
            {
                ShowDarkDialog($"El usuario '{username}' ya está en la lista Premium", "Info", MessageBoxButtons.OK, "ℹ️");
                return;
            }
            
            premiumUsers.Add(username);
            SavePremiumUsers();
            
            Log($"⭐ Usuario agregado a lista Premium: {username}");
            ShowDarkDialog($"✅ Usuario '{username}' agregado a lista Premium\n\nEste usuario tendrá máxima prioridad en futuras descargas.", 
                "Usuario Premium", MessageBoxButtons.OK, "⭐");
        }
        
        private void RemoveUserFromPremiumList()
        {
            var task = GetSelectedDownloadTask();
            if (task == null) return;
            
            string username = task.File.Username;
            
            if (!premiumUsers.Contains(username))
            {
                ShowDarkDialog($"El usuario '{username}' no está en la lista Premium", "Info", MessageBoxButtons.OK, "ℹ️");
                return;
            }
            
            premiumUsers.Remove(username);
            SavePremiumUsers();
            
            Log($"❌ Usuario removido de lista Premium: {username}");
            ShowDarkDialog($"✅ Usuario '{username}' removido de lista Premium", 
                "Usuario Premium", MessageBoxButtons.OK, "✅");
        }
        
        private void ShowPremiumUsersList()
        {
            var form = new Form
            {
                Text = "⭐ Lista de Usuarios Premium",
                Size = new Size(600, 500),
                BackColor = Color.FromArgb(20, 20, 20),
                ForeColor = Color.White,
                StartPosition = FormStartPosition.CenterParent,
                Font = new Font("Segoe UI", 10)
            };
            
            var listBox = new ListBox
            {
                Dock = DockStyle.Fill,
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.White,
                Font = new Font("Consolas", 10),
                BorderStyle = BorderStyle.None
            };
            
            if (premiumUsers.Count == 0)
            {
                listBox.Items.Add("(No hay usuarios premium)");
            }
            else
            {
                foreach (var user in premiumUsers.OrderBy(u => u))
                {
                    var stats = GetProviderStats(user);
                    if (stats != null)
                    {
                        listBox.Items.Add($"⭐ {user} - Score: {stats.QualityScore:F0} | Velocidad: {stats.AverageSpeed:F2} MB/s | Éxito: {stats.SuccessRate:F1}%");
                    }
                    else
                    {
                        listBox.Items.Add($"⭐ {user} (sin estadísticas)");
                    }
                }
            }
            
            var buttonPanel = new Panel
            {
                Dock = DockStyle.Bottom,
                Height = 50,
                BackColor = Color.FromArgb(20, 20, 20)
            };
            
            var btnRemove = new Button
            {
                Text = "❌ Eliminar Seleccionado",
                Location = new Point(10, 10),
                Size = new Size(180, 30),
                BackColor = Color.FromArgb(180, 50, 50),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat
            };
            btnRemove.Click += (s, e) =>
            {
                if (listBox.SelectedItem != null)
                {
                    string item = listBox.SelectedItem.ToString();
                    string username = item.Split(' ')[1]; // Extraer username
                    
                    if (premiumUsers.Remove(username))
                    {
                        SavePremiumUsers();
                        Log($"❌ Usuario removido de lista Premium: {username}");
                        form.Close();
                        ShowPremiumUsersList(); // Reabrir actualizado
                    }
                }
            };
            
            var btnClose = new Button
            {
                Text = "Cerrar",
                Location = new Point(200, 10),
                Size = new Size(100, 30),
                BackColor = Color.FromArgb(60, 60, 60),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat
            };
            btnClose.Click += (s, e) => form.Close();
            
            buttonPanel.Controls.Add(btnRemove);
            buttonPanel.Controls.Add(btnClose);
            
            form.Controls.Add(listBox);
            form.Controls.Add(buttonPanel);
            
            form.ShowDialog();
        }
        
        private void SavePremiumUsers()
        {
            try
            {
                System.IO.File.WriteAllLines(premiumUsersPath, premiumUsers.OrderBy(u => u));
                Log($"💾 Lista Premium guardada ({premiumUsers.Count} usuarios)");
            }
            catch (Exception ex)
            {
                Log($"❌ Error guardando lista Premium: {ex.Message}");
            }
        }
        
        private void LoadPremiumUsers()
        {
            try
            {
                if (System.IO.File.Exists(premiumUsersPath))
                {
                    var lines = System.IO.File.ReadAllLines(premiumUsersPath);
                    premiumUsers = new HashSet<string>(lines.Where(l => !string.IsNullOrWhiteSpace(l)), StringComparer.OrdinalIgnoreCase);
                    Log($"📥 Lista Premium cargada ({premiumUsers.Count} usuarios)");
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error cargando lista Premium: {ex.Message}");
            }
        }
        
        private bool IsFileDownloaded(string path)
        {
            // Usar cache optimizado si está disponible
            if (useFileValidationCache && fileValidationCache != null)
            {
                if (fileValidationCache.TryGet(path, out bool exists, out long size))
                {
                    return exists;
                }
                
                // Cache miss: verificar archivo
                bool fileExists = System.IO.File.Exists(path);
                long fileSize = 0;
                DateTime lastModified = DateTime.MinValue;
                
                if (fileExists)
                {
                    try
                    {
                        var info = new FileInfo(path);
                        fileSize = info.Length;
                        lastModified = info.LastWriteTimeUtc;
                    }
                    catch { }
                }
                
                fileValidationCache.Set(path, fileExists, fileSize, lastModified);
                return fileExists;
            }
            
            // Fallback al cache antiguo
            lock (fileExistsCacheLock)
            {
                if (fileExistsCache.TryGetValue(path, out var cached))
                {
                    if (DateTime.Now - cached.checkedAt < cacheExpiration)
                        return cached.exists;
                }
                
                bool exists = System.IO.File.Exists(path);
                fileExistsCache[path] = (exists, DateTime.Now);
                return exists;
            }
        }
        
        private void InvalidateFileCache(string path)
        {
            if (useFileValidationCache && fileValidationCache != null)
            {
                fileValidationCache.Invalidate(path);
            }
            
            lock (fileExistsCacheLock)
            {
                fileExistsCache.Remove(path);
            }
        }
        
        private void ClearFileCache()
        {
            lock (fileExistsCacheLock)
            {
                fileExistsCache.Clear();
            }
        }
        
        private void BuildAuthorIndex()
        {
            lock (authorIndexLock)
            {
                filesByAuthorIndex.Clear();
                
                // OPTIMIZACIÓN: Usar procesamiento paralelo para grandes volúmenes (50K+ autores)
                List<AutoSearchFileResult> filesToIndex;
                lock (autoSearchResultsLock)
                {
                    filesToIndex = autoSearchResults.ToList();
                }
                
                var sw = System.Diagnostics.Stopwatch.StartNew();
                
                if (filesToIndex.Count > 500) // Reducido el umbral para usar paralelo antes
                {
                    // Procesamiento paralelo optimizado para 50K+ archivos
                    var tempIndex = new System.Collections.Concurrent.ConcurrentDictionary<string, System.Collections.Concurrent.ConcurrentBag<AutoSearchFileResult>>(
                        Environment.ProcessorCount * 4, 
                        60000, // Capacidad inicial para 50K+ autores
                        StringComparer.OrdinalIgnoreCase);
                    
                    // MEJORA #6: Limitar a 75% de cores
                    int maxParallelism = Math.Max(1, (int)(Environment.ProcessorCount * 0.75));
                    Parallel.ForEach(filesToIndex, 
                        new ParallelOptions { MaxDegreeOfParallelism = maxParallelism },
                        file =>
                        {
                            var bag = tempIndex.GetOrAdd(file.Author, _ => new System.Collections.Concurrent.ConcurrentBag<AutoSearchFileResult>());
                            bag.Add(file);
                        });
                    
                    // Convertir a diccionario normal con capacidad pre-allocada
                    foreach (var kvp in tempIndex)
                    {
                        filesByAuthorIndex[kvp.Key] = kvp.Value.ToList();
                    }
                    
                    sw.Stop();
                    AutoLog($"📇 Índice de autores construido (paralelo): {filesByAuthorIndex.Count:N0} autores, {filesToIndex.Count:N0} archivos en {sw.ElapsedMilliseconds}ms");
                }
                else
                {
                    // Procesamiento secuencial para pocos archivos
                    // MEJORA #8: Usar TryGetValue para evitar doble lookup
                    foreach (var file in filesToIndex)
                    {
                        if (!filesByAuthorIndex.TryGetValue(file.Author, out var authorFiles))
                        {
                            authorFiles = new List<AutoSearchFileResult>();
                            filesByAuthorIndex[file.Author] = authorFiles;
                        }
                        authorFiles.Add(file);
                    }
                    
                    sw.Stop();
                    AutoLog($"📇 Índice de autores construido: {filesByAuthorIndex.Count:N0} autores, {filesToIndex.Count:N0} archivos en {sw.ElapsedMilliseconds}ms");
                }
            }
        }
        
        private List<AutoSearchFileResult> SearchByAuthor(string authorQuery)
        {
            var results = new List<AutoSearchFileResult>();
            
            lock (authorIndexLock)
            {
                var matchingAuthors = filesByAuthorIndex.Keys
                    .Where(author => author.IndexOf(authorQuery, StringComparison.OrdinalIgnoreCase) >= 0)
                    .ToList();
                
                foreach (var author in matchingAuthors)
                {
                    results.AddRange(filesByAuthorIndex[author]);
                }
            }
            
            return results;
        }
        
        private void UpdateProviderStats(string username, bool success, double speedMBps, long bytes)
        {
            lock (providerStatsLock)
            {
                if (!providerStats.ContainsKey(username))
                {
                    providerStats[username] = new ProviderStats { Username = username };
                }
                
                var stats = providerStats[username];
                stats.TotalDownloads++;
                
                if (success)
                {
                    stats.SuccessfulDownloads++;
                    stats.TotalBytesDownloaded += bytes;
                    
                    // Calcular velocidad promedio ponderada
                    double totalSpeed = stats.AverageSpeed * (stats.SuccessfulDownloads - 1) + speedMBps;
                    stats.AverageSpeed = totalSpeed / stats.SuccessfulDownloads;
                }
                else
                {
                    stats.FailedDownloads++;
                }
                
                stats.LastDownload = DateTime.Now;
            }
        }
        
        private ProviderStats GetProviderStats(string username)
        {
            lock (providerStatsLock)
            {
                return providerStats.TryGetValue(username, out var stats) ? stats : null;
            }
        }
        
        private double GetProviderScore(string username)
        {
            var stats = GetProviderStats(username);
            return stats?.QualityScore ?? 0;
        }
        
        private async Task<bool> ShouldSkipDownloadDuplicate(AutoSearchFileResult file)
        {
            try
            {
                // 1. Verificación rápida: Ya descargado según historial
                if (IsAlreadyDownloaded(file.FileName, file.Username, file.SizeBytes))
                {
                    return true;
                }
                
                // 2. Buscar archivos con mismo nombre en disco
                var downloadPath = txtDownloadDir?.Text ?? 
                    Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments), "SlskDown");
                
                if (!System.IO.Directory.Exists(downloadPath))
                    return false;
                
                var existingFiles = System.IO.Directory.GetFiles(downloadPath, file.FileName, SearchOption.AllDirectories);
                
                if (!existingFiles.Any())
                    return false;
                
                // 3. Verificar por hash (ultra-rápido con Rust)
                foreach (var existingFile in existingFiles)
                {
                    try
                    {
                        var fileInfo = new FileInfo(existingFile);
                        
                        // Si el tamaño es diferente, no es duplicado
                        if (Math.Abs(fileInfo.Length - file.SizeBytes) > 1024) // Tolerancia de 1KB
                            continue;
                        
                        // Calcular hash del archivo existente
                        string existingHash = await Task.Run(() => 
                            SlskDownCore.HashFileBlake3(existingFile)
                        );
                        
                        // Buscar en historial si ya tenemos este hash
                        bool hashExists = false;
                        lock (downloadHistoryLock)
                        {
                            hashExists = downloadHistory.Any(h => 
                                h.Hash == existingHash && 
                                !string.IsNullOrEmpty(h.Hash)
                            );
                        }
                        
                        if (hashExists)
                        {
                            AutoLog($"🔍 Hash duplicado encontrado: {file.FileName}");
                            return true; // Es duplicado
                        }
                    }
                    catch (Exception ex)
                    {
                        AutoLog($"⚠️ Error verificando hash de {Path.GetFileName(existingFile)}: {ex.Message}");
                    }
                }
                
                return false; // No es duplicado
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error en verificación de duplicados: {ex.Message}");
                return false; // En caso de error, permitir descarga
            }
        }
        
        private void RenameToLibreFormat(string filePath, string author)
        {
            try
            {
                // Extensiones de ebooks soportadas
                string[] ebookExtensions = { ".epub", ".mobi", ".azw", ".azw3", ".pdf", ".fb2", ".lit", ".prc", ".djvu", ".cbr", ".cbz" };
                
                string extension = Path.GetExtension(filePath).ToLower();
                if (!ebookExtensions.Contains(extension))
                {
                    return; // No es un ebook, no renombrar
                }
                
                string fileName = Path.GetFileNameWithoutExtension(filePath);
                string directory = Path.GetDirectoryName(filePath);
                
                // Limpiar nombre del archivo
                string cleanTitle = CleanFileName(fileName);
                
                // Limpiar nombre del autor
                string cleanAuthor = CleanAuthorName(author);
                
                // Formato Calibre: "Título - Autor.ext"
                string newFileName = $"{cleanTitle} - {cleanAuthor}{extension}";
                string newFilePath = Path.Combine(directory, newFileName);
                
                // Evitar sobrescribir si ya existe
                if (System.IO.File.Exists(newFilePath))
                {
                    AutoLog($"⚠️ El archivo ya existe: {newFileName}");
                    return;
                }
                
                // Renombrar archivo
                System.IO.File.Move(filePath, newFilePath);
                AutoLog($"📚 Renombrado a formato Calibre: {newFileName}");
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error renombrando archivo: {ex.Message}");
            }
        }
        
        private string CleanFileName(string fileName)
        {
            // Remover caracteres inválidos y limpiar
            string cleaned = fileName;
            
            // OPTIMIZACIÓN: Usar Regex compilado cacheado
            cleaned = RegexFileExtensions.Replace(cleaned, "");
            
            // MEJORA #16: Usar StringBuilder para evitar múltiples allocaciones
            var sb = new System.Text.StringBuilder(cleaned.Length);
            bool lastWasSpace = false;
            
            foreach (char c in cleaned)
            {
                if (c == '_' || c == '.' || c == '-')
                {
                    if (!lastWasSpace)
                    {
                        sb.Append(' ');
                        lastWasSpace = true;
                    }
                }
                else if (char.IsWhiteSpace(c))
                {
                    if (!lastWasSpace)
                    {
                        sb.Append(' ');
                        lastWasSpace = true;
                    }
                }
                else
                {
                    sb.Append(c);
                    lastWasSpace = false;
                }
            }
            
            cleaned = sb.ToString();
            
            // Capitalizar primera letra de cada palabra
            cleaned = System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(cleaned.ToLower());
            
            return cleaned.Trim();
        }
        
        private string CleanAuthorName(string author)
        {
            if (string.IsNullOrWhiteSpace(author))
            {
                return "Unknown Author";
            }
            
            // MEJORA #16: Usar StringBuilder para evitar múltiples allocaciones
            var sb = new System.Text.StringBuilder(author.Length);
            bool lastWasSpace = false;
            
            foreach (char c in author)
            {
                if (c == '_' || c == '.')
                {
                    if (!lastWasSpace)
                    {
                        sb.Append(' ');
                        lastWasSpace = true;
                    }
                }
                else if (char.IsWhiteSpace(c))
                {
                    if (!lastWasSpace)
                    {
                        sb.Append(' ');
                        lastWasSpace = true;
                    }
                }
                else
                {
                    sb.Append(c);
                    lastWasSpace = false;
                }
            }
            
            string cleaned = sb.ToString();
            
            // Capitalizar nombre
            cleaned = System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(cleaned.ToLower());
            
            return cleaned.Trim();
        }
        
        private List<ProviderStats> GetTopProviders(int count = 10)
        {
            lock (providerStatsLock)
            {
                return providerStats.Values
                    .OrderByDescending(p => p.QualityScore)
                    .Take(count)
                    .ToList();
            }
        }
        
        private void InitializeLegacyDatabase()
        {
            try
            {
                SafeLog( "  - Creando connection string...\n");
                var connectionString = $"Data Source={dbPath}";
                SafeLog( $"  - DB Path: {dbPath}\n");
                
                SafeLog( "  - Creando SqliteConnection...\n");
                dbConnection = new SqliteConnection(connectionString);
                
                SafeLog( "  - Abriendo conexión...\n");
                dbConnection.Open();
                SafeLog( "  - Conexión abierta OK\n");
                
                // MEJORA #41: Optimizaciones de SQLite para máxima performance
                SafeLog( "  - Aplicando optimizaciones de SQLite...\n");
                using (var cmd = dbConnection.CreateCommand())
                {
                    cmd.CommandText = @"
                        PRAGMA journal_mode=WAL;           -- Write-Ahead Logging (3-5x mejor concurrencia)
                        PRAGMA synchronous=NORMAL;         -- Balance entre seguridad y velocidad
                        PRAGMA cache_size=-64000;          -- 64MB de caché en RAM
                        PRAGMA temp_store=MEMORY;          -- Tablas temporales en RAM
                        PRAGMA mmap_size=268435456;        -- 256MB memory-mapped I/O
                        PRAGMA page_size=4096;             -- Tamaño de página óptimo
                        PRAGMA auto_vacuum=INCREMENTAL;    -- Vacuum automático incremental
                    ";
                    cmd.ExecuteNonQuery();
                }
                SafeLog( "  - Optimizaciones aplicadas ✓\n");
                
                // Crear tablas
                SafeLog( "  - Preparando SQL para crear tablas...\n");
                var createTables = @"
                    CREATE TABLE IF NOT EXISTS Files (
                        Id INTEGER PRIMARY KEY AUTOINCREMENT,
                        FileName TEXT NOT NULL,
                        Author TEXT NOT NULL,
                        Username TEXT NOT NULL,
                        Directory TEXT,
                        SizeBytes INTEGER NOT NULL,
                        IsSpanish INTEGER DEFAULT 0,
                        IsDocument INTEGER DEFAULT 0,
                        Timestamp TEXT NOT NULL,
                        UNIQUE(FileName, Author, Username)
                    );
                    
                    CREATE TABLE IF NOT EXISTS DownloadHistory (
                        Id INTEGER PRIMARY KEY AUTOINCREMENT,
                        FileName TEXT NOT NULL,
                        Author TEXT,
                        Username TEXT NOT NULL,
                        SizeBytes INTEGER NOT NULL,
                        DownloadedAt TEXT NOT NULL,
                        Status TEXT NOT NULL,
                        SpeedMBps REAL,
                        LocalPath TEXT
                    );
                    
                    CREATE TABLE IF NOT EXISTS ProviderStats (
                        Username TEXT PRIMARY KEY,
                        TotalDownloads INTEGER DEFAULT 0,
                        SuccessfulDownloads INTEGER DEFAULT 0,
                        FailedDownloads INTEGER DEFAULT 0,
                        AverageSpeed REAL DEFAULT 0,
                        TotalBytesDownloaded INTEGER DEFAULT 0,
                        LastDownload TEXT
                    );
                    
                    -- Optimización #10: Índices inteligentes para queries frecuentes
                    CREATE INDEX IF NOT EXISTS idx_files_author ON Files(Author);
                    CREATE INDEX IF NOT EXISTS idx_files_filename ON Files(FileName);
                    CREATE INDEX IF NOT EXISTS idx_history_date ON DownloadHistory(DownloadedAt);
                    CREATE INDEX IF NOT EXISTS idx_provider_quality ON ProviderStats(SuccessfulDownloads, AverageSpeed);
                    
                    -- Índices compuestos para búsquedas complejas (100-1000x más rápido)
                    CREATE INDEX IF NOT EXISTS idx_files_author_filename ON Files(Author, FileName);
                    CREATE INDEX IF NOT EXISTS idx_files_author_spanish ON Files(Author, IsSpanish, IsDocument);
                    CREATE INDEX IF NOT EXISTS idx_files_size_ext ON Files(SizeBytes, FileName);
                    CREATE INDEX IF NOT EXISTS idx_files_timestamp_spanish ON Files(Timestamp, IsSpanish);
                    CREATE INDEX IF NOT EXISTS idx_files_spanish_doc ON Files(IsSpanish, IsDocument) WHERE IsSpanish = 1 AND IsDocument = 1;
                    CREATE INDEX IF NOT EXISTS idx_files_username_size ON Files(Username, SizeBytes);
                    
                    -- Índices para historial y estadísticas
                    CREATE INDEX IF NOT EXISTS idx_history_status ON DownloadHistory(Status, DownloadedAt);
                    CREATE INDEX IF NOT EXISTS idx_history_author ON DownloadHistory(Author);
                    CREATE INDEX IF NOT EXISTS idx_history_author_status ON DownloadHistory(Author, Status);
                    CREATE INDEX IF NOT EXISTS idx_provider_success_rate ON ProviderStats(SuccessfulDownloads, TotalDownloads);
                ";
                
                SafeLog( "  - Ejecutando CREATE TABLES...\n");
                using (var cmd = new SqliteCommand(createTables, dbConnection))
                {
                    cmd.ExecuteNonQuery();
                }
                SafeLog( "  - Tablas e índices creados OK\n");
                
                // PRAGMA OPTIMIZATIONS para máximo rendimiento
                SafeLog( "  - Aplicando PRAGMA optimizations...\n");
                var pragmas = @"
                    PRAGMA journal_mode = WAL;
                    PRAGMA synchronous = NORMAL;
                    PRAGMA cache_size = -64000;
                    PRAGMA temp_store = MEMORY;
                    PRAGMA mmap_size = 268435456;
                    PRAGMA page_size = 4096;
                    PRAGMA auto_vacuum = INCREMENTAL;
                ";
                
                using (var cmd = new SqliteCommand(pragmas, dbConnection))
                {
                    cmd.ExecuteNonQuery();
                }
                SafeLog( "  - PRAGMA optimizations aplicadas OK\n");
                
                AutoLog("✅ Base de datos SQLite inicializada");
                
                // Migrar datos existentes si es necesario
                SafeLog( "  - Iniciando migración CSV...\n");
                MigrateFromCsvToSqlite();
                SafeLog( "  - Migración completada\n");
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error inicializando base de datos: {ex.Message}");
            }
        }
        
