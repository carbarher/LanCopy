                html.AppendLine("        body { font-family: 'Segoe UI', Arial, sans-serif; background: linear-gradient(135deg, #1e1e1e 0%, #2d2d2d 100%); color: #e0e0e0; padding: 20px; }");
                html.AppendLine("        .container { max-width: 1400px; margin: 0 auto; background: #2a2a2a; border-radius: 10px; padding: 30px; box-shadow: 0 10px 40px rgba(0,0,0,0.5); }");
                html.AppendLine("        h1 { color: #4CAF50; margin-bottom: 10px; font-size: 2.5em; text-align: center; text-shadow: 2px 2px 4px rgba(0,0,0,0.5); }");
                html.AppendLine("        .stats { background: #1e1e1e; padding: 20px; border-radius: 8px; margin: 20px 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; }");
                html.AppendLine("        .stat-item { text-align: center; padding: 15px; background: #2d2d2d; border-radius: 5px; border-left: 4px solid #4CAF50; }");
                html.AppendLine("        .stat-value { font-size: 2em; font-weight: bold; color: #4CAF50; }");
                html.AppendLine("        .stat-label { font-size: 0.9em; color: #888; margin-top: 5px; }");
                html.AppendLine("        .search-box { margin: 20px 0; }");
                html.AppendLine("        .search-box input { width: 100%; padding: 15px; font-size: 16px; border: 2px solid #4CAF50; border-radius: 5px; background: #1e1e1e; color: #e0e0e0; }");
                html.AppendLine("        table { width: 100%; border-collapse: collapse; margin-top: 20px; background: #1e1e1e; border-radius: 8px; overflow: hidden; }");
                html.AppendLine("        th { background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%); color: white; padding: 15px; text-align: left; font-weight: 600; position: sticky; top: 0; z-index: 10; }");
                html.AppendLine("        td { padding: 12px 15px; border-bottom: 1px solid #333; }");
                html.AppendLine("        tr:hover { background: #2d2d2d; }");
                html.AppendLine("        .status-downloaded { color: #4CAF50; font-weight: bold; }");
                html.AppendLine("        .status-pending { color: #FFC107; }");
                html.AppendLine("        .badge { display: inline-block; padding: 4px 8px; border-radius: 3px; font-size: 0.85em; font-weight: bold; }");
                html.AppendLine("        .badge-yes { background: #4CAF50; color: white; }");
                html.AppendLine("        .badge-no { background: #666; color: white; }");
                html.AppendLine("        .footer { text-align: center; margin-top: 30px; padding-top: 20px; border-top: 1px solid #333; color: #666; }");
                html.AppendLine("    </style>");
                html.AppendLine("</head>");
                html.AppendLine("<body>");
                html.AppendLine("    <div class='container'>");
                html.AppendLine("        <h1>📥 SlskDown - Resultados de Búsqueda</h1>");
                
                // Estadísticas
                // MEJORA FASE 1.3: lock para snapshot de solo lectura
                int totalFiles, uniqueAuthors, spanishFiles;
                double totalSize;
                lock (autoSearchResultsLock)
                {
                    totalFiles = autoSearchResults.Count;
                    uniqueAuthors = autoSearchResults.Select(f => f.Author).Distinct().Count();
                    totalSize = autoSearchResults.Sum(f => f.SizeBytes) / 1024.0 / 1024.0 / 1024.0;
                    spanishFiles = autoSearchResults.Count(f => f.IsSpanish);
                }
                
                html.AppendLine("        <div class='stats'>");
                html.AppendLine($"            <div class='stat-item'><div class='stat-value'>{totalFiles:N0}</div><div class='stat-label'>Total Archivos</div></div>");
                html.AppendLine($"            <div class='stat-item'><div class='stat-value'>{uniqueAuthors}</div><div class='stat-label'>Autores Únicos</div></div>");
                html.AppendLine($"            <div class='stat-item'><div class='stat-value'>{totalSize:F2} GB</div><div class='stat-label'>Tamaño Total</div></div>");
                html.AppendLine($"            <div class='stat-item'><div class='stat-value'>{spanishFiles}</div><div class='stat-label'>En Español</div></div>");
                html.AppendLine("        </div>");
                
                html.AppendLine("        <div class='search-box'>");
                html.AppendLine("            <input type='text' id='searchInput' placeholder='🔍 Buscar por nombre de archivo o autor...' onkeyup='filterTable()'>");
                html.AppendLine("        </div>");
                
                html.AppendLine("        <table id='resultsTable'>");
                html.AppendLine("            <thead>");
                html.AppendLine("                <tr>");
                html.AppendLine("                    <th>Estado</th>");
                html.AppendLine("                    <th>Autor</th>");
                html.AppendLine("                    <th>Archivo</th>");
                html.AppendLine("                    <th>Tamaño</th>");
                html.AppendLine("                    <th>Usuario</th>");
                html.AppendLine("                    <th>Español</th>");
                html.AppendLine("                    <th>Doc</th>");
                html.AppendLine("                    <th>Fecha</th>");
                html.AppendLine("                </tr>");
                html.AppendLine("            </thead>");
                html.AppendLine("            <tbody>");
                
                foreach (ListViewItem item in listView.Items)
                {
                    var file = (AutoSearchFileResult)item.Tag;
                    var statusClass = item.SubItems[0].Text.Contains("✓") ? "status-downloaded" : "status-pending";
                    
                    html.AppendLine("                <tr>");
                    html.AppendLine($"                    <td class='{statusClass}'>{System.Web.HttpUtility.HtmlEncode(item.SubItems[0].Text)}</td>");
                    html.AppendLine($"                    <td>{System.Web.HttpUtility.HtmlEncode(file.Author)}</td>");
                    html.AppendLine($"                    <td>{System.Web.HttpUtility.HtmlEncode(file.FileName)}</td>");
                    html.AppendLine($"                    <td>{System.Web.HttpUtility.HtmlEncode(file.SizeReadable)}</td>");
                    html.AppendLine($"                    <td>{System.Web.HttpUtility.HtmlEncode(file.Username)}</td>");
                    html.AppendLine($"                    <td><span class='badge badge-{(file.IsSpanish ? "yes" : "no")}'>{(file.IsSpanish ? "Sí" : "No")}</span></td>");
                    html.AppendLine($"                    <td><span class='badge badge-{(file.IsDocument ? "yes" : "no")}'>{(file.IsDocument ? "Sí" : "No")}</span></td>");
                    html.AppendLine($"                    <td>{file.Timestamp:yyyy-MM-dd HH:mm}</td>");
                    html.AppendLine("                </tr>");
                }
                
                html.AppendLine("            </tbody>");
                html.AppendLine("        </table>");
                html.AppendLine($"        <div class='footer'>Generado el {DateTime.Now:dd/MM/yyyy HH:mm:ss} por SlskDown</div>");
                html.AppendLine("    </div>");
                
                // JavaScript para búsqueda
                html.AppendLine("    <script>");
                html.AppendLine("        function filterTable() {");
                html.AppendLine("            var input = document.getElementById('searchInput');");
                html.AppendLine("            var filter = input.value.toUpperCase();");
                html.AppendLine("            var table = document.getElementById('resultsTable');");
                html.AppendLine("            var tr = table.getElementsByTagName('tr');");
                html.AppendLine("            for (var i = 1; i < tr.length; i++) {");
                html.AppendLine("                var td = tr[i].getElementsByTagName('td');");
                html.AppendLine("                var found = false;");
                html.AppendLine("                for (var j = 0; j < td.length; j++) {");
                html.AppendLine("                    if (td[j].innerHTML.toUpperCase().indexOf(filter) > -1) {");
                html.AppendLine("                        found = true;");
                html.AppendLine("                        break;");
                html.AppendLine("                    }");
                html.AppendLine("                }");
                html.AppendLine("                tr[i].style.display = found ? '' : 'none';");
                html.AppendLine("            }");
                html.AppendLine("        }");
                html.AppendLine("    </script>");
                html.AppendLine("</body>");
                html.AppendLine("</html>");
                
                System.IO.File.WriteAllText(htmlPath, html.ToString(), Encoding.UTF8);
                
                // Abrir en navegador
                Process.Start(new ProcessStartInfo { FileName = htmlPath, UseShellExecute = true });
                
                AutoLog($"💾 Exportado a HTML: {htmlPath}");
                MessageBox.Show($"Exportado exitosamente a:\n{htmlPath}\n\nEl archivo se ha abierto en tu navegador.", "Exportar HTML", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error exportando a HTML: {ex.Message}");
                MessageBox.Show($"Error al exportar: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        /// <summary>
        /// Procesa un autor individual en paralelo (usado por purga paralela)
        /// NOTA: Método legacy, no se usa actualmente
        /// </summary>
        private async Task ProcessSingleAuthorPurge(
            string author,
            CancellationToken cancellationToken,
            int authorNumber,
            int totalAuthors)
        {
            try
            {
                UpdateAuthorStatus(author, "🔍 Buscando...");
                
                // Usar búsqueda con caché
                var validFiles = await SearchAuthorWithCache(author, cancellationToken);
                
                if (validFiles.Count > 0)
                {
                    lock (purgeAuthorsWithFiles) purgeAuthorsWithFiles.Add(author);
                    
                    // Agregar archivos válidos a autoSearchResults
                    lock (autoSearchResultsLock)
                    {
                        autoSearchResults.AddRange(validFiles);
                    }
                    
                    AutoLog($"        ✅ {author}: {validFiles.Count} archivos válidos → Conservado");
                    UpdateAuthorData(author, validFiles.Count, "✅ Válido", UIColors.AuthorSuccess);
                }
                else
                {
                    AutoLog($"        ❌ {author}: 0 archivos válidos → Eliminado de la lista");
                    UpdateAuthorData(author, 0, "❌ Eliminado", UIColors.AuthorError);
                }
                
                // NUEVO: Marcar autor como procesado y guardar checkpoint periódicamente
                purgeProcessedAuthors.Add(author);
                if ((DateTime.UtcNow - purgeCheckpointLastSave).TotalSeconds >= CHECKPOINT_SAVE_INTERVAL_SECONDS)
                {
                    SavePurgeCheckpoint();
                }
                    
                // Eliminar inmediatamente si no tiene archivos
                if (validFiles.Count == 0)
                {
                    SafeInvoke(() =>
                    {
                        try
                        {
                            var authorData = allAuthorsData.FirstOrDefault(a => a.Name.Equals(author, StringComparison.OrdinalIgnoreCase));
                            if (authorData != null)
                            {
                                allAuthorsData.Remove(authorData);
                                authorIndex.Remove(author);
                                
                                var filteredAuthor = filteredAuthorsData.FirstOrDefault(a => a.Name.Equals(author, StringComparison.OrdinalIgnoreCase));
                                if (filteredAuthor != null)
                                {
                                    filteredAuthorsData.Remove(filteredAuthor);
                                }
                                
                                if (lvAutoAuthors != null && lvAutoAuthors.IsHandleCreated)
                                {
                                    var itemToRemove = lvAutoAuthors.Items.Cast<ListViewItem>()
                                        .FirstOrDefault(item => item.Text.Equals(author, StringComparison.OrdinalIgnoreCase));
                                    if (itemToRemove != null)
                                    {
                                        lvAutoAuthors.Items.Remove(itemToRemove);
                                    }
                                    UpdateAuthorCount();
                                }
                            }
                        }
                        catch { }
                    });
                }
            }
            catch (OperationCanceledException)
            {
                AutoLog($"        ⏹️ {author}: Búsqueda cancelada");
                UpdateAuthorData(author, 0, "⏹️ Cancelado", UIColors.AuthorReady);
            }
            catch (Exception ex)
            {
                AutoLog($"        ⚠️ Error buscando {author}: {ex.Message}");
                UpdateAuthorData(author, 0, $"⚠️ Error", UIColors.AuthorError);
            }
        }

        private async Task PurgeAuthorsWithoutResults()
        {
            // MEJORA #5: Limpiar cachés antiguos antes de iniciar purga
            CleanupExpiredCaches();
            
            // DIAGNÓSTICO DETALLADO - GRABADO INMEDIATAMENTE A DISCO
            CriticalLog("═══════════════════════════════════════════════════");
            CriticalLog("🔍 DIAGNÓSTICO DE PURGA:");
            CriticalLog($"   • Autores cargados: {allAuthorsData.Count:N0}");
            
            // ADVERTENCIA: Demasiados autores cargados
            if (allAuthorsData.Count > 1000)
            {
                CriticalLog($"⚠️ ADVERTENCIA: {allAuthorsData.Count:N0} autores cargados");
                CriticalLog($"   💡 Recomendación: Usa modo incremental (100 autores a la vez)");
                CriticalLog($"   🔄 Recarga el archivo para activar modo incremental automático");
                AutoLog($"");
                AutoLog($"⚠️ ADVERTENCIA: Tienes {allAuthorsData.Count:N0} autores cargados");
                AutoLog($"   💡 Con tantos autores, la purga puede ser lenta");
                AutoLog($"   🔄 Recomendación: Recarga el archivo para usar modo incremental (100 a la vez)");
                AutoLog($"");
            }
            
            CriticalLog($"   • Cliente: {(client == null ? "NULL" : "OK")}");
            if (client != null)
            {
                CriticalLog($"   • Estado conexión: {client.State}");
                CriticalLog($"   • Connected: {client.State.HasFlag(SoulseekClientStates.Connected)}");
                CriticalLog($"   • LoggedIn: {client.State.HasFlag(SoulseekClientStates.LoggedIn)}");
            }
            
            if (allAuthorsData.Count == 0 || client == null || 
                (!client.State.HasFlag(SoulseekClientStates.Connected) && !client.State.HasFlag(SoulseekClientStates.LoggedIn)))
            {
                CriticalLog("❌ No se puede purgar: lista vacía o no conectado.");
                CriticalLog("═══════════════════════════════════════════════════");
                return;
            }

            // NUEVO: Intentar cargar checkpoint de sesión anterior PRIMERO
            bool checkpointLoaded = LoadPurgeCheckpoint();
            
            // Solo obtener autores de la UI si NO hay checkpoint
            if (!checkpointLoaded)
            {
                CriticalLog("✅ Paso 1: Obteniendo lista de autores (seleccionados)...");
                purgeAllAuthors.Clear();
                try
                {
                    if (lvAutoAuthors != null)
                    {
                        purgeAllAuthors = lvAutoAuthors.Items
                            .Cast<ListViewItem>()
                            .Where(it => it.Checked)
                            .Select(it => it.Text)
                            .ToList();
                    }
                }
                catch { }
                CriticalLog($"✅ Paso 2: Obtenidos {purgeAllAuthors.Count:N0} autores seleccionados");
                
                if (purgeAllAuthors.Count == 0)
                {
                    CriticalLog("❌ No hay autores seleccionados para purgar");
                    CriticalLog("═══════════════════════════════════════════════════");
                    return;
                }
            }
            else
            {
                CriticalLog($"✅ Paso 1-2: Lista de autores restaurada desde checkpoint ({purgeAllAuthors.Count:N0} autores)");
            }
            
            // Si se cargó un checkpoint, filtrar autores ya procesados
            if (checkpointLoaded && purgeProcessedAuthors.Count > 0)
            {
                int originalCount = purgeAllAuthors.Count;
                purgeAllAuthors = purgeAllAuthors.Where(a => !purgeProcessedAuthors.Contains(a)).ToList();
                CriticalLog($"✅ Checkpoint aplicado: {originalCount - purgeAllAuthors.Count} autores ya procesados, quedan {purgeAllAuthors.Count}");
                
                if (purgeAllAuthors.Count == 0)
                {
                    CriticalLog("✅ Purga ya completada según checkpoint");
                    CriticalLog("═══════════════════════════════════════════════════");
                    DeletePurgeCheckpoint();
                    return;
                }
            }
            
            CriticalLog("✅ Validaciones pasadas, iniciando purga...");
            CriticalLog("═══════════════════════════════════════════════════");
            
            // MEJORA #2: Iniciar sesión de métricas
            StartPurgeSession();

            // OPTIMIZACIÓN #4: PROCESAMIENTO INCREMENTAL - Dividir en chunks para evitar desconexiones
            CriticalLog("✅ Paso 3: Preparando procesamiento incremental...");
            int totalAuthors = purgeAllAuthors.Count;
            const int CHUNK_SIZE = 100; // Procesar 100 autores por chunk
            int totalChunks = (int)Math.Ceiling(totalAuthors / (double)CHUNK_SIZE);
            bool useIncrementalMode = totalAuthors > 200; // Activar modo incremental si hay más de 200 autores
            
            if (useIncrementalMode)
            {
                CriticalLog($"✅ Paso 4: MODO INCREMENTAL activado - {totalChunks} chunks de {CHUNK_SIZE} autores");
                AutoLog($"📦 MODO INCREMENTAL: Procesando {totalAuthors:N0} autores en {totalChunks} chunks");
                AutoLog($"   📦 Tamaño de chunk: {CHUNK_SIZE} autores");
                AutoLog($"   ⏸️ Pausa entre chunks: 5 minutos");
                AutoLog($"   💡 Esto evita desconexiones y permite procesar grandes cantidades");
            }
            else
            {
                CriticalLog($"✅ Paso 4: Procesando todos los {totalAuthors:N0} autores (modo normal)");
                AutoLog($"   📦 Total de autores a procesar: {totalAuthors:N0}");
                AutoLog($"   💡 Los autores sin archivos válidos se eliminarán automáticamente");
            }
            AutoLog($"   ⏱️ Esto puede tomar tiempo, pero procesará todos los autores");

            AutoLog("");
            AutoLog($"🧹 PURGA: Verificando {purgeAllAuthors.Count} autores...");
            if (chkAutoSpanishDocuments?.Checked == true) AutoLog("   Filtro: Solo documentos en español");
            if (autoMinSearchSizeKB > 0) AutoLog($"   Filtro: Tamaño mínimo {autoMinSearchSizeKB} KB");
            AutoLog($"⏱️ Tiempo estimado: {(purgeAllAuthors.Count * 20 / 60):F0} minutos (modo conservador)");
            AutoLog($"   • Delay base: 12-20s entre búsquedas");
            AutoLog($"   • Pausas anti-patrón: 25-35s cada 10 búsquedas");
            AutoLog($"   • Pausas de cortesía: 90-150s cada 10 búsquedas");
            AutoLog("");

            CriticalLog("✅ Paso 5: Configurando estado de purga...");
            autoPurgeRunning = true;

            CriticalLog("✅ Paso 6: Creando CancellationToken...");
            autoSearchCts?.Dispose();
            autoSearchCts = new CancellationTokenSource();
            var cancellationToken = autoSearchCts.Token;

            CriticalLog("✅ Paso 7: Habilitando botones...");
            // Habilitar botón Detener DIRECTAMENTE
            if (btnStopAuto != null)
            {
                btnStopAuto.Enabled = true;
                btnStopAuto.BackColor = Color.FromArgb(0, 255, 0); // Verde
                btnStopAuto.Refresh();
            }
            if (btnPurge != null)
                btnPurge.Enabled = false;
            if (btnStartAuto != null)
                btnStartAuto.Enabled = false;
                
            CriticalLog("✅ Paso 8: Botones configurados");
            CriticalLog("✅ Paso 9: Actualizando UI de progreso...");
            SafeInvoke(() => { if (lblPurgeProgress != null) { lblPurgeProgress.Visible = true; lblPurgeProgress.Text = $"⏳ 0/{purgeAllAuthors.Count} (0%) | Purga..."; } });
            SafeInvoke(() => { if (lblAutoProgress != null) lblAutoProgress.Text = $"Progreso: 0/{purgeAllAuthors.Count} (0%)"; });

            CriticalLog("✅ Paso 10: Pausando Auto-Tuning y Keep-Alive...");
            // Pausar Auto-Tuning durante purga (opción C)
            if (autoTuner != null && useAutoTuning)
            {
                EnsureAutoTuningState(true);
                pausedAutoTuningByPurge = true;
                AutoLog("🛑 Auto-Tuning PAUSADO durante purga");
            }
            
            // MEJORA #48: Keep-alive ahora es TCP nativo (no necesita detenerse)
            // El TCP Keep-Alive del SO se mantiene activo durante la purga sin interferir
            // pausedKeepAliveByPurge = keepAliveTimer != null && keepAliveTimer.Enabled;
            CriticalLog("✅ TCP Keep-Alive nativo permanece activo durante purga");

            CriticalLog("✅ Paso 11: Esperando 2 segundos antes de iniciar...");
            await DelayWithCancellation(TimeSpan.FromSeconds(2), cancellationToken);
            CriticalLog("✅ Paso 12: Delay completado, iniciando bucle de purga...");

            // Solo resetear si NO se cargó un checkpoint
            if (!checkpointLoaded)
            {
                purgeAuthorsWithFiles.Clear();
                purgeSearchCount = 0; // Contador para pausas inteligentes
            }
            else
            {
                CriticalLog($"✅ Manteniendo estado del checkpoint: {purgeAuthorsWithFiles.Count} autores con archivos, {purgeSearchCount} búsquedas realizadas");
            }
            
            // MEJORA #7: Inicializar tracker de progreso con ETA
            // Si hay checkpoint, ajustar el total para reflejar el progreso real
            int totalAuthorsForTracker = checkpointLoaded ? 
                purgeAllAuthors.Count + purgeProcessedAuthors.Count : 
                purgeAllAuthors.Count;
            purgeProgressTracker = new SlskDown.Core.PurgeProgressTracker(totalAuthorsForTracker);
            
            // Si hay checkpoint, marcar los autores ya procesados
            if (checkpointLoaded && purgeProcessedAuthors.Count > 0)
            {
                purgeProgressTracker.RecordProgress(purgeProcessedAuthors.Count);
                CriticalLog($"✅ Progress Tracker inicializado: {purgeProcessedAuthors.Count}/{totalAuthorsForTracker} ya procesados");
            }
            else
            {
                CriticalLog($"✅ Progress Tracker inicializado para {purgeAllAuthors.Count} autores");
            }

            CriticalLog("✅ Paso 13: Inicializando estados de autores...");
            // OPTIMIZACIÓN: No actualizar UI durante inicialización (demasiado lento con 55K autores)
            // Solo actualizar el modelo de datos
            await Task.Run(() =>
            {
                foreach (var author in purgeAllAuthors)
                {
                    if (authorIndex.TryGetValue(author, out var authorData))
                    {
                        authorData.Status = "⏳ En cola";
                    }
                }
            });
            CriticalLog($"✅ Paso 14: {purgeAllAuthors.Count} autores inicializados (sin actualizar UI)");

            try
            {
                CriticalLog("✅ Paso 15: ENTRANDO AL BUCLE PRINCIPAL DE PURGA");
                CriticalLog($"   • Total autores a procesar: {purgeAllAuthors.Count}");
                CriticalLog($"   • Ultra Safe Mode: {ultraSafePurgeMode}");
                CriticalLog($"   • Conservative Mode: {conservativeMode}");
                CriticalLog($"   • Batch Size Paralelo: {purgeBatchSize}");
                
                // Inicializar semáforo para paralelización
                if (purgeSemaphore == null || purgeSemaphore.CurrentCount != purgeBatchSize)
                {
                    purgeSemaphore?.Dispose();
                    purgeSemaphore = new SemaphoreSlim(purgeBatchSize, purgeBatchSize);
                }
                
                AutoLog($"🚀 MODO PARALELO: Procesando {purgeBatchSize} autores simultáneamente");
                
                // OPTIMIZACIÓN #4: Procesar en chunks si hay muchos autores
                int processedCount = 0;
                
                if (useIncrementalMode)
                {
                    // Procesar por chunks
                    for (int chunkIndex = 0; chunkIndex < totalChunks; chunkIndex++)
                    {
                        var chunkAuthors = purgeAllAuthors.Skip(chunkIndex * CHUNK_SIZE).Take(CHUNK_SIZE).ToList();
                        AutoLog($"");
                        AutoLog($"📦 CHUNK {chunkIndex + 1}/{totalChunks}: Procesando {chunkAuthors.Count} autores");
                        CriticalLog($"📦 Iniciando chunk {chunkIndex + 1}/{totalChunks} ({chunkAuthors.Count} autores)");
                        
                        int chunkProcessed = await ProcessAuthorChunk(chunkAuthors, cancellationToken);
                        processedCount += chunkProcessed;
                        
                        // Pausa entre chunks (excepto después del último)
                        if (chunkIndex < totalChunks - 1 && autoPurgeRunning && !cancellationToken.IsCancellationRequested)
                        {
                            AutoLog($"");
                            AutoLog($"⏸️ PAUSA ENTRE CHUNKS: 5 minutos para evitar sobrecarga");
                            AutoLog($"   📊 Progreso: {processedCount}/{totalAuthors} autores procesados ({(processedCount * 100.0 / totalAuthors):F1}%)");
                            CriticalLog($"⏸️ Pausa entre chunks: 5 minutos");
                            await DelayWithCancellation(TimeSpan.FromMinutes(5), cancellationToken);
                            AutoLog($"✅ Continuando con siguiente chunk...");
                        }
                    }
                }
                else
                {
                    // Modo normal: procesar todos juntos
                    processedCount = await ProcessAuthorChunk(purgeAllAuthors, cancellationToken);
                }
                
                // Resumen después de procesar todos los chunks
                // Actualizar grilla y guardar lista final (las eliminaciones ya se hicieron durante el proceso)
                filteredAuthorsData = new List<AuthorData>(allAuthorsData);
                RefreshAuthorsListView();
                UpdateAuthorCount();
                
                int totalProcessed = purgeSearchCount;
                int totalValid = purgeAuthorsWithFiles.Count;
                int totalRemoved = totalProcessed - totalValid;
                
                AutoLog($"\n📊 RESUMEN DE PURGA:");
                AutoLog($"   • Total procesados: {totalProcessed}");
                AutoLog($"   • Autores válidos: {totalValid}");
                AutoLog($"   • Autores eliminados: {totalRemoved}");
                
                // Guardar automáticamente la lista actualizada (sin los purgados)
                if (totalRemoved > 0)
                {
                    try
                    {
                        var validatedSnapshot = purgeAuthorsWithFiles.ToList(); // GetValidatedAuthorsSnapshot(); // TODO: Implementar
                        SaveAuthorsToFile(validatedSnapshot);
                        // ApplyValidatedAuthorsSnapshot(validatedSnapshot); // TODO: Implementar
                        AutoLog($"💾 Lista actualizada y guardada: {validatedSnapshot.Count} autores restantes");
                    }
                    catch (Exception ex)
                    {
                        AutoLog($"⚠️ Error al guardar lista actualizada: {ex.Message}");
                    }
                }

                if (cancellationToken.IsCancellationRequested)
                {
                    AutoLog($"\n⏹️ PURGA CANCELADA: {purgeAuthorsWithFiles.Count} válidos verificados, {totalRemoved} eliminados");
                    
                    // Guardar también cuando se cancela (si hubo cambios)
                    if (totalRemoved > 0)
                    {
                        try
                        {
                            var validatedSnapshot = purgeAuthorsWithFiles.ToList(); // GetValidatedAuthorsSnapshot(); // TODO: Implementar
                            SaveAuthorsToFile(validatedSnapshot);
                            // ApplyValidatedAuthorsSnapshot(validatedSnapshot); // TODO: Implementar
                            AutoLog($"💾 Lista parcial guardada: {validatedSnapshot.Count} autores restantes");
                        }
                        catch (Exception ex)
                        {
                            AutoLog($"⚠️ Error al guardar lista: {ex.Message}");
                        }
                    }
                    
                    AutoLog($"");
                    SafeInvoke(() => { if (lblPurgeProgress != null) lblPurgeProgress.Text = "⏹️ Purga cancelada"; });
                    var pct = (int)Math.Floor(purgeSearchCount * 100.0 / purgeAllAuthors.Count);
                    SafeInvoke(() => { if (lblAutoProgress != null) lblAutoProgress.Text = $"Progreso: {purgeSearchCount}/{purgeAllAuthors.Count} ({pct}%)"; });
                }
                else
                {
                    AutoLog($"\n✅ PURGA COMPLETADA: {purgeAuthorsWithFiles.Count} con archivos válidos, {totalRemoved} eliminados\n");
                    SafeInvoke(() => { if (lblPurgeProgress != null) lblPurgeProgress.Text = "✅ Purga completada"; });
                    SafeInvoke(() => { if (lblAutoProgress != null) lblAutoProgress.Text = $"Progreso: {purgeAllAuthors.Count}/{purgeAllAuthors.Count} (100%)"; });
                    
                    // MEJORA: Notificar purga completada
                    try
                    {
                        var purgeDuration = purgeProgressTracker != null 
                            ? TimeSpan.FromSeconds(purgeProgressTracker.ElapsedSeconds) 
                            : TimeSpan.Zero;
                        notificationService?.NotifyPurgeCompleted(purgeAllAuthors.Count, purgeAuthorsWithFiles.Count, purgeDuration);
                    }
                    catch { }
                }
            }
            catch (Exception ex)
            {
                CriticalLog($"❌ Error en bucle principal: {ex.Message}");
                AutoLog($"❌ Error en purga: {ex.Message}");
            }
            finally
            {
                autoPurgeRunning = false;
                
                // MEJORA #2: Finalizar sesión de métricas
                EndPurgeSession();
                
                // NUEVO: Guardar checkpoint final y limpiar
                SavePurgeCheckpoint();
                DeletePurgeCheckpoint();

                if (pausedAutoTuningByPurge)
                {
                    try
                    {
                        EnsureAutoTuningState(false);
                    }
                    catch (Exception tunerEx)
                    {
                        Log($"⚠️ Error reanudando Auto-Tuning tras purga: {tunerEx.Message}");
                    }
                    finally
                    {
                        pausedAutoTuningByPurge = false;
                    }
                }

                // Restaurar botones DIRECTAMENTE
                if (btnStopAuto != null)
                {
                    btnStopAuto.Enabled = false;
                    btnStopAuto.BackColor = Color.FromArgb(150, 0, 0); // Rojo oscuro
                    btnStopAuto.Refresh();
                }
                if (btnPurge != null)
                    btnPurge.Enabled = true;
                if (btnStartAuto != null)
                    btnStartAuto.Enabled = true;
                    
                UpdateAutoControlsEnabled();
            }
        }

        // OPTIMIZACIÓN #4: Método auxiliar para procesar un chunk de autores CON PARALELIZACIÓN REAL
        private async Task<int> ProcessAuthorChunk(List<string> authors, CancellationToken cancellationToken)
        {
            int processedCount = 0;
            
            // Calcular paralelismo óptimo según salud de conexión
            int optimalParallelism = GetOptimalParallelism();
            if (optimalParallelism != purgeParallelism)
            {
                purgeParallelism = optimalParallelism;
                AutoLog($"🔧 Paralelismo ajustado: {purgeParallelism} búsquedas simultáneas");
                CriticalLog($"🔧 Paralelismo: {purgeParallelism} (Health: {connectionHealthScore:F0}, Latency: {averageLatency:F0}ms)");
            }
            
            // Crear semáforo con el paralelismo actual
            using var semaphore = new SemaphoreSlim(purgeParallelism, purgeParallelism);
            
            // OPTIMIZACIÓN: Procesar en micro-batches para evitar acumular demasiadas tareas en memoria
            const int MICRO_BATCH_SIZE = 20; // Procesar máximo 20 tareas a la vez
            var tasks = new List<Task>(MICRO_BATCH_SIZE);
            
            // Procesar autores en paralelo
            foreach (var author in authors)
            {
                // PROTECCIÓN: Detener si se detectó desconexión
                if (autoPurgePausedByDisconnection)
                {
                    CriticalLog($"🔌 Desconexión detectada, deteniendo procesamiento de nuevos autores");
                    break;
                }
                
                // Skip autores ya procesados (checkpoint)
                if (purgeProcessedAuthors.Contains(author))
                {
                    CriticalLog($"⏭️ Saltando autor ya procesado: {author}");
                    Interlocked.Increment(ref processedCount);
                    continue;
                }
                
                // Verificar circuit breaker antes de crear nueva tarea
                if (!await CheckCircuitBreaker(cancellationToken))
                    continue;
                
                // Esperar slot del semáforo (limita paralelismo)
                await semaphore.WaitAsync(cancellationToken);
                
                // Crear tarea paralela para procesar este autor
                var task = Task.Run(async () =>
                {
                    try
                    {
                        // Procesar autor usando método auxiliar
                        await ProcessSingleAuthorForPurge(author, cancellationToken);
                        Interlocked.Increment(ref processedCount);
                    }
                    catch (OperationCanceledException)
                    {
                        CriticalLog($"⏹️ Tarea cancelada para: {author}");
                    }
                    catch (Exception ex)
                    {
                        CriticalLog($"❌ Error en tarea paralela para {author}: {ex.Message}");
                    }
                    finally
                    {
                        // Liberar slot del semáforo
                        semaphore.Release();
                    }
                }, cancellationToken);
                
                tasks.Add(task);
                
                // OPTIMIZACIÓN: Si alcanzamos el límite del micro-batch, esperar a que terminen
                if (tasks.Count >= MICRO_BATCH_SIZE)
                {
                    try
                    {
                        await Task.WhenAll(tasks);
                    }
                    catch (OperationCanceledException)
                    {
                        CriticalLog("⏹️ Micro-batch cancelado");
                        // Esperar a que las tareas en curso terminen gracefully
                        try { await Task.WhenAll(tasks); } catch { }
                    }
                    catch (Exception ex)
                    {
                        CriticalLog($"❌ Error en micro-batch: {ex.Message}");
                    }
                    
                    // Limpiar lista para siguiente batch
                    tasks.Clear();
                }
            }
            
            // Esperar a que todas las tareas restantes terminen
            try
            {
                await Task.WhenAll(tasks);
            }
            catch (OperationCanceledException)
            {
                CriticalLog("⏹️ Procesamiento de chunk cancelado");
                // Esperar a que las tareas en curso terminen gracefully
                CriticalLog($"⏳ Esperando a que {tasks.Count} tareas en curso terminen...");
                try
                {
                    await Task.WhenAll(tasks);
                }
                catch { /* Ignorar errores de tareas canceladas */ }
            }
            catch (Exception ex)
            {
                CriticalLog($"❌ Error esperando tareas: {ex.Message}");
            }
            
            // PROTECCIÓN: Guardar checkpoint si se detectó desconexión
            if (autoPurgePausedByDisconnection)
            {
                CriticalLog($"💾 Guardando checkpoint por desconexión...");
                SavePurgeCheckpoint();
            }
            
            return processedCount;
        }

        // ============================================
        // INTEGRACIÓN MULTI-RED
        // ============================================

        /// <summary>
        /// Inicializa el orquestador de redes P2P
        /// Registra Soulseek
        /// </summary>
        private void InitializeNetworkOrchestrator()
        {
            try
            {
                // Si ya existe un orquestador, solo registrar Soulseek sin recrearlo
                if (_networkOrchestrator != null)
                {
                    Log("🌐 Orquestador ya existe, registrando Soulseek...");
                    
                    // Registrar Soulseek
                    _soulseekAdapter = new SlskDown.Core.SoulseekClientAdapter(client);
                    var provider = new SlskDown.Core.SoulseekSearchProvider(client);

                    _networkOrchestrator.RegisterClient("Soulseek", _soulseekAdapter);
                    _networkOrchestrator.RegisterSearchProvider("Soulseek", provider);

                    Log("   ✅ Soulseek registrado en orquestador existente");
                    return; // No recrear el orquestador ni eMule
                }

                Log("🌐 Inicializando orquestador multi-red...");

                _networkOrchestrator = new SlskDown.Core.NetworkOrchestrator();

                // Registrar Soulseek (siempre activo)
                _soulseekAdapter = new SlskDown.Core.SoulseekClientAdapter(client);
                var soulseekProvider = new SlskDown.Core.SoulseekSearchProvider(client);

                _networkOrchestrator.RegisterClient("Soulseek", _soulseekAdapter);
                _networkOrchestrator.RegisterSearchProvider("Soulseek", soulseekProvider);

                Log("   ✅ Soulseek registrado en orquestador");

                // Suscribirse a eventos del orquestador
                _networkOrchestrator.NetworkStatusChanged += (sender, e) =>
                {
                    Log($"🌐 [{e.NetworkName}] Estado: {e.State}");
                    if (!string.IsNullOrEmpty(e.Message))
                    {
                        Log($"   Mensaje: {e.Message}");
                    }
                    if (e.Error != null)
                    {
                        Log($"   Error: {e.Error.Message}");
                    }
                };

                Log("✅ Orquestador inicializado");
            }
            catch (Exception ex)
            {
                Log($"❌ Error inicializando orquestador: {ex.Message}");
                Log($"   Soulseek seguirá funcionando en modo standalone");
            }
        }

