        // Estadísticas de filtrado de idioma
        private class LanguageFilteringStats
        {
            public int RejectedByTitle { get; set; }
            public int RejectedByContent { get; set; }
            public int AcceptedByTitle { get; set; }
            public int AcceptedByContent { get; set; }
            public int VerificationErrors { get; set; }
            public int CacheHits { get; set; } // MEJORA #2: Contador de hits de caché
            public int CacheCleanups { get; set; } // MEJORA #2: Contador de limpiezas de caché
            
            public int TotalProcessed => RejectedByTitle + RejectedByContent + AcceptedByTitle + AcceptedByContent;
            public int TotalRejected => RejectedByTitle + RejectedByContent;
            public int TotalAccepted => AcceptedByTitle + AcceptedByContent;
            public int TotalContentVerifications => AcceptedByContent + RejectedByContent;
            
            public void Reset()
            {
                RejectedByTitle = 0;
                RejectedByContent = 0;
                AcceptedByTitle = 0;
                AcceptedByContent = 0;
                VerificationErrors = 0;
                CacheHits = 0;
                CacheCleanups = 0;
            }
            
            public override string ToString()
            {
                double cacheEfficiency = (TotalContentVerifications + CacheHits) > 0 
                    ? (CacheHits * 100.0 / (TotalContentVerifications + CacheHits)) 
                    : 0;
                    
                return $"📊 Estadísticas de Filtrado de Idioma:\n" +
                       $"   ✅ Aceptados por título: {AcceptedByTitle}\n" +
                       $"   ✅ Aceptados por contenido: {AcceptedByContent}\n" +
                       $"   ❌ Rechazados por título: {RejectedByTitle}\n" +
                       $"   ❌ Rechazados por contenido: {RejectedByContent}\n" +
                       $"   📈 Total procesados: {TotalProcessed}\n" +
                       $"   📊 Tasa de aceptación: {(TotalProcessed > 0 ? (TotalAccepted * 100.0 / TotalProcessed).ToString("F1") : "0")}%\n" +
                       $"   ⚠️ Errores de verificación: {VerificationErrors}\n" +
                       $"   🗂️ Hits de caché: {CacheHits} (eficiencia: {cacheEfficiency:F1}%)\n" +
                       $"   🗑️ Limpiezas de caché: {CacheCleanups}";
            }
        }
        
