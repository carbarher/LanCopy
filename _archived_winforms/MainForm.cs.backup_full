            var chkIntelligentCache = CreateCheckBox("🧠 Caché inteligente", useIntelligentCache, (s, e) => { useIntelligentCache = ((CheckBox)s).Checked; SaveConfig(); });
            var chkAutoTuning = CreateCheckBox("🎯 Auto-ajuste", useAutoTuning, (s, e) => 
