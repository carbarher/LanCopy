        // THROTTLING ADAPTATIVO: Métodos
        private async Task ApplyAdaptiveThrottling()
        {
            // Limpiar solicitudes antiguas
            var now = DateTime.UtcNow;
            while (recentRequests.Count > 0 && 
                   now.Subtract(recentRequests.Peek()).TotalSeconds > requestWindowSeconds)
            {
                recentRequests.Dequeue();
            }
            
            // MEJORA #15: Calcular delay basado en nivel de throttling (reducido para mayor velocidad)
            if (isThrottled && currentThrottleLevel > 0)
            {
                var baseDelay = currentThrottleLevel * 500; // MEJORA #15: Reducido de 1s a 500ms por nivel
                var randomJitter = stealthRandom.Next(0, 200); // MEJORA #39: Reutilizar Random existente
                var totalDelay = baseDelay + randomJitter;
                
                Log($"🚦 Throttling nivel {currentThrottleLevel}: esperando {totalDelay}ms");
                await Task.Delay(totalDelay).ConfigureAwait(false); // MEJORA #37
            }
            
            recentRequests.Enqueue(now);
        }
        
        // Idea #12: Rate limiting por operación (búsquedas)
        private async Task ThrottleSearchRate()
        {
            var now = DateTime.UtcNow;
            
            // Limpiar búsquedas antiguas (ventana de 1 minuto)
            while (searchRateTimes.Count > 0 && (now - searchRateTimes.Peek()).TotalMinutes > 1)
            {
                searchRateTimes.Dequeue();
            }
            
            // Si alcanzamos el límite, esperar hasta que pase 1 minuto desde la primera búsqueda
            if (searchRateTimes.Count >= maxSearchesPerMinute)
            {
                var oldestSearch = searchRateTimes.Peek();
                var waitTime = TimeSpan.FromMinutes(1) - (now - oldestSearch);
                
                if (waitTime.TotalMilliseconds > 0)
                {
                    Log($"⏳ Rate limit: esperando {waitTime.TotalSeconds:F0}s ({searchRateTimes.Count}/{maxSearchesPerMinute} búsquedas/min)");
                    await Task.Delay(waitTime).ConfigureAwait(false); // MEJORA #37
                }
            }
            
            // Registrar esta búsqueda
            searchRateTimes.Enqueue(DateTime.UtcNow);
        }
        
        private void UpdateThrottlingBasedOnResponse(double searchDuration, int responseCount)
        {
            // Incrementar errores si la búsqueda es lenta o no hay respuestas
            if (searchDuration > 5000 || responseCount == 0)
            {
                consecutiveErrors++;
                Log($"⚠️ Error de búsqueda: {searchDuration:F0}ms, {responseCount} respuestas (errores consecutivos: {consecutiveErrors})");
                
                if (consecutiveErrors >= 3 && currentThrottleLevel < maxThrottleLevel)
                {
                    currentThrottleLevel++;
                    isThrottled = true;
                    lastThrottleTime = DateTime.UtcNow;
                    Log($"🚦 Throttling aumentado a nivel {currentThrottleLevel}");
                }
            }
            else if (searchDuration < 2000 && responseCount > 5)
            {
                // MEJORA #15: Reducir throttling si la respuesta es buena (más agresivo)
                consecutiveErrors = Math.Max(0, consecutiveErrors - 1);
                
                if (consecutiveErrors == 0 && currentThrottleLevel > 0 && 
                    DateTime.UtcNow.Subtract(lastThrottleTime).TotalMinutes > 2) // MEJORA #15: Reducido de 5 a 2 minutos
                {
                    currentThrottleLevel--;
                    if (currentThrottleLevel == 0)
                    {
                        isThrottled = false;
                        Log("✅ Throttling desactivado - respuesta del servidor estable");
                    }
                    else
                    {
                        Log($"🚦 Throttling reducido a nivel {currentThrottleLevel}");
                    }
                }
            }
        }

