            filterFlow.Controls.AddRange(new Control[] { chkActive, chkPaused, chkCompleted, chkFailed, chkQueued });
            controlsLayout.Controls.Add(filterFlow, 0, 0);

            var actionsFlow = new FlowLayoutPanel
            {
