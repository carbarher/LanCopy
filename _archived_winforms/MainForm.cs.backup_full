        /// <summary>
        /// Descarga archivos de autores seleccionados (Modo Manual)
        /// </summary>
        private async Task DownloadSelectedAuthorsAsync()
        {
            var selectedAuthors = filteredAuthorsData.Where(a => a.IsChecked).ToList();
            
            if (selectedAuthors.Count == 0)
            {
                AutoLog("⚠️ No hay autores seleccionados");
                DarkMessageBox.Show("Por favor, selecciona al menos un autor para descargar.", 
                    "Sin selección", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }
            
            if (client == null)
            {
                AutoLog("❌ Cliente no inicializado");
                DarkMessageBox.Show("No hay conexión activa. Conéctate antes de iniciar descargas.",
                    "Sin conexión", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }
            
            if (autoPurgeRunning)
            {
                AutoLog("⛔ No se puede iniciar descarga manual mientras hay una búsqueda en curso");
                DarkMessageBox.Show("No puedes iniciar descargas manuales mientras la búsqueda está en curso. Pausa o finaliza la búsqueda e inténtalo de nuevo.",
                    "Búsqueda en curso", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }
            
            AutoLog($"⬇️ Iniciando descarga manual de {selectedAuthors.Count} autores...");
            
            foreach (var author in selectedAuthors)
            {
                try
                {
                    AutoLog($"🔍 Buscando archivos de '{author.Name}'...");
                    UpdateAuthorStatus(author.Name, "🔍 Buscando...");
                    
                    // Buscar archivos del autor
                    var searchQuery = author.Name;
                    var searchOptions = new SearchOptions(
                        searchTimeout: 5000,
                        filterResponses: true,
                        maximumPeerQueueLength: 50
                    );
                    
                    await ThrottleSearchRate();
                    var searchClient = GetClientFromPool();
                    var results = await ExecuteWithReconnect(
                        () => searchClient.SearchAsync(
                            SearchQuery.FromText(searchQuery),
                            options: searchOptions
                        ),
                        "manual author search"
                    );
                    
                    if (results.Responses != null && results.Responses.Count > 0)
                    {
                        AutoLog($"   ✅ Encontrados {results.Responses.Count} resultados para '{author.Name}'");
                        int enqueuedCount = 0;
                        
                        // Procesar y encolar descargas
                        foreach (var response in results.Responses)
                        {
                            if (response?.Files == null) continue;
                            foreach (var file in response.Files)
                            {
                                // Aplicar filtros
                                if (autoMinSearchSizeKB > 0 && file.Size < (long)autoMinSearchSizeKB * 1024L) continue;
                                var fileExt = Path.GetExtension(file.Filename).ToLower();
                                if (!IsDocumentExtension(fileExt)) continue;
                                if (chkAutoSpanishDocuments?.Checked == true && !IsSpanishText(file.Filename)) continue;

                                // Crear AutoSearchFileResult
                                var fileResult = new AutoSearchFileResult
                                {
                                    FileName = Path.GetFileName(file.Filename),
                                    Directory = Path.GetDirectoryName(file.Filename) ?? "",
                                    SizeBytes = file.Size,
                                    SizeReadable = FormatFileSize(file.Size),
                                    Username = response.Username,
                                    Author = author.Name,
                                    IsDocument = true,
                                    Timestamp = DateTime.UtcNow
                                };
                                
                                // Omitir ya descargados antes de agregar a lista/cola
                                var localPath = Path.Combine(downloadDir, fileResult.FileName);
                                bool existsOnDisk = System.IO.File.Exists(localPath);
                                bool existsInHistory = false;
                                lock (downloadHistoryLock)
                                {
                                    existsInHistory = downloadHistory.Any(h =>
                                        string.Equals(h.FileName, fileResult.FileName, StringComparison.OrdinalIgnoreCase) &&
                                        h.Status == "Completed");
                                }
                                // MEJORA FASE 1.3: ReadLock para Any
                                bool alreadyQueued = ReadLocked(downloadQueueLock, () =>
                                    downloadQueue.Any(t =>
                                        string.Equals(t.File.FileName, fileResult.FileName, StringComparison.OrdinalIgnoreCase) &&
                                        string.Equals(t.File.Username, fileResult.Username, StringComparison.OrdinalIgnoreCase)));

                                bool skipDownloaded = chkExcludeDownloaded == null || chkExcludeDownloaded.Checked;
                                if ((skipDownloaded && (existsOnDisk || existsInHistory)) || alreadyQueued)
                                {
                                    continue;
                                }

                                // Crear ListViewItem
                                var downloadItem = new ListViewItem(fileResult.FileName);
                                downloadItem.SubItems.Add(response.Username);
                                downloadItem.SubItems.Add("0%");
                                downloadItem.SubItems.Add("En cola");
                                downloadItem.SubItems.Add(FormatFileSize(file.Size));
                                downloadItem.Tag = fileResult;
                                
                                // Agregar a UI
                                if (lvDownloads != null)
                                {
                                    // MEJORA #40: Usar BeginInvoke en lugar de Invoke para no bloquear
                                    if (lvDownloads.InvokeRequired)
                                    {
                                        lvDownloads.BeginInvoke(new Action(() => AddItemWithAutoScroll(lvDownloads, downloadItem)));
                                    }
                                    else
                                    {
                                        AddItemWithAutoScroll(lvDownloads, downloadItem);
                                    }
                                }
                                
                                // Encolar descarga
                                AddToDownloadQueue(fileResult, localPath, downloadItem);
                                enqueuedCount++;
                            }
                        }
                        // Actualizar grilla de autores con el total de archivos encolados
                        UpdateAuthorData(author.Name, enqueuedCount, enqueuedCount > 0 ? "⬇️ En cola" : "⚠️ Sin resultados", enqueuedCount > 0 ? UIColors.AuthorDownloading : UIColors.AuthorNoResults);
                    }
                    else
                    {
                        AutoLog($"   ⚠️ Sin resultados para '{author.Name}'");
                        UpdateAuthorData(author.Name, 0, "⚠️ Sin resultados", UIColors.AuthorNoResults);
                    }
                }
                catch (OperationCanceledException)
                {
                    AutoLog($"❌ Error descargando '{author.Name}': The operation was canceled.");
                }
                catch (Exception ex)
                {
                    AutoLog($"❌ Error descargando '{author.Name}': {ex.Message}");
                }
            }
            
            AutoLog($"✅ Proceso de descarga manual completado");
        }
        
        /// <summary>
        /// Verifica integridad de archivos descargados (Modo Manual)
        /// </summary>
        private async void VerifyDownloadedFiles()
        {
            try
            {
                // MEJORA NICOTINE+: Usar DirectoryExistsCached
                if (!DirectoryExistsCached(downloadDir))
                {
                    AutoLog("⚠️ Carpeta de descargas no existe");
                    return;
                }
                
                AutoLog("🔍 Verificando archivos descargados (integridad + idioma)...");
                
                var files = System.IO.Directory.GetFiles(downloadDir, "*.*", SearchOption.AllDirectories);
                int validFiles = 0;
                int invalidFiles = 0;
                int spanishFiles = 0;
                int nonSpanishFiles = 0;
                int unverifiedLanguage = 0;
                long totalSize = 0;
                
                // MEJORA #31: Procesamiento paralelo con thread-safe counters
                await Task.Run(() =>
                {
                    int processed = 0;
                    object lockObj = new object();
                    
                    // Usar Parallel.ForEach para procesar múltiples archivos simultáneamente
                    // MEJORA #40: Limitar a 75% de cores para evitar saturación
                    var parallelOptions = new ParallelOptions
                    {
                        MaxDegreeOfParallelism = Math.Max(1, (int)(Environment.ProcessorCount * 0.75))
                    };
                    
                    Parallel.ForEach(files, parallelOptions, file =>
                    {
                        int currentProcessed;
                        lock (lockObj)
                        {
                            processed++;
                            currentProcessed = processed;
                        }
                        
                        if (currentProcessed % 10 == 0)
                        {
                            SafeInvoke(() => AutoLog($"   📊 Procesando {currentProcessed}/{files.Length}..."));
                        }
                        
                        try
                        {
                            var fileInfo = new FileInfo(file);
                            
                            // Verificar que el archivo no esté vacío
                            if (fileInfo.Length == 0)
                            {
                                SafeInvoke(() => AutoLog($"   ⚠️ Archivo vacío: {Path.GetFileName(file)}"));
                                lock (lockObj) { invalidFiles++; }
                                return;
                            }
                            
                            // Verificar extensión válida
                            var ext = fileInfo.Extension.ToLower();
                            if (!IsDocumentExtension(ext))
                            {
                                SafeInvoke(() => AutoLog($"   ⚠️ Extensión no válida: {Path.GetFileName(file)}"));
                                lock (lockObj) { invalidFiles++; }
                                return;
                            }
                            
                            // Verificar idioma por contenido
                            string content = ExtractTextFromFile(file);
                            if (!string.IsNullOrWhiteSpace(content))
                            {
                                bool isSpanish = IsSpanishText(content);
                                if (isSpanish)
                                {
                                    lock (lockObj) { spanishFiles++; }
                                }
                                else
                                {
                                    lock (lockObj) { nonSpanishFiles++; }
                                    SafeInvoke(() => AutoLog($"   🌍 No español: {Path.GetFileName(file)}"));
                                }
                            }
                            else
                            {
                                // No se pudo extraer contenido, verificar por nombre
                                bool isSpanish = IsSpanishText(Path.GetFileName(file));
                                if (isSpanish)
                                {
                                    lock (lockObj) { spanishFiles++; }
                                }
                                else
                                {
                                    lock (lockObj) { unverifiedLanguage++; }
                                    SafeInvoke(() => AutoLog($"   ❓ No se pudo verificar idioma: {Path.GetFileName(file)}"));
                                }
                            }
                            
                            lock (lockObj)
                            {
                                validFiles++;
                                totalSize += fileInfo.Length;
                            }
                        }
                        catch (Exception ex)
                        {
                            SafeInvoke(() => AutoLog($"   ❌ Error verificando {Path.GetFileName(file)}: {ex.Message}"));
                            lock (lockObj) { invalidFiles++; }
                        }
                    });
                });
                
                AutoLog($"✅ Verificación completada:");
                AutoLog($"   📄 Archivos válidos: {validFiles}");
                AutoLog($"   ⚠️ Archivos inválidos: {invalidFiles}");
                AutoLog($"   🇪🇸 Archivos en español: {spanishFiles}");
                AutoLog($"   🌍 Archivos en otros idiomas: {nonSpanishFiles}");
                AutoLog($"   ❓ Idioma no verificado: {unverifiedLanguage}");
                AutoLog($"   💾 Tamaño total: {FormatFileSize(totalSize)}");
                
                DarkMessageBox.Show(
                    $"Verificación completada:\n\n" +
                    $"✅ Archivos válidos: {validFiles}\n" +
                    $"⚠️ Archivos inválidos: {invalidFiles}\n\n" +
                    $"🇪🇸 En español: {spanishFiles}\n" +
                    $"🌍 Otros idiomas: {nonSpanishFiles}\n" +
                    $"❓ No verificado: {unverifiedLanguage}\n\n" +
                    $"💾 Tamaño total: {FormatFileSize(totalSize)}",
                    "Verificación",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Information
                );
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error en verificación: {ex.Message}");
                DarkMessageBox.Show($"Error al verificar archivos:\n{ex.Message}", 
                    "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
        /// <summary>
        /// MEJORA #15: Versión asíncrona de verificación sin UI (para uso automático)
        /// </summary>
        private async Task VerifyDownloadedFilesAsync()
        {
            try
            {
                // MEJORA NICOTINE+: Usar DirectoryExistsCached
                if (!DirectoryExistsCached(downloadDir))
                {
                    AutoLog("⚠️ Carpeta de descargas no existe");
                    return;
                }
                
                AutoLog("🔍 Verificando archivos descargados (integridad + idioma)...");
                
                var files = System.IO.Directory.GetFiles(downloadDir, "*.*", SearchOption.AllDirectories);
                int validFiles = 0;
                int invalidFiles = 0;
                int spanishFiles = 0;
                int nonSpanishFiles = 0;
                int unverifiedLanguage = 0;
                long totalSize = 0;
                
                // MEJORA #31: Procesamiento paralelo con thread-safe counters
                await Task.Run(() =>
                {
                    int processed = 0;
                    object lockObj = new object();
                    
                    // Usar Parallel.ForEach para procesar múltiples archivos simultáneamente
                    // MEJORA #40: Limitar a 75% de cores para evitar saturación
                    var parallelOptions = new ParallelOptions
                    {
                        MaxDegreeOfParallelism = Math.Max(1, (int)(Environment.ProcessorCount * 0.75))
                    };
                    
                    Parallel.ForEach(files, parallelOptions, file =>
                    {
                        int currentProcessed;
                        lock (lockObj)
                        {
                            processed++;
                            currentProcessed = processed;
                        }
                        
                        if (currentProcessed % 10 == 0)
                        {
                            SafeInvoke(() => AutoLog($"   📊 Procesando {currentProcessed}/{files.Length}..."));
                        }
                        
                        try
                        {
                            var fileInfo = new FileInfo(file);
                            
                            // Verificar que el archivo no esté vacío
                            if (fileInfo.Length == 0)
                            {
                                SafeInvoke(() => AutoLog($"   ⚠️ Archivo vacío: {Path.GetFileName(file)}"));
                                lock (lockObj) { invalidFiles++; }
                                return;
                            }
                            
                            // Verificar extensión válida
                            var ext = fileInfo.Extension.ToLower();
                            if (!IsDocumentExtension(ext))
                            {
                                SafeInvoke(() => AutoLog($"   ⚠️ Extensión no válida: {Path.GetFileName(file)}"));
                                lock (lockObj) { invalidFiles++; }
                                return;
                            }
                            
                            // MEJORA NICOTINE+: Usar MetadataScanner para archivos de audio
                            if (_metadataScanner != null && (ext == ".mp3" || ext == ".flac" || ext == ".m4a" || ext == ".ogg"))
                            {
                                try
                                {
                                    var metadata = _metadataScanner.ScanFile(file);
                                    if (metadata != null)
                                    {
                                        if (audioQualityFilters?.MinBitrate != null && metadata.Bitrate < audioQualityFilters.MinBitrate.Value)
                                        {
                                            SafeInvoke(() => AutoLog($"   ⚠️ Calidad baja: {Path.GetFileName(file)} ({metadata.Bitrate} kbps)"));
                                            _eventBus?.Publish(SystemEvents.FileQualityWarning, new { FilePath = file, Bitrate = metadata.Bitrate, MinRequired = audioQualityFilters.MinBitrate.Value, Timestamp = DateTime.UtcNow });
                                        }
                                        if (metadata.Duration > 0 && metadata.Duration < 30)
                                        {
                                            SafeInvoke(() => AutoLog($"   ⚠️ Archivo muy corto: {Path.GetFileName(file)} ({metadata.Duration}s)"));
                                            lock (lockObj) { invalidFiles++; }
                                            return;
                                        }
                                        if (currentProcessed % 50 == 0)
                                        {
                                            var durationStr = metadata.Duration > 0 ? $"{(metadata.Duration / 60.0):F1}min" : "N/A";
                                            SafeInvoke(() => AutoLog($"   ✅ {Path.GetFileName(file)}: {metadata.Bitrate}kbps, {metadata.SampleRate}Hz, {durationStr}"));
                                        }
                                    }
                                }
                                catch (Exception metaEx)
                                {
                                    SafeInvoke(() => AutoLog($"   ⚠️ Error metadatos: {metaEx.Message}"));
                                }
                            }
                            
                            // Verificar idioma por contenido
                            string content = ExtractTextFromFile(file);
                            if (!string.IsNullOrWhiteSpace(content))
                            {
                                bool isSpanish = IsSpanishText(content);
                                if (isSpanish)
                                {
                                    lock (lockObj) { spanishFiles++; }
                                }
                                else
                                {
                                    lock (lockObj) { nonSpanishFiles++; }
                                    SafeInvoke(() => AutoLog($"   🌍 No español: {Path.GetFileName(file)}"));
                                }
                            }
                            else
                            {
                                // No se pudo extraer contenido, verificar por nombre
                                bool isSpanish = IsSpanishText(Path.GetFileName(file));
                                if (isSpanish)
                                {
                                    lock (lockObj) { spanishFiles++; }
                                }
                                else
                                {
                                    lock (lockObj) { unverifiedLanguage++; }
                                    SafeInvoke(() => AutoLog($"   ❓ No se pudo verificar idioma: {Path.GetFileName(file)}"));
                                }
                            }
                            
                            lock (lockObj)
                            {
                                validFiles++;
                                totalSize += fileInfo.Length;
                            }
                        }
                        catch (Exception ex)
                        {
                            SafeInvoke(() => AutoLog($"   ❌ Error verificando {Path.GetFileName(file)}: {ex.Message}"));
                            lock (lockObj) { invalidFiles++; }
                        }
                    });
                });
                
                AutoLog($"✅ Verificación completada:");
                AutoLog($"   📄 Archivos válidos: {validFiles}");
                AutoLog($"   ⚠️ Archivos inválidos: {invalidFiles}");
                AutoLog($"   🇪🇸 Archivos en español: {spanishFiles}");
                AutoLog($"   🌍 Archivos en otros idiomas: {nonSpanishFiles}");
                AutoLog($"   ❓ Idioma no verificado: {unverifiedLanguage}");
                AutoLog($"   💾 Tamaño total: {FormatFileSize(totalSize)}");
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error en verificación: {ex.Message}");
            }
        }
        
        /// <summary>
        /// Verifica si una extensión es de documento
        /// </summary>
        private bool IsDocumentExtension(string ext)
        {
            var docExtensions = new[] { ".pdf", ".epub", ".mobi", ".azw", ".azw3", ".djvu", ".fb2", ".txt", ".doc", ".docx" };
            return docExtensions.Contains(ext.ToLower());
        }
        
        /// <summary>
        /// MEJORA NICOTINE+: Verifica si un directorio existe usando PathCache
        /// </summary>
        private bool DirectoryExistsCached(string path)
        {
            if (_pathCache == null)
                return System.IO.Directory.Exists(path);
            
            var normalized = _pathCache.GetNormalized(path);
            
            // Publicar evento de caché (verificar si existe en caché)
            var existsInCache = System.IO.Directory.Exists(normalized);
            if (existsInCache)
            {
                _eventBus?.Publish(SystemEvents.CacheHit, new { Path = path, Type = "Directory", Timestamp = DateTime.UtcNow });
            }
            else
            {
                _eventBus?.Publish(SystemEvents.CacheMiss, new { Path = path, Type = "Directory", Timestamp = DateTime.UtcNow });
            }
            
            return existsInCache;
        }
        
        /// <summary>
        /// MEJORA NICOTINE+: Verifica si un archivo existe usando PathCache
        /// </summary>
        private bool FileExistsCached(string path)
        {
            if (_pathCache == null)
                return System.IO.File.Exists(path);
            
            var normalized = _pathCache.GetNormalized(path);
            
            // Publicar evento de caché (verificar si existe en caché)
            var existsInCache = System.IO.File.Exists(normalized);
            if (existsInCache)
            {
                _eventBus?.Publish(SystemEvents.CacheHit, new { Path = path, Type = "File", Timestamp = DateTime.UtcNow });
            }
            else
            {
                _eventBus?.Publish(SystemEvents.CacheMiss, new { Path = path, Type = "File", Timestamp = DateTime.UtcNow });
            }
            
            return existsInCache;
        }
        
        /// <summary>
        /// Inicia el proceso de purga de autores seleccionados (Modo Purga)
        /// </summary>
        private async Task StartPurgeProcessAsync()
        {
            try
            {
                var checkedItems = lvAutoAuthors.Items.Cast<ListViewItem>()
                    .Where(item => item.Checked)
                    .ToList();
                
                if (checkedItems.Count == 0)
                {
                    AutoLog("⚠️ No hay autores seleccionados para purgar");
                    DarkMessageBox.Show("Selecciona al menos un autor para purgar", 
                        "Advertencia", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    return;
                }
                
                var result = DarkMessageBox.Show(
                    $"¿Iniciar búsqueda de {checkedItems.Count} autores seleccionados?\n\n" +
                    "Esto buscará y encolará descargas de todos los archivos de estos autores.",
                    "Confirmar Búsqueda",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Question
                );
                
                if (result != DialogResult.Yes)
                {
                    return;
                }
                
                AutoLog($"🔎 Iniciando búsqueda (purga) de {checkedItems.Count} autores...");
                
                // Ejecutar rutina de purga: analiza y actualiza estado/archivos, NO encola descargas
                await PurgeAuthorsWithoutResults();
                
                AutoLog($"✅ Búsqueda (purga) completada");
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error en proceso de búsqueda: {ex.Message}");
                DarkMessageBox.Show($"Error al buscar autores:\n{ex.Message}", 
                    "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
        /// <summary>
        /// Guarda la lista de autores que tienen archivos encontrados
        /// </summary>
        private void SaveAuthorsWithFiles()
        {
            try
            {
                // Obtener autores que tienen archivos (FilesCount > 0)
                var authorsWithFiles = filteredAuthorsData
                    .Where(a => a.FilesCount > 0)
                    .Select(a => a.Name)
                    .OrderBy(name => name)
                    .ToList();
                
                if (authorsWithFiles.Count == 0)
                {
                    AutoLog("⚠️ No hay autores con archivos encontrados");
                    DarkMessageBox.Show("No hay autores con archivos para guardar.\nPrimero realiza una búsqueda.", 
                        "Advertencia", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    return;
                }
                
                var filePath = DarkFileDialog.ShowSaveDialog(this, 
                    "Guardar autores con archivos", 
                    "TXT|*.txt|Todos|*.*",
                    "autores_con_archivos.txt");
                
                if (string.IsNullOrWhiteSpace(filePath))
                {
                    return; // Usuario canceló
                }
                
                System.IO.File.WriteAllLines(filePath, authorsWithFiles, System.Text.Encoding.UTF8);
                
                AutoLog($"💾 Guardados {authorsWithFiles.Count} autores con archivos en {Path.GetFileName(filePath)}");
                DarkMessageBox.Show(
                    $"Se guardaron {authorsWithFiles.Count} autores con archivos en:\n{filePath}",
                    "Guardado Exitoso",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Information
                );
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error al guardar autores: {ex.Message}");
                DarkMessageBox.Show($"Error al guardar:\n{ex.Message}", 
                    "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
