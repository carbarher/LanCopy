        /// <summary>
        /// Ejecuta una acción en el thread de UI de forma segura
        /// REFACTORIZACIÓN: Usa UIManager cuando está disponible
        /// </summary>
        private void SafeInvoke(Action action)
        {
            // REFACTORIZACIÓN: Usar UIManager si está disponible
            if (uiManager != null)
            {
                uiManager.SafeInvoke(action);
                return;
            }
            
            // Fallback: Implementación directa
            if (InvokeRequired)
            {
                try
                {
                    BeginInvoke(action); // No bloqueante - evita deadlocks
                }
                catch (ObjectDisposedException)
                {
                    // Control ya destruido, ignorar
                }
                catch (InvalidOperationException)
                {
                    // Thread de destino ya no existe, ignorar
                }
            }
            else
            {
                try
                {
                    action();
                }
                catch (ObjectDisposedException)
                {
                    // Control ya destruido, ignorar
                }
                catch (InvalidOperationException)
                {
                    // Thread de destino ya no existe, ignorar
                }
                catch (NullReferenceException)
                {
                    // Control o referencia nula durante actualización (común durante purga), ignorar
                }
            }
        }

        /// <summary>
        /// Actualiza un control de forma thread-safe
        /// </summary>
        private void UpdateControl(Control control, Action<Control> updateAction)
        {
            if (control == null) return;
            SafeInvoke(() => updateAction(control));
        }
        
        /// <summary>
        /// Ejecuta una acción en el thread de UI de forma asíncrona (no bloqueante)
        /// Usar cuando NO necesitas esperar el resultado
        /// </summary>
        private void SafeBeginInvoke(Action action)
        {
            if (IsDisposed || Disposing) return;
            
            try
            {
                if (InvokeRequired)
                    BeginInvoke(action);
                else
                    action();
            }
            catch (ObjectDisposedException)
            {
                // Control ya destruido, ignorar
            }
            catch (InvalidOperationException)
            {
                // Handle cerrado, ignorar
            }
        }

        /// <summary>
        /// Actualiza el texto de un control de forma thread-safe
        /// </summary>
        private void UpdateControlText(Control? control, string text)
        {
            if (control == null) return;
            SafeInvoke(() => control.Text = text);
        }

        /// <summary>
        /// Actualiza el estado enabled de un control de forma thread-safe
        /// </summary>
        private void UpdateControlEnabled(Control? control, bool enabled)
        {
            if (control == null) return;
            SafeInvoke(() => control.Enabled = enabled);
        }

        /// <summary>
        /// Guarda el ancho de las columnas de un ListView
        /// </summary>
        private void SaveColumnWidths(ListView listView, string listViewName)
        {
            try
            {
                var widths = new List<int>();
                foreach (ColumnHeader column in listView.Columns)
                {
                    widths.Add(column.Width);
                }
                
                columnWidthsCache[listViewName] = widths;
                
                // Guardar en archivo JSON
                var json = JsonSerializer.Serialize(columnWidthsCache, new JsonSerializerOptions { WriteIndented = true });
                System.IO.File.WriteAllText(columnWidthsConfigPath, json);
            }
            catch (Exception ex)
            {
                // Silenciar errores de guardado
                Debug.WriteLine($"Error guardando anchos de columnas: {ex.Message}");
            }
        }

        /// <summary>
        /// Carga el ancho de las columnas de un ListView
        /// </summary>
        private void LoadColumnWidths(ListView listView, string listViewName)
        {
            try
            {
                if (!System.IO.File.Exists(columnWidthsConfigPath))
                    return;

                var json = System.IO.File.ReadAllText(columnWidthsConfigPath);
                var config = JsonSerializer.Deserialize<Dictionary<string, List<int>>>(json);
                
                if (config != null && config.ContainsKey(listViewName))
                {
                    var widths = config[listViewName];
                    for (int i = 0; i < Math.Min(widths.Count, listView.Columns.Count); i++)
                    {
                        if (widths[i] > 0) // Solo aplicar anchos válidos
                        {
                            listView.Columns[i].Width = widths[i];
                        }
                    }
                    columnWidthsCache[listViewName] = widths;
                }
            }
            catch (Exception ex)
            {
                // Silenciar errores de carga
                Debug.WriteLine($"Error cargando anchos de columnas: {ex.Message}");
            }
        }

        /// <summary>
        /// Configura un ListView para que persista el ancho de sus columnas
        /// </summary>
        private void SetupColumnWidthPersistence(ListView listView, string listViewName)
        {
            // Cargar anchos guardados
            LoadColumnWidths(listView, listViewName);
            
            // Suscribirse al evento de cambio de ancho
            listView.ColumnWidthChanged += (s, e) =>
            {
                SaveColumnWidths(listView, listViewName);
            };
        }
        
        private DateTime lastUpdateTime = DateTime.MinValue;
        private const int UPDATE_THROTTLE_MS = 500; // Actualizar UI máximo cada 500ms
        
        /// <summary>
        /// Actualiza los resultados de búsqueda usando Virtual ListView
        /// </summary>
        // DESACTIVADO: SearchResultItem no disponible
        private void UpdateSearchResults(List<SearchResultItem> items)
        {
            // Throttling: solo actualizar si han pasado 500ms desde la última actualización
            var now = DateTime.Now;
            if ((now - lastUpdateTime).TotalMilliseconds < UPDATE_THROTTLE_MS)
            {
                return; // Saltar esta actualización para no saturar el UI thread
            }
            lastUpdateTime = now;
            
            SafeInvoke(() =>
            {
                // using (PerformanceMetrics.Instance.Track("UpdateSearchResults")) // DESACTIVADO: PerformanceMetrics excluido
                {
                    // Suspender redibujado durante actualización masiva
                    lvResults.BeginUpdate();
                    try
                    {
                        lvResults.Items.Clear();
                        
                        // Crear array de items para agregar en batch
                        var listItems = new ListViewItem[items.Count];
                        for (int i = 0; i < items.Count; i++)
                        {
                            var item = items[i];
                            var listItem = new ListViewItem(item.Filename);
                            listItem.SubItems.Add(item.Extension);
                            listItem.SubItems.Add(item.Username);
                            listItem.SubItems.Add(FormatSize(item.Size));
                            listItem.SubItems.Add(item.Network); // Columna Red
                            listItem.SubItems.Add(item.FolderPath);
                            listItem.Tag = item;
                            listItem.ToolTipText = $"{item.Filename}\nUsuario: {item.Username}\nTamaño: {FormatSize(item.Size)}\nRed: {item.Network}\nCarpeta: {item.FolderPath}";
                            
                            // Aplicar colores según calidad
                            if (item.Extension.ToLower() == ".flac")
                                listItem.ForeColor = Color.FromArgb(50, 255, 255);
                            else if (item.Size > 100 * 1024 * 1024)
                                listItem.ForeColor = Color.FromArgb(255, 80, 80);
                            
                            listItems[i] = listItem;
                        }
                        
                        // Agregar todos los items de una vez (más rápido que Add individual)
                        lvResults.Items.AddRange(listItems);
                        lblResultsCount.Text = $"{items.Count:N0} archivos";
                    }
                    finally
                    {
                        // Reanudar redibujado
                        lvResults.EndUpdate();
                    }
                }
            });
        }
        
        /// <summary>
        /// Actualiza los resultados de búsqueda desde autoSearchResults
        /// </summary>
        private void UpdateSearchResults()
        {
            // Convertir autoSearchResults a SearchResultItem
            var items = new List<SearchResultItem>();
            lock (autoSearchResultsLock)
            {
                foreach (var result in autoSearchResults)
                {
                    items.Add(new SearchResultItem
                    {
                        Filename = result.FileName,
                        Extension = Path.GetExtension(result.FileName),
                        Username = result.Username,
                        Size = result.SizeBytes,
                        FolderPath = result.Directory,
                        Network = result.Network // Incluir red de origen
                    });
                }
            }
            UpdateSearchResults(items);
        }
        
        /// <summary>
        /// Agrega resultados incrementalmente
        /// </summary>
        private void AddSearchResults(List<SearchResultItem> newItems)
        {
            // Throttling: solo actualizar si han pasado 500ms desde la última actualización
            var now = DateTime.Now;
            if ((now - lastUpdateTime).TotalMilliseconds < UPDATE_THROTTLE_MS)
            {
                return; // Saltar esta actualización para no saturar el UI thread
            }
            lastUpdateTime = now;
            
            SafeInvoke(() =>
            {
                // using (PerformanceMetrics.Instance.Track("AddSearchResults")) // DESACTIVADO: PerformanceMetrics excluido
                {
                    // Suspender redibujado durante actualización masiva
                    lvResults.BeginUpdate();
                    try
                    {
                        // Crear array de items para agregar en batch
                        var listItems = new ListViewItem[newItems.Count];
                        for (int i = 0; i < newItems.Count; i++)
                        {
                            var item = newItems[i];
                            var listItem = new ListViewItem(item.Filename);
                            listItem.SubItems.Add(item.Extension);
                            listItem.SubItems.Add(item.Username);
                            listItem.SubItems.Add(FormatSize(item.Size));
                            listItem.SubItems.Add(item.Network); // Columna Red
                            listItem.SubItems.Add(item.FolderPath);
                            listItem.Tag = item;
                            listItem.ToolTipText = $"{item.Filename}\nUsuario: {item.Username}\nTamaño: {FormatSize(item.Size)}\nRed: {item.Network}\nCarpeta: {item.FolderPath}";
                            
                            // Aplicar colores según calidad
                            if (item.Extension.ToLower() == ".flac")
                                listItem.ForeColor = Color.FromArgb(50, 255, 255);
                            else if (item.Size > 100 * 1024 * 1024)
                                listItem.ForeColor = Color.FromArgb(255, 80, 80);
                            
                            listItems[i] = listItem;
                        }
                        
                        // Agregar todos los items de una vez (más rápido que Add individual)
                        lvResults.Items.AddRange(listItems);
                        lblResultsCount.Text = $"{lvResults.Items.Count:N0} archivos";
                    }
                    finally
                    {
                        // Reanudar redibujado
                        lvResults.EndUpdate();
                    }
                }
            });
        }
        
        /// <summary>
        /// Limpia los resultados de búsqueda
        /// </summary>
        private void ClearSearchResults()
        {
            SafeInvoke(() =>
            {
                lvResults.Items.Clear();
                lblResultsCount.Text = "0 archivos";
            });
        }
        
