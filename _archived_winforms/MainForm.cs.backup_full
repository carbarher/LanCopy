                html.AppendLine("    <meta charset='UTF-8'>");
                html.AppendLine("    <meta name='viewport' content='width=device-width, initial-scale=1.0'>");
                html.AppendLine("    <title>SlskDown - Resultados de Búsqueda</title>");
                html.AppendLine("    <style>");
