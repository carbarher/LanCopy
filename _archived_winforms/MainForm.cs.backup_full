                int defVal = 500;
                var count = PromptForInteger("Generar Lista Autores SF", $"¿Cuántos autores quieres en la lista? (1-{max})", defVal, 1, max);
                if (!count.HasValue) return;
                
                // Siempre buscar en internet (la lista local es solo fallback)
                Log($"🌐 Buscando {count.Value} autores de ciencia ficción en internet...");
                var selected = await SearchSFAuthorsOnline(count.Value, authorsOnly);
                
                // Guardar en c:\p2p en lugar de dataDir
                var filePath = Path.Combine(@"c:\p2p", $"autores_sf_{count.Value}.txt");
                System.IO.File.WriteAllLines(filePath, selected, System.Text.Encoding.UTF8);
                
                Log($"✅ Lista de autores SF generada: {filePath}");
                Log($"   📚 {selected.Length} autores incluidos");
                
                var result = DarkMessageBox.Show(
                    $"Lista de autores de ciencia ficción generada exitosamente:\n\n" +
                    $"📁 Ubicación: {filePath}\n" +
                    $"📚 Autores: {selected.Length}\n\n" +
                    $"¿Deseas abrir la carpeta donde se guardó el archivo?",
                    "Lista Generada",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Information
                );
                
                if (result == DialogResult.Yes)
                {
                    System.Diagnostics.Process.Start("explorer.exe", $"/select,\"{filePath}\"");
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error generando lista de autores SF: {ex.Message}");
                DarkMessageBox.Show(
                    $"Error al generar la lista de autores:\n\n{ex.Message}",
                    "Error",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Error
                );
            }
        }

        /// <summary>
        /// Busca autores de ciencia ficción en internet con caché y búsqueda paralela
        /// </summary>
        private async Task<string[]> SearchSFAuthorsOnline(int targetCount, string[] baseAuthors)
        {
            var allAuthors = new HashSet<string>(baseAuthors);
            
            try
            {
                // NO USAR CACHÉ - siempre descargar fresco desde internet
                var cacheFile = Path.Combine(dataDir, "sf_authors_cache.json");
                Log($"🌐 Descargando autores desde internet (sin usar caché)...");
                
                // 2. BÚSQUEDA PARALELA EN MÚLTIPLES FUENTES
                Log($"🌐 Buscando autores en múltiples fuentes (paralelo)...");
                
                using (var httpClient = new System.Net.Http.HttpClient())
                {
                    httpClient.Timeout = TimeSpan.FromSeconds(30);
                    httpClient.DefaultRequestHeaders.Add("User-Agent", "SlskDown/1.0 (Educational Purpose)");
                    
                    // Fuentes de datos
                    var sources = new[]
                    {
                        // Wikipedia (las más confiables)
                        ("Wikipedia EN - List", "https://en.wikipedia.org/wiki/List_of_science_fiction_authors"),
                        ("Wikipedia EN - Category", "https://en.wikipedia.org/wiki/Category:Science_fiction_writers"),
                        ("Wikipedia EN - A-C", "https://en.wikipedia.org/wiki/Category:American_science_fiction_writers"),
                        ("Wikipedia EN - British", "https://en.wikipedia.org/wiki/Category:British_science_fiction_writers"),
                        
                        // Listas adicionales
                        ("SF Encyclopedia", "http://www.sf-encyclopedia.com/"),
                        ("LibraryThing - SF", "https://www.librarything.com/tag/science+fiction")
                    };
                    
                    // Descargar todas las fuentes en paralelo
                    var downloadTasks = sources.Select(async source =>
                    {
                        try
                        {
                            Log($"   📡 Descargando {source.Item1}...");
                            var sw = System.Diagnostics.Stopwatch.StartNew();
                            var html = await httpClient.GetStringAsync(source.Item2);
                            sw.Stop();
                            var authors = ExtractAuthorsFromHtml(html, source.Item1);
                            Log($"   ✅ {source.Item1}: {authors.Count} autores extraídos ({sw.ElapsedMilliseconds}ms)");
                            return authors;
                        }
                        catch (Exception ex)
                        {
                            Log($"   ❌ {source.Item1} FALLÓ: {ex.Message}");
                            return new HashSet<string>();
                        }
                    });
                    
                    var results = await Task.WhenAll(downloadTasks);
                    
                    // Combinar todos los resultados
                    int beforeMerge = allAuthors.Count;
                    foreach (var authorSet in results)
                    {
                        int before = allAuthors.Count;
                        allAuthors.UnionWith(authorSet);
                        int added = allAuthors.Count - before;
                        if (authorSet.Count > 0)
                        {
                            Log($"   📊 Agregados {added} autores únicos de {authorSet.Count} descargados");
                        }
                    }
                    int totalAdded = allAuthors.Count - beforeMerge;
                    Log($"🌐 Descarga completada: {totalAdded} autores nuevos desde internet");
                }
                
                Log($"✅ Total de autores únicos recopilados: {allAuthors.Count}");
                
                if (allAuthors.Count < targetCount)
                {
                    Log($"⚠️ ADVERTENCIA: Solo se obtuvieron {allAuthors.Count} autores de {targetCount} solicitados");
                    Log($"   Esto puede deberse a:");
                    Log($"   - Duplicados eliminados (normal)");
                    Log($"   - Fallos en descargas HTTP");
                    Log($"   - Filtros de validación muy estrictos");
                }
                
                // 3. GUARDAR EN CACHÉ (MEJORA #33: Con compresión)
                try
                {
                    var jsonOptions = new System.Text.Json.JsonSerializerOptions 
                    { 
                        WriteIndented = false // No indentar para mejor compresión
                    };
                    Core.CompressionHelper.SaveCompressedJson(cacheFile, allAuthors.ToArray(), jsonOptions);
                    
                    // Calcular ratio de compresión
                    var ratio = Core.CompressionHelper.GetCompressionRatio(cacheFile);
                    Log($"💾 Caché actualizado: {cacheFile} (compresión: {ratio:F1}%)");
                }
                catch (Exception ex)
                {
                    Log($"⚠️ No se pudo guardar caché: {ex.Message}");
                }
                
                return allAuthors.Take(targetCount).ToArray();
            }
            catch (Exception ex)
            {
                Log($"❌ Error buscando autores online: {ex.Message}");
                Log($"   📚 Usando solo lista local ({baseAuthors.Length} autores)");
                return baseAuthors;
            }
        }
        
        /// <summary>
        /// Extrae nombres de autores de HTML según la fuente
        /// </summary>
        private HashSet<string> ExtractAuthorsFromHtml(string html, string sourceName)
        {
            var authors = new HashSet<string>();
            
            try
            {
                // Patrón mejorado para Wikipedia - captura múltiples formatos
                var wikiPatterns = new[]
                {
                    @"<a href=""/wiki/([^""]+)"" title=""([^""]+)""[^>]*>([^<]+)</a>",  // Formato estándar
                    @"<li><a[^>]+title=""([^""]+)""[^>]*>([^<]+)</a>",                  // Listas
                    @"title=""([^""]+)""[^>]*class=""mw-redirect""[^>]*>([^<]+)</a>"    // Redirects
                };
                
                // Patrón para SF Encyclopedia
                var sfEncyclopediaPattern = @"<a[^>]+href=""/entry/([^""]+)""[^>]*>([^<]+)</a>";
                
                // Patrón para LibraryThing
                var libraryThingPattern = @"<a[^>]+href=""/author/([^""]+)""[^>]*>([^<]+)</a>";
                
                if (sourceName.Contains("SF Encyclopedia"))
                {
                    var matches = System.Text.RegularExpressions.Regex.Matches(html, sfEncyclopediaPattern);
                    foreach (System.Text.RegularExpressions.Match match in matches)
                    {
                        var name = System.Net.WebUtility.HtmlDecode(match.Groups[2].Value.Trim());
                        if (IsValidAuthorName(name))
                            authors.Add(name);
                    }
                }
                else if (sourceName.Contains("LibraryThing"))
                {
                    var matches = System.Text.RegularExpressions.Regex.Matches(html, libraryThingPattern);
                    foreach (System.Text.RegularExpressions.Match match in matches)
                    {
                        var name = System.Net.WebUtility.HtmlDecode(match.Groups[2].Value.Trim());
                        if (IsValidAuthorName(name))
                            authors.Add(name);
                    }
                }
                else // Wikipedia - probar todos los patrones
                {
                    foreach (var pattern in wikiPatterns)
                    {
                        var matches = System.Text.RegularExpressions.Regex.Matches(html, pattern);
                        foreach (System.Text.RegularExpressions.Match match in matches)
                        {
                            // El nombre puede estar en diferentes grupos según el patrón
                            for (int i = 1; i < match.Groups.Count; i++)
                            {
                                var name = System.Net.WebUtility.HtmlDecode(match.Groups[i].Value.Trim());
                                if (IsValidAuthorName(name))
                                {
                                    authors.Add(name);
                                    break; // Solo agregar una vez por match
                                }
                            }
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error extrayendo de {sourceName}: {ex.Message}");
            }
            
            return authors;
        }
        
        /// <summary>
        /// Valida si un nombre es válido como autor
        /// </summary>
        private bool IsValidAuthorName(string name)
        {
            if (string.IsNullOrWhiteSpace(name)) return false;
            
            // Filtros de exclusión
            if (name.Contains("Category:") || 
                name.Contains("List of") || 
                name.Contains("Portal:") ||
                name.Contains("Wikipedia:") ||
                name.Contains("Template:") ||
                name.Contains("File:") ||
                name.Contains("Help:"))
                return false;
            
            // Debe empezar con letra mayúscula
            if (!char.IsUpper(name[0])) return false;
            
            // No debe empezar con año
            if (System.Text.RegularExpressions.Regex.IsMatch(name, @"^\d{4}")) 
                return false;
            
            // Longitud razonable
            if (name.Length < 3 || name.Length > 50) 
                return false;
            
            // Debe contener al menos un espacio (nombre + apellido)
            if (!name.Contains(" ")) 
                return false;
            
            // No debe tener demasiados caracteres especiales
            var specialChars = name.Count(c => !char.IsLetterOrDigit(c) && c != ' ' && c != '.' && c != '-' && c != '\'');
            if (specialChars > 3) 
                return false;
            
            return true;
        }

