                Log($"❌ Error obteniendo sinopsis: {ex.Message}");
            }
        }
        
        private async Task<BookMetadata> FetchBookMetadataFromGoogleBooks(string title, string author)
        {
            try
            {
                using (var httpClient = new System.Net.Http.HttpClient())
                {
                    httpClient.Timeout = TimeSpan.FromSeconds(10);
                    
                    var query = string.IsNullOrEmpty(author) ? title : $"{title} {author}";
                    var url = $"https://www.googleapis.com/books/v1/volumes?q={Uri.EscapeDataString(query)}&maxResults=1";
                    
                    var response = await httpClient.GetStringAsync(url);
                    var json = System.Text.Json.JsonDocument.Parse(response);
                    
                    if (json.RootElement.TryGetProperty("items", out var items) && items.GetArrayLength() > 0)
                    {
                        var book = items[0].GetProperty("volumeInfo");
                        
                        var metadata = new BookMetadata
                        {
                            Title = book.TryGetProperty("title", out var t) ? t.GetString() : title,
                            Author = book.TryGetProperty("authors", out var a) && a.GetArrayLength() > 0 
                                ? a[0].GetString() 
                                : author,
                            Synopsis = book.TryGetProperty("description", out var d) ? d.GetString() : null,
                            PublishDate = book.TryGetProperty("publishedDate", out var pd) ? pd.GetString() : null,
                            PageCount = book.TryGetProperty("pageCount", out var pc) ? pc.GetInt32() : 0,
                            Rating = book.TryGetProperty("averageRating", out var r) ? r.GetDouble() : 0,
                            Source = "Google Books"
                        };
                        
                        return metadata;
                    }
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error en Google Books: {ex.Message}");
            }
            
            return null;
        }
        
        private async Task<BookMetadata> FetchBookMetadataFromOpenLibrary(string title, string author)
        {
            try
            {
                using (var httpClient = new System.Net.Http.HttpClient())
                {
                    httpClient.Timeout = TimeSpan.FromSeconds(10);
                    
                    var query = string.IsNullOrEmpty(author) ? title : $"{title} {author}";
                    var url = $"https://openlibrary.org/search.json?q={Uri.EscapeDataString(query)}&limit=1";
                    
                    var response = await httpClient.GetStringAsync(url);
                    var json = System.Text.Json.JsonDocument.Parse(response);
                    
                    if (json.RootElement.TryGetProperty("docs", out var docs) && docs.GetArrayLength() > 0)
                    {
                        var book = docs[0];
                        
                        // Obtener descripción de la obra
                        string description = null;
                        if (book.TryGetProperty("key", out var key))
                        {
                            try
                            {
                                var workUrl = $"https://openlibrary.org{key.GetString()}.json";
                                var workResponse = await httpClient.GetStringAsync(workUrl);
                                var workJson = System.Text.Json.JsonDocument.Parse(workResponse);
                                
                                if (workJson.RootElement.TryGetProperty("description", out var desc))
                                {
                                    if (desc.ValueKind == System.Text.Json.JsonValueKind.String)
                                    {
                                        description = desc.GetString();
                                    }
                                    else if (desc.ValueKind == System.Text.Json.JsonValueKind.Object && 
                                             desc.TryGetProperty("value", out var descValue))
                                    {
                                        description = descValue.GetString();
                                    }
                                }
                            }
                            catch { }
                        }
                        
                        var metadata = new BookMetadata
                        {
                            Title = book.TryGetProperty("title", out var t) ? t.GetString() : title,
                            Author = book.TryGetProperty("author_name", out var a) && a.GetArrayLength() > 0 
                                ? a[0].GetString() 
                                : author,
                            Synopsis = description,
                            PublishDate = book.TryGetProperty("first_publish_year", out var py) ? py.GetInt32().ToString() : null,
                            PageCount = book.TryGetProperty("number_of_pages_median", out var pc) ? pc.GetInt32() : 0,
                            Rating = 0,
                            Source = "Open Library"
                        };
                        
                        return metadata;
                    }
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error en Open Library: {ex.Message}");
            }
            
            return null;
        }
        
        private async Task AnalyzeUserCollection()
        {
            if (lvResults.SelectedItems.Count == 0)
            {
                Log("⚠️ Selecciona un archivo para analizar la colección");
                return;
            }
            
            dynamic tag = lvResults.SelectedItems[0].Tag;
            string username = tag?.Username;
            
            if (string.IsNullOrEmpty(username))
                return;
            
            var result = MessageBox.Show($"¿Buscar todos los archivos del usuario '{username}'?\n\nEsto puede tardar varios segundos.", 
                "Análisis de Colección", MessageBoxButtons.YesNo, MessageBoxIcon.Question);
            
            if (result != DialogResult.Yes)
                return;
            
            try
            {
                if (lblStatus != null) lblStatus.Text = $"Analizando colección de {username}...";
                Log($"Obteniendo información de usuario: {username}");
                
                var userInfo = await client.GetUserInfoAsync(username);
                
                // MEJORA #30: Usar pool de StringBuilder
                var stats = GetStringBuilder();
                stats.AppendLine($"👤 Usuario: {username}");
                stats.AppendLine($"📝 Descripción: {userInfo.Description ?? "Sin descripción"}");
                stats.AppendLine($"🖼️ Imagen: {(userInfo.HasPicture ? "Sí" : "No")}");
                stats.AppendLine($"📁 Carpetas en cola: {userInfo.QueueLength}");
                stats.AppendLine();
                stats.AppendLine("¿Deseas buscar todos sus archivos?");
                
                var searchResult = MessageBox.Show(stats.ToString(), $"Colección de {username}", 
                    MessageBoxButtons.YesNo, MessageBoxIcon.Information);
                
                if (searchResult == DialogResult.Yes)
                {
                    // Buscar por usuario específico
                    cmbSearch.Text = username;
                    await SearchAsync();
                }
                
                if (lblStatus != null) lblStatus.Text = "Análisis completado";
            }
            catch (Exception ex)
            {
                Log($"Error al analizar colección: {ex.Message}");
                DarkMessageBox.Show($"Error al obtener información del usuario:\n{ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
        private void SortResults(int column)
        {
            // En modo virtual, no podemos ordenar directamente
            // TODO: Implementar ordenación en el DataSource
            try
            {
                if (sortColumn == column)
                    sortAscending = !sortAscending;
                else
                {
                    sortColumn = column;
                    sortAscending = true;
                }
                
                // Por ahora, solo guardamos la preferencia de ordenación
                // La ordenación real se haría en searchDataSource
            }
            catch
            {
                // Ignorar errores de ordenación en modo virtual
            }
        }
        
        
        private void OpenDownloadedFile()
        {
            if (lvDownloads.SelectedItems.Count == 0)
                return;
            
            var selectedItem = lvDownloads.SelectedItems[0];
            var fileName = selectedItem.Text;
            
            // Buscar la tarea en downloadQueue para obtener la ruta real
            var task = downloadQueue.FirstOrDefault(t => 
                Path.GetFileName(t.File.FileName) == fileName || t.File.FileName == fileName);
            
            string filePath = null;
            
            if (task != null && !string.IsNullOrEmpty(task.LocalPath))
            {
                // Usar la ruta local guardada en la tarea
                filePath = task.LocalPath;
            }
            else
            {
                // Intentar construir la ruta (fallback)
                filePath = Path.Combine(downloadDir, fileName);
                
                // Si no existe, buscar en subdirectorios
                if (!System.IO.File.Exists(filePath))
                {
                    try
                    {
                        var files = System.IO.Directory.GetFiles(downloadDir, fileName, SearchOption.AllDirectories);
                        if (files.Length > 0)
                        {
                            filePath = files[0];
                        }
                    }
                    catch { }
                }
            }
            
            if (!string.IsNullOrEmpty(filePath) && System.IO.File.Exists(filePath))
            {
                try
                {
                    Log($"📂 Abriendo archivo: {filePath}");
                    Process.Start(new ProcessStartInfo(filePath) { UseShellExecute = true });
                }
                catch (Exception ex)
                {
                    DarkMessageBox.Show($"Error al abrir archivo: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                    Log($"❌ Error abriendo archivo: {ex.Message}");
                }
            }
            else
            {
                DarkMessageBox.Show($"El archivo no existe en:\n{filePath ?? "ruta desconocida"}\n\nVerifica que la descarga se haya completado correctamente.", 
                    "Archivo no encontrado", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                Log($"⚠️ Archivo no encontrado: {fileName}");
            }
        }
        
        private void CreateAuthorsTab(TabPage parent)
        {
            parent.BackColor = Color.FromArgb(18, 18, 18);
            
            var mainLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 2,
                RowCount = 3,
                BackColor = Color.FromArgb(18, 18, 18),
                Padding = new Padding(20)
            };
            mainLayout.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 60f));
            mainLayout.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 40f));
            mainLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize)); // Título
            mainLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize)); // Info
            mainLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100f)); // Contenido
            
            // Título
            var lblTitle = new Label 
            { 
                Text = "👤 Búsqueda por Autor", 
                AutoSize = true,
                ForeColor = Color.White, 
                Font = new Font("Segoe UI", 14, FontStyle.Bold),
                Margin = new Padding(0, 0, 0, 10)
            };
            mainLayout.Controls.Add(lblTitle, 0, 0);
            mainLayout.SetColumnSpan(lblTitle, 2);
            
            // Info
            var lblInfo = new Label 
            { 
                Text = "Busca automáticamente todos los libros/música de tus autores favoritos.", 
                AutoSize = true,
                ForeColor = Color.LightGray,
                Margin = new Padding(0, 0, 0, 20)
            };
            mainLayout.Controls.Add(lblInfo, 0, 1);
            mainLayout.SetColumnSpan(lblInfo, 2);
            
            // ListBox de autores
            var lstAuthors = new ListBox 
            { 
                Dock = DockStyle.Fill,
                BackColor = Color.FromArgb(45, 45, 45), 
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 10),
                BorderStyle = BorderStyle.FixedSingle
            };
            lstAuthors.Items.AddRange(authors.ToArray());
            mainLayout.Controls.Add(lstAuthors, 0, 2);
            
            // Panel de controles (derecha)
            var controlsPanel = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                FlowDirection = FlowDirection.TopDown,
                BackColor = Color.FromArgb(18, 18, 18),
                Padding = new Padding(10, 0, 0, 0),
                WrapContents = false
            };
            
            var txtAuthor = new TextBox 
            { 
                Width = 250,
                Height = 30,
                BackColor = Color.FromArgb(60, 60, 60), 
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 10),
                Margin = new Padding(0, 0, 0, 10)
            };
            controlsPanel.Controls.Add(txtAuthor);
            
            var btnAdd = new Button 
            { 
                Text = "➕ Agregar", 
                Width = 250, 
                Height = 40, 
                BackColor = Color.FromArgb(60, 60, 60), 
                ForeColor = Color.White, 
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 10),
                Margin = new Padding(0, 0, 0, 10)
            };
            btnAdd.FlatAppearance.BorderSize = 0;
            btnAdd.Click += (s, e) =>
            {
                if (!string.IsNullOrWhiteSpace(txtAuthor.Text) && !authors.Contains(txtAuthor.Text))
                {
                    var authorName = txtAuthor.Text;
                    authors.Add(authorName);
                    lstAuthors.Items.Add(authorName);
                    SaveAuthors();
                    txtAuthor.Clear();
                    
                    // MEJORA NICOTINE+: Publicar evento de autor agregado
                    _eventBus?.Publish(SystemEvents.AuthorAdded, new
                    {
                        AuthorName = authorName,
                        TotalAuthors = authors.Count,
                        Timestamp = DateTime.UtcNow
                    });
                }
            };
            controlsPanel.Controls.Add(btnAdd);
            
            var btnSearchAuthor = new Button 
            { 
                Text = "🔍 Buscar autor", 
                Width = 250, 
                Height = 40, 
                BackColor = Color.FromArgb(0, 120, 215), 
                ForeColor = Color.White, 
                FlatStyle = FlatStyle.Flat, 
                Font = new Font("Segoe UI", 10, FontStyle.Bold),
                Margin = new Padding(0, 0, 0, 10)
            };
            btnSearchAuthor.FlatAppearance.BorderSize = 0;
            btnSearchAuthor.Click += async (s, e) =>
            {
                if (lstAuthors.SelectedItem != null)
                {
                    string authorName = lstAuthors.SelectedItem.ToString();
                    Log($"Iniciando búsqueda de autor: {authorName}");
                    
                    // Cambiar a pestaña de búsqueda
                    SafeBeginInvoke(() =>
                    {
                        cmbSearch.Text = authorName;
                        tabControl.SelectedIndex = 0;
                    });
                    
                    // Esperar a que se cambie de pestaña
                    await Task.Delay(200).ConfigureAwait(false); // MEJORA #37
                    
                    // Iniciar búsqueda
                    await SearchAsync();
                }
                else
                {
                    Log("⚠️ Selecciona un autor de la lista primero");
                }
            };
            controlsPanel.Controls.Add(btnSearchAuthor);
            
            var btnRemove = new Button 
            { 
                Text = "❌ Eliminar", 
                Width = 250, 
                Height = 40, 
                BackColor = Color.FromArgb(60, 60, 60), 
                ForeColor = Color.White, 
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 10)
            };
            btnRemove.FlatAppearance.BorderSize = 0;
            btnRemove.Click += (s, e) =>
            {
                if (lstAuthors.SelectedItem != null)
                {
                    var authorName = lstAuthors.SelectedItem.ToString();
                    authors.Remove(authorName);
                    lstAuthors.Items.Remove(lstAuthors.SelectedItem);
                    SaveAuthors();
                    
                    // MEJORA NICOTINE+: Publicar evento de autor eliminado
                    _eventBus?.Publish(SystemEvents.AuthorRemoved, new
                    {
                        AuthorName = authorName,
                        TotalAuthors = authors.Count,
                        Timestamp = DateTime.UtcNow
                    });
                }
            };
            controlsPanel.Controls.Add(btnRemove);
            
            mainLayout.Controls.Add(controlsPanel, 1, 2);
            var tipsAuthors = GetToolTip();
            tipsAuthors.SetToolTip(lblTitle, "Gestión de autores (agregar, buscar, eliminar)");
            tipsAuthors.SetToolTip(lblInfo, "Busca automáticamente libros/música de tus autores");
            tipsAuthors.SetToolTip(lstAuthors, "Lista de autores guardados");
            tipsAuthors.SetToolTip(txtAuthor, "Nombre del autor a agregar");
            tipsAuthors.SetToolTip(btnAdd, "Agregar autor a la lista");
            tipsAuthors.SetToolTip(btnSearchAuthor, "Buscar resultados del autor seleccionado");
            tipsAuthors.SetToolTip(btnRemove, "Eliminar autor seleccionado de la lista");
            parent.Controls.Add(mainLayout);
        }
        
