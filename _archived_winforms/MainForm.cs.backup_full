        public MainForm()
        {
            // Constructor mínimo - toda la inicialización se hace en el evento Load
            this.Text = "SlskDown - Cliente Soulseek";
            this.Size = new Size(1920, 1200);
            this.MinimumSize = new Size(1700, 1080);
            this.StartPosition = FormStartPosition.CenterScreen;
            this.BackColor = Color.FromArgb(18, 18, 18);
            
            // Inicializar métricas de sesión
            InitializeSessionMetrics();
            
            // Inicializar limitador de ancho de banda
            bandwidthLimiter = new Core.BandwidthLimiter(maxBandwidthKBps);
            
            // Inicializar gestor de memoria
            memoryManager = new Core.MemoryManager();
            memoryManager.OnMemoryWarning += (mb) => LogEx(LogLevel.WARN, LogCategory.SISTEMA, $"⚠️ Memoria alta: {mb} MB");
            memoryManager.OnMemoryCritical += (mb) => LogEx(LogLevel.ERROR, LogCategory.SISTEMA, $"🚨 Memoria crítica: {mb} MB");
            memoryManager.OnMemoryEmergency += (mb) => LogEx(LogLevel.FATAL, LogCategory.SISTEMA, $"💥 EMERGENCIA de memoria: {mb} MB");
            memoryManager.OnCleanupCompleted += (result) => LogEx(LogLevel.INFO, LogCategory.SISTEMA, $"🧹 Cleanup memoria: {result}");
            
            // CONFIGURACIÓN DE REDES: Cargar configuración de redes P2P
            _networkConfig = NetworkConfiguration.Load();
            
            // Registrar evento Load para inicialización pesada
            this.Load += MainForm_Load;
            this.FormClosing += MainForm_FormClosing;
            
            // NOTA: Los eventos ResizeEnd y LocationChanged se registran en MainForm_Load
            // después de que _settingsManager esté inicializado para evitar NullReferenceException
            
            // Habilitar captura de teclas
            this.KeyPreview = true;
        }
        
        // Atajos de teclado globales
        protected override bool ProcessCmdKey(ref Message msg, Keys keyData)
        {
            try
            {
                // Ctrl+F: Enfocar búsqueda
                // Ctrl+F: Buscar (desactivado - control no existe)
                /*
                if (keyData == (Keys.Control | Keys.F))
                {
                    if (txtSearch != null && tabControl.SelectedIndex == 0)
                    {
                        txtSearch.Focus();
                        txtSearch.SelectAll();
                        return true;
                    }
                }
                */
                
                // Ctrl+D: Descargar seleccionado
                if (keyData == (Keys.Control | Keys.D))
                {
                    if (tabControl.SelectedIndex == 0 && lvResults != null && lvResults.SelectedItems.Count > 0)
                    {
                        DownloadSelected();
                        return true;
                    }
                }
                
                // Ctrl+P: Pausar/Reanudar descargas
                // Ctrl+P: Pausar descargas (desactivado - control no existe)
                /*
                if (keyData == (Keys.Control | Keys.P))
                {
                    if (btnPauseDownloads != null)
                    {
                        btnPauseDownloads.PerformClick();
                        return true;
                    }
                }
                */
                
                // MEJORA #12 (Nicotine+): Ctrl+Shift+T - Reabrir última pestaña cerrada
                if (keyData == (Keys.Control | Keys.Shift | Keys.T))
                {
                    if (tabHistoryManager != null && tabControl != null)
                    {
                        try
                        {
                            if (tabHistoryManager.ReopenLastTab(tabControl))
                            {
                                Log("✅ Pestaña reabierta con Ctrl+Shift+T");
                                return true;
                            }
                        }
                        catch (Exception exTab)
                        {
                            Log($"⚠️ Error reabriendo pestaña: {exTab.Message}");
                        }
                    }
                }
                
                // MEJORA #12 (Nicotine+): Ctrl+W - Cerrar pestaña actual (opcional)
                if (keyData == (Keys.Control | Keys.W))
                {
                    if (tabHistoryManager != null && tabControl != null && 
                        tabControl.SelectedTab != null && tabControl.TabPages.Count > 1)
                    {
                        try
                        {
                            var tab = tabControl.SelectedTab;
                            var index = tabControl.SelectedIndex;
                            tabControl.TabPages.Remove(tab);
                            tabHistoryManager.RecordClosedTab(tab, index);
                            Log($"📋 Pestaña '{tab.Text}' cerrada con Ctrl+W");
                            return true;
                        }
                        catch (Exception exClose)
                        {
                            Log($"⚠️ Error cerrando pestaña: {exClose.Message}");
                        }
                    }
                }
                
                // Ctrl+L: Limpiar log
                if (keyData == (Keys.Control | Keys.L))
                {
                    if (tabControl.SelectedIndex == 8 && txtLog != null)  // Tab de logs
                    {
                        txtLog.Clear();
                        Log("📋 Log limpiado manualmente");
                        return true;
                    }
                }
                
                // Ctrl+H: Ir a historial
                if (keyData == (Keys.Control | Keys.H))
                {
                    tabControl.SelectedIndex = 6;  // Tab de historial
                    return true;
                }
                
                // Ctrl+S: Guardar configuración
                if (keyData == (Keys.Control | Keys.S))
                {
                    SaveConfig();
                    Log("💾 Configuración guardada manualmente");
                    return true;
                }
                
                // F5: Actualizar vista actual
                if (keyData == Keys.F5)
                {
                    if (tabControl.SelectedIndex == 2)  // Historial
                    {
                        RefreshHistoryView(true);
                        return true;
                    }
                }
                
                // Esc: Detener búsqueda
                if (keyData == Keys.Escape)
                {
                    if (tabControl.SelectedIndex == 0 && btnStopSearch != null && btnStopSearch.Enabled)
                    {
                        btnStopSearch.PerformClick();
                        return true;
                    }
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error procesando atajo de teclado: {ex.Message}");
            }
            
            return base.ProcessCmdKey(ref msg, keyData);
        }
        
        protected override void WndProc(ref Message m)
        {
            try
            {
                if (m.Msg == WM_SYSCOMMAND)
                {
                    var wParam = (int)(m.WParam.ToInt64() & 0xFFFF);
                    if ((wParam & 0xFFF0) == SC_CLOSE)
                    {
                        SafeLog("WndProc: WM_SYSCOMMAND / SC_CLOSE recibido\n");
                    }
                }
                else if (m.Msg == WM_CLOSE)
                {
                    SafeLog("WndProc: WM_CLOSE recibido\n");
                }
            }
            catch (Exception ex)
            {
                SafeLog($"WndProc: error registrando mensaje de cierre: {ex.Message}\n");
            }

            base.WndProc(ref m);
        }
        
        private async void MainForm_Load(object sender, EventArgs e)
        {
            try
            {
                SafeLog("MainForm_Load: Iniciando inicialización...\n");
                
                // Inicializar sistema anti-rate-limiting
                _rateLimitDetector = new SlskDown.Core.RateLimitDetector();
                SafeLog("✅ RateLimitDetector inicializado");
                
                // 🚀 INICIALIZAR SISTEMAS AVANZADOS
                await InitializeAdvancedSystems();
                
                // Inicializar dataDir ANTES de usarlo
                if (portableMode)
                {
                    dataDir = portableDataDir;
                }
                else
                {
                    dataDir = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.ApplicationData), "SlskDown");
                }
                
                // Crear directorio si no existe
                if (!System.IO.Directory.Exists(dataDir))
                {
                    System.IO.Directory.CreateDirectory(dataDir);
                    Log($"📁 Directorio de datos creado: {dataDir}");
                }
                
                Log($"📂 Directorio de datos: {dataDir}");
                
                // MEJORA #2: Inicializar caché persistente SQLite
                try
                {
                    persistentLanguageCache = new LanguageCache();
                    Log("✅ Caché persistente SQLite inicializada");
                    
                    // Limpiar entradas antiguas (más de 30 días)
                    int cleaned = persistentLanguageCache.CleanOldEntries(720);
                    if (cleaned > 0)
                    {
                        Log($"🧹 Limpiadas {cleaned} entradas antiguas de la caché");
                    }
                    
                    // Mostrar estadísticas
                    var stats = persistentLanguageCache.GetStats();
                    Log($"📊 Caché: {stats.TotalEntries:N0} entradas ({stats.SpanishCount:N0} español, {stats.NonSpanishCount:N0} otros)");
                }
                catch (Exception ex)
                {
                    Log($"⚠️ Error inicializando caché persistente: {ex.Message}");
                }
                
                // Inicializar servicio de credenciales seguras
                InitializeSecureCredentials();
                
                // Inicializar variables (las que no son readonly)
                downloadSpeedHistory = new List<double>();
                
                // Inicializar UnifiedSettingsManager (reemplaza ConfigManager)
                _settingsManager = new SlskDown.Core.UnifiedSettingsManager(dataDir);
                var configPath = _settingsManager.SettingsPath;
                Log($"📁 Config path unificado: {configPath}");
                
                // Cargar configuración
                LoadConfig();
                
                // OPT #6: Verificar disponibilidad de Rust optimizer
                try
                {
                    if (RustOptimizer.IsAvailable)
                    {
                        var version = RustOptimizer.GetVersion();
                        Log($"✅ Rust optimizer cargado: {version}");
                        Log("⚡ Optimizaciones nativas habilitadas (10-50x más rápido)");
                    }
                    else
                    {
                        Log("ℹ️ Rust optimizer no disponible - usando fallback C#");
                        Log("   Para habilitar: compilar c:\\p2p\\slsk_optimizer\\");
                    }
                }
                catch (Exception ex)
                {
                    Log($"⚠️ Error verificando Rust optimizer: {ex.Message}");
                    Log("   Continuando con fallback C#");
                }
                
                // OPT #9: Cargar caché de autores sin español
                LoadNoSpanishAuthorsCache();
                
                // Registrar eventos para guardar tamaño y posición DESPUÉS de que _settingsManager esté inicializado
                // OPTIMIZACIÓN: Solo guardar en ResizeEnd (LocationChanged se dispara demasiado frecuentemente)
                this.ResizeEnd += (s, ev) => SaveConfig();
                // Usar FormClosing en lugar de LocationChanged para evitar guardados excesivos
                Log("✅ Eventos de ventana registrados (ResizeEnd)");
                
                // Inicializar base de datos SQLite legacy
                InitializeLegacyDatabase();
                
                // MEJORA NICOTINE+: Inicializar componentes inspirados en Nicotine+
                InitializeNicotineImprovements();
                
                // Limpiar logs antiguos al iniciar
                CleanupOldLogs();
                
                // Bloquear SaveConfig durante la creación de tabs y restauración de columnas
                isRestoringColumns = true;
                Log("🔒 SaveConfig bloqueado durante inicialización");
                
                // Crear tabs
                CreateTabs();
                
                // Restaurar anchos de columnas DESPUÉS de crear los ListView
                RestoreColumnWidths();
                
                // Registrar eventos de columnas DESPUÉS de restaurar
                RegisterColumnEvents();
                
                // Inicializar cliente Soulseek
                await InitializeSoulseekClient();
                
                // ============================================
                // INICIALIZAR OPTIMIZACIONES DE RENDIMIENTO
                // ============================================
                InitializePerformanceOptimizations();
                
                // ============================================
                // INICIALIZAR TIMERS CONSOLIDADOS Y OBJECT POOL
                // ============================================
                InitializeAdvancedOptimizations();
                
                // ============================================
                // INICIALIZAR HEALTH SCORE DASHBOARD
                // ============================================
                InitializeHealthScoreDashboard();
                
                // Cargar métricas históricas
                LoadMetricsFromFile();
                
                // ============================================
                // INICIALIZAR SESSION METRICS
                // ============================================
                InitializeSessionMetrics();

                // Monitor de conexión en background
                StartConnectionMonitor();
                
                // MEJORA #5: Inicializar health check periódico
                InitializeHealthCheck();
                
                // Auto-conexión si está habilitada
                Log($"🔍 Verificando auto-conexión: autoConnect={autoConnect}, username='{username}' (longitud: {username?.Length ?? 0}), password={new string('*', password?.Length ?? 0)}");
                
                // Verificar si hay alguna red habilitada para conectar
                bool shouldAutoConnect = (_networkConfig?.SoulseekEnabled == true && autoConnect && !string.IsNullOrWhiteSpace(username) && !string.IsNullOrWhiteSpace(password));
                
                if (shouldAutoConnect)
                {
                    Log("🔄 Auto-conexión habilitada, conectando en 2 segundos...");
                    
                    // Usar timer en lugar de Task.Run para asegurar que se ejecute
                    var autoConnectTimer = new System.Windows.Forms.Timer();
                    autoConnectTimer.Interval = RECONNECT_DELAY_MS;
                    autoConnectTimer.Tick += async (s, ev) =>
                    {
                        autoConnectTimer.Stop();
                        autoConnectTimer.Dispose();
                        
                        try
                        {
                            // Evitar que la reconexión automática interfiera con la conexión inicial
                            lock (this)
                            {
                                if (isConnecting || isReconnecting)
                                {
                                    Log("⚠️ Auto-conexión cancelada - ya hay un intento en curso");
                                    return;
                                }
                            }
                            
                            Log("🚀 Iniciando auto-conexión a redes habilitadas...");
                            
                            // Conectar a Soulseek si está habilitado y tiene credenciales
                            if (_networkConfig?.SoulseekEnabled == true && autoConnect && !string.IsNullOrWhiteSpace(username) && !string.IsNullOrWhiteSpace(password))
                            {
                                Log("🔵 Auto-conectando a Soulseek...");
                                await ConnectToSoulseek();
                            }
                            else if (_networkConfig?.SoulseekEnabled == true)
                            {
                                Log("ℹ️ Soulseek habilitado pero falta autoConnect o credenciales");
                            }
                            
                            // Actualizar el estado en la UI
                            UpdateNetworkStatusLabel();
                        }
                        catch (Exception connEx)
                        {
                            Log($"❌ Auto-conexión falló: {connEx.Message}");
                            Log("🔄 El sistema de reconexión automática se encargará de reintentar");
                            // No mostrar diálogo - dejar que el sistema de reconexión maneje esto
                            
                            // Activar reconexión automática si no está ya activa
                            if (autoReconnect && !isReconnecting)
                            {
                                // MEJORA #26: Eliminar Task.Run redundante
                                _ = CheckAndReconnect();
                            }
                        }
                    };
                    autoConnectTimer.Start();
                    Log("⏰ Timer de auto-conexión iniciado");
                }
                else
                {
                    Log($"⚠️ Auto-conexión deshabilitada o credenciales faltantes");
                    if (!autoConnect)
                        Log("   - autoConnect está deshabilitado");
                    if (string.IsNullOrWhiteSpace(username))
                        Log("   - username está vacío");
                    if (string.IsNullOrWhiteSpace(password))
                        Log("   - password está vacío");
                    if (_networkConfig?.SoulseekEnabled != true)
                        Log("   - Soulseek no está habilitado");
                }
                
                // Aplicar tema oscuro a toda la UI (evita texto negro en fondo oscuro)
                try
                {
                    if (themeManager == null) themeManager = new ThemeManager();
                    themeManager.ApplyTheme(this);
                }
                catch { }
                
                // MEJORAS NICOTINE+ 2024: Inicializar nuevos managers
                try
                {
                    Log("🎵 Inicializando mejoras de Nicotine+ 2024...");
                    
                    // #7: Graceful Shutdown Manager
                    shutdownManager = new SlskDown.Core.GracefulShutdownManager(
                        () => new List<object>(), // TODO: Implementar GetActiveUploads()
                        () => new List<object>(), // TODO: Implementar GetActiveDownloads()
                        Log
                    );
                    Log("✅ GracefulShutdownManager inicializado");
                    
                    // #11: Download Cleanup Manager
                    cleanupManager = new SlskDown.Core.DownloadCleanupManager(Log);
                    Log("✅ DownloadCleanupManager inicializado");
                    
                    // #12: Tab History Manager
                    tabHistoryManager = new SlskDown.Core.TabHistoryManager(10, Log);
                    Log("✅ TabHistoryManager inicializado");
                    
                    // #8: Share Scanner with Progress
                    shareScanner = new SlskDown.Core.ShareScannerWithProgress(Log);
                    Log("✅ ShareScannerWithProgress inicializado");
                    
                    // #13-15: Advanced Network Features
                    networkFeatures = new SlskDown.Core.AdvancedNetworkFeatures(Log);
                    Log("✅ AdvancedNetworkFeatures inicializado");
                    
                    Log("🎉 Todas las mejoras de Nicotine+ 2024 inicializadas");
                }
                catch (Exception exNic)
                {
                    Log($"⚠️ Error inicializando mejoras Nicotine+: {exNic.Message}");
                }
                
                // Cargar cola de descargas guardada automáticamente (al final de la inicialización)
                LoadDownloadQueue();

                SafeLog("MainForm_Load: Inicialización completada\n");
                
                // CONFIGURACIÓN DE REDES: Aplicar configuración y mostrar estado
                ApplyNetworkConfiguration();
            }
            catch (Exception ex)
            {
                SafeLog($"ERROR en MainForm_Load: {ex.Message}\n{ex.StackTrace}\n");
                DarkMessageBox.Show($"Error al inicializar la aplicación:\n{ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
        /// <summary>
        /// Aplica la configuración de redes cargada
        /// </summary>
        private void ApplyNetworkConfiguration()
        {
            try
            {
                // MIGRACIÓN: Forzar Soulseek siempre habilitado (doble verificación)
                if (_networkConfig != null)
                {
                    _networkConfig.SoulseekEnabled = true;
                    _networkConfig.PreferredNetwork = "Soulseek";
                }
                
                // Mostrar resumen de redes habilitadas
                Log("═══════════════════════════════════════════════════");
                Log("🌐 CONFIGURACIÓN DE REDES P2P");
                Log("═══════════════════════════════════════════════════");
                Log($"   {_networkConfig.GetModeDescription()}");
                Log($"   🔵 Soulseek: {(_networkConfig.SoulseekEnabled ? "✅ HABILITADO" : "❌ DESHABILITADO")}");
                Log("═══════════════════════════════════════════════════");
                
                // Log de redes activas
                var activeNetworks = _networkConfig.GetActiveNetworks();
                if (activeNetworks.Length > 0)
                {
                    Log($"✅ Redes activas: {string.Join(", ", activeNetworks)}");
                }
                else
                {
                    Log("⚠️ No hay redes activas configuradas");
                }
                
                Log("✅ Configuración de redes actualizada");
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error aplicando configuración de redes: {ex.Message}");
            }
        }
        
        /// <summary>
        /// Abre el formulario de configuración de redes
        /// </summary>
        private void OpenNetworkConfiguration()
        {
            try
            {
                using var configForm = new SlskDown.UI.NetworkConfigurationForm();
                if (configForm.ShowDialog() == DialogResult.OK)
                {
                    // Recargar configuración
                    _networkConfig = NetworkConfiguration.Load();
                    ApplyNetworkConfiguration();
                    
                    Log("✅ Configuración de redes actualizada");
                    
                    // Mostrar mensaje al usuario
                    DarkMessageBox.Show(
                        $"Configuración guardada correctamente.\n\n{_networkConfig.GetModeDescription()}",
                        "Configuración de Redes",
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Information
                    );
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error abriendo configuración de redes: {ex.Message}");
                DarkMessageBox.Show(
                    $"Error al abrir configuración de redes:\n{ex.Message}",
                    "Error",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Error
                );
            }
        }
        
        private void MainForm_FormClosing(object sender, FormClosingEventArgs e)
        {
            SafeLog($"MainForm_FormClosing: inicio (Reason={e.CloseReason}, Cancel={e.Cancel})\n");
            
            // MEJORA #7 (Nicotine+): Graceful Shutdown - Esperar uploads activos
            if (shutdownManager != null && e.CloseReason == CloseReason.UserClosing)
            {
                try
                {
                    if (!shutdownManager.TryShutdown())
                    {
                        e.Cancel = true; // Usuario canceló el cierre
                        SafeLog("❌ Cierre cancelado por el usuario\n");
                        return;
                    }
                }
                catch (Exception shutdownEx)
                {
                    SafeLog($"⚠️ Error en Graceful Shutdown: {shutdownEx.Message}\n");
                }
            }
            
            // Forzar cierre inmediato al inicio para evitar cuelgues
            // MEJORA #32: Usar Task.Delay en lugar de Thread.Sleep
            Task.Run(async () =>
            {
                await Task.Delay(500).ConfigureAwait(false); // MEJORA #37: Dar tiempo a cleanup básico
                try
                {
                    var currentProcess = System.Diagnostics.Process.GetCurrentProcess();
                    currentProcess.Kill();
                }
                catch
                {
                    Environment.Exit(0);
                }
            });
            
            try
            {
                // MEJORA NICOTINE+: Detener componentes
                try
                {
                    _autoSaveManager?.Stop();
                    _eventBus?.Publish(SlskDown.Core.SystemEvents.Quit, null);
                    _eventBus?.CancelAllScheduled();
                    SafeLog("✅ Componentes de Nicotine+ detenidos\n");
                }
                catch (Exception nicotineEx)
                {
                    SafeLog($"⚠️ Error deteniendo componentes de Nicotine+: {nicotineEx.Message}\n");
                }
                
                // MEJORA #1: Detener y limpiar Health Check Service
                try
                {
                    healthCheckService?.Dispose();
                    SafeLog("✅ Health Check Service limpiado\n");
                }
                catch (Exception hcEx)
                {
                    SafeLog($"⚠️ Error limpiando Health Check Service: {hcEx.Message}\n");
                }
                
                // Limpiar Memory Manager
                try
                {
                    memoryManager?.Dispose();
                    SafeLog("✅ Memory Manager limpiado\n");
                }
                catch (Exception mmEx)
                {
                    SafeLog($"⚠️ Error limpiando Memory Manager: {mmEx.Message}\n");
                }
                
                // Forzar guardado final sin throttle
                lastConfigSave = DateTime.MinValue;
                SaveConfig();
                
                SafeLog("✅ Configuración guardada al cerrar\n");

                try
                {
                    downloadManager?.Stop();
                    SafeLog("✅ DownloadManager detenido\n");

                    downloadManager?.SaveStateAsync().GetAwaiter().GetResult();
                    SafeLog("✅ Estado de DownloadManager guardado\n");
                }
                catch (Exception stateEx)
                {
                    SafeLog($"⚠️ Error deteniendo/guardando DownloadManager: {stateEx.Message}\n");
                }

                try
                {
                    StopAutoMode();
                }
                catch (Exception autoModeEx)
                {
                    AutoLog($"⚠️ Error deteniendo modo automático: {autoModeEx.Message}");
                }

                try
                {
                    autoSearchRunning = false;
                    autoPurgeRunning = false;
                    autoSearchPausedByDisconnection = false;
                    autoSearchCts?.Cancel();
                    autoSearchCts?.Dispose();
                    autoSearchCts = null;
                    StopAutoSearchUIUpdateTimer();
                }
                catch (Exception autoSearchEx)
                {
                    AutoLog($"⚠️ Error deteniendo búsqueda automática: {autoSearchEx.Message}");
                }

                try
                {
                    StopShareWatchers();
                }
                catch (Exception ex) { AutoLog($"⚠️ Error deteniendo watchers: {ex.Message}"); }

                try
                {
                    appCts?.Cancel();
                }
                catch (Exception ex) { AutoLog($"⚠️ Error cancelando CTS: {ex.Message}"); }

                try
                {
                    client?.Dispose();
                    client = null;

                    if (clientPool != null)
                    {
                        foreach (var poolClient in clientPool)
                        {
                            try { poolClient?.Dispose(); } catch (Exception disposeEx) { AutoLog($"⚠️ Error disponiendo cliente del pool: {disposeEx.Message}"); }
                        }
                        clientPool.Clear();
                        currentClientIndex = 0;
                    }
                }
                catch (Exception clientEx)
                {
                    AutoLog($"⚠️ Error al disposar clientes: {clientEx.Message}");
                }

                try
                {
                    // Cerrar cualquier formulario adicional que siga abierto (config, diálogo, etc.)
                    foreach (Form openForm in Application.OpenForms.Cast<Form>().ToList())
                    {
                        if (openForm != this)
                        {
                            try
                            {
                                openForm.Close();
                                openForm.Dispose();
                            }
                            catch (Exception formEx)
                            {
                                AutoLog($"⚠️ Error cerrando formulario secundario '{openForm.Name}': {formEx.Message}");
                            }
                        }
                    }
                }
                catch (Exception formsEx)
                {
                    AutoLog($"⚠️ Error cerrando formularios secundarios: {formsEx.Message}");
                }

                // Cerrar base de datos
                try
                {
                    database?.Dispose();
                    SafeLog("✅ Base de datos cerrada correctamente\n");
                }
                catch (Exception dbEx)
                {
                    SafeLog($"⚠️ Error cerrando base de datos: {dbEx.Message}\n");
                }
                
                // MEJORA #2: Cerrar caché persistente SQLite
                try
                {
                    persistentLanguageCache?.Dispose();
                    SafeLog("✅ Caché persistente cerrada correctamente\n");
                }
                catch (Exception cacheEx)
                {
                    SafeLog($"⚠️ Error cerrando caché persistente: {cacheEx.Message}\n");
                }
                
                // Limpiar optimizaciones avanzadas
                try
                {
                    consolidatedTimers?.Dispose();
                    // downloadTaskPool no tiene método Clear en la implementación actual
                    SafeLog("✅ Optimizaciones avanzadas limpiadas\n");
                }
                catch (Exception optEx)
                {
                    SafeLog($"⚠️ Error limpiando optimizaciones: {optEx.Message}\n");
                }
                
                // OPTIMIZACIÓN: Disponer todos los timers para evitar memory leaks
                try
                {
                    healthScoreTimer?.Dispose();
                    watchlistTimer?.Dispose();
                    reconnectTimer?.Dispose();
                    keepAliveTimer?.Dispose();
                    saveTimer?.Dispose();
                    qualityTimer?.Dispose();
                    reconnectCheckTimer?.Dispose();
                    autoCleanupTimer?.Dispose();
                    autoTestTimer?.Dispose();
                    aggressiveModeTimer?.Dispose();
                    statsUpdateTimer?.Dispose();
                    downloadUIBatchTimer?.Dispose();
                    wishlistSearchTimer?.Dispose();
                    SafeLog("✅ Timers dispuestos correctamente\n");
                }
                catch (Exception timerEx)
                {
                    SafeLog($"⚠️ Error disponiendo timers: {timerEx.Message}\n");
                }
            }
            catch (Exception ex)
            {
                SafeLog($"❌ Error al guardar configuración al cerrar: {ex.Message}\n");
            }
            finally
            {
                try
                {
                    SafeLog("🛑 Cerrando aplicación...\n");
                    
                    // Forzar cierre inmediato sin esperar a que termine Application.Run
                    // MEJORA #32: Usar Task.Delay en lugar de Thread.Sleep
                    Task.Run(async () =>
                    {
                        await Task.Delay(100).ConfigureAwait(false); // MEJORA #37: Dar tiempo a que se escriba el log
                        
                        // Terminación agresiva del proceso
                        try
                        {
                            var currentProcess = System.Diagnostics.Process.GetCurrentProcess();
                            currentProcess.Kill();
                        }
                        catch
                        {
                            Environment.Exit(0);
                        }
                    });
                    
                    Application.ExitThread();
                    Application.Exit();
                }
                catch (Exception exitEx)
                {
                    SafeLog($"⚠️ Error forzando cierre: {exitEx.Message}\n");
                    Environment.Exit(1);
                }
                finally
                {
                    SafeLog("MainForm_FormClosing: fin\n");
                }
            }
        }
        
        /// <summary>
        /// Initializes the secure credentials system and migrates from old config if needed.
        /// </summary>
        private void InitializeSecureCredentials()
        {
            try
            {
                Log("🔐 Inicializando sistema de credenciales seguras...");
                
                // Create secure credentials service
                secureCredentials = new SecureCredentialsService(dataDir, portableMode);
                
                // Create migration service
                credentialMigration = new CredentialMigrationService(secureCredentials, configPath);
                
                // Attempt migration from old config.json
                if (credentialMigration.MigrateFromConfig())
                {
                    Log("✅ Credenciales migradas desde config.json");
                }
                
                // Load credentials from secure storage
                var creds = secureCredentials.LoadCredentials();
                if (creds.HasValue)
                {
                    username = creds.Value.username;
                    password = creds.Value.password;
                    Log($"✅ Credenciales cargadas para usuario: {username}");
                }
                else
                {
                    Log("⚠️ No hay credenciales guardadas - se solicitarán al conectar");
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error inicializando credenciales: {ex.Message}");
                // Continue without crashing - credentials will be prompted when needed
            }
        }
        
        /// <summary>
        /// Prompts user for credentials if not stored securely.
        /// Returns true if credentials were obtained successfully.
        /// </summary>
        private bool PromptForCredentialsIfNeeded()
        {
            try
            {
                // Check if we already have credentials
                if (!string.IsNullOrWhiteSpace(username) && !string.IsNullOrWhiteSpace(password))
                {
                    return true;
                }
                
                Log("🔑 Solicitando credenciales al usuario...");
                
                // Show credential prompt dialog
                var result = CredentialPromptDialog.ShowDialog(this, username);
                
                if (result.HasValue)
                {
                    username = result.Value.username;
                    password = result.Value.password;
                    
                    // Save to secure storage if user wants to remember
                    if (result.Value.remember)
                    {
                        if (secureCredentials.SaveCredentials(username, password))
                        {
                            Log("✅ Credenciales guardadas de forma segura");
                        }
                        else
                        {
                            Log("⚠️ No se pudieron guardar las credenciales");
                        }
                    }
                    
                    return true;
                }
                else
                {
                    Log("❌ Usuario canceló ingreso de credenciales");
                    return false;
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error solicitando credenciales: {ex.Message}");
                return false;
            }
        }
        

        private void CreateTabs()
        {
            tabControl = new TabControl
            {
                Dock = DockStyle.Fill,
                Font = new Font("Segoe UI", 10, FontStyle.Regular),
                DrawMode = TabDrawMode.OwnerDrawFixed,
                ItemSize = new Size(140, 45),
                Name = "tabControl",
                Padding = new Point(12, 10)
            };
            
            // Habilitar doble buffer para reducir parpadeo
            typeof(TabControl).InvokeMember("DoubleBuffered",
                System.Reflection.BindingFlags.SetProperty | System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic,
                null, tabControl, new object[] { true });
            
            tabControl.DrawItem += (s, e) =>
            {
                if (e.Index < 0 || e.Index >= tabControl.TabPages.Count) return;
                
                var tabPage = tabControl.TabPages[e.Index];
                var isSelected = e.State == DrawItemState.Selected;
                var backColor = isSelected ? Color.FromArgb(0, 122, 204) : Color.FromArgb(35, 35, 40);
                var textColor = isSelected ? Color.White : Color.FromArgb(180, 180, 185);
                
                // Optimización: usar Graphics de alta calidad solo si es necesario
                e.Graphics.SmoothingMode = System.Drawing.Drawing2D.SmoothingMode.HighSpeed;
                e.Graphics.TextRenderingHint = System.Drawing.Text.TextRenderingHint.SystemDefault;
                
                using (var brush = new SolidBrush(backColor))
                {
                    e.Graphics.FillRectangle(brush, e.Bounds);
                }
                
                TextRenderer.DrawText(e.Graphics, tabPage.Text, tabControl.Font, e.Bounds, textColor, 
                    TextFormatFlags.HorizontalCenter | TextFormatFlags.VerticalCenter | TextFormatFlags.NoPrefix);
            };
            
            // LAZY LOADING: Construir pestañas solo cuando se seleccionan
            var tabBuilders = new Dictionary<string, Action<TabPage>>();
            var tabsBuilt = new HashSet<string>();

            string NormalizeTabKey(string value) => (value ?? string.Empty).Trim();

            void AddLazyTab(string name, Action<TabPage> builder)
            {
                var tab = new TabPage(name);
                tab.BackColor = Color.FromArgb(18, 18, 18);

                var key = NormalizeTabKey(name);
                tab.Tag = key;
                tabBuilders[key] = builder;
                tab.Enter += (s, _) => BuildTabIfNeeded(tab);
                tabControl.TabPages.Add(tab);
            }

            void BuildTabIfNeeded(TabPage tab)
            {
                if (tab == null) return;

                var key = tab.Tag as string ?? NormalizeTabKey(tab.Text);
                if (tabsBuilt.Contains(key)) return;

                if (tabBuilders.TryGetValue(key, out var builder))
                {
                    builder(tab);
                    tabsBuilt.Add(key);
                }
            }
            
            tabControl.SelectedIndexChanged += (s, e) =>
            {
                try
                {
                    if (tabControl.SelectedTab == null) return;
                    
                    var sw = System.Diagnostics.Stopwatch.StartNew();
                    var tabName = tabControl.SelectedTab.Text?.Trim() ?? "?";
                    
                    // Construir pestaña si no se ha construido aún (solo primera vez)
                    var key = tabControl.SelectedTab.Tag as string ?? NormalizeTabKey(tabControl.SelectedTab.Text);
                    if (!tabsBuilt.Contains(key))
                    {
                        BuildTabIfNeeded(tabControl.SelectedTab);
                    }
                    
                    // Lazy loading de grilla de autores (Automático) - SOLO si está vacía
                    if (tabName.Contains("Automático"))
                    {
                        if (allAuthorsData.Count > 0 && lvAutoAuthors != null && lvAutoAuthors.Items.Count == 0)
                        {
                            AutoLog($"📊 Pestaña {tabName} visible - Cargando {allAuthorsData.Count:N0} autores en grilla...");
                            lastAuthorsRefresh = DateTime.MinValue;
                            RefreshAuthorsListView();
                        }
                    }
                    
                    sw.Stop();
                    if (sw.ElapsedMilliseconds > 50)
                    {
                        Log($"⚠️ Cambio a pestaña '{tabName}' tardó {sw.ElapsedMilliseconds}ms");
                    }
                }
                catch (Exception ex)
                {
                    AutoLog($"⚠️ Error en lazy loading: {ex.Message}");
                }
            };
            
            // Agregar pestañas con lazy loading
            AddLazyTab(" Búsqueda", CreateSearchTab);
            AddLazyTab("Descargas", CreateDownloadsTab);
            AddLazyTab(" Lista Negra", CreateBlacklistTab);
            AddLazyTab(" Watchlist", CreateWatchlistTab);
            AddLazyTab(" Autores", CreateAuthorsTab);
            AddLazyTab(" Automático ", CreateAutomTab); // Espacio extra al final para forzar rebuild
            
            // Historial se crea diferente, mantener como está
            tabControl.TabPages.Add(CreateHistoryTab());
            
            AddLazyTab(" Configuración", CreateConfigTab);
            AddLazyTab(" Log", CreateLogTab);
            AddLazyTab("🌐 Traducir", CreateTranslateTab);
            
            // 🚀 AGREGAR PESTAÑAS AVANZADAS DE SLSKDOWN 2.0
            AddLazyTab("📊 Dashboard", CreateDashboardTab);
            AddLazyTab("🔌 Plugins", CreatePluginsTab);
            AddLazyTab("🤖 IA Assistant", CreateAIAssistantTab);
            
            // Construir la primera pestaña (Búsqueda) inmediatamente
            BuildTabIfNeeded(tabControl.TabPages[0]);
            
            this.Controls.Add(tabControl);
        }
        
        private void CreateSearchTab(TabPage parent)
        {
            parent.BackColor = Color.FromArgb(18, 18, 18);

            var mainLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 1,
                RowCount = 2,
                BackColor = Color.FromArgb(18, 18, 18),
                Padding = new Padding(30, 24, 30, 24)
            };
            mainLayout.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 100f));
            mainLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize)); // Controles superiores
            mainLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100f)); // ListView

            var contentPanel = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                AutoSize = true,
                AutoSizeMode = AutoSizeMode.GrowAndShrink,
                ColumnCount = 1,
                BackColor = Color.FromArgb(18, 18, 18)
            };
            contentPanel.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 100f));

            var headerLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Top,
                AutoSize = true,
                ColumnCount = 4,
                BackColor = Color.FromArgb(35, 35, 40),
                Padding = new Padding(24, 18, 24, 18),
                Margin = new Padding(0, 0, 0, 20)
            };
            headerLayout.ColumnStyles.Add(new ColumnStyle(SizeType.AutoSize));
            headerLayout.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 100f));
            headerLayout.ColumnStyles.Add(new ColumnStyle(SizeType.AutoSize));
            headerLayout.ColumnStyles.Add(new ColumnStyle(SizeType.AutoSize));

            btnConnect = new Button
            {
                Text = "🔌 Conectar",
                AutoSize = true,
                BackColor = Color.FromArgb(0, 122, 204),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 11, FontStyle.Bold),
                Padding = new Padding(20, 8, 20, 8),
                Cursor = Cursors.Hand
            };
            btnConnect.FlatAppearance.BorderSize = 0;
            btnConnect.FlatAppearance.MouseOverBackColor = Color.FromArgb(0, 140, 230);
            btnConnect.Margin = new Padding(0, 0, 16, 0);
