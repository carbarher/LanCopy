        private void UpdateMetricsDashboard(object sender, EventArgs e)
        {
            if (sessionMetrics == null || lblMetricsDashboard == null) return;
            
            try
            {
                var summary = $"📊 Sesión: {sessionMetrics.SessionDuration.Hours}h {sessionMetrics.SessionDuration.Minutes}m | " +
                             $"📥 {sessionMetrics.CompletedDownloads}/{sessionMetrics.TotalDownloads} ({sessionMetrics.GetSuccessRate():F1}%) | " +
                             $"🔍 {sessionMetrics.SuccessfulSearches}/{sessionMetrics.TotalSearches} | " +
                             $"👤 {sessionMetrics.AuthorsProcessed} ({sessionMetrics.AuthorsPerHour:F1}/h)";
                
                SafeInvoke(() => lblMetricsDashboard.Text = summary);
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error actualizando dashboard: {ex.Message}");
            }
        }
        
        private void ExportSessionMetrics()
        {
            if (sessionMetrics == null) return;
            
            try
            {
                var timestamp = DateTime.Now.ToString("yyyyMMdd_HHmmss");
                var jsonPath = Path.Combine(dataDir, $"session_metrics_{timestamp}.json");
                var csvPath = Path.Combine(dataDir, $"session_metrics_{timestamp}.csv");
                
                sessionMetrics.ExportToJson(jsonPath);
                sessionMetrics.ExportToCsv(csvPath);
                
                Log($"📊 Métricas exportadas:");
                Log($"   JSON: {jsonPath}");
                Log($"   CSV: {csvPath}");
                
                // También mostrar resumen en log
                Log(sessionMetrics.GetSummary());
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error exportando métricas: {ex.Message}");
            }
        }
        
