            var memorySection = CreateConfigSectionPanel("🧠 GESTIÓN DE MEMORIA");
            
            // Estadísticas de memoria
            var memoryStatsRow = CreateConfigRow("Memoria actual:", CreateMemoryStatsLabel());
            memorySection.Controls.Add(memoryStatsRow);
            
            // Intervalo de limpieza automática
            var cleanupIntervalRow = CreateNumericRow("Intervalo limpieza (min):", out var numCleanupInterval, 5, 1, 60, (s, e) =>
            {
                if (memoryManager != null)
                {
                    memoryManager.CleanupIntervalMinutes = (int)numCleanupInterval.Value;
                    SaveConfig();
                }
            });
            memorySection.Controls.Add(cleanupIntervalRow);
            
            // Botón de optimización manual
            var btnOptimizeMemory = CreateButton("⚡ Optimizar Ahora", Color.FromArgb(13, 110, 253), OnOptimizeMemoryClick);
            btnOptimizeMemory.Width = 140;
