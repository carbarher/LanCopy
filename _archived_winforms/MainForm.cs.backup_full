        // HEALTH SCORE DE CONEXIÓN: Métodos
        private void UpdateConnectionHealthScore()
        {
            // Calcular componentes del health score
            double latencyScore = CalculateLatencyScore();
            double packetLossScore = CalculatePacketLossScore();
            double throttlingScore = CalculateThrottlingScore();
            double circuitScore = CalculateCircuitScore();
            double connectionScore = CalculateConnectionStabilityScore();
            
            // Ponderar componentes (0-100 cada una)
            connectionHealthScore = (
                latencyScore * 0.25 +      // 25% peso latencia
                packetLossScore * 0.20 +   // 20% peso pérdida de paquetes
                throttlingScore * 0.20 +   // 20% peso throttling
                circuitScore * 0.15 +      // 15% peso circuit breaker
                connectionScore * 0.20     // 20% peso estabilidad de conexión
            );
            
            // Mantener en rango 0-100
            connectionHealthScore = Math.Max(0, Math.Min(100, connectionHealthScore));
            
            // Actualizar historial
            recentHealthScores.Enqueue(connectionHealthScore);
            if (recentHealthScores.Count > maxHealthSamples)
            {
                recentHealthScores.Dequeue();
            }
            
            lastHealthUpdate = DateTime.UtcNow;
            
            // Guardar métricas en historial
            SaveCurrentMetrics();
            
            // Sistema de alertas proactivas
            CheckAndSendAlerts();
            
            // Guardar métricas persistentes periódicamente
            SaveMetricsToFile();
            
            // Log si el score es bajo
            if (connectionHealthScore < 30)
            {
                Log($"🚨 HEALTH SCORE CRÍTICO: {connectionHealthScore:F1}/100");
                Log($"   - Latencia: {averageLatency:F0}ms (óptimo <500ms)");
                Log($"   - Pérdida: {packetLossRate:F1}% (óptimo <5%)");
                Log($"   - Throttling: Nivel {currentThrottleLevel}/{maxThrottleLevel}");
                Log($"   - Circuit: {connectionCircuit} (óptimo: Closed)");
                Log($"   - Timeouts consecutivos: {consecutiveTimeouts}");
            }
            else if (connectionHealthScore < 50)
            {
                Log($"⚠️ HEALTH SCORE BAJO: {connectionHealthScore:F1}/100 (L:{latencyScore:F1} P:{packetLossScore:F1} T:{throttlingScore:F1} C:{circuitScore:F1} S:{connectionScore:F1})");
            }
            else if (connectionHealthScore < 70)
            {
                Log($"⚡ Health Score: {connectionHealthScore:F1}/100");
            }
        }
        
        private void SaveCurrentMetrics()
        {
            var metrics = new ConnectionMetrics
            {
                HealthScore = connectionHealthScore,
                Latency = averageLatency,
                PacketLoss = packetLossRate,
                ThrottleLevel = currentThrottleLevel,
                CircuitState = connectionCircuit,
                ConsecutiveTimeouts = consecutiveTimeouts,
                ConservativeMode = conservativeMode,
                Timestamp = DateTime.UtcNow
            };
            
            metricsHistory.Value.Add(metrics);
            
            // Mantener solo últimas 1000 métricas
            if (metricsHistory.Value.Count > 1000)
            {
                metricsHistory.Value.RemoveRange(0, metricsHistory.Value.Count - 1000);
            }
        }
        
        private void CheckAndSendAlerts()
        {
            if (connectionHealthScore < 40 && !alertSent)
            {
                // Usar DarkMessageBox en lugar de ShowNotification
                SafeBeginInvoke(() => 
                {
                    DarkMessageBox.Show($"⚠️ Conexión Degradada\n\nHealth Score: {connectionHealthScore:F1}/100\n\nVerifique su conexión a internet.", 
                                  "Alerta de Conexión", 
                                  MessageBoxButtons.OK, 
                                  MessageBoxIcon.Warning);
                });
                alertSent = true;
            }
            else if (connectionHealthScore > 60 && alertSent)
            {
                alertSent = false;
            }
        }
        
        private void SaveMetricsToFile()
        {
            if (DateTime.UtcNow.Subtract(lastMetricsSave) < metricsSaveInterval)
                return;
                
            try
            {
                var fileName = $"connection_metrics_{DateTime.Now:yyyyMMdd_HHmmss}.json";
                var filePath = Path.Combine(dataDir, fileName);
                
                var data = new
                {
                    timestamp = DateTime.UtcNow,
                    currentScore = connectionHealthScore,
                    averageScore = GetAverageHealthScore(),
                    components = new
                    {
                        latency = CalculateLatencyScore(),
                        packetLoss = CalculatePacketLossScore(),
                        throttling = CalculateThrottlingScore(),
                        circuit = CalculateCircuitScore(),
                        stability = CalculateConnectionStabilityScore()
                    },
                    metrics = metricsHistory.Value.TakeLast(100).ToList(),
                    cooldowns = cooldownHistorySeconds.Value.TakeLast(50).ToList()
                };
                
                // Asegurar que la carpeta de datos existe antes de escribir
                try { System.IO.Directory.CreateDirectory(dataDir); } catch (Exception ex) { AutoLog($"⚠️ Error creando directorio: {ex.Message}"); }
                var json = System.Text.Json.JsonSerializer.Serialize(data, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
                System.IO.File.WriteAllText(filePath, json);
                var latestPath = Path.Combine(dataDir, "connection_metrics_latest.json");
                System.IO.File.WriteAllText(latestPath, json);
                
                lastMetricsSave = DateTime.UtcNow;
                Log($"📊 Métricas guardadas: {fileName}");
            }
            catch (Exception ex)
            {
                Log($"❌ Error guardando métricas: {ex.Message}");
            }
        }
        
        private double CalculateLatencyScore()
        {
            if (recentLatencies.Count == 0) return 100.0;
            
            // Latencia óptima < 500ms = 100 puntos
            // Latencia máx 5000ms = 0 puntos
            double avgLatency = averageLatency;
            if (avgLatency <= 500) return 100.0;
            if (avgLatency >= 5000) return 0.0;
            
            // Escala lineal inversa
            return 100.0 * (1.0 - (avgLatency - 500) / 4500.0);
        }
        
        private double CalculatePacketLossScore()
        {
            if (recentPingSuccesses.Count == 0) return 100.0;
            
            // 0% pérdida = 100 puntos
            // 100% pérdida = 0 puntos
            return 100.0 * (1.0 - packetLossRate / 100.0);
        }
        
        private double CalculateThrottlingScore()
        {
            // Sin throttling = 100 puntos
            // Nivel máximo throttling = 0 puntos
            if (currentThrottleLevel == 0) return 100.0;
            return 100.0 * (1.0 - (double)currentThrottleLevel / maxThrottleLevel);
        }
        
        private double CalculateCircuitScore()
        {
            // Circuit cerrado = 100 puntos
            // Circuit abierto = 0 puntos
            // Circuit half-open = 50 puntos
            switch (connectionCircuit)
            {
                case CircuitState.Closed: return 100.0;
                case CircuitState.HalfOpen: return 50.0;
                case CircuitState.Open: return 0.0;
                default: return 50.0;
            }
        }
        
        private double CalculateConnectionStabilityScore()
        {
            if (client == null) return 0.0;
            
            var state = client.State;
            bool isConnected = state.HasFlag(SoulseekClientStates.Connected) || 
                               state.HasFlag(SoulseekClientStates.LoggedIn);
            
            if (!isConnected) return 0.0;
            
            // Penalizar por reconexiones recientes
            if (DateTime.UtcNow.Subtract(lastConnectionIssue).TotalMinutes < 5)
            {
                return 50.0;
            }
            
            // Conexión estable = 100 puntos
            return 100.0;
        }
        
        private double GetAverageHealthScore()
        {
            if (recentHealthScores.Count == 0) return connectionHealthScore;
            return recentHealthScores.Average();
        }
        
        // Métodos de persistencia de métricas avanzados
        private void LoadMetricsFromFile()
        {
            try
            {
                var fileName = $"connection_metrics_latest.json";
                var filePath = Path.Combine(dataDir, fileName);
                
                if (System.IO.File.Exists(filePath))
                {
                    var json = System.IO.File.ReadAllText(filePath);
                    var data = System.Text.Json.JsonSerializer.Deserialize<ConnectionMetricsData>(json);
                    
                    if (data?.metrics != null)
                    {
                        // Forzar inicialización y reemplazar contenido
                        metricsHistory.Value.Clear();
                        metricsHistory.Value.AddRange(data.metrics.TakeLast(100));
                        Log($"📊 Métricas históricas cargadas: {metricsHistory.Value.Count} registros");
                    }
                    if (data?.cooldowns != null && data.cooldowns.Count > 0)
                    {
                        cooldownHistorySeconds.Value.Clear();
                        cooldownHistorySeconds.Value.AddRange(data.cooldowns.TakeLast(50));
                        Log($"⏱️ Cooldowns históricos cargados: {cooldownHistorySeconds.Value.Count} muestras");
                    }
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error cargando métricas: {ex.Message}");
            }
        }
        
        // Dashboard flotante de Health Score
        private System.Windows.Forms.Timer healthScoreTimer;
        private Panel healthScorePanel;
        private Label healthScoreLabel;
        
        private void InitializeHealthScoreDashboard()
        {
            // Crear panel flotante
            healthScorePanel = new Panel
            {
                BackColor = Color.FromArgb(40, 40, 40),
                BorderStyle = BorderStyle.FixedSingle,
                Location = new Point(this.Width - 200, 10),
                Size = new Size(180, 80),
                Anchor = AnchorStyles.Top | AnchorStyles.Right
            };
            
            // Crear label para Health Score
            healthScoreLabel = new Label
            {
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 10, FontStyle.Bold),
                Location = new Point(10, 10),
                Size = new Size(160, 60),
                Text = "🏥 Health Score\n---/100",
                TextAlign = ContentAlignment.MiddleCenter
            };
            
            healthScorePanel.Controls.Add(healthScoreLabel);
            this.Controls.Add(healthScorePanel);
            
            // Timer para actualizar dashboard
            healthScoreTimer = new System.Windows.Forms.Timer
            {
                Interval = TIMER_HEALTH_SCORE_MS
            };
            healthScoreTimer.Tick += UpdateHealthScoreDashboard;
            healthScoreTimer.Start();
        }
        
        private void UpdateHealthScoreDashboard(object sender, EventArgs e)
        {
            if (healthScoreLabel != null)
            {
                var icon = connectionHealthScore >= 70 ? "🟢" : 
                          connectionHealthScore >= 50 ? "🟡" : "🔴";
                healthScoreLabel.Text = $"{icon} Health Score\n{connectionHealthScore:F1}/100";
                
                // Cambiar color según score usando paleta mejorada
                if (connectionHealthScore >= 70)
                    healthScoreLabel.ForeColor = UIColors.HealthGood;
                else if (connectionHealthScore >= 50)
                    healthScoreLabel.ForeColor = UIColors.HealthWarning;
                else
                    healthScoreLabel.ForeColor = UIColors.HealthBad;
            }
        }
        
