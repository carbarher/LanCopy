            // === SECCIÓN BÚSQUEDA ===
            var searchSection = CreateConfigSectionPanel("🔍 BÚSQUEDA");
            
            NumericUpDown numTimeoutControl, numResponseLimitControl, numFileLimitControl, numSearchesControl;
            numTimeoutControl = numResponseLimitControl = numFileLimitControl = numSearchesControl = null;
            
            searchSection.Controls.Add(CreateNumericRow("Timeout (seg):", out numTimeoutControl, searchTimeout, 1, 10, (s, e) =>
            {
                searchTimeout = Math.Min((int)numTimeoutControl.Value, 10);
                SaveConfig();
            }));
            searchSection.Controls.Add(CreateNumericRow("Respuestas:", out numResponseLimitControl, responseLimit, 1, 50, (s, e) =>
            {
                responseLimit = Math.Min((int)numResponseLimitControl.Value, 50);
                SaveConfig();
            }));
            searchSection.Controls.Add(CreateNumericRow("Archivos:", out numFileLimitControl, fileLimit, 0, 999999, (s, e) =>
            {
                fileLimit = (int)numFileLimitControl.Value;
                SaveConfig();
            }));
            searchSection.Controls.Add(CreateNumericRow("Simultáneas:", out numSearchesControl, maxParallelSearches, 1, 10, (s, e) =>
            {
                maxParallelSearches = Math.Min((int)numSearchesControl.Value, 10);
                SaveConfig();
            }));
            
