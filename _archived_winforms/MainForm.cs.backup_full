        private void CleanupTempFiles()
        {
            // LOGGING ANTES de hacer cualquier cosa
            System.IO.File.AppendAllText("cleanup_log.txt", $"CleanupTempFiles llamado: {DateTime.Now:HH:mm:ss.fff}\n");
            
            try
            {
                var baseDir = AppDomain.CurrentDomain.BaseDirectory;
                
                // Limpiar startup_log.txt si es muy grande (>5MB)
                var logPath = Path.Combine(baseDir, "startup_log.txt");
                if (System.IO.File.Exists(logPath))
                {
                    // MEJORA #27: Usar caché de FileInfo
                    var logInfo = GetCachedFileInfo(logPath);
                    System.IO.File.AppendAllText("cleanup_log.txt", $"  - startup_log.txt existe, tamaño: {logInfo.Length} bytes\n");
                    if (logInfo.Length > 5 * 1024 * 1024) // 5MB
                    {
                        System.IO.File.Delete(logPath);
                        System.IO.File.AppendAllText("cleanup_log.txt", $"  - startup_log.txt ELIMINADO (muy grande)\n");
                    }
                    else
                    {
                        System.IO.File.AppendAllText("cleanup_log.txt", $"  - startup_log.txt NO eliminado (tamaño OK)\n");
                    }
                }
                else
                {
                    System.IO.File.AppendAllText("cleanup_log.txt", $"  - startup_log.txt NO existe\n");
                }
                
                // Eliminar archivos .tmp antiguos (>7 días)
                var tempFiles = System.IO.Directory.GetFiles(baseDir, "*.tmp");
                foreach (var file in tempFiles)
                {
                    try
                    {
                        // MEJORA #27: Usar caché de FileInfo
                        var fileInfo = GetCachedFileInfo(file);
                        if ((DateTime.Now - fileInfo.LastWriteTime).TotalDays > 7)
                        {
                            System.IO.File.Delete(file);
                        }
                    }
                    catch { }
                }
                
                // Rotar logs si son muy grandes
                RotateLogFile(Path.Combine(dataDir, "download_log.txt"), 10 * 1024 * 1024); // 10MB
            }
            catch (Exception ex)
            {
                SafeLog( $"Error en limpieza: {ex.Message}\n");
            }
        }
        
        private void RotateLogFile(string logPath, long maxSize)
        {
            try
            {
                if (!System.IO.File.Exists(logPath)) return;
                
                // MEJORA #27: Usar caché de FileInfo
                var fileInfo = GetCachedFileInfo(logPath);
                if (fileInfo.Length > maxSize)
                {
                    // Crear backup con timestamp
                    var backupPath = Path.Combine(
                        Path.GetDirectoryName(logPath),
                        $"{Path.GetFileNameWithoutExtension(logPath)}_{DateTime.Now:yyyyMMdd_HHmmss}.bak"
                    );
                    
                    System.IO.File.Move(logPath, backupPath);
                    
                    // Eliminar backups antiguos (mantener solo últimos 3)
                    var backups = System.IO.Directory.GetFiles(Path.GetDirectoryName(logPath), "*.bak")
                        .OrderByDescending(f => System.IO.File.GetCreationTime(f))
                        .Skip(3)
                        .ToList();
                    
                    foreach (var backup in backups)
                    {
                        try { System.IO.File.Delete(backup); } catch (Exception ex) { AutoLog($"⚠️ Error eliminando backup de log: {ex.Message}"); }
                    }
                }
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error rotando logs: {ex.Message}");
            }
        }
        
        private async Task<Dictionary<string, object>> GetDownloadStatistics()
        {
            var stats = new Dictionary<string, object>();
            
            try
            {
                // Verificar que la conexión existe y está abierta
                if (dbConnection == null || dbConnection.State != System.Data.ConnectionState.Open)
                {
                    return stats; // Retornar stats vacío si no hay conexión
                }
                
                using (var cmd = dbConnection.CreateCommand())
                {
                    // Total de archivos descargados
                    cmd.CommandText = "SELECT COUNT(*) FROM download_history WHERE status = 'Completed'";
                    stats["TotalDownloads"] = Convert.ToInt32(await cmd.ExecuteScalarAsync());
                    
                    // Espacio total descargado
                    cmd.CommandText = "SELECT SUM(size_bytes) FROM download_history WHERE status = 'Completed'";
                    var totalBytes = await cmd.ExecuteScalarAsync();
                    stats["TotalBytes"] = totalBytes != DBNull.Value ? Convert.ToInt64(totalBytes) : 0L;
                    stats["TotalSize"] = FormatFileSize((long)stats["TotalBytes"]);
                    
                    // Top 10 autores
                    cmd.CommandText = @"
                        SELECT author, COUNT(*) as count 
                        FROM download_history 
                        WHERE status = 'Completed' AND author IS NOT NULL
                        GROUP BY author 
                        ORDER BY count DESC 
                        LIMIT 10";
                    
                    var topAuthors = new List<(string author, int count)>();
                    using (var reader = await cmd.ExecuteReaderAsync())
                    {
                        while (await reader.ReadAsync())
                        {
                            topAuthors.Add((reader.GetString(0), reader.GetInt32(1)));
                        }
                    }
                    stats["TopAuthors"] = topAuthors;
                    
                    // Descargas hoy
                    cmd.CommandText = @"
                        SELECT COUNT(*) 
                        FROM download_history 
                        WHERE status = 'Completed' 
                        AND date(timestamp) = date('now')";
                    stats["TodayDownloads"] = Convert.ToInt32(await cmd.ExecuteScalarAsync());
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error obteniendo estadísticas: {ex.Message}");
            }
            
            return stats;
        }
        
        private void StartAllDownloads()
        {
            try
            {
                if (downloadManager != null)
                {
                    downloadManager.Start();
                    
                    // MEJORA FASE 1.3: ReadLock para Count
                    int queued = ReadLocked(downloadQueueLock, () =>
                        downloadQueue.Count(t => t.Status == DownloadStatus.Queued || t.Status == DownloadStatus.Paused));
                    
                    Log($"▶️ Gestor de descargas iniciado ({queued} archivos en cola)");
                }
                else
                {
                    Log("⚠️ Gestor de descargas no disponible");
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error iniciando descargas: {ex.Message}");
            }
        }
        
        private void PauseAllDownloads()
        {
            try
            {
                if (downloadManager != null)
                {
                    var snapshot = downloadManager.GetQueueSnapshot();
                    int paused = 0;

                    foreach (var task in snapshot.Where(t => t.Status == DownloadStatus.Downloading || t.Status == DownloadStatus.Queued))
                    {
                        if (downloadManager.PauseTask(task))
                        {
                            paused++;
                        }
                    }

                    Log($"⏸️ {paused} descargas pausadas (activas + en cola)");
                }
                else
                {
                    // MEJORA FASE 1.3: ReadLock para snapshot, WriteLock para modificar
                    var tasksToPause = ReadLocked(downloadQueueLock, () =>
                        downloadQueue
                            .Where(t => t.Status == DownloadStatus.Downloading || t.Status == DownloadStatus.Queued)
                            .ToList());

                    foreach (var task in tasksToPause)
                    {
                        WriteLocked(downloadQueueLock, () =>
                        {
                            task.Status = DownloadStatus.Paused;
                            if (task.CancellationToken != null)
                            {
                                try { task.CancellationToken.Cancel(); } catch (Exception ex) { AutoLog($"⚠️ Error cancelando token: {ex.Message}"); }
                            }
                        });
                    }

                    foreach (var task in tasksToPause)
                    {
                        UpdateDownloadUI(task, "⏸️ Pausado");
                    }

                    Log($"⏸️ {tasksToPause.Count} descargas pausadas (activas + en cola)");
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error pausando descargas: {ex.Message}");
            }
        }
        
        private void ResumeAllDownloads()
        {
            try
            {
                if (downloadManager != null)
                {
                    var snapshot = downloadManager.GetQueueSnapshot();
                    int resumed = 0;

                    foreach (var task in snapshot.Where(t => t.Status == DownloadStatus.Paused))
                    {
                        if (downloadManager.ResumeTask(task))
                        {
                            resumed++;
                        }
                    }

                    if (resumed > 0)
                    {
                        downloadManager.Start();
                    }

                    Log($"▶️ Reanudando {resumed} descargas");
                }
                else
                {
                    // MEJORA FASE 1.3: ReadLock para snapshot, WriteLock para modificar
                    var pausedTasks = ReadLocked(downloadQueueLock, () =>
                        downloadQueue.Where(t => t.Status == DownloadStatus.Paused).ToList());

                    foreach (var task in pausedTasks)
                    {
                        WriteLocked(downloadQueueLock, () => task.Status = DownloadStatus.Queued);
                        UpdateDownloadUI(task, "⏳ Pendiente");
                    }

                    foreach (var task in pausedTasks)
                    {
                        // MEJORA #26: Eliminar Task.Run redundante
                        _ = ProcessDownload(task);
                    }

                    Log($"▶️ Reanudando {pausedTasks.Count} descargas (modo legacy)");
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error reanudando descargas: {ex.Message}");
            }
        }

        private void RetryNotDownloaded()
        {
            try
            {
                PauseAllDownloads();
                AutoLog("═══════════════════════════════════════════════════");
                AutoLog("🔄 Reintentar: limpiando lista de descargas...");

                // MEJORA FASE 1.3: WriteLock para ToList + Clear
                List<DownloadTask> previousTasks = new List<DownloadTask>();
                WriteLocked(downloadQueueLock, () =>
                {
                    previousTasks = downloadQueue.ToList();
                    downloadQueue.Clear();
                });

                SafeInvoke(() =>
                {
                    if (lvDownloads != null)
                        lvDownloads.Items.Clear();
                });

                if (downloadManager != null)
                {
                    _ = downloadManager.SaveQueueAsync();
                }

                int requeued = 0;
                foreach (var task in previousTasks)
                {
                    try
                    {
                        var localPath = task.LocalPath;
                        if (string.IsNullOrWhiteSpace(localPath))
                        {
                            localPath = GetDownloadPath(task.File.FileName, task.File.Author);
                        }

                        if (IsFileDownloaded(localPath))
                        {
                            continue;
                        }

                        var item = new ListViewItem(task.File.FileName);
                        item.SubItems.Add(task.File.Username);
                        item.SubItems.Add("0%");
                        item.SubItems.Add("En cola");
                        item.SubItems.Add(task.File.SizeReadable);
                        item.Tag = task.File;

                        SafeInvoke(() =>
                        {
                            if (lvDownloads != null)
                                AddItemWithAutoScroll(lvDownloads, item);
                        });

                        AddToDownloadQueue(task.File, localPath, item, false);
                        requeued++;
                    }
                    catch (Exception ex)
                    {
                        AutoLog($"⚠️ Error re-encolando archivo: {ex.Message}");
                    }
                }

                AutoLog($"✅ Reintentar completado: {requeued} archivo(s) re-encolado(s)");
                AutoLog("═══════════════════════════════════════════════════");
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error en Reintentar: {ex.Message}");
            }
        }
        
        private async Task BackupDatabase()
        {
            try
            {
                var backupDir = Path.Combine(dataDir, "backups");
                System.IO.Directory.CreateDirectory(backupDir);
                
                var backupPath = Path.Combine(backupDir, $"slskdown_backup_{DateTime.Now:yyyyMMdd_HHmmss}.db");
                
                // Cerrar conexión temporalmente
                var wasOpen = dbConnection.State == System.Data.ConnectionState.Open;
                if (wasOpen)
                {
                    dbConnection.Close();
                }
                
                // Copiar archivo
                System.IO.File.Copy(dbPath, backupPath, true);
                
                // Reabrir conexión
                if (wasOpen)
                {
                    await dbConnection.OpenAsync();
                }
                
                // Mantener solo últimos 7 backups
                var backups = System.IO.Directory.GetFiles(backupDir, "slskdown_backup_*.db")
                    .OrderByDescending(f => System.IO.File.GetCreationTime(f))
                    .Skip(7)
                    .ToList();
                
                foreach (var backup in backups)
                {
                    try { System.IO.File.Delete(backup); } catch (Exception ex) { AutoLog($"⚠️ Error eliminando backup antiguo: {ex.Message}"); }
                }
                
                Log($"💾 Backup creado: {Path.GetFileName(backupPath)}");
            }
            catch (Exception ex)
            {
                Log($"❌ Error creando backup: {ex.Message}");
            }
        }
        
        private async Task ShowDailySummary()
        {
            try
            {
                var stats = await GetDownloadStatistics();
                
                if ((int)stats["TodayDownloads"] > 0)
                {
                    var message = $"📊 Resumen del día:\n\n" +
                                  $"✅ Descargas completadas: {stats["TodayDownloads"]}\n" +
                                  $"📦 Total acumulado: {stats["TotalDownloads"]} archivos\n" +
                                  $"💾 Espacio total: {stats["TotalSize"]}";
                    
                    // Resumen diario registrado en log
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error mostrando resumen: {ex.Message}");
            }
        }
        
        private void LoadConfig()
        {
            try
            {
                // Logging para debug
                Log($"🔍 Iniciando LoadConfig() con UnifiedSettingsManager");
                Log($"📁 Buscando config en: {configPath}");
                Log($"📂 Directorio base: {AppDomain.CurrentDomain.BaseDirectory}");
                
                // Cargar configuración usando UnifiedSettingsManager
                var config = _settingsManager.LoadSettings();
                
                // Cargar valores desde UnifiedSettingsManager
                username = _settingsManager.GetSetting("username", "");
                password = _settingsManager.GetSetting("password", "");
                downloadDir = _settingsManager.GetSetting("downloadDir", downloadDir);
                autoConnect = _settingsManager.GetSetting("autoConnect", true);
                maxParallelDownloads = _settingsManager.GetSetting("maxParallelDownloads", 3);
                maxSimultaneousDownloads = maxParallelDownloads;
                maxParallelSearches = Math.Min(_settingsManager.GetSetting("maxParallelSearches", 5), 10);
                maxRetries = Math.Min(_settingsManager.GetSetting("maxRetries", 3), 10);
                maxAlternativeRetries = Math.Min(_settingsManager.GetSetting("maxAlternativeRetries", 3), MAX_TOTAL_ATTEMPTS);
                searchTimeout = Math.Min(_settingsManager.GetSetting("searchTimeout", 10), 10);
                responseLimit = Math.Min(_settingsManager.GetSetting("responseLimit", 50), 50);
                fileLimit = _settingsManager.GetSetting("fileLimit", 0);
                listenPort = _settingsManager.GetSetting("listenPort", 50000);
                enableDistributedNetwork = _settingsManager.GetSetting("enableDistributedNetwork", true);
                stealthMode = _settingsManager.GetSetting("stealthMode", true);
                minFileSizeKB = _settingsManager.GetSetting("minFileSizeKB", 0);
                organizeByAuthor = _settingsManager.GetSetting("organizeByAuthor", false);
                autoBackup = _settingsManager.GetSetting("autoBackup", false);
                autoMode = _settingsManager.GetSetting("autoMode", false);
                instantDownload = _settingsManager.GetSetting("instantDownload", true);
                onlyNewFilesInAutoSearch = _settingsManager.GetSetting("onlyNewFilesInAutoSearch", false);
                priorityBySize = _settingsManager.GetSetting("priorityBySize", false);
                enableUploads = _settingsManager.GetSetting("enableUploads", false);
                maxConcurrentUploads = _settingsManager.GetSetting("maxConcurrentUploads", 2);
                maxUploadSpeedKib = _settingsManager.GetSetting("maxUploadSpeedKib", 0);
                shareVerboseLogging = _settingsManager.GetSetting("shareVerboseLogging", false);
                
                // Cargar configuraciones adicionales
                maxSimultaneousDownloads = _settingsManager.GetSetting("maxSimultaneousDownloads", maxSimultaneousDownloads);
                continuousSearch = _settingsManager.GetSetting("continuousSearch", continuousSearch);
                enableNotifications = _settingsManager.GetSetting("enableNotifications", enableNotifications);
                enableSounds = _settingsManager.GetSetting("enableSounds", enableSounds);
                queuePositionRefreshIntervalSeconds = _settingsManager.GetSetting("queuePositionRefreshIntervalSeconds", queuePositionRefreshIntervalSeconds);
                retryConnectionIntervalSeconds = _settingsManager.GetSetting("retryConnectionIntervalSeconds", retryConnectionIntervalSeconds);
                retryIoIntervalSeconds = _settingsManager.GetSetting("retryIoIntervalSeconds", retryIoIntervalSeconds);
                cleanupIntervalSeconds = _settingsManager.GetSetting("cleanupIntervalSeconds", cleanupIntervalSeconds);
                downloadSpeedLimitKib = _settingsManager.GetSetting("downloadSpeedLimitKib", downloadSpeedLimitKib);
                retryBackoffMilliseconds = _settingsManager.GetSetting("retryBackoffMilliseconds", retryBackoffMilliseconds);
                incompleteDownloadsDirectory = _settingsManager.GetSetting("incompleteDownloadsDirectory", incompleteDownloadsDirectory);
                
                // Cargar configuración de límite de ancho de banda
                maxBandwidthKBps = _settingsManager.GetSetting("maxBandwidthKBps", 0);
                
                // Recrear el limitador de ancho de banda con la nueva configuración
                if (bandwidthLimiter != null)
                {
                    bandwidthLimiter.Dispose();
                }
                bandwidthLimiter = new Core.BandwidthLimiter(maxBandwidthKBps);
                postDownloadCommand = _settingsManager.GetSetting("postDownloadCommand", postDownloadCommand);
                downloadFilterPattern = _settingsManager.GetSetting("downloadFilterPattern", downloadFilterPattern);
                autoReconnect = _settingsManager.GetSetting("autoReconnect", false);
                queueStrategy = (QueuePrioritizationStrategy)_settingsManager.GetSetting("queueStrategy", (int)QueuePrioritizationStrategy.Balanced);
                carbarherPath = _settingsManager.GetSetting("carbarherPath", carbarherPath);
                autoStartDownloadsOnEnqueue = _settingsManager.GetSetting("autoStartDownloadsOnEnqueue", false);
                
                // Cargar configuraciones adicionales
                
                
                batchSize = _settingsManager.GetSetting("batchSize", 500);
                enableAdaptiveParallelism = _settingsManager.GetSetting("enableAdaptiveParallelism", false);
                enableNativeLib = _settingsManager.GetSetting("enableNativeLib", true);
                currentParallelism = _settingsManager.GetSetting("currentParallelism", 1);
                minParallelism = _settingsManager.GetSetting("minParallelism", 1);
                maxParallelism = _settingsManager.GetSetting("maxParallelism", 1);
                logRetentionDays = _settingsManager.GetSetting("logRetentionDays", 30);
                
                // Ban-aware cooldown
                banStrikeCount = _settingsManager.GetSetting("banStrikeCount", 0);
                long cooldownBin = _settingsManager.GetSetting<long>("banCooldownUntil", 0L);
                long lastBanBin = _settingsManager.GetSetting<long>("lastBanEventAt", 0L);
                banCooldownUntil = cooldownBin != 0 ? DateTime.FromBinary(cooldownBin) : DateTime.MinValue;
                lastBanEventAt = lastBanBin != 0 ? DateTime.FromBinary(lastBanBin) : DateTime.MinValue;
                // Recorte automático del cooldown activo según nueva política (opción A)
                if (banCooldownUntil > DateTime.UtcNow)
                {
                    var allowed = GetBanCooldownForStrike(banStrikeCount);
                    var target = DateTime.UtcNow + allowed;
                    if (banCooldownUntil > target)
                    {
                        banCooldownUntil = target;
                        nextAllowedReconnect = banCooldownUntil;
                        Log($"🔧 Pausa anti-bloqueo recortada a {allowed.TotalMinutes:F0} min (strike {banStrikeCount})");
                        try { SaveConfig(); } catch (Exception ex) { AutoLog($"⚠️ Error guardando config: {ex.Message}"); }
                    }
                }
                
                // Cargar configuración de optimizaciones Fase 1-3
                useVirtualListView = _settingsManager.GetSetting("useVirtualListView", true);
                useSQLiteForLargeResults = _settingsManager.GetSetting("useSQLiteForLargeResults", true);
                useRustOptimizations = _settingsManager.GetSetting("useRustOptimizations", true);

                // Configuraciones de optimización de descargas
                useOptimizedDownloadManager = _settingsManager.GetSetting("useOptimizedDownloadManager", true);
                useVirtualDownloadsList = _settingsManager.GetSetting("useVirtualDownloadsList", true);
                useStringInterning = _settingsManager.GetSetting("useStringInterning", true);
                useLZ4Compression = _settingsManager.GetSetting("useLZ4Compression", true);
                useObjectPooling = _settingsManager.GetSetting("useObjectPooling", true);
                useAdaptiveTimeout = _settingsManager.GetSetting("useAdaptiveTimeout", true);
                useCircuitBreaker = _settingsManager.GetSetting("useCircuitBreaker", true);
                useSmartRetry = _settingsManager.GetSetting("useSmartRetry", true);
                useAsyncIO = _settingsManager.GetSetting("useAsyncIO", true);
                useHardLinks = _settingsManager.GetSetting("useHardLinks", true);
                usePreAllocation = _settingsManager.GetSetting("usePreAllocation", true);

                // Configuraciones de optimización de red
                usePerformanceMonitor = _settingsManager.GetSetting("usePerformanceMonitor", true);
                useIntelligentCache = _settingsManager.GetSetting("useIntelligentCache", true);
                useAutoTuning = _settingsManager.GetSetting("useAutoTuning", true);
                
                // MEJORA PROTOCOLO SOULSEEK: Cargar configuración del protocolo oficial
                _useWishlistSearch = _settingsManager.GetSetting("useWishlistSearch", true);
                _wishlistInterval = _settingsManager.GetSetting("wishlistInterval", 720u);
                var excludedList = _settingsManager.GetSetting<List<string>>("excludedPhrases", new List<string>());
                _excludedPhrases = new HashSet<string>(excludedList, StringComparer.OrdinalIgnoreCase);
                
                Log($"✅ Protocolo Soulseek cargado:");
                Log($"   ⭐ WishlistSearch: {(_useWishlistSearch ? "Activado" : "Desactivado")}");
                Log($"   ⏱️ Intervalo: {_wishlistInterval}s ({_wishlistInterval/60}min)");
                Log($"   🚫 Frases prohibidas: {_excludedPhrases.Count}");
                
                // Cargar filtros de calidad de audio (Nicotine+ inspired)
                bool audioFilterEnabled = _settingsManager.GetSetting("audioQualityFilterEnabled", false);
                if (audioFilterEnabled)
                {
                    int minBitrate = _settingsManager.GetSetting("audioMinBitrate", 192);
                    if (audioQualityFilters != null)
                    {
                        audioQualityFilters.MinBitrate = minBitrate;
                        audioQualityFilters.MinQualityScore = 50;
                    }
                }
                
                // Cargar configuración de redes P2P
                Log($"🔵 Red: Soulseek");
                
                // Cargar listas
                searchHistory = _settingsManager.GetSetting<List<string>>("searchHistory", new List<string>());
                favorites = _settingsManager.GetSetting<List<string>>("favorites", new List<string>());
                sharedDirs = _settingsManager.GetSetting<List<string>>("sharedDirs", new List<string>());
                
                // Actualizar ComboBox de favoritos si existe
                if (cmbFavorites != null)
                {
                    cmbFavorites.Items.Clear();
                    cmbFavorites.Items.Add("-- Seleccionar --");
                    cmbFavorites.Items.AddRange(favorites.ToArray());
                    cmbFavorites.SelectedIndex = 0;
                }
                if (chkEnableUploads != null) chkEnableUploads.Checked = enableUploads;
                if (numMaxUploads != null) numMaxUploads.Value = Math.Max(1, Math.Min(10, maxConcurrentUploads));
                if (numUploadSpeed != null) numUploadSpeed.Value = Math.Max(0, Math.Min(1048576, maxUploadSpeedKib));
                if (lstSharedDirs != null)
                {
                    lstSharedDirs.Items.Clear();
                    foreach (var d in sharedDirs) lstSharedDirs.Items.Add(d);
                }
                
                // Restaurar tamaño y posición de ventana
                int windowWidth = _settingsManager.GetSetting("windowWidth", 1920);
                int windowHeight = _settingsManager.GetSetting("windowHeight", 1200);
                int windowX = _settingsManager.GetSetting("windowX", -1);
                int windowY = _settingsManager.GetSetting("windowY", -1);
                int windowState = _settingsManager.GetSetting("windowState", (int)FormWindowState.Normal);
                
                // Aplicar tamaño
                this.Size = new Size(windowWidth, windowHeight);
                
                // Aplicar posición si es válida
                if (windowX >= 0 && windowY >= 0)
                {
                    this.StartPosition = FormStartPosition.Manual;
                    this.Location = new Point(windowX, windowY);
                }
                
                // Aplicar estado (Normal, Maximized, etc.)
                this.WindowState = (FormWindowState)windowState;
                
                Log($"✅ Ventana restaurada: {windowWidth}x{windowHeight} en ({windowX},{windowY}), estado={windowState}");
                
                Log($"✅ Config cargado - username: '{username}' (longitud: {username.Length})");
                Log($"✅ Config cargado - responseLimit: {responseLimit}, fileLimit: {fileLimit}");
                
                // Inicializar Modo Automático si está activado
                if (autoMode)
                {
                    InitializeAutoMode();
                }
                
                // Cargar lista negra
                if (System.IO.File.Exists(blacklistPath))
                {
                    var json = System.IO.File.ReadAllText(blacklistPath);
                    var list = JsonSerializer.Deserialize<List<string>>(json) ?? new List<string>();
                    blacklist = new HashSet<string>(list, StringComparer.OrdinalIgnoreCase);
                }
                
                // Cargar autores
                if (System.IO.File.Exists(authorsPath))
                {
                    authors = new HashSet<string>(System.IO.File.ReadAllLines(authorsPath), StringComparer.OrdinalIgnoreCase);
                }
                
                // Cargar watchlist
                if (System.IO.File.Exists(watchlistPath))
                {
                    watchlist = new HashSet<string>(System.IO.File.ReadAllLines(watchlistPath), StringComparer.OrdinalIgnoreCase);
                }
                
                // Cargar caché de países
                if (System.IO.File.Exists(countryCachePath))
                {
                    var json = System.IO.File.ReadAllText(countryCachePath);
                    var dict = JsonSerializer.Deserialize<Dictionary<string, string>>(json) ?? new Dictionary<string, string>();
                    countryCache = new ConcurrentDictionary<string, string>(dict);
                }
            }
            catch (Exception ex)
            {
                Log($"❌ ERROR en LoadConfig: {ex.Message}");
                Log($"Stack: {ex.StackTrace}");
            }
            
            if (enableUploads)
            {
                InitializeSharing();
            }

            Log($"✅ LoadConfig completado. responseLimit={responseLimit}, fileLimit={fileLimit}");
        }
        
        private void RestoreColumnWidths()
        {
            try
            {
                // Cargar anchos y orden de columnas de lvDownloads
                var downloadsColumnWidths = _settingsManager.GetSetting<List<int>>("lvDownloadsColumnWidths", new List<int>());
                var downloadsColumnOrder = _settingsManager.GetSetting<List<int>>("lvDownloadsColumnOrder", new List<int>());
                
                if (downloadsColumnWidths != null && downloadsColumnWidths.Count > 0 && lvDownloads != null && lvDownloads.Columns.Count == downloadsColumnWidths.Count)
                {
                    for (int i = 0; i < downloadsColumnWidths.Count; i++)
                    {
                        lvDownloads.Columns[i].Width = downloadsColumnWidths[i];
                    }
                    
                    if (downloadsColumnOrder != null && downloadsColumnOrder.Count == lvDownloads.Columns.Count)
                    {
                        for (int i = 0; i < downloadsColumnOrder.Count; i++)
                        {
                            lvDownloads.Columns[i].DisplayIndex = downloadsColumnOrder[i];
                        }
                    }
                    
                    hasRestoredDownloadsColumns = true; // Marcar que se restauraron columnas personalizadas
                }
                
                // Cargar anchos y orden de columnas de lvResults
                var searchColumnWidths = _settingsManager.GetSetting<List<int>>("lvSearchColumnWidths", new List<int>());
                var searchColumnOrder = _settingsManager.GetSetting<List<int>>("lvSearchColumnOrder", new List<int>());
                if (searchColumnWidths != null && searchColumnWidths.Count > 0 && lvResults != null && lvResults.Columns.Count == searchColumnWidths.Count)
                {
                    for (int i = 0; i < searchColumnWidths.Count; i++)
                    {
                        lvResults.Columns[i].Width = searchColumnWidths[i];
                    }
                    
                    if (searchColumnOrder != null && searchColumnOrder.Count == lvResults.Columns.Count)
                    {
                        for (int i = 0; i < searchColumnOrder.Count; i++)
                        {
                            lvResults.Columns[i].DisplayIndex = searchColumnOrder[i];
                        }
                    }
                    
                    hasRestoredResultsColumns = true; // Marcar que se restauraron columnas personalizadas
                }
                
                // Cargar anchos y orden de columnas de lvHistory
                var historyColumnWidths = _settingsManager.GetSetting<List<int>>("lvHistoryColumnWidths", new List<int>());
                var historyColumnOrder = _settingsManager.GetSetting<List<int>>("lvHistoryColumnOrder", new List<int>());
                if (historyColumnWidths != null && historyColumnWidths.Count > 0 && lvHistory != null && lvHistory.Columns.Count == historyColumnWidths.Count)
                {
                    for (int i = 0; i < historyColumnWidths.Count; i++)
                    {
                        lvHistory.Columns[i].Width = historyColumnWidths[i];
                    }
                    
                    if (historyColumnOrder != null && historyColumnOrder.Count == lvHistory.Columns.Count)
                    {
                        for (int i = 0; i < historyColumnOrder.Count; i++)
                        {
                            lvHistory.Columns[i].DisplayIndex = historyColumnOrder[i];
                        }
                    }
                }
                
                // Cargar anchos y orden de columnas de lvAutoAuthors
                var autoAuthorsColumnWidths = _settingsManager.GetSetting<List<int>>("lvAutoAuthorsColumnWidths", new List<int>());
                var autoAuthorsColumnOrder = _settingsManager.GetSetting<List<int>>("lvAutoAuthorsColumnOrder", new List<int>());
                if (autoAuthorsColumnWidths != null && autoAuthorsColumnWidths.Count > 0 && lvAutoAuthors != null && lvAutoAuthors.Columns.Count == autoAuthorsColumnWidths.Count)
                {
                    for (int i = 0; i < autoAuthorsColumnWidths.Count; i++)
                    {
                        lvAutoAuthors.Columns[i].Width = autoAuthorsColumnWidths[i];
                    }
                    
                    if (autoAuthorsColumnOrder != null && autoAuthorsColumnOrder.Count == lvAutoAuthors.Columns.Count)
                    {
                        for (int i = 0; i < autoAuthorsColumnOrder.Count; i++)
                        {
                            lvAutoAuthors.Columns[i].DisplayIndex = autoAuthorsColumnOrder[i];
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error restaurando anchos de columnas: {ex.Message}");
            }
            finally
            {
                isRestoringColumns = false; // Desbloquear SaveConfig
                Log("🔓 SaveConfig desbloqueado");
            }
        }
        
        private void RegisterColumnEvents()
        {
            Log("🔗 Registrando eventos de columnas...");
            
            // lvDownloads
            if (lvDownloads != null)
            {
                lvDownloads.ColumnWidthChanged += (s, e) => SaveConfig();
                lvDownloads.ColumnReordered += (s, e) => SaveConfig();
            }
            
            // lvResults
            if (lvResults != null)
            {
                lvResults.ColumnWidthChanged += (s, e) => SaveConfig();
                lvResults.ColumnReordered += (s, e) => SaveConfig();
            }
            
            // lvHistory
            if (lvHistory != null)
            {
                lvHistory.ColumnWidthChanged += (s, e) => SaveConfig();
                lvHistory.ColumnReordered += (s, e) => SaveConfig();
            }
            
            // lvAutoAuthors
            if (lvAutoAuthors != null)
            {
                lvAutoAuthors.ColumnWidthChanged += (s, e) => SaveConfig();
                lvAutoAuthors.ColumnReordered += (s, e) => SaveConfig();
            }
            
            Log("✅ Eventos de columnas registrados");
        }
        
        private DateTime lastConfigSave = DateTime.MinValue;
        private const int CONFIG_SAVE_THROTTLE_MS = 1000;
        private bool isRestoringColumns = false;
        private bool isRefreshingAuthors = false;
        private bool hasRestoredResultsColumns = false;
        private bool hasRestoredDownloadsColumns = false;
        
        private void SaveConfig()
        {
            // No guardar si _settingsManager no está inicializado
            if (_settingsManager == null)
            {
                return;
            }
            
            // No guardar si estamos restaurando columnas
            if (isRestoringColumns)
            {
                return;
            }
            
            // Throttle: no guardar más de una vez por segundo
            if ((DateTime.Now - lastConfigSave).TotalMilliseconds < CONFIG_SAVE_THROTTLE_MS)
            {
                return;
            }
            lastConfigSave = DateTime.Now;
            
            try
            {
                // Guardar anchos y orden de columnas de lvDownloads
                var downloadsColumnWidths = new List<int>();
                var downloadsColumnOrder = new List<int>();
                if (lvDownloads != null && lvDownloads.Columns.Count > 0)
                {
                    foreach (ColumnHeader col in lvDownloads.Columns)
                    {
                        downloadsColumnWidths.Add(col.Width);
                        downloadsColumnOrder.Add(col.DisplayIndex);
                    }
                }
                
                // Guardar anchos y orden de columnas de lvResults
                var resultsColumnWidths = new List<int>();
                var resultsColumnOrder = new List<int>();
                if (lvResults != null && lvResults.Columns.Count > 0)
                {
                    foreach (ColumnHeader col in lvResults.Columns)
                    {
                        resultsColumnWidths.Add(col.Width);
                        resultsColumnOrder.Add(col.DisplayIndex);
                    }
                }
                
                // Guardar anchos y orden de columnas de lvHistory
                var historyColumnWidths = new List<int>();
                var historyColumnOrder = new List<int>();
                if (lvHistory != null && lvHistory.Columns.Count > 0)
                {
                    foreach (ColumnHeader col in lvHistory.Columns)
                    {
                        historyColumnWidths.Add(col.Width);
                        historyColumnOrder.Add(col.DisplayIndex);
                    }
                }
                
                // Guardar anchos y orden de columnas de lvAutoAuthors
                var autoAuthorsColumnWidths = new List<int>();
                var autoAuthorsColumnOrder = new List<int>();
                if (lvAutoAuthors != null && lvAutoAuthors.Columns.Count > 0)
                {
                    foreach (ColumnHeader col in lvAutoAuthors.Columns)
                    {
                        autoAuthorsColumnWidths.Add(col.Width);
                        autoAuthorsColumnOrder.Add(col.DisplayIndex);
                    }
                }
                
                // Usar UnifiedSettingsManager para guardar
                _settingsManager.SetSetting("searchHistory", searchHistory);
                _settingsManager.SetSetting("favorites", favorites);
                _settingsManager.SetSetting("downloadDir", downloadDir);
                _settingsManager.SetSetting("username", username);
                _settingsManager.SetSetting("password", password);
                _settingsManager.SetSetting("autoConnect", autoConnect);
                _settingsManager.SetSetting("maxParallelDownloads", maxParallelDownloads);
                _settingsManager.SetSetting("maxParallelSearches", Math.Min(maxParallelSearches, 10));
                _settingsManager.SetSetting("maxRetries", maxRetries);
                _settingsManager.SetSetting("maxAlternativeRetries", maxAlternativeRetries);
                _settingsManager.SetSetting("searchTimeout", Math.Min(searchTimeout, 10));
                _settingsManager.SetSetting("responseLimit", Math.Min(responseLimit, 50));
                _settingsManager.SetSetting("fileLimit", fileLimit);
                _settingsManager.SetSetting("listenPort", listenPort);
                _settingsManager.SetSetting("enableDistributedNetwork", enableDistributedNetwork);
                _settingsManager.SetSetting("stealthMode", stealthMode);
                _settingsManager.SetSetting("minFileSizeKB", minFileSizeKB);
                _settingsManager.SetSetting("organizeByAuthor", organizeByAuthor);
                _settingsManager.SetSetting("autoBackup", autoBackup);
                _settingsManager.SetSetting("autoMode", autoMode);
                _settingsManager.SetSetting("instantDownload", instantDownload);
                _settingsManager.SetSetting("onlyNewFilesInAutoSearch", onlyNewFilesInAutoSearch);
                _settingsManager.SetSetting("priorityBySize", priorityBySize);
                _settingsManager.SetSetting("enableUploads", enableUploads);
                _settingsManager.SetSetting("maxConcurrentUploads", maxConcurrentUploads);
                _settingsManager.SetSetting("maxUploadSpeedKib", maxUploadSpeedKib);
                _settingsManager.SetSetting("shareVerboseLogging", shareVerboseLogging);
                
                // Guardar configuraciones adicionales
                _settingsManager.SetSetting("maxSimultaneousDownloads", maxSimultaneousDownloads);
                _settingsManager.SetSetting("continuousSearch", continuousSearch);
                _settingsManager.SetSetting("enableNotifications", enableNotifications);
                _settingsManager.SetSetting("enableSounds", enableSounds);
                _settingsManager.SetSetting("queuePositionRefreshIntervalSeconds", queuePositionRefreshIntervalSeconds);
                _settingsManager.SetSetting("retryConnectionIntervalSeconds", retryConnectionIntervalSeconds);
                _settingsManager.SetSetting("retryIoIntervalSeconds", retryIoIntervalSeconds);
                _settingsManager.SetSetting("cleanupIntervalSeconds", cleanupIntervalSeconds);
                _settingsManager.SetSetting("downloadSpeedLimitKib", downloadSpeedLimitKib);
                _settingsManager.SetSetting("retryBackoffMilliseconds", retryBackoffMilliseconds);
                _settingsManager.SetSetting("incompleteDownloadsDirectory", incompleteDownloadsDirectory);
                _settingsManager.SetSetting("postDownloadCommand", postDownloadCommand);
                _settingsManager.SetSetting("downloadFilterPattern", downloadFilterPattern);
                _settingsManager.SetSetting("autoReconnect", autoReconnect);
                _settingsManager.SetSetting("queueStrategy", (int)queueStrategy);
                _settingsManager.SetSetting("carbarherPath", carbarherPath);
                _settingsManager.SetSetting("autoStartDownloadsOnEnqueue", autoStartDownloadsOnEnqueue);
                _settingsManager.SetSetting("maxBandwidthKBps", maxBandwidthKBps);
                
                _settingsManager.SetSetting("batchSize", batchSize);
                _settingsManager.SetSetting("enableAdaptiveParallelism", enableAdaptiveParallelism);
                _settingsManager.SetSetting("enableNativeLib", enableNativeLib);
                _settingsManager.SetSetting("currentParallelism", currentParallelism);
                _settingsManager.SetSetting("minParallelism", minParallelism);
                _settingsManager.SetSetting("maxParallelism", maxParallelism);
                _settingsManager.SetSetting("logRetentionDays", logRetentionDays);
                
                // Ban-aware cooldown
                _settingsManager.SetSetting("banStrikeCount", banStrikeCount);
                _settingsManager.SetSetting("banCooldownUntil", banCooldownUntil.ToBinary());
                _settingsManager.SetSetting("lastBanEventAt", lastBanEventAt.ToBinary());
                
                // Guardar configuración de optimizaciones Fase 1-3
                _settingsManager.SetSetting("useVirtualListView", useVirtualListView);
                _settingsManager.SetSetting("useSQLiteForLargeResults", useSQLiteForLargeResults);
                _settingsManager.SetSetting("useRustOptimizations", useRustOptimizations);
                
                // Guardar configuración de optimizaciones Fase 4-8
                _settingsManager.SetSetting("useOptimizedDownloadManager", useOptimizedDownloadManager);
                _settingsManager.SetSetting("useVirtualDownloadsList", useVirtualDownloadsList);
                _settingsManager.SetSetting("useStringInterning", useStringInterning);
                _settingsManager.SetSetting("useLZ4Compression", useLZ4Compression);
                _settingsManager.SetSetting("useObjectPooling", useObjectPooling);
                _settingsManager.SetSetting("useAdaptiveTimeout", useAdaptiveTimeout);
                _settingsManager.SetSetting("useCircuitBreaker", useCircuitBreaker);
                _settingsManager.SetSetting("useSmartRetry", useSmartRetry);
                _settingsManager.SetSetting("useAsyncIO", useAsyncIO);
                _settingsManager.SetSetting("useHardLinks", useHardLinks);
                _settingsManager.SetSetting("usePreAllocation", usePreAllocation);
                
                // Guardar filtros de calidad de audio (Nicotine+ inspired)
                _settingsManager.SetSetting("audioQualityFilterEnabled", audioQualityFilters?.MinBitrate != null);
                if (audioQualityFilters?.MinBitrate != null)
                {
                    _settingsManager.SetSetting("audioMinBitrate", audioQualityFilters.MinBitrate.Value);
                }
                
                // MEJORA PROTOCOLO SOULSEEK: Guardar configuración del protocolo oficial
                _settingsManager.SetSetting("useWishlistSearch", _useWishlistSearch);
                _settingsManager.SetSetting("wishlistInterval", _wishlistInterval);
                _settingsManager.SetSetting("excludedPhrases", _excludedPhrases.ToList());
                
                // Guardar configuración Top 3
                _settingsManager.SetSetting("usePerformanceMonitor", usePerformanceMonitor);
                _settingsManager.SetSetting("useIntelligentCache", useIntelligentCache);
                _settingsManager.SetSetting("useAutoTuning", useAutoTuning);
                
                // Guardar tamaño y posición de ventana
                _settingsManager.SetSetting("windowWidth", this.Width);
                _settingsManager.SetSetting("windowHeight", this.Height);
                _settingsManager.SetSetting("windowX", this.Location.X);
                _settingsManager.SetSetting("windowY", this.Location.Y);
                _settingsManager.SetSetting("windowState", (int)this.WindowState);
                _settingsManager.SetSetting("sharedDirs", sharedDirs);
                
                // Guardar anchuras de columnas
                _settingsManager.SetSetting("lvDownloadsColumnWidths", downloadsColumnWidths);
                _settingsManager.SetSetting("lvDownloadsColumnOrder", downloadsColumnOrder);
                _settingsManager.SetSetting("lvResultsColumnWidths", resultsColumnWidths);
                _settingsManager.SetSetting("lvResultsColumnOrder", resultsColumnOrder);
                _settingsManager.SetSetting("lvHistoryColumnWidths", historyColumnWidths);
                _settingsManager.SetSetting("lvHistoryColumnOrder", historyColumnOrder);
                _settingsManager.SetSetting("lvAutoAuthorsColumnWidths", autoAuthorsColumnWidths);
                _settingsManager.SetSetting("lvAutoAuthorsColumnOrder", autoAuthorsColumnOrder);
                
                // Guardar
                _settingsManager.SaveSettings();
                SafeLog($"✅ Config guardado exitosamente\n");
                
                // MEJORA NICOTINE+: Publicar evento de configuración cambiada
                _eventBus?.Publish(SystemEvents.ConfigChanged, new
                {
                    Timestamp = DateTime.UtcNow,
                    AutoBackupEnabled = autoBackup
                });
                
                // Backup automático si está activado
                if (autoBackup)
                {
                    _settingsManager.CreateBackup();
                }
            }
            catch (Exception ex)
            {
                SafeLog($"❌ Error en SaveConfig: {ex.Message}\n");
            }
        }
        
        private void AddToSearchHistory(string searchTerm)
        {
            if (string.IsNullOrWhiteSpace(searchTerm)) return;
            
            // Eliminar si ya existe (para moverlo al principio)
            searchHistory.Remove(searchTerm);
            
            // Agregar al principio
            searchHistory.Insert(0, searchTerm);
            
            // Limitar tamaño del historial
            if (searchHistory.Count > MAX_SEARCH_HISTORY)
            {
                searchHistory = searchHistory.Take(MAX_SEARCH_HISTORY).ToList();
            }
            
            // Actualizar ComboBox
            LoadSearchHistory();
            
            // Guardar configuración
            SaveConfig();
        }
        
        private void LoadSearchHistory()
        {
            if (cmbSearch == null) return;
            
            try
            {
                var currentText = cmbSearch.Text;
                cmbSearch.Items.Clear();
                cmbSearch.Items.AddRange(searchHistory.ToArray());
                cmbSearch.Text = currentText;
            }
            catch { }
        }
        
        // Helper para construir ruta de descarga con subcarpeta de autor
        private string GetDownloadPath(string fileName, string author)
        {
            // Sanitizar nombre de autor para usar como carpeta
            string sanitizedAuthor = string.IsNullOrWhiteSpace(author) ? "Unknown" : author.Trim();
            
            // MEJORA #17: Usar StringBuilder para evitar múltiples allocaciones de Replace()
            var invalidChars = new HashSet<char>(Path.GetInvalidFileNameChars());
            var sb = new System.Text.StringBuilder(sanitizedAuthor.Length);
            
            foreach (char c in sanitizedAuthor)
            {
                sb.Append(invalidChars.Contains(c) ? '_' : c);
            }
            
            sanitizedAuthor = sb.ToString();
            
            // Normalizar: Windows trata variantes como iguales
            // - "Jose" y "José" (con/sin acentos)
            // - "Pepe J. Perez" y "Pepe J Perez" (con/sin puntos)
            string authorFolder = Path.Combine(downloadDir, sanitizedAuthor);
            
            // Si el directorio base existe, buscar carpetas existentes con nombre similar
            // MEJORA NICOTINE+: Usar DirectoryExistsCached
            if (DirectoryExistsCached(downloadDir))
            {
                try
                {
                    // Buscar carpetas que coincidan ignorando acentos y puntos
                    var existingFolders = System.IO.Directory.GetDirectories(downloadDir)
                        .Select(d => Path.GetFileName(d))
                        .Where(d => 
                            string.Equals(d, sanitizedAuthor, StringComparison.OrdinalIgnoreCase) ||
                            NormalizeForComparison(d).Equals(NormalizeForComparison(sanitizedAuthor), StringComparison.OrdinalIgnoreCase))
                        .ToList();
                    
                    // Si existe una carpeta similar, usar esa (preferir: sin puntos > con tildes > original)
                    if (existingFolders != null && existingFolders.Count > 0)
                    {
                        var preferredFolder = existingFolders
                            // 1. Preferir SIN puntos (más limpio)
                            .OrderBy(f => f.Count(c => c == '.'))
                            // 2. Luego preferir CON tildes/acentos (correcto en español)
                            .ThenByDescending(f => f.Any(c => c > 127))
                            // 3. Desempate alfabético
                            .ThenBy(f => f)
                            .First();
                        
                        authorFolder = Path.Combine(downloadDir, preferredFolder);
                    }
                }
                catch
                {
                    // Si hay error, usar el nombre original
                }
            }
            
            // Crear subcarpeta si no existe
            System.IO.Directory.CreateDirectory(authorFolder);
            
            return Path.Combine(authorFolder, fileName);
        }
        
        // Helper para normalizar nombres para comparación (sin acentos ni puntos)
        private string NormalizeForComparison(string text)
        {
            if (string.IsNullOrWhiteSpace(text))
                return text;
            
            // 1. Remover acentos
            var normalizedString = text.Normalize(System.Text.NormalizationForm.FormD);
            var stringBuilder = new System.Text.StringBuilder();
            
            foreach (var c in normalizedString)
            {
                var unicodeCategory = System.Globalization.CharUnicodeInfo.GetUnicodeCategory(c);
                if (unicodeCategory != System.Globalization.UnicodeCategory.NonSpacingMark)
                {
                    stringBuilder.Append(c);
                }
            }
            
            var withoutAccents = stringBuilder.ToString().Normalize(System.Text.NormalizationForm.FormC);
            
            // MEJORA #15: Usar StringBuilder para evitar múltiples allocaciones de Replace()
            stringBuilder.Clear();
            bool lastWasSpace = false;
            
            foreach (char c in withoutAccents)
            {
                // Remover puntuación y normalizar espacios en un solo paso
                if (c == '.' || c == ',' || c == ';' || c == ':')
                    continue;
                
                if (char.IsWhiteSpace(c))
                {
                    if (!lastWasSpace)
                    {
                        stringBuilder.Append(' ');
                        lastWasSpace = true;
                    }
                }
                else
                {
                    stringBuilder.Append(c);
                    lastWasSpace = false;
                }
            }
            
            // Trim manual para evitar ToString() adicional
            int start = 0;
            int end = stringBuilder.Length - 1;
            while (start <= end && stringBuilder[start] == ' ') start++;
            while (end >= start && stringBuilder[end] == ' ') end--;
            
            return start <= end ? stringBuilder.ToString(start, end - start + 1) : string.Empty;
        }
        
        // Helper para remover solo acentos/diacríticos (mantiene puntos)
        private string RemoveAccents(string text)
        {
            if (string.IsNullOrWhiteSpace(text))
                return text;
            
            var normalizedString = text.Normalize(System.Text.NormalizationForm.FormD);
            var stringBuilder = new System.Text.StringBuilder();
            
            foreach (var c in normalizedString)
            {
                var unicodeCategory = System.Globalization.CharUnicodeInfo.GetUnicodeCategory(c);
                if (unicodeCategory != System.Globalization.UnicodeCategory.NonSpacingMark)
                {
                    stringBuilder.Append(c);
                }
            }
            
            return stringBuilder.ToString().Normalize(System.Text.NormalizationForm.FormC);
        }
        
        // Consolidar carpetas duplicadas (variantes del mismo autor)
        private async Task ConsolidateDuplicateFolders()
        {
            try
            {
                // MEJORA NICOTINE+: Usar DirectoryExistsCached
                if (!DirectoryExistsCached(downloadDir))
                {
                    DarkMessageBox.Show(
                        $"La carpeta de descargas no existe:\n{downloadDir}",
                        "Carpeta no encontrada",
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Warning);
                    return;
                }
                
                AutoLog("🔀 Iniciando consolidación de carpetas...");
                
                // Obtener todas las carpetas de autores
                var allFolders = System.IO.Directory.GetDirectories(downloadDir)
                    .Select(d => Path.GetFileName(d))
                    .ToList();
                
                if (allFolders == null || allFolders.Count == 0)
                {
                    DarkMessageBox.Show(
                        "No hay carpetas de autores para consolidar.",
                        "Sin carpetas",
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Information);
                    return;
                }
                
                // Agrupar carpetas similares
                var groups = new Dictionary<string, List<string>>();
                
                foreach (var folder in allFolders)
                {
                    var normalized = NormalizeForComparison(folder);
                    
                    if (!groups.ContainsKey(normalized))
                    {
                        groups[normalized] = new List<string>();
                    }
                    
                    groups[normalized].Add(folder);
                }
                
                // Filtrar solo grupos con duplicados
                var duplicateGroups = groups.Where(g => g.Value.Count > 1).ToList();
                
                if (duplicateGroups.Count == 0)
                {
                    DarkMessageBox.Show(
                        "✅ No se encontraron carpetas duplicadas.\n\nTodas las carpetas están correctamente organizadas.",
                        "Sin duplicados",
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Information);
                    AutoLog("✅ No se encontraron carpetas duplicadas");
                    return;
                }
                
                // Mostrar resumen
                var summary = new System.Text.StringBuilder();
                summary.AppendLine($"Se encontraron {duplicateGroups.Count} grupo(s) de carpetas duplicadas:\n");
                
                int totalFolders = 0;
                foreach (var group in duplicateGroups.Take(10))
                {
                    summary.AppendLine($"• {string.Join(" / ", group.Value)}");
                    totalFolders += group.Value.Count;
                }
                
                if (duplicateGroups.Count > 10)
                {
                    summary.AppendLine($"... y {duplicateGroups.Count - 10} grupo(s) más");
                }
                
                summary.AppendLine($"\nTotal: {totalFolders} carpetas se consolidarán en {duplicateGroups.Count} carpetas.");
                summary.AppendLine("\n¿Deseas continuar?");
                
                var result = DarkMessageBox.Show(
                    summary.ToString(),
                    "Consolidar Carpetas",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Question);
                
                if (result != DialogResult.Yes)
                {
                    AutoLog("❌ Consolidación cancelada por el usuario");
                    return;
                }
                
                // Consolidar
                int movedFiles = 0;
                int deletedFolders = 0;
                int errors = 0;
                
                foreach (var group in duplicateGroups)
                {
                    try
                    {
                        // Elegir carpeta preferida (sin puntos > con tildes > alfabético)
                        var preferredFolder = group.Value
                            .OrderBy(f => f.Count(c => c == '.'))
                            .ThenByDescending(f => f.Any(c => c > 127))
                            .ThenBy(f => f)
                            .First();
                        
                        var preferredPath = Path.Combine(downloadDir, preferredFolder);
                        
                        AutoLog($"🔀 Consolidando en: {preferredFolder}");
                        
                        // Mover archivos de las otras carpetas
                        foreach (var folder in group.Value)
                        {
                            if (folder == preferredFolder)
                                continue;
                            
                            var sourcePath = Path.Combine(downloadDir, folder);
                            
                            try
                            {
                                var files = System.IO.Directory.GetFiles(sourcePath);
                                
                                foreach (var file in files)
                                {
                                    var fileName = Path.GetFileName(file);
                                    var destFile = Path.Combine(preferredPath, fileName);
                                    
                                    // Si el archivo ya existe en destino, comparar tamaños
                                    if (System.IO.File.Exists(destFile))
                                    {
                                        var sourceInfo = new FileInfo(file);
                                        var destInfo = new FileInfo(destFile);
                                        
                                        // Mantener el más grande
                                        if (sourceInfo.Length > destInfo.Length)
                                        {
                                            System.IO.File.Delete(destFile);
                                            System.IO.File.Move(file, destFile);
                                            AutoLog($"  ↔️ Reemplazado (más grande): {fileName}");
                                            movedFiles++;
                                        }
                                        else
                                        {
                                            System.IO.File.Delete(file);
                                            AutoLog($"  ⏭️ Omitido (ya existe): {fileName}");
                                        }
                                    }
                                    else
                                    {
                                        System.IO.File.Move(file, destFile);
                                        AutoLog($"  ✅ Movido: {fileName}");
                                        movedFiles++;
                                    }
                                }
                                
                                // Eliminar carpeta vacía
                                if (System.IO.Directory.GetFiles(sourcePath).Length == 0)
                                {
                                    System.IO.Directory.Delete(sourcePath);
                                    AutoLog($"  🗑️ Eliminada carpeta vacía: {folder}");
                                    deletedFolders++;
                                }
                            }
                            catch (Exception ex)
                            {
                                AutoLog($"  ❌ Error procesando {folder}: {ex.Message}");
                                errors++;
                            }
                        }
                    }
                    catch (Exception ex)
                    {
                        AutoLog($"❌ Error en grupo: {ex.Message}");
                        errors++;
                    }
                }
                
                // Resumen final
                var finalMessage = $"✅ Consolidación completada:\n\n" +
                    $"• {movedFiles} archivo(s) movido(s)\n" +
                    $"• {deletedFolders} carpeta(s) eliminada(s)\n" +
                    $"• {duplicateGroups.Count} grupo(s) consolidado(s)";
                
                if (errors > 0)
                {
                    finalMessage += $"\n\n⚠️ {errors} error(es) - revisa el log";
                }
                
                DarkMessageBox.Show(
                    finalMessage,
                    "Consolidación Completada",
                    MessageBoxButtons.OK,
                    errors > 0 ? MessageBoxIcon.Warning : MessageBoxIcon.Information);
                
                AutoLog($"✅ Consolidación completada: {movedFiles} archivos, {deletedFolders} carpetas eliminadas");
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error en consolidación: {ex.Message}");
                DarkMessageBox.Show(
                    $"Error durante la consolidación:\n\n{ex.Message}",
                    "Error",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Error);
            }
        }
        
        private void CleanDuplicateFiles()
        {
            try
            {
                var result = DarkMessageBox.Show(
                    "Esta herramienta buscará archivos duplicados en tu carpeta de descargas.\n\n" +
                    "Se consideran duplicados los archivos con el mismo nombre (sin importar mayúsculas/minúsculas).\n" +
                    "Se conservará el archivo más reciente y se eliminarán los duplicados.\n\n" +
                    "¿Deseas continuar?",
                    "Limpiar Duplicados",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Question);
                
                if (result != DialogResult.Yes)
                    return;
                
                Log("🧹 Iniciando limpieza de duplicados...");
                
                // MEJORA NICOTINE+: Usar DirectoryExistsCached
                if (!DirectoryExistsCached(downloadDir))
                {
                    DarkMessageBox.Show("La carpeta de descargas no existe.", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                    return;
                }
                
                // Obtener todos los archivos recursivamente
                var allFiles = System.IO.Directory.GetFiles(downloadDir, "*.*", SearchOption.AllDirectories)
                    .Select(f => new FileInfo(f))
                    .ToList();
                
                Log($"📁 Analizando {allFiles.Count} archivos...");
                
                // Agrupar por nombre de archivo (sin ruta, case-insensitive)
                var duplicateGroups = allFiles
                    .GroupBy(f => f.Name, StringComparer.OrdinalIgnoreCase)
                    .Where(g => g.Count() > 1)
                    .ToList();
                
                if (duplicateGroups.Count == 0)
                {
                    Log("✅ No se encontraron duplicados");
                    return;
                }
                
                int deletedCount = 0;
                long freedSpace = 0;
                
                foreach (var group in duplicateGroups)
                {
                    // Ordenar por fecha de modificación (más reciente primero)
                    var sorted = group.OrderByDescending(f => f.LastWriteTime).ToList();
                    var keep = sorted.First();
                    var toDelete = sorted.Skip(1).ToList();
                    
                    Log($"📄 {group.Key}: conservando {keep.FullName}");
                    
                    foreach (var file in toDelete)
                    {
                        try
                        {
                            freedSpace += file.Length;
                            file.Delete();
                            deletedCount++;
                            Log($"  🗑️ Eliminado: {file.FullName}");
                        }
                        catch (Exception ex)
                        {
                            Log($"  ❌ Error eliminando {file.FullName}: {ex.Message}");
                        }
                    }
                }
                
                var freedMB = freedSpace / (1024.0 * 1024.0);
                var message = $"Limpieza completada:\n\n" +
                             $"• Archivos eliminados: {deletedCount}\n" +
                             $"• Espacio liberado: {freedMB:F2} MB\n" +
                             $"• Grupos de duplicados: {duplicateGroups.Count}";
                
                Log($"✅ {message.Replace("\n", " ")}");
            }
            catch (Exception ex)
            {
                Log($"❌ Error en CleanDuplicateFiles: {ex.Message}");
                DarkMessageBox.Show($"Error limpiando duplicados:\n{ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
        private void InitializeNotifications()
        {
            try
            {
                notifyIcon = new NotifyIcon
                {
                    Icon = SystemIcons.Information,
                    Visible = true,
                    Text = "SlskDown - Cliente Soulseek"
                };
                
                notifyIcon.BalloonTipClicked += (s, e) =>
                {
                    this.WindowState = FormWindowState.Normal;
                    this.Activate();
                };
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error inicializando notificaciones: {ex.Message}");
            }
        }
        
        private void ShowNotification(string title, string message, ToolTipIcon icon = ToolTipIcon.Info)
        {
            if (!enableNotifications || notifyIcon == null)
                return;
            
            try
            {
                notifyIcon.ShowBalloonTip(3000, title, message, icon);
                
                if (enableSounds)
                {
                    System.Media.SystemSounds.Asterisk.Play();
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error mostrando notificación: {ex.Message}");
            }
        }
        
        // Mostrar diálogo en modo oscuro
        private DialogResult ShowDarkDialog(string message, string title, MessageBoxButtons buttons = MessageBoxButtons.OK, string icon = "ℹ️")
        {
            // Calcular tamaño necesario basado en el contenido
            var tempLabel = new Label
            {
                Text = $"{icon}  {message}",
                Font = new Font("Segoe UI", 10),
                MaximumSize = new Size(700, 0),
                AutoSize = true
            };
            
            using (var g = Graphics.FromHwnd(IntPtr.Zero))
            {
                var size = g.MeasureString(tempLabel.Text, tempLabel.Font, 700);
                var calculatedWidth = Math.Max(450, (int)size.Width + 80);  // Mínimo 450px, +80 para padding
                var calculatedHeight = Math.Max(180, (int)size.Height + 150); // Mínimo 180px, +150 para botones y padding
                
                var form = new Form
                {
                    Text = title,
                    BackColor = Color.FromArgb(25, 25, 25),
                    ForeColor = Color.White,
                    StartPosition = FormStartPosition.CenterParent,
                    FormBorderStyle = FormBorderStyle.FixedDialog,
                    MaximizeBox = false,
                    MinimizeBox = false,
                    Font = new Font("Segoe UI", 10),
                    ClientSize = new Size(calculatedWidth, calculatedHeight),
                    Padding = new Padding(10)
                };

                var mainLayout = new TableLayoutPanel
                {
                    Dock = DockStyle.Fill,
                    ColumnCount = 1,
                    RowCount = 2,
                    Padding = new Padding(24),
                    BackColor = Color.FromArgb(25, 25, 25)
                };
                mainLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100));
                mainLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize));

                var lblMessage = new Label
                {
                    Text = $"{icon}  {message}",
                    AutoSize = true,
                    ForeColor = Color.White,
                    Font = new Font("Segoe UI", 10),
                    MaximumSize = new Size(calculatedWidth - 80, 0),
                    Padding = new Padding(0, 0, 0, 10),
                    Anchor = AnchorStyles.Top | AnchorStyles.Left
                };
                mainLayout.Controls.Add(lblMessage, 0, 0);

                var buttonPanel = new FlowLayoutPanel
                {
                    FlowDirection = FlowDirection.RightToLeft,
                    AutoSize = true,
                    AutoSizeMode = AutoSizeMode.GrowAndShrink,
                    WrapContents = false,
                    BackColor = Color.FromArgb(25, 25, 25),
                    Margin = new Padding(0, 20, 0, 0),
                    Anchor = AnchorStyles.Right
                };

                DialogResult result = DialogResult.OK;
                
                if (buttons == MessageBoxButtons.YesNo)
                {
                    var btnNo = new Button
                    {
                        Text = "No",
                        AutoSize = true,
                        MinimumSize = new Size(90, 35),
                        BackColor = Color.FromArgb(60, 60, 60),
                        ForeColor = Color.White,
                        FlatStyle = FlatStyle.Flat,
                        DialogResult = DialogResult.No,
                        Margin = new Padding(5, 0, 0, 0),
                        Padding = new Padding(15, 5, 15, 5)
                    };
                    btnNo.FlatAppearance.BorderSize = 0;
                    btnNo.Click += (s, e) => { result = DialogResult.No; form.Close(); };

                    var btnYes = new Button
                    {
                        Text = "Sí",
                        AutoSize = true,
                        MinimumSize = new Size(90, 35),
                        BackColor = Color.FromArgb(0, 120, 215),
                        ForeColor = Color.White,
                        FlatStyle = FlatStyle.Flat,
                        DialogResult = DialogResult.Yes,
                        Margin = new Padding(5, 0, 0, 0),
                        Padding = new Padding(15, 5, 15, 5)
                    };
                    btnYes.FlatAppearance.BorderSize = 0;
                    btnYes.Click += (s, e) => { result = DialogResult.Yes; form.Close(); };

                    buttonPanel.Controls.Add(btnNo);
                    buttonPanel.Controls.Add(btnYes);

                    form.AcceptButton = btnYes;
                    form.CancelButton = btnNo;
                }
                else
                {
                    var btnOK = new Button
                    {
                        Text = "OK",
                        AutoSize = true,
                        MinimumSize = new Size(90, 35),
                        BackColor = Color.FromArgb(0, 120, 215),
                        ForeColor = Color.White,
                        FlatStyle = FlatStyle.Flat,
                        DialogResult = DialogResult.OK,
                        Margin = new Padding(5, 0, 0, 0),
                        Padding = new Padding(15, 5, 15, 5)
                    };
                    btnOK.FlatAppearance.BorderSize = 0;
                    btnOK.Click += (s, e) => { result = DialogResult.OK; form.Close(); };
                    buttonPanel.Controls.Add(btnOK);
                    form.AcceptButton = btnOK;
                }

                mainLayout.Controls.Add(buttonPanel, 0, 1);
                form.Controls.Add(mainLayout);
                form.ShowDialog();

                return result;
            }
        }
        
        // MEJORA #5: Verificar hitos de progreso
        private void CheckProgressMilestone()
        {
            try
            {
                if (totalDownloadsInSession == 0)
                    return;
                
                // MEJORA FASE 1.3: ReadLock para Count
                int completed = ReadLocked(downloadQueueLock, () =>
                    downloadQueue.Count(t => t.Status == DownloadStatus.Completed));
                
                int progressPercent = (int)((double)completed / totalDownloadsInSession * 100);
                
                if (progressPercent >= 25 && lastProgressNotification < 25)
                {
                    ShowNotification("Progreso 25%", 
                        $"🎉 {completed}/{totalDownloadsInSession} archivos completados\n\n¡Vas por buen camino!", 
                        ToolTipIcon.Info);
                    lastProgressNotification = 25;
                    AutoLog($"🎉 Progreso 25%: {completed}/{totalDownloadsInSession} archivos");
                }
                else if (progressPercent >= 50 && lastProgressNotification < 50)
                {
                    ShowNotification("Progreso 50%", 
                        $"🎉 {completed}/{totalDownloadsInSession} archivos completados\n\n¡A mitad de camino!", 
                        ToolTipIcon.Info);
                    lastProgressNotification = 50;
                    AutoLog($"🎉 Progreso 50%: {completed}/{totalDownloadsInSession} archivos");
                }
                else if (progressPercent >= 75 && lastProgressNotification < 75)
                {
                    ShowNotification("Progreso 75%", 
                        $"🎉 {completed}/{totalDownloadsInSession} archivos completados\n\n¡Casi terminado!", 
                        ToolTipIcon.Info);
                    lastProgressNotification = 75;
                    AutoLog($"🎉 Progreso 75%: {completed}/{totalDownloadsInSession} archivos");
                }
                else if (progressPercent >= 100 && lastProgressNotification < 100)
                {
                    ShowNotification("¡Completado!", 
                        $"✅ {completed}/{totalDownloadsInSession} archivos completados\n\n¡Todas las descargas finalizadas!", 
                        ToolTipIcon.Info);
                    lastProgressNotification = 100;
                    AutoLog($"✅ 100% Completado: {completed}/{totalDownloadsInSession} archivos");
                }
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error verificando progreso: {ex.Message}");
            }
        }
        
        // MEJORA #4: Retry inteligente con exponential backoff y jitter
        private int GetRetryDelay(int retryCount, string errorMessage = null)
        {
            // Base: backoff exponencial con jitter
            // 30s, 60s, 120s, 240s, máximo 480s (8 minutos)
            int baseDelay = (int)Math.Min(30 * Math.Pow(2, retryCount), 480);
            
            // Agregar jitter (±20%) para evitar thundering herd
            var random = new Random();
            double jitter = 1.0 + (random.NextDouble() * 0.4 - 0.2); // 0.8 a 1.2
            int delayWithJitter = (int)(baseDelay * jitter);
            
            // Ajustar delay según tipo de error
            if (!string.IsNullOrEmpty(errorMessage))
            {
                var errorLower = errorMessage.ToLowerInvariant();
                
                // MEJORA #6 (Nicotine+): Queue Full / File Too Large - retry más frecuente (5 min)
                if (errorLower.Contains("queue") || 
                    errorLower.Contains("too large") ||
                    errorLower.Contains("file size") ||
                    errorLower.Contains("maximum"))
                {
                    return 300; // 5 minutos fijo (antes era 30 min con backoff)
                }
                // Errores de red/timeout: delay más largo
                else if (errorLower.Contains("timeout") || 
                    errorLower.Contains("timed out") ||
                    errorLower.Contains("connection") ||
                    errorLower.Contains("network"))
                {
                    delayWithJitter = (int)(delayWithJitter * 1.5); // +50%
                }
                // Usuario offline: delay mucho más largo
                else if (errorLower.Contains("offline") || 
                         errorLower.Contains("not available") ||
                         errorLower.Contains("unavailable"))
                {
                    delayWithJitter = (int)(delayWithJitter * 2.0); // +100%
                }
                // Errores de rate limit: delay extremadamente largo
                else if (errorLower.Contains("rate limit") || 
                         errorLower.Contains("too many") ||
                         errorLower.Contains("throttle"))
                {
                    delayWithJitter = (int)(delayWithJitter * 3.0); // +200%
                }
                // Errores de archivo (corrupto, no existe): delay corto
                else if (errorLower.Contains("file not found") || 
                         errorLower.Contains("access denied") ||
                         errorLower.Contains("corrupt"))
                {
                    delayWithJitter = (int)(delayWithJitter * 0.5); // -50%
                }
            }
            
            return Math.Max(10, delayWithJitter); // Mínimo 10 segundos
        }
        
        // MEJORA #4: Determinar si un error es recuperable
        private bool IsRecoverableError(string errorMessage)
        {
            if (string.IsNullOrEmpty(errorMessage))
                return true; // Asumir recuperable si no hay mensaje
            
            var errorLower = errorMessage.ToLowerInvariant();
            
            // Errores NO recuperables
            if (errorLower.Contains("file not found") ||
                errorLower.Contains("access denied") ||
                errorLower.Contains("invalid") ||
                errorLower.Contains("banned") ||
                errorLower.Contains("blocked"))
            {
                return false;
            }
            
            // Errores recuperables (temporales)
            return errorLower.Contains("timeout") ||
                   errorLower.Contains("offline") ||
                   errorLower.Contains("connection") ||
                   errorLower.Contains("network") ||
                   errorLower.Contains("busy") ||
                   errorLower.Contains("unavailable");
        }
        
        // MEJORA #7: Cachear proveedores
        private void CacheProviders(string fileName, List<string> providers)
        {
            if (providers == null || providers.Count == 0)
                return;
            
            lock (fileProvidersCache)
            {
                fileProvidersCache[fileName] = (new List<string>(providers), DateTime.Now);
                AutoLog($"💾 Cacheados {providers.Count} proveedores para: {fileName}");
            }
        }
        
        // Levenshtein distance para fuzzy matching
        private int LevenshteinDistance(string s1, string s2)
        {
            if (string.IsNullOrEmpty(s1)) return s2?.Length ?? 0;
            if (string.IsNullOrEmpty(s2)) return s1.Length;
            
            int[,] d = new int[s1.Length + 1, s2.Length + 1];
            
            for (int i = 0; i <= s1.Length; i++)
                d[i, 0] = i;
            for (int j = 0; j <= s2.Length; j++)
                d[0, j] = j;
            
            for (int i = 1; i <= s1.Length; i++)
            {
                for (int j = 1; j <= s2.Length; j++)
                {
                    int cost = (s2[j - 1] == s1[i - 1]) ? 0 : 1;
                    d[i, j] = Math.Min(Math.Min(d[i - 1, j] + 1, d[i, j - 1] + 1), d[i - 1, j - 1] + cost);
                }
            }
            
            return d[s1.Length, s2.Length];
        }
        
        // Calcular similitud entre 0 y 1 (1 = idéntico, 0 = completamente diferente)
        private double CalculateSimilarity(string s1, string s2)
        {
            if (string.IsNullOrEmpty(s1) || string.IsNullOrEmpty(s2))
                return 0;
            
            int maxLen = Math.Max(s1.Length, s2.Length);
            if (maxLen == 0) return 1;
            
            int distance = LevenshteinDistance(s1.ToLowerInvariant(), s2.ToLowerInvariant());
            return 1.0 - ((double)distance / maxLen);
        }
        
        // Normalizar nombre de archivo para comparación
        private string NormalizeFileName(string fileName)
        {
            if (string.IsNullOrEmpty(fileName))
                return string.Empty;
            
            // Remover extensión
            fileName = Path.GetFileNameWithoutExtension(fileName);
            
            // Convertir a minúsculas
            fileName = fileName.ToLowerInvariant();
            
            // OPTIMIZACIÓN: Usar Regex compilados cacheados
            fileName = RegexSpecialChars.Replace(fileName, " ");
            fileName = RegexMultipleSpaces.Replace(fileName, " ");
            
            return fileName.Trim();
        }
        
        // Cargar blacklist de autores desde archivo
        private void LoadBlacklistedAuthors()
        {
            try
            {
                blacklistedAuthors.Clear();
                ClearBlacklistCache(); // Limpiar caché al recargar
                
                if (System.IO.File.Exists(blacklistAuthorsFile))
                {
                    var lines = System.IO.File.ReadAllLines(blacklistAuthorsFile, Encoding.UTF8);
                    foreach (var line in lines)
                    {
                        if (!string.IsNullOrWhiteSpace(line) && !line.TrimStart().StartsWith("#"))
                        {
                            blacklistedAuthors.Add(line.Trim());
                        }
                    }
                    Log($"📋 Blacklist cargada: {blacklistedAuthors.Count} autores ignorados");
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error cargando blacklist: {ex.Message}");
            }
        }
        
        // Guardar blacklist de autores a archivo
        private void SaveBlacklistedAuthors()
        {
            try
            {
                var lines = new List<string>
                {
                    "# Autores ignorados - uno por línea",
                    "# Las líneas que comienzan con # son comentarios",
                    ""
                };
                lines.AddRange(blacklistedAuthors.OrderBy(a => a));
                
                System.IO.File.WriteAllLines(blacklistAuthorsFile, lines, Encoding.UTF8);
                Log($"💾 Blacklist guardada: {blacklistedAuthors.Count} autores");
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error guardando blacklist: {ex.Message}");
            }
        }
        
        // Agregar autor a blacklist
        private void AddToBlacklist(string author)
        {
            if (string.IsNullOrWhiteSpace(author))
                return;
            
            author = author.Trim();
            if (blacklistedAuthors.Add(author))
            {
                // Actualizar caché inmediatamente
                blacklistCache[author] = true;
                
                SaveBlacklistedAuthors();
                Log($"🚫 Autor agregado a blacklist: {author}");
            }
        }
        
        // Verificar si un autor está en blacklist (con caché para performance)
        private bool IsAuthorBlacklisted(string author)
        {
            if (string.IsNullOrWhiteSpace(author))
                return false;
            
            author = author.Trim();
            
            // Verificar caché primero (O(1) lookup)
            if (blacklistCache.TryGetValue(author, out bool isBlacklisted))
                return isBlacklisted;
            
            // Si no está en caché, verificar en HashSet y cachear resultado
            isBlacklisted = blacklistedAuthors.Contains(author);
            blacklistCache[author] = isBlacklisted;
            
            return isBlacklisted;
        }
        
        // Limpiar caché de blacklist (llamar al recargar blacklist)
        private void ClearBlacklistCache()
        {
            blacklistCache.Clear();
        }
        
