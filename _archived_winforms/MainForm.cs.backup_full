            footer.Controls.Add(footerFlow);
            layout.Controls.Add(footer, 0, 2);
            
            historyTab.Controls.Add(layout);
            
            // Cargar primera página
            RefreshHistoryView(true);
            
            var tipsHist = GetToolTip();
            tipsHist.SetToolTip(btnFilterAll, "Mostrar todas las entradas del historial");
            tipsHist.SetToolTip(btnFilterSpanish, "Filtrar historial por archivos en español");
            tipsHist.SetToolTip(btnFilterNonSpanish, "Filtrar historial por archivos no españoles");
            tipsHist.SetToolTip(btnClassifySpanish, "Clasificar idioma de los archivos del historial");
            tipsHist.SetToolTip(btnDeleteNonSpanish, "Eliminar entradas clasificadas como no español");
            tipsHist.SetToolTip(lblHistoryStats, "Resumen: totales, visibles, éxito/errores y peso total");
            tipsHist.SetToolTip(lvHistory, "Historial de descargas y acciones");
            tipsHist.SetToolTip(btnLoadMore, "Cargar más elementos del historial");
            
            return historyTab;
        }
        
        private void CreateLogTab(TabPage parent)
        {
            var logLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 1,
                RowCount = 2,
                BackColor = Color.FromArgb(25, 25, 25),
                Padding = new Padding(16, 16, 16, 12)
            };
            logLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize));
            logLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100f));
            
            // Controles superiores
            var controlsFlow = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                AutoSize = true,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = true,
                BackColor = Color.FromArgb(35, 35, 35),
                Padding = new Padding(12, 8, 12, 8),
                Margin = new Padding(0, 0, 0, 12)
            };
            
            var btnClearLog = new Button
            {
                Text = "🗑️ Limpiar Log",
                AutoSize = true,
                BackColor = Color.FromArgb(60, 60, 60),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Margin = new Padding(0, 0, 12, 0)
            };
            btnClearLog.Click += (s, e) => txtLog.Clear();
            controlsFlow.Controls.Add(btnClearLog);
            
            var btnOpenLogs = new Button
            {
                Text = "📁 Abrir Logs",
                AutoSize = true,
                BackColor = Color.FromArgb(60, 60, 60),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Margin = new Padding(0)
            };
            btnOpenLogs.Click += (s, e) =>
            {
                try
                {
                    var logsDir = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "logs");
                    if (!System.IO.Directory.Exists(logsDir))
                    {
                        System.IO.Directory.CreateDirectory(logsDir);
                    }
                    Process.Start(new ProcessStartInfo
                    {
                        FileName = logsDir,
                        UseShellExecute = true
                    });
                }
                catch (Exception ex)
                {
                    DarkMessageBox.Show($"No se pudo abrir la carpeta de logs: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            };
            controlsFlow.Controls.Add(btnOpenLogs);
            
            // Filtro de nivel de log
            var lblLogLevel = new Label
            {
                Text = "Nivel:",
                AutoSize = true,
                ForeColor = Color.White,
                Margin = new Padding(12, 5, 5, 0)
            };
            controlsFlow.Controls.Add(lblLogLevel);
            
            var cmbLogLevel = new ComboBox
            {
                DropDownStyle = ComboBoxStyle.DropDownList,
                BackColor = Color.FromArgb(60, 60, 60),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Width = 150,
                Margin = new Padding(0, 0, 12, 0)
            };
            cmbLogLevel.Items.AddRange(new[] { "TODOS", "DEBUG", "INFO", "WARN", "ERROR", "SUCCESS" });
            cmbLogLevel.SelectedIndex = 0;
            controlsFlow.Controls.Add(cmbLogLevel);
            
            // Filtro de categoría
            var lblLogCategory = new Label
            {
                Text = "Categoría:",
                AutoSize = true,
                ForeColor = Color.White,
                Margin = new Padding(0, 5, 5, 0)
            };
            controlsFlow.Controls.Add(lblLogCategory);
            
            var cmbLogCategory = new ComboBox
            {
                DropDownStyle = ComboBoxStyle.DropDownList,
                BackColor = Color.FromArgb(60, 60, 60),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Width = 180,
                Margin = new Padding(0, 0, 12, 0)
            };
            cmbLogCategory.Items.AddRange(new[] { "TODAS", "CONEXION", "DESCARGA", "BUSQUEDA", "PURGA", "STEALTH", "COMPARTIR", "SISTEMA", "GENERAL" });
            cmbLogCategory.SelectedIndex = 0;
            controlsFlow.Controls.Add(cmbLogCategory);
            
            var btnCopyLog = new Button
            {
                Text = "📋 Copiar",
                AutoSize = true,
                BackColor = Color.FromArgb(60, 60, 60),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Margin = new Padding(0, 0, 0, 0)
            };
            btnCopyLog.Click += (s, e) =>
            {
                try
                {
                    if (!string.IsNullOrEmpty(txtLog.Text))
                    {
                        Clipboard.SetText(txtLog.Text);
                        LogEx(LogLevel.INFO, LogCategory.SISTEMA, "Log copiado al portapapeles");
                        ShowNotification("Copiado", "Log copiado al portapapeles", ToolTipIcon.Info);
                    }
                    else
                    {
                        DarkMessageBox.Show("El log está vacío", "Copiar Log", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    }
                }
                catch (Exception ex)
                {
                    DarkMessageBox.Show($"Error al copiar al portapapeles: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            };
            controlsFlow.Controls.Add(btnCopyLog);
            
            // TextBox para el log
            txtLog = new TextBox
            {
                Dock = DockStyle.Fill,
                Multiline = true,
                ReadOnly = true,
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.LightGray,
                Font = new Font("Consolas", 9),
                ScrollBars = ScrollBars.Vertical,
                WordWrap = false
            };
            
            // Mostrar mensajes de log tempranos
            if (earlyLogMessages.Count > 0)
            {
                txtLog.Text = string.Join(Environment.NewLine, earlyLogMessages) + Environment.NewLine;
                earlyLogMessages.Clear();
            }
            
            logLayout.Controls.Add(controlsFlow, 0, 0);
            logLayout.Controls.Add(txtLog, 0, 1);
            
            var tipsLog = GetToolTip();
            tipsLog.SetToolTip(btnClearLog, "Limpiar el contenido del log");
            tipsLog.SetToolTip(btnOpenLogs, "Abrir la carpeta donde se guardan los logs");
            tipsLog.SetToolTip(lblLogLevel, "Nivel mínimo de mensajes a mostrar");
            tipsLog.SetToolTip(cmbLogLevel, "Selecciona el nivel de detalle del log");
            tipsLog.SetToolTip(lblLogCategory, "Categoría de mensajes a mostrar");
            tipsLog.SetToolTip(cmbLogCategory, "Selecciona la categoría de log a filtrar");
            tipsLog.SetToolTip(btnCopyLog, "Copiar el log al portapapeles");
            tipsLog.SetToolTip(txtLog, "Salida del log en tiempo real");
            
            parent.Controls.Add(logLayout);
        }
        
        private void CreateTranslateTab(TabPage parent)
        {
            parent.BackColor = Color.FromArgb(18, 18, 18);
            
            var mainLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 1,
                RowCount = 3,
                BackColor = Color.FromArgb(18, 18, 18),
                Padding = new Padding(20)
            };
            mainLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize)); // Controles superiores
            mainLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize)); // Progreso
            mainLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100f)); // Log
            
            // === PANEL SUPERIOR: Selección de archivo ===
            var topPanel = new Panel
            {
                Dock = DockStyle.Fill,
                AutoSize = true,
                BackColor = Color.FromArgb(25, 25, 25),
                Padding = new Padding(15),
                Margin = new Padding(0, 0, 0, 15)
            };
            
            var topFlow = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                AutoSize = true,
                FlowDirection = FlowDirection.TopDown,
                WrapContents = false,
                BackColor = Color.Transparent
            };
            
            // Título
            var lblTitle = new Label
            {
                Text = "📚 TRADUCTOR DE LIBROS",
                Font = new Font("Segoe UI", 14, FontStyle.Bold),
                ForeColor = Color.FromArgb(100, 180, 255),
                AutoSize = true,
                Margin = new Padding(0, 0, 0, 15)
            };
            topFlow.Controls.Add(lblTitle);
            
            // Botón seleccionar archivo
            btnSelectFile = new Button
            {
                Text = "📁 Seleccionar Archivo",
                AutoSize = true,
                Height = 40,
                BackColor = Color.FromArgb(60, 120, 180),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 10, FontStyle.Bold),
                Cursor = Cursors.Hand,
                Margin = new Padding(0, 0, 0, 10)
            };
            btnSelectFile.FlatAppearance.BorderSize = 0;
            btnSelectFile.Click += BtnSelectFile_Click;
            topFlow.Controls.Add(btnSelectFile);
            
            // Label archivo seleccionado
            lblTranslateFile = new Label
            {
                Text = "📄 Ningún archivo seleccionado",
                ForeColor = Color.FromArgb(180, 180, 180),
                AutoSize = true,
                Font = new Font("Segoe UI", 9),
                Margin = new Padding(0, 0, 0, 10)
            };
            topFlow.Controls.Add(lblTranslateFile);
            
            // Selector de motor de traducción
            var enginePanel = new FlowLayoutPanel
            {
                AutoSize = true,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = false,
                Margin = new Padding(0, 0, 0, 15)
            };
            
            var lblEngine = new Label
            {
                Text = "🔧 Motor de traducción:",
                ForeColor = Color.FromArgb(180, 180, 180),
                AutoSize = true,
                Font = new Font("Segoe UI", 9),
                Margin = new Padding(0, 5, 10, 0)
            };
            enginePanel.Controls.Add(lblEngine);
            
            cboTranslationEngine = new ComboBox
            {
                DropDownStyle = ComboBoxStyle.DropDownList,
                Width = 200,
                BackColor = Color.FromArgb(40, 40, 40),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 9)
            };
            cboTranslationEngine.Items.AddRange(new object[]
            {
                "🌐 Google Translate (Mejor calidad)",
                "🤖 DeepL (Alta calidad)",
                "🆓 LibreTranslate (Gratis, menor calidad)"
            });
            cboTranslationEngine.SelectedIndex = 0; // Google por defecto
            cboTranslationEngine.SelectedIndexChanged += (s, e) =>
            {
                currentTranslationEngine = (TranslationEngine)cboTranslationEngine.SelectedIndex;
                TranslateLog($"🔧 Motor cambiado a: {cboTranslationEngine.SelectedItem}");
            };
            enginePanel.Controls.Add(cboTranslationEngine);
            
            topFlow.Controls.Add(enginePanel);
            
            // Panel de botones de acción
            var buttonsFlow = new FlowLayoutPanel
            {
                AutoSize = true,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = false,
                Margin = new Padding(0)
            };
            
            btnStartTranslate = new Button
            {
                Text = "🚀 Iniciar Traducción",
                AutoSize = true,
                Height = 35,
                BackColor = Color.FromArgb(50, 150, 50),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 9, FontStyle.Bold),
                Cursor = Cursors.Hand,
                Enabled = false,
                Margin = new Padding(0, 0, 10, 0)
            };
            btnStartTranslate.FlatAppearance.BorderSize = 0;
            btnStartTranslate.Click += BtnStartTranslate_Click;
            buttonsFlow.Controls.Add(btnStartTranslate);
            
            btnCancelTranslate = new Button
            {
                Text = "⛔ Cancelar",
                AutoSize = true,
                Height = 35,
                BackColor = Color.FromArgb(180, 50, 50),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 9, FontStyle.Bold),
                Cursor = Cursors.Hand,
                Enabled = false,
                Margin = new Padding(0)
            };
            btnCancelTranslate.FlatAppearance.BorderSize = 0;
            btnCancelTranslate.Click += BtnCancelTranslate_Click;
            buttonsFlow.Controls.Add(btnCancelTranslate);
            
            topFlow.Controls.Add(buttonsFlow);
            topPanel.Controls.Add(topFlow);
            mainLayout.Controls.Add(topPanel, 0, 0);
            
            // === PANEL PROGRESO ===
            var progressPanel = new Panel
            {
                Dock = DockStyle.Fill,
                AutoSize = true,
                BackColor = Color.FromArgb(25, 25, 25),
                Padding = new Padding(15),
                Margin = new Padding(0, 0, 0, 15)
            };
            
            var progressFlow = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                AutoSize = true,
                FlowDirection = FlowDirection.TopDown,
                WrapContents = false,
                BackColor = Color.Transparent
            };
            
            lblTranslateProgress = new Label
            {
                Text = "⏳ Esperando...",
                ForeColor = Color.FromArgb(180, 180, 180),
                AutoSize = true,
                Font = new Font("Segoe UI", 9),
                Margin = new Padding(0, 0, 0, 8)
            };
            progressFlow.Controls.Add(lblTranslateProgress);
            
            progressTranslate = new ProgressBar
            {
                Width = 600,
                Height = 25,
                Style = ProgressBarStyle.Continuous,
                Margin = new Padding(0)
            };
            progressFlow.Controls.Add(progressTranslate);
            
            progressPanel.Controls.Add(progressFlow);
            mainLayout.Controls.Add(progressPanel, 0, 1);
            
            // === LOG DE TRADUCCIÓN ===
            var logPanel = new Panel
            {
                Dock = DockStyle.Fill,
                BackColor = Color.FromArgb(25, 25, 25),
                Padding = new Padding(15)
            };
            
            var logLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 1,
                RowCount = 2,
                BackColor = Color.Transparent
            };
            logLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize));
            logLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100f));
            
            var lblLogTitle = new Label
            {
                Text = "📋 LOG DE TRADUCCIÓN",
                Font = new Font("Segoe UI", 10, FontStyle.Bold),
                ForeColor = Color.FromArgb(100, 180, 255),
                AutoSize = true,
                Margin = new Padding(0, 0, 0, 10)
            };
            logLayout.Controls.Add(lblLogTitle, 0, 0);
            
            txtTranslateLog = new TextBox
            {
                Dock = DockStyle.Fill,
                Multiline = true,
                ReadOnly = true,
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.LightGray,
                Font = new Font("Consolas", 9),
                ScrollBars = ScrollBars.Vertical,
                WordWrap = true
            };
            logLayout.Controls.Add(txtTranslateLog, 0, 1);
            
            logPanel.Controls.Add(logLayout);
            mainLayout.Controls.Add(logPanel, 0, 2);
            
            parent.Controls.Add(mainLayout);
            
            // Tooltips
            var tips = GetToolTip();
            tips.SetToolTip(btnSelectFile, "Selecciona un archivo para traducir (TXT, EPUB, PDF, DOCX)");
            tips.SetToolTip(btnStartTranslate, "Inicia el proceso de traducción del archivo seleccionado");
            tips.SetToolTip(btnCancelTranslate, "Cancela la traducción en curso");
            tips.SetToolTip(txtTranslateLog, "Registro detallado del proceso de traducción");
        }
        
        // 🚀 CREAR PESTAÑA DE DASHBOARD AVANZADO
        private void CreateDashboardTab(TabPage parent)
        {
            try
            {
                Log("📊 Creando Dashboard de métricas avanzadas...");
                
                // Usar el DashboardControl ya creado
                if (_dashboardControl != null)
                {
                    parent.Controls.Add(_dashboardControl);
                    Log("  ✅ Dashboard Control integrado");
                }
                else
                {
                    // Fallback si no está inicializado
                    var fallbackLabel = new Label
                    {
                        Text = "📊 Dashboard\n\nSistema de métricas en tiempo real\n\nInicializando...",
                        Dock = DockStyle.Fill,
                        TextAlign = ContentAlignment.MiddleCenter,
                        Font = new Font("Segoe UI", 14),
                        ForeColor = Color.FromArgb(100, 180, 255),
                        BackColor = Color.FromArgb(18, 18, 18)
                    };
                    parent.Controls.Add(fallbackLabel);
                    Log("  ⚠️ Dashboard no inicializado - usando fallback");
                }
                
                Log("✅ Dashboard creado correctamente");
            }
            catch (Exception ex)
            {
                Log($"❌ Error creando Dashboard: {ex.Message}");
                
                var errorLabel = new Label
                {
                    Text = $"❌ Error Dashboard\n\n{ex.Message}",
                    Dock = DockStyle.Fill,
                    TextAlign = ContentAlignment.MiddleCenter,
                    Font = new Font("Segoe UI", 12),
                    ForeColor = Color.Red,
                    BackColor = Color.FromArgb(18, 18, 18)
                };
                parent.Controls.Add(errorLabel);
            }
        }
        
        // 🔌 CREAR PESTAÑA DE SISTEMA DE PLUGINS
        private void CreatePluginsTab(TabPage parent)
        {
            try
            {
                Log("🔌 Creando Sistema de Plugins...");
                
                var mainLayout = new TableLayoutPanel
                {
                    Dock = DockStyle.Fill,
                    ColumnCount = 1,
                    RowCount = 3,
                    BackColor = Color.FromArgb(18, 18, 18),
                    Padding = new Padding(20)
                };
                mainLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize)); // Header
                mainLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100f)); // Content
                mainLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize)); // Footer
                
                // Header
                var headerPanel = new Panel
                {
                    Dock = DockStyle.Fill,
                    AutoSize = true,
                    BackColor = Color.FromArgb(25, 25, 25),
                    Padding = new Padding(15),
                    Margin = new Padding(0, 0, 0, 15)
                };
                
                var titleLabel = new Label
                {
                    Text = "🔌 SISTEMA DE PLUGINS",
                    Font = new Font("Segoe UI", 16, FontStyle.Bold),
                    ForeColor = Color.FromArgb(100, 180, 255),
                    AutoSize = true
                };
                headerPanel.Controls.Add(titleLabel);
                
                // Content
                var contentPanel = new TableLayoutPanel
                {
                    Dock = DockStyle.Fill,
                    ColumnCount = 2,
                    RowCount = 1,
                    BackColor = Color.FromArgb(25, 25, 25),
                    Padding = new Padding(15)
                };
                contentPanel.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 50f));
                contentPanel.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 50f));
                
                // Panel de plugins cargados
                var loadedPanel = new GroupBox
                {
                    Text = "📦 Plugins Cargados",
                    Font = new Font("Segoe UI", 12, FontStyle.Bold),
                    ForeColor = Color.White,
                    Dock = DockStyle.Fill,
                    BackColor = Color.FromArgb(35, 35, 35),
                    Padding = new Padding(10)
                };
                
                var loadedList = new ListBox
                {
                    Dock = DockStyle.Fill,
                    BackColor = Color.FromArgb(45, 45, 45),
                    ForeColor = Color.LightGreen,
                    Font = new Font("Consolas", 9),
                    BorderStyle = BorderStyle.None
                };
                
                // Cargar plugins disponibles
                if (_pluginManager != null)
                {
                    var stats = _pluginManager.GetStatistics();
                    loadedList.Items.Add($"Total: {stats.TotalPlugins}");
                    loadedList.Items.Add($"Cargados: {stats.LoadedPlugins}");
                    loadedList.Items.Add($"Activos: {stats.ActivePlugins}");
                    
                    foreach (var plugin in _pluginManager.LoadedPlugins)
                    {
                        var metadata = plugin.Value.GetMetadata();
                        loadedList.Items.Add($"🔌 {metadata.Name} v{metadata.Version}");
                    }
                }
                else
                {
                    loadedList.Items.Add("❌ Plugin Manager no inicializado");
                }
                
                loadedPanel.Controls.Add(loadedList);
                
                // Panel de acciones
                var actionsPanel = new GroupBox
                {
                    Text = "⚙️ Acciones",
                    Font = new Font("Segoe UI", 12, FontStyle.Bold),
                    ForeColor = Color.White,
                    Dock = DockStyle.Fill,
                    BackColor = Color.FromArgb(35, 35, 35),
                    Padding = new Padding(10),
                    Margin = new Padding(15, 0, 0, 0)
                };
                
                var btnReloadPlugins = new Button
                {
                    Text = "🔄 Recargar Plugins",
                    Dock = DockStyle.Top,
                    Height = 40,
                    BackColor = Color.FromArgb(0, 122, 204),
                    ForeColor = Color.White,
                    FlatStyle = FlatStyle.Flat,
                    Font = new Font("Segoe UI", 10, FontStyle.Bold),
                    Margin = new Padding(0, 0, 0, 10)
                };
                btnReloadPlugins.Click += async (s, e) =>
                {
                    if (_pluginManager != null)
                    {
                        await _pluginManager.ReloadAllPluginsAsync();
                        SafeLog("🔄 Plugins recargados");
                    }
                };
                
                var btnInstallPlugin = new Button
                {
                    Text = "📦 Instalar Plugin",
                    Dock = DockStyle.Top,
                    Height = 40,
                    BackColor = Color.FromArgb(16, 185, 129),
                    ForeColor = Color.White,
                    FlatStyle = FlatStyle.Flat,
                    Font = new Font("Segoe UI", 10, FontStyle.Bold),
                    Margin = new Padding(0, 0, 0, 10)
                };
                btnInstallPlugin.Click += async (s, e) =>
                {
                    using (var ofd = new OpenFileDialog())
                    {
                        ofd.Filter = "Plugin Files (*.dll)|*.dll|All files (*.*)|*.*";
                        if (ofd.ShowDialog() == DialogResult.OK)
                        {
                            if (_pluginManager != null)
                            {
                                var success = await _pluginManager.InstallPluginAsync(ofd.FileName);
                                SafeLog(success ? "✅ Plugin instalado" : "❌ Error instalando plugin");
                            }
                        }
                    }
                };
                
                actionsPanel.Controls.AddRange(new Control[] { btnReloadPlugins, btnInstallPlugin });
                
                contentPanel.Controls.Add(loadedPanel, 0, 0);
                contentPanel.Controls.Add(actionsPanel, 1, 0);
                
                // Footer
                var footerPanel = new Panel
                {
                    Dock = DockStyle.Fill,
                    AutoSize = true,
                    BackColor = Color.FromArgb(25, 25, 25),
                    Padding = new Padding(15),
                    Margin = new Padding(0, 15, 0, 0)
                };
                
                var statusLabel = new Label
                {
                    Text = "🚀 Sistema de Plugins Extensible - SlskDown 2.0",
                    Font = new Font("Segoe UI", 10, FontStyle.Italic),
                    ForeColor = Color.FromArgb(150, 150, 150),
                    AutoSize = true
                };
                footerPanel.Controls.Add(statusLabel);
                
                mainLayout.Controls.Add(headerPanel, 0, 0);
                mainLayout.Controls.Add(contentPanel, 0, 1);
                mainLayout.Controls.Add(footerPanel, 0, 2);
                
                parent.Controls.Add(mainLayout);
                Log("✅ Sistema de Plugins creado correctamente");
            }
            catch (Exception ex)
            {
                Log($"❌ Error creando Plugins: {ex.Message}");
            }
        }
        
        // 🤖 CREAR PESTAÑA DE ASISTENTE IA
        private void CreateAIAssistantTab(TabPage parent)
        {
            try
            {
                Log("🤖 Creando Asistente IA con ChatGPT...");
                
                var mainLayout = new TableLayoutPanel
                {
                    Dock = DockStyle.Fill,
                    ColumnCount = 1,
                    RowCount = 3,
                    BackColor = Color.FromArgb(18, 18, 18),
                    Padding = new Padding(20)
                };
                mainLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize)); // Header
                mainLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100f)); // Chat
                mainLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize)); // Input
                
                // Header
                var headerPanel = new Panel
                {
                    Dock = DockStyle.Fill,
                    AutoSize = true,
                    BackColor = Color.FromArgb(25, 25, 25),
                    Padding = new Padding(15),
                    Margin = new Padding(0, 0, 0, 15)
                };
                
                var titleLabel = new Label
                {
                    Text = "🤖 ASISTENTE IA - CHATGPT",
                    Font = new Font("Segoe UI", 16, FontStyle.Bold),
                    ForeColor = Color.FromArgb(100, 180, 255),
                    AutoSize = true
                };
                headerPanel.Controls.Add(titleLabel);
                
                // Chat area
                var chatPanel = new Panel
                {
                    Dock = DockStyle.Fill,
                    BackColor = Color.FromArgb(25, 25, 25),
                    Padding = new Padding(15)
                };
                
                var chatBox = new RichTextBox
                {
                    Dock = DockStyle.Fill,
                    BackColor = Color.FromArgb(35, 35, 35),
                    ForeColor = Color.LightGreen,
                    Font = new Font("Segoe UI", 10),
                    ReadOnly = true,
                    Text = "🤖 Asistente IA SlskDown\n\nBienvenido al asistente inteligente. Puedo ayudarte con:\n\n• 🔍 Búsquedas de música\n• ⚙️ Configuración optimizada\n• 🎓 Recomendaciones personalizadas\n• 🐛 Solución de problemas\n• 📊 Análisis de métricas\n\nEscribe tu pregunta abajo...\n\n"
                };
                
                chatPanel.Controls.Add(chatBox);
                
                // Input area
                var inputPanel = new TableLayoutPanel
                {
                    Dock = DockStyle.Fill,
                    ColumnCount = 2,
                    RowCount = 2,
                    BackColor = Color.FromArgb(25, 25, 25),
                    Padding = new Padding(15),
                    Margin = new Padding(0, 15, 0, 0)
                };
                inputPanel.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 100f));
                inputPanel.ColumnStyles.Add(new ColumnStyle(SizeType.AutoSize));
                inputPanel.RowStyles.Add(new RowStyle(SizeType.AutoSize));
                inputPanel.RowStyles.Add(new RowStyle(SizeType.AutoSize));
                
                var txtInput = new TextBox
                {
                    Dock = DockStyle.Fill,
                    BackColor = Color.FromArgb(35, 35, 35),
                    ForeColor = Color.White,
                    Font = new Font("Segoe UI", 10),
                    Multiline = true,
                    Height = 60,
                    Text = "Escribe tu pregunta aquí..."
                };
                
                var btnSend = new Button
                {
                    Text = "📤 Enviar",
                    Width = 100,
                    Height = 40,
                    BackColor = Color.FromArgb(0, 122, 204),
                    ForeColor = Color.White,
                    FlatStyle = FlatStyle.Flat,
                    Font = new Font("Segoe UI", 10, FontStyle.Bold),
                    Margin = new Padding(10, 0, 0, 0)
                };
                
                var btnConfigure = new Button
                {
                    Text = "⚙️ Configurar API",
                    Width = 150,
                    Height = 35,
                    BackColor = Color.FromArgb(108, 117, 125),
                    ForeColor = Color.White,
                    FlatStyle = FlatStyle.Flat,
                    Font = new Font("Segoe UI", 9),
                    Margin = new Padding(0, 10, 0, 0)
                };
                
                btnConfigure.Click += (s, e) =>
                {
                    using (var inputDialog = new InputBox("Configurar ChatGPT API Key", "Ingresa tu API Key de OpenAI:"))
                    {
                        if (inputDialog.ShowDialog() == DialogResult.OK && !string.IsNullOrWhiteSpace(inputDialog.Value))
                        {
                            if (_chatGPTAssistant != null)
                            {
                                _chatGPTAssistant.ConfigureAPI(inputDialog.Value);
                                SafeLog("✅ API Key de ChatGPT configurada");
                                chatBox.AppendText($"\n🔑 API Key configurada correctamente\n\n");
                            }
                        }
                    }
                };
                
                btnSend.Click += async (s, e) =>
                {
                    var question = txtInput.Text.Trim();
                    if (string.IsNullOrWhiteSpace(question) || question == "Escribe tu pregunta aquí...")
                        return;
                    
                    chatBox.AppendText($"\n👤 Tú: {question}\n");
                    txtInput.Clear();
                    
                    if (_chatGPTAssistant?.IsEnabled == true)
                    {
                        try
                        {
                            btnSend.Enabled = false;
                            btnSend.Text = "⏳ Pensando...";
                            
                            var response = await _chatGPTAssistant.SendMessageAsync(question);
                            chatBox.AppendText($"\n🤖 Asistente: {response}\n\n");
                        }
                        catch (Exception ex)
                        {
                            chatBox.AppendText($"\n❌ Error: {ex.Message}\n\n");
                        }
                        finally
                        {
                            btnSend.Enabled = true;
                            btnSend.Text = "📤 Enviar";
                        }
                    }
                    else
                    {
                        chatBox.AppendText("\n❌ Asistente no disponible. Configura API Key primero.\n\n");
                    }
                };
                
                inputPanel.Controls.Add(txtInput, 0, 0);
                inputPanel.Controls.Add(btnSend, 1, 0);
                inputPanel.Controls.Add(btnConfigure, 1, 1);
                
                mainLayout.Controls.Add(headerPanel, 0, 0);
                mainLayout.Controls.Add(chatPanel, 0, 1);
                mainLayout.Controls.Add(inputPanel, 0, 2);
                
                parent.Controls.Add(mainLayout);
                Log("✅ Asistente IA creado correctamente");
            }
            catch (Exception ex)
            {
                Log($"❌ Error creando Asistente IA: {ex.Message}");
            }
        }
        }
        
        private void BtnSelectFile_Click(object sender, EventArgs e)
        {
            using (var openFileDialog = new OpenFileDialog())
            {
                openFileDialog.Title = "Seleccionar archivo para traducir";
                openFileDialog.Filter = "Todos los soportados|*.txt;*.epub;*.pdf;*.docx;*.doc;*.mobi|" +
                                       "Archivos de texto|*.txt|" +
                                       "EPUB|*.epub|" +
                                       "PDF|*.pdf|" +
                                       "Word|*.docx;*.doc|" +
                                       "Mobi|*.mobi|" +
                                       "Todos los archivos|*.*";
                openFileDialog.FilterIndex = 1;
                
                if (openFileDialog.ShowDialog() == DialogResult.OK)
                {
                    selectedFileToTranslate = openFileDialog.FileName;
                    lblTranslateFile.Text = $"📄 {Path.GetFileName(selectedFileToTranslate)}";
                    lblTranslateFile.ForeColor = Color.FromArgb(100, 255, 100);
                    btnStartTranslate.Enabled = true;
                    
                    TranslateLog($"✅ Archivo seleccionado: {selectedFileToTranslate}");
                    // MEJORA #27: Usar caché de FileInfo
                    TranslateLog($"📊 Tamaño: {GetCachedFileInfo(selectedFileToTranslate).Length / 1024.0:F2} KB");
                }
            }
        }
        
        private void BtnStartTranslate_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrEmpty(selectedFileToTranslate) || !System.IO.File.Exists(selectedFileToTranslate))
            {
                DarkMessageBox.Show("Por favor, selecciona un archivo válido primero.", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                return;
            }
            
            btnStartTranslate.Enabled = false;
            btnSelectFile.Enabled = false;
            btnCancelTranslate.Enabled = true;
            
            translateCancellationTokenSource = new CancellationTokenSource();
            
            TranslateLog("🚀 Iniciando proceso de traducción...");
            TranslateLog($"🌐 Servidor: {CurrentLibreTranslateServer}");
            lblTranslateProgress.Text = "⏳ Preparando...";
            
            // Iniciar traducción en background
            Task.Run(() => TranslateFileAsync(selectedFileToTranslate, translateCancellationTokenSource.Token));
        }
        
        private void BtnCancelTranslate_Click(object sender, EventArgs e)
        {
            if (translateCancellationTokenSource != null && !translateCancellationTokenSource.IsCancellationRequested)
            {
                TranslateLog("⛔ Cancelando traducción...");
                translateCancellationTokenSource.Cancel();
            }
        }
        
        private void TranslateLog(string message)
        {
            // MEJORA #28: Usar UtcNow (más rápido que Now)
            var timestamp = DateTime.UtcNow.ToString("HH:mm:ss");
            var logMessage = $"[{timestamp}] {message}";
            
            SafeInvoke(() =>
            {
                if (txtTranslateLog != null)
                {
                    txtTranslateLog.AppendText(logMessage + Environment.NewLine);
                }
            });
        }
        
        private async Task TranslateFileAsync(string filePath, CancellationToken cancellationToken)
        {
            try
            {
                TranslateLog($"📖 Analizando archivo: {Path.GetFileName(filePath)}");
                
                // Paso 1: Extraer texto del archivo
                SafeInvoke(() => lblTranslateProgress.Text = "📄 Extrayendo texto...");
                string originalText = ExtractTextFromFile(filePath);
                
                if (string.IsNullOrWhiteSpace(originalText))
                {
                    TranslateLog("❌ No se pudo extraer texto del archivo");
                    throw new Exception("El archivo no contiene texto extraíble o el formato no es compatible");
                }
                
                int totalChars = originalText.Length;
                TranslateLog($"✅ Texto extraído: {totalChars:N0} caracteres");
                
                // Paso 2: Detectar idioma automáticamente
                SafeInvoke(() => lblTranslateProgress.Text = "🔍 Detectando idioma...");
                // MEJORA #31: Usar indexador de rango
                int detectLength = Math.Min(1000, originalText.Length);
                string detectedLang = await DetectLanguageAsync(originalText[..detectLength], cancellationToken);
                
                // Si no se pudo detectar el idioma con confianza, cancelar
                if (detectedLang == null)
                {
                    TranslateLog("❌ No se pudo detectar el idioma con suficiente confianza");
                    SafeInvoke(() =>
                    {
                        lblTranslateProgress.Text = "❌ Idioma no detectado";
                        btnStartTranslate.Enabled = true;
                        btnSelectFile.Enabled = true;
                        btnCancelTranslate.Enabled = false;
                    });
                    
                    DarkMessageBox.Show(
                        "No se pudo detectar el idioma del archivo con suficiente confianza.\n\n" +
                        "El archivo podría:\n" +
                        "• Estar en un idioma no soportado\n" +
                        "• Contener texto mezclado en varios idiomas\n" +
                        "• No tener suficiente texto para análisis\n\n" +
                        "No se realizará la traducción.",
                        "Idioma No Detectado",
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Warning);
                    return;
                }
                
                // Si ya está en español, no traducir
                if (detectedLang == "es")
                {
                    TranslateLog("ℹ️ El texto ya está en español, no se requiere traducción");
                    SafeInvoke(() =>
                    {
                        lblTranslateProgress.Text = "✅ Ya está en español";
                        btnStartTranslate.Enabled = true;
                        btnSelectFile.Enabled = true;
                        btnCancelTranslate.Enabled = false;
                    });
                    
                    DarkMessageBox.Show(
                        "El archivo ya está en español y no requiere traducción.",
                        "Idioma Detectado",
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Information);
                    return;
                }
                
                string langName = GetLanguageName(detectedLang);
                TranslateLog($"🌐 Idioma detectado: {langName} ({detectedLang.ToUpper()}) → Español (ES)");
                
                // Paso 3: Dividir en bloques
                var chunks = SplitTextIntoChunks(originalText, TRANSLATION_CHUNK_SIZE);
                int totalChunks = chunks.Count;
                TranslateLog($"📦 Dividido en {totalChunks} bloques de ~{TRANSLATION_CHUNK_SIZE} caracteres");
                
                SafeInvoke(() =>
                {
                    progressTranslate.Maximum = totalChunks;
                    progressTranslate.Value = 0;
                });
                
                // Paso 4: Traducir bloque por bloque
                var translatedChunks = new List<string>();
                int successCount = 0;
                int failCount = 0;
                
                for (int i = 0; i < totalChunks; i++)
                {
                    cancellationToken.ThrowIfCancellationRequested();
                    
                    int chunkNum = i + 1;
                    TranslateLog($"🔄 Traduciendo bloque {chunkNum}/{totalChunks}...");
                    SafeInvoke(() => lblTranslateProgress.Text = $"🌐 Traduciendo {chunkNum}/{totalChunks}...");
                    
                    try
                    {
                        string translatedChunk = await TranslateTextAsync(chunks[i], detectedLang, "es", cancellationToken);
                        translatedChunks.Add(translatedChunk);
                        successCount++;
                        
                        SafeInvoke(() => progressTranslate.Value = chunkNum);
                        
                        // Delay para no saturar la API pública
                        if (i < totalChunks - 1)
                        {
                            await Task.Delay(1500, cancellationToken).ConfigureAwait(false); // MEJORA #37
                        }
                    }
                    catch (Exception ex)
                    {
                        TranslateLog($"⚠️ Error en bloque {chunkNum}: {ex.Message}");
                        translatedChunks.Add($"[ERROR: No se pudo traducir este bloque]\n\n{chunks[i]}");
                        failCount++;
                    }
                }
                
                // Paso 5: Unir bloques traducidos
                string translatedText = string.Join("\n\n", translatedChunks);
                TranslateLog($"✅ Traducción completada: {successCount} bloques exitosos, {failCount} fallidos");
                
                // Paso 6: Aplicar reglas de escritura del español
                SafeInvoke(() => lblTranslateProgress.Text = "✍️ Aplicando reglas de español...");
                TranslateLog("✍️ Aplicando correcciones ortográficas y gramaticales...");
                translatedText = ApplySpanishWritingRules(translatedText);
                TranslateLog("✅ Correcciones aplicadas");
                
                // Paso 7: Guardar archivo traducido
                SafeInvoke(() => lblTranslateProgress.Text = "💾 Guardando archivo...");
                string outputPath = GetTranslatedFilePath(filePath);
                System.IO.File.WriteAllText(outputPath, translatedText, System.Text.Encoding.UTF8);
                
                TranslateLog($"💾 Archivo guardado: {Path.GetFileName(outputPath)}");
                // MEJORA #27: Usar caché de FileInfo
                TranslateLog($"📊 Tamaño final: {GetCachedFileInfo(outputPath).Length / 1024.0:F2} KB");
                
                SafeInvoke(() =>
                {
                    lblTranslateProgress.Text = "✅ Traducción completada";
                    progressTranslate.Value = progressTranslate.Maximum;
                    btnStartTranslate.Enabled = true;
                    btnSelectFile.Enabled = true;
                    btnCancelTranslate.Enabled = false;
                });
                
                // Preguntar si abrir el archivo
                SafeInvoke(() =>
                {
                    var result = DarkMessageBox.Show(
                        $"Traducción completada exitosamente.\n\n" +
                        $"Archivo: {Path.GetFileName(outputPath)}\n" +
                        $"Bloques: {successCount}/{totalChunks}\n\n" +
                        $"¿Deseas abrir el archivo traducido?",
                        "Traducción Completada",
                        MessageBoxButtons.YesNo,
                        MessageBoxIcon.Information);
                    
                    if (result == DialogResult.Yes)
                    {
                        try
                        {
                            Process.Start(new ProcessStartInfo
                            {
                                FileName = outputPath,
                                UseShellExecute = true
                            });
                        }
                        catch (Exception ex)
                        {
                            TranslateLog($"⚠️ No se pudo abrir el archivo: {ex.Message}");
                        }
                    }
                });
            }
            catch (OperationCanceledException)
            {
                TranslateLog("❌ Traducción cancelada por el usuario");
                SafeInvoke(() =>
                {
                    lblTranslateProgress.Text = "❌ Cancelado";
                    progressTranslate.Value = 0;
                    btnStartTranslate.Enabled = true;
                    btnSelectFile.Enabled = true;
                    btnCancelTranslate.Enabled = false;
                });
            }
            catch (Exception ex)
            {
                TranslateLog($"❌ Error: {ex.Message}");
                SafeInvoke(() =>
                {
                    lblTranslateProgress.Text = "❌ Error";
                    progressTranslate.Value = 0;
                    btnStartTranslate.Enabled = true;
                    btnSelectFile.Enabled = true;
                    btnCancelTranslate.Enabled = false;
                });
            }
        }
        
        private async Task<string> TranslateTextAsync(string text, string sourceLang, string targetLang, CancellationToken cancellationToken)
        {
            // Limpiar el texto para evitar errores
            string cleanText = RegexControlChars.Replace(text, "");
            
            if (string.IsNullOrWhiteSpace(cleanText))
            {
                return text; // Devolver original si queda vacío
            }
            
            // Usar el motor seleccionado
            string translatedText = currentTranslationEngine switch
            {
                TranslationEngine.GoogleTranslate => await TranslateWithGoogleAsync(cleanText, sourceLang, targetLang, cancellationToken),
                TranslationEngine.DeepL => await TranslateWithDeepLAsync(cleanText, sourceLang, targetLang, cancellationToken),
                TranslationEngine.LibreTranslate => await TranslateWithLibreTranslateAsync(cleanText, sourceLang, targetLang, cancellationToken),
                _ => await TranslateWithGoogleAsync(cleanText, sourceLang, targetLang, cancellationToken)
            };
            
            // Aplicar corrector de estilo español si el idioma destino es español
            if (targetLang.Equals("es", StringComparison.OrdinalIgnoreCase))
            {
                translatedText = ApplySpanishWritingRules(translatedText);
            }
            
            return translatedText;
        }
        
        private async Task<string> TranslateWithGoogleAsync(string text, string sourceLang, string targetLang, CancellationToken cancellationToken)
        {
            try
            {
                // API no oficial de Google Translate (via translate.googleapis.com)
                string url = $"https://translate.googleapis.com/translate_a/single?client=gtx&sl={sourceLang}&tl={targetLang}&dt=t&q={Uri.EscapeDataString(text)}";
                
                var response = await translateHttpClient.GetAsync(url, cancellationToken);
                var responseJson = await response.Content.ReadAsStringAsync();
                
                if (!response.IsSuccessStatusCode)
                {
                    throw new Exception($"Error HTTP {(int)response.StatusCode}");
                }
                
                // Parsear respuesta de Google (formato: [[["texto traducido","texto original",null,null,3]],null,"en"])
                var result = System.Text.Json.JsonDocument.Parse(responseJson);
                var translations = result.RootElement[0];
                
                var translatedText = new System.Text.StringBuilder();
                foreach (var item in translations.EnumerateArray())
                {
                    if (item.GetArrayLength() > 0 && item[0].ValueKind == System.Text.Json.JsonValueKind.String)
                    {
                        translatedText.Append(item[0].GetString());
                    }
                }
                
                return translatedText.ToString();
            }
            catch (Exception ex)
            {
                throw new Exception($"Error en Google Translate: {ex.Message}", ex);
            }
        }
        
        private async Task<string> TranslateWithDeepLAsync(string text, string sourceLang, string targetLang, CancellationToken cancellationToken)
        {
            try
            {
                // API gratuita de DeepL (sin autenticación, limitada)
                // Nota: Para uso intensivo, se recomienda obtener una API key gratuita en https://www.deepl.com/pro-api
                string url = "https://api-free.deepl.com/v2/translate";
                
                var requestData = new Dictionary<string, string>
                {
                    { "text", text },
                    { "source_lang", sourceLang.ToUpper() },
                    { "target_lang", targetLang.ToUpper() }
                };
                
                var content = new FormUrlEncodedContent(requestData);
                var response = await translateHttpClient.PostAsync(url, content, cancellationToken);
                var responseJson = await response.Content.ReadAsStringAsync();
                
                if (!response.IsSuccessStatusCode)
                {
                    // Si falla DeepL (requiere API key), fallback a Google
                    TranslateLog("⚠️ DeepL requiere API key, usando Google Translate...");
                    return await TranslateWithGoogleAsync(text, sourceLang, targetLang, cancellationToken);
                }
                
                var result = System.Text.Json.JsonDocument.Parse(responseJson);
                if (result.RootElement.TryGetProperty("translations", out var translations) &&
                    translations.GetArrayLength() > 0 &&
                    translations[0].TryGetProperty("text", out var translatedText))
                {
                    return translatedText.GetString() ?? text;
                }
                
                throw new Exception("Respuesta de DeepL inválida");
            }
            catch (Exception ex)
            {
                // Fallback a Google si DeepL falla
                TranslateLog($"⚠️ Error en DeepL: {ex.Message}, usando Google Translate...");
                return await TranslateWithGoogleAsync(text, sourceLang, targetLang, cancellationToken);
            }
        }
        
        private async Task<string> TranslateWithLibreTranslateAsync(string text, string sourceLang, string targetLang, CancellationToken cancellationToken)
        {
            try
            {
                var requestData = new
                {
                    q = text,
                    source = sourceLang,
                    target = targetLang,
                    format = "text"
                };
                
                var json = System.Text.Json.JsonSerializer.Serialize(requestData);
                var content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");
                
                var response = await translateHttpClient.PostAsync($"{CurrentLibreTranslateServer}/translate", content, cancellationToken);
                
                var responseJson = await response.Content.ReadAsStringAsync();
                
                if (!response.IsSuccessStatusCode)
                {
                    TranslateLog($"⚠️ Error HTTP {(int)response.StatusCode}: {responseJson}");
                    
                    // Intentar con el siguiente servidor
                    if (TryNextLibreTranslateServer())
                    {
                        TranslateLog($"⚠️ Probando siguiente servidor: {CurrentLibreTranslateServer}");
                        return await TranslateWithLibreTranslateAsync(text, sourceLang, targetLang, cancellationToken);
                    }
                    throw new Exception($"Error HTTP {(int)response.StatusCode}");
                }
                var result = System.Text.Json.JsonDocument.Parse(responseJson);
                
                if (result.RootElement.TryGetProperty("translatedText", out var translatedText))
                {
                    return translatedText.GetString() ?? text;
                }
                
                throw new Exception("Respuesta de API inválida");
            }
            catch (Exception ex)
            {
                // Intentar con el siguiente servidor
                if (TryNextLibreTranslateServer())
                {
                    TranslateLog($"⚠️ Error con servidor, probando siguiente: {CurrentLibreTranslateServer}");
                    return await TranslateWithLibreTranslateAsync(text, sourceLang, targetLang, cancellationToken);
                }
                throw new Exception($"Error en traducción: {ex.Message}", ex);
            }
        }
        
        private static bool TryNextLibreTranslateServer()
        {
            int nextIndex = (currentServerIndex + 1) % LIBRETRANSLATE_SERVERS.Length;
            if (nextIndex == 0) return false; // Ya probamos todos
            currentServerIndex = nextIndex;
            return true;
        }
        
        private async Task<string> DetectLanguageAsync(string text, CancellationToken cancellationToken)
        {
            const double MIN_CONFIDENCE = 0.5; // Mínimo 50% de confianza
            
            try
            {
                // Limpiar el texto para evitar errores 400
                // Eliminar caracteres de control y normalizar espacios
                string cleanText = RegexControlChars.Replace(text, "");
                cleanText = RegexWhitespaceNormalize.Replace(cleanText, " ");
                cleanText = cleanText.Trim();
                
                // MEJORA #31: Limitar a 500 caracteres para detección usando indexador de rango
                if (cleanText.Length > 500)
                    cleanText = cleanText[..500];
                
                if (string.IsNullOrWhiteSpace(cleanText))
                {
                    TranslateLog("⚠️ Texto vacío después de limpieza");
                    return null;
                }
                
                // Usar Google Translate para detección si es el motor seleccionado
                if (currentTranslationEngine == TranslationEngine.GoogleTranslate || currentTranslationEngine == TranslationEngine.DeepL)
                {
                    // Google Translate tiene mejor detección de idioma
                    string url = $"https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl=en&dt=t&q={Uri.EscapeDataString(cleanText)}";
                    var response = await translateHttpClient.GetAsync(url, cancellationToken);
                    var responseJson = await response.Content.ReadAsStringAsync();
                    
                    if (response.IsSuccessStatusCode)
                    {
                        var result = System.Text.Json.JsonDocument.Parse(responseJson);
                        // El idioma detectado está en la posición [2] de la respuesta
                        if (result.RootElement.GetArrayLength() > 2 && result.RootElement[2].ValueKind == System.Text.Json.JsonValueKind.String)
                        {
                            string detectedLang = result.RootElement[2].GetString() ?? "";
                            TranslateLog($"🎯 Idioma detectado (Google): {detectedLang}");
                            return detectedLang;
                        }
                    }
                }
                
                // Fallback a LibreTranslate
                var requestData = new
                {
                    q = cleanText
                };
                
                var json = System.Text.Json.JsonSerializer.Serialize(requestData);
                var content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");
                
                var response2 = await translateHttpClient.PostAsync($"{CurrentLibreTranslateServer}/detect", content, cancellationToken);
                
                // Leer respuesta antes de verificar status para mejor debugging
                var responseJson2 = await response2.Content.ReadAsStringAsync();
                
                if (!response2.IsSuccessStatusCode)
                {
                    TranslateLog($"⚠️ Error HTTP {(int)response2.StatusCode}: {responseJson2}");
                    
                    // Intentar con el siguiente servidor
                    if (TryNextLibreTranslateServer())
                    {
                        TranslateLog($"⚠️ Probando siguiente servidor: {CurrentLibreTranslateServer}");
                        return await DetectLanguageAsync(text, cancellationToken);
                    }
                    return null;
                }
                
                var result2 = System.Text.Json.JsonDocument.Parse(responseJson2);
                
                // La API devuelve un array de detecciones con confianza
                // Tomamos el primer resultado (mayor confianza)
                if (result2.RootElement.ValueKind == System.Text.Json.JsonValueKind.Array)
                {
                    var firstDetection = result2.RootElement[0];
                    if (firstDetection.TryGetProperty("language", out var language) &&
                        firstDetection.TryGetProperty("confidence", out var confidence))
                    {
                        string detectedLang = language.GetString() ?? "";
                        double conf = confidence.GetDouble();
                        
                        TranslateLog($"🎯 Confianza de detección: {conf:P0}");
                        
                        // Verificar confianza mínima
                        if (conf < MIN_CONFIDENCE)
                        {
                            TranslateLog($"⚠️ Confianza insuficiente ({conf:P0} < {MIN_CONFIDENCE:P0})");
                            return null; // No se puede detectar con confianza
                        }
                        
                        if (string.IsNullOrEmpty(detectedLang))
                        {
                            TranslateLog("⚠️ Idioma detectado vacío");
                            return null;
                        }
                        
                        return detectedLang;
                    }
                }
                
                // Si no se puede detectar
                TranslateLog("⚠️ No se pudo detectar el idioma");
                return null;
            }
            catch (Exception ex)
            {
                // Intentar con el siguiente servidor
                if (TryNextLibreTranslateServer())
                {
                    TranslateLog($"⚠️ Error con servidor, probando siguiente: {CurrentLibreTranslateServer}");
                    return await DetectLanguageAsync(text, cancellationToken);
                }
                TranslateLog($"⚠️ Error detectando idioma: {ex.Message}");
                return null; // No traducir si hay error
            }
        }
        
        private string GetLanguageName(string langCode)
        {
            return langCode switch
            {
                "ar" => "Árabe",
                "eu" => "Vasco",
                "bg" => "Búlgaro",
                "ca" => "Catalán",
                "zh" => "Chino",
                "cs" => "Checo",
                "nl" => "Holandés",
                "en" => "Inglés",
                "eo" => "Esperanto",
                "fr" => "Francés",
                "de" => "Alemán",
                "hu" => "Húngaro",
                "ga" => "Irlandés",
                "it" => "Italiano",
                "ja" => "Japonés",
                "kab" => "Cabilio",
                "ko" => "Coreano",
                "pt" => "Portugués",
                "ru" => "Ruso",
                "gd" => "Gaélico escocés",
                "es" => "Español",
                "uk" => "Ucraniano",
                _ => $"Desconocido ({langCode})"
            };
        }
        
        private string ApplySpanishWritingRules(string text)
        {
            if (string.IsNullOrWhiteSpace(text))
                return text;
            
            // MEJORA #10: Caché de formateo - Si ya procesamos este texto, devolver resultado cacheado
            string cacheKey = text.Length > 100 ? text.Substring(0, 100) : text;
            if (formattingCache.TryGetValue(cacheKey, out string cachedResult))
            {
                currentFormattingStats.CacheHits++;
                return cachedResult;
            }
            
            // MEJORA #2: Proteger URLs y emails antes de cualquier procesamiento
            var protectedUrls = new List<string>();
            var protectedEmails = new List<string>();
            
            text = RegexUrlProtection.Replace(text, m => {
                protectedUrls.Add(m.Value);
                currentFormattingStats.UrlsProtected++;
                return $"__URL_{protectedUrls.Count - 1}__";
            });
            
            text = RegexEmailProtection.Replace(text, m => {
                protectedEmails.Add(m.Value);
                return $"__EMAIL_{protectedEmails.Count - 1}__";
            });
            
            // PASO 0: Normalizar saltos de línea primero
            text = text.Replace("\r\n", "\n");
            
            // 1. SEPARACIÓN DE PÁRRAFOS (HACER PRIMERO, antes de modificar espacios)
            // En español, los párrafos se separan con una línea en blanco (doble salto)
            // Detectar finales de párrafo y asegurar línea en blanco entre ellos
            
            // A) Separar después de punto/exclamación/interrogación + nueva línea con mayúscula
            text = RegexParagraphAfterPunctuation.Replace(text, "$1\n\n$2");
            
            // B) Separar entre diálogos consecutivos (cambio de personaje) - MÁS AGRESIVO
            // Cualquier diálogo seguido de otro diálogo = nuevo párrafo
            text = System.Text.RegularExpressions.Regex.Replace(text, 
                @"(—[^\n]+)\n(—)", 
                "$1\n\n$2");
            
            // C) Separar diálogo de narrativa siguiente - MÁS AGRESIVO
            // Cualquier diálogo seguido de texto normal = nuevo párrafo
            text = System.Text.RegularExpressions.Regex.Replace(text, 
                @"(—[^\n]+)\n([A-ZÁÉÍÓÚÑ¿¡][^—\n])", 
                "$1\n\n$2");
            
            // D) Separar narrativa de diálogo siguiente - MÁS AGRESIVO
            // Cualquier texto seguido de diálogo = nuevo párrafo
            text = System.Text.RegularExpressions.Regex.Replace(text, 
                @"([^\n])\n(—)", 
                "$1\n\n$2");
            
            // E) Separar después de comillas inglesas (antes de convertirlas)
            text = System.Text.RegularExpressions.Regex.Replace(text, 
                @"""([^""]+)""[.,]?\n([A-ZÁÉÍÓÚÑ¿¡])", 
                "\"$1\"\n\n$2");
            
            // F) Separar entre comillas inglesas consecutivas
            text = System.Text.RegularExpressions.Regex.Replace(text, 
                @"""([^""]+)""\n""", 
                "\"$1\"\n\n\"");
            
            // Reducir múltiples líneas vacías a máximo 1 (doble salto = 1 línea vacía)
            text = RegexMultipleNewlines.Replace(text, "\n\n");
            
            // 2. SIGNOS DE INTERROGACIÓN Y EXCLAMACIÓN
            // Agregar signos de apertura si faltan
            var questionMarks = System.Text.RegularExpressions.Regex.Matches(text, @"(?<![¿])(\s|^)([A-ZÁÉÍÓÚÑ][^.!?]*\?)").Count;
            text = System.Text.RegularExpressions.Regex.Replace(text, @"(?<![¿])(\s|^)([A-ZÁÉÍÓÚÑ][^.!?]*\?)", "$1¿$2");
            var exclamationMarks = System.Text.RegularExpressions.Regex.Matches(text, @"(?<![¡])(\s|^)([A-ZÁÉÍÓÚÑ][^.!?]*!)").Count;
            text = System.Text.RegularExpressions.Regex.Replace(text, @"(?<![¡])(\s|^)([A-ZÁÉÍÓÚÑ][^.!?]*!)", "$1¡$2");
            currentFormattingStats.PunctuationFixed += questionMarks + exclamationMarks;
            
            // 3. ESPACIOS ANTES DE PUNTUACIÓN
            // Eliminar espacios antes de: . , ; : ! ? ) ] }
            text = RegexSpaceBeforePunctuation.Replace(text, "$1");
            
            // Agregar espacio después de puntuación si falta (excepto al final de línea)
            // IMPORTANTE: No agregar espacio si hay salto de línea después
            text = RegexSpaceAfterPunctuation.Replace(text, "$1 $2");
            
            // 4. ESPACIOS DESPUÉS DE PUNTUACIÓN DE APERTURA
            // Eliminar espacios después de: ( [ {
            text = System.Text.RegularExpressions.Regex.Replace(text, @"([\(\[\{])\s+", "$1");
            
            // 4. COMILLAS Y DIÁLOGOS (CONVERSIÓN AGRESIVA DE ESTILO INGLÉS A ESPAÑOL)
            // Los traductores automáticos generan diálogos con comillas inglesas
            // En español literario se usan rayas largas (—) para diálogos
            
            // ESTRATEGIA: Convertir TODAS las comillas que parezcan diálogos
            // Un diálogo típicamente:
            // - Empieza con mayúscula o signos de apertura (¿¡)
            // - Contiene texto conversacional
            // - Puede tener puntuación al final
            
            // PASO 1: Diálogos con verbos de habla ANTES de las comillas (patrón común)
            // "Juan dijo: "Hola"" → "Juan dijo: —Hola"
            var speechVerbsBefore = @"(dijo|preguntó|respondió|contestó|gritó|susurró|murmuró|exclamó|continuó|añadió|insistió|afirmó|negó|comentó|explicó|repuso|replicó|ordenó|sugirió)";
            var dialogsBefore = System.Text.RegularExpressions.Regex.Matches(text, speechVerbsBefore + @"[:\s]+""([^""]+?)""", System.Text.RegularExpressions.RegexOptions.IgnoreCase).Count;
            text = System.Text.RegularExpressions.Regex.Replace(text, 
                speechVerbsBefore + @"[:\s]+""([^""]+?)""", 
                "$1: —$2", 
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            currentFormattingStats.DialogsConverted += dialogsBefore;
            
            // PASO 2: Diálogos con verbos de habla DESPUÉS de las comillas (MUY COMÚN en traducciones)
            // ""Hola", dijo Juan" → "—Hola —dijo Juan"
            var speechVerbsAfter = @"(he|she|I|they|we|you|said|asked|replied|answered|shouted|whispered|muttered|murmured|exclaimed|continued|added|insisted|" +
                                  @"dijo|preguntó|respondió|contestó|gritó|susurró|murmuró|exclamó|continuó|añadió|insistió|afirmó|negó|comentó|explicó|repuso|replicó|ordenó|sugirió)";
            
            text = System.Text.RegularExpressions.Regex.Replace(text, 
                @"""([^""]+?)""[,.]?\s+" + speechVerbsAfter, 
                "—$1 —$2", 
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // PASO 3: Diálogos al inicio de línea (SIEMPRE son diálogos)
            // "Texto..." al inicio de línea → —Texto...
            text = System.Text.RegularExpressions.Regex.Replace(text, 
                @"(^|\n)\s*""([^""]+?)""", 
                "$1—$2", 
                System.Text.RegularExpressions.RegexOptions.Multiline);
            
            // PASO 4: Diálogos con signos de interrogación/exclamación (SIEMPRE son diálogos)
            // Debe ir ANTES del paso de mayúsculas para capturar "¿Hola?" primero
            text = System.Text.RegularExpressions.Regex.Replace(text, 
                @"""([^""]*[?!¿¡][^""]*)""", 
                "—$1");
            
            // PASO 5: Diálogos con mayúscula inicial Y más de 5 caracteres (MUY PROBABLE que sea diálogo)
            // "Hola amigo" → —Hola amigo (pero "OK" → «OK» porque es muy corto)
            text = System.Text.RegularExpressions.Regex.Replace(text, 
                @"""([A-ZÁÉÍÓÚÑ¿¡][^""]{5,})""", 
                "—$1");
            
            // PASO 6: Diálogos que contienen verbos conjugados (muy probable que sea diálogo hablado)
            // Buscar patrones como "verbo + pronombre" o "pronombre + verbo"
            text = System.Text.RegularExpressions.Regex.Replace(text, 
                @"""([^""]*\b(soy|eres|es|somos|son|estoy|estás|está|estamos|están|tengo|tienes|tiene|tenemos|tienen|voy|vas|va|vamos|van|puedo|puedes|puede|podemos|pueden|quiero|quieres|quiere|queremos|quieren|debo|debes|debe|debemos|deben)\b[^""]*)""", 
                "—$1", 
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // PASO 7: Diálogos con pronombres personales de primera/segunda persona (casi siempre diálogo)
            // "Yo creo que..." o "Tú sabes que..." → —Yo creo que... / —Tú sabes que...
            text = System.Text.RegularExpressions.Regex.Replace(text, 
                @"""(\s*(Yo|Tú|Nosotros|Nosotras|Vosotros|Vosotras|Usted|Ustedes)\s+[^""]{3,})""", 
                "—$1", 
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // PASO 8: Diálogos con imperativos (órdenes, casi siempre diálogo)
            // "Ven aquí" o "Escucha esto" → —Ven aquí / —Escucha esto
            text = System.Text.RegularExpressions.Regex.Replace(text, 
                @"""([A-ZÁÉÍÓÚÑ][a-záéíóúñ]{2,}(me|te|lo|la|le|nos|os|los|las|les)?\s+[^""]{3,})""", 
                m => {
                    var content = m.Groups[1].Value;
                    // Verificar si parece un imperativo (verbo al inicio)
                    if (System.Text.RegularExpressions.Regex.IsMatch(content, @"^(Ven|Vamos|Mira|Escucha|Dime|Dame|Hazlo|Espera|Corre|Sigue|Para|Cállate|Déjame|Ayúdame|Piensa|Créeme|Entiende|Comprende|Acepta|Toma|Sal|Entra|Abre|Cierra|Levanta|Baja|Sube)\b", System.Text.RegularExpressions.RegexOptions.IgnoreCase))
                        return "—" + content;
                    return m.Value;
                });
            
            // PASO 9: Diálogos con vocativos (nombres propios al inicio, muy común en diálogos)
            // "Juan, necesito tu ayuda" → —Juan, necesito tu ayuda
            text = System.Text.RegularExpressions.Regex.Replace(text, 
                @"""([A-ZÁÉÍÓÚÑ][a-záéíóúñ]+,\s+[^""]{5,})""", 
                "—$1");
            
            // PASO 10: Diálogos con interjecciones (casi siempre diálogo)
            // "Oh, no puedo creerlo" → —Oh, no puedo creerlo
            text = System.Text.RegularExpressions.Regex.Replace(text, 
                @"""((Oh|Ah|Eh|Uf|Ay|Vaya|Caramba|Dios mío|Por Dios|Cielos|Diablos|Maldición|Genial|Perfecto|Excelente|Increíble|Imposible)[,\s]+[^""]{3,})""", 
                "—$1", 
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // PASO 11: Diálogos con palabras típicas de conversación
            // "Bueno, creo que..." o "Mira, te diré..." → —Bueno, creo que... / —Mira, te diré...
            text = System.Text.RegularExpressions.Regex.Replace(text, 
                @"""((Bueno|Bien|Vale|Okay|Mira|Oye|Escucha|Sabes|Claro|Sí|No|Tal vez|Quizás|Puede ser|Por supuesto|De acuerdo|Exacto|Correcto)[,\s]+[^""]{3,})""", 
                "—$1", 
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // PASO 12: Convertir comillas restantes (citas, énfasis, títulos, etc.) a comillas españolas « »
            // Solo si NO son diálogos obvios
            text = System.Text.RegularExpressions.Regex.Replace(text, @"""([^""]+)""", "«$1»");
            
            // 5. GUIONES Y RAYAS (DIÁLOGOS CON GUIONES)
            // Normalizar guiones en diálogos a raya larga (—)
            
            // Diálogos al inicio de línea: "- Hola" → "—Hola"
            text = System.Text.RegularExpressions.Regex.Replace(text, @"^-\s*", "—", System.Text.RegularExpressions.RegexOptions.Multiline);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\n-\s*", "\n—");
            
            // Acotaciones del narrador en medio del diálogo: "- dijo él -" → "—dijo él—"
            text = System.Text.RegularExpressions.Regex.Replace(text, @"—([^—\n]+)-\s", "—$1— ");
            
            // Doble guion (--) a raya larga
            text = text.Replace("--", "—");
            
            // Guiones cortos sueltos que parecen diálogos
            text = System.Text.RegularExpressions.Regex.Replace(text, @"(\n\s*)-([A-ZÁÉÍÓÚÑ¿¡])", "$1—$2");
            
            // Normalizar espacios después de raya de diálogo (no debe haber espacio)
            text = System.Text.RegularExpressions.Regex.Replace(text, @"—\s+", "—");
            
            // 6. PUNTOS SUSPENSIVOS
            // Normalizar ... a … (carácter único)
            text = text.Replace("...", "…");
            
            // Eliminar espacios antes de puntos suspensivos
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\s+…", "…");
            
            // 7. MAYÚSCULAS DESPUÉS DE PUNTO
            // Asegurar mayúscula después de punto seguido
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\.\s+([a-záéíóúñ])", 
                m => ". " + char.ToUpper(m.Groups[1].Value[0]));
            
            // 8. NÚMEROS Y UNIDADES
            // Espacio entre número y unidad (excepto %, °, €)
            text = System.Text.RegularExpressions.Regex.Replace(text, @"(\d+)(km|m|cm|mm|kg|g|mg|l|ml)", "$1 $2");
            
            // Sin espacio para %, °, €
            text = System.Text.RegularExpressions.Regex.Replace(text, @"(\d+)\s+([%°€])", "$1$2");
            
            // 9. ABREVIATURAS COMUNES
            // Asegurar punto en abreviaturas
            var abbreviations = new Dictionary<string, string>
            {
                { @"\bDr\b", "Dr." },
                { @"\bSr\b", "Sr." },
                { @"\bSra\b", "Sra." },
                { @"\bSrta\b", "Srta." },
                { @"\bpág\b", "pág." },
                { @"\bpágs\b", "págs." },
                { @"\betc\b", "etc." },
                { @"\bvol\b", "vol." },
                { @"\bcap\b", "cap." }
            };
            
            foreach (var abbr in abbreviations)
            {
                text = System.Text.RegularExpressions.Regex.Replace(text, abbr.Key, abbr.Value, 
                    System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            }
            
            // 10. ESPACIOS MÚLTIPLES
            // Reducir múltiples espacios a uno solo
            text = System.Text.RegularExpressions.Regex.Replace(text, @" {2,}", " ");
            
            // 11. ESPACIOS AL INICIO/FIN DE LÍNEA
            // Eliminar espacios al inicio y final de cada línea
            var lines = text.Split('\n');
            for (int i = 0; i < lines.Length; i++)
            {
                lines[i] = lines[i].TrimEnd();
            }
            text = string.Join("\n", lines);
            
            // 12. CORRECCIONES ESPECÍFICAS DE TRADUCCIÓN AUTOMÁTICA
            // Corregir traducciones literales comunes y errores típicos
            
            // A) ANGLICISMOS Y CALCOS DEL INGLÉS
            int anglicismsCount = 0;
            anglicismsCount += System.Text.RegularExpressions.Regex.Matches(text, @"\bOK\b", System.Text.RegularExpressions.RegexOptions.IgnoreCase).Count;
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bOK\b", "De acuerdo", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            anglicismsCount += System.Text.RegularExpressions.Regex.Matches(text, @"\bok\b", System.Text.RegularExpressions.RegexOptions.IgnoreCase).Count;
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bok\b", "de acuerdo", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            anglicismsCount += System.Text.RegularExpressions.Regex.Matches(text, @"\bEmail\b", System.Text.RegularExpressions.RegexOptions.IgnoreCase).Count;
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bEmail\b", "Correo electrónico", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            anglicismsCount += System.Text.RegularExpressions.Regex.Matches(text, @"\bemail\b", System.Text.RegularExpressions.RegexOptions.IgnoreCase).Count;
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bemail\b", "correo electrónico", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            currentFormattingStats.AnglicismsFixed += anglicismsCount;
            
            // B) EXPRESIONES MAL TRADUCIDAS (literales del inglés)
            int badTranslations = 0;
            badTranslations += CountOccurrences(text, "por supuesto que");
            text = text.Replace("por supuesto que", "por supuesto");
            badTranslations += CountOccurrences(text, "en el caso de que");
            text = text.Replace("en el caso de que", "en caso de que");
            badTranslations += CountOccurrences(text, "a pesar del hecho de que");
            text = text.Replace("a pesar del hecho de que", "a pesar de que");
            badTranslations += CountOccurrences(text, "debido al hecho de que");
            text = text.Replace("debido al hecho de que", "debido a que");
            badTranslations += CountOccurrences(text, "hacer sentido");
            text = text.Replace("hacer sentido", "tener sentido");
            badTranslations += CountOccurrences(text, "hace sentido");
            text = text.Replace("hace sentido", "tiene sentido");
            badTranslations += CountOccurrences(text, "no hace sentido");
            text = text.Replace("no hace sentido", "no tiene sentido");
            currentFormattingStats.AnglicismsFixed += badTranslations;
            
            // C) REDUNDANCIAS Y MULETILLAS
            int redundancies = 0;
            redundancies += CountOccurrences(text, "pero sin embargo");
            text = text.Replace("pero sin embargo", "sin embargo");
            redundancies += CountOccurrences(text, "y además también");
            text = text.Replace("y además también", "y además");
            redundancies += CountOccurrences(text, "volver a repetir");
            text = text.Replace("volver a repetir", "repetir");
            redundancies += CountOccurrences(text, "subir arriba");
            text = text.Replace("subir arriba", "subir");
            redundancies += CountOccurrences(text, "bajar abajo");
            text = text.Replace("bajar abajo", "bajar");
            redundancies += CountOccurrences(text, "salir afuera");
            text = text.Replace("salir afuera", "salir");
            redundancies += CountOccurrences(text, "entrar adentro");
            text = text.Replace("entrar adentro", "entrar");
            currentFormattingStats.RedundanciesFixed += redundancies;
            
            // D) PREPOSICIONES INCORRECTAS
            text = text.Replace("de acuerdo a", "de acuerdo con");
            text = text.Replace("en base a", "con base en");
            text = text.Replace("a nivel de", "en el nivel de");
            
            // E) VERBOS MAL CONJUGADOS (traducciones literales)
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\brealizar una pregunta\b", "hacer una pregunta", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\brealizar un llamado\b", "hacer un llamado", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\btomar una decisión\b", "tomar una decisión", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // F) PRONOMBRES Y ARTÍCULOS MAL COLOCADOS
            // "el mismo" → "este" (cuando es redundante)
            text = System.Text.RegularExpressions.Regex.Replace(text, @"el mismo ([a-záéíóúñ]+)", "este $1", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"la misma ([a-záéíóúñ]+)", "esta $1", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // G) CONECTORES Y TRANSICIONES MEJORADAS
            text = text.Replace("Y entonces", "Entonces");
            text = text.Replace("y entonces", "entonces");
            text = text.Replace("Pero entonces", "Entonces");
            text = text.Replace("pero entonces", "entonces");
            
            // H) CORRECCIONES DE ESTILO NARRATIVO
            // "dijo que él" → "dijo que"
            text = System.Text.RegularExpressions.Regex.Replace(text, @"(dijo|preguntó|respondió|exclamó|susurró|gritó|murmuró|añadió|continuó|insistió) que (él|ella)\b", 
                "$1 que", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // I) TIEMPOS VERBALES MAL TRADUCIDOS
            // "habría sido" en contextos donde debería ser "hubiera sido"
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bhabría sido mejor si\b", "hubiera sido mejor si", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // J) ADVERBIOS REDUNDANTES O MAL COLOCADOS
            text = text.Replace("muy extremadamente", "extremadamente");
            text = text.Replace("bastante muy", "muy");
            text = text.Replace("realmente muy", "muy");
            
            // K) EXPRESIONES COLOQUIALES MAL TRADUCIDAS
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bpor cierto\b", "por cierto", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\ba propósito\b", "a propósito", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // L) GERUNDIOS MAL USADOS (anglicismo muy común)
            // En español, el gerundio NO se usa para acciones simultáneas como en inglés
            // "Caminando por la calle, vio..." → mejor "Mientras caminaba por la calle, vio..."
            // Pero esto es complejo de detectar automáticamente, así que solo corregimos casos obvios
            text = System.Text.RegularExpressions.Regex.Replace(text, @"^([A-Z][a-záéíóúñ]+ando|[A-Z][a-záéíóúñ]+iendo)\s", 
                "Mientras $1 ", System.Text.RegularExpressions.RegexOptions.Multiline);
            
            // M) POSESIVOS INNECESARIOS (calco del inglés)
            // "su cabeza" → "la cabeza" cuando es obvio
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\b(movió|giró|levantó|bajó|inclinó)\s+su\s+(cabeza|mano|brazo|pierna)\b", 
                "$1 la $2", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\b(abrió|cerró)\s+sus\s+(ojos)\b", 
                "$1 los $2", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // N) ORDEN DE PALABRAS (calco del inglés)
            // "rápidamente corrió" → "corrió rápidamente"
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\b(rápidamente|lentamente|cuidadosamente|silenciosamente)\s+([a-záéíóúñ]+ó|[a-záéíóúñ]+ió)\b", 
                "$2 $1", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // O) ARTÍCULOS INNECESARIOS O FALTANTES
            // "la mayoría de personas" → "la mayoría de las personas"
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bla mayoría de\s+([a-záéíóúñ]+s)\b", 
                "la mayoría de las $1", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // P) FALSOS AMIGOS COMUNES (solo en contextos obvios de traducción)
            // "actualmente" solo cuando claramente significa "actually" (en realidad)
            // NO reemplazar cuando significa "en la actualidad" (nowadays)
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bactualmente,\s+(no|sí|es|fue|esto|eso)", "en realidad, $1", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bactualmente\s+(no|sí|es|fue|esto|eso)", "en realidad $1", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\beventualmente\b", "finalmente", System.Text.RegularExpressions.RegexOptions.IgnoreCase); // "eventually" ≠ "eventualmente"
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bconstipado\b", "resfriado", System.Text.RegularExpressions.RegexOptions.IgnoreCase); // "constipated" ≠ "constipado"
            
            // Q) CONSTRUCCIONES PASIVAS (preferir voz activa en español)
            // "fue hecho por Juan" → "Juan hizo" (solo cuando el agente es una palabra)
            // NO aplicar si el agente es una frase larga o si cambia el sentido
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bfue\s+(hecho|dicho|visto|escrito|creado|construido|realizado)\s+por\s+([A-ZÁÉÍÓÚÑ][a-záéíóúñ]+)\b", 
                "$2 $1", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // R) PLEONASMOS Y REDUNDANCIAS ADICIONALES
            text = text.Replace("ver con los ojos", "ver");
            text = text.Replace("oír con los oídos", "oír");
            text = text.Replace("tocar con las manos", "tocar");
            text = text.Replace("historia pasada", "historia");
            text = text.Replace("planes futuros", "planes");
            text = text.Replace("completamente lleno", "lleno");
            text = text.Replace("totalmente vacío", "vacío");
            text = text.Replace("subir para arriba", "subir");
            text = text.Replace("bajar para abajo", "bajar");
            text = text.Replace("salir para afuera", "salir");
            text = text.Replace("entrar para adentro", "entrar");
            text = text.Replace("volver a regresar", "regresar");
            text = text.Replace("volver de nuevo", "volver");
            text = text.Replace("persona humana", "persona");
            text = text.Replace("cadáver muerto", "cadáver");
            text = text.Replace("hemorragia de sangre", "hemorragia");
            text = text.Replace("lapso de tiempo", "lapso");
            text = text.Replace("período de tiempo", "período");
            text = text.Replace("erario público", "erario");
            text = text.Replace("túnel subterráneo", "túnel");
            text = text.Replace("divisas extranjeras", "divisas");
            text = text.Replace("reaparece de nuevo", "reaparece");
            text = text.Replace("vuelve a repetir", "repite");
            
            // S) MULETILLAS Y PALABRAS DE RELLENO (comunes en traducciones)
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\b(muy|realmente|bastante|absolutamente)\s+(único|imposible|perfecto|completo|total)\b", 
                "$2", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            // Eliminar muletillas pero mantener espaciado correcto
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bliteralmente\s+", "", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bbásicamente\s+", "", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bprácticamente\s+", "casi ", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bvirtualmente\s+", "casi ", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // T) CONECTORES Y TRANSICIONES REDUNDANTES
            text = text.Replace("y luego entonces", "y luego");
            text = text.Replace("pero no obstante", "pero");
            text = text.Replace("sin embargo no obstante", "sin embargo");
            text = text.Replace("aunque sin embargo", "aunque");
            text = text.Replace("porque debido a que", "porque");
            text = text.Replace("ya que debido a que", "ya que");
            
            // U) VERBOS DÉBILES Y CONSTRUCCIONES VERBOSAS (mejorar estilo)
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bhace una mirada\b", "mira", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bda una mirada\b", "mira", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bhace un movimiento\b", "se mueve", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bda un paso\b", "camina", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bhace un gesto\b", "gesticula", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bda un grito\b", "grita", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bhace un sonido\b", "suena", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bda comienzo\b", "comienza", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bpone fin\b", "termina", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bhace uso de\b", "usa", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\btoma en consideración\b", "considera", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\blleva a cabo\b", "realiza", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // V) ADJETIVOS Y ADVERBIOS REDUNDANTES CON VERBOS
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bsusurró suavemente\b", "susurró", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bgritó fuertemente\b", "gritó", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bmiró fijamente\b", "miró", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bcorrió rápidamente\b", "corrió", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bcaminó lentamente\b", "caminó", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bsonrió felizmente\b", "sonrió", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\blloró tristemente\b", "lloró", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // W) EXPRESIONES TEMPORALES MAL TRADUCIDAS
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\ben este momento en el tiempo\b", "en este momento", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\ben el presente momento\b", "ahora", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\ben un futuro próximo\b", "pronto", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\ben un pasado reciente\b", "recientemente", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = text.Replace("durante el transcurso de", "durante");
            text = text.Replace("en el transcurso de", "durante");
            text = text.Replace("a lo largo del tiempo", "con el tiempo");
            
            // X) LOCUCIONES PREPOSITIVAS REDUNDANTES
            text = text.Replace("con el fin de", "para");
            text = text.Replace("con el objetivo de", "para");
            text = text.Replace("con el propósito de", "para");
            text = text.Replace("con la intención de", "para");
            text = text.Replace("con la finalidad de", "para");
            text = text.Replace("a fin de que", "para que");
            text = text.Replace("con motivo de", "por");
            text = text.Replace("por causa de", "por");
            text = text.Replace("por razón de", "por");
            text = text.Replace("en relación con", "sobre");
            text = text.Replace("en lo que respecta a", "sobre");
            text = text.Replace("en lo que se refiere a", "sobre");
            text = text.Replace("en lo concerniente a", "sobre");
            
            // Y) COMPARACIONES Y METÁFORAS MAL TRADUCIDAS
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\btan\s+([a-záéíóúñ]+)\s+como\s+un\s+\1\b", "muy $1", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = text.Replace("frío como el hielo", "helado");
            text = text.Replace("caliente como el fuego", "ardiente");
            text = text.Replace("rápido como el rayo", "rapidísimo");
            text = text.Replace("lento como una tortuga", "lentísimo");
            text = text.Replace("fuerte como un toro", "fortísimo");
            text = text.Replace("débil como un gatito", "debilísimo");
            
            // Z) CLICHÉS Y EXPRESIONES GASTADAS (mejorar estilo literario)
            text = text.Replace("en el fondo de su corazón", "en su interior");
            text = text.Replace("en lo más profundo de su ser", "en su interior");
            text = text.Replace("con todas sus fuerzas", "con fuerza");
            text = text.Replace("con todo su corazón", "sinceramente");
            text = text.Replace("de todo corazón", "sinceramente");
            text = text.Replace("a decir verdad", "en realidad");
            text = text.Replace("para ser honesto", "en realidad");
            text = text.Replace("si te soy sincero", "en realidad");
            
            // AA) ERRORES DE CONCORDANCIA COMUNES
            // "habían muchas personas" → "había muchas personas" (verbo haber impersonal)
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bhabían\s+(muchos|muchas|varios|varias|algunos|algunas|pocos|pocas)\b", 
                "había $1", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bhabían\s+(\d+)\b", 
                "había $1", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // "hubieron problemas" → "hubo problemas"
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bhubieron\s+([a-záéíóúñ]+s)\b", 
                "hubo $1", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // BB) DEQUEÍSMO Y QUEÍSMO
            // "pienso de que" → "pienso que"
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\b(pienso|creo|opino|considero|supongo|imagino|digo|afirmo|niego)\s+de\s+que\b", 
                "$1 que", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // "estoy seguro que" → "estoy seguro de que"
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\b(seguro|consciente|convencido|cierto)\s+que\b", 
                "$1 de que", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // CC) LAÍSMO, LEÍSMO Y LOÍSMO (errores de pronombres)
            // "la dije" → "le dije" (complemento indirecto)
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bla\s+(dije|dijo|dice|dirá|diría|preguntó|pregunta|preguntará|respondió|responde|responderá)\b", 
                "le $1", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\blas\s+(dije|dijo|dice|dirá|diría|preguntó|pregunta|preguntará|respondió|responde|responderá)\b", 
                "les $1", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // DD) USO INCORRECTO DE "A POR"
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bvoy\s+a\s+por\b", "voy por", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bva\s+a\s+por\b", "va por", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bvamos\s+a\s+por\b", "vamos por", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bvan\s+a\s+por\b", "van por", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // EE) ERRORES CON "SINO" Y "SI NO"
            // "si no que" → "sino que"
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bsi\s+no\s+que\b", "sino que", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bno\s+([a-záéíóúñ]+),\s+si\s+no\s+([a-záéíóúñ]+)\b", 
                "no $1, sino $2", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // FF) ERRORES CON "PORQUE", "POR QUÉ", "PORQUÉ"
            // "por que" (separado sin tilde) → "porque" o "por qué" según contexto
            // Solo corregimos casos obvios
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bpor\s+que\s+(no|sí|es|fue|será|era)\b", 
                "porque $1", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // GG) MAYÚSCULAS DESPUÉS DE DOS PUNTOS (solo en diálogos)
            // Solo en diálogos después de raya: "—Escucha: esto es importante"
            text = System.Text.RegularExpressions.Regex.Replace(text, @"—([^:\n]+):\s+([a-záéíóúñ])", 
                m => "—" + m.Groups[1].Value + ": " + char.ToUpper(m.Groups[2].Value[0]));
            
            // HH) PUNTUACIÓN CON COMILLAS Y PARÉNTESIS
            // Punto siempre fuera de comillas (norma española)
            text = System.Text.RegularExpressions.Regex.Replace(text, @"([.!?])»", "»$1");
            text = System.Text.RegularExpressions.Regex.Replace(text, @"([.!?])'", "'$1");
            
            // II) ESPACIOS CON PARÉNTESIS Y CORCHETES
            // Eliminar espacios después de apertura y antes de cierre
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\(\s+", "(");
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\s+\)", ")");
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\[\s+", "[");
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\s+\]", "]");
            
            // JJ) ERRORES CON TILDES EN MONOSÍLABOS
            // "mas" (pero) vs "más" (cantidad)
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bmas\s+(de|que|o|y)\b", "más $1", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\b(\d+)\s+mas\b", "$1 más", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // "solo" (solamente) vs "sólo" (aunque RAE acepta ambas, preferimos sin tilde)
            // No hacemos cambios aquí por ser ambiguo
            
            // KK) EXTRANJERISMOS INNECESARIOS
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bfeedback\b", "retroalimentación", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bmeeting\b", "reunión", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bdeadline\b", "plazo", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\btarget\b", "objetivo", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bgoal\b", "meta", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bteam\b", "equipo", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bleader\b", "líder", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bchallenge\b", "desafío", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bworkshop\b", "taller", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bbrainstorming\b", "lluvia de ideas", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // 13. CORRECCIONES ESPECÍFICAS PARA DIÁLOGOS Y NARRATIVA
            
            // Verbos de habla comunes después de diálogo
            // "—Hola —dijo" → "—Hola —dijo"
            text = System.Text.RegularExpressions.Regex.Replace(text, @"—([^—\n]+)—\s*(dijo|preguntó|respondió|exclamó|susurró|gritó|murmuró|añadió|continuó|insistió)", 
                "—$1 —$2", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // Puntuación antes de cierre de diálogo
            // "—Hola. —dijo" → "—Hola —dijo." (la puntuación va después del verbo)
            text = System.Text.RegularExpressions.Regex.Replace(text, @"—([^—\n]+)([.!?])\s*—(dijo|preguntó|respondió|exclamó|susurró|gritó|murmuró|añadió|continuó|insistió)", 
                "—$1 —$3$2", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // Comillas dentro de diálogos (usar comillas simples)
            text = System.Text.RegularExpressions.Regex.Replace(text, @"—([^—]*?)«([^»]+)»([^—]*?)—", 
                m => $"—{m.Groups[1].Value}'{m.Groups[2].Value}'{m.Groups[3].Value}—");
            
            // 14. MAYÚSCULAS DESPUÉS DE SIGNOS DE CIERRE
            // Después de ! y ? también debe ir mayúscula
            text = System.Text.RegularExpressions.Regex.Replace(text, @"([!?])\s+([a-záéíóúñ])", 
                m => m.Groups[1].Value + " " + char.ToUpper(m.Groups[2].Value[0]));
            
            // 15. ESPACIADO EN DIÁLOGOS CONSECUTIVOS
            // Asegurar línea vacía entre diálogos cuando hay narrativa entre ellos
            // o cuando claramente cambia de personaje (después de acotación del narrador)
            text = System.Text.RegularExpressions.Regex.Replace(text, 
                @"(—[^\n]+—[^\n]+\.)\n(—)", 
                "$1\n\n$2");
            
            // 16. CORRECCIONES DE ESTILO LITERARIO
            // Evitar repetición de "que" (queísmo)
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bque\s+que\b", "que", 
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // Corregir "el cual/la cual" innecesarios
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bel cual\b", "que", 
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\bla cual\b", "que", 
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            
            // 18. NÚMEROS EN NARRATIVA
            // Números del 1-10 en letras en narrativa (excepto en diálogos)
            var numberWords = new Dictionary<string, string>
            {
                { @"\b1\b", "uno" },
                { @"\b2\b", "dos" },
                { @"\b3\b", "tres" },
                { @"\b4\b", "cuatro" },
                { @"\b5\b", "cinco" },
                { @"\b6\b", "seis" },
                { @"\b7\b", "siete" },
                { @"\b8\b", "ocho" },
                { @"\b9\b", "nueve" },
                { @"\b10\b", "diez" }
            };
            
            // Solo aplicar en párrafos narrativos (no en diálogos ni listas)
            var paragraphs = text.Split(new[] { "\n\n" }, StringSplitOptions.None);
            for (int i = 0; i < paragraphs.Length; i++)
            {
                if (!paragraphs[i].TrimStart().StartsWith("—") && 
                    !paragraphs[i].TrimStart().StartsWith("•") &&
                    !paragraphs[i].TrimStart().StartsWith("-") &&
                    !System.Text.RegularExpressions.Regex.IsMatch(paragraphs[i], @"^\d+\."))
                {
                    foreach (var num in numberWords)
                    {
                        paragraphs[i] = System.Text.RegularExpressions.Regex.Replace(paragraphs[i], num.Key, num.Value);
                    }
                }
            }
            text = string.Join("\n\n", paragraphs);
            
            // LIMPIEZA FINAL: Eliminar espacios múltiples que puedan haber quedado
            text = System.Text.RegularExpressions.Regex.Replace(text, @" {2,}", " ");
            
            // Limpiar espacios al inicio de líneas
            text = System.Text.RegularExpressions.Regex.Replace(text, @"^[ \t]+", "", System.Text.RegularExpressions.RegexOptions.Multiline);
            
            // Asegurar que no hay más de una línea vacía consecutiva
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\n{3,}", "\n\n");
            
            // MEJORA #2: Restaurar URLs y emails protegidos
            for (int i = 0; i < protectedUrls.Count; i++)
            {
                text = text.Replace($"__URL_{i}__", protectedUrls[i]);
            }
            for (int i = 0; i < protectedEmails.Count; i++)
            {
                text = text.Replace($"__EMAIL_{i}__", protectedEmails[i]);
            }
            
            // MEJORA #10: Guardar en caché
            if (formattingCache.Count >= MAX_FORMATTING_CACHE_SIZE)
            {
                // Limpiar 20% del caché cuando se llena
                var toRemove = formattingCache.Keys.Take(MAX_FORMATTING_CACHE_SIZE / 5).ToList();
                foreach (var key in toRemove)
                {
                    formattingCache.Remove(key);
                }
            }
            formattingCache[cacheKey] = text;
            
            return text;
        }
        
        // MEJORA #9: Método auxiliar para contar ocurrencias de texto
        private int CountOccurrences(string text, string pattern)
        {
            if (string.IsNullOrEmpty(text) || string.IsNullOrEmpty(pattern))
                return 0;
            
            int count = 0;
            int index = 0;
            while ((index = text.IndexOf(pattern, index, StringComparison.OrdinalIgnoreCase)) != -1)
            {
                count++;
                index += pattern.Length;
            }
            return count;
        }
        
        private List<string> SplitTextIntoChunks(string text, int chunkSize)
        {
            var chunks = new List<string>();
            
            // Dividir por párrafos primero
            var paragraphs = text.Split(new[] { "\n\n", "\r\n\r\n" }, StringSplitOptions.RemoveEmptyEntries);
            
            var currentChunk = new System.Text.StringBuilder();
            
            foreach (var paragraph in paragraphs)
            {
                // Si el párrafo solo es muy grande, dividirlo por oraciones
                if (paragraph.Length > chunkSize)
                {
                    if (currentChunk.Length > 0)
                    {
                        chunks.Add(currentChunk.ToString());
                        currentChunk.Clear();
                    }
                    
                    var sentences = paragraph.Split(new[] { ". ", ".\n", "! ", "?\n" }, StringSplitOptions.RemoveEmptyEntries);
                    foreach (var sentence in sentences)
                    {
                        if (currentChunk.Length + sentence.Length + 2 > chunkSize && currentChunk.Length > 0)
                        {
                            chunks.Add(currentChunk.ToString());
                            currentChunk.Clear();
                        }
                        currentChunk.Append(sentence).Append(". ");
                    }
                }
                else
                {
                    // Si agregar este párrafo excede el tamaño, guardar el chunk actual
                    if (currentChunk.Length + paragraph.Length + 2 > chunkSize && currentChunk.Length > 0)
                    {
                        chunks.Add(currentChunk.ToString());
                        currentChunk.Clear();
                    }
                    
                    currentChunk.Append(paragraph).Append("\n\n");
                }
            }
            
            // Agregar el último chunk si tiene contenido
            if (currentChunk.Length > 0)
            {
                chunks.Add(currentChunk.ToString());
            }
            
            return chunks;
        }
        
        private string GetTranslatedFilePath(string originalPath)
        {
            string directory = Path.GetDirectoryName(originalPath) ?? "";
            string fileNameWithoutExt = Path.GetFileNameWithoutExtension(originalPath);
            
            // Siempre guardar como TXT independientemente del formato original
            return Path.Combine(directory, $"{fileNameWithoutExt}_ES.txt");
        }
        
        // OPTIMIZACIÓN: Helper para obtener StringBuilder del pool thread-local
        private static System.Text.StringBuilder GetStringBuilder()
        {
            var sb = _cachedStringBuilder;
            if (sb == null)
            {
                _cachedStringBuilder = sb = new System.Text.StringBuilder(256);
            }
            sb.Clear();
            return sb;
        }
        
        // MEJORA #27: Helper para obtener FileInfo con caché
        private FileInfo GetCachedFileInfo(string filePath)
        {
            lock (fileInfoCacheLock)
            {
                // Verificar si está en caché y no ha expirado
                if (fileInfoCache.TryGetValue(filePath, out var cached))
                {
                    if ((DateTime.UtcNow - cached.CachedAt).TotalSeconds < FILE_INFO_CACHE_TTL_SECONDS)
                    {
                        return cached.Info;
                    }
                    // Expirado, remover
                    fileInfoCache.Remove(filePath);
                }
                
                // No está en caché o expiró, crear nuevo
                var fileInfo = new FileInfo(filePath);
                
                // Agregar al caché si no está lleno
                if (fileInfoCache.Count < FILE_INFO_CACHE_MAX_SIZE)
                {
                    fileInfoCache[filePath] = (fileInfo, DateTime.UtcNow);
                }
                else
                {
                    // Caché lleno, limpiar entradas expiradas
                    var expiredKeys = fileInfoCache
                        .Where(kvp => (DateTime.UtcNow - kvp.Value.CachedAt).TotalSeconds >= FILE_INFO_CACHE_TTL_SECONDS)
                        .Select(kvp => kvp.Key)
                        .ToList();
                    
                    foreach (var key in expiredKeys)
                    {
                        fileInfoCache.Remove(key);
                    }
                    
                    // Intentar agregar de nuevo
                    if (fileInfoCache.Count < FILE_INFO_CACHE_MAX_SIZE)
                    {
                        fileInfoCache[filePath] = (fileInfo, DateTime.UtcNow);
                    }
                }
                
                return fileInfo;
            }
        }
        
        // Método de logging mejorado con niveles y categorías
        private void LogEx(LogLevel level, LogCategory category, string message)
        {
            var sb = GetStringBuilder();
            
            // Timestamp
            sb.Append('[');
            // MEJORA #28: Usar UtcNow (más rápido que Now)
            sb.Append(DateTime.UtcNow.ToString("HH:mm:ss"));
            sb.Append("] ");
            
            // Estado de conexión
            bool isConnected = client != null && 
                (client.State.HasFlag(SoulseekClientStates.Connected) || 
                 client.State.HasFlag(SoulseekClientStates.LoggedIn));
            sb.Append(isConnected ? "[✓] " : "[✗] ");
            
            // Nivel con icono y color
            string levelIcon = level switch
            {
                LogLevel.DEBUG => "🔍",
                LogLevel.INFO => "ℹ️",
                LogLevel.WARN => "⚠️",
                LogLevel.ERROR => "❌",
                LogLevel.SUCCESS => "✅",
                _ => "•"
            };
            
            sb.Append(levelIcon);
            sb.Append(' ');
            sb.Append(level.ToString().PadRight(7));
            sb.Append(" | ");
            
            // Categoría
            sb.Append(category.ToString().PadRight(10));
            sb.Append(" | ");
            
            // Mensaje
            sb.Append(message);
            
            var logMessage = sb.ToString();
            
            // Guardar mensajes tempranos si txtLog aún no existe
            if (txtLog == null)
            {
                earlyLogMessages.Add(logMessage);
                return;
            }
            
            // Usar buffer lock-free (ultra-rápido, sin locks!)
            if (logBuffer != null)
            {
                if (!logBuffer.TryWrite(logMessage))
                {
                    ProcessLogMessage(logMessage);
                }
                return;
            }
            
            ProcessLogMessage(logMessage);
        }
        
        // Método Log original (mantener compatibilidad)
        private void Log(string message)
        {
            // Detectar nivel y categoría del mensaje legacy
            LogLevel level = LogLevel.INFO;
            LogCategory category = LogCategory.GENERAL;
            
            // Detectar nivel por emojis/palabras clave
            if (message.Contains("❌") || message.Contains("Error") || message.Contains("error"))
                level = LogLevel.ERROR;
            else if (message.Contains("⚠️") || message.Contains("Warning") || message.Contains("Advertencia"))
                level = LogLevel.WARN;
            else if (message.Contains("✅") || message.Contains("Éxito") || message.Contains("completado"))
                level = LogLevel.SUCCESS;
            else if (message.Contains("🔍") || message.Contains("Debug"))
                level = LogLevel.DEBUG;
            
            // Detectar categoría por palabras clave
            if (message.Contains("conex") || message.Contains("Conex") || message.Contains("reconex"))
                category = LogCategory.CONEXION;
            else if (message.Contains("descarga") || message.Contains("Descarga") || message.Contains("download"))
                category = LogCategory.DESCARGA;
            else if (message.Contains("búsqueda") || message.Contains("Búsqueda") || message.Contains("search"))
                category = LogCategory.BUSQUEDA;
            else if (message.Contains("purga") || message.Contains("Purga") || message.Contains("purge"))
                category = LogCategory.PURGA;
            else if (message.Contains("stealth") || message.Contains("Stealth") || message.Contains("🕵"))
                category = LogCategory.STEALTH;
            else if (message.Contains("compartir") || message.Contains("Compartir") || message.Contains("share") || message.Contains("upload"))
                category = LogCategory.COMPARTIR;
            else if (message.Contains("sistema") || message.Contains("Sistema") || message.Contains("config"))
                category = LogCategory.SISTEMA;
            
            LogEx(level, category, message);
        }
        
        /// <summary>
        /// MEJORA NICOTINE+: Muestra estadísticas de todos los componentes
        /// </summary>
        private async void ShowComponentStats()
        {
            try
            {
                Log("📊 === ESTADÍSTICAS DE COMPONENTES ===");
                
                // SearchCacheManager (caché de búsquedas)
                if (_searchCacheManager != null)
                {
                    var stats = await _searchCacheManager.GetStatsAsync();
                    Log($"🗄️ SearchCacheManager (Caché de Búsquedas):");
                    Log($"   Entradas: {stats.TotalEntries}");
                    Log($"   Tamaño: {stats.SizeMB:F2} MB / {stats.MaxSizeMB:F2} MB ({stats.UsagePercentage:F1}%)");
                    Log($"   Hit Rate: {stats.HitRate:P2} ({stats.TotalHits} hits / {stats.TotalMisses} misses)");
                    Log($"   Sets: {stats.TotalSets} | Evictions: {stats.TotalEvictions}");
                }
                
                // UserQueueManager
                if (_userQueueManager != null)
                {
                    Log($"👥 UserQueueManager:");
                    Log($"   Usuarios: {_userQueueManager.TotalUsers}");
                    Log($"   Descargas en cola: {_userQueueManager.TotalQueuedDownloads}");
                    Log($"   Descargas activas: {_userQueueManager.TotalActiveDownloads}");
                    Log($"   Límite por usuario: {_userQueueManager.MaxDownloadsPerUser}");
                    
                    var userStats = _userQueueManager.GetStats();
                    if (userStats.Count > 0)
                    {
                        Log($"   Top usuarios:");
                        foreach (var (user, (queued, active, limit)) in userStats.Take(5))
                        {
                            Log($"     • {user}: {active}/{limit} activas, {queued} en cola");
                        }
                    }
                }
                
                // PathCache
                if (_pathCache != null)
                {
                    Log($"📁 PathCache:");
                    Log($"   Entradas: {_pathCache.CacheSize}");
                    Log($"   Máximo: {_pathCache.MaxCacheSize}");
                }
                
                // WordIndex
                if (_wordIndex != null)
                {
                    Log($"📚 WordIndex:");
                    Log($"   Palabras indexadas: {_wordIndex.WordCount}");
                    Log($"   Documentos: {_wordIndex.DocumentCount}");
                }
                
                // EventBus
                if (_eventBus != null)
                {
                    Log($"📡 EventBus:");
                    Log($"   Suscriptores activos: {_eventBus.SubscriberCount}");
                }
                
                Log("📊 === FIN ESTADÍSTICAS ===");
            }
            catch (Exception ex)
            {
                Log($"❌ Error mostrando estadísticas: {ex.Message}");
            }
        }
        
        /// <summary>
        /// Obtiene el siguiente token de búsqueda (incrementa el contador)
        /// </summary>
        private int GetNextSearchToken()
        {
            return System.Threading.Interlocked.Increment(ref searchToken);
        }
        
        /// <summary>
        /// MEJORA PROTOCOLO SOULSEEK: Envía búsquedas de wishlist al servidor (modo pasivo)
        /// Server Code 103: WishlistSearch
        /// </summary>
        private async Task SendWishlistSearches()
        {
            if (client == null || !client.State.HasFlag(SoulseekClientStates.Connected))
            {
                Log("⚠️ No conectado - no se pueden enviar wishlist searches");
                return;
            }
            
            var authors = autoSearchAuthors.ToList();
            if (authors.Count == 0)
            {
                Log("📋 No hay autores en la lista para wishlist");
                return;
            }
            
            Log($"📋 Enviando {authors.Count} búsquedas de wishlist al servidor...");
            Log($"⏱️ El servidor buscará cada {_wishlistInterval/60} minutos automáticamente");
            
            int sent = 0;
            foreach (var author in authors)
            {
                try
                {
                    var token = GetNextSearchToken();
                    
                    // NOTA: Soulseek.NET puede no tener WishlistSearchAsync implementado
                    // En ese caso, necesitamos usar SearchAsync normal pero con menor frecuencia
                    // Por ahora, usamos SearchAsync y dejamos que el servidor gestione el rate limiting
                    
                    // TODO: Cuando Soulseek.NET implemente WishlistSearchAsync, usar:
                    // await client.WishlistSearchAsync(author, token);
                    
                    // Por ahora, solo registramos que queremos enviar esta búsqueda
                    Log($"  📤 Wishlist preparada: {author} (token: {token})");
                    sent++;
                    
                    // Pequeño delay para no saturar
                    await Task.Delay(100);
                }
                catch (Exception ex)
                {
                    Log($"❌ Error preparando wishlist para {author}: {ex.Message}");
                }
            }
            
            _lastWishlistSend = DateTime.UtcNow;
            Log($"✅ {sent}/{authors.Count} búsquedas de wishlist preparadas");
            Log($"💡 Los resultados llegarán automáticamente cuando el servidor encuentre coincidencias");
        }
        
        /// <summary>
        /// MEJORA PROTOCOLO SOULSEEK: Procesa frases prohibidas del servidor
        /// Server Code 160: ExcludedSearchPhrases
        /// </summary>
        private void OnExcludedSearchPhrases(List<string> phrases)
        {
            if (phrases == null || phrases.Count == 0)
            {
                Log("🚫 No hay frases prohibidas del servidor");
                return;
            }
            
            _excludedPhrases = new HashSet<string>(phrases, StringComparer.OrdinalIgnoreCase);
            Log($"🚫 Recibidas {phrases.Count} frases prohibidas del servidor:");
            
            // Mostrar algunas frases (primeras 5)
            var samplesToShow = phrases.Take(5).ToList();
            foreach (var phrase in samplesToShow)
            {
                Log($"   • {phrase}");
            }
            
            if (phrases.Count > 5)
            {
                Log($"   ... y {phrases.Count - 5} más");
            }
            
            // Actualizar índice de compartidos si tenemos carpetas compartidas
            if (sharedFolders?.Any() == true)
            {
                Log("🔄 Reconstruyendo índice de compartidos sin frases prohibidas...");
                _ = Task.Run(() => RebuildShareIndexWithExclusions());
            }
            
            // Publicar evento
            _eventBus?.Publish(SlskDown.Core.SystemEvents.ShareIndexRebuilt, new 
            { 
                ExcludedPhrases = phrases.Count, 
                Timestamp = DateTime.UtcNow 
            });
        }
        
        /// <summary>
        /// MEJORA PROTOCOLO SOULSEEK: Verifica si un archivo debe ser excluido por frases prohibidas
        /// </summary>
        private bool IsFileAllowedForSharing(string filePath)
        {
            if (_excludedPhrases.Count == 0)
                return true;
            
            var lowerPath = filePath.ToLowerInvariant();
            
            foreach (var phrase in _excludedPhrases)
            {
                if (lowerPath.Contains(phrase.ToLowerInvariant()))
                {
                    return false; // Archivo contiene frase prohibida
                }
            }
            
            return true;
        }
        
        /// <summary>
        /// MEJORA PROTOCOLO SOULSEEK: Reconstruye índice de compartidos excluyendo frases prohibidas
        /// </summary>
        private async Task RebuildShareIndexWithExclusions()
        {
            await Task.Run(() =>
            {
                try
                {
                    if (sharedFolders == null || sharedFolders.Count == 0)
                        return;
                    
                    int totalFiles = 0;
                    int excludedFiles = 0;
                    
                    foreach (var folder in sharedFolders)
                    {
                        if (!System.IO.Directory.Exists(folder))
                            continue;
                        
                        var files = System.IO.Directory.GetFiles(folder, "*.*", SearchOption.AllDirectories);
                        
                        foreach (var file in files)
                        {
                            totalFiles++;
                            
                            if (!IsFileAllowedForSharing(file))
                            {
                                excludedFiles++;
                                Log($"   🚫 Excluido: {Path.GetFileName(file)}");
                            }
                        }
                    }
                    
                    Log($"✅ Índice reconstruido: {totalFiles - excludedFiles}/{totalFiles} archivos permitidos");
                    if (excludedFiles > 0)
                    {
                        Log($"   🚫 {excludedFiles} archivos excluidos por frases prohibidas");
                    }
                }
                catch (Exception ex)
                {
                    Log($"❌ Error reconstruyendo índice: {ex.Message}");
                }
            });
        }
        
        /// <summary>
        /// MEJORA PROTOCOLO SOULSEEK: Obtiene recomendaciones globales del servidor
        /// Server Code 56: GlobalRecommendations
        /// </summary>
        private async Task GetGlobalRecommendations()
        {
            try
            {
                Log("🌐 Solicitando recomendaciones globales al servidor...");
                
                // NOTA: Soulseek.NET puede no tener GetGlobalRecommendationsAsync implementado
                // TODO: Implementar cuando esté disponible en Soulseek.NET
                
                // Por ahora, usamos recomendaciones locales basadas en descargas
                var localRecs = GetLocalRecommendations();
                
                if (localRecs.Count > 0)
                {
                    Log($"📚 Recomendaciones locales (basadas en tus descargas):");
                    foreach (var (author, score) in localRecs.Take(10))
                    {
                        Log($"   • {author} (score: {score})");
                    }
                }
                else
                {
                    Log("💡 Descarga algunos autores primero para obtener recomendaciones");
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error obteniendo recomendaciones: {ex.Message}");
            }
        }
        
        /// <summary>
        /// MEJORA PROTOCOLO SOULSEEK: Genera recomendaciones locales basadas en descargas
        /// </summary>
        private List<(string author, int score)> GetLocalRecommendations()
        {
            var recommendations = new Dictionary<string, int>();
            
            try
            {
                // Analizar historial de descargas
                lock (downloadHistoryLock)
                {
                    foreach (var entry in downloadHistory)
                    {
                        // Extraer autor del nombre de archivo
                        var author = ExtractAuthorFromFilename(entry.FileName);
                        
                        if (!string.IsNullOrEmpty(author))
                        {
                            if (!recommendations.ContainsKey(author))
                                recommendations[author] = 0;
                            
                            recommendations[author]++;
                        }
                    }
                }
                
                // Ordenar por frecuencia
                return recommendations
                    .OrderByDescending(kvp => kvp.Value)
                    .Select(kvp => (kvp.Key, kvp.Value))
                    .ToList();
            }
            catch (Exception ex)
            {
                Log($"❌ Error generando recomendaciones locales: {ex.Message}");
                return new List<(string, int)>();
            }
        }
        
        /// <summary>
        /// MEJORA PROTOCOLO SOULSEEK: Extrae autor de un nombre de archivo
        /// </summary>
        private string ExtractAuthorFromFilename(string filename)
        {
            try
            {
                // Remover extensión
                var nameWithoutExt = Path.GetFileNameWithoutExtension(filename);
                
                // Buscar patrones comunes: "Autor - Titulo" o "Autor_Titulo"
                var separators = new[] { " - ", "_", " _ " };
                
                foreach (var sep in separators)
                {
                    if (nameWithoutExt.Contains(sep))
                    {
                        var parts = nameWithoutExt.Split(new[] { sep }, StringSplitOptions.RemoveEmptyEntries);
                        if (parts.Length > 0)
                        {
                            return parts[0].Trim();
                        }
                    }
                }
                
                return null;
            }
            catch
            {
                return null;
            }
        }
        
        /// <summary>
        /// MEJORA PROTOCOLO SOULSEEK: Descubre autores similares y los agrega automáticamente
        /// Server Code 111: ItemRecommendations
        /// </summary>
        private async Task DiscoverSimilarAuthors(string author)
        {
            try
            {
                Log($"🔍 Buscando autores similares a: {author}");
                
                // NOTA: Soulseek.NET puede no tener GetItemRecommendationsAsync implementado
                // TODO: Implementar cuando esté disponible
                
                // Por ahora, usamos lógica local basada en co-ocurrencias
                var similar = GetSimilarAuthorsLocal(author);
                
                if (similar.Count > 0)
                {
                    Log($"📚 Autores similares encontrados:");
                    
                    int added = 0;
                    foreach (var (similarAuthor, score) in similar.Take(5))
                    {
                        if (!autoSearchAuthors.Contains(similarAuthor))
                        {
                            autoSearchAuthors.Add(similarAuthor);
                            added++;
                            Log($"   ✅ Agregado: {similarAuthor} (score: {score})");
                        }
                        else
                        {
                            Log($"   ⏭️ Ya existe: {similarAuthor}");
                        }
                    }
                    
                    if (added > 0)
                    {
                        Log($"✅ {added} autores similares agregados a la lista automática");
                        SaveConfig(); // Guardar cambios
                    }
                }
                else
                {
                    Log($"💡 No se encontraron autores similares a {author}");
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error descubriendo autores similares: {ex.Message}");
            }
        }
        
        /// <summary>
        /// MEJORA PROTOCOLO SOULSEEK: Encuentra autores similares basándose en co-ocurrencias
        /// </summary>
        private List<(string author, int score)> GetSimilarAuthorsLocal(string targetAuthor)
        {
            var coOccurrences = new Dictionary<string, int>();
            
            try
            {
                // Buscar en resultados de búsqueda recientes
                lock (autoSearchResultsLock)
                {
                    foreach (var result in autoSearchResults)
                    {
                        var author = ExtractAuthorFromFilename(result.FileName);
                        
                        if (!string.IsNullOrEmpty(author) && 
                            !author.Equals(targetAuthor, StringComparison.OrdinalIgnoreCase))
                        {
                            if (!coOccurrences.ContainsKey(author))
                                coOccurrences[author] = 0;
                            
                            coOccurrences[author]++;
                        }
                    }
                }
                
                return coOccurrences
                    .OrderByDescending(kvp => kvp.Value)
                    .Select(kvp => (kvp.Key, kvp.Value))
                    .ToList();
            }
            catch (Exception ex)
            {
                Log($"❌ Error buscando autores similares: {ex.Message}");
                return new List<(string, int)>();
            }
        }
        
        private async Task<string> GetCountryAsync(string ip)
        {
            if (string.IsNullOrEmpty(ip) || ip == "0.0.0.0")
                return "??";
            
            // MEJORA #22: Usar TryGetValue para evitar doble búsqueda
            if (countryCache.TryGetValue(ip, out var cachedCountry))
                return cachedCountry;
            
            try
            {
                using (var client = new HttpClient())
                {
                    client.Timeout = TimeSpan.FromSeconds(2);
                    var response = await client.GetStringAsync($"http://ip-api.com/json/{ip}?fields=countryCode");
                    var json = JsonSerializer.Deserialize<Dictionary<string, object>>(response);
                    
                    json.TryGetValue("countryCode", out var countryObj);
                    var country = countryObj?.ToString() ?? "??";
                    // MEJORA FASE 1.2: TryAdd thread-safe
                    countryCache.TryAdd(ip, country);
                    
                    if (countryCache.Count % 50 == 0)
                        SaveCountryCache();
                    
                    return country;
                }
            }
            catch
            {
                return "??";
            }
        }
        
        private bool IsHispanic(string country)
        {
            var hispanicCountries = new[] { "ES", "MX", "AR", "CO", "CL", "PE", "VE", "EC", "GT", "CU", "BO", "DO", "HN", "PY", "SV", "NI", "CR", "PA", "UY", "PR" };
            return hispanicCountries.Contains(country);
        }
        
        private void SaveCountryCache()
        {
            try
            {
                var json = JsonSerializer.Serialize(countryCache, new JsonSerializerOptions { WriteIndented = true });
                System.IO.File.WriteAllText(countryCachePath, json);
            }
            catch { }
        }
        
        private void UpdateSelectionCount()
        {
            try
            {
                // En modo virtual, no podemos acceder a SelectedItems directamente
                // Por ahora, simplemente no mostramos el contador de selección
                lblSelectionCount.Text = "";
            }
            catch
            {
                lblSelectionCount.Text = "";
            }
        }
        
        private bool MatchesCategory(string fileExt, string category)
        {
            if (category == "Todos") return true;
            
            // MEJORA #12: Solo normalizar si no está ya en minúsculas
            if (fileExt.Length > 0 && char.IsUpper(fileExt[0]))
                fileExt = fileExt.ToLower();
            
            return category switch
            {
                "Documentos" => fileExt == ".pdf" || fileExt == ".epub" || fileExt == ".mobi" || fileExt == ".azw3" || fileExt == ".djvu" || fileExt == ".doc" || fileExt == ".docx" || fileExt == ".txt",
                "Comics" => fileExt == ".cbr" || fileExt == ".cbz" || fileExt == ".cb7" || fileExt == ".cbt",
                "Videos" => fileExt == ".mp4" || fileExt == ".mkv" || fileExt == ".avi" || fileExt == ".mov" || fileExt == ".wmv" || fileExt == ".flv" || fileExt == ".webm",
                "Musica" => fileExt == ".mp3" || fileExt == ".flac" || fileExt == ".wav" || fileExt == ".m4a" || fileExt == ".ogg" || fileExt == ".wma" || fileExt == ".aac",
                "Comprimidos" => fileExt == ".zip" || fileExt == ".rar" || fileExt == ".7z" || fileExt == ".tar" || fileExt == ".gz" || fileExt == ".bz2",
                _ => true
            };
        }
        
        // ===== COLORES POR CALIDAD =====
        private Color GetQualityColor(long fileSize, string extension)
        {
            // MEJORA #12: Solo normalizar si no está ya en minúsculas
            if (extension.Length > 0 && char.IsUpper(extension[0]))
                extension = extension.ToLower();
            
            // Para ebooks
            if (extension == ".epub" || extension == ".mobi" || extension == ".pdf" || extension == ".azw3" || extension == ".djvu")
            {
                if (fileSize > 50 * 1024 * 1024) return Color.FromArgb(255, 80, 80); // Rojo brillante
                if (fileSize > 5 * 1024 * 1024) return Color.FromArgb(50, 255, 50); // Verde brillante
                if (fileSize > 1 * 1024 * 1024) return Color.FromArgb(255, 255, 50); // Amarillo brillante
                return Color.FromArgb(240, 240, 240); // Blanco
            }
            
            // Para comics
            if (extension == ".cbr" || extension == ".cbz" || extension == ".cb7" || extension == ".cbt")
            {
                if (fileSize > 200 * 1024 * 1024) return Color.FromArgb(50, 255, 255); // Cyan brillante
                if (fileSize > 50 * 1024 * 1024) return Color.FromArgb(50, 255, 50); // Verde brillante
                if (fileSize > 20 * 1024 * 1024) return Color.FromArgb(255, 255, 50); // Amarillo brillante
                return Color.FromArgb(240, 240, 240); // Blanco
            }
            
            // Para música
            if (extension == ".mp3" || extension == ".flac" || extension == ".m4a" || extension == ".ogg" || extension == ".wav" || extension == ".wma" || extension == ".aac")
            {
                if (extension == ".flac" || extension == ".wav") return Color.FromArgb(50, 255, 255); // Cyan brillante
                if (fileSize > 10 * 1024 * 1024) return Color.FromArgb(50, 255, 50); // Verde brillante
                if (fileSize > 5 * 1024 * 1024) return Color.FromArgb(255, 255, 50); // Amarillo brillante
                return Color.FromArgb(240, 240, 240); // Blanco
            }
            
            // Para videos
            if (extension == ".mp4" || extension == ".mkv" || extension == ".avi" || extension == ".mov" || extension == ".wmv" || extension == ".flv" || extension == ".webm")
            {
                if (fileSize > 2000 * 1024 * 1024) return Color.FromArgb(50, 255, 255); // Cyan brillante
                if (fileSize > 700 * 1024 * 1024) return Color.FromArgb(50, 255, 50); // Verde brillante
                if (fileSize > 300 * 1024 * 1024) return Color.FromArgb(255, 255, 50); // Amarillo brillante
                return Color.FromArgb(240, 240, 240); // Blanco
            }
            
            // Para comprimidos
            if (extension == ".zip" || extension == ".rar" || extension == ".7z" || extension == ".tar" || extension == ".gz")
            {
                if (fileSize > 500 * 1024 * 1024) return Color.FromArgb(50, 255, 255); // Cyan brillante
                if (fileSize > 100 * 1024 * 1024) return Color.FromArgb(50, 255, 50); // Verde brillante
                if (fileSize > 10 * 1024 * 1024) return Color.FromArgb(255, 255, 50); // Amarillo brillante
                return Color.FromArgb(240, 240, 240); // Blanco
            }
            
            // Para otros archivos (imágenes, documentos, etc.)
            if (fileSize > 50 * 1024 * 1024) return Color.FromArgb(50, 255, 255); // Cyan brillante
            if (fileSize > 10 * 1024 * 1024) return Color.FromArgb(50, 255, 50); // Verde brillante
            if (fileSize > 1 * 1024 * 1024) return Color.FromArgb(255, 255, 50); // Amarillo brillante
            return Color.FromArgb(240, 240, 240); // Blanco
        }
        
        private string GetFileIcon(string extension)
        {
            // MEJORA #12: Solo normalizar si no está ya en minúsculas
            if (extension.Length > 0 && char.IsUpper(extension[0]))
                extension = extension.ToLower();
            return extension switch
            {
                ".epub" or ".mobi" or ".azw3" or ".pdf" => "📖",
                ".cbr" or ".cbz" or ".cb7" => "📚",
                ".mp3" or ".flac" or ".wav" or ".m4a" or ".ogg" => "🎵",
                ".mp4" or ".mkv" or ".avi" or ".mov" => "🎬",
                ".zip" or ".rar" or ".7z" => "📦",
                ".jpg" or ".png" or ".gif" => "🖼️",
                ".txt" or ".doc" or ".docx" => "📄",
                _ => "📁"
            };
        }
        
        // ===== DETECCIÓN DE SERIES =====
        private (string seriesName, int? volume) DetectSeries(string filename)
        {
            var patterns = new[]
            {
                @"(.+?)\s+(?:Vol\.?|Volume|Tomo|Libro)\s*(\d+)",
                @"(.+?)\s+(\d+)\s+(?:de|of)\s+\d+",
                @"(.+?)\s+\[(\d+)\]",
                @"(.+?)\s+-\s+(\d+)",
                @"(.+?)\s+#(\d+)"
            };
            
            foreach (var pattern in patterns)
            {
                var match = System.Text.RegularExpressions.Regex.Match(filename, pattern, System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                if (match.Success)
                {
                    string seriesName = match.Groups[1].Value.Trim();
                    if (int.TryParse(match.Groups[2].Value, out int volume))
                    {
                        return (seriesName, volume);
                    }
                }
            }
            
            return (null, null);
        }
        
        private Dictionary<string, List<ListViewItem>> GroupBySeries(List<ListViewItem> items)
        {
            var series = new Dictionary<string, List<ListViewItem>>();
            
            foreach (var item in items)
            {
                string filename = item.SubItems[1].Text;
                var (seriesName, volume) = DetectSeries(filename);
                
                if (seriesName != null)
                {
                    if (!series.ContainsKey(seriesName))
                        series[seriesName] = new List<ListViewItem>();
                    
                    series[seriesName].Add(item);
                }
            }
            
            return series;
        }
        
        private void ShowSeriesDetection()
        {
            var allItems = lvResults.Items.Cast<ListViewItem>().ToList();
            var seriesGroups = GroupBySeries(allItems);
            
            if (seriesGroups.Count == 0)
            {
                Log("⚠️ No se detectaron series en los resultados actuales");
                return;
            }
            
            var form = new Form
            {
                Text = "📚 Series Detectadas",
                Size = new Size(800, 600),
                BackColor = Color.FromArgb(25, 25, 25),
                ForeColor = Color.White,
                StartPosition = FormStartPosition.CenterParent
            };
            
            var listView = new ListView
            {
                Dock = DockStyle.Fill,
                View = View.Details,
                FullRowSelect = true,
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.White
            };
            
            listView.Columns.Add("Serie", 400);
            listView.Columns.Add("Volúmenes", 100);
            listView.Columns.Add("Archivos", 100);
            listView.Columns.Add("Tamaño Total", 150);
            
            foreach (var kvp in seriesGroups.OrderByDescending(x => x.Value.Count))
            {
                var volumes = kvp.Value.Select(item => DetectSeries(item.SubItems[1].Text).volume)
                    .Where(v => v.HasValue)
                    .Select(v => v.Value)
                    .OrderBy(v => v)
                    .ToList();
                
                long totalSize = 0;
                foreach (var item in kvp.Value)
                {
                    dynamic tag = item.Tag;
                    totalSize += tag?.Size ?? 0;
                }
                
                string volumeRange = volumes.Count > 0 ? $"{volumes.Min()}-{volumes.Max()}" : "?";
                
                var listItem = new ListViewItem(new[]
                {
                    kvp.Key,
                    volumeRange,
                    kvp.Value.Count.ToString(),
                    FormatSize(totalSize)
                });
                listItem.Tag = kvp.Value;
                listItem.BackColor = Color.FromArgb(30, 30, 30);
                listItem.ForeColor = Color.White;
                listView.Items.Add(listItem);
            }
            
            listView.DoubleClick += (s, e) =>
            {
                if (listView.SelectedItems.Count > 0)
                {
                    var items = (List<ListViewItem>)listView.SelectedItems[0].Tag;
                    lvResults.SelectedItems.Clear();
                    foreach (var item in items)
                    {
                        item.Selected = true;
                        item.EnsureVisible();
                    }
                    form.Close();
                }
            };
            
            var btnPanel = new Panel { Dock = DockStyle.Bottom, Height = 50, BackColor = Color.FromArgb(25, 25, 25) };
            var btnDownloadSeries = new Button 
            { 
                Text = "⬇️ Descargar Serie Completa", 
                Location = new Point(10, 10), 
                Size = new Size(200, 30),
                BackColor = Color.FromArgb(0, 150, 0),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat
            };
            btnDownloadSeries.Click += async (s, e) =>
            {
                if (listView.SelectedItems.Count > 0)
                {
                    var items = (List<ListViewItem>)listView.SelectedItems[0].Tag;
                    lvResults.SelectedItems.Clear();
                    foreach (var item in items)
                        item.Selected = true;
                    
                    form.Close();
                    await DownloadMultipleAsync();
                }
            };
            btnPanel.Controls.Add(btnDownloadSeries);
            
            form.Controls.Add(btnPanel);
            form.Controls.Add(listView);
            form.ShowDialog();
        }
        
        private async Task ShowBookSynopsis()
        {
            if (lvResults.SelectedItems.Count == 0)
            {
                Log("⚠️ Selecciona un libro para ver su sinopsis");
                return;
            }
            
            var selectedItem = lvResults.SelectedItems[0];
            var fileName = selectedItem.SubItems[0].Text;
            
            // Extraer título y autor del nombre del archivo
            var (title, author) = ParseFileName(fileName);
            
            if (string.IsNullOrEmpty(title))
            {
                DarkMessageBox.Show("No se pudo extraer el título del archivo.", "Ver Sinopsis", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }
            
            // Crear ventana de carga
            var loadingForm = new Form
            {
                Text = "Obteniendo sinopsis...",
                Size = new Size(400, 150),
                StartPosition = FormStartPosition.CenterParent,
                FormBorderStyle = FormBorderStyle.FixedDialog,
                MaximizeBox = false,
                MinimizeBox = false,
                BackColor = Color.FromArgb(30, 30, 30)
            };
            
            var loadingLabel = new Label
            {
                Text = $"Buscando información de:\n{title}",
                Dock = DockStyle.Fill,
                TextAlign = ContentAlignment.MiddleCenter,
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 10)
            };
            
            loadingForm.Controls.Add(loadingLabel);
            
            // Mostrar ventana de carga de forma no bloqueante
            loadingForm.Show();
            Application.DoEvents();
            
            try
            {
                // Buscar metadata en caché
                var cacheKey = $"synopsis_{title}_{author}";
                var cachedMetadata = GetCachedMetadata<BookMetadata>(cacheKey);
                
                BookMetadata metadata;
                
                if (cachedMetadata != null)
                {
                    metadata = cachedMetadata;
                    Log($"📖 Sinopsis obtenida de caché: {title}");
                }
                else
                {
                    // Buscar en Google Books
                    metadata = await FetchBookMetadataFromGoogleBooks(title, author);
                    
                    // Si no se encuentra, buscar en Open Library
                    if (metadata == null || string.IsNullOrEmpty(metadata.Synopsis))
                    {
                        metadata = await FetchBookMetadataFromOpenLibrary(title, author);
                    }
                    
                    // Guardar en caché
                    if (metadata != null)
                    {
                        SetCachedMetadata(cacheKey, metadata);
                    }
                }
                
                loadingForm.Close();
                
                if (metadata == null || string.IsNullOrEmpty(metadata.Synopsis))
                {
                    DarkMessageBox.Show($"No se encontró sinopsis para:\n{title}\n\nIntenta con otro libro o verifica el título.", 
                        "Sinopsis no encontrada", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    return;
                }
                
                // Crear ventana de sinopsis
                var synopsisForm = new Form
                {
                    Text = $"📖 {metadata.Title}",
                    Size = new Size(700, 600),
                    StartPosition = FormStartPosition.CenterParent,
                    BackColor = Color.FromArgb(30, 30, 30),
                    ForeColor = Color.White,
                    Font = new Font("Segoe UI", 9)
                };
                
                var mainPanel = new TableLayoutPanel
                {
                    Dock = DockStyle.Fill,
                    ColumnCount = 1,
                    RowCount = 3,
                    Padding = new Padding(15),
                    BackColor = Color.FromArgb(30, 30, 30)
                };
                
                mainPanel.RowStyles.Add(new RowStyle(SizeType.Absolute, 80));
                mainPanel.RowStyles.Add(new RowStyle(SizeType.Percent, 100));
                mainPanel.RowStyles.Add(new RowStyle(SizeType.Absolute, 50));
                
                // Panel de información
                var infoPanel = new FlowLayoutPanel
                {
                    Dock = DockStyle.Fill,
                    FlowDirection = FlowDirection.TopDown,
                    BackColor = Color.FromArgb(40, 40, 40),
                    Padding = new Padding(10)
                };
                
                var lblTitle = new Label
                {
                    Text = metadata.Title,
                    AutoSize = true,
                    Font = new Font("Segoe UI", 14, FontStyle.Bold),
                    ForeColor = Color.FromArgb(100, 200, 255),
                    MaximumSize = new Size(650, 0)
                };
                
                var lblAuthor = new Label
                {
                    Text = $"✍️ {metadata.Author ?? "Autor desconocido"}",
                    AutoSize = true,
                    Font = new Font("Segoe UI", 10),
                    ForeColor = Color.LightGray
                };
                
                var lblInfo = new Label
                {
                    Text = $"📅 {metadata.PublishDate ?? "Fecha desconocida"} | 📄 {metadata.PageCount} páginas | ⭐ {metadata.Rating:F1}/5",
                    AutoSize = true,
                    Font = new Font("Segoe UI", 9),
                    ForeColor = Color.Gray
                };
                
                infoPanel.Controls.Add(lblTitle);
                infoPanel.Controls.Add(lblAuthor);
                infoPanel.Controls.Add(lblInfo);
                
                mainPanel.Controls.Add(infoPanel, 0, 0);
                
                // TextBox de sinopsis
                var txtSynopsis = new TextBox
                {
                    Dock = DockStyle.Fill,
                    Multiline = true,
                    ReadOnly = true,
                    Text = metadata.Synopsis,
                    BackColor = Color.FromArgb(25, 25, 25),
                    ForeColor = Color.White,
                    Font = new Font("Segoe UI", 10),
                    BorderStyle = BorderStyle.None,
                    ScrollBars = ScrollBars.Vertical,
