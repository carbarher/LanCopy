        private void HookNumericSave(NumericUpDown control, Action onChange)
        {
            if (control == null || onChange == null)
                return;

            control.ValueChanged += (s, e) => onChange();
            control.Leave += (s, e) => onChange();
        }

        private async Task<(Search search, IReadOnlyCollection<Soulseek.SearchResponse> responses)> SearchAlternativesWithFallbackAsync(string fileName, string author)
        {
            // INTEGRACIÓN MULTI-RED: Intentar búsqueda multi-red primero
            if (_networkOrchestrator != null && _networkOrchestrator.GetActiveNetworks().Any())
            {
                try
                {
                    var multiNetResults = await _networkOrchestrator.SearchAsync(fileName);
                    
                    if (multiNetResults.Any())
                    {
                        // Convertir resultados multi-red a SearchResponse
                        // Nota: Esto es una conversión simplificada ya que NetworkSearchResult no es SearchResponse
                        // Para una implementación completa, necesitaríamos crear SearchResponse mock o usar directamente NetworkSearchResult
                        AutoLog($"✅ Búsqueda multi-red de alternativas: {multiNetResults.Count} resultados");
                        
                        // Por ahora, retornamos vacío y dejamos que caiga al fallback Soulseek
                        // TODO: Implementar conversión completa de NetworkSearchResult a SearchResponse
                    }
                }
                catch (Exception multiEx)
                {
                    AutoLog($"⚠️ Error en búsqueda multi-red de alternativas: {multiEx.Message}");
                }
            }
            
            // Fallback a Soulseek standalone
            if (client == null)
                return (null, Array.Empty<Soulseek.SearchResponse>());

            try
            {
                var (search, responses) = await client.SearchAsync(
                    SearchQuery.FromText(fileName),
                    options: new SearchOptions(
                        searchTimeout: downloadManager?.Config?.QueuePositionRefreshIntervalSeconds * 1000 ?? 7000,
                        responseLimit: 50,
                        fileLimit: 200,
                        filterResponses: true
                    ),
                    cancellationToken: CancellationToken.None);

                return (search, responses ?? Array.Empty<Soulseek.SearchResponse>());
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error en búsqueda: {ex.Message}");
                return (null, Array.Empty<Soulseek.SearchResponse>());
            }
        }

        private Task<int?> RequestQueuePositionFallbackAsync(SoulseekClient soulseekClient, string username, string fileName)
        {
            // La biblioteca actual no expone API pública para consultar la cola remota;
            // devolvemos null para indicar que la posición es desconocida.
            return Task.FromResult<int?>(null);
        }

        private void SetDownloadSpeedLimit(SoulseekClient soulseekClient, int limitKib)
        {
            if (soulseekClient == null)
                return;

            // La API actual del cliente no soporta cambiar el límite desde código;
            // registramos la intención para diagnóstico.
            AutoLog(limitKib > 0
                ? $"ℹ️ Límite de descarga deseado: {limitKib} KiB/s (no soportado por la API)"
                : "ℹ️ Límite de descarga desactivado (no soportado por la API)");
        }

        private NumericUpDown CreateNumericSetting(FlowLayoutPanel parent, string labelText, int value, int min, int max, int increment)
        {
            var panel = new FlowLayoutPanel
            {
                AutoSize = true,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = false,
                Margin = new Padding(3)
            };

            var label = new Label
            {
                Text = labelText,
                AutoSize = true,
                Margin = new Padding(3, 6, 6, 0)
            };

            var numeric = new NumericUpDown
            {
                Minimum = min,
                Maximum = max,
                Increment = increment,
                Value = Math.Max(min, Math.Min(value, max)),
                Width = 90,
                Margin = new Padding(3)
            };

            panel.Controls.Add(label);
            panel.Controls.Add(numeric);
            parent.Controls.Add(panel);

            return numeric;
        }

        private TextBox CreatePathSetting(FlowLayoutPanel parent, string labelText, string initialValue, out Button browseButton)
        {
            var panel = new FlowLayoutPanel
            {
                AutoSize = true,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = false,
                Margin = new Padding(3)
            };

            var label = new Label
            {
                Text = labelText,
                AutoSize = true,
                Margin = new Padding(3, 6, 6, 0)
            };

            var textBox = new TextBox
            {
                Width = 240,
                Text = initialValue ?? string.Empty,
                Margin = new Padding(3)
            };

            browseButton = CreateButton("📂", Color.FromArgb(80, 120, 200));

            panel.Controls.Add(label);
            panel.Controls.Add(textBox);
            panel.Controls.Add(browseButton);
            parent.Controls.Add(panel);

            return textBox;
        }

        private TextBox CreateTextSetting(FlowLayoutPanel parent, string labelText, string initialValue, Button trailingButton)
        {
            var panel = new FlowLayoutPanel
            {
                AutoSize = true,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = false,
                Margin = new Padding(3)
            };

            var label = new Label
            {
                Text = labelText,
                AutoSize = true,
                Margin = new Padding(3, 6, 6, 0)
            };

            var textBox = new TextBox
            {
                Width = 240,
                Text = initialValue ?? string.Empty,
                Margin = new Padding(3)
            };

            panel.Controls.Add(label);
            panel.Controls.Add(textBox);
            if (trailingButton != null)
            {
                panel.Controls.Add(trailingButton);
            }

            parent.Controls.Add(panel);
            return textBox;
        }

        private void OpenDownloadsWindow()
        {
            var downloadsForm = new Form
            {
                Text = "📥 Descargas Automáticas - SlskDown",
                Size = new Size(1400, 700),
                StartPosition = FormStartPosition.CenterParent,
                BackColor = Color.FromArgb(24, 24, 24),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9)
            };

            var mainLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 2,
                RowCount = 4,
                Padding = new Padding(10)
            };
            mainLayout.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 60));
            mainLayout.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 40));
            mainLayout.RowStyles.Add(new RowStyle(SizeType.Absolute, 80));  // Fila 0: Botones
            mainLayout.RowStyles.Add(new RowStyle(SizeType.Absolute, 35));  // Fila 1: Filtros (solo 2 checkboxes)
            mainLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100));  // Fila 2: Grilla y log
            mainLayout.RowStyles.Add(new RowStyle(SizeType.Absolute, 50));  // Fila 3: Stats

            // Panel superior izquierdo con controles de archivos
            var topLeftPanel = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = true,
                BackColor = Color.FromArgb(30, 30, 30),
                Padding = new Padding(5)
            };

            // Variables para navegación autor por autor
            int currentAuthorIndex = 0;
            List<string> authorsList = new List<string>();
            
            var btnLoadAuthorsFile = CreateButton("📂 Cargar Autores", Color.FromArgb(0, 120, 215));
            var btnNextAuthor = CreateButton("▶️ Comenzar", Color.FromArgb(0, 150, 215));
            var btnDownloadSelected = CreateButton("⬇️ Descargar", Color.FromArgb(0, 150, 0));
            var btnRedownload = CreateButton("🔄 Redescargar", Color.FromArgb(200, 100, 0));
            var btnStopDownload = CreateButton("⏸️ Detener", Color.FromArgb(150, 100, 0));
            var btnResumeDownload = CreateButton("▶️ Continuar", Color.FromArgb(0, 150, 0));
            var btnOpenFolder = CreateButton("📂 Abrir Carpeta", Color.FromArgb(60, 120, 60));
            var btnExport = CreateButton("💾 Exportar", Color.FromArgb(100, 60, 150));
            var btnClose = CreateButton("❌ Salir", Color.FromArgb(150, 0, 0));
            
            btnNextAuthor.Enabled = false; // Deshabilitado hasta cargar autores

            topLeftPanel.Controls.Add(btnLoadAuthorsFile);
            topLeftPanel.Controls.Add(btnNextAuthor);
            topLeftPanel.Controls.Add(btnDownloadSelected);
            topLeftPanel.Controls.Add(btnRedownload);
            topLeftPanel.Controls.Add(btnStopDownload);
            topLeftPanel.Controls.Add(btnResumeDownload);
            topLeftPanel.Controls.Add(btnOpenFolder);
            topLeftPanel.Controls.Add(btnExport);
            topLeftPanel.Controls.Add(btnClose);

            mainLayout.Controls.Add(topLeftPanel, 0, 0);

            // Segunda fila: Panel de filtros (checkboxes)
            var filtersPanel = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = false,
                BackColor = Color.FromArgb(30, 30, 30),
                Padding = new Padding(5)
            };

            // Variable para mantener el estado del filtro español (accesible desde todo el método)
            bool spanishChecked = false;
            Label lblOnlySpanish = null;

            var chkOnlyDocs = new CheckBox 
            { 
                Text = "📚 Solo Docs", 
                AutoSize = true, 
                ForeColor = Color.White,
                Margin = new Padding(10, 8, 20, 0),
                Font = new Font("Segoe UI", 9)
            };
            filtersPanel.Controls.Add(chkOnlyDocs);

            // Reemplazar CheckBox por Label personalizado con comportamiento de checkbox
            lblOnlySpanish = new Label 
            { 
                Text = "[ ] Solo Español", 
                AutoSize = true, 
                ForeColor = Color.White,
                BackColor = Color.Transparent,
                Cursor = Cursors.Hand,
                Margin = new Padding(10, 8, 20, 0),
                Font = new Font("Segoe UI", 9)
            };
            
            lblOnlySpanish.Tag = "KeepColor";
            filtersPanel.Controls.Add(lblOnlySpanish);

            // Control de tamaño mínimo
            var lblMinSize = new Label
            {
                Text = "📏 Tamaño mín (KB):",
                AutoSize = true,
                ForeColor = Color.White,
                Margin = new Padding(20, 10, 5, 0),
                Font = new Font("Segoe UI", 9)
            };
            filtersPanel.Controls.Add(lblMinSize);

            var numMinSizeKB = new NumericUpDown
            {
                Width = 80,
                Minimum = 0,
                Maximum = 1000000,
                Value = 0,
                Increment = 100,
                BackColor = Color.FromArgb(50, 50, 50),
                ForeColor = Color.White,
                Margin = new Padding(0, 6, 10, 0),
                Font = new Font("Segoe UI", 9)
            };
            filtersPanel.Controls.Add(numMinSizeKB);

            mainLayout.Controls.Add(filtersPanel, 0, 1);

            // Panel superior derecho con título del log
            var rightInfoLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 1,
                BackColor = Color.FromArgb(30, 30, 30),
                Padding = new Padding(12),
                AutoSize = true,
                AutoSizeMode = AutoSizeMode.GrowAndShrink
            };
            rightInfoLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize));
            rightInfoLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize));
            rightInfoLayout.RowStyles.Add(new RowStyle(SizeType.AutoSize));
            rightInfoLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100f));

            var lblLogTitle = new Label
            {
                Text = "📋 Log de Descargas",
                AutoSize = true,
                Font = new Font("Segoe UI", 11, FontStyle.Bold),
                ForeColor = Color.White,
                Margin = new Padding(0, 0, 0, 12)
            };
            rightInfoLayout.Controls.Add(lblLogTitle, 0, 0);

            var statsLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 1,
                AutoSize = true,
                AutoSizeMode = AutoSizeMode.GrowAndShrink,
                BackColor = Color.FromArgb(40, 40, 40),
                Padding = new Padding(12),
                Margin = new Padding(0, 0, 0, 12)
            };
            statsLayout.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 100f));

            var lblStatsTitle = new Label
            {
                Text = "📊 ESTADÍSTICAS GLOBALES",
                AutoSize = true,
                Font = new Font("Segoe UI", 9, FontStyle.Bold),
                ForeColor = Color.LightBlue,
                Margin = new Padding(0, 0, 0, 6)
            };
            statsLayout.Controls.Add(lblStatsTitle, 0, 0);

            var lblGlobalStats = new Label
            {
                AutoSize = true,
                Font = new Font("Consolas", 8),
                ForeColor = Color.LightGray,
                Text = "Cargando estadísticas...",
                Margin = new Padding(0)
            };
            statsLayout.Controls.Add(lblGlobalStats, 0, 1);
            rightInfoLayout.Controls.Add(statsLayout, 0, 1);

            var configFlow = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                AutoSize = true,
                AutoSizeMode = AutoSizeMode.GrowAndShrink,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = false,
                BackColor = Color.FromArgb(40, 40, 40),
                Padding = new Padding(12),
                Margin = new Padding(0, 0, 0, 12)
            };

            var lblSimultaneous = new Label
            {
                Text = "⚙️ Descargas simultáneas:",
                AutoSize = true,
                ForeColor = Color.LightGray,
                Font = new Font("Segoe UI", 9),
                Margin = new Padding(0, 4, 12, 0)
            };
            configFlow.Controls.Add(lblSimultaneous);

            numSimultaneous = new NumericUpDown
            {
                Width = 70,
                Minimum = 1,
                Maximum = 50,
                Value = maxSimultaneousDownloads,
                BackColor = Color.FromArgb(50, 50, 50),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                Margin = new Padding(0, 2, 12, 0)
            };
            numSimultaneous.ValueChanged += (s, e) =>
            {
                maxSimultaneousDownloads = (int)numSimultaneous.Value;
                // LogDownload se declarará después
            };
            configFlow.Controls.Add(numSimultaneous);
            
            var chkAutoStartOnEnqueue = new CheckBox
            {
                Text = "▶️ Auto iniciar al encolar",
                AutoSize = true,
                ForeColor = Color.LightGray,
                Margin = new Padding(0, 4, 12, 0),
                Checked = autoStartDownloadsOnEnqueue
            };
            configFlow.Controls.Add(chkAutoStartOnEnqueue);

            var btnApplyConfig = CreateButton("✓", Color.FromArgb(0, 120, 215));
            btnApplyConfig.Width = 44;
            btnApplyConfig.Height = 32;
            btnApplyConfig.Margin = new Padding(0);
            // btnApplyConfig.Click se configurará después
            configFlow.Controls.Add(btnApplyConfig);

            // NUEVO: Controles avanzados DownloadManager
            numQueueInterval = CreateNumericSetting(configFlow, "🔁 Cola remota (s):", queuePositionRefreshIntervalSeconds, 30, 3600, 30);
            numRetryConnInterval = CreateNumericSetting(configFlow, "🌐 Retry conexión (s):", retryConnectionIntervalSeconds, 30, 3600, 30);
            numRetryIoInterval = CreateNumericSetting(configFlow, "💾 Retry IO (s):", retryIoIntervalSeconds, 60, 7200, 60);
            numCleanupInterval = CreateNumericSetting(configFlow, "🧹 Limpieza temporales (s):", cleanupIntervalSeconds, 60, 7200, 60);
            numSpeedLimit = CreateNumericSetting(configFlow, "🚀 Límite velocidad (KiB/s):", downloadSpeedLimitKib, 0, 102400, 128);
            numRetryBackoff = CreateNumericSetting(configFlow, "⏳ Backoff (ms):", retryBackoffMilliseconds, 100, 60000, 100);

            txtIncompleteDir = CreatePathSetting(configFlow, "📂 Temporales incompletos:", incompleteDownloadsDirectory, out btnBrowseIncompleteDir);
            btnTestPostDownloadCommand = CreateButton("▶️", Color.FromArgb(80, 120, 200));
            txtPostDownloadCommand = CreateTextSetting(configFlow, "🛠️ Comando post-descarga:", postDownloadCommand, btnTestPostDownloadCommand);
            txtDownloadFilter = CreateTextSetting(configFlow, "🔎 Filtro Regex:", downloadFilterPattern, null);

            rightInfoLayout.Controls.Add(configFlow, 0, 2);

            // Actualizar estadísticas globales
            Action updateGlobalStats = () =>
            {
                lock (autoSearchResultsLock)
                {
                    var uniqueAuthors = autoSearchResults.Select(f => f.Author).Distinct().Count();
                    var totalSize = autoSearchResults.Sum(f => f.SizeBytes);
                    var totalSizeGB = totalSize / 1024.0 / 1024.0 / 1024.0;
                    
                    lblGlobalStats.Text = 
                        $"Total encontrados: {autoSearchResults.Count:N0} archivos\n" +
                        $"Descargados: {statistics.TotalFilesDownloaded:N0} | Tamaño: {(statistics.TotalBytesDownloaded / 1024.0 / 1024.0 / 1024.0):F2} GB\n" +
                        $"Autores únicos: {uniqueAuthors} | Vel. promedio: {statistics.AverageDownloadSpeed:F2} MB/s";
                }
            };

            mainLayout.Controls.Add(rightInfoLayout, 1, 0);  // Columna 1, Fila 0
            mainLayout.SetRowSpan(rightInfoLayout, 2);  // Ocupa filas 0 y 1

            // Panel de búsqueda
            var searchPanel = new FlowLayoutPanel
            {
                Dock = DockStyle.Top,
                AutoSize = true,
                AutoSizeMode = AutoSizeMode.GrowAndShrink,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = false,
                BackColor = Color.FromArgb(35, 35, 35),
                Padding = new Padding(12, 8, 12, 8),
                Margin = new Padding(0, 0, 0, 4)
            };
            
            var lblSearch = new Label
            {
                Text = "🔍 Buscar:",
                AutoSize = true,
                ForeColor = Color.LightGray,
                Font = new Font("Segoe UI", 9),
                Margin = new Padding(0, 4, 10, 0)
            };
            searchPanel.Controls.Add(lblSearch);
            
            txtSearch = new TextBox
            {
                Width = 280,
                BackColor = Color.FromArgb(50, 50, 50),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                Margin = new Padding(0, 0, 10, 0)
            };
            searchPanel.Controls.Add(txtSearch);
            
            var btnClearSearch = new Button
            {
                Text = "✖",
                AutoSize = true,
                BackColor = Color.FromArgb(60, 60, 60),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Cursor = Cursors.Hand,
                Margin = new Padding(0, 0, 12, 0)
            };
            btnClearSearch.FlatAppearance.BorderSize = 0;
            btnClearSearch.Click += (s, e) => { txtSearch.Text = ""; txtSearch.Focus(); };
            searchPanel.Controls.Add(btnClearSearch);
            
            var lblSearchResults = new Label
            {
                AutoSize = true,
                ForeColor = Color.LightBlue,
                Font = new Font("Segoe UI", 8),
                Margin = new Padding(0, 4, 0, 0)
            };
            searchPanel.Controls.Add(lblSearchResults);

            // ListView para mostrar archivos
            var lvFiles = new ListView
            {
                Dock = DockStyle.Fill,
                View = View.Details,
                FullRowSelect = true,
                GridLines = true,
                CheckBoxes = true,
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                OwnerDraw = true,
                HotTracking = true
            };
            lvFiles.DrawColumnHeader += ListView_DrawColumnHeader;
            lvFiles.DrawItem += ListView_DrawItem;
            lvFiles.DrawSubItem += ListView_DrawSubItem;

            lvFiles.Columns.Add("Estado", 100);
            lvFiles.Columns.Add("Autor", 130);
            lvFiles.Columns.Add("Archivo", 250);
            lvFiles.Columns.Add("Extensión", 70);
            lvFiles.Columns.Add("Tamaño", 80);
            lvFiles.Columns.Add("Usuario", 100);
            lvFiles.Columns.Add("Directorio", 200);
            lvFiles.Columns.Add("Español", 60);
            lvFiles.Columns.Add("Doc", 50);
            lvFiles.Columns.Add("Fecha", 130);

            // Variables para ordenamiento
            int sortColumnIndex = -1;
            bool sortAscending = true;

            // Helper para obtener valor de ordenamiento según columna
            Func<ListViewItem, int, IComparable> GetSortValue = (item, columnIndex) =>
            {
                var file = (AutoSearchFileResult)item.Tag;
                switch (columnIndex)
                {
                    case 0: return item.Text; // Estado
                    case 1: return file.Author; // Autor
                    case 2: return file.FileName; // Archivo
                    case 3: return Path.GetExtension(file.FileName).ToLower(); // Extensión
                    case 4: return file.SizeBytes; // Tamaño (ordenar por bytes)
                    case 5: return file.Username; // Usuario
                    case 6: return file.Directory; // Directorio
                    case 7: return file.IsSpanish ? 0 : 1; // Español (Sí primero)
                    case 8: return file.IsDocument ? 0 : 1; // Doc (Sí primero)
                    case 9: return file.Timestamp; // Fecha
                    default: return item.Text;
                }
            };

            // Helper para actualizar encabezados con indicadores visuales
            Action<ListView, int, bool> UpdateColumnHeaders = (lv, sortCol, ascending) =>
            {
                string[] columnNames = { "Estado", "Autor", "Archivo", "Extensión", "Tamaño", "Usuario", "Directorio", "Español", "Doc", "Fecha" };
                for (int i = 0; i < lv.Columns.Count; i++)
                {
                    string header = columnNames[i];
                    if (i == sortCol)
                    {
                        header += ascending ? " ▲" : " ▼";
                    }
                    lv.Columns[i].Text = header;
                }
            };

            // Comparador personalizado para ordenamiento rápido
            var listViewItemComparer = new ListViewItemComparer(sortColumnIndex, sortAscending, GetSortValue);
            lvFiles.ListViewItemSorter = listViewItemComparer;

            // Event handler para ordenar al hacer clic en columnas (OPTIMIZADO)
            lvFiles.ColumnClick += (s, e) =>
            {
                // Si se hace clic en la misma columna, invertir orden
                if (e.Column == sortColumnIndex)
                {
                    sortAscending = !sortAscending;
                }
                else
                {
                    sortColumnIndex = e.Column;
                    sortAscending = true;
                }

                // Actualizar comparador y ordenar (MUY RÁPIDO)
                listViewItemComparer.ColumnIndex = sortColumnIndex;
                listViewItemComparer.Ascending = sortAscending;
                lvFiles.Sort();

                // Actualizar encabezados con indicador visual
                UpdateColumnHeaders(lvFiles, sortColumnIndex, sortAscending);
            };

            // Panel contenedor para búsqueda + lista
            var filesContainer = new Panel
            {
                Dock = DockStyle.Fill
            };
            filesContainer.Controls.Add(lvFiles);
            filesContainer.Controls.Add(searchPanel);
            
            mainLayout.Controls.Add(filesContainer, 0, 2);  // Fila 2: Grilla

            // TextBox de log en el lado derecho
            var txtDownloadLog = new TextBox
            {
                Dock = DockStyle.Fill,
                Multiline = true,
                ReadOnly = true,
                BackColor = Color.FromArgb(20, 20, 20),
                ForeColor = Color.LightGray,
                Font = new Font("Consolas", 9),
                ScrollBars = ScrollBars.Both,
                WordWrap = false
            };
            mainLayout.Controls.Add(txtDownloadLog, 1, 2);  // Fila 2: Log

            // Helper para agregar mensajes al log (OPTIMIZADO con límite)
            const int MAX_LOG_LINES = 500;
            Action<string> LogDownload = (msg) =>
            {
                Action appendLog = () =>
                {
                    txtDownloadLog.AppendText($"[{DateTime.Now:HH:mm:ss}] {msg}{Environment.NewLine}");
                    
                    // Optimización: limitar líneas del log
                    var lines = txtDownloadLog.Lines;
                    if (lines.Length > MAX_LOG_LINES)
                    {
                        var newLines = lines.Skip(lines.Length - MAX_LOG_LINES).ToArray();
                        txtDownloadLog.Lines = newLines;
                        txtDownloadLog.SelectionStart = txtDownloadLog.Text.Length;
                        txtDownloadLog.ScrollToCaret();
                    }
                };
                
                if (txtDownloadLog.InvokeRequired)
                    SafeBeginInvoke(appendLog);
                else
                    appendLog();
            };

            // Panel inferior con estadísticas
            var bottomPanel = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                AutoSize = true,
                AutoSizeMode = AutoSizeMode.GrowAndShrink,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = true,
                BackColor = Color.FromArgb(30, 30, 30),
                Padding = new Padding(12, 10, 12, 10)
            };

            var lblStats = new Label
            {
                Text = "Total: 0 archivos",
                AutoSize = true,
                Font = new Font("Segoe UI", 9),
                ForeColor = Color.LightGray,
                Margin = new Padding(0, 0, 20, 0)
            };
            bottomPanel.Controls.Add(lblStats);

            mainLayout.Controls.Add(bottomPanel, 0, 3);  // Fila 3: Stats
            mainLayout.SetColumnSpan(bottomPanel, 2);  // Ocupa 2 columnas

            downloadsForm.Controls.Add(mainLayout);

            // Registrar evento ItemChecked DESPUÉS de crear lblStats
            lvFiles.ItemChecked += (s, e) =>
            {
                int checkedCount = lvFiles.CheckedItems.Count;
                var downloadPath = txtDownloadDir?.Text ?? Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments), "SlskDown");
                int existingCount = 0;
                
                foreach (ListViewItem item in lvFiles.Items)
                {
                    var file = (AutoSearchFileResult)item.Tag;
                    var fullPath = GetDownloadPath(file.FileName, file.Author);
                    if (IsFileDownloaded(fullPath)) existingCount++;
                }
                
                lblStats.Text = $"Total: {lvFiles.Items.Count} archivos | Descargados: {existingCount} | Pendientes: {lvFiles.Items.Count - existingCount} | Seleccionados: {checkedCount}";
            };

            // Cargar datos con filtros (OPTIMIZADO)
            Action<string> loadData = (searchFilter) =>
            {
                lvFiles.BeginUpdate(); // Optimización: suspender redibujado
                try
                {
                    lvFiles.Items.Clear();
                    List<AutoSearchFileResult> files;
                    lock (autoSearchResultsLock)
                    {
                        files = autoSearchResults.ToList();
                    }

                    var downloadPath = txtDownloadDir?.Text ?? Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments), "SlskDown");
                    
                    int existingCount = 0;
                    int pendingCount = 0;
                    var existsCache = new Dictionary<string, bool>(files.Count);

                    // Contadores adicionales para stats
                    int displayedCount = 0;
                    const int MAX_DISPLAY_ITEMS = 10000; // Límite para evitar problemas de rendimiento
                    
                    // OPTIMIZACIÓN: Cachear valores de filtros (evitar acceso a controles en loop)
                    bool filterDocs = chkOnlyDocs.Checked;
                    bool filterSpanish = spanishChecked;
                    long minSizeBytes = minFileSizeKB * 1024L;
                    // MEJORA #29: Usar IsNullOrWhiteSpace en lugar de IsNullOrEmpty + Trim
                    string searchText = string.IsNullOrWhiteSpace(searchFilter) ? 
                        (string.IsNullOrWhiteSpace(txtSearch.Text) ? "" : txtSearch.Text.Trim().ToLower()) : 
                        searchFilter.Trim().ToLower();
                    bool hasSearch = !string.IsNullOrEmpty(searchText);
                    int filteredBySearch = 0;

                    // Una sola iteración optimizada
                    foreach (var file in files)
                    {
                        // Filtrar autores en blacklist (PRIMERO para máxima eficiencia)
                        if (IsAuthorBlacklisted(file.Author)) continue;
                        
                        // Aplicar filtros de contenido primero (más rápido)
                        if (filterDocs && !file.IsDocument) continue;
                        if (filterSpanish && !file.IsSpanish) continue;
                        
                        // Filtro de tamaño mínimo (comparar bytes directamente)
                        if (minSizeBytes > 0 && file.SizeBytes < minSizeBytes) continue;
                        
                        // Filtro de búsqueda (archivo, autor o usuario)
                        // MEJORA #9: IndexOf es más eficiente que ToLower().Contains()
                        if (hasSearch)
                        {
                            bool matches = file.FileName.IndexOf(searchText, StringComparison.OrdinalIgnoreCase) >= 0 ||
                                          file.Author.IndexOf(searchText, StringComparison.OrdinalIgnoreCase) >= 0 ||
                                          file.Username.IndexOf(searchText, StringComparison.OrdinalIgnoreCase) >= 0;
                            if (!matches)
                            {
                                filteredBySearch++;
                                continue;
                            }
                        }

                        // Verificar existencia (con cache)
                        var fullPath = GetDownloadPath(file.FileName, file.Author);
                        if (!existsCache.TryGetValue(fullPath, out bool fileExists))
                        {
                            fileExists = IsFileDownloaded(fullPath);
                            existsCache[fullPath] = fileExists;
                        }
                        
                        if (fileExists) existingCount++;
                        else pendingCount++;

                        string status = fileExists ? "✓ Descargado" : "⏳ Pendiente";
                        var statusColor = fileExists ? Color.LightGreen : Color.LightGray;

                        // OPTIMIZACIÓN: Cachear extensión para no calcularla dos veces
                        string extension = Path.GetExtension(file.FileName).ToLower();
                        
                        var item = new ListViewItem(status) { ForeColor = statusColor, Tag = file };
                        item.SubItems.Add(file.Author);
                        item.SubItems.Add(file.FileName);
                        item.SubItems.Add(extension);
                        item.SubItems.Add(file.SizeReadable);
                        item.SubItems.Add(file.Username);
                        item.SubItems.Add(file.Directory);
                        item.SubItems.Add(file.IsSpanish ? "Sí" : "No");
                        item.SubItems.Add(file.IsDocument ? "Sí" : "No");
                        item.SubItems.Add(file.Timestamp.ToString("yyyy-MM-dd HH:mm:ss"));
                        
                        // ✅ Marcar como seleccionado si está pendiente (no descargado)
                        item.Checked = !fileExists;
                        
                        lvFiles.Items.Add(item);
                        displayedCount++;
                        
                        // Límite de visualización para evitar problemas de rendimiento
                        if (displayedCount >= MAX_DISPLAY_ITEMS)
                        {
                            // LogDownload se declara después, se mostrará en lblStats
                            break;
                        }
                    }

                    var totalFiles = files.Count;
                    var hiddenFiles = totalFiles - displayedCount;
                    var statsText = $"Mostrando: {displayedCount:N0}";
                    if (hiddenFiles > 0) statsText += $" (⚠️ {hiddenFiles:N0} ocultos - usa filtros)";
                    statsText += $" | Descargados: {existingCount:N0} | Pendientes: {pendingCount:N0} | Seleccionados: 0";
                    lblStats.Text = statsText;
                    
                    // Actualizar label de resultados de búsqueda
                    if (hasSearch)
                    {
                        lblSearchResults.Text = filteredBySearch > 0 
                            ? $"({filteredBySearch} filtrados por búsqueda)" 
                            : "";
                    }
                    else
                    {
                        lblSearchResults.Text = "";
                    }
                    
                    updateGlobalStats();
                }
                finally
                {
                    lvFiles.EndUpdate(); // Optimización: reanudar redibujado
                }
            };

            loadData("");
            
            // Event handler para búsqueda en tiempo real con debounce
            txtSearch.TextChanged += (s, e) =>
            {
                searchDebounceTimer?.Dispose();
                searchDebounceTimer = new System.Threading.Timer(_ => 
                {
                    SafeInvoke(() => loadData(txtSearch.Text));
                }, null, 300, Timeout.Infinite); // 300ms delay
            };
            LogDownload("✅ Ventana de descargas iniciada");

            // Configurar event handlers que necesitaban LogDownload
            HookNumericSave(numSimultaneous, () =>
            {
                maxSimultaneousDownloads = (int)numSimultaneous.Value;
                if (downloadManager?.Config != null)
                {
                    downloadManager.Config.MaxSimultaneousDownloads = maxSimultaneousDownloads;
                }
                SaveConfig();
            });
            HookNumericSave(numQueueInterval, () =>
            {
                queuePositionRefreshIntervalSeconds = (int)numQueueInterval.Value;
                if (downloadManager?.Config != null)
                {
                    downloadManager.Config.QueuePositionRefreshIntervalSeconds = queuePositionRefreshIntervalSeconds;
                }
                SaveConfig();
            });
            HookNumericSave(numRetryConnInterval, () =>
            {
                retryConnectionIntervalSeconds = (int)numRetryConnInterval.Value;
                if (downloadManager?.Config != null)
                {
                    downloadManager.Config.RetryConnectionIntervalSeconds = retryConnectionIntervalSeconds;
                }
                SaveConfig();
            });
            HookNumericSave(numRetryIoInterval, () =>
            {
                retryIoIntervalSeconds = (int)numRetryIoInterval.Value;
                if (downloadManager?.Config != null)
                {
                    downloadManager.Config.RetryIoIntervalSeconds = retryIoIntervalSeconds;
                }
                SaveConfig();
            });
            HookNumericSave(numCleanupInterval, () =>
            {
                cleanupIntervalSeconds = (int)numCleanupInterval.Value;
                if (downloadManager?.Config != null)
                {
                    downloadManager.Config.CleanupIntervalSeconds = cleanupIntervalSeconds;
                }
                SaveConfig();
            });
            HookNumericSave(numSpeedLimit, () =>
            {
                downloadSpeedLimitKib = (int)numSpeedLimit.Value;
                if (downloadManager?.Config != null)
                {
                    downloadManager.Config.DownloadSpeedLimitKiB = downloadSpeedLimitKib;
                }
                SaveConfig();
            });
            HookNumericSave(numRetryBackoff, () =>
            {
                retryBackoffMilliseconds = (int)numRetryBackoff.Value;
                if (downloadManager?.Config != null)
                {
                    downloadManager.Config.RetryBackoffMilliseconds = retryBackoffMilliseconds;
                }
                SaveConfig();
            });
            chkAutoStartOnEnqueue.CheckedChanged += (s, e) =>
            {
                autoStartDownloadsOnEnqueue = chkAutoStartOnEnqueue.Checked;
                LogDownload($"▶️ Auto iniciar al encolar: {(autoStartDownloadsOnEnqueue ? "ON" : "OFF")}");
                SaveConfig();
            };

            btnBrowseIncompleteDir.Click += (s, e) =>
            {
                using var dialog = new FolderBrowserDialog
                {
                    Description = "Selecciona la carpeta para archivos incompletos",
                    SelectedPath = string.IsNullOrWhiteSpace(incompleteDownloadsDirectory) ? downloadDir : incompleteDownloadsDirectory
                };
                if (dialog.ShowDialog(this) == DialogResult.OK)
                {
                    incompleteDownloadsDirectory = dialog.SelectedPath;
                    txtIncompleteDir.Text = incompleteDownloadsDirectory;
                    if (downloadManager?.Config != null)
                    {
                        downloadManager.Config.IncompleteDownloadsDirectory = incompleteDownloadsDirectory;
                    }
                    SaveConfig();
                }
            };

            btnTestPostDownloadCommand.Click += (s, e) =>
            {
                string preview = (txtPostDownloadCommand.Text ?? string.Empty)
                    .Replace("{file}", "C:\\ruta\\archivo.mp3")
                    .Replace("{user}", "usuario")
                    .Replace("{size}", "5 MB");
                DarkMessageBox.Show($"Ejemplo de comando:\n\n{preview}", "Vista previa", MessageBoxButtons.OK, MessageBoxIcon.Information);
            };

            txtIncompleteDir.Leave += (s, e) =>
            {
                incompleteDownloadsDirectory = txtIncompleteDir.Text.Trim();
                if (downloadManager?.Config != null)
                {
                    downloadManager.Config.IncompleteDownloadsDirectory = incompleteDownloadsDirectory;
                }
                SaveConfig();
            };

            txtPostDownloadCommand.Leave += (s, e) =>
            {
                postDownloadCommand = txtPostDownloadCommand.Text?.Trim() ?? string.Empty;
                if (downloadManager?.Config != null)
                {
                    downloadManager.Config.PostDownloadCommand = postDownloadCommand;
                }
                SaveConfig();
            };

            txtDownloadFilter.Leave += (s, e) =>
            {
                downloadFilterPattern = txtDownloadFilter.Text?.Trim() ?? string.Empty;
                if (downloadManager?.Config != null)
                {
                    downloadManager.Config.DownloadFilterPattern = downloadFilterPattern;
                }
                SaveConfig();
            };

            btnApplyConfig.Click += (s, e) =>
            {
                maxSimultaneousDownloads = (int)numSimultaneous.Value;
                queuePositionRefreshIntervalSeconds = (int)numQueueInterval.Value;
                retryConnectionIntervalSeconds = (int)numRetryConnInterval.Value;
                retryIoIntervalSeconds = (int)numRetryIoInterval.Value;
                cleanupIntervalSeconds = (int)numCleanupInterval.Value;
                downloadSpeedLimitKib = (int)numSpeedLimit.Value;
                retryBackoffMilliseconds = (int)numRetryBackoff.Value;
                incompleteDownloadsDirectory = txtIncompleteDir.Text?.Trim() ?? string.Empty;
                postDownloadCommand = txtPostDownloadCommand.Text?.Trim() ?? string.Empty;
                downloadFilterPattern = txtDownloadFilter.Text?.Trim() ?? string.Empty;

                if (downloadManager?.Config != null)
                {
                    var cfg = downloadManager.Config;
                    cfg.MaxSimultaneousDownloads = maxSimultaneousDownloads;
                    cfg.QueuePositionRefreshIntervalSeconds = queuePositionRefreshIntervalSeconds;
                    cfg.RetryConnectionIntervalSeconds = retryConnectionIntervalSeconds;
                    cfg.RetryIoIntervalSeconds = retryIoIntervalSeconds;
                    cfg.CleanupIntervalSeconds = cleanupIntervalSeconds;
                    cfg.DownloadSpeedLimitKiB = downloadSpeedLimitKib;
                    cfg.RetryBackoffMilliseconds = retryBackoffMilliseconds;
                    cfg.IncompleteDownloadsDirectory = incompleteDownloadsDirectory;
                    cfg.PostDownloadCommand = postDownloadCommand;
                    cfg.DownloadFilterPattern = downloadFilterPattern;
                }

                SaveConfig();

                DarkMessageBox.Show($"Configuración aplicada:\n\nDescargas simultáneas: {maxSimultaneousDownloads}\nCola remota: {queuePositionRefreshIntervalSeconds}s\nReintentos red: {retryConnectionIntervalSeconds}s\nReintentos IO: {retryIoIntervalSeconds}s\nLímite velocidad: {(downloadSpeedLimitKib <= 0 ? "Sin límite" : downloadSpeedLimitKib + " KiB/s")}", "Configuración", MessageBoxButtons.OK, MessageBoxIcon.Information);
                LogDownload($"✅ Configuración aplicada: {maxSimultaneousDownloads} descargas simultáneas, límite {(downloadSpeedLimitKib <= 0 ? "sin límite" : downloadSpeedLimitKib + " KiB/s")}");
            };

            btnApplyConfig.Click += (s, e) =>
            {
                DarkMessageBox.Show($"Configuración aplicada:\n\nDescargas simultáneas: {maxSimultaneousDownloads}\nCola remota: {queuePositionRefreshIntervalSeconds}s\nReintentos red: {retryConnectionIntervalSeconds}s\nReintentos IO: {retryIoIntervalSeconds}s\nLímite velocidad: {(downloadSpeedLimitKib <= 0 ? "Sin límite" : downloadSpeedLimitKib + " KiB/s")}", "Configuración", MessageBoxButtons.OK, MessageBoxIcon.Information);
                LogDownload($"✅ Configuración aplicada: {maxSimultaneousDownloads} descargas simultáneas, límite {downloadSpeedLimitKib} KiB/s");
                SaveConfig();
                downloadManager?.UpdateRetryPolicy(maxRetries, maxAlternativeRetries, maxTotalAttempts, providerBlacklistThreshold, providerBlacklistHours);
            };

            // Debounce timer para búsqueda (optimización)
            // Event handlers para filtros
            chkOnlyDocs.CheckedChanged += (s, e) => { loadData(""); LogDownload($"📚 Filtro documentos: {(chkOnlyDocs.Checked ? "ON" : "OFF")}"); };
            numMinSizeKB.ValueChanged += (s, e) => { loadData(""); LogDownload($"📏 Tamaño mínimo: {numMinSizeKB.Value:N0} KB"); };
            
            // Event handler para simular checkbox del filtro español
            lblOnlySpanish.Click += (s, e) => {
                spanishChecked = !spanishChecked;
                lblOnlySpanish.Text = spanishChecked ? "[✓] Solo Español" : "[ ] Solo Español";
                loadData(""); 
                LogDownload($"🇪🇸 Filtro español: {(spanishChecked ? "ON" : "OFF")}");
            };
            
            // Event handler para hover del filtro español
            lblOnlySpanish.MouseEnter += (s, e) => {
                lblOnlySpanish.ForeColor = Color.LightGray;
            };
            
            lblOnlySpanish.MouseLeave += (s, e) => {
                lblOnlySpanish.ForeColor = Color.White;
            };

            lblOnlySpanish.Paint += (s, e) => {
                lblOnlySpanish.ForeColor = Color.White;
            };
            lblOnlySpanish.HandleCreated += (s, e) => {
                lblOnlySpanish.ForeColor = Color.White;
            };
            lblOnlySpanish.ParentChanged += (s, e) => {
                lblOnlySpanish.ForeColor = Color.White;
            };
            lblOnlySpanish.TextChanged += (s, e) => {
                lblOnlySpanish.ForeColor = Color.White;
            };

            // Menú contextual para ignorar autores
            var contextMenu = new ContextMenuStrip
            {
                BackColor = Color.FromArgb(40, 40, 40),
                ForeColor = Color.White
            };

            var menuIgnoreAuthor = new ToolStripMenuItem("🚫 Ignorar este autor");
            menuIgnoreAuthor.Click += (s, e) =>
            {
                if (lvFiles.SelectedItems.Count > 0)
                {
                    var selectedItem = lvFiles.SelectedItems[0];
                    var file = (AutoSearchFileResult)selectedItem.Tag;
                    
                    var result = MessageBox.Show(
                        $"¿Ignorar todos los archivos del autor '{file.Author}'?\n\nEsto agregará el autor a la blacklist y filtrará sus archivos en futuras búsquedas.",
                        "Ignorar Autor",
                        MessageBoxButtons.YesNo,
                        MessageBoxIcon.Question);
                    
                    if (result == DialogResult.Yes)
                    {
                        AddToBlacklist(file.Author);
                        
                        // Eliminar archivos del autor de autoSearchResults
                        lock (autoSearchResultsLock)
                        {
                            int removedCount = autoSearchResults.RemoveAll(f => 
                                f.Author.Equals(file.Author, StringComparison.OrdinalIgnoreCase));
                            LogDownload($"🗑️ Eliminados {removedCount} archivos de {file.Author} de la memoria");
                        }
                        
                        // Recargar grilla sin el autor ignorado
                        loadData("");
                        
                        // Guardar CSV actualizado sin el autor ignorado
                        SaveAutoResultsToCsv();
                        
                        ShowNotification("Autor Ignorado", 
                            $"'{file.Author}' agregado a la blacklist\n\nLa lista se ha actualizado automáticamente.", 
                            ToolTipIcon.Warning);
                        
                        LogDownload($"⛔ Autor '{file.Author}' agregado a blacklist y eliminado de la lista");
                        LogDownload($"💾 CSV actualizado - autor eliminado del archivo");
                    }
                }
            };
            contextMenu.Items.Add(menuIgnoreAuthor);

            lvFiles.ContextMenuStrip = contextMenu;

            // Event handlers
            btnLoadAuthorsFile.Click += async (s, e) =>
            {
                try
                {
                    LogDownload("═══════════════════════════════════════════════════");
                    LogDownload("📂 CARGA DE LISTA DE AUTORES");
                    LogDownload("═══════════════════════════════════════════════════");
                    LogDownload("⏳ Abriendo diálogo de selección de archivo...");
                    
                    var initialDir = !string.IsNullOrEmpty(lastAuthorsFilePath) ? Path.GetDirectoryName(lastAuthorsFilePath) : "";
                    var filePath = DarkFileDialog.ShowOpenDialog(this, "Seleccionar archivo de autores", "Archivos de texto (*.txt)|*.txt|Todos los archivos (*.*)|*.*", initialDir);
                    
                    if (!string.IsNullOrWhiteSpace(filePath))
                    {
                        LogDownload($"📁 Archivo seleccionado: {filePath}");
                        LogDownload($"📏 Tamaño: {new FileInfo(filePath).Length / 1024.0:F2} KB");
                        
                        lastVaciarAuthorsFilePath = filePath;
                        // No guardar en configuración - Vaciar usa su propia ruta
                        LogDownload("💾 Ruta cargada para Vaciar");
                        
                        // Cargar lista de autores
                        LogDownload("⏳ Leyendo archivo...");
                        authorsList = System.IO.File.ReadAllLines(filePath)
                            .Where(line => !string.IsNullOrWhiteSpace(line))
                            .Select(line => line.Trim())
                            .ToList();
                        
                        currentAuthorIndex = 0;
                        
                        LogDownload($"✅ {authorsList.Count} autores cargados en la lista");
                        LogDownload($"📌 Usa el botón '▶️ Comenzar' para iniciar la búsqueda");
                        LogDownload("═══════════════════════════════════════════════════");
                        
                        // Habilitar botón Siguiente
                        btnNextAuthor.Enabled = true;
                        btnNextAuthor.Text = $"🔄 Actualizar (1/{authorsList.Count})";
                    }
                    else
                    {
                        LogDownload("❌ Selección de archivo cancelada por el usuario");
                    }
                }
                catch (Exception ex)
                {
                    LogDownload("═══════════════════════════════════════════════════");
                    LogDownload($"❌ ERROR CRÍTICO: {ex.Message}");
                    LogDownload($"📍 Stack trace: {ex.StackTrace}");
                    LogDownload("═══════════════════════════════════════════════════");
                    DarkMessageBox.Show($"Error al cargar archivo: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            };

            btnNextAuthor.Click += async (s, e) =>
            {
                try
                {
                    if (currentAuthorIndex >= authorsList.Count)
                    {
                        LogDownload("═══════════════════════════════════════════════════");
                        LogDownload("✅ TODOS LOS AUTORES PROCESADOS");
                        LogDownload("═══════════════════════════════════════════════════");
                        btnNextAuthor.Enabled = false;
                        return;
                    }

                    string currentAuthor = authorsList[currentAuthorIndex];
                    
                    LogDownload("═══════════════════════════════════════════════════");
                    LogDownload($"🔍 BUSCANDO AUTOR {currentAuthorIndex + 1}/{authorsList.Count}");
                    LogDownload($"👤 Autor: {currentAuthor}");
                    LogDownload("═══════════════════════════════════════════════════");

                    // Validar conexión
                    if (client == null || !client.State.HasFlag(SoulseekClientStates.Connected))
                    {
                        LogDownload("❌ ERROR: No conectado a Soulseek");
                        DarkMessageBox.Show("Debes estar conectado a Soulseek.\n\nConéctate desde la pestaña principal primero.", "No conectado", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                        return;
                    }

                    // Limpiar resultados anteriores de la grilla
                    lock (autoSearchResultsLock)
                    {
                        autoSearchResults.Clear();
                    }
                    loadData("");
                    LogDownload("🗑️ Grilla limpiada");

                    // Buscar archivos del autor actual REPETIDAMENTE hasta que no haya nuevos
                    LogDownload($"⏳ Buscando archivos de '{currentAuthor}' (búsqueda exhaustiva)...");
                    var searchStart = DateTime.Now;
                    
                    int totalNewFiles = 0;
                    int searchIteration = 0;
                    int consecutiveEmptySearches = 0;
                    const int MAX_EMPTY_SEARCHES = 1; // Solo 1 búsqueda por autor para mayor velocidad
                    
                    var seenFiles = new HashSet<string>(5000); // Pre-allocar para ~5k archivos
                    
                    while (consecutiveEmptySearches < MAX_EMPTY_SEARCHES)
                    {
                        searchIteration++;
                        LogDownload($"🔄 Búsqueda #{searchIteration}...");
                        
                        var searchResponse = await client.SearchAsync(SearchQuery.FromText(currentAuthor));
                        lastActivityTime = DateTime.UtcNow; // Sticky session
                        int totalUsers = searchResponse.Responses.Count;
                        
                        // OPTIMIZACIÓN: Cachear DateTime.Now (costoso si se llama miles de veces)
                        var timestamp = DateTime.Now;
                        
                        // Batch processing: procesar archivos en lote antes del lock
                        var newFilesToAdd = new List<AutoSearchFileResult>(1000); // Pre-allocar
                        int newFilesThisIteration = 0;
                        
                        foreach (var response in searchResponse.Responses)
                        {
                            // Filtrar usuarios de blacklist
                            if (blacklist.Contains(response.Username))
                                continue;
                            
                            foreach (var file in response.Files)
                            {
                                // MEJORA #23: Usar interpolación para mejor rendimiento que Concat
                                string fileKey = $"{response.Username}|{file.Filename}|{file.Size}";
                                
                                if (seenFiles.Contains(fileKey))
                                    continue; // Ya lo tenemos
                                
                                seenFiles.Add(fileKey);
                                
                                // OPTIMIZACIÓN: ToLowerInvariant es más rápido que ToLower
                                string filenameLower = file.Filename.ToLowerInvariant();
                                
                                // Usar IndexOf con StringComparison para mejor rendimiento
                                bool isSpanish = filenameLower.IndexOf("spanish", StringComparison.Ordinal) >= 0 || 
                                               filenameLower.IndexOf("español", StringComparison.Ordinal) >= 0 ||
                                               filenameLower.IndexOf("castellano", StringComparison.Ordinal) >= 0;
                                
                                bool isDocument = filenameLower.EndsWith(".pdf") ||
                                                filenameLower.EndsWith(".epub") ||
                                                filenameLower.EndsWith(".mobi");

                                // OPTIMIZACIÓN: Cachear operaciones de Path
                                string fileName = Path.GetFileName(file.Filename);
                                string directory = Path.GetDirectoryName(file.Filename) ?? "";

                                // Preparar objeto fuera del lock
                                newFilesToAdd.Add(new AutoSearchFileResult
                                {
                                    Author = currentAuthor,
                                    Username = response.Username,
                                    FileName = fileName,
                                    Directory = directory,
                                    SizeBytes = file.Size,
                                    SizeReadable = FormatFileSize(file.Size),
                                    IsSpanish = isSpanish,
                                    IsDocument = isDocument,
                                    Timestamp = timestamp  // Usar timestamp cacheado
                                });
                                newFilesThisIteration++;
                                totalNewFiles++;
                            }
                        }
                        
                        // OPTIMIZACIÓN: Un solo lock para agregar todos los archivos
                        if (newFilesToAdd.Count > 0)
                        {
                            lock (autoSearchResultsLock)
                            {
                                autoSearchResults.AddRange(newFilesToAdd);
                            }
                        }
                        
                        LogDownload($"   📊 {totalUsers} usuarios, {newFilesThisIteration} archivos nuevos");
                        
                        if (newFilesThisIteration == 0)
                        {
                            consecutiveEmptySearches++;
                            LogDownload($"   ⚠️ Sin resultados nuevos ({consecutiveEmptySearches}/{MAX_EMPTY_SEARCHES})");
                        }
                        else
                        {
                            consecutiveEmptySearches = 0; // Resetear contador
                            // OPTIMIZACIÓN: Actualizar grilla solo cada 2 iteraciones con resultados
                            if (searchIteration % 2 == 0)
                            {
                                loadData("");
                            }
                        }
                        
                        // Pequeña pausa entre búsquedas para no saturar
                        await Task.Delay(500);
                    }

                    var searchDuration = (DateTime.Now - searchStart).TotalSeconds;
                    LogDownload($"✅ BÚSQUEDA COMPLETADA:");
                    LogDownload($"   • {searchIteration} búsquedas realizadas");
                    LogDownload($"   • {totalNewFiles} archivos únicos encontrados");
                    LogDownload($"   • Duración: {searchDuration:F1}s");
                    
                    // Actualizar grilla final
                    loadData("");
                    LogDownload("📊 Grilla actualizada con todos los resultados");

                    // Avanzar al siguiente autor
                    currentAuthorIndex++;
                    
                    if (currentAuthorIndex < authorsList.Count)
                    {
                        btnNextAuthor.Text = $"🔄 Actualizar ({currentAuthorIndex + 1}/{authorsList.Count})";
                        LogDownload($"📌 Siguiente autor preparado");
                    }
                    else
                    {
                        btnNextAuthor.Text = "✅ Completado";
                        btnNextAuthor.Enabled = false;
                        LogDownload("═══════════════════════════════════════════════════");
                        LogDownload("🎉 TODOS LOS AUTORES PROCESADOS");
                        LogDownload("═══════════════════════════════════════════════════");
                        
                        // Notificación de finalización
                        ShowNotification("Búsqueda Completada", 
                            $"Se procesaron {authorsList.Count} autores. Total archivos: {totalNewFiles}", 
                            ToolTipIcon.Info);
                    }
                    
                    LogDownload("═══════════════════════════════════════════════════");
                }
                catch (Exception ex)
                {
                    LogDownload($"❌ ERROR: {ex.Message}");
                    DarkMessageBox.Show($"Error al buscar autor: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            };

            btnDownloadSelected.Click += async (s, e) =>
            {
                var checkedItems = lvFiles.CheckedItems.Cast<ListViewItem>().ToList();
                if (checkedItems.Count == 0)
                {
                    DarkMessageBox.Show("Selecciona al menos un archivo para descargar", "Descargar", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    return;
                }

                var downloadPath = txtDownloadDir?.Text ?? Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments), "SlskDown");
                
                // Verificar cuántos archivos ya existen
                int existingFiles = 0;
                int newFiles = 0;
                foreach (ListViewItem item in checkedItems)
                {
                    var file = (AutoSearchFileResult)item.Tag;
                    var fullPath = GetDownloadPath(file.FileName, file.Author);
                    if (IsFileDownloaded(fullPath))
                        existingFiles++;
                    else
                        newFiles++;
                }

                if (existingFiles > 0 && newFiles == 0)
                {
                    DarkMessageBox.Show(
                        $"Todos los archivos seleccionados ({existingFiles}) ya existen.\n\nUsa el botón '🔄 Redescargar' para descargarlos de nuevo.",
                        "Archivos existentes",
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Information
                    );
                    LogDownload($"⚠️ {existingFiles} archivo(s) ya descargado(s), omitidos");
                    return;
                }

                string message = newFiles == checkedItems.Count
                    ? $"¿Descargar {newFiles} archivo(s)?"
                    : $"¿Descargar {newFiles} archivo(s) nuevo(s)?\n({existingFiles} ya descargado(s) serán omitidos)";

                var result = MessageBox.Show(message, "Confirmar descarga", MessageBoxButtons.YesNo, MessageBoxIcon.Question);

                if (result == DialogResult.Yes)
                {
                    LogDownload("═══════════════════════════════════════════════════");
                    LogDownload("📥 INICIANDO PROCESO DE DESCARGA");
                    LogDownload("═══════════════════════════════════════════════════");
                    LogDownload($"📊 Estadísticas:");
                    LogDownload($"   • Archivos seleccionados: {checkedItems.Count:N0}");
                    LogDownload($"   • Archivos nuevos a descargar: {newFiles:N0}");
                    LogDownload($"   • Archivos ya descargados (omitidos): {existingFiles:N0}");
                    LogDownload($"📁 Carpeta de destino: {downloadPath}");
                    LogDownload($"⏰ Hora de inicio: {DateTime.Now:HH:mm:ss}");
                    LogDownload("───────────────────────────────────────────────────");
                    
                    int downloaded = 0;
                    int skipped = 0;

                    // Crear directorio si no existe
                    if (!System.IO.Directory.Exists(downloadPath))
                    {
                        System.IO.Directory.CreateDirectory(downloadPath);
                        LogDownload($"📂 Carpeta creada: {downloadPath}");
                    }

                    foreach (ListViewItem item in checkedItems)
                    {
                        var file = (AutoSearchFileResult)item.Tag;
                        var fullPath = GetDownloadPath(file.FileName, file.Author);
                        
                        if (IsFileDownloaded(fullPath))
                        {
                            LogDownload($"  ⏭️ Omitido (ya existe): {file.FileName}");
                            skipped++;
                        }
                        else
                        {
                            LogDownload($"  📋 Agregando a cola: {file.FileName} ({file.SizeReadable})");
                            AddToDownloadQueue(file, fullPath, item);
                            downloaded++;
                        }
                    }
                    
                    LogDownload("───────────────────────────────────────────────────");
                    LogDownload($"✅ PROCESO COMPLETADO");
                    LogDownload($"📊 Resumen:");
                    LogDownload($"   • Agregados a cola: {downloaded:N0}");
                    LogDownload($"   • Omitidos (ya existen): {skipped:N0}");
                    LogDownload($"   • Total procesados: {checkedItems.Count:N0}");
                    LogDownload($"⏰ Hora de finalización: {DateTime.Now:HH:mm:ss}");
                    LogDownload("═══════════════════════════════════════════════════");
                    LogDownload($"🚀 Las descargas comenzarán automáticamente");
                    LogDownload($"📊 Límite de descargas simultáneas: {maxSimultaneousDownloads}");
                    LogDownload("═══════════════════════════════════════════════════");
                    
                    await Task.Delay(500);
                    loadData(""); // Actualizar lista
                }
            };

            btnRedownload.Click += async (s, e) =>
            {
                var checkedItems = lvFiles.CheckedItems.Cast<ListViewItem>().ToList();
                if (checkedItems.Count == 0)
                {
                    DarkMessageBox.Show("Selecciona al menos un archivo para redescargar", "Redescargar", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    return;
                }

                var result = DarkMessageBox.Show(
                    $"¿Redescargar {checkedItems.Count} archivo(s)?\n\nEsto sobrescribirá los archivos existentes.",
                    "Confirmar redescargar",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Warning
                );

                if (result == DialogResult.Yes)
                {
                    var downloadPath = txtDownloadDir?.Text ?? Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments), "SlskDown");
                    
                    if (!System.IO.Directory.Exists(downloadPath))
                    {
                        System.IO.Directory.CreateDirectory(downloadPath);
                    }

                    LogDownload($"🔄 Recomenzando descarga de {checkedItems.Count} archivo(s)...");
                    foreach (ListViewItem item in checkedItems)
                    {
                        var file = (AutoSearchFileResult)item.Tag;
                        var fullPath = GetDownloadPath(file.FileName, file.Author);
                        
                        // Eliminar archivo existente si existe
                        if (IsFileDownloaded(fullPath))
                        {
                            try
                            {
                                System.IO.File.Delete(fullPath);
                                LogDownload($"  🗑️ Eliminado archivo existente: {file.FileName}");
                            }
                            catch (Exception ex)
                            {
                                LogDownload($"  ⚠️ No se pudo eliminar {file.FileName}: {ex.Message}");
                            }
                        }
                        
                        LogDownload($"  📋 Agregando a cola: {file.FileName} ({file.SizeReadable})");
                        AddToDownloadQueue(file, fullPath, item, true);
                    }
                    LogDownload($"✅ {checkedItems.Count} descarga(s) reiniciada(s)");
                    await Task.Delay(500);
                    loadData(""); // Actualizar lista
                }
            };

            btnStopDownload.Click += (s, e) =>
            {
                PauseAllDownloads();
                LogDownload("⏸️ Todas las descargas pausadas");
            };

            btnResumeDownload.Click += (s, e) =>
            {
                ResumeAllDownloads();
                LogDownload("▶️ Descargas reanudadas");
            };

            btnOpenFolder.Click += (s, e) =>
            {
                try
                {
                    var downloadPath = txtDownloadDir?.Text ?? Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments), "SlskDown");
                    if (System.IO.Directory.Exists(downloadPath))
                    {
                        Process.Start(new ProcessStartInfo { FileName = downloadPath, UseShellExecute = true });
                        LogDownload($"📂 Abriendo carpeta: {downloadPath}");
                    }
                    else
                    {
                        DarkMessageBox.Show($"La carpeta no existe: {downloadPath}", "Abrir Carpeta", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                        LogDownload($"⚠️ Carpeta no encontrada: {downloadPath}");
                    }
                }
                catch (Exception ex)
                {
                    LogDownload($"❌ Error al abrir carpeta: {ex.Message}");
                }
            };

            btnExport.Click += (s, e) =>
            {
                var exportForm = new Form
                {
                    Text = "Exportar Resultados",
                    Size = new Size(400, 250),
                    StartPosition = FormStartPosition.CenterParent,
                    BackColor = Color.FromArgb(30, 30, 30),
                    FormBorderStyle = FormBorderStyle.FixedDialog,
                    MaximizeBox = false,
                    MinimizeBox = false
                };

                var lblTitle = new Label
                {
                    Text = "Selecciona formato de exportación:",
                    Location = new Point(20, 20),
                    AutoSize = true,
                    ForeColor = Color.White,
                    Font = new Font("Segoe UI", 10, FontStyle.Bold)
                };
                exportForm.Controls.Add(lblTitle);

                var btnExportHTML = CreateButton("📄 HTML Interactivo", Color.FromArgb(0, 120, 215));
                btnExportHTML.Location = new Point(20, 60);
                btnExportHTML.Width = 340;
                btnExportHTML.Click += (se, ev) =>
                {
                    ExportToHTML(lvFiles);
                    LogDownload("💾 Exportado a HTML");
                    exportForm.Close();
                };
                exportForm.Controls.Add(btnExportHTML);

                var btnExportJSON = CreateButton("📋 JSON", Color.FromArgb(100, 60, 150));
                btnExportJSON.Location = new Point(20, 100);
                btnExportJSON.Width = 340;
                btnExportJSON.Click += (se, ev) =>
                {
                    SaveAutoResultsToJson();
                    LogDownload("💾 Exportado a JSON");
                    DarkMessageBox.Show($"Exportado a:\n{autoSearchResultsJsonPath}", "Exportar JSON", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    exportForm.Close();
                };
                exportForm.Controls.Add(btnExportJSON);

                var btnExportCSV = CreateButton("📊 CSV (Excel)", Color.FromArgb(0, 150, 0));
                btnExportCSV.Location = new Point(20, 140);
                btnExportCSV.Width = 340;
                btnExportCSV.Click += (se, ev) =>
                {
                    SaveAutoResultsToCsv();
                    LogDownload("💾 Exportado a CSV");
                    DarkMessageBox.Show($"Exportado a:\n{autoResultsCsvPath}", "Exportar CSV", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    exportForm.Close();
                };
                exportForm.Controls.Add(btnExportCSV);

                var btnCancelExport = CreateButton("❌ Cancelar", Color.FromArgb(150, 0, 0));
                btnCancelExport.Location = new Point(20, 180);
                btnCancelExport.Width = 340;
                btnCancelExport.Click += (se, ev) => exportForm.Close();
                exportForm.Controls.Add(btnCancelExport);

                exportForm.ShowDialog(downloadsForm);
            };

            btnClose.Click += (s, e) =>
            {
                LogDownload("❌ Cerrando ventana de descargas");
                downloadsForm.Close();
            };

            downloadsForm.Show();
        }

        private void LoadCarbarherCache(Action<string> log = null)
        {
            if (carbarherCacheLoaded)
                return;

            carbarherFilesCache.Clear();
            
            // Intentar cargar desde caché en disco
            if (System.IO.File.Exists(calibreCacheFile))
            {
                try
                {
                    log?.Invoke("💾 Cargando caché cbh comprimido desde disco...");
                    var sw = System.Diagnostics.Stopwatch.StartNew();
                    
                    // Descomprimir con GZip y leer líneas
                    using (var fileStream = new FileStream(calibreCacheFile, FileMode.Open, FileAccess.Read))
                    using (var gzipStream = new GZipStream(fileStream, CompressionMode.Decompress))
                    using (var reader = new StreamReader(gzipStream, Encoding.UTF8))
                    {
                        string line;
                        while ((line = reader.ReadLine()) != null)
                        {
                            if (!string.IsNullOrWhiteSpace(line))
                                carbarherFilesCache.Add(line.Trim());
                        }
                    }
                    
                    sw.Stop();
                    carbarherCacheLoaded = true;
                    log?.Invoke($"✅ Caché cbh cargado: {carbarherFilesCache.Count:N0} archivos en {sw.ElapsedMilliseconds}ms");
                    return;
                }
                catch (Exception ex)
                {
                    log?.Invoke($"⚠️ Error leyendo caché: {ex.Message}. Regenerando...");
                }
            }
            
            // Si no hay caché o falló, escanear carpeta
            if (!System.IO.Directory.Exists(carbarherPath))
            {
                log?.Invoke($"⚠️ Carpeta cbh no encontrada: {carbarherPath}");
                carbarherCacheLoaded = true;
                return;
            }

            try
            {
                log?.Invoke("📂 Iniciando escaneo carpeta cbh...");
                log?.Invoke($"   Ruta: {carbarherPath}");
                var sw = System.Diagnostics.Stopwatch.StartNew();
                
                // Usar EnumerateFiles para reducir uso de memoria (streaming)
                log?.Invoke("🔍 Enumerando archivos...");
                var enumerationStart = System.Diagnostics.Stopwatch.StartNew();
                var filesEnumerable = System.IO.Directory.EnumerateFiles(carbarherPath, "*.*", SearchOption.AllDirectories);
                var filesList = filesEnumerable.ToList(); // Materializar para contar
                enumerationStart.Stop();
                
                log?.Invoke($"✅ Enumeración completada: {filesList.Count:N0} archivos encontrados en {enumerationStart.ElapsedMilliseconds}ms");
                log?.Invoke("📊 Procesando archivos en paralelo...");
                
                var processingStart = System.Diagnostics.Stopwatch.StartNew();
                int processedCount = 0;
                int lastReportedCount = 0;
                var lockObj = new object();
                
                // Procesar en paralelo con PLINQ para mejor rendimiento
                var fileNames = filesList
                    .AsParallel()
                    .WithDegreeOfParallelism(Environment.ProcessorCount)
                    .Select((filePath, index) =>
                    {
                        var fileName = Path.GetFileName(filePath);
                        
                        // Reportar progreso thread-safe cada 1000 archivos
                        int currentCount;
                        lock (lockObj)
                        {
                            processedCount++;
                            currentCount = processedCount;
                        }
                        
                        if (currentCount - lastReportedCount >= 1000)
                        {
                            lock (lockObj)
                            {
                                if (currentCount - lastReportedCount >= 1000)
                                {
                                    var elapsed = processingStart.ElapsedMilliseconds;
                                    var rate = currentCount / (elapsed / 1000.0);
                                    var progress = (currentCount * 100.0) / filesList.Count;
                                    log?.Invoke($"   ⏳ {currentCount:N0}/{filesList.Count:N0} ({progress:F1}%) - {rate:F0} archivos/seg");
                                    lastReportedCount = currentCount;
                                }
                            }
                        }
                        
                        return fileName;
                    })
                    .ToList();
                
                // Agregar todos los nombres al HashSet de una vez
                foreach (var fileName in fileNames)
                {
                    carbarherFilesCache.Add(fileName);
                }
                
                processingStart.Stop();
                sw.Stop();
                carbarherCacheLoaded = true;
                
                // Estadísticas finales
                log?.Invoke($"✅ Procesamiento completado:");
                log?.Invoke($"   • Total archivos: {carbarherFilesCache.Count:N0}");
                log?.Invoke($"   • Tiempo enumeración: {enumerationStart.ElapsedMilliseconds:N0}ms");
                log?.Invoke($"   • Tiempo procesamiento: {processingStart.ElapsedMilliseconds:N0}ms");
                log?.Invoke($"   • Tiempo total: {sw.ElapsedMilliseconds:N0}ms ({sw.Elapsed.TotalSeconds:F1}s)");
                log?.Invoke($"   • Velocidad promedio: {(carbarherFilesCache.Count / sw.Elapsed.TotalSeconds):F0} archivos/seg");
                
                // Guardar caché en disco para próximas sesiones
                SaveCalibreCacheToDisk(log);
            }
            catch (Exception ex)
            {
                log?.Invoke($"❌ Error cargando caché cbh: {ex.Message}");
                carbarherCacheLoaded = true;
            }
        }

        private void SaveCalibreCacheToDisk(Action<string> log = null)
        {
            try
            {
                log?.Invoke("💾 Guardando caché comprimido en disco...");
                var sw = System.Diagnostics.Stopwatch.StartNew();
                
                // Comprimir con GZip para reducir tamaño
                using (var fileStream = new FileStream(calibreCacheFile, FileMode.Create, FileAccess.Write))
                using (var gzipStream = new GZipStream(fileStream, CompressionLevel.Optimal))
                using (var writer = new StreamWriter(gzipStream, Encoding.UTF8))
                {
                    foreach (var file in carbarherFilesCache)
                    {
                        writer.WriteLine(file);
                    }
                }
                
                sw.Stop();
                var fileInfo = new FileInfo(calibreCacheFile);
                var sizeKB = fileInfo.Length / 1024.0;
                log?.Invoke($"✅ Caché guardado: {calibreCacheFile} ({sizeKB:F1} KB, {sw.ElapsedMilliseconds}ms)");
            }
            catch (Exception ex)
            {
                log?.Invoke($"⚠️ No se pudo guardar caché: {ex.Message}");
            }
        }

