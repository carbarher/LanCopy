            SafeSetToolTip(lblAutoProgress, "📈 Progreso\nAvance del proceso actual (autores procesados / total)");
            SafeSetToolTip(btnClearLog, "🗑️ Limpiar log\nBorra todo el contenido del registro de actividad");
