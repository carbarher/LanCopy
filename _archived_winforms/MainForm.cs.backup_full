        // NUEVA OPTIMIZACIÓN: Caché de búsquedas de autores (evita re-buscar)
        private ConcurrentDictionary<string, (List<AutoSearchFileResult> results, DateTime cachedAt)> authorSearchCache 
            = new ConcurrentDictionary<string, (List<AutoSearchFileResult>, DateTime)>(StringComparer.OrdinalIgnoreCase);
        private TimeSpan searchCacheExpiration = TimeSpan.FromHours(24); // Caché válido por 24 horas
        private DateTime lastCacheCleanup = DateTime.UtcNow; // MEJORA #5: Timestamp de última limpieza
        
        // NUEVA OPTIMIZACIÓN: Paralelización de purga
        private int purgeBatchSize = 2; // Procesar 2 autores simultáneamente (optimizado para evitar desconexiones)
        private SemaphoreSlim purgeSemaphore = null; // Se inicializa dinámicamente
        
        // MEJORA #5: Limpieza automática de cachés antiguos
        private void CleanupExpiredCaches()
        {
            try
            {
                var now = DateTime.UtcNow;
                
                // Limpiar cada 30 minutos
                if ((now - lastCacheCleanup).TotalMinutes < 30)
                    return;
                
                lastCacheCleanup = now;
                int removedCount = 0;
                
                // Limpiar authorSearchCache
                var expiredKeys = authorSearchCache
                    .Where(kvp => (now - kvp.Value.cachedAt) > searchCacheExpiration)
                    .Select(kvp => kvp.Key)
                    .ToList();
                
                foreach (var key in expiredKeys)
                {
                    if (authorSearchCache.TryRemove(key, out _))
                        removedCount++;
                }
                
                if (removedCount > 0)
                {
                    AutoLog($"🧹 Limpieza de caché: {removedCount} entradas antiguas eliminadas (total: {authorSearchCache.Count})");
                }
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error en limpieza de caché: {ex.Message}");
            }
        }

        private void UpdateAutoControlsEnabled()
        {
            try
            {
                bool anyRunning = autoSearchRunning || autoPurgeRunning;
                
                AutoLog($"[DEBUG UpdateControls] autoSearchRunning={autoSearchRunning}, autoPurgeRunning={autoPurgeRunning}");

                if (btnStartAuto != null && btnStartAuto.IsHandleCreated)
                {
                    btnStartAuto.Enabled = !autoSearchRunning && !autoPurgeRunning;
                    AutoLog($"[DEBUG UpdateControls] btnStartAuto.Enabled={btnStartAuto.Enabled}");
                }

                if (btnPurge != null && btnPurge.IsHandleCreated)
                {
                    // Permitir purga incluso si hay búsqueda en curso
                    btnPurge.Enabled = !autoPurgeRunning;
                    AutoLog($"[DEBUG UpdateControls] btnPurge.Enabled={btnPurge.Enabled}");
                }

                if (btnStopAuto != null && btnStopAuto.IsHandleCreated)
                {
                    btnStopAuto.Enabled = anyRunning;
                    AutoLog($"[DEBUG UpdateControls] btnStopAuto.Enabled={btnStopAuto.Enabled}");
                }

                RefreshAutoSummary();
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error en UpdateAutoControlsEnabled: {ex.Message}");
            }
        }
        
        private async Task StartAutomaticSearch()
        {
            var checkedAuthors = GetCheckedAuthorsFromVirtualList();
            if (checkedAuthors.Length == 0)
            {
                AutoLog("⚠️ No hay autores seleccionados");
                DarkMessageBox.Show("Selecciona al menos un autor de la lista (usa los checkboxes)", "Búsqueda Automática", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }
            
            if (client == null)
            {
                AutoLog("❌ Cliente no inicializado");
                DarkMessageBox.Show("Debes conectarte a Soulseek primero", "Búsqueda Automática", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }
            
            // Verificar si está conectado (puede tener múltiples flags)
            bool isConnected = client.State.HasFlag(SoulseekClientStates.Connected) || 
                               client.State.HasFlag(SoulseekClientStates.LoggedIn);
            
            if (!isConnected)
            {
                AutoLog($"❌ No estás conectado a Soulseek (Estado: {client.State})");
                DarkMessageBox.Show($"Debes estar conectado a Soulseek\nEstado actual: {client.State}", "Búsqueda Automática", MessageBoxButtons.OK, MessageBoxIcon.Error);
                return;
            }
            
            AutoLog($"✅ Conectado (Estado: {client.State})");
            
            var selectedAuthors = checkedAuthors.ToList();
            
            // OPTIMIZACIÓN #10: Cargar checkpoint si existe
            selectedAuthors = await LoadCheckpointIfExists(selectedAuthors);
            
            autoSearchRunning = true;

            autoSearchCts?.Dispose();
            autoSearchCts = new CancellationTokenSource();
            var cancellationToken = autoSearchCts.Token;
            
            // Limpiar lista de autores excluidos al iniciar nueva búsqueda
            excludedAuthors.Clear();
            
            // Iniciar timer para actualizaciones UI en batch
            StartAutoSearchUIUpdateTimer();

            UpdateAutoControlsEnabled();
            
            AutoLog("");
            AutoLog("═══════════════════════════════════════");
            AutoLog("🚀 INICIANDO BÚSQUEDA AUTOMÁTICA");
            AutoLog($"📚 {selectedAuthors.Count} autores seleccionados");
            AutoLog("═══════════════════════════════════════");
            SafeInvoke(() => { if (lblPurgeProgress != null) { lblPurgeProgress.Visible = true; lblPurgeProgress.Text = $"⏳ 0/{selectedAuthors.Count} (0%) | Calculando..."; } });
            
            // También mostrar en log principal
            Log($"🚀 Iniciando búsqueda automática de {selectedAuthors.Count} autores");
            
            int round = 1;
            bool anyResultsFound = true;
            int totalNewFilesThisRound = 0;
            var authorNoResultsCount = new Dictionary<string, int>(selectedAuthors.Count);
            var authorUniqueFiles = new Dictionary<string, HashSet<string>>(selectedAuthors.Count); // Trackear archivos únicos por autor
            // MEJORA #24: Usar capacidad inicial estimada (promedio ~100 archivos por autor)
            var globalUniqueFiles = new HashSet<string>(selectedAuthors.Count * 100); // Todos los archivos únicos globales
            
            // Inicializar contador para cada autor y resetear contadores
            foreach (var author in selectedAuthors)
            {
                authorNoResultsCount[author] = 0;
                // MEJORA #24: Estimar ~100 archivos por autor
                authorUniqueFiles[author] = new HashSet<string>(100);
                
                // Resetear columnas de archivos y estado
                SafeBeginInvoke(() => UpdateAuthorInList(author, 0, "Listo", true));
            }
            
            try
            {
                while (selectedAuthors.Count > 0 && autoSearchRunning)
                {
                    AutoLog("");
                    AutoLog($"🔄 ═══ RONDA {round} ═══");
                    AutoLog($"👥 Buscando {selectedAuthors.Count} autores en paralelo ({MAX_PARALLEL_SEARCHES} simultáneos)...");
                    AutoLog($"🔍 DEBUG: selectedAuthors.Count={selectedAuthors.Count}, autoSearchRunning={autoSearchRunning}");
                    anyResultsFound = false;
                    totalNewFilesThisRound = 0;
                    var authorsToRemove = new List<string>();
                    var roundStopwatch = System.Diagnostics.Stopwatch.StartNew();
                    
                    // OPTIMIZACIÓN #1: Búsqueda paralela masiva (128 simultáneas = 16x más rápido)
                    using (var semaphore = new SemaphoreSlim(MAX_PARALLEL_SEARCHES, MAX_PARALLEL_SEARCHES))
                    {
                        var processedInRound = 0;
                        var totalInRound = selectedAuthors.Count;
                        var tasks = selectedAuthors.ToList().Select(async author =>
                        {
                            await semaphore.WaitAsync(cancellationToken);
                            try
                            {
                                if (!autoSearchRunning || cancellationToken.IsCancellationRequested)
                                {
                                    return;
                                }
                            
                            // Verificar si el autor fue excluido durante la búsqueda
                            if (excludedAuthors.Contains(author))
                            {
                                AutoLog($"⛔ Autor excluido, saltando: {author}");
                                UpdateAuthorStatus(author, "⛔ Excluido");
                                return;
                            }
                            
                            // OPTIMIZACIÓN #8: Skip autores sin resultados después de 5 intentos
                            if (noResultsAuthors.Contains(author))
                            {
                                AutoLog($"⏭️ Autor sin resultados, saltando: {author}");
                                UpdateAuthorStatus(author, "⏭️ Sin resultados");
                                return;
                            }
                            
                            // OPT #9: Skip autores sin obras en español (caché persistente)
                            if (authorsWithoutSpanishWorks.Contains(author))
                            {
                                AutoLog($"🚫 Autor sin español (caché), saltando: {author}");
                                UpdateAuthorStatus(author, "🚫 Sin español");
                                return;
                            }
                            
                            // OPTIMIZACIÓN #3: Verificar caché de búsquedas (24h)
                            if (authorSearchCache.TryGetValue(author, out var cachedSearch))
                            {
                                if ((DateTime.Now - cachedSearch.cachedAt).TotalHours < AUTHOR_CACHE_HOURS)
                                {
                                    AutoLog($"💾 Usando caché para: {author} ({cachedSearch.results.Count} archivos)");
                                    
                                    lock (autoSearchResultsLock)
                                    {
                                        autoSearchResults.AddRange(cachedSearch.results);
                                    }
                                    
                                    // CORRECCIÓN: Actualizar grilla para que los archivos cacheados sean visibles
                                    BuildAuthorIndex();
                                    
                                    UpdateAuthorStatus(author, $"💾 Caché ({cachedSearch.results.Count})");
                                    return;
                                }
                            }
                            
                            // Actualizar estado a "Buscando..."
                            SafeBeginInvoke(() => UpdateAuthorStatus(author, "🔍 Buscando..."));
                            
                            int uniqueNewFiles = 0;
                            
                            try
                            {
                                // MEJORA #15: Timeout reducido para mayor velocidad (1.5s si ya falló, 3s si no)
                                // MEJORA #8: TryGetValue es más eficiente que ContainsKey + indexer
                                int timeout = (authorNoResultsCount.TryGetValue(author, out int failCount) && failCount > 2)
                                    ? 1500  // MEJORA #15: Reducido de 2s a 1.5s
                                    : 3000; // MEJORA #15: Reducido de 4s a 3s
                                
                                var searchOptions = new Soulseek.SearchOptions(
                                    searchTimeout: timeout,  // Adaptativo: 2s o 4s
                                    maximumPeerQueueLength: 10000,  // Aumentado de 5000 a 10000
                                    filterResponses: true,
                                    minimumResponseFileCount: 1,
                                    minimumPeerUploadSpeed: 0
                                );
                                
                                // Búsqueda rápida: solo 1 búsqueda por autor para mayor velocidad
                                int searchIteration = 0;
                                int consecutiveEmptySearches = 0;
                                const int MAX_EMPTY_SEARCHES = 1;
                                
                                while (consecutiveEmptySearches < MAX_EMPTY_SEARCHES && autoSearchRunning && !cancellationToken.IsCancellationRequested)
                                {
                                    searchIteration++;
                                    
                                    // Esperar mientras esté pausado por desconexión
                                    while (autoSearchPausedByDisconnection && autoSearchRunning)
                                    {
                                        // MEJORA #37: ConfigureAwait(false) en loop crítico
                                        await Task.Delay(1000, cancellationToken).ConfigureAwait(false);
                                    }
                                    
                                    // Verificar cancelación antes de buscar
                                    if (!autoSearchRunning || cancellationToken.IsCancellationRequested)
                                    {
                                        return;
                                    }
                                    
                                    // Optimización #8: Usar cliente del pool para evitar throttling
                                    var searchClient = GetClientFromPool();
                                    var results = await searchClient.SearchAsync(
                                        SearchQuery.FromText(author),
                                        options: searchOptions,
                                        cancellationToken: cancellationToken
                                    );
                                    
                                    // Verificar cancelación después de buscar
                                    if (!autoSearchRunning || cancellationToken.IsCancellationRequested)
                                    {
                                        return;
                                    }
                                    
                                    // Validar que Responses no sea null
                                    if (results.Responses == null || results.Responses.Count == 0)
                                    {
                                        AutoLog($"⚠️ {author}: Sin resultados");
                                        break;
                                    }
                                    
                                    int totalFiles = results.Responses.Sum(r => r?.FileCount ?? 0);
                                    int totalUsers = results.Responses.Count;
                                    int newFilesThisIteration = 0;
                                    
                                    foreach (var response in results.Responses)
                                    {
                                        // Verificar cancelación en cada respuesta
                                        if (!autoSearchRunning || cancellationToken.IsCancellationRequested)
                                        {
                                            return;
                                        }
                                        
                                        // Validar que response no sea null
                                        if (response == null)
                                            continue;
                                        
                                        // Filtrar usuarios de blacklist
                                        if (blacklist.Contains(response.Username))
                                            continue;
                                        
                                        // Validar que Files no sea null
                                        if (response.Files == null)
                                            continue;
                                        
                                        // MEJORA #1: Recolectar archivos que necesitan verificación de contenido para procesarlos en paralelo
                                        var filesToVerify = new List<(string username, string filename, long fileSize, Soulseek.File fileObj)>();
                                        var filesReadyToProcess = new List<(Soulseek.File file, bool isSpanish)>();
                                        
                                        foreach (var file in response.Files)
                                        {
                                            // Verificar cancelación cada 100 archivos
                                            if (!autoSearchRunning || cancellationToken.IsCancellationRequested)
                                            {
                                                return;
                                            }
                                            
                                            // Filtrar archivos de 0 bytes o sin extensión
                                            if (file.Size == 0)
                                                continue;
                                            
                                            string extension = Path.GetExtension(file.Filename);
                                            if (string.IsNullOrEmpty(extension))
                                                continue;
                                            
                                            // Filtrar por tamaño mínimo configurado
                                            if (minFileSizeKB > 0 && file.Size < (minFileSizeKB * 1024))
                                                continue;

                                            // Verificar si es documento ANTES de agregar
                                            bool isDocument = IsDocumentFile(file.Filename);
                                            if (!isDocument)
                                                continue;
                                            
                                            // Filtro de idioma en 3 pasos (con estadísticas):
                                            // 1. Si es CLARAMENTE otro idioma por el título → rechazar
                                            if (ValidationHelpers.IsClearlyNonSpanish(file.Filename))
                                            {
                                                languageStats.RejectedByTitle++;
                                                continue;
                                            }
                                            
                                            // 2. Si el título tiene evidencia positiva de español → aceptar
                                            bool isSpanish = IsSpanishText(file.Filename);
                                            
                                            if (isSpanish)
                                            {
                                                languageStats.AcceptedByTitle++;
                                                filesReadyToProcess.Add((file, true));
                                            }
                                            // 3. Si el título es neutral/ambiguo → verificar contenido parcial (SOLO en modo preciso)
                                            else if (preciseLanguageMode)
                                            {
                                                // Agregar a lista para verificación en batch
                                                filesToVerify.Add((response.Username, file.Filename, file.Size, file));
                                            }
                                            else
                                            {
                                                // Modo rápido: aceptar archivos neutrales sin verificar contenido
                                                filesReadyToProcess.Add((file, true));
                                            }
                                        }
                                        
                                        // MEJORA #1: Verificar archivos en paralelo si hay alguno pendiente
                                        if (filesToVerify.Count > 0)
                                        {
                                            try
                                            {
                                                var verificationTasks = filesToVerify.Select(async f =>
                                                {
                                                    try
                                                    {
                                                        bool isSpanish = await IsSpanishFileByContent(f.username, f.filename, f.fileSize);
                                                        return (f.fileObj, isSpanish, success: true);
                                                    }
                                                    catch (Exception ex)
                                                    {
                                                        languageStats.VerificationErrors++;
                                                        AutoLog($"⚠️ No se pudo verificar contenido, aceptando por autor: {Path.GetFileName(f.filename)}");
                                                        return (f.fileObj, isSpanish: true, success: false);
                                                    }
                                                }).ToList();
                                                
                                                var verificationResults = await Task.WhenAll(verificationTasks);
                                                
                                                foreach (var (fileObj, isSpanish, success) in verificationResults)
                                                {
                                                    if (isSpanish)
                                                    {
                                                        if (success)
                                                        {
                                                            languageStats.AcceptedByContent++;
                                                            AutoLog($"✅ Verificado español por contenido: {Path.GetFileName(fileObj.Filename)}");
                                                        }
                                                        filesReadyToProcess.Add((fileObj, true));
                                                    }
                                                    else
                                                    {
                                                        languageStats.RejectedByContent++;
                                                        AutoLog($"⏭️ Descartado por contenido no-español: {Path.GetFileName(fileObj.Filename)}");
                                                    }
                                                }
                                            }
                                            catch (Exception ex)
                                            {
                                                AutoLog($"⚠️ Error en verificación paralela: {ex.Message}");
                                                // En caso de error, aceptar todos los archivos pendientes
                                                foreach (var f in filesToVerify)
                                                {
                                                    filesReadyToProcess.Add((f.fileObj, true));
                                                }
                                            }
                                        }
                                        
                                        // Procesar todos los archivos que pasaron los filtros
                                        foreach (var (file, isSpanish) in filesReadyToProcess)
                                        {
                                            // Verificar cancelación
                                            if (!autoSearchRunning || cancellationToken.IsCancellationRequested)
                                            {
                                                return;
                                            }
                                            
                                            // VERIFICAR SI YA EXISTE EN CARBARHER (cbh)
                                            string fileName = Path.GetFileName(file.Filename);
                                            if (carbarherCacheLoaded && carbarherFilesCache.Contains(fileName))
                                                continue;
                                            
                                            // VERIFICAR SI YA ESTÁ DESCARGADO (carpeta de descargas)
                                            if (IsAlreadyDownloaded(fileName, "", 0))
                                                continue;
                                            
                                            string fileKey = $"{file.Filename}|{file.Size}";
                                            if (!authorUniqueFiles[author].Contains(fileKey))
                                            {
                                                authorUniqueFiles[author].Add(fileKey);
                                                globalUniqueFiles.Add(fileKey);
                                                uniqueNewFiles++;
                                                newFilesThisIteration++;
                                                
                                                // OPTIMIZACIÓN #4: Bloom Filter (C#)
                                                var bloomKey = $"{author}:{Path.GetFileName(file.Filename)}";
                                                BloomAdd(bloomKey);
                                                
                                                // Guardar archivo en la lista de resultados
                                                // OPTIMIZACIÓN: Crear objeto fuera del lock + String Interning
                                                string fileNameInterned = Path.GetFileName(file.Filename);
                                                string directory = Path.GetDirectoryName(file.Filename) ?? "";
                                                
                                                // Aplicar string interning si está habilitado
                                                if (useStringInterning && fileNamePool != null && authorPool != null)
                                                {
                                                    fileNameInterned = fileNamePool.InternFileName(fileNameInterned);
                                                    author = authorPool.InternAuthor(author);
                                                    directory = pathPool?.Intern(directory) ?? directory;
                                                }
                                                
                                                // Calcular isDocument para este archivo
                                                bool isDocument = IsDocumentFile(file.Filename);
                                                
                                                var newFile = new AutoSearchFileResult
                                                {
                                                    Author = author,
                                                    Username = response.Username,
                                                    FileName = fileNameInterned,
                                                    Directory = directory,
                                                    SizeBytes = file.Size,
                                                    SizeReadable = FormatFileSize(file.Size),
                                                    IsSpanish = isSpanish,
                                                    IsDocument = isDocument,
                                                    Timestamp = DateTime.Now
                                                };
                                                
                                                // Enriquecer con metadatos de audio (Nicotine+ inspired)
                                                if (file.Attributes != null && file.Attributes.Count > 0)
                                                {
                                                    var audioMetadata = GetAudioMetadata(file);
                                                    if (audioMetadata != null && !PassesAudioQualityFilters(audioMetadata))
                                                    {
                                                        continue; // Filtrar por calidad de audio
                                                    }
                                                }
                                                
                                                // MEJORA #9: Filtro 'Solo Nuevos'
                                                if (onlyNewFilesInAutoSearch)
                                                {
                                                    string localPath = GetDownloadPath(newFile.FileName, newFile.Author);
                                                    if (System.IO.File.Exists(localPath))
                                                    {
                                                        continue; // Omitir archivos ya descargados
                                                    }
                                                }
                                                
                                                // Lock corto: solo agregar
                                                lock (autoSearchResultsLock)
                                                {
                                                    autoSearchResults.Add(newFile);
                                                }
                                                
                                                // Agregar al índice invertido (fuera del lock)
                                                if (searchIndex != null)
                                                {
                                                    searchIndex.Add(newFile);
                                                }
                                                
                                                // Cachear metadatos fuera del lock
                                                SetCachedMetadata(fileKey, newFile);
                                                
                                                // 🚀 DESCARGA INMEDIATA (estilo Nicotine+)
                                                if (instantDownload)
                                                {
                                                    _ = Task.Run(async () =>
                                                    {
                                                        try
                                                        {
                                                            string localPath = GetDownloadPath(newFile.FileName, newFile.Author);
                                                            
                                                            // Crear ListViewItem para UI
                                                            ListViewItem downloadItem = null;
                                                            SafeInvoke(() =>
                                                            {
                                                                downloadItem = new ListViewItem(newFile.FileName);
                                                                string usernameDisplay = premiumUsers.Contains(newFile.Username) ? $"⭐ {newFile.Username}" : newFile.Username;
                                                                downloadItem.SubItems.Add(usernameDisplay);
                                                                downloadItem.SubItems.Add("0%");
                                                                downloadItem.SubItems.Add("⏳ En cola");
                                                                downloadItem.SubItems.Add(newFile.SizeReadable);
                                                                downloadItem.SubItems.Add(GetMetadataStatusSync(newFile.FileName));
                                                                downloadItem.ForeColor = Color.LightGray;
                                                                AddItemWithAutoScroll(lvDownloads, downloadItem);
                                                            });
                                                            
                                                            // Agregar a cola de descarga inmediatamente
                                                            AddToDownloadQueue(newFile, localPath, downloadItem, false);
                                                        }
                                                        catch (Exception ex)
                                                        {
                                                            AutoLog($"❌ Error agregando descarga inmediata: {ex.Message}");
                                                        }
                                                    });
                                                }
                                                
                                                // Notificar actualización en tiempo real
                                                int count = autoSearchResults.Count;
                                                
                                                // OPTIMIZACIÓN #6: Deduplicar con Rust cada 1000 archivos
                                                if (count % DEDUPE_INTERVAL == 0 && SlskNativeInterop.IsAvailable)
                                                {
                                                    var sw = System.Diagnostics.Stopwatch.StartNew();
                                                    var deduplicated = SlskNativeInterop.DeduplicateFiles(
                                                        autoSearchResults.ToList(),
                                                        f => f.FileName,
                                                        f => f.Username,
                                                        f => f.SizeBytes,
                                                        username => (int)GetProviderScore(username)
                                                    );
                                                    autoSearchResults.Clear();
                                                    autoSearchResults.AddRange(deduplicated);
                                                    sw.Stop();
                                                    AutoLog($"🦀 Deduplicación Rust en {sw.ElapsedMilliseconds}ms ({count} → {autoSearchResults.Count})");
                                                }
                                                
                                                // Actualizar estadísticas cada 10 archivos (rápido, no recarga grilla)
                                                if (count % 10 == 0)
                                                {
                                                    realtimeStatsUpdater?.Invoke(count);
                                                }
                                                
                                                // Log cada 50 archivos
                                                if (count % 50 == 0)
                                                {
                                                    secondaryLogger?.Invoke($"📊 {count:N0} archivos encontrados hasta ahora...");
                                                }
                                                
                                                // Actualizar grilla completa solo cada 200 archivos (para no saturar con miles)
                                                if (count % 200 == 0)
                                                {
                                                    realtimeGridUpdater?.Invoke();
                                                }
                                            }
                                        }
                                }
                            
                                // Controlar búsquedas vacías consecutivas
                                if (newFilesThisIteration == 0)
                                {
                                    consecutiveEmptySearches++;
                                }
                                else
                                {
                                    consecutiveEmptySearches = 0;
                                }
                                
                                // Pequeña pausa entre iteraciones
                                if (consecutiveEmptySearches < MAX_EMPTY_SEARCHES)
                                {
                                    // MEJORA #37: ConfigureAwait(false) en loop de búsqueda
                                    await Task.Delay(500, cancellationToken).ConfigureAwait(false);
                                }
                            }
                        }
                        catch (OperationCanceledException)
                        {
                            AutoLog($"⏹️ {author}: Búsqueda cancelada");
                        }
                        catch (Exception ex)
                        {
                            AutoLog($"   ❌ {author}: Error - {ex.Message}");
                        }
                        finally
                        {
                            lock (authorNoResultsCount)
                            {
                                processedInRound++;
                                
                                // OPTIMIZACIÓN #5: Guardado incremental cada 50 autores
                                if (processedInRound % SAVE_INTERVAL == 0)
                                {
                                    AutoLog($"💾 Guardando progreso ({processedInRound}/{totalInRound})...");
                                    _ = Task.Run(async () =>
                                    {
                                        await SaveAutoResultsToJsonAsync();
                                        await SaveProgressCheckpoint(processedInRound, selectedAuthors);
                                    });
                                }
                                
                                // Log de progreso cada 10 autores
                                if (processedInRound % 10 == 0)
                                {
                                    var elapsed = roundStopwatch.Elapsed;
                                    var speed = processedInRound / elapsed.TotalSeconds;
                                    var remaining = totalInRound - processedInRound;
                                    var eta = TimeSpan.FromSeconds(remaining / speed);
                                    AutoLog($"   📊 Progreso: {processedInRound}/{totalInRound} ({(processedInRound * 100.0 / totalInRound):F0}%) | ETA: {eta:mm\\:ss}");
                                    var percentRound = (int)Math.Floor(processedInRound * 100.0 / totalInRound);
                                    SafeInvoke(() => { if (lblPurgeProgress != null) lblPurgeProgress.Text = $"⏳ {processedInRound}/{totalInRound} ({percentRound}%) | Calculando..."; });
                                }
                                
                                if (uniqueNewFiles > 0)
                                {
                                    anyResultsFound = true;
                                    totalNewFilesThisRound += uniqueNewFiles;
                                    authorNoResultsCount[author] = 0; // Resetear contador
                                    int totalUniqueForAuthor = authorUniqueFiles[author].Count;
                                    
                                    // OPTIMIZACIÓN #3: Guardar en caché de búsquedas
                                    var authorFiles = autoSearchResults
                                        .Where(f => f.Author.Equals(author, StringComparison.OrdinalIgnoreCase))
                                        .ToList();
                                    authorSearchCache[author] = (results: authorFiles, cachedAt: DateTime.Now);
                                    
                                    // Log siempre que encuentre archivos
                                    AutoLog($"   ✅ {author}: +{uniqueNewFiles} archivos (total: {totalUniqueForAuthor})");
                                    
                                    // Actualizar columnas con total de archivos únicos del autor
                                    SafeBeginInvoke(() => UpdateAuthorInList(author, totalUniqueForAuthor, "✅ Encontrado", false));
                                }
                                else
                                {
                                    authorNoResultsCount[author]++;
                                    
                                    // OPT #9: Verificar si tiene archivos pero ninguno en español
                                    var authorFilesAnyLanguage = autoSearchResults
                                        .Where(f => f.Author.Equals(author, StringComparison.OrdinalIgnoreCase))
                                        .ToList();
                                    
                                    bool hasFilesButNoSpanish = authorFilesAnyLanguage.Count > 0 && !authorFilesAnyLanguage.Any(f => f.IsSpanish);
                                    
                                    if (hasFilesButNoSpanish && !authorsWithoutSpanishWorks.Contains(author))
                                    {
                                        // Tiene archivos pero ninguno en español → agregar a caché persistente
                                        authorsWithoutSpanishWorks.Add(author);
                                        SaveNoSpanishAuthorsCache();
                                        AutoLog($"   🚫 {author}: Tiene archivos pero ninguno en español, agregado a caché");
                                        authorsToRemove.Add(author);
                                        SafeBeginInvoke(() => UpdateAuthorStatus(author, "🚫 Sin español"));
                                    }
                                    else if (!hasFilesButNoSpanish)
                                    {
                                        // OPTIMIZACIÓN #8: Añadir a blacklist después de 5 intentos
                                        if (authorNoResultsCount[author] >= 5)
                                        {
                                            noResultsAuthors.Add(author);
                                            AutoLog($"   ⛔ {author}: Sin resultados después de 5 intentos, añadido a blacklist");
                                            authorsToRemove.Add(author);
                                        }
                                        // Log solo si es la primera vez sin resultados o la tercera
                                        else if (authorNoResultsCount[author] == 1 || authorNoResultsCount[author] == 3)
                                        {
                                            AutoLog($"   ⚪ {author}: Sin resultados ({authorNoResultsCount[author]}/3)");
                                        }
                                        
                                        // Actualizar estado
                                        SafeBeginInvoke(() => UpdateAuthorStatus(author, $"⚪ Sin resultados ({authorNoResultsCount[author]}/3)"));
                                        
                                        // Si lleva 3 rondas sin resultados, marcarlo para eliminar
                                        if (authorNoResultsCount[author] >= 3)
                                        {
                                            authorsToRemove.Add(author);
                                            AutoLog($"   🚫 {author} será eliminado (3 rondas sin resultados)");
                                            
                                            SafeBeginInvoke(() => UpdateAuthorStatus(author, "🚫 Eliminado"));
                                        }
                                    }
                                }
                            }
                        }
                    }
                    finally
                    {
                        // Asegurar que el semaphore siempre se libere
                        semaphore.Release();
                    }
                });
                
                try
                {
                    await Task.WhenAll(tasks);
                }
                catch (OperationCanceledException)
                {
                    AutoLog("⏹️ Búsqueda cancelada por el usuario");
                    SafeInvoke(() => { if (lblPurgeProgress != null) lblPurgeProgress.Text = "⏹️ Cancelado"; });
                }
            } // Cerrar using del semaphore
            
            // Eliminar autores que llevan 3 rondas sin resultados
            if (authorsToRemove.Count > 0)
            {
                AutoLog("");
                AutoLog($"🗑️ Eliminando {authorsToRemove.Count} autor(es) inactivo(s):");
                foreach (var author in authorsToRemove)
                {
                    selectedAuthors.Remove(author);
                    authorNoResultsCount.Remove(author);
                    AutoLog($"   ❌ {author}");
                }
            }
            
            AutoLog($"🔍 DEBUG: Fin ronda {round} - anyResultsFound={anyResultsFound}, selectedAuthors.Count={selectedAuthors.Count}, totalNewFilesThisRound={totalNewFilesThisRound}");
            
            // Mostrar resumen de la ronda
            AutoLog("");
            AutoLog($"📊 RESUMEN RONDA {round}:");
            roundStopwatch.Stop();
            AutoLog($"   📁 Archivos nuevos: {totalNewFilesThisRound}");
            AutoLog($"   👥 Autores restantes: {selectedAuthors.Count}");
            AutoLog($"   ⏱️ Tiempo ronda: {roundStopwatch.Elapsed:mm\\:ss}");
            if (roundStopwatch.Elapsed.TotalSeconds > 0)
            {
                AutoLog($"   ⚡ Velocidad: {(selectedAuthors.Count / roundStopwatch.Elapsed.TotalSeconds):F1} autores/seg");
            }
            
            // Si no quedan autores, terminar
            if (selectedAuthors.Count == 0)
            {
                AutoLog("");
                AutoLog("═══════════════════════════════════════");
                AutoLog($"✅ COMPLETADO - Todos los autores procesados");
                AutoLog("═══════════════════════════════════════");
                SafeInvoke(() => { if (lblPurgeProgress != null) lblPurgeProgress.Text = "✅ Completado"; });
                break;
            }
            
            // También mostrar en log principal
            Log($"📊 Ronda {round}: {totalNewFilesThisRound} archivos nuevos, {selectedAuthors.Count} autores restantes");
            
            // Guardar resultados después de cada ronda
            int totalResults;
            lock (autoSearchResultsLock)
            {
                totalResults = autoSearchResults.Count;
            }
            if (totalResults > 0)
            {
                SaveAutoResultsToCsv();
                AutoLog($"   💾 Total archivos guardados: {totalResults}");
            }
            
            if (selectedAuthors.Count > 0)
            {
                AutoLog($"   ▶️ Continuando con ronda {round + 1}...");
            }
            round++;
        }
        
                // MEJORA #15: Verificación automática al finalizar búsqueda
                AutoLog("");
                AutoLog("═══════════════════════════════════════");
                AutoLog("🔍 INICIANDO VERIFICACIÓN AUTOMÁTICA");
                AutoLog("═══════════════════════════════════════");
                
                try
                {
                    await VerifyDownloadedFilesAsync();
                    AutoLog("✅ Verificación automática completada");
                }
                catch (Exception verifyEx)
                {
                    AutoLog($"⚠️ Error en verificación automática: {verifyEx.Message}");
                }
            }
            finally
            {
                // Detener timer de actualizaciones UI
                StopAutoSearchUIUpdateTimer();
                
                // Procesar actualizaciones UI pendientes
                FlushAutoSearchUIUpdates();
                
                // Marcar búsqueda como no activa
                autoSearchRunning = false;
                
                // Refrescar ListView final
                SafeBeginInvoke(() =>
                {
                    try
                    {
                        if (lvAutoAuthors != null && lvAutoAuthors.IsHandleCreated)
                        {
                            RefreshAuthorsListView();
                            UpdateAuthorCount();
                        }
                    }
                    catch (Exception ex)
                    {
                        AutoLog($"⚠️ Error al refrescar ListView: {ex.Message}");
                    }
                });
                
                UpdateAutoControlsEnabled();
                
                // OPTIMIZACIÓN #10: Eliminar checkpoint al finalizar
                DeleteCheckpoint();
                
                // OPT #9: Guardar caché de autores sin español
                SaveNoSpanishAuthorsCache();
                
                // Guardar resultados finales
                int finalCount;
                lock (autoSearchResultsLock)
                {
                    finalCount = autoSearchResults.Count;
                }
                if (finalCount > 0)
                {
                    SaveAutoResultsToCsv();
                    AutoLog("");
                    AutoLog($" Guardado final: {finalCount} archivos únicos en {autoResultsCsvPath}");
                }
            }
            
            // return validFiles; // TODO: Verificar si este return es necesario - variable no definida en este contexto
        }
        
        private async void RefreshHistoryView(bool loadAll)
        {
            if (lvHistory == null) return;
            
            if (InvokeRequired)
            {
                BeginInvoke(new Action<bool>(RefreshHistoryView), loadAll);
                return;
            }
            
            lvHistory.BeginUpdate();
            try
            {
                if (loadAll)
                {
                    lvHistory.Items.Clear();
                    historyCurrentPage = 0;
                }
                
                // Usar SQLite si está disponible, sino usar lista en memoria
                if (database != null)
                {
                    try
                    {
                        int skip = historyCurrentPage * historyPageSize;
                        var pageItems = await database.GetDownloadsAsync(limit: historyPageSize, offset: skip);
                        
                        foreach (var item in pageItems)
                        {
                            var listItem = new ListViewItem(item.DownloadedAt.ToString("yyyy-MM-dd HH:mm:ss"));
                            listItem.SubItems.Add(item.FileName);
                            listItem.SubItems.Add(item.Author ?? "");
                            listItem.SubItems.Add(item.Username);
                            listItem.SubItems.Add(FormatFileSize(item.SizeBytes));
                            listItem.SubItems.Add(item.Status);
                            
                            listItem.ForeColor = item.Status == "Completed" ? Color.LightGreen : Color.Red;
                            AddItemWithAutoScroll(lvHistory, listItem);
                        }
                        
                        historyCurrentPage++;
                        
                        // Obtener estadísticas de la DB
                        var stats = await database.GetStatisticsAsync();
                        var totalCount = Convert.ToInt32(stats["TotalDownloads"]);
                        var totalGB = Convert.ToDouble(stats["TotalGB"]);
                        var successRate = Convert.ToDouble(stats["SuccessRate"]);
                        
                        // Mostrar botón "Cargar más" si hay más registros
                        if (btnLoadMore != null)
                        {
                            btnLoadMore.Visible = (skip + historyPageSize) < totalCount;
                        }
                        
                        if (lblHistoryStats != null)
                        {
                            lblHistoryStats.Text = $"Total: {totalCount} | Mostrando: {lvHistory.Items.Count} | ✅ {successRate:F1}% | 📦 {totalGB:F2} GB";
                        }
                    }
                    catch (Exception ex)
                    {
                        Log($"⚠️ Error cargando historial desde DB: {ex.Message}");
                        // Fallback a lista en memoria
                        LoadHistoryFromMemory();
                    }
                }
                else
                {
                    // Fallback a lista en memoria
                    LoadHistoryFromMemory();
                }
            }
            finally
            {
                lvHistory.EndUpdate();
            }
        }
        
        private void LoadHistoryFromMemory()
        {
            lock (downloadHistoryLock)
            {
                var orderedHistory = downloadHistory.OrderByDescending(h => h.DownloadedAt).ToList();
                int skip = historyCurrentPage * historyPageSize;
                var pageItems = orderedHistory.Skip(skip).Take(historyPageSize).ToList();
                
                foreach (var item in pageItems)
                {
                    var listItem = new ListViewItem(item.DownloadedAt.ToString("yyyy-MM-dd HH:mm:ss"));
                    listItem.SubItems.Add(item.FileName);
                    listItem.SubItems.Add(item.Author);
                    listItem.SubItems.Add(item.Username);
                    listItem.SubItems.Add(FormatFileSize(item.SizeBytes));
                    listItem.SubItems.Add(item.Status);
                    
                    listItem.ForeColor = item.Status == "Completed" ? Color.LightGreen : Color.Red;
                    listItem.ToolTipText = $"{item.FileName}\nAutor: {item.Author}\nUsuario: {item.Username}\nTamaño: {FormatFileSize(item.SizeBytes)}\nEstado: {item.Status}\nFecha: {item.DownloadedAt:yyyy-MM-dd HH:mm:ss}";
                    lvHistory.Items.Add(listItem);
                }
                
                historyCurrentPage++;
                
                // Mostrar botón "Cargar más" si hay más registros
                if (btnLoadMore != null)
                {
                    btnLoadMore.Visible = (skip + historyPageSize) < orderedHistory.Count;
                }
                
                var completed = downloadHistory.Count(h => h.Status == "Completed");
                var failed = downloadHistory.Count(h => h.Status == "Failed");
                var totalSize = FormatFileSize(downloadHistory.Where(h => h.Status == "Completed").Sum(h => h.SizeBytes));
                
                if (lblHistoryStats != null)
                {
                    lblHistoryStats.Text = $"Total: {downloadHistory.Count} | Mostrando: {lvHistory.Items.Count} | ✅ {completed} | ❌ {failed} | 📦 {totalSize}";
                }
            }
        }
        
        private async Task ClassifyHistoryByLanguage()
        {
            if (downloadHistory.Count == 0)
            {
                DarkMessageBox.Show("No hay archivos en el historial para clasificar.", "Historial vacío", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }
            
            btnClassifySpanish.Enabled = false;
            btnClassifySpanish.Text = "Clasificando...";
            spanishFiles.Clear();
            nonSpanishFiles.Clear();
            
            int analyzedContent = 0;
            int analyzedByName = 0;
            
            await Task.Run(() =>
            {
                int processed = 0;
                int total = downloadHistory.Count;
                
                lock (downloadHistoryLock)
                {
                    foreach (var item in downloadHistory)
                    {
                        processed++;
                        
                        // Actualizar progreso cada 50 archivos
                        if (processed % 50 == 0)
                        {
                            SafeInvoke(() =>
                            {
                                btnClassifySpanish.Text = $"Analizando {processed}/{total}...";
                            });
                        }
                        
                        string fileName = item.FileName ?? "";
                        bool isSpanish = false;
                        
                        // Descartar rápidamente si el título parece de otro idioma
                        if (ValidationHelpers.IsClearlyNonSpanish(fileName))
                        {
                            analyzedByName++;
                            nonSpanishFiles.Add(fileName);
                            continue;
                        }

                        // Intentar clasificar por contenido del archivo
                        string filePath = GetFilePathFromHistory(item);
                        if (!string.IsNullOrEmpty(filePath) && System.IO.File.Exists(filePath))
                        {
                            string content = ExtractTextFromFile(filePath);
                            if (!string.IsNullOrEmpty(content))
                            {
                                isSpanish = IsSpanishText(content);
                                analyzedContent++;
                            }
                            else
                            {
                                // Si no se pudo extraer contenido, usar nombre de archivo
                                isSpanish = IsSpanishText(fileName);
                                analyzedByName++;
                            }
                        }
                        else
                        {
                            // Si el archivo no existe, clasificar solo por nombre
                            isSpanish = IsSpanishText(fileName);
                            analyzedByName++;
                        }
                        
                        if (isSpanish)
                        {
                            spanishFiles.Add(fileName);
                        }
                        else
                        {
                            nonSpanishFiles.Add(fileName);
                        }
                    }
                }
            });
            
            historyClassified = true;
            
            SafeInvoke(() =>
            {
                btnClassifySpanish.Text = "Solo español";
                btnClassifySpanish.Enabled = true;
                btnDeleteNonSpanish.Visible = true;
                
                // Mostrar panel completo de filtros
                if (historyFilterPanel != null)
                {
                    historyFilterPanel.Visible = true;
                }
                UpdateFilterButtons();
                
                // Actualizar vista con colores
                RefreshHistoryViewWithClassification();
                
                Log($"✅ Clasificación completada: {spanishFiles.Count} español, {nonSpanishFiles.Count} no español");
                Log($"📊 Análisis: {analyzedContent} por contenido, {analyzedByName} por nombre");
                
                DarkMessageBox.Show(
                    $"Clasificación completada:\n\n" +
                    $"✅ Español: {spanishFiles.Count} archivos\n" +
                    $"❌ No español: {nonSpanishFiles.Count} archivos\n\n" +
                    $"📊 Método de análisis:\n" +
                    $"   • Por contenido: {analyzedContent} archivos\n" +
                    $"   • Por nombre: {analyzedByName} archivos\n\n" +
                    $"Usa los botones de filtro para ver categorías específicas.\n" +
                    $"Puedes eliminar los archivos no español.",
                    "Clasificación completada",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Information);
            });
        }
        
        private void RefreshHistoryViewWithClassification()
        {
            if (lvHistory == null || !historyClassified) return;
            
            lvHistory.BeginUpdate();
            try
            {
                lvHistory.Items.Clear();
                historyCurrentPage = 0;
                
                lock (downloadHistoryLock)
                {
                    // Aplicar filtro
                    var orderedHistory = downloadHistory.OrderByDescending(h => h.DownloadedAt).ToList();
                    
                    if (historyFilter == "spanish")
                    {
                        orderedHistory = orderedHistory.Where(h => spanishFiles.Contains(h.FileName)).ToList();
                    }
                    else if (historyFilter == "non-spanish")
                    {
                        orderedHistory = orderedHistory.Where(h => nonSpanishFiles.Contains(h.FileName)).ToList();
                    }
                    
                    int skip = historyCurrentPage * historyPageSize;
                    var pageItems = orderedHistory.Skip(skip).Take(historyPageSize).ToList();
                    
                    foreach (var item in pageItems)
                    {
                        var listItem = new ListViewItem(item.DownloadedAt.ToString("yyyy-MM-dd HH:mm:ss"));
                        listItem.SubItems.Add(item.FileName);
                        listItem.SubItems.Add(item.Author);
                        listItem.SubItems.Add(item.Username);
                        listItem.SubItems.Add(FormatFileSize(item.SizeBytes));
                        listItem.SubItems.Add(item.Status);
                        
                        // Colorear según clasificación
                        if (spanishFiles.Contains(item.FileName))
                        {
                            listItem.ForeColor = Color.LightGreen;
                            listItem.BackColor = Color.FromArgb(20, 50, 20);
                        }
                        else if (nonSpanishFiles.Contains(item.FileName))
                        {
                            listItem.ForeColor = Color.LightCoral;
                            listItem.BackColor = Color.FromArgb(50, 20, 20);
                        }
                        else
                        {
                            listItem.ForeColor = item.Status == "Completed" ? Color.LightGreen : Color.Red;
                        }
                        listItem.ToolTipText = $"{item.FileName}\nAutor: {item.Author}\nUsuario: {item.Username}\nTamaño: {FormatFileSize(item.SizeBytes)}\nEstado: {item.Status}\nFecha: {item.DownloadedAt:yyyy-MM-dd HH:mm:ss}";
                        
                        lvHistory.Items.Add(listItem);
                    }
                    
                    historyCurrentPage++;
                    
                    if (btnLoadMore != null)
                    {
                        btnLoadMore.Visible = (skip + historyPageSize) < orderedHistory.Count;
                    }
                    
                    var completed = downloadHistory.Count(h => h.Status == "Completed");
                    var failed = downloadHistory.Count(h => h.Status == "Failed");
                    var totalSize = FormatFileSize(downloadHistory.Where(h => h.Status == "Completed").Sum(h => h.SizeBytes));
                    
                    if (lblHistoryStats != null)
                    {
                        string filterText = historyFilter == "all" ? "Todos" : 
                                          historyFilter == "spanish" ? "Solo español" : "Solo no español";
                        lblHistoryStats.Text = $"Total: {downloadHistory.Count} | Filtro: {filterText} | Mostrando: {orderedHistory.Count} | ✅ Español: {spanishFiles.Count} | ❌ No español: {nonSpanishFiles.Count} | 📦 {totalSize}";
                    }
                }
            }
            finally
            {
                lvHistory.EndUpdate();
            }
        }
        
        private void DeleteNonSpanishFiles()
        {
            if (!historyClassified || nonSpanishFiles.Count == 0)
            {
                DarkMessageBox.Show("No hay archivos no español para eliminar.", "Sin archivos", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }
            
            var result = MessageBox.Show(
                $"¿Estás seguro de que quieres eliminar {nonSpanishFiles.Count} archivos no español?\n\n" +
                $"Se eliminarán:\n" +
                $"• Los archivos físicos del disco\n" +
                $"• Los registros del historial\n\n" +
                $"Esta acción NO se puede deshacer.",
                "Confirmar eliminación",
                MessageBoxButtons.YesNo,
                MessageBoxIcon.Warning);
            
            if (result == DialogResult.Yes)
            {
                int deletedFromHistory = 0;
                int deletedFromDisk = 0;
                int failedToDelete = 0;
                long totalSize = 0;
                
                lock (downloadHistoryLock)
                {
                    // Eliminar del historial y del disco
                    var toRemove = downloadHistory.Where(h => nonSpanishFiles.Contains(h.FileName)).ToList();
                    foreach (var item in toRemove)
                    {
                        // Intentar eliminar archivo físico
                        string filePath = GetFilePathFromHistory(item);
                        if (!string.IsNullOrEmpty(filePath) && System.IO.File.Exists(filePath))
                        {
                            try
                            {
                                var fileInfo = new FileInfo(filePath);
                                long fileSize = fileInfo.Length;
                                
                                System.IO.File.Delete(filePath);
                                deletedFromDisk++;
                                totalSize += fileSize;
                                
                                Log($"🗑️ Archivo eliminado: {item.FileName} ({FormatFileSize(fileSize)})");
                            }
                            catch (Exception ex)
                            {
                                failedToDelete++;
                                Log($"❌ Error eliminando {item.FileName}: {ex.Message}");
                            }
                        }
                        
                        // Eliminar del historial
                        downloadHistory.Remove(item);
                        downloadHistoryCache.Remove(item.FileName);
                        deletedFromHistory++;
                    }
                }
                
                // Guardar cambios
                SaveDownloadHistory();
                
                // Limpiar clasificación
                nonSpanishFiles.Clear();
                spanishFiles.Clear();
                historyClassified = false;
                historyFilter = "all";
                btnDeleteNonSpanish.Visible = false;
                btnFilterAll.Visible = false;
                btnFilterSpanish.Visible = false;
                btnFilterNonSpanish.Visible = false;
                
                // Actualizar vista
                RefreshHistoryView(true);
                
                // Mensaje de resultado
                string message = $"Eliminación completada:\n\n" +
                                $"📁 Archivos físicos eliminados: {deletedFromDisk}\n" +
                                $"📋 Registros del historial: {deletedFromHistory}\n" +
                                $"💾 Espacio liberado: {FormatFileSize(totalSize)}";
                
                if (failedToDelete > 0)
                {
                    message += $"\n\n⚠️ No se pudieron eliminar {failedToDelete} archivos (puede que ya no existan)";
                }
                
                Log($"✅ Eliminados {deletedFromDisk} archivos físicos y {deletedFromHistory} registros del historial");
                Log($"💾 Espacio liberado: {FormatFileSize(totalSize)}");
                
                DarkMessageBox.Show(
                    message,
                    "Eliminación completada",
                    MessageBoxButtons.OK,
                    failedToDelete > 0 ? MessageBoxIcon.Warning : MessageBoxIcon.Information);
            }
        }
        
        private string GetFilePathFromHistory(DownloadHistory item)
        {
            try
            {
                // Construir la ruta del archivo basándose en la configuración
                string basePath = downloadDir;
                
                if (organizeByAuthor && !string.IsNullOrEmpty(item.Author))
                {
                    basePath = Path.Combine(basePath, SanitizeFolderName(item.Author));
                }
                
                string filePath = Path.Combine(basePath, item.FileName);
                return filePath;
            }
            catch
            {
                return null;
            }
        }
        
        private string ExtractTextFromFile(string filePath)
        {
            try
            {
                string extension = Path.GetExtension(filePath).ToLower();
                
                // Soportar archivos de texto comunes
                if (extension == ".txt" || extension == ".md" || extension == ".log" || 
                    extension == ".csv" || extension == ".json" || extension == ".xml" ||
                    extension == ".html" || extension == ".htm" || extension == ".css" ||
                    extension == ".js" || extension == ".cs" || extension == ".py" ||
                    extension == ".java" || extension == ".cpp" || extension == ".c" ||
                    extension == ".h" || extension == ".sql" || extension == ".sh" ||
                    extension == ".ini" || extension == ".cfg" || extension == ".conf")
                {
                    return ExtractPlainText(filePath);
                }
                
                // Documentos de Microsoft Office (formato OpenXML)
                if (extension == ".docx" || extension == ".docm")
                {
                    return ExtractDocxText(filePath);
                }
                
                if (extension == ".xlsx" || extension == ".xlsm")
                {
                    return ExtractXlsxText(filePath);
                }
                
                if (extension == ".pptx" || extension == ".pptm")
                {
                    return ExtractPptxText(filePath);
                }
                
                // Documentos de OpenOffice/LibreOffice (formato ODF)
                if (extension == ".odt")
                {
                    return ExtractOdtText(filePath);
                }
                
                if (extension == ".ods")
                {
                    return ExtractOdsText(filePath);
                }
                
                if (extension == ".odp")
                {
                    return ExtractOdpText(filePath);
                }
                
                // RTF (Rich Text Format)
                if (extension == ".rtf")
                {
                    return ExtractRtfText(filePath);
                }
                
                // Documentos antiguos de Office (formato binario)
                if (extension == ".doc" || extension == ".xls" || extension == ".ppt")
                {
                    // Para formatos binarios antiguos, intentar extracción básica
                    return ExtractLegacyOfficeText(filePath);
                }
                
                // EPUB es un ZIP con archivos XHTML
                if (extension == ".epub")
                {
                    return ExtractEpubText(filePath);
                }
                
                // MOBI y formatos Kindle
                if (extension == ".mobi" || extension == ".azw" || extension == ".azw3")
                {
                    return ExtractMobiText(filePath);
                }
                
                // Para archivos PDF, usar extracción básica
                if (extension == ".pdf")
                {
                    return ExtractPdfText(filePath);
                }
                
                // Para otros formatos, intentar leer como texto plano
                return null;
            }
            catch
            {
                return null;
            }
        }
        
        private string ExtractPlainText(string filePath)
        {
            try
            {
                // OPTIMIZACIÓN: Usar ArrayPool para buffer de lectura
                const int maxBytes = 100 * 1024;
                var buffer = System.Buffers.ArrayPool<byte>.Shared.Rent(maxBytes);
                try
                {
                    int bytesRead;
                    
                    using (FileStream fs = new FileStream(filePath, FileMode.Open, FileAccess.Read, FileShare.Read))
                    {
                        bytesRead = fs.Read(buffer, 0, Math.Min(maxBytes, (int)fs.Length));
                    }
                    
                    // Intentar múltiples encodings
                    string text = null;
                    
                    // Intentar UTF-8
                    text = System.Text.Encoding.UTF8.GetString(buffer, 0, bytesRead);
                    if (text.Count(c => c == '\0') < bytesRead / 20)
                        return text;
                    
                    // Intentar Latin1/ISO-8859-1 (común en español)
                    text = System.Text.Encoding.GetEncoding("ISO-8859-1").GetString(buffer, 0, bytesRead);
                    if (text.Count(c => c == '\0') < bytesRead / 20)
                        return text;
                    
                    // Intentar Windows-1252
                    text = System.Text.Encoding.GetEncoding(1252).GetString(buffer, 0, bytesRead);
                    return text;
                }
                finally
                {
                    System.Buffers.ArrayPool<byte>.Shared.Return(buffer);
                }
            }
            catch
            {
                return null;
            }
        }
        
        private string ExtractEpubText(string filePath)
        {
            try
            {
                // Usar librería VersOne.Epub para extracción robusta
                var book = VersOne.Epub.EpubReader.ReadBook(filePath);
                var textBuilder = new System.Text.StringBuilder();
                
                // Extraer texto de los archivos HTML/XHTML
                var htmlFiles = book.Content.Html.Local
                    .Take(10); // Primeros 10 archivos
                
                foreach (var htmlFile in htmlFiles)
                {
                    string content = htmlFile.Content;
                    
                    if (!string.IsNullOrWhiteSpace(content))
                    {
                        // Limpiar HTML tags
                        content = RegexHtmlTags.Replace(content, " ");
                        textBuilder.AppendLine(content);
                        
                        // Limitar a ~50KB de texto
                        if (textBuilder.Length > 50000)
                            break;
                    }
                }
                
                return textBuilder.ToString();
            }
            catch (Exception ex)
            {
                TranslateLog($"⚠️ Error extrayendo EPUB: {ex.Message}");
                return null;
            }
        }
        
        private string ExtractMobiText(string filePath)
        {
            try
            {
                // MOBI es un formato binario complejo, extracción básica
                // Buscar texto plano en el archivo (similar a PDF básico)
                const int maxBytes = 200 * 1024; // Primeros 200KB
                var buffer = System.Buffers.ArrayPool<byte>.Shared.Rent(maxBytes);
                try
                {
                    int bytesRead;
                    
                    using (FileStream fs = new FileStream(filePath, FileMode.Open, FileAccess.Read, FileShare.Read))
                    {
                        // Saltar el header MOBI (primeros 1024 bytes típicamente)
                        fs.Seek(1024, SeekOrigin.Begin);
                        bytesRead = fs.Read(buffer, 0, Math.Min(maxBytes, (int)(fs.Length - 1024)));
                    }
                    
                    // Intentar decodificar como UTF-8 y Latin1
                    string content = System.Text.Encoding.UTF8.GetString(buffer, 0, bytesRead);
                    
                    // Limpiar caracteres no imprimibles
                    var textBuilder = new System.Text.StringBuilder();
                    foreach (char c in content)
                    {
                        if (char.IsLetterOrDigit(c) || char.IsWhiteSpace(c) || char.IsPunctuation(c))
                        {
                            textBuilder.Append(c);
                        }
                    }
                    
                    string cleanText = textBuilder.ToString();
                    
                    // Si hay suficiente texto legible, retornarlo
                    if (cleanText.Length > 100)
                    {
                        // MEJORA #31: Usar indexador de rango en lugar de Substring
                        return cleanText.Length > 50000 ? cleanText[..50000] : cleanText;
                    }
                    
                    return null;
                }
                finally
                {
                    System.Buffers.ArrayPool<byte>.Shared.Return(buffer);
                }
            }
            catch
            {
                return null;
            }
        }
        
        private string ExtractPdfText(string filePath)
        {
            try
            {
                // Usar iText7 para extracción robusta de PDF
                using (var pdfReader = new iText.Kernel.Pdf.PdfReader(filePath))
                using (var pdfDoc = new iText.Kernel.Pdf.PdfDocument(pdfReader))
                {
                    var textBuilder = new System.Text.StringBuilder();
                    
                    // Extraer texto de las primeras 20 páginas
                    int maxPages = Math.Min(20, pdfDoc.GetNumberOfPages());
                    
                    for (int i = 1; i <= maxPages; i++)
                    {
                        var page = pdfDoc.GetPage(i);
                        string pageText = iText.Kernel.Pdf.Canvas.Parser.PdfTextExtractor.GetTextFromPage(page);
                        
                        if (!string.IsNullOrWhiteSpace(pageText))
                        {
                            textBuilder.AppendLine(pageText);
                            
                            // Limitar a ~50KB de texto
                            if (textBuilder.Length > 50000)
                                break;
                        }
                    }
                    
                    return textBuilder.ToString();
                }
            }
            catch (Exception ex)
            {
                TranslateLog($"⚠️ Error extrayendo PDF: {ex.Message}");
                return null;
            }
        }
        
        private string ExtractDocxText(string filePath)
        {
            try
            {
                using (var doc = DocumentFormat.OpenXml.Packaging.WordprocessingDocument.Open(filePath, false))
                {
                    var body = doc.MainDocumentPart?.Document?.Body;
                    if (body == null) return null;
                    
                    var textBuilder = new System.Text.StringBuilder();
                    foreach (var text in body.Descendants<DocumentFormat.OpenXml.Wordprocessing.Text>())
                    {
                        textBuilder.Append(text.Text);
                        textBuilder.Append(" ");
                        
                        // Limitar a ~100KB de texto
                        if (textBuilder.Length > 100000)
                            break;
                    }
                    
                    return textBuilder.ToString();
                }
            }
            catch
            {
                return null;
            }
        }
        
        private string ExtractXlsxText(string filePath)
        {
            try
            {
                using (var doc = DocumentFormat.OpenXml.Packaging.SpreadsheetDocument.Open(filePath, false))
                {
                    var workbookPart = doc.WorkbookPart;
                    if (workbookPart == null) return null;
                    
                    var textBuilder = new System.Text.StringBuilder();
                    
                    // Obtener tabla de strings compartidos
                    var stringTable = workbookPart.SharedStringTablePart?.SharedStringTable;
                    
                    // Leer primeras hojas
                    var sheets = workbookPart.Workbook.Descendants<DocumentFormat.OpenXml.Spreadsheet.Sheet>().Take(3);
                    
                    foreach (var sheet in sheets)
                    {
                        var worksheetPart = (DocumentFormat.OpenXml.Packaging.WorksheetPart)workbookPart.GetPartById(sheet.Id);
                        var sheetData = worksheetPart.Worksheet.Elements<DocumentFormat.OpenXml.Spreadsheet.SheetData>().FirstOrDefault();
                        
                        if (sheetData != null)
                        {
                            foreach (var row in sheetData.Elements<DocumentFormat.OpenXml.Spreadsheet.Row>().Take(100))
                            {
                                foreach (var cell in row.Elements<DocumentFormat.OpenXml.Spreadsheet.Cell>())
                                {
                                    string cellValue = GetCellValue(cell, stringTable);
                                    if (!string.IsNullOrEmpty(cellValue))
                                    {
                                        textBuilder.Append(cellValue);
                                        textBuilder.Append(" ");
                                    }
                                }
                            }
                        }
                        
                        // Limitar a ~50KB
                        if (textBuilder.Length > 50000)
                            break;
                    }
                    
                    return textBuilder.ToString();
                }
            }
            catch
            {
                return null;
            }
        }
        
        private string GetCellValue(DocumentFormat.OpenXml.Spreadsheet.Cell cell, DocumentFormat.OpenXml.Spreadsheet.SharedStringTable stringTable)
        {
            try
            {
                if (cell.CellValue == null) return null;
                
                string value = cell.CellValue.InnerText;
                
                if (cell.DataType != null && cell.DataType.Value == DocumentFormat.OpenXml.Spreadsheet.CellValues.SharedString)
                {
                    if (stringTable != null && int.TryParse(value, out int index))
                    {
                        return stringTable.ElementAt(index).InnerText;
                    }
                }
                
                return value;
            }
            catch
            {
                return null;
            }
        }
        
        private string ExtractPptxText(string filePath)
        {
            try
            {
                using (var doc = DocumentFormat.OpenXml.Packaging.PresentationDocument.Open(filePath, false))
                {
                    var presentationPart = doc.PresentationPart;
                    if (presentationPart == null) return null;
                    
                    var textBuilder = new System.Text.StringBuilder();
                    
                    // Leer primeras 10 diapositivas
                    var slideIds = presentationPart.Presentation.SlideIdList?.ChildElements.Take(10);
                    if (slideIds == null) return null;
                    
                    foreach (DocumentFormat.OpenXml.Presentation.SlideId slideId in slideIds)
                    {
                        var slidePart = (DocumentFormat.OpenXml.Packaging.SlidePart)presentationPart.GetPartById(slideId.RelationshipId);
                        
                        foreach (var text in slidePart.Slide.Descendants<DocumentFormat.OpenXml.Drawing.Text>())
                        {
                            textBuilder.Append(text.Text);
                            textBuilder.Append(" ");
                        }
                        
                        // Limitar a ~50KB
                        if (textBuilder.Length > 50000)
                            break;
                    }
                    
                    return textBuilder.ToString();
                }
            }
            catch
            {
                return null;
            }
        }
        
        private string ExtractOdtText(string filePath)
        {
            try
            {
                // ODT es un ZIP con content.xml
                using (var archive = System.IO.Compression.ZipFile.OpenRead(filePath))
                {
                    var contentEntry = archive.GetEntry("content.xml");
                    if (contentEntry == null) return null;
                    
                    using (var stream = contentEntry.Open())
                    using (var reader = new StreamReader(stream))
                    {
                        string content = reader.ReadToEnd();
                        // OPTIMIZACIÓN: Usar Regex compilado cacheado
                        content = RegexHtmlTags.Replace(content, " ");
                        // MEJORA #31: Usar indexador de rango
                        return content.Length > 100000 ? content[..100000] : content;
                    }
                }
            }
            catch
            {
                return null;
            }
        }
        
