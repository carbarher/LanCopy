        private void SaveAuthors()
        {
            try
            {
                System.IO.File.WriteAllLines(authorsPath, authors);
                Log($"Lista de autores guardada: {authors.Count} autores");
            }
            catch (Exception ex)
            {
                Log($"Error al guardar autores: {ex.Message}");
            }
        }
        
        private void LoadAuthors()
        {
            try
            {
                if (System.IO.File.Exists(authorsPath))
                {
                    authors = new HashSet<string>(System.IO.File.ReadAllLines(authorsPath), StringComparer.OrdinalIgnoreCase);
                    Log($"Lista de autores cargada: {authors.Count} autores");
                }
                else
                {
                    Log("No se encontró lista de autores");
                }
            }
            catch (Exception ex)
            {
                Log($"Error al cargar autores: {ex.Message}");
            }
        }
        
        private void SaveWatchlist()
        {
            try
            {
                System.IO.File.WriteAllLines(watchlistPath, watchlist);
            }
            catch { }
        }
        
        private async Task CheckWatchlist()
        {
            if (client == null || watchlist.Count == 0)
                return;
            
            // COMPORTAMIENTO HUMANO: Si hay muchos términos en watchlist (>10), aplicar delays variables
            bool useHumanBehavior = watchlist.Count > 10;
            if (useHumanBehavior)
            {
                Log($"🎭 Watchlist: Modo comportamiento humano ({watchlist.Count} términos)");
            }
            
            int searchCount = 0;
            foreach (var term in watchlist)
            {
                try
                {
                    searchCount++;
                    var oldSearch = cmbSearch.Text;
                    cmbSearch.Text = term;
                    await SearchAsync();
                    
                    // COMPORTAMIENTO HUMANO: Delay variable entre búsquedas
                    if (useHumanBehavior)
                    {
                        // DISTRIBUCIÓN ALEATORIA: Jitter avanzado para evitar patrones
                        int baseDelay = Random.Shared.Next(15000, 45000); // 15-45 segundos base
                        int jitter = Random.Shared.Next(-5000, 5000); // ±5s jitter adicional
                        int totalDelay = Math.Max(10000, baseDelay + jitter); // Mínimo 10s
                        
                        Log($"⏳ Watchlist: Esperando {totalDelay/1000}s (base:{baseDelay/1000}s + jitter:{jitter/1000}s)...");
                        await Task.Delay(totalDelay).ConfigureAwait(false); // MEJORA #37
                        
                        // Pausa cada 5 búsquedas con jitter exponencial
                        if (searchCount % 5 == 0)
                        {
                            int pauseBase = Random.Shared.Next(60000, 180000); // 1-3 minutos base
                            int pauseJitter = Random.Shared.Next(-30000, 30000); // ±30s jitter
                            int totalPause = Math.Max(30000, pauseBase + pauseJitter); // Mínimo 30s
                            
                            Log($"☕ Watchlist: Pausa de {totalPause/60000:F1} minutos (base:{pauseBase/60000:F1} + jitter:{pauseJitter/1000}s)...");
                            await Task.Delay(totalPause).ConfigureAwait(false); // MEJORA #37
                        }
                    }
                    else
                    {
                        // Jitter también en delays normales
                        int normalDelay = 5000 + Random.Shared.Next(-2000, 2000); // 3-7s
                        Log($"⏳ Delay normal: {normalDelay/1000}s");
                        await Task.Delay(normalDelay).ConfigureAwait(false); // MEJORA #37
                    }
                    
                    cmbSearch.Text = oldSearch;
                }
                catch { }
            }
        }
        
        private async Task RetryDownload()
        {
            if (lvDownloads.SelectedItems.Count == 0)
                return;
            
            int retriedCount = 0;
            var tasksToRetry = new List<(DownloadTask task, ListViewItem item)>();
            
            // Procesar TODOS los archivos seleccionados
            foreach (ListViewItem selectedItem in lvDownloads.SelectedItems)
            {
                var fileName = selectedItem.Text;
                
                // Buscar en la lista allDownloadItems o en downloadQueue
                var task = downloadQueue.FirstOrDefault(t => 
                    Path.GetFileName(t.File.FileName) == fileName || t.File.FileName == fileName);
                
                if (task != null)
                {
                    // Preparar para reintentar
                    selectedItem.SubItems[2].Text = "0%";
                    selectedItem.SubItems[3].Text = "🔄 Reintentando...";
                    selectedItem.ForeColor = Color.White;
                    
                    // Resetear estado de la tarea
                    task.Status = DownloadStatus.Queued;
                    task.ProgressPercent = 0;
                    task.BytesDownloaded = 0;
                    task.CancellationToken = new CancellationTokenSource();
                    
                    tasksToRetry.Add((task, selectedItem));
                    retriedCount++;
                }
            }
            
            if (retriedCount > 0)
            {
                Log($"🔄 Reintentando {retriedCount} descarga(s)");
                
                // Procesar todas las descargas en paralelo
                var retryTasks = tasksToRetry.Select(async pair =>
                {
                    try
                    {
                        await ProcessDownload(pair.task);
                    }
                    catch (Exception ex)
                    {
                        Log($"❌ Error al reintentar {pair.task.File.FileName}: {ex.Message}");
                        SafeInvoke(() =>
                        {
                            pair.item.SubItems[3].Text = $"❌ Error: {ex.Message}";
                            pair.item.ForeColor = Color.Red;
                        });
                    }
                });
                
                await Task.WhenAll(retryTasks);
            }
            else
            {
                DarkMessageBox.Show("No se encontraron descargas en la cola para reintentar", "Error", MessageBoxButtons.OK, MessageBoxIcon.Warning);
            }
        }
        
        private string FormatDuration(int seconds)
        {
            var ts = TimeSpan.FromSeconds(seconds);
            return ts.Hours > 0 ? $"{ts.Hours}:{ts.Minutes:D2}:{ts.Seconds:D2}" : $"{ts.Minutes}:{ts.Seconds:D2}";
        }
        
        private void FilterResults()
        {
            if (string.IsNullOrWhiteSpace(txtFilterResults.Text))
            {
                for (int i = 0; i < lvResults.Items.Count; i++)
                {
                    lvResults.Items[i].BackColor = Color.FromArgb(45, 45, 45);
                }
                return;
            }
            
            // MEJORA #11: IndexOf es más eficiente que ToLower().Contains()
            var filterText = txtFilterResults.Text;
            for (int i = 0; i < lvResults.Items.Count; i++)
            {
                var item = lvResults.Items[i];
                bool matches = false;
                
                for (int j = 0; j < item.SubItems.Count; j++)
                {
                    if (item.SubItems[j].Text.IndexOf(filterText, StringComparison.OrdinalIgnoreCase) >= 0)
                    {
                        matches = true;
                        break;
                    }
                }
                
                item.BackColor = matches ? Color.FromArgb(45, 45, 45) : Color.FromArgb(30, 30, 30);
            }
        }
        
        private void ExportToCSV()
        {
            try
            {
                var filePath = DarkFileDialog.ShowSaveDialog(this, "Exportar resultados", "CSV files (*.csv)|*.csv", $"slskdown-results-{DateTime.Now:yyyy-MM-dd-HHmmss}.csv");
                
                if (!string.IsNullOrWhiteSpace(filePath))
                {
                    var lines = new List<string>();
                    lines.Add("Archivo,Usuario,Tamaño,Velocidad,Carpeta");
                    
                    foreach (ListViewItem item in lvResults.Items)
                    {
                        var line = string.Join(",", item.SubItems.Cast<ListViewItem.ListViewSubItem>().Select(s => $"\"{s.Text}\""));
                        lines.Add(line);
                    }
                    
                    System.IO.File.WriteAllLines(filePath, lines);
                    Log($"✅ Exportado {lvResults.Items.Count} resultados a {filePath}");
                }
            }
            catch (Exception ex)
            {
                DarkMessageBox.Show($"Error al exportar: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
        private async Task TestConnection()
        {
            try
            {
                var testClient = new SoulseekClient(new SoulseekClientOptions(
                    listenPort: listenPort,
                    enableDistributedNetwork: enableDistributedNetwork
                ));
                
                await testClient.ConnectAsync(username, password);
                testClient.Dispose();
                
                DarkMessageBox.Show("✅ Conexión exitosa!", "Test Conexión", MessageBoxButtons.OK, MessageBoxIcon.Information);
                Log("Test de conexión exitoso");
            }
            catch (Exception ex)
            {
                DarkMessageBox.Show($"❌ Error de conexión: {ex.Message}", "Test Conexión", MessageBoxButtons.OK, MessageBoxIcon.Error);
                Log($"Test de conexión fallido: {ex.Message}");
            }
        }
        
        private void TabControl_DrawItem(object sender, DrawItemEventArgs e)
        {
            TabControl tabControl = (TabControl)sender;
            TabPage tabPage = tabControl.TabPages[e.Index];
            Rectangle tabRect = tabControl.GetTabRect(e.Index);
            
            // Color de fondo de la pestaña
            Color backColor = (e.State == DrawItemState.Selected) 
                ? Color.FromArgb(45, 45, 45) 
                : Color.FromArgb(25, 25, 25);
            
            using (SolidBrush brush = new SolidBrush(backColor))
            {
                e.Graphics.FillRectangle(brush, tabRect);
            }
            
            // Borde superior de la pestaña seleccionada
            if (e.State == DrawItemState.Selected)
            {
                using (Pen pen = new Pen(Color.FromArgb(0, 120, 215), 3))
                {
                    e.Graphics.DrawLine(pen, tabRect.Left, tabRect.Top, tabRect.Right, tabRect.Top);
                }
            }
            
            // Texto de la pestaña
            TextRenderer.DrawText(
                e.Graphics,
                tabPage.Text,
                tabControl.Font,
                tabRect,
                Color.White,
                TextFormatFlags.HorizontalCenter | TextFormatFlags.VerticalCenter
            );
        }
        
        // ===== FUNCIONALIDADES ADICIONALES =====
        
        private async Task SearchMultipleTerms(List<string> terms)
        {
            try
            {
                // Crear nuevo CancellationTokenSource
                searchCancellationTokenSource?.Cancel();
                searchCancellationTokenSource = new System.Threading.CancellationTokenSource();
                
                if (btnSearch != null) btnSearch.Enabled = false;
                if (btnStopSearch != null) btnStopSearch.Enabled = true;
                if (lblStatus != null) lblStatus.Text = $"Buscando {terms.Count} términos...";
                if (lvResults != null) lvResults.Items.Clear();
                allResults.Clear();
                
                int totalFiles = 0;
                
                // Interpretar 0 como sin límite
                int actualResponseLimit = responseLimit == 0 ? int.MaxValue : responseLimit;
                int actualFileLimit = fileLimit == 0 ? int.MaxValue : fileLimit;
                int actualTimeout = searchTimeout == 0 ? int.MaxValue : searchTimeout * 1000;
                
                // COMPORTAMIENTO HUMANO: Si hay muchos términos (>10), aplicar delays
                bool useHumanBehavior = terms.Count > 10;
                if (useHumanBehavior)
                {
                    Log($"🎭 Modo comportamiento humano activado ({terms.Count} términos)");
                }
                
                // Procesar términos en lotes paralelos según maxParallelSearches
                for (int i = 0; i < terms.Count; i += maxParallelSearches)
                {
                    var batch = terms.Skip(i).Take(maxParallelSearches).ToList();
                    Log($"📦 Procesando lote {(i/maxParallelSearches)+1}: {batch.Count} términos en paralelo");
                    
                    // Crear tareas de búsqueda para este lote
                    var searchTasks = batch.Select(async term =>
                    {
                        try
                        {
                            // Verificar si se canceló
                            searchCancellationTokenSource.Token.ThrowIfCancellationRequested();
                            
                            var startTime = DateTime.Now;
                            Log($"🔍 Iniciando: {term} (timeout: {actualTimeout/1000}s)");
                            
                            var searchOptions = new Soulseek.SearchOptions(
                                filterResponses: true,
                                maximumPeerQueueLength: actualResponseLimit,
                                searchTimeout: actualTimeout
                            );
                            
                            var searchResult = await client.SearchAsync(
                                SearchQuery.FromText(term), 
                                options: searchOptions
                            );
                            lastActivityTime = DateTime.UtcNow; // Sticky session
                            
                            var results = searchResult.Responses;
                            var elapsed = (DateTime.Now - startTime).TotalSeconds;
                            Log($"✅ {term}: {results.Count()} respuestas en {elapsed:F1}s");
                            
                            return (term, results);
                        }
                        catch (Exception ex)
                        {
                            Log($"❌ Error en {term}: {ex.Message}");
                            return (term, Enumerable.Empty<Soulseek.SearchResponse>());
                        }
                    }).ToList();
                    
                    // Esperar a que todas las búsquedas del lote terminen
                    var batchResults = await Task.WhenAll(searchTasks);
                    
                    // COMPORTAMIENTO HUMANO: Delay entre lotes si hay muchos términos
                    if (useHumanBehavior && i + maxParallelSearches < terms.Count)
                    {
                        int batchDelay = Random.Shared.Next(10000, 30000); // 10-30 segundos entre lotes
                        Log($"⏳ Pausa de {batchDelay/1000}s antes del siguiente lote...");
                        await Task.Delay(batchDelay, searchCancellationTokenSource.Token);
                    }
                    
                    // Procesar resultados de este lote
                    long minSizeBytes = numMinSize != null ? (long)(numMinSize.Value * 1024) : 0;
                    long maxSizeBytes = numMaxSize != null && numMaxSize.Value > 0 ? (long)(numMaxSize.Value * 1024) : long.MaxValue;
                    string extFilter = cmbExtension?.SelectedItem?.ToString();
                    
                    foreach (var (term, results) in batchResults)
                    {
                        foreach (var response in results)
                        {
                            // Verificar cancelación
                            searchCancellationTokenSource.Token.ThrowIfCancellationRequested();
                            
                            if (blacklist.Contains(response.Username))
                                continue;
                            
                            foreach (var file in response.Files.Take(500))
                            {
                                // Descartar archivos de tamaño 0
                                if (file.Size == 0)
                                    continue;
                                
                                if (minSizeBytes > 0 && file.Size < minSizeBytes)
                                    continue;
                                if (maxSizeBytes < long.MaxValue && file.Size > maxSizeBytes)
                                    continue;
                                
                                string fileExt = Path.GetExtension(file.Filename).ToLower();
                                if (!MatchesCategory(fileExt, extFilter))
                                    continue;
                                
                                // Filtro de idioma español
                                if (chkSpanishOnly != null && chkSpanishOnly.Checked && !IsSpanishText(file.Filename))
                                    continue;
                                
                                // Crear SearchResultItem
                                var searchItem = new SearchResultItem
                                {
                                    Username = response.Username,
                                    Filename = Path.GetFileName(file.Filename),
                                    Size = file.Size,
                                    Extension = fileExt,
                                    FolderPath = Path.GetDirectoryName(file.Filename) ?? "",
                                    UploadSpeed = response.UploadSpeed,
                                    Network = "Soulseek" // Red de origen
                                };
                                allResults.Add(searchItem);
                                totalFiles++;
                                
                                // Actualizar contador cada 10 archivos (más inmediato)
                                if (totalFiles % 10 == 0)
                                {
                                    UpdateSearchResults(allResults);
                                    SafeInvoke(() =>
                                    {
                                        if (lblResultsCount != null) lblResultsCount.Text = $"{totalFiles:N0} archivos...";
                                        if (lblStatus != null) lblStatus.Text = $"Búsqueda múltiple... {totalFiles:N0} encontrados";
                                    });
                                }
                            }
                        }
                    }
                }
                
                // Actualizar Virtual ListView con todos los resultados
                UpdateSearchResults(allResults);
                
                if (lblStatus != null) lblStatus.Text = $"{totalFiles} archivos encontrados ({terms.Count} búsquedas)";
                if (lblResultsCount != null) lblResultsCount.Text = $"{totalFiles} resultados";
                Log($"✅ Búsqueda múltiple completada: {totalFiles} archivos de {terms.Count} términos");
            }
            catch (OperationCanceledException)
            {
                if (lblStatus != null) lblStatus.Text = "Búsqueda múltiple cancelada";
                if (lblResultsCount != null) lblResultsCount.Text = $"{allResults.Count} resultados (cancelado)";
                Log("Búsqueda múltiple cancelada por el usuario");
            }
            catch (Exception ex)
            {
                if (lblStatus != null) lblStatus.Text = $"Error: {ex.Message}";
                Log($"Error en búsqueda múltiple: {ex.Message}");
            }
            finally
            {
                if (btnSearch != null) btnSearch.Enabled = true;
                if (btnStopSearch != null) btnStopSearch.Enabled = false;
            }
        }
        
        
        private void SaveStats()
        {
            try
            {
                var stats = new
                {
                    totalSearches,
                    totalDownloads,
                    searchStats,
                    lastUpdate = DateTime.Now
                };
                System.IO.File.WriteAllText(statsPath, JsonSerializer.Serialize(stats));
            }
            catch (Exception ex)
            {
                Log($"Error al guardar estadísticas: {ex.Message}");
            }
        }
        
        private void LoadStats()
        {
            try
            {
                if (System.IO.File.Exists(statsPath))
                {
                    var json = System.IO.File.ReadAllText(statsPath);
                    var doc = JsonDocument.Parse(json);
                    totalSearches = doc.RootElement.GetProperty("totalSearches").GetInt32();
                    totalDownloads = doc.RootElement.GetProperty("totalDownloads").GetInt32();
                    
                    if (doc.RootElement.TryGetProperty("searchStats", out var statsElement))
                    {
                        foreach (var prop in statsElement.EnumerateObject())
                        {
                            searchStats[prop.Name] = prop.Value.GetInt32();
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                Log($"Error al cargar estadísticas: {ex.Message}");
            }
        }
        
        // ===== OPTIMIZACIÓN #8: POOL DE CONEXIONES =====
        
        private SoulseekClient GetClientFromPool()
        {
            // Si el pool no está listo, usar cliente principal
            if (clientPool == null || clientPool.Count == 0)
                return client;

            // Rotar entre clientes del pool (sin lock: uso UI-thread predominante)
            var index = clientPool.Count == 0 ? 0 : (currentClientIndex % clientPool.Count);
            var selectedClient = clientPool[index];
            currentClientIndex = (currentClientIndex + 1) % Math.Max(1, clientPool.Count);

            // Verificar que el cliente esté conectado
            if (selectedClient?.State == SoulseekClientStates.Connected)
                return selectedClient;

            // Fallback al cliente principal
            return client;
        }
        
        // ===== OPTIMIZACIÓN #16: BLOOM FILTER =====
        
        private void InitializeBloomFilter()
        {
            bloomFilter = new System.Collections.BitArray(BLOOM_SIZE, false);
            AutoLog($"🌸 Bloom Filter inicializado: {BLOOM_SIZE / 1_000_000}M bits ({BLOOM_SIZE / 8 / 1024}KB)");
        }
        
        private void InitializeLockFreeLogging()
        {
            // Buffer de 50,000 mensajes (sin locks!)
            logBuffer = new LockFreeStructures.LockFreeRingBuffer<string>(50000);
            
            // Thread dedicado para procesar logs
            logProcessorRunning = true;
            logProcessorThread = new System.Threading.Thread(() =>
            {
                while (logProcessorRunning)
                {
                    if (logBuffer.TryRead(out string message))
                    {
                        ProcessLogMessage(message);
                    }
                    else
                    {
                        // MEJORA #7: SpinWait es más eficiente que Thread.Sleep para esperas cortas
                        System.Threading.Thread.SpinWait(1000); // ~1-2μs en lugar de 10ms
                    }
                }
            })
            {
                IsBackground = true,
                Priority = System.Threading.ThreadPriority.BelowNormal
            };
            logProcessorThread.Start();
            
            AutoLog("🚀 Sistema de logs lock-free inicializado (buffer: 50K mensajes)");
            AutoLog($"📁 Los logs se guardan en: {logDir}");
        }
        
        private void ProcessLogMessage(string message)
        {
            try
            {
                // Crear directorio de logs si no existe
                System.IO.Directory.CreateDirectory(logDir);
                var logFile = Path.Combine(logDir, $"slskdown-{DateTime.Now:yyyy-MM-dd}.txt");
                
                // Escribir en archivo con retry simple
                for (int i = 0; i < 3; i++)
                {
                    try
                    {
                        System.IO.File.AppendAllText(logFile, message + Environment.NewLine);
                        break;
                    }
                    catch (IOException) when (i < 2)
                    {
                        // MEJORA #7: SpinWait para retry rápido
                        System.Threading.Thread.SpinWait(5000); // ~5μs
                    }
                }
                
                // Actualizar UI si es necesario
                if (txtLog != null && !txtLog.IsDisposed)
                {
                    SafeBeginInvoke(() =>
                    {
                        txtLog.AppendText(message + Environment.NewLine);
                        txtLog.SelectionStart = txtLog.Text.Length;
                        txtLog.ScrollToCaret();
                    });
                }
            }
            catch
            {
                // Ignorar errores silenciosamente para no interrumpir el flujo
            }
        }
        
        private void CleanupOldLogs()
        {
            try
            {
                if (!System.IO.Directory.Exists(logDir))
                    return;
                
                // MEJORA #28: Usar UtcNow (más rápido que Now)
                var cutoffDate = DateTime.UtcNow.AddDays(-logRetentionDays);
                var logFiles = System.IO.Directory.GetFiles(logDir, "slskdown-*.txt");
                int deletedCount = 0;
                long totalSize = 0;
                
                foreach (var logFile in logFiles)
                {
                    try
                    {
                        // MEJORA #27: Usar caché de FileInfo
                        var fileInfo = GetCachedFileInfo(logFile);
                        
                        // Eliminar si es más antiguo que el período de retención
                        if (fileInfo.LastWriteTime < cutoffDate)
                        {
                            totalSize += fileInfo.Length;
                            System.IO.File.Delete(logFile);
                            deletedCount++;
                        }
                    }
                    catch (Exception ex)
                    {
                        System.Diagnostics.Debug.WriteLine($"Error eliminando log {logFile}: {ex.Message}");
                    }
                }
                
                if (deletedCount > 0)
                {
                    AutoLog($"🧹 Limpieza de logs: {deletedCount} archivo(s) eliminado(s) ({FormatFileSize(totalSize)} liberados)");
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error en limpieza de logs: {ex.Message}");
            }
        }
        
        private void InitializeCircuitBreakerPersistence()
        {
            try
            {
                circuitBreakerPersistence = new CircuitBreakerPersistence(dataDir);
                
                // Cargar circuit breakers guardados
                var loadedBreakers = circuitBreakerPersistence.LoadCircuitBreakers();
                userCircuitBreakers = new ConcurrentDictionary<string, RetryPolicy.CircuitBreaker>(loadedBreakers);
                
                var stats = circuitBreakerPersistence.GetStatistics();
                AutoLog($"💾 Circuit breakers cargados: {stats.total} total ({stats.open} abiertos, {stats.halfOpen} semi-abiertos)");
                
                // Limpiar breakers antiguos
                var cleaned = circuitBreakerPersistence.CleanupOldBreakers();
                if (cleaned > 0)
                {
                    AutoLog($"🧹 Limpiados {cleaned} circuit breakers antiguos");
                }
                
                // Timer para guardar periódicamente
                saveTimer = new System.Windows.Forms.Timer { Interval = TIMER_SAVE_INTERVAL_MS };
                saveTimer.Tick += (s, e) => SaveCircuitBreakers();
                saveTimer.Start();
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error inicializando persistencia de circuit breakers: {ex.Message}");
            }
        }
        
        private void SaveCircuitBreakers()
        {
            try
            {
                foreach (var kvp in userCircuitBreakers)
                {
                    circuitBreakerPersistence.SaveCircuitBreaker(kvp.Key, kvp.Value);
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error guardando circuit breakers: {ex.Message}");
            }
        }
        
        private void InitializeConnectionMonitor()
        {
            connectionMonitor = new ConnectionMonitor();
            
            connectionMonitor.NetworkStatusChanged += (isAvailable) =>
            {
                SafeBeginInvoke(() =>
                {
                    if (isAvailable)
                    {
                        AutoLog("✅ Conexión a internet restaurada");
                    }
                    else
                    {
                        AutoLog("⚠️ Sin conexión a internet");
                        lblStatus.Text = "Sin conexión a internet";
                        lblStatus.ForeColor = Color.Red;
                    }
                });
            };
            
            connectionMonitor.ConnectionLost += () =>
            {
                SafeBeginInvoke(() =>
                {
                    AutoLog("🌐 Conexión perdida - pausando operaciones");
                    lblConnectionQuality.Text = "🔴 Sin conexión";
                    lblConnectionQuality.ForeColor = Color.Red;
                });
            };
            
            connectionMonitor.ConnectionRestored += async () =>
            {
                SafeBeginInvoke(() =>
                {
                    AutoLog("🌐 Conexión restaurada - reanudando");
                    lblConnectionQuality.Text = "🟢 Conectado";
                    lblConnectionQuality.ForeColor = Color.LimeGreen;
                });
                
                // Intentar reconectar si es necesario
                if (autoReconnect)
                {
                    await Task.Delay(2000);
                    await CheckAndReconnect();
                }
            };
            
            // Iniciar monitoreo
            connectionMonitor.Start(intervalSeconds: 30);
            
            // Actualizar calidad de conexión periódicamente
            qualityTimer = new System.Windows.Forms.Timer { Interval = TIMER_QUALITY_CHECK_MS };
            qualityTimer.Tick += async (s, e) => await UpdateConnectionQuality();
            qualityTimer.Start();
            
            // Timer para verificar estado del cliente y auto-reconectar si es necesario
            reconnectCheckTimer = new System.Windows.Forms.Timer { Interval = TIMER_RECONNECT_CHECK_MS };
            reconnectCheckTimer.Tick += async (s, e) =>
            {
                if (autoReconnect && client != null)
                {
                    // Verificar si el cliente está desconectado
                    if (client.State == SoulseekClientStates.Disconnected || 
                        (!client.State.HasFlag(SoulseekClientStates.Connected) && 
                         !client.State.HasFlag(SoulseekClientStates.LoggedIn)))
                    {
                        AutoLog($"⚠️ Cliente desconectado detectado (Estado: {client.State})");
                        // MEJORA #26: Eliminar Task.Run redundante
                        _ = CheckAndReconnect();
                    }
                }
            };
            reconnectCheckTimer.Start();
            
            AutoLog("🌐 Monitor de conexión inicializado");
            AutoLog("🔄 Auto-reconexión habilitada");
        }
        
        private async Task UpdateConnectionQuality()
        {
            try
            {
                var quality = await connectionMonitor.GetConnectionQuality();
                var latency = await connectionMonitor.GetLatency("8.8.8.8");
                
                SafeBeginInvoke(() =>
                {
                    switch (quality)
                    {
                        case ConnectionQuality.Excellent:
                            lblConnectionQuality.Text = $"🟢 Excelente ({latency}ms)";
                            lblConnectionQuality.ForeColor = Color.LimeGreen;
                            break;
                        case ConnectionQuality.Good:
                            lblConnectionQuality.Text = $"🟡 Buena ({latency}ms)";
                            lblConnectionQuality.ForeColor = Color.Yellow;
                            break;
                        case ConnectionQuality.Fair:
                            lblConnectionQuality.Text = $"🟠 Regular ({latency}ms)";
                            lblConnectionQuality.ForeColor = Color.Orange;
                            break;
                        case ConnectionQuality.Poor:
                            lblConnectionQuality.Text = $"🔴 Mala ({latency}ms)";
                            lblConnectionQuality.ForeColor = Color.OrangeRed;
                            break;
                        case ConnectionQuality.None:
                            lblConnectionQuality.Text = "🔴 Sin conexión";
                            lblConnectionQuality.ForeColor = Color.Red;
                            break;
                    }
                });
            }
            catch
            {
                // Ignorar errores silenciosamente
            }
        }
        
        
        private int[] GetBloomHashes(string key)
        {
            var hashes = new int[BLOOM_HASHES];
            var hash1 = key.GetHashCode();
            var hash2 = key.Reverse().ToString().GetHashCode();
            
            for (int i = 0; i < BLOOM_HASHES; i++)
            {
                hashes[i] = Math.Abs((hash1 + i * hash2) % BLOOM_SIZE);
            }
            return hashes;
        }
        
        private void BloomAdd(string key)
        {
            if (bloomFilter == null) return;
            foreach (var hash in GetBloomHashes(key))
            {
                bloomFilter[hash] = true;
            }
        }
        
        private bool BloomMightContain(string key)
        {
            if (bloomFilter == null) return true; // Si no hay bloom, asumir que puede existir
            foreach (var hash in GetBloomHashes(key))
            {
                if (!bloomFilter[hash]) return false; // Definitivamente NO existe
            }
            return true; // Puede existir (o falso positivo)
        }
        
        // ===== OPTIMIZACIÓN #15: DEDUPLICACIÓN POR HASH =====
        
        private string CheckDuplicateFile(string filePath, string hash)
        {
            // MEJORA FASE 1.2: Lock-free con ConcurrentDictionary
            if (hashToFilePath.TryGetValue(hash, out var existingPath))
            {
                if (System.IO.File.Exists(existingPath))
                {
                    AutoLog($"♻️ Archivo duplicado detectado: {Path.GetFileName(filePath)}");
                    return existingPath;
                }
            }
            hashToFilePath.TryAdd(hash, filePath);
            return null;
        }
        
        private void CreateHardLink(string existingPath, string newPath)
        {
            try
            {
                // Crear hardlink en Windows
                var result = System.IO.File.CreateSymbolicLink(newPath, existingPath);
                AutoLog($"🔗 Hardlink creado: {Path.GetFileName(newPath)} → {Path.GetFileName(existingPath)}");
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ No se pudo crear hardlink: {ex.Message}");
            }
        }
        
        // ===== OPTIMIZACIÓN #11: CACHÉ DE METADATOS =====
        
        private T GetCachedMetadata<T>(string key) where T : class
        {
            return metadataCache.Get(key) as T;
        }
        
        private void SetCachedMetadata<T>(string key, T value) where T : class
        {
            var policy = new System.Runtime.Caching.CacheItemPolicy
            {
                AbsoluteExpiration = DateTimeOffset.Now.AddHours(METADATA_CACHE_HOURS)
            };
            metadataCache.Set(key, value, policy);
        }
        
        // ===== OPTIMIZACIÓN #13: COMPRESIÓN LZ4 =====
        
        private byte[] CompressLZ4(byte[] data)
        {
            // OPTIMIZACIÓN: Usar ArrayPool para reducir GC pressure
            var maxSize = K4os.Compression.LZ4.LZ4Codec.MaximumOutputSize(data.Length);
            var target = System.Buffers.ArrayPool<byte>.Shared.Rent(maxSize);
            try
            {
                var encodedLength = K4os.Compression.LZ4.LZ4Codec.Encode(
                    data, 0, data.Length,
                    target, 0, maxSize,
                    K4os.Compression.LZ4.LZ4Level.L00_FAST
                );
                
                // Copiar solo los bytes comprimidos al resultado final
                var result = new byte[encodedLength];
                Array.Copy(target, 0, result, 0, encodedLength);
                return result;
            }
            finally
            {
                System.Buffers.ArrayPool<byte>.Shared.Return(target);
            }
        }
        
        private byte[] DecompressLZ4(byte[] compressed, int originalSize)
        {
            // OPTIMIZACIÓN: Usar ArrayPool para reducir GC pressure
            var target = System.Buffers.ArrayPool<byte>.Shared.Rent(originalSize);
            try
            {
                var decodedLength = K4os.Compression.LZ4.LZ4Codec.Decode(
                    compressed, 0, compressed.Length,
                    target, 0, originalSize
                );
                
                // Copiar solo los bytes descomprimidos al resultado final
                var result = new byte[decodedLength];
                Array.Copy(target, 0, result, 0, decodedLength);
                return result;
            }
            finally
            {
                System.Buffers.ArrayPool<byte>.Shared.Return(target);
            }
        }
        
        // ===== OPTIMIZACIÓN #23: SIMD PARA PROCESAMIENTO DE TEXTO =====
        
        private bool ContainsSpanishKeywordsSIMD(string text)
        {
            if (string.IsNullOrEmpty(text)) return false;
            
            // Convertir a lowercase usando Span<char> (zero-copy)
            Span<char> textSpan = stackalloc char[Math.Min(text.Length, 512)];
            text.AsSpan(0, Math.Min(text.Length, 512)).ToLowerInvariant(textSpan);
            
            // Búsqueda vectorizada de keywords
            ReadOnlySpan<char> keywords = "español spanish castellano es-es latino";
            return textSpan.IndexOfAny(keywords) >= 0;
        }
        
        private bool FastStringContains(ReadOnlySpan<char> haystack, ReadOnlySpan<char> needle)
        {
            // Usar SIMD-optimized IndexOf de .NET
            return haystack.IndexOf(needle, StringComparison.OrdinalIgnoreCase) >= 0;
        }
        
        // ===== KEEP-ALIVE =====
        
        private void StartKeepAliveTimer()
        {
            try
            {
                // Detener timer anterior si existe
                StopKeepAliveTimer();
                
                // FIX: Intervalo de 90s para evitar timeout del servidor (~3 min de inactividad)
                keepAliveTimer = new System.Windows.Forms.Timer();
                var baseInterval = 90 * 1000; // 90 segundos (servidor timeout ~180s)
                var jitterMs = portRng.Next(-5 * 1000, 5 * 1000); // ±5 seg para evitar patrones
                keepAliveTimer.Interval = Math.Max(60000, baseInterval + jitterMs); // mínimo 60 seg
                keepAliveTimer.Tick += async (s, e) => await KeepAliveCheck();
                keepAliveTimer.Start();
                
                Log($"🔔 Keep-alive timer iniciado ({keepAliveTimer.Interval / 1000:F0}s con jitter)");
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error iniciando keep-alive timer: {ex.Message}");
            }
        }
        
        private void StopKeepAliveTimer()
        {
            try
            {
                if (keepAliveTimer != null)
                {
                    keepAliveTimer.Stop();
                    keepAliveTimer.Dispose();
                    keepAliveTimer = null;
                    Log("🔕 Keep-alive timer detenido");
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error deteniendo keep-alive timer: {ex.Message}");
            }
        }
        
        private async Task KeepAliveCheck()
        {
            if (keepAliveInProgress)
            {
                Log("⏳ Keep-alive ya en curso - omitiendo");
                return;
            }
            
            // CRÍTICO: No ejecutar keep-alive durante purga
            if (autoPurgeRunning)
            {
                CriticalLog("⏭️ Keep-alive OMITIDO: purga en curso");
                return;
            }

            try
            {
                keepAliveInProgress = true;
                if (client == null)
                {
                    Log("⚠️ Keep-alive: Cliente es null");
                    return;
                }
                
                var state = client.State;
                bool isConnected = state.HasFlag(SoulseekClientStates.Connected) || 
                                   state.HasFlag(SoulseekClientStates.LoggedIn);
                
                if (!isConnected)
                {
                    Log($"❌ Keep-alive: Estado {state} - solicitando reconexión");
                    // MEJORA #26: Eliminar Task.Run redundante
                    _ = CheckAndReconnect();
                    return;
                }
                
                // FIX: Siempre enviar keep-alive porque Auto-Tuner actualiza lastActivityTime
                // pero no genera tráfico de red real, causando timeout del servidor
                Log("💓 Keep-alive: enviando ping al servidor...");
                
                // DETECCIÓN DE DEGRADACIÓN DE RED: Medir latencia y pérdida
                var pingStart = DateTime.UtcNow;
                bool pingSuccess = false;
                
                try
                {
                    using (var cts = new CancellationTokenSource(TimeSpan.FromSeconds(5)))
                    {
                        await ExecuteWithReconnect(
                            () => client.SearchAsync(
                                SearchQuery.FromText($"keepalive_{Guid.NewGuid():N}"),
                                options: new Soulseek.SearchOptions(
                                    searchTimeout: 1000,
                                    responseLimit: 1,
                                    filterResponses: true),
                                cancellationToken: cts.Token),
                            "keepalive ping");
                    }
                    
                    pingSuccess = true;
                    var latency = (long)(DateTime.UtcNow - pingStart).TotalMilliseconds;
                    lastActivityTime = DateTime.UtcNow; // Idea #11: sticky session
                    
                    // Actualizar métricas de red
                    recentLatencies.Enqueue(latency);
                    recentPingSuccesses.Enqueue(true);
                    
                    if (recentLatencies.Count > maxNetworkSamples)
                    {
                        recentLatencies.Dequeue();
                        recentPingSuccesses.Dequeue();
                    }
                    
                    // Calcular promedios
                    averageLatency = recentLatencies.Average();
                    var successCount = recentPingSuccesses.Count(x => x);
                    packetLossRate = recentPingSuccesses.Count > 0 ? 
                        (1.0 - (double)successCount / recentPingSuccesses.Count) * 100 : 0;
                    
                    Log($"📊 Métricas de red: Latencia={averageLatency:F0}ms, Pérdida={packetLossRate:F1}%");
                    
                    // ACTUALIZAR HEALTH SCORE en keep-alive
                    UpdateConnectionHealthScore();
                    
                    // Idea #5: Health-based throttling
                    ApplyHealthBasedThrottling();
                    
                    // Idea #1: Check port rotation
                    CheckPortRotation();
                    
                    // Detectar degradación
                    if (averageLatency > 2000 || packetLossRate > 20)
                    {
                        Log($"⚠️ DEGRADACIÓN DE RED DETECTADA - Latencia alta o pérdida elevada");
                        if (!conservativeMode)
                        {
                            conservativeMode = true;
                            AutoLog("🛡️ MODO CONSERVADOR ACTIVADO por degradación de red");
                        }
                    }
                }
                catch (OperationCanceledException)
                {
                    Log("⚠️ Keep-alive cancelado por timeout (normal)");
                    recentPingSuccesses.Enqueue(false);
                }
                catch (TimeoutException)
                {
                    Log("⚠️ Keep-alive timeout - podría ser inactividad");
                    recentPingSuccesses.Enqueue(false);
                }
                catch (Exception ex)
                {
                    Log($"⚠️ Keep-alive ping falló: {ex.Message}");
                    recentPingSuccesses.Enqueue(false);
                }
                
                // Mantener tamaño de cola de ping successes
                if (recentPingSuccesses.Count > maxNetworkSamples)
                {
                    recentPingSuccesses.Dequeue();
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error en keep-alive check: {ex.Message}");
            }
            finally
            {
                keepAliveInProgress = false;
            }
        }

        private int GetBackoffDelaySeconds(int attempt, bool isReconnect = false)
        {
            if (useExponentialBackoff)
            {
                int baseSec = isReconnect ? exponentialBaseSecondsReconnect : exponentialBaseSecondsConnect;
                double val = baseSec * Math.Pow(2, Math.Max(0, attempt - 1));
                return (int)Math.Min(exponentialCapSeconds, Math.Max(1, val));
            }
            else
            {
                int[] connectDelays = { 10, 30, 60, 90, 120 };
                int[] reconnectDelays = { 30, 60, 120, 240, 300 };
                var table = isReconnect ? reconnectDelays : connectDelays;
                return table[Math.Min(attempt - 1, table.Length - 1)];
            }
        }

        private async Task DelayWithCancellation(TimeSpan delay, CancellationToken token)
        {
            try
            {
                if (delay <= TimeSpan.Zero) return;
                await Task.Delay(delay, token);
            }
            catch (OperationCanceledException)
            {
                Log("⏹️ Delay cancelado por cierre de aplicación");
            }
        }

        private void StartConnectionMonitor()
        {
            try
            {
                if (connectionMonitorTask != null && !connectionMonitorTask.IsCompleted)
                    return;
                if (appCts == null || appCts.IsCancellationRequested)
                    appCts = new CancellationTokenSource();
                var token = appCts.Token;
                connectionMonitorTask = Task.Run(async () =>
                {
                    while (!token.IsCancellationRequested)
                    {
                        try
                        {
                            // MEJORA #3: Delay adaptativo optimizado según estado y bloqueos
                            int delaySeconds = 5; // Normal: verificar cada 5s
                            
                            if (autoReconnect && !IsClientConnected() && !isConnecting && !isReconnecting)
                            {
                                // Solo monitorear si Soulseek está habilitado
                                if (_networkConfig?.SoulseekEnabled == false)
                                {
                                    delaySeconds = 60; // Verificar cada minuto cuando está deshabilitado
                                }
                                else if (DateTime.UtcNow >= nextAllowedReconnect)
                                {
                                    Log("🔍 Monitor: desconectado - solicitando CheckAndReconnect()");
                                    await CheckAndReconnect();
                                }
                                else
                                {
                                    // Si estamos esperando por cooldown, usar delay más largo
                                    var timeUntilReconnect = (nextAllowedReconnect - DateTime.UtcNow).TotalSeconds;
                                    
                                    // MEJORA #3: Delays optimizados según duración de espera
                                    if (timeUntilReconnect > 600) // Más de 10 minutos (bloqueo largo)
                                    {
                                        delaySeconds = 120; // Verificar cada 2 minutos
                                        Log($"💤 Monitor en modo ahorro: {timeUntilReconnect/60:F1}m restantes - verificando cada 2 min");
                                    }
                                    else if (timeUntilReconnect > 300) // Más de 5 minutos
                                    {
                                        delaySeconds = 60; // Verificar cada minuto
                                    }
                                    else if (timeUntilReconnect > 60) // Más de 1 minuto
                                    {
                                        delaySeconds = 30; // Verificar cada 30s
                                    }
                                    else
                                    {
                                        delaySeconds = 10; // Verificar cada 10s cuando queda poco
                                    }
                                }
                            }
                            else if (isReconnecting || isConnecting)
                            {
                                // Durante reconexión activa, verificar cada minuto para reducir CPU
                                delaySeconds = 60;
                            }
                            
                            await DelayWithCancellation(TimeSpan.FromSeconds(delaySeconds), token);
                        }
                        catch (Exception ex)
                        {
                            Log($"Monitor de conexión: {ex.Message}");
                            await DelayWithCancellation(TimeSpan.FromSeconds(5), token);
                        }
                    }
                }, token);
            }
            catch (Exception ex)
            {
                Log($"❌ Error iniciando monitor de conexión: {ex.Message}");
            }
        }

        // MEJORA #5: Health check periódico (ping cada 5 minutos cuando idle)
        private void InitializeHealthCheck()
        {
            try
            {
                // Inicializar timer para health check cada 5 minutos
                healthCheckTimer = new System.Threading.Timer(
                    callback: async _ => await PerformHealthCheck(),
                    state: null,
                    dueTime: TimeSpan.FromMinutes(HEALTH_CHECK_INTERVAL_MINUTES),
                    period: TimeSpan.FromMinutes(HEALTH_CHECK_INTERVAL_MINUTES)
                );
                
                Log($"✅ Health check periódico inicializado (cada {HEALTH_CHECK_INTERVAL_MINUTES} minutos)");
            }
            catch (Exception ex)
            {
                Log($"❌ Error inicializando health check: {ex.Message}");
            }
        }
        
        private async Task PerformHealthCheck()
        {
            try
            {
                // Solo hacer health check si:
                // 1. El cliente está conectado
                // 2. No hay actividad reciente (idle)
                // 3. No estamos en medio de una reconexión
                
                if (client == null || !IsClientConnected())
                {
                    AutoLog("⏭️ Health check omitido: cliente no conectado");
                    return;
                }
                
                if (isConnecting || isReconnecting || isReconnectCoolingDown)
                {
                    AutoLog("⏭️ Health check omitido: reconexión en curso");
                    return;
                }
                
                // Verificar si hay actividad reciente (últimos 5 minutos)
                var now = DateTime.UtcNow;
                var timeSinceLastActivity = (now - lastHealthCheck).TotalMinutes;
                
                // Si hubo actividad reciente, no hacer ping
                if (timeSinceLastActivity < HEALTH_CHECK_INTERVAL_MINUTES)
                {
                    AutoLog($"⏭️ Health check omitido: actividad reciente ({timeSinceLastActivity:F1}m atrás)");
                    return;
                }
                
                // Realizar ping al servidor
                AutoLog("🏥 Realizando health check periódico...");
                
                try
                {
                    // Verificar el estado de la conexión directamente
                    if (client.State.HasFlag(SoulseekClientStates.Connected) && 
                        client.State.HasFlag(SoulseekClientStates.LoggedIn))
                    {
                        // Conexión activa
                        lastHealthCheck = now;
                        sessionMetrics?.RecordConnectionHealthCheck(true);
                        AutoLog("✅ Health check exitoso - conexión saludable");
                    }
                    else
                    {
                        // Desconectado
                        sessionMetrics?.RecordConnectionHealthCheck(false);
                        AutoLog("⚠️ Health check falló - cliente desconectado");
                        
                        // Intentar reconectar proactivamente
                        if (autoReconnect && !isReconnecting)
                        {
                            AutoLog("🔄 Iniciando reconexión proactiva por health check fallido");
                            _ = CheckAndReconnect();
                        }
                    }
                }
                catch (Exception pingEx)
                {
                    sessionMetrics?.RecordConnectionHealthCheck(false);
                    AutoLog($"❌ Health check fallido: {pingEx.Message}");
                    
                    // Intentar reconectar proactivamente
                    if (autoReconnect && !isReconnecting)
                    {
                        AutoLog("🔄 Iniciando reconexión proactiva por health check fallido");
                        _ = CheckAndReconnect();
                    }
                }
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error en health check: {ex.Message}");
            }
        }

        private void RecordCooldownFromLastFailure(DateTime successTime)
        {
            if (lastFailureTime == DateTime.MinValue) return;
            var seconds = (successTime - lastFailureTime).TotalSeconds;
            if (seconds > 0 && seconds < 36000)
            {
                cooldownHistorySeconds.Value.Add(seconds);
                if (cooldownHistorySeconds.Value.Count > 50) cooldownHistorySeconds.Value.RemoveAt(0);
            }
            lastFailureTime = DateTime.MinValue;
        }

        private double GetRecommendedCooldownSeconds()
        {
            if (!cooldownHistorySeconds.IsValueCreated || cooldownHistorySeconds.Value.Count < 3) return 0;
            var sorted = cooldownHistorySeconds.Value.OrderBy(x => x).ToArray();
            int n = sorted.Length;
            double p = 0.8;
            double idx = (n - 1) * p;
            int lo = (int)Math.Floor(idx);
            int hi = (int)Math.Ceiling(idx);
            if (lo == hi) return ClampCooldown(sorted[lo]);
            double val = sorted[lo] + (sorted[hi] - sorted[lo]) * (idx - lo);
            return ClampCooldown(val);
        }

        private double ClampCooldown(double v)
        {
            if (v < 30) return 30;
            if (v > 600) return 600;
            return v;
        }

        private int GetTimeoutPenaltyDelaySeconds(int consecutiveTimeouts)
        {
            if (consecutiveTimeouts <= 0)
            {
                return 0;
            }

            // Penalizaciones progresivas ULTRA CONSERVADORAS - evitar bloqueos de IP del servidor
            // Timeouts consecutivos indican posible rate limiting o bloqueo temporal
            // Aumentar delays significativamente para dar tiempo al servidor a "olvidar" la IP
            // MEJORA: Primer timeout aumentado de 60s a 120s para evitar rate limiting
            int[] timeoutPenalties = { 120, 240, 360, 600, 900, 1800 }; // 2m, 4m, 6m, 10m, 15m, 30m
            return timeoutPenalties[Math.Min(consecutiveTimeouts - 1, timeoutPenalties.Length - 1)];
        }

        private TimeSpan GetJitter(TimeSpan baseDelay)
        {
            lock (reconnectRandomLock)
            {
                var jitterMs = reconnectRandom.Next(0, (int)Math.Max(250, baseDelay.TotalMilliseconds * 0.15));
                return TimeSpan.FromMilliseconds(jitterMs);
            }
        }
        
        // MEJORA #2: Métodos del sistema de métricas y aprendizaje
        private void StartPurgeSession()
        {
            currentSession = new PurgeSessionMetrics
            {
                SessionStart = DateTime.UtcNow,
                // MEJORA #28: Usar UtcNow consistentemente
                HourOfDay = DateTime.UtcNow.Hour,
                SearchesBeforeBlock = 0,
                AverageSearchRate = 0,
                WasBlocked = false,
                TimeoutsCount = 0
            };
            sessionSearchCount = 0;
            sessionStartTime = DateTime.UtcNow;
            AutoLog("📊 Nueva sesión de purga iniciada - recolectando métricas");
        }
        
        private void EndPurgeSession()
        {
            if (currentSession != null)
            {
                var elapsed = (DateTime.UtcNow - sessionStartTime).TotalMinutes;
                currentSession.AverageSearchRate = elapsed > 0 ? sessionSearchCount / elapsed : 0;
                currentSession.TimeoutsCount = consecutiveTimeouts;
                
                sessionHistory.Add(currentSession);
                if (sessionHistory.Count > 50) sessionHistory.RemoveAt(0); // Mantener últimas 50 sesiones
                
                AutoLog($"📊 Sesión de purga finalizada - {sessionSearchCount} búsquedas en {elapsed:F1} min");
                currentSession = null;
            }
        }
        
        // Sistema de checkpoint para recuperación automática
        private void SavePurgeCheckpoint()
        {
            try
            {
                var checkpoint = new
                {
                    Timestamp = DateTime.UtcNow,
                    TotalAuthors = purgeAllAuthors.Count,
                    AllAuthors = purgeAllAuthors.ToList(),
                    ProcessedAuthors = purgeProcessedAuthors.ToList(),
                    AuthorsWithFiles = purgeAuthorsWithFiles.ToList(),
                    SearchCount = purgeSearchCount
                };
                
                var json = Newtonsoft.Json.JsonConvert.SerializeObject(checkpoint, Newtonsoft.Json.Formatting.Indented);
                System.IO.File.WriteAllText(purgeCheckpointFile, json);
                purgeCheckpointLastSave = DateTime.UtcNow;
                
                CriticalLog($"💾 Checkpoint guardado: {purgeProcessedAuthors.Count}/{purgeAllAuthors.Count} autores procesados");
            }
            catch (Exception ex)
            {
                CriticalLog($"⚠️ Error guardando checkpoint: {ex.Message}");
            }
        }
        
        private bool LoadPurgeCheckpoint()
        {
            try
            {
                if (!System.IO.File.Exists(purgeCheckpointFile))
                    return false;
                
                var json = System.IO.File.ReadAllText(purgeCheckpointFile);
                var checkpoint = Newtonsoft.Json.JsonConvert.DeserializeAnonymousType(json, new
                {
                    Timestamp = DateTime.MinValue,
                    TotalAuthors = 0,
                    AllAuthors = new List<string>(),
                    ProcessedAuthors = new List<string>(),
                    AuthorsWithFiles = new List<string>(),
                    SearchCount = 0
                });
                
                // Solo cargar si el checkpoint es reciente (menos de 24 horas)
                if ((DateTime.UtcNow - checkpoint.Timestamp).TotalHours > 24)
                {
                    CriticalLog("⚠️ Checkpoint antiguo (>24h), ignorando");
                    System.IO.File.Delete(purgeCheckpointFile);
                    return false;
                }
                
                purgeProcessedAuthors = new HashSet<string>(checkpoint.ProcessedAuthors, StringComparer.OrdinalIgnoreCase);
                purgeAuthorsWithFiles = new HashSet<string>(checkpoint.AuthorsWithFiles);
                purgeSearchCount = checkpoint.SearchCount;
                
                // CRÍTICO: Restaurar la lista completa de autores de la purga original
                if (checkpoint.AllAuthors != null && checkpoint.AllAuthors.Count > 0)
                {
                    purgeAllAuthors = checkpoint.AllAuthors;
                    AutoLog($"");
                    AutoLog($"📂 CHECKPOINT ENCONTRADO");
                    AutoLog($"   ✅ Recuperando progreso anterior...");
                    AutoLog($"   📊 Lista completa restaurada: {purgeAllAuthors.Count} autores");
                    AutoLog($"   📊 Autores ya procesados: {purgeProcessedAuthors.Count}/{checkpoint.TotalAuthors}");
                    AutoLog($"   📊 Autores con archivos: {purgeAuthorsWithFiles.Count}");
                    AutoLog($"   ⏱️ Checkpoint guardado: {(DateTime.UtcNow - checkpoint.Timestamp).TotalMinutes:F0} minutos atrás");
                    AutoLog($"   💡 Continuando desde donde se quedó...");
                    AutoLog($"");
                    
                    CriticalLog($"✅ Checkpoint cargado: {purgeProcessedAuthors.Count} autores ya procesados");
                    return true;
                }
                else
                {
                    CriticalLog("⚠️ Checkpoint sin lista de autores, ignorando");
                    return false;
                }
            }
            catch (Exception ex)
            {
                CriticalLog($"⚠️ Error cargando checkpoint: {ex.Message}");
                return false;
            }
        }
        
        private void DeletePurgeCheckpoint()
        {
            try
            {
                if (System.IO.File.Exists(purgeCheckpointFile))
                {
                    System.IO.File.Delete(purgeCheckpointFile);
                    CriticalLog("🗑️ Checkpoint eliminado (purga completada)");
                }
            }
            catch (Exception ex)
            {
                CriticalLog($"⚠️ Error eliminando checkpoint: {ex.Message}");
            }
        }
        
        // OPTIMIZACIÓN: Rate limiting global para paralelización
        private async Task<bool> WaitForRateLimit(CancellationToken ct)
        {
            while (true)
            {
                double waitSeconds = 0;
                int currentCount = 0;
                var now = DateTime.UtcNow;

                // Limpiar y verificar dentro del lock
                lock (globalSearchTimes)
                {
                    while (globalSearchTimes.Count > 0 &&
                           (now - globalSearchTimes.Peek()).TotalSeconds >= 60)
                    {
                        globalSearchTimes.Dequeue();
                    }

                    if (globalSearchTimes.Count < MAX_SEARCHES_PER_MINUTE)
                    {
                        globalSearchTimes.Enqueue(now);
                        // MEJORA #1: Notificar actividad al health check
                        healthCheckService?.NotifyActivity();
                        return true;
                    }

                    var oldestSearch = globalSearchTimes.Peek();
                    waitSeconds = Math.Max(0, 60 - (now - oldestSearch).TotalSeconds + 1);
                    currentCount = globalSearchTimes.Count;
                }

                if (waitSeconds > 0)
                {
                    CriticalLog($"⏸️ Rate limit global alcanzado ({currentCount}/{MAX_SEARCHES_PER_MINUTE}): esperando {waitSeconds:F0}s");
                    await Task.Delay(TimeSpan.FromSeconds(waitSeconds), ct);
                }
                else
                {
                    await Task.Yield();
                }
            }
        }
        
        // OPTIMIZACIÓN: Calcular paralelismo óptimo según salud de conexión
        private int GetOptimalParallelism()
        {
            // Conexión excelente (health > 80, latency < 100ms) → 5 paralelos
            if (connectionHealthScore > 80 && averageLatency < 100 && averageLatency > 0)
            {
                return 5;
            }
            
            // Conexión buena (health > 60, latency < 200ms) → 3 paralelos
            if (connectionHealthScore > 60 && averageLatency < 200)
            {
                return 3;
            }
            
            // Conexión regular (health > 40) → 2 paralelos
            if (connectionHealthScore > 40)
            {
                return 2;
            }
            
            // Conexión mala → 1 paralelo (secuencial)
            return 1;
        }
        
        // OPTIMIZACIÓN: Circuit breaker para protección anti-ban
        private async Task<bool> CheckCircuitBreaker(CancellationToken ct)
        {
            // Si el circuit breaker está abierto, esperar
            if (DateTime.UtcNow < circuitBreakerUntil)
            {
                var remaining = (circuitBreakerUntil - DateTime.UtcNow).TotalMinutes;
                CriticalLog($"🛑 Circuit breaker activo: {remaining:F1} min restantes");
                await Task.Delay(TimeSpan.FromMinutes(1), ct);
                return false;
            }
            
            return true;
        }
        
        private void RecordSearchSuccess()
        {
            consecutiveSearchErrors = 0; // Reset en éxito
        }
        
        private void RecordSearchError()
        {
            consecutiveSearchErrors++;
            
            // Si hay 5 errores consecutivos, abrir circuit breaker por 5 minutos
            if (consecutiveSearchErrors >= 5)
            {
                circuitBreakerUntil = DateTime.UtcNow.AddMinutes(5);
                AutoLog($"🛑 CIRCUIT BREAKER ABIERTO: {consecutiveSearchErrors} errores consecutivos");
                AutoLog($"   ⏸️ Pausando búsquedas por 5 minutos para proteger la conexión");
                
                // Reducir paralelismo a 1 (modo seguro)
                purgeParallelism = 1;
                CriticalLog($"🔧 Paralelismo reducido a 1 (modo recuperación)");
            }
        }
        
        // OPTIMIZACIÓN: Delays adaptativos según salud de conexión
        private TimeSpan CalculateAdaptiveDelay()
        {
            // Conexión excelente (health > 80, latency < 100ms) → 2-4s
            if (connectionHealthScore > 80 && averageLatency < 100 && averageLatency > 0)
            {
                return TimeSpan.FromSeconds(2 + Random.Shared.Next(0, 2));
            }
            
            // Conexión buena (health > 60, latency < 200ms) → 5-8s
            if (connectionHealthScore > 60 && averageLatency < 200)
            {
                return TimeSpan.FromSeconds(5 + Random.Shared.Next(0, 3));
            }
            
            // Conexión regular (health > 40) → 10-15s
            if (connectionHealthScore > 40)
            {
                return TimeSpan.FromSeconds(10 + Random.Shared.Next(0, 5));
            }
            
            // Conexión mala → 15-20s (conservador)
            return TimeSpan.FromSeconds(15 + Random.Shared.Next(0, 5));
        }
        
        // OPTIMIZACIÓN: Procesar un solo autor (método auxiliar para paralelización)
        private async Task ProcessSingleAuthorForPurge(string author, CancellationToken ct)
        {
            try
            {
                // PROTECCIÓN 1: Rate limiting global
                await WaitForRateLimit(ct);
                
                // PROTECCIÓN 2: Delay adaptativo según salud
                var delay = CalculateAdaptiveDelay();
                CriticalLog($"   ⏱️ Delay adaptativo: {delay.TotalSeconds:F1}s (Health: {connectionHealthScore:F0})");
                await Task.Delay(delay, ct);
                
                // PROTECCIÓN 3: Verificar salud antes de buscar
                if (connectionHealthScore < 30)
                {
                    AutoLog($"⏸️ Salud muy baja ({connectionHealthScore:F0}), saltando búsqueda de {author}");
                    return;
                }
                
                // Verificar conexión
                if (client == null || 
                    !client.State.HasFlag(SoulseekClientStates.Connected) || 
                    !client.State.HasFlag(SoulseekClientStates.LoggedIn))
                {
                    var state = client?.State.ToString() ?? "null";
                    CriticalLog($"   ❌ Cliente no disponible! Estado: {state}");
                    autoPurgePausedByDisconnection = true;
                    return;
                }
                
                CriticalLog($"   🔍 Buscando: {author}");
                UpdateAuthorStatus(author, "🔍 Buscando...");
                
                // Realizar búsqueda
                var results = await client.SearchAsync(
                    SearchQuery.FromText(author),
                    options: new Soulseek.SearchOptions(
                        searchTimeout: 8000,
                        maximumPeerQueueLength: 15000,
                        filterResponses: true,
                        responseLimit: 1,
                        minimumResponseFileCount: 1,
                        minimumPeerUploadSpeed: 0),
                    cancellationToken: ct);
                
                // Registrar éxito
                RecordSearchSuccess();
                
                // Registrar búsqueda exitosa en métricas
                sessionMetrics?.RecordSearchCompleted(0, true);
                
                // Incrementar contadores
                Interlocked.Increment(ref purgeSearchCount);
                Interlocked.Increment(ref sessionSearchCount);
                
                // Procesar respuestas
                var responses = results.Responses;
                int validFilesCount = 0;
                bool hasValid = false;
                
                if (responses != null)
                {
                    foreach (var response in responses)
                    {
                        if (response.Files == null) continue;
                        foreach (var f in response.Files)
                        {
                            if (!IsDocumentFile(f.Filename)) continue;
                            bool isSpanish = IsSpanishText(f.Filename);
                            if (chkAutoSpanishDocuments?.Checked == true && !isSpanish) continue;
                            if (autoMinSearchSizeKB > 0 && f.Size < (long)autoMinSearchSizeKB * 1024L) continue;
                            
                            validFilesCount++;
                            hasValid = true;
                        }
                    }
                }
                
                // Actualizar estado del autor
                if (hasValid)
                {
                    lock (purgeAuthorsWithFiles)
                    {
                        purgeAuthorsWithFiles.Add(author);
                    }
                    
                    // Registrar autor procesado en métricas
                    sessionMetrics?.RecordAuthorProcessed(validFilesCount > 0);
                    
                    UpdateAuthorData(author, validFilesCount, $"✅ {validFilesCount} archivos", UIColors.AuthorSuccess);
                    CriticalLog($"   ✅ {author}: {validFilesCount} archivos válidos");
                }
                else
                {
                    // Eliminar autor sin archivos
                    SafeInvoke(() =>
                    {
                        try
                        {
                            var authorData = allAuthorsData.FirstOrDefault(a => a.Name.Equals(author, StringComparison.OrdinalIgnoreCase));
                            if (authorData != null)
                            {
                                allAuthorsData.Remove(authorData);
                                filteredAuthorsData = new List<AuthorData>(allAuthorsData);
                            }
                        }
                        catch { }
                    });
                    UpdateAuthorData(author, 0, "❌ Sin archivos", UIColors.AuthorError);
                    CriticalLog($"   ❌ {author}: Sin archivos válidos - ELIMINADO");
                }
                
                // Marcar como procesado
                lock (purgeProcessedAuthors)
                {
                    purgeProcessedAuthors.Add(author);
                }
                
                // MEJORA #7: Actualizar progreso con ETA
                purgeProgressTracker?.RecordProgress();
                UpdatePurgeProgressUI();
                
                // Guardar checkpoint periódicamente
                if ((DateTime.UtcNow - purgeCheckpointLastSave).TotalSeconds >= CHECKPOINT_SAVE_INTERVAL_SECONDS)
                {
                    SavePurgeCheckpoint();
                }
            }
            catch (OperationCanceledException)
            {
                CriticalLog($"   ⏹️ {author}: Búsqueda cancelada");
                UpdateAuthorStatus(author, "⏹️ Cancelado");
            }
            catch (TimeoutException)
            {
                RecordSearchError();
                sessionMetrics?.RecordSearchCompleted(0, false);
                CriticalLog($"   ⏱️ {author}: Timeout");
                UpdateAuthorStatus(author, "⏱️ Timeout");
            }
            catch (Exception ex)
            {
                RecordSearchError();
                sessionMetrics?.RecordSearchCompleted(0, false);
                CriticalLog($"   ❌ {author}: Error - {ex.Message}");
                UpdateAuthorStatus(author, $"❌ Error");
                
                // PROTECCIÓN: Detectar desconexión durante búsqueda
                if (client == null || 
                    !client.State.HasFlag(SoulseekClientStates.Connected) || 
                    !client.State.HasFlag(SoulseekClientStates.LoggedIn))
                {
                    CriticalLog($"   🔌 Desconexión detectada durante búsqueda, pausando purga");
                    autoPurgePausedByDisconnection = true;
                }
            }
        }
        
        private void RecordBlockEvent()
        {
            if (currentSession != null)
            {
                currentSession.WasBlocked = true;
                currentSession.SearchesBeforeBlock = sessionSearchCount;
                var elapsed = (DateTime.UtcNow - sessionStartTime).TotalMinutes;
                currentSession.AverageSearchRate = elapsed > 0 ? sessionSearchCount / elapsed : 0;
                currentSession.TimeoutsCount = consecutiveTimeouts;
                
                sessionHistory.Add(currentSession);
                if (sessionHistory.Count > 50) sessionHistory.RemoveAt(0); // Mantener últimas 50 sesiones
                
                AutoLog($"📊 Bloqueo registrado: {sessionSearchCount} búsquedas en {elapsed:F1} min ({currentSession.AverageSearchRate:F1} búsq/min)");
                
                // Ajustar parámetros basado en historial
                AdjustPurgeParametersFromHistory();
            }
        }
        
        private void AdjustPurgeParametersFromHistory()
        {
            if (sessionHistory.Count < 3) return;
            
            var blockedSessions = sessionHistory.Where(s => s.WasBlocked).ToList();
            if (blockedSessions.Count == 0) return;
            
            // Calcular promedio de búsquedas antes de bloqueo
            var avgSearchesBeforeBlock = blockedSessions.Average(s => s.SearchesBeforeBlock);
            var avgRate = blockedSessions.Average(s => s.AverageSearchRate);
            
            // Ajustar purgeMaxPerMinute para estar 20% por debajo del promedio que causa bloqueos
            if (avgRate > 0)
            {
                int suggestedMax = (int)Math.Floor(avgRate * 0.8);
                if (suggestedMax < purgeMaxPerMinute && suggestedMax >= 10)
                {
                    AutoLog($"🤖 APRENDIZAJE: Reduciendo búsquedas/min de {purgeMaxPerMinute} a {suggestedMax} (basado en {blockedSessions.Count} bloqueos)");
                    purgeMaxPerMinute = suggestedMax;
                }
            }
            
            // Verificar si cierta hora del día tiene más bloqueos
            var blocksByHour = blockedSessions.GroupBy(s => s.HourOfDay)
                                              .OrderByDescending(g => g.Count())
                                              .FirstOrDefault();
            if (blocksByHour != null && blocksByHour.Count() >= 2)
            {
                AutoLog($"⚠️ PATRÓN DETECTADO: Hora {blocksByHour.Key}:00 tiene más bloqueos ({blocksByHour.Count()})");
            }
        }

        private CancellationTokenSource appCts;
        private Task connectionMonitorTask;
        private bool useExponentialBackoff = false;
        private int exponentialBaseSecondsConnect = 1;
        private int exponentialBaseSecondsReconnect = 1;
        private int exponentialCapSeconds = 600;

        private bool IsClientConnected()
        {
            return client != null && (client.State.HasFlag(SoulseekClientStates.Connected) || client.State.HasFlag(SoulseekClientStates.LoggedIn));
        }

        private async Task<bool> HandleDisconnectAsync(string reason)
        {
            try
            {
                if (IsClientConnected()) return true;
                if (client != null)
                {
                    try { client.Dispose(); } catch { }
                    client = null;
                }
                if (autoReconnect)
                {
                    await CheckAndReconnect();
                    return IsClientConnected();
                }
                return false;
            }
            catch (Exception ex)
            {
                Log($"Error en HandleDisconnectAsync: {ex.Message}");
                return false;
            }
        }

        private async Task<T> ExecuteWithReconnect<T>(Func<Task<T>> operation, string reason)
        {
            try
            {
                return await operation();
            }
            catch (Exception ex)
            {
                LogEx(LogLevel.WARN, LogCategory.CONEXION, $"Error en operación '{reason}': {ex.Message}");
                LogEx(LogLevel.INFO, LogCategory.CONEXION, $"Intentando reconectar para reintentar operación...");
                
                var reconnected = await HandleDisconnectAsync(reason);
                
                if (!reconnected)
                {
                    LogEx(LogLevel.ERROR, LogCategory.CONEXION, $"No se pudo reconectar para '{reason}'");
                    throw;
                }
                
                LogEx(LogLevel.SUCCESS, LogCategory.CONEXION, $"🔁 [REINTENTANDO] Operación '{reason}' tras reconexión exitosa");
                return await operation();
            }
        }
        
        // ===== RECONEXIÓN AUTOMÁTICA =====
        
        private int reconnectAttempts = 0;
        private DateTime lastReconnectAttempt = DateTime.MinValue;
        private bool isReconnecting = false;
        private bool isConnecting = false;
        private bool isReconnectCoolingDown = false;
        private DateTime lastDisconnectWarning = DateTime.MinValue;
        private const int DISCONNECT_WARNING_THROTTLE_SECONDS = 5;
        private DateTime lastReconnectWarningLog = DateTime.MinValue;
        private DateTime lastCooldownLog = DateTime.MinValue;
        private DateTime lastReconnectSkipLog = DateTime.MinValue;
        private DateTime lastCooldownStateChange = DateTime.MinValue;
        private bool autoTuningPausedByConnectionIssue = false;
        private readonly TimeSpan reconnectWarningThrottle = TimeSpan.FromSeconds(60);
        private readonly TimeSpan cooldownLogThrottle = TimeSpan.FromSeconds(60);
        private readonly TimeSpan reconnectSkipThrottle = TimeSpan.FromSeconds(60);
        
        // OPTIMIZACIÓN: Cache de validaciones de autores (reduce requests al servidor)
        private Dictionary<string, (bool hasFiles, DateTime validatedAt)> _validationCache = 
            new Dictionary<string, (bool hasFiles, DateTime validatedAt)>();
        
        private async Task PauseConnectionMonitorsAsync(TimeSpan duration)
        {
            if (duration <= TimeSpan.Zero)
                return;

            bool pausedAutoTuning = false;
            try
            {
                reconnectCheckTimer?.Stop();
                healthCheckTimer?.Change(Timeout.InfiniteTimeSpan, Timeout.InfiniteTimeSpan);
                qualityTimer?.Stop();

                if (useAutoTuning && autoTuner != null && !autoTuningPausedByConnectionIssue)
                {
                    try
                    {
                        EnsureAutoTuningState(true);
                        autoTuningPausedByConnectionIssue = true;
                        pausedAutoTuning = true;
                        Log("⏸️ Auto-Tuning pausado durante cooldown de conexión");
                    }
                    catch (Exception tunerEx)
                    {
                        Log($"⚠️ Error pausando Auto-Tuning: {tunerEx.Message}");
                    }
                }
            }
            catch (Exception timerEx)
            {
                Log($"⚠️ Error deteniendo timers de monitor: {timerEx.Message}");
            }

            try
            {
                await DelayWithCancellation(duration, appCts?.Token ?? CancellationToken.None);
            }
            catch (OperationCanceledException)
            {
                // ignorar cancelaciones
            }
            finally
            {
                try
                {
                    reconnectCheckTimer?.Start();
                    qualityTimer?.Start();
                    healthCheckTimer?.Change(TimeSpan.FromMinutes(HEALTH_CHECK_INTERVAL_MINUTES),
                        TimeSpan.FromMinutes(HEALTH_CHECK_INTERVAL_MINUTES));

                    if (useAutoTuning && autoTuner != null && (autoTuningPausedByConnectionIssue || pausedAutoTuning))
                    {
                        try
                        {
                            EnsureAutoTuningState(false);
                            autoTuningPausedByConnectionIssue = false;
                        }
                        catch (Exception tunerEx)
                        {
                            Log($"⚠️ Error reanudando Auto-Tuning: {tunerEx.Message}");
                        }
                    }

                    Log("▶️ Timers de monitor reanudados tras cooldown");
                }
                catch (Exception timerEx)
                {
                    Log($"⚠️ Error reanudando timers de monitor: {timerEx.Message}");
                }
            }
        }

        private async Task CheckAndReconnect()
        {
            Log("[DEBUG] CheckAndReconnect() llamado");
            
            // MIGRACIÓN: Forzar Soulseek siempre habilitado (triple verificación)
            if (_networkConfig != null)
            {
                _networkConfig.SoulseekEnabled = true;
                _networkConfig.PreferredNetwork = "Soulseek";
            }
            
            // Protección contra reconexiones simultáneas
            bool shouldReconnect = false;
            lock (this)
            {
                Log($"[DEBUG] En lock: autoReconnect={autoReconnect}, isReconnecting={isReconnecting}, isConnecting={isConnecting}, cooldown={isReconnectCoolingDown}");
                if (!autoReconnect || isReconnecting || isConnecting || isReconnectCoolingDown)
                {
                    if (DateTime.UtcNow - lastReconnectWarningLog >= reconnectWarningThrottle)
                    {
                        Log($"⚠️ Reconexión ignorada - autoReconnect={autoReconnect}, isReconnecting={isReconnecting}, isConnecting={isConnecting}, cooldown={isReconnectCoolingDown}");
                        lastReconnectWarningLog = DateTime.UtcNow;
                    }
                    return;
                }
                
                // Respetar ventana de cooldown global
                if (DateTime.UtcNow < nextAllowedReconnect)
                {
                    var waitRemaining = nextAllowedReconnect - DateTime.UtcNow;
                    if (DateTime.UtcNow - lastCooldownLog >= cooldownLogThrottle)
                    {
                        Log($"⏸️ Cooldown activo ({waitRemaining.TotalSeconds:F0}s restantes), ignorando reconexión anticipada");
                        lastCooldownLog = DateTime.UtcNow;
                    }
                    isReconnectCoolingDown = true;
                    lastCooldownStateChange = DateTime.UtcNow;
                    ScheduleReconnectRetry(waitRemaining);
                    return;
                }

                isReconnecting = true;
                shouldReconnect = true;
                Log("[DEBUG] isReconnecting establecido a true");
            }
            
            if (!shouldReconnect)
                return;
            
            try
            {
                // 1. Verificar Circuit Breaker
                if (connectionCircuitBreaker != null && !connectionCircuitBreaker.AllowRequest())
                {
                    var timeUntilRetry = connectionCircuitBreaker.GetTimeUntilRetry();
                    Log($"⛔ Circuit Breaker ABIERTO - Esperando {timeUntilRetry.TotalSeconds:F0}s antes de reintentar");
                    Log($"   {connectionCircuitBreaker.GetStatusInfo()}");
                    lock (this)
                    {
                        isReconnecting = false;
                        isReconnectCoolingDown = true;
                        lastCooldownStateChange = DateTime.UtcNow;
                    }
                    ScheduleReconnectRetry(timeUntilRetry);
                    return;
                }
                
                // 2. Verificar límite de intentos
                if (reconnectAttempts >= MAX_RECONNECT_ATTEMPTS)
                {
                    Log($" Máximo de intentos alcanzado ({MAX_RECONNECT_ATTEMPTS}), deshabilitando auto-reconexión");
                    autoReconnect = false;
                    
                    SafeBeginInvoke(() => 
                    {
                        lblStatus.Text = "Reconexión deshabilitada (máximo intentos)";
                        lblStatus.ForeColor = Color.Red;
                    });
                    lock (this) { isReconnecting = false; }
                    return;
                }
                
                // 3. Verificar si el cliente está desconectado o en estado inválido
                bool needsReconnect = false;
                string reason = "";
                
                if (client == null)
                {
                    needsReconnect = true;
                    reason = "Cliente nulo";
                }
                else if (client.State == SoulseekClientStates.Disconnected)
                {
                    needsReconnect = true;
                    reason = "Desconectado";
                }
                else if (!client.State.HasFlag(SoulseekClientStates.Connected) && 
                         !client.State.HasFlag(SoulseekClientStates.LoggedIn))
                {
                    needsReconnect = true;
                    reason = $"Estado inválido: {client.State}";
                }
                
                if (!needsReconnect)
                {
                    // Verificar pool de conexiones
                    if (clientPool != null)
                    {
                        int disconnected = 0;
                        foreach (var poolClient in clientPool)
                        {
                            if (poolClient?.State == SoulseekClientStates.Disconnected)
                                disconnected++;
                        }
                        
                        if (disconnected > 0)
                        {
                            AutoLog($"⚠️ {disconnected}/{clientPool.Count} clientes del pool desconectados");
                            CleanupDisconnectedPoolClients();
                        }
                    }
                    
                    // Resetear contador y backoff si está conectado
                    reconnectAttempts = 0;
                    if (reconnectBackoff != null)
                        reconnectBackoff.Reset();
                    if (connectionCircuitBreaker != null)
                        connectionCircuitBreaker.Reset();
                    lock (this) { isReconnecting = false; }
                    return;
                }
                
                // Evitar reintentos muy seguidos mediante ventana límite
                var now = DateTime.UtcNow;
                if (now < nextAllowedReconnect)
                {
                    var wait = nextAllowedReconnect - now;
                    Log($"⏳ Reconexión aplazada {wait.TotalSeconds:F0}s - respetando ventana de backoff");
                    lock (this)
                    {
                        isReconnecting = false;
                        isReconnectCoolingDown = true;
                        lastCooldownStateChange = DateTime.UtcNow;
                    }
                    ScheduleReconnectRetry(wait);
                    return;
                }
                
                lastReconnectAttempt = DateTime.Now;
                reconnectAttempts++;
                Log($"🔄 Intento de reconexión #{reconnectAttempts}/{MAX_RECONNECT_ATTEMPTS} - Razón: {reason}");
                
                // Usar Exponential Backoff con jitter
                TimeSpan backoffDelay;
                if (reconnectBackoff != null)
                {
                    backoffDelay = reconnectBackoff.GetNextDelay(BackoffScenario.NetworkError);
                    Log($"⏱️ Backoff exponencial: {backoffDelay.TotalSeconds:F1}s (con jitter)");
                }
                else
                {
                    // Fallback al método antiguo
                    int delaySeconds = GetBackoffDelaySeconds(reconnectAttempts, true);
                    backoffDelay = TimeSpan.FromSeconds(delaySeconds);
                }
                
                // Respetar cooldown por posible ban (solo después del 2do intento)
                double recommendedCooldown = 0;
                if (reconnectAttempts > 2)
                {
                    recommendedCooldown = GetRecommendedCooldownSeconds();
                    if (recommendedCooldown > 0)
                    {
                        var recDelay = TimeSpan.FromSeconds(recommendedCooldown);
                        if (recDelay > backoffDelay)
                        {
                            backoffDelay = recDelay;
                            Log($"⚠️ Usando cooldown recomendado: {backoffDelay.TotalSeconds:F0}s (posible ban detectado)");
                        }
                    }
                }
                
                Log($"⚠️ Conexión perdida ({reason}). Reintentando en {backoffDelay.TotalSeconds:F1}s...");
                
                SafeBeginInvoke(() => 
                {
                    var recText = recommendedCooldown > 0 ? $" (recomendado: {Math.Ceiling(recommendedCooldown)}s)" : string.Empty;
                    lblStatus.Text = $"Reconectando (intento {reconnectAttempts}) en {backoffDelay.TotalSeconds:F0}s{recText}...";
                    lblStatus.ForeColor = Color.Orange;
                });
                
                if (lastFailureTime == DateTime.MinValue) lastFailureTime = DateTime.UtcNow;
                nextAllowedReconnect = DateTime.UtcNow + backoffDelay;
                lock (this) { isReconnectCoolingDown = true; }
                await DelayWithCancellation(backoffDelay, appCts?.Token ?? CancellationToken.None);
                lock (this) { isReconnectCoolingDown = false; }
                
                // Limpiar cliente anterior
                if (client != null)
                {
                    try { client.Dispose(); } catch { }
                    client = null;
                }
                
                // Limpiar pool
                if (clientPool != null)
                {
                    foreach (var poolClient in clientPool)
                    {
                        try { poolClient?.Dispose(); } catch { }
                    }
                    clientPool.Clear();
                    currentClientIndex = 0;
                }
                
                // Intentar reconexión (puede lanzar excepción si falla)
                try
                {
                    // Solo reconectar a Soulseek si está habilitado
                    if (_networkConfig?.SoulseekEnabled == true)
                    {
                        await ConnectToSoulseek();
                    }
                    else
                    {
                        Log("[DEBUG] Soulseek deshabilitado - omitiendo reconexión");
                        return; // No hay nada que reconectar
                    }
                    
                    // Verificar que realmente se conectó
                    if (client != null && (client.State.HasFlag(SoulseekClientStates.Connected) || client.State.HasFlag(SoulseekClientStates.LoggedIn)))
                    {
                        SafeBeginInvoke(() => 
                        {
                            btnConnect.Text = "Desconectar";
                            btnConnect.Enabled = true;
                            btnSearch.Enabled = true;
                            lblStatus.Text = "Reconectado";
                            lblStatus.ForeColor = Color.FromArgb(0, 200, 0);
                        });
                        
                        // MEJORA: Notificar reconexión exitosa
                        try { notificationService?.NotifyReconnected(); } catch { }
                        
                        LogEx(LogLevel.SUCCESS, LogCategory.CONEXION, $"═══════════════════════════════════════════════════");
                        LogEx(LogLevel.SUCCESS, LogCategory.CONEXION, $"✅ RECONEXIÓN EXITOSA (intento #{reconnectAttempts})");
                        LogEx(LogLevel.SUCCESS, LogCategory.CONEXION, $"═══════════════════════════════════════════════════");
                        
                        // Registrar éxito en Circuit Breaker y Health Monitor
                        if (connectionCircuitBreaker != null)
                        {
                            connectionCircuitBreaker.RecordSuccess();
                            Log($"✅ Circuit Breaker: {connectionCircuitBreaker.GetStatusInfo()}");
                        }
                        
                        if (healthMonitor != null)
                        {
                            healthMonitor.RecordSuccess(TimeSpan.FromSeconds(1)); // Latencia estimada
                            Log($"✅ Health Monitor: {healthMonitor.GetStatusSummary()}");
                        }
                        
                        if (reconnectBackoff != null)
                        {
                            reconnectBackoff.Reset();
                        }
                        
                        reconnectAttempts = 0; // Reset en éxito
                        
                        // REANUDAR PROCESOS PAUSADOS POR DESCONEXIÓN
                        if (autoSearchPausedByDisconnection || autoPurgePausedByDisconnection || downloadsPausedByDisconnection)
                        {
                            LogEx(LogLevel.INFO, LogCategory.CONEXION, "Esperando 5 segundos antes de reanudar procesos...");
                            _ = Task.Run(async () =>
                            {
                                await Task.Delay(5000);
                                
                                // Verificar que sigue conectado
                                if (client != null && (client.State.HasFlag(SoulseekClientStates.Connected) || client.State.HasFlag(SoulseekClientStates.LoggedIn)))
                                {
                                    LogEx(LogLevel.SUCCESS, LogCategory.SISTEMA, "═══════════════════════════════════════════════════");
                                    LogEx(LogLevel.SUCCESS, LogCategory.SISTEMA, "▶️  REANUDANDO PROCESOS TRAS RECONEXIÓN EXITOSA");
                                    LogEx(LogLevel.SUCCESS, LogCategory.SISTEMA, "═══════════════════════════════════════════════════");
                                    
                                    int tasksResumed = 0;
                                    
                                    // 1. Reanudar búsquedas automáticas
                                    if (autoSearchPausedByDisconnection)
                                    {
                                        autoSearchPausedByDisconnection = false;
                                        tasksResumed++;
                                        LogEx(LogLevel.SUCCESS, LogCategory.BUSQUEDA, "▶️  [REANUDADA] Búsqueda automática");
                                    }
                                    
                                    // 2. Reanudar purga automática
                                    if (autoPurgePausedByDisconnection)
                                    {
                                        // Verificar si hay pausa extendida por uso excesivo
                                        if (autoPurgePausedByExcessiveUse)
                                        {
                                            var timeSincePause = DateTime.UtcNow.Subtract(excessiveUsePauseTime).TotalMinutes;
                                            if (timeSincePause >= 15)
                                            {
                                                autoPurgePausedByDisconnection = false;
                                                autoPurgePausedByExcessiveUse = false;
                                                tasksResumed++;
                                                LogEx(LogLevel.SUCCESS, LogCategory.PURGA, "▶️  [REANUDADA] Purga automática (pausa extendida finalizada)");
                                            }
                                            else
                                            {
                                                LogEx(LogLevel.WARN, LogCategory.PURGA, $"⏸️  [PAUSADA] Purga sigue pausada por uso excesivo ({15 - timeSincePause:F0} min restantes)");
                                            }
                                        }
                                        else
                                        {
                                            autoPurgePausedByDisconnection = false;
                                            tasksResumed++;
                                            LogEx(LogLevel.SUCCESS, LogCategory.PURGA, "▶️  [REANUDADA] Purga automática");
                                            if (autoPurgeNeedsRestart && !autoPurgeRunning)
                                            {
                                                autoPurgeNeedsRestart = false;
                                                LogEx(LogLevel.INFO, LogCategory.PURGA, "🔁 [REINICIANDO] Purga automática desde el principio...");
                                                // MEJORA #26: Eliminar Task.Run redundante
                                                _ = PurgeAuthorsWithoutResults();
                                            }
                                        }
                                    }
                                    
                                    // 3. Reanudar descargas
                                    if (downloadsPausedByDisconnection)
                                    {
                                        downloadsPausedByDisconnection = false;
                                        tasksResumed++;
                                        
                                        // MEJORA FASE 1.3: ReadLock para Count
                                        int pendingDownloads = ReadLocked(downloadQueueLock, () =>
                                            downloadQueue.Count(t => 
                                                t.Status == DownloadStatus.Queued || 
                                                t.Status == DownloadStatus.Downloading ||
                                                t.Status == DownloadStatus.Paused));
                                        
                                        LogEx(LogLevel.SUCCESS, LogCategory.DESCARGA, $"▶️  [REANUDADAS] Descargas ({pendingDownloads} pendientes en cola)");
                                    }
                                    
                                    LogEx(LogLevel.SUCCESS, LogCategory.SISTEMA, $"═══════════════════════════════════════════════════");
                                    LogEx(LogLevel.SUCCESS, LogCategory.SISTEMA, $"✅ Total de procesos reanudados: {tasksResumed}");
                                    LogEx(LogLevel.SUCCESS, LogCategory.SISTEMA, "═══════════════════════════════════════════════════");
                                }
                                else
                                {
                                    LogEx(LogLevel.ERROR, LogCategory.CONEXION, "No se reanudaron procesos: conexión perdida nuevamente");
                                }
                            });
                        }
                    }
                    else
                    {
                        throw new Exception("Conexión no establecida después de ConnectToSoulseek");
                    }
                }
                catch (Exception connEx)
                {
                    Log($"❌ ConnectToSoulseek falló: {connEx.Message}");
                    // Lanzar para que los catch externos manejen el reintento
                    throw;
                }
            }
            catch (TimeoutException)
            {
                Log($"⏱️ Timeout en reconexión (intento {reconnectAttempts})");
                
                // Registrar fallo en Circuit Breaker y Health Monitor
                if (connectionCircuitBreaker != null)
                    connectionCircuitBreaker.RecordFailure();
                
                if (healthMonitor != null)
                    healthMonitor.RecordTimeout();
                
                // Reintentar automáticamente
                if (autoReconnect)
                {
                    Log($"🔄 Reintentando automáticamente...");
                    ScheduleReconnectRetry(TimeSpan.FromSeconds(5));
                }
            }
            catch (System.Net.Sockets.SocketException ex)
            {
                Log($"🌐 Error de red en reconexión: {ex.Message} (intento {reconnectAttempts})");
                
                // Registrar fallo en Circuit Breaker y Health Monitor
                if (connectionCircuitBreaker != null)
                    connectionCircuitBreaker.RecordFailure();
                
                if (healthMonitor != null)
                    healthMonitor.RecordTimeout();
                
                // Reintentar automáticamente
                if (autoReconnect)
                {
                    Log($"🔄 Reintentando automáticamente...");
                    ScheduleReconnectRetry(TimeSpan.FromSeconds(5));
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error en reconexión automática: {ex.Message} (intento {reconnectAttempts})");
                Log($"   StackTrace:\n{ex}");
                
                // Registrar fallo en Circuit Breaker y Health Monitor
                if (connectionCircuitBreaker != null)
                    connectionCircuitBreaker.RecordFailure();
                
                if (healthMonitor != null)
                    healthMonitor.RecordTimeout();
                
                // Solo deshabilitar auto-reconexión si es un error de autenticación
                if (ex.Message.Contains("Invalid credentials"))
                {
                    Log("⚠️ Error de autenticación detectado. Deshabilitando auto-reconexión para evitar bloqueos.");
                    autoReconnect = false;
                    
                    // Usar backoff para auth errors
                    if (reconnectBackoff != null)
                    {
                        var authBackoff = ExponentialBackoff.ForScenario(BackoffScenario.AuthError);
                        var delay = authBackoff.GetNextDelay();
                        Log($"⏱️ Backoff para auth error: {delay.TotalSeconds:F0}s");
                    }
                    
                    SafeBeginInvoke(() => 
                    {
                        lblStatus.Text = "Error de autenticación";
                        lblStatus.ForeColor = Color.Red;
                    });
                }
                else if (autoReconnect)
                {
                    Log($"🔄 Reintentando automáticamente...");
                    ScheduleReconnectRetry(TimeSpan.FromSeconds(5));
                }
            }
            finally
            {
                lock (this)
                {
                    isReconnecting = false;
                    Log($"[CheckAndReconnect] Finally: isReconnecting establecido en false");
                }
            }
        }
        
        // ===== DIBUJO PERSONALIZADO LISTVIEW =====
        
        private void LvResults_DrawColumnHeader(object sender, DrawListViewColumnHeaderEventArgs e)
        {
            // Fondo oscuro para encabezados
            using (SolidBrush backBrush = new SolidBrush(Color.FromArgb(35, 35, 35)))
            {
                e.Graphics.FillRectangle(backBrush, e.Bounds);
            }
            
            // Borde inferior
            using (Pen borderPen = new Pen(Color.FromArgb(60, 60, 60)))
            {
                e.Graphics.DrawLine(borderPen, e.Bounds.Left, e.Bounds.Bottom - 1, e.Bounds.Right, e.Bounds.Bottom - 1);
            }
            
            // Texto del encabezado con padding
            Rectangle textBounds = new Rectangle(e.Bounds.X + 5, e.Bounds.Y, e.Bounds.Width - 5, e.Bounds.Height);
            TextRenderer.DrawText(
                e.Graphics,
                e.Header.Text,
                new Font("Segoe UI", 9, FontStyle.Bold),
                textBounds,
                Color.White,
                TextFormatFlags.Left | TextFormatFlags.VerticalCenter
            );
            
            e.DrawDefault = false;
        }
        
        private void LvResults_DrawItem(object sender, DrawListViewItemEventArgs e)
        {
            e.DrawDefault = true;
        }
        
        private void LvResults_DrawSubItem(object sender, DrawListViewSubItemEventArgs e)
        {
            // Columna 3 = Estado
            if (e.ColumnIndex == 3 && e.SubItem != null)
            {
                // Determinar color según el estado
                Color textColor = Color.White;
                Color backColor = e.Item.BackColor;
                
                string estado = e.SubItem.Text.ToLowerInvariant();
                
                if (estado.Contains("completado") || estado.Contains("✅"))
                {
                    textColor = Color.LightGreen;
                }
                else if (estado.Contains("descargando") || estado.Contains("⬇️"))
                {
                    textColor = Color.Cyan;
                }
                else if (estado.Contains("en cola") || estado.Contains("⏳"))
                {
                    textColor = Color.Yellow;
                }
                else if (estado.Contains("pausado") || estado.Contains("⏸️"))
                {
                    textColor = Color.Orange;
                }
                else if (estado.Contains("error") || estado.Contains("fallido") || estado.Contains("❌"))
                {
                    textColor = Color.Red;
                }
                else if (estado.Contains("cancelado") || estado.Contains("🚫"))
                {
                    textColor = Color.Gray;
                }
                
                // Dibujar fondo
                e.Graphics.FillRectangle(new SolidBrush(backColor), e.Bounds);
                
                // Dibujar texto con color
                TextRenderer.DrawText(e.Graphics, e.SubItem.Text, e.Item.Font, e.Bounds, textColor, 
                    TextFormatFlags.Left | TextFormatFlags.VerticalCenter);
            }
            else
            {
                e.DrawDefault = true;
            }
        }
        
        // ===== DETECCIÓN DE IDIOMA ESPAÑOL =====
        
        // Caché LRU para IsSpanishText - Optimizado con evicción automática
        // private readonly LRUCache<string, bool> spanishTextCache = new LRUCache<string, bool>(10000); // DESACTIVADO: LRUCache excluido
        private readonly Dictionary<string, bool> spanishTextCache = new Dictionary<string, bool>(10000); // Fallback a Dictionary
        private const int MAX_SPANISH_CACHE_SIZE = 10000;
        
        // OPT #3: Contador de accesos para limpieza LRU simulada
        private int spanishCacheAccessCount = 0;
        
        // ArrayPool para caracteres españoles (Optimización #18)
        private static readonly char[] spanishChars = new[] { 'ñ', 'á', 'é', 'í', 'ó', 'ú', 'ü' };
        
        private bool IsSpanishText(string text)
        {
            if (string.IsNullOrWhiteSpace(text))
                return false;
            
            // Verificar caché primero
            if (spanishTextCache.TryGetValue(text, out var cached))
            {
                spanishCacheAccessCount++;
                return cached;
            }
            
            // OPT #3: Limpieza LRU simulada (eliminar 20% más antiguo en lugar de Clear completo)
            if (spanishTextCache.Count >= MAX_SPANISH_CACHE_SIZE)
            {
                // Cada 1000 accesos, limpiar 20% para simular LRU
                if (spanishCacheAccessCount > 1000)
                {
                    var toRemove = spanishTextCache.Keys.Take(MAX_SPANISH_CACHE_SIZE / 5).ToList();
                    foreach (var key in toRemove)
                        spanishTextCache.Remove(key);
                    
                    spanishCacheAccessCount = 0;
                }
                else
                {
                    // Si no hay suficientes accesos, limpiar todo (fallback)
                    spanishTextCache.Clear();
                    spanishCacheAccessCount = 0;
                }
            }
            
            // OPT #6: Intentar usar Rust primero (10-20x más rápido)
            bool isSpanish;
            try
            {
                if (RustOptimizer.IsAvailable)
                {
                    isSpanish = RustOptimizer.IsSpanishText(text);
                    spanishTextCache[text] = isSpanish;
                    return isSpanish;
                }
            }
            catch
            {
                // Fallback a C# si Rust falla
            }
            
            // Fallback: Usar detección C# ESTRICTA - Requiere evidencia positiva de español
            var textLower = text.ToLower();
                
                // MEJORA #34: Rechazar inglés obvio usando Regex compilado (100x más rápido que cientos de Contains)
                if (textLower.StartsWith("the ") || textLower.EndsWith(" the") || 
                    RegexEnglishWords.IsMatch(textLower) || RegexEnglishSuffixes.IsMatch(textLower))
                {
                    LanguageFilterStats.Instance.RecordFiltered("inglés", "the/of/and/with/prepositions");
                    spanishTextCache[text] = false; // Usar indexer en lugar de Add
                    return false;
                }
                
                // MEJORA #34: Rechazar italiano obvio usando Regex compilado
                if (textLower.StartsWith("il ") || textLower.EndsWith(" il") || RegexItalianWords.IsMatch(textLower))
                {
                    LanguageFilterStats.Instance.RecordFiltered("italiano", "il/della/di/sono/galassia/urania");
                    spanishTextCache[text] = false;
                    return false;
                }
                
                // MEJORA #34: Rechazar francés obvio usando Regex compilado
                if (RegexFrenchContractions.IsMatch(textLower))
                {
                    LanguageFilterStats.Instance.RecordFiltered("francés", "l'/d'/c'");
                    spanishTextCache[text] = false;
                    return false;
                }
                
                // MEJORA #34: Rechazar alemán obvio usando Regex compilado
                if ((textLower.StartsWith("ge") && textLower.Length > 5) || RegexGermanWords.IsMatch(textLower))
                {
                    LanguageFilterStats.Instance.RecordFiltered("alemán", "der/die/das/und/nicht/von");
                    spanishTextCache[text] = false;
                    return false;
                }
                
                // MEJORA #34: Rechazar portugués obvio usando Regex compilado
                if (RegexPortugueseChars.IsMatch(text) || textLower.Contains(" você ") || textLower.Contains(" voce ") ||
                    textLower.Contains(" está ") || textLower.Contains(" esta ") || textLower.Contains(" são ") ||
                    textLower.Contains(" sao ") || textLower.Contains(" português ") || textLower.Contains(" portugues ") || textLower.Contains(" brasil "))
                {
                    LanguageFilterStats.Instance.RecordFiltered("portugués", "ã/õ/ç/não");
                    spanishTextCache[text] = false;
                    return false;
                }
                
                // Si tiene caracteres españoles (pero NO portugueses), aceptar
                if (text.Contains("ñ") || text.Contains("á") || text.Contains("é") || 
                    text.Contains("í") || text.Contains("ó") || text.Contains("ú"))
                {
                    spanishTextCache[text] = true;
                    return true;
                }
                
                // Buscar palabras españolas comunes (evidencia positiva)
                int spanishScore = 0;
                
                // Artículos y preposiciones españolas distintivas
                if (textLower.Contains(" del ")) spanishScore += 3;  // Muy distintivo
                if (textLower.Contains(" los ")) spanishScore += 2;
                if (textLower.Contains(" las ")) spanishScore += 2;
                if (textLower.Contains(" por ")) spanishScore += 2;
                if (textLower.Contains(" para ")) spanishScore += 3;
                if (textLower.Contains(" donde ")) spanishScore += 3;
                if (textLower.Contains(" cuando ")) spanishScore += 3;
                if (textLower.Contains(" con ")) spanishScore += 1;
                if (textLower.Contains(" sin ")) spanishScore += 2;
                if (textLower.Contains(" sobre ")) spanishScore += 2;
                if (textLower.Contains(" entre ")) spanishScore += 2;
                if (textLower.Contains(" desde ")) spanishScore += 2;
                if (textLower.Contains(" hasta ")) spanishScore += 2;
                
                // Palabras comunes en títulos de libros en español
                if (textLower.Contains(" una ")) spanishScore += 1;
                if (textLower.Contains(" uno ")) spanishScore += 1;
                if (textLower.Contains(" esta ")) spanishScore += 1;
                if (textLower.Contains(" este ")) spanishScore += 1;
                if (textLower.Contains(" ese ")) spanishScore += 1;
                if (textLower.Contains(" esa ")) spanishScore += 1;
                if (textLower.Contains(" aquel ")) spanishScore += 2;
                if (textLower.Contains(" aquella ")) spanishScore += 2;
                if (textLower.Contains(" como ")) spanishScore += 1;
                if (textLower.Contains(" porque ")) spanishScore += 2;
                if (textLower.Contains(" aunque ")) spanishScore += 2;
                if (textLower.Contains(" mientras ")) spanishScore += 2;
                if (textLower.Contains(" siempre ")) spanishScore += 2;
                if (textLower.Contains(" nunca ")) spanishScore += 2;
                if (textLower.Contains(" también ")) spanishScore += 2;
                if (textLower.Contains(" tampoco ")) spanishScore += 2;
                if (textLower.Contains(" después ")) spanishScore += 2;
                if (textLower.Contains(" antes ")) spanishScore += 2;
                if (textLower.Contains(" ahora ")) spanishScore += 2;
                if (textLower.Contains(" entonces ")) spanishScore += 2;
                if (textLower.Contains(" todo ")) spanishScore += 1;
                if (textLower.Contains(" todos ")) spanishScore += 1;
                if (textLower.Contains(" toda ")) spanishScore += 1;
                if (textLower.Contains(" todas ")) spanishScore += 1;
                if (textLower.Contains(" nada ")) spanishScore += 2;
                if (textLower.Contains(" algo ")) spanishScore += 1;
                if (textLower.Contains(" alguien ")) spanishScore += 2;
                if (textLower.Contains(" nadie ")) spanishScore += 2;
                if (textLower.Contains(" otro ")) spanishScore += 1;
                if (textLower.Contains(" otra ")) spanishScore += 1;
                if (textLower.Contains(" otros ")) spanishScore += 1;
                if (textLower.Contains(" otras ")) spanishScore += 1;
                if (textLower.Contains(" mismo ")) spanishScore += 1;
                if (textLower.Contains(" misma ")) spanishScore += 1;
                
                // Verbos españoles comunes
                if (textLower.Contains(" ser ")) spanishScore += 2;
                if (textLower.Contains(" estar ")) spanishScore += 2;
                if (textLower.Contains(" haber ")) spanishScore += 2;
                if (textLower.Contains(" hacer ")) spanishScore += 2;
                if (textLower.Contains(" tener ")) spanishScore += 2;
                
                // Términos literarios españoles (alto valor)
                if (textLower.Contains(" libro ")) spanishScore += 3;
                if (textLower.Contains(" novela ")) spanishScore += 3;
                if (textLower.Contains(" historia ")) spanishScore += 2;
                if (textLower.Contains(" cuento ")) spanishScore += 2;
                if (textLower.Contains(" saga ")) spanishScore += 2;
                if (textLower.Contains(" serie ")) spanishScore += 2;
                if (textLower.Contains(" tomo ")) spanishScore += 2;
                if (textLower.Contains(" volumen ")) spanishScore += 2;
                if (textLower.Contains(" edición ") || textLower.Contains(" edicion ")) spanishScore += 2;
                if (textLower.Contains(" español ") || textLower.Contains(" espanol ")) spanishScore += 3;
                if (textLower.Contains(" castellano ")) spanishScore += 3;
                
                // Ajustar umbral según longitud del texto (títulos cortos necesitan menos evidencia)
                // Reducido de 3 a 2 para mejorar detección de títulos españoles simples
                int requiredScore = text.Length < 20 ? 1 : 2;
                isSpanish = spanishScore >= requiredScore;
                
                if (isSpanish)
                {
                    LanguageFilterStats.Instance.RecordPassed();
                }
                
                spanishTextCache[text] = isSpanish;
                return isSpanish;
        }
        
        // OPT #4: Caché de extensiones pre-calculadas
        private static readonly HashSet<string> textExtensions = new HashSet<string>(StringComparer.OrdinalIgnoreCase) 
            { ".epub", ".txt" };
        private static readonly HashSet<string> pdfExtensions = new HashSet<string>(StringComparer.OrdinalIgnoreCase) 
            { ".pdf" };
        private static readonly HashSet<string> mobiExtensions = new HashSet<string>(StringComparer.OrdinalIgnoreCase) 
            { ".mobi", ".azw", ".azw3" };
        
        /// <summary>
        /// Descarga parcialmente un archivo (primeros KB) para verificar su idioma
        /// MEJORA #6: Tamaño de muestra dinámico según extensión
        /// MEJORA #3: Caché para evitar verificar el mismo archivo múltiples veces
        /// MEJORA #7: Integración con normalización de autores
        /// OPT #4: Pre-cálculo de extensiones para evitar ToLowerInvariant repetido
        /// </summary>
        private async Task<bool> IsSpanishFileByContent(string username, string filename, long fileSize, string network = "Soulseek")
        {
            // MEJORA #7: Usar nombre de usuario normalizado en la clave de caché
            // Esto evita verificar el mismo archivo de "A. E. Pepito" y "AE Pepito"
            string normalizedUsername = ValidationHelpers.NormalizeAuthorName(username);
            string cacheKey = $"{normalizedUsername}|{filename}";
            
            // MEJORA #2: Verificar caché persistente SQLite primero
            if (persistentLanguageCache != null)
            {
                var persistentResult = persistentLanguageCache.Get(cacheKey, maxAgeHours: 720); // 30 días
                if (persistentResult.HasValue)
                {
                    languageStats.CacheHits++;
                    // Agregar también a caché en memoria para acceso rápido
                    contentVerificationCache[cacheKey] = persistentResult.Value;
                    return persistentResult.Value;
                }
            }
            
            // MEJORA #3: Verificar caché en memoria
            if (contentVerificationCache.TryGetValue(cacheKey, out bool cachedResult))
            {
                languageStats.CacheHits++;
                return cachedResult;
            }
            
            try
            {
                // Determinar el cliente correcto según la red de origen
                SoulseekClient downloadClient = client; // Por defecto Soulseek
                
                if (!string.IsNullOrEmpty(network) && network != "Soulseek")
                {
                    if (_networkOrchestrator != null)
                    {
                        var networkClient = _networkOrchestrator.GetClient(network);
                        if (networkClient is SlskDown.Core.SoulseekClientAdapter adapter)
                        {
                            downloadClient = adapter.GetUnderlyingClient();
                        }
                    }
                }
                
                // OPT #4: Usar HashSet pre-calculado en lugar de switch con ToLowerInvariant
                string ext = Path.GetExtension(filename);
                int sampleSize;
                
                if (textExtensions.Contains(ext))
                    sampleSize = 30 * 1024; // 30 KB (texto plano/comprimido)
                else if (pdfExtensions.Contains(ext))
                    sampleSize = 100 * 1024; // 100 KB (puede tener imágenes/portadas)
                else if (mobiExtensions.Contains(ext))
                    sampleSize = 50 * 1024; // 50 KB (intermedio)
                else
                    sampleSize = 50 * 1024; // 50 KB (por defecto)
                
                // Crear archivo temporal
                var tempPath = Path.Combine(Path.GetTempPath(), $"slsk_sample_{Guid.NewGuid()}.tmp");
                
                // Descargar solo los primeros KB
                long bytesToDownload = Math.Min(sampleSize, fileSize);
                
                // MEJORA #4: Timeout adaptativo basado en tamaño de muestra
                // 1 segundo por cada 10KB, mínimo 5s, máximo 30s
                int timeoutSeconds = Math.Max(5, Math.Min(30, sampleSize / 10240));
                
                using (var cts = new CancellationTokenSource(TimeSpan.FromSeconds(timeoutSeconds)))
                {
                    await downloadClient.DownloadAsync(
                        username,
                        filename,
                        () => Task.FromResult<Stream>(new FileStream(tempPath, FileMode.Create)),
                        bytesToDownload,
                        startOffset: 0,
                        cancellationToken: cts.Token
                    );
                }
                
                // Extraer texto del archivo parcial
                string content = ExtractTextFromFile(tempPath);
                
                // Limpiar archivo temporal
                try { System.IO.File.Delete(tempPath); } catch { }
                
                // Verificar idioma del contenido
                bool isSpanish = false;
                if (!string.IsNullOrWhiteSpace(content))
                {
                    isSpanish = IsSpanishText(content);
                }
                
                // MEJORA #3: Guardar en caché en memoria
                // MEJORA #2: Verificar límite de caché antes de agregar
                AddToContentCache(cacheKey, isSpanish);
                
                // MEJORA #2: Guardar también en caché persistente SQLite
                if (persistentLanguageCache != null)
                {
                    persistentLanguageCache.Set(cacheKey, isSpanish, fileSize, "content");
                }
                
                return isSpanish;
            }
            catch (Exception ex)
            {
                // Si falla la descarga parcial, asumir que no es español
                languageStats.VerificationErrors++;
                AutoLog($"⚠️ Error verificando contenido: {ex.Message}");
                
                // Guardar en caché como false para no reintentar
                AddToContentCache(cacheKey, false);
                
                // MEJORA #2: Guardar también en caché persistente
                if (persistentLanguageCache != null)
                {
                    persistentLanguageCache.Set(cacheKey, false, fileSize, "error");
                }
                
                return false;
            }
        }
        
        /// <summary>
        /// MEJORA #1: Verificar múltiples archivos en paralelo para acelerar el proceso
        /// Procesa hasta MAX_PARALLEL_CONTENT_VERIFICATIONS archivos simultáneamente
        /// </summary>
        private async Task<Dictionary<string, bool>> VerifyMultipleFilesInParallel(
            List<(string username, string filename, long fileSize)> filesToVerify)
        {
            var results = new Dictionary<string, bool>();
            
            if (filesToVerify == null || filesToVerify.Count == 0)
                return results;
            
            using (var semaphore = new SemaphoreSlim(MAX_PARALLEL_CONTENT_VERIFICATIONS))
            {
                var tasks = filesToVerify.Select(async file =>
                {
                    await semaphore.WaitAsync();
                    try
                    {
                        var isSpanish = await IsSpanishFileByContent(file.username, file.filename, file.fileSize);
                        return (file.filename, isSpanish);
                    }
                    finally
                    {
                        semaphore.Release();
                    }
                }).ToList();
                
                var completedResults = await Task.WhenAll(tasks);
                
                foreach (var (filename, isSpanish) in completedResults)
                {
                    results[filename] = isSpanish;
                }
            }
            
            return results;
        }
        
        /// <summary>
        /// MEJORA #2: Agrega entrada al caché con límite de tamaño
        /// </summary>
        private void AddToContentCache(string key, bool value)
        {
            if (contentVerificationCache.Count >= MAX_CONTENT_CACHE_SIZE)
            {
                // Eliminar 20% más antiguo (primeros elementos del diccionario)
                var toRemove = contentVerificationCache.Keys.Take(MAX_CONTENT_CACHE_SIZE / 5).ToList();
                foreach (var k in toRemove)
                {
                    contentVerificationCache.Remove(k);
                }
                
                languageStats.CacheCleanups++;
                AutoLog($"🗑️ Caché de contenido limpiado: {toRemove.Count} entradas eliminadas");
            }
            
            contentVerificationCache[key] = value;
        }
        
        /// <summary>
        /// Muestra ventana de estadísticas de filtrado de idioma con actualización en tiempo real
        /// </summary>
        private void ShowLanguageStatsWindow()
        {
            var statsForm = new Form
            {
                Text = "📊 Estadísticas de Filtrado de Idioma",
                Size = new Size(600, 500),
                BackColor = Color.FromArgb(18, 18, 18),
                ForeColor = Color.White,
                StartPosition = FormStartPosition.CenterParent,
                FormBorderStyle = FormBorderStyle.FixedDialog,
                MaximizeBox = false,
                MinimizeBox = false
            };

            var mainPanel = new Panel
            {
                Dock = DockStyle.Fill,
                BackColor = Color.FromArgb(18, 18, 18),
                Padding = new Padding(20)
            };

            var statsLabel = new Label
            {
                Dock = DockStyle.Fill,
                Font = new Font("Consolas", 10),
                ForeColor = Color.FromArgb(220, 220, 220),
                BackColor = Color.FromArgb(25, 25, 25),
                Padding = new Padding(15),
                Text = languageStats.ToString()
            };

            var updateTimer = new System.Windows.Forms.Timer
            {
                Interval = 1000 // Actualizar cada segundo
            };

            updateTimer.Tick += (s, e) =>
            {
                if (statsForm.IsDisposed)
                {
                    updateTimer.Stop();
                    updateTimer.Dispose();
                    return;
                }

                try
                {
                    double cacheEfficiency = (languageStats.TotalContentVerifications + languageStats.CacheHits) > 0
                        ? (languageStats.CacheHits * 100.0 / (languageStats.TotalContentVerifications + languageStats.CacheHits))
                        : 0;

                    double acceptanceRate = languageStats.TotalProcessed > 0
                        ? (languageStats.TotalAccepted * 100.0 / languageStats.TotalProcessed)
                        : 0;

                    statsLabel.Text = $"📊 ESTADÍSTICAS DE FILTRADO DE IDIOMA\n" +
                                     $"{'═',60}\n\n" +
                                     $"✅ ACEPTADOS:\n" +
                                     $"   • Por título:    {languageStats.AcceptedByTitle,8:N0}\n" +
                                     $"   • Por contenido: {languageStats.AcceptedByContent,8:N0}\n" +
                                     $"   • Total:         {languageStats.TotalAccepted,8:N0}\n\n" +
                                     $"❌ RECHAZADOS:\n" +
                                     $"   • Por título:    {languageStats.RejectedByTitle,8:N0}\n" +
                                     $"   • Por contenido: {languageStats.RejectedByContent,8:N0}\n" +
                                     $"   • Total:         {languageStats.TotalRejected,8:N0}\n\n" +
                                     $"📈 RESUMEN:\n" +
                                     $"   • Total procesados:      {languageStats.TotalProcessed,8:N0}\n" +
                                     $"   • Tasa de aceptación:    {acceptanceRate,8:F1}%\n" +
                                     $"   • Verificaciones contenido: {languageStats.TotalContentVerifications,8:N0}\n\n" +
                                     $"🗂️ CACHÉ:\n" +
                                     $"   • Hits de caché:     {languageStats.CacheHits,8:N0}\n" +
                                     $"   • Eficiencia:        {cacheEfficiency,8:F1}%\n" +
                                     $"   • Limpiezas:         {languageStats.CacheCleanups,8:N0}\n\n" +
                                     $"⚠️ ERRORES:\n" +
                                     $"   • Errores verificación: {languageStats.VerificationErrors,8:N0}\n\n" +
                                     $"🕐 Actualizado: {DateTime.Now:HH:mm:ss}";
                }
                catch
                {
                    // Ignorar errores durante actualización
                }
            };

            var closeButton = new Button
            {
                Text = "Cerrar",
                Dock = DockStyle.Bottom,
                Height = 40,
                BackColor = Color.FromArgb(60, 60, 60),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 10)
            };
            closeButton.FlatAppearance.BorderSize = 0;
            closeButton.Click += (s, e) => statsForm.Close();

            mainPanel.Controls.Add(statsLabel);
            mainPanel.Controls.Add(closeButton);
            statsForm.Controls.Add(mainPanel);

            statsForm.FormClosing += (s, e) =>
            {
                updateTimer.Stop();
                updateTimer.Dispose();
            };

            updateTimer.Start();
            statsForm.ShowDialog();
        }
        
