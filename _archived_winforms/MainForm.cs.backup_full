        private ToolTip sharedToolTip;
        private ToolTip GetToolTip()
        {
            if (sharedToolTip == null)
            {
                var t = new ToolTip
                {
                    ShowAlways = true,
                    InitialDelay = 250,
                    AutoPopDelay = 12000,
                    ReshowDelay = 100,
                    OwnerDraw = true
                };
                t.Draw += SharedToolTip_Draw;
                t.Popup += SharedToolTip_Popup;
                sharedToolTip = t;
            }
            return sharedToolTip;
        }
        private void SharedToolTip_Popup(object sender, PopupEventArgs e) { }
        private void SharedToolTip_Draw(object sender, DrawToolTipEventArgs e)
        {
            var back = Color.FromArgb(42, 42, 42);
            var fore = Color.FromArgb(240, 240, 240);
            using (var bg = new SolidBrush(back)) e.Graphics.FillRectangle(bg, e.Bounds);
            using (var pen = new Pen(Color.FromArgb(70, 70, 70))) e.Graphics.DrawRectangle(pen, e.Bounds);
            using (var textBrush = new SolidBrush(fore)) e.Graphics.DrawString(e.ToolTipText, e.Font, textBrush, e.Bounds);
        }
