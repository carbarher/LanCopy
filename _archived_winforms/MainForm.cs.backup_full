                    Size = new Size(100, 35),
                    BackColor = Color.FromArgb(100, 100, 100),
                    ForeColor = Color.White,
                    FlatStyle = FlatStyle.Flat,
                    Font = new Font("Segoe UI", 9, FontStyle.Bold),
                    Cursor = Cursors.Hand
                };
                btnClose.FlatAppearance.BorderSize = 0;
                btnClose.Click += (s, e) => synopsisForm.Close();
                
                var btnDownload = new Button
                {
                    Text = "⬇️ Descargar",
                    Size = new Size(120, 35),
                    BackColor = Color.FromArgb(0, 150, 0),
                    ForeColor = Color.White,
                    FlatStyle = FlatStyle.Flat,
                    Font = new Font("Segoe UI", 9, FontStyle.Bold),
                    Cursor = Cursors.Hand,
                    Margin = new Padding(10, 0, 0, 0)
                };
                btnDownload.FlatAppearance.BorderSize = 0;
                btnDownload.Click += async (s, e) =>
                {
                    synopsisForm.Close();
                    
                    // Verificar que el usuario no esté en blacklist antes de descargar
                    dynamic tag = selectedItem.Tag;
                    string username = tag?.Username;
                    
                    if (!string.IsNullOrEmpty(username) && blacklist.Contains(username))
                    {
                        DarkMessageBox.Show($"El usuario '{username}' está en la blacklist.\nNo se puede descargar de este usuario.", 
                            "Usuario Bloqueado", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                        return;
                    }
                    
                    // Descargar archivo seleccionado
                    await DownloadMultipleAsync();
