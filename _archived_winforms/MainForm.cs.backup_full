        private void OnAutoModeChanged(object sender, EventArgs e)
        {
            autoMode = chkAutoMode.Checked;
            SaveConfig();

            if (autoMode)
            {
                InitializeAutoMode();
                Log("🤖 Modo Automático ACTIVADO:");
                Log("  • Auto-limpieza de resultados al añadir a descargas");
                Log("  • Auto-limpieza de cachés viejas (>30 días)");
                Log("  • Auto-inicio de cola al conectar");
                Log("  • Auto-detección de duplicados con Rust");
                Log("  • Auto-test de conexión cada 5 minutos");
            }
            else
            {
                StopAutoMode();
                Log("🤖 Modo Automático DESACTIVADO");
            }
        }

        private void OnTurboModeChanged(object sender, EventArgs e)
        {
            if (chkTurboMode.Checked)
            {
                maxParallelDownloads = 6; // Valor optimizado por defecto
                maxSimultaneousDownloads = 8;
                maxParallelSearches = 12;
                searchTimeout = 20;
                
                // Ajustar rango antes de establecer valor
                if (numParallelDownloads.Maximum < 6)
                    numParallelDownloads.Maximum = 6;
                numParallelDownloads.Value = 6;
                if (numParallelDownloads.Maximum < 8)
                    numParallelDownloads.Maximum = 8;
                numParallelDownloads.Value = 8;
                
                Log("⚡ Modo Turbo ACTIVADO: 8 descargas simultáneas + 12 búsquedas paralelas, timeout 20s");
            }
            else
            {
                maxParallelDownloads = 2;
                maxSimultaneousDownloads = 2; // Reducido de 3 a 2 para mayor estabilidad
                maxParallelSearches = 3;
                searchTimeout = 30;
                
                // Ajustar rango antes de establecer valor
                if (numParallelDownloads.Maximum < 3)
                    numParallelDownloads.Maximum = 3;
                numParallelDownloads.Value = 3;
                
                Log("🐢 Modo Normal: 3 descargas simultáneas + 3 búsquedas paralelas, timeout 30s");
            }

            numParallelDownloads.Enabled = chkTurboMode.Checked;
            SaveConfig();
        }


        private void BrowseDownloadFolder()
        {
            var selectedPath = DarkFolderBrowserDialog.ShowDialog(this, "Seleccionar carpeta de descargas", downloadDir);
            if (!string.IsNullOrWhiteSpace(selectedPath))
            {
                txtDownloadDir.Text = selectedPath;
            }
        }

        private void OnEditBlacklistClick(object sender, EventArgs e)
        {
            try
            {
                if (!System.IO.File.Exists(blacklistAuthorsFile))
                {
                    SaveBlacklistedAuthors();
                }

                Process.Start("notepad.exe", blacklistAuthorsFile);
                DarkMessageBox.Show(
                    $"Blacklist actualizada desde:\n{blacklistAuthorsFile}",
                    "Blacklist Actualizada",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Information);

                // MEJORA #40: Usar async/await en lugar de ContinueWith
                _ = Task.Run(async () =>
                {
                    await Task.Delay(1000).ConfigureAwait(false);
                    SafeBeginInvoke(() => LoadBlacklistedAuthors());
                });
            }
            catch (Exception ex)
            {
                DarkMessageBox.Show($"Error: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private void OnAggressiveModeClick(object sender, EventArgs e)
        {
            if (!aggressiveModeActive)
            {
                savedMaxParallelDownloads = maxParallelDownloads;
                savedMaxSimultaneousDownloads = maxSimultaneousDownloads;
                savedMaxParallelSearches = maxParallelSearches;
                savedSearchTimeout = searchTimeout;

                maxParallelDownloads = 15;
                maxSimultaneousDownloads = 15;
                maxParallelSearches = 20;
                searchTimeout = 15;

                aggressiveModeActive = true;
                aggressiveModeEndTime = DateTime.Now.AddMinutes(30);

                if (aggressiveModeTimer == null)
                {
                    aggressiveModeTimer = new System.Windows.Forms.Timer();
                    aggressiveModeTimer.Interval = TIMER_AGGRESSIVE_MODE_MS;
                    aggressiveModeTimer.Tick += (ts, te) =>
                    {
                        if (DateTime.Now >= aggressiveModeEndTime)
                        {
                            maxParallelDownloads = savedMaxParallelDownloads;
                            maxSimultaneousDownloads = savedMaxSimultaneousDownloads;
                            maxParallelSearches = savedMaxParallelSearches;
                            searchTimeout = savedSearchTimeout;

                            aggressiveModeActive = false;
                            aggressiveModeTimer.Stop();

                            Log("🔥 Modo Agresivo DESACTIVADO - Valores restaurados");
                        }
                    };
                }

                aggressiveModeTimer.Start();
                Log("🔥 Modo Agresivo ACTIVADO por 30 minutos:");
                Log($"  • Descargas simultáneas: {maxSimultaneousDownloads}");
                Log($"  • Búsquedas paralelas: {maxParallelSearches}");
                Log($"  • Timeout: {searchTimeout}s");
                Log("⚠️ ADVERTENCIA: Modo agresivo puede causar bans si se usa con búsquedas masivas");
                ShowNotification("Modo Agresivo", "Modo agresivo activado por 30 minutos.\nMáxima velocidad!\n⚠️ No usar con búsquedas masivas", ToolTipIcon.Warning);
            }
            else
            {
                maxParallelDownloads = savedMaxParallelDownloads;
                maxSimultaneousDownloads = savedMaxSimultaneousDownloads;
                maxParallelSearches = savedMaxParallelSearches;
                searchTimeout = savedSearchTimeout;

                aggressiveModeActive = false;
                aggressiveModeTimer?.Stop();

                Log("🔥 Modo Agresivo DESACTIVADO manualmente");
            }
        }

        private Label CreateMemoryStatsLabel()
        {
            lblMemoryStats = new Label
            {
                Text = "Calculando...",
                ForeColor = Color.LightGreen,
                Font = new Font("Segoe UI", 9),
                AutoSize = true
            };
            
            // Actualizar cada 5 segundos
            var memoryUpdateTimer = new System.Windows.Forms.Timer();
            memoryUpdateTimer.Interval = 5000;
            memoryUpdateTimer.Tick += (s, e) => UpdateMemoryStats();
            memoryUpdateTimer.Start();
            
            // Actualización inicial
            UpdateMemoryStats();
            
            return lblMemoryStats;
        }
        
        private void UpdateMemoryStats()
        {
            try
            {
                if (memoryManager == null)
                {
                    lblMemoryStats.Text = "N/A";
                    return;
                }
                
                var stats = memoryManager.GetMemoryStats();
                var memoryMB = stats.WorkingSetMB;
                
                // Determinar estado según umbrales
                string status;
                Color color;
                
                if (memoryMB >= 1500) // Emergency
                {
                    status = "💥 Emergencia";
                    color = Color.Red;
                }
                else if (memoryMB >= 1000) // Critical
                {
                    status = "🚨 Crítica";
                    color = Color.Orange;
                }
                else if (memoryMB >= 500) // Warning
                {
                    status = "⚠️ Alta";
                    color = Color.Yellow;
                }
                else // Normal
                {
                    status = "✅ Normal";
                    color = Color.LightGreen;
                }
                
                lblMemoryStats.Text = $"{memoryMB} MB ({status}) | GC: {stats.GCMemoryMB} MB | Disp: {stats.RegisteredDisposables}";
                lblMemoryStats.ForeColor = color;
            }
            catch (Exception ex)
            {
                SafeLog($"Error actualizando stats memoria: {ex.Message}");
                lblMemoryStats.Text = "Error";
                lblMemoryStats.ForeColor = Color.Gray;
            }
        }
        
        private void OnOptimizeMemoryClick(object sender, EventArgs e)
        {
            try
            {
                if (memoryManager != null)
                {
                    LogEx(LogLevel.INFO, LogCategory.SISTEMA, "⚡ Iniciando optimización agresiva de memoria...");
                    
                    var memoryBefore = memoryManager.GetCurrentMemoryUsage();
                    
                    // 1. Forzar GC completo múltiple
                    for (int i = 0; i < 3; i++)
                    {
                        GC.Collect(GC.MaxGeneration, GCCollectionMode.Forced);
                        GC.WaitForPendingFinalizers();
                        Thread.Sleep(100);
                    }
                    
                    // 2. Limpieza completa del MemoryManager
                    var result = memoryManager.PerformCleanup();
                    
                    // 3. Compactar Large Object Heap
                    GCSettings.LargeObjectHeapCompactionMode = GCLargeObjectHeapCompactionMode.CompactOnce;
                    GC.Collect(GC.MaxGeneration, GCCollectionMode.Aggressive);
                    
                    var memoryAfter = memoryManager.GetCurrentMemoryUsage();
                    var totalFreed = memoryBefore - memoryAfter;
                    
                    LogEx(LogLevel.INFO, LogCategory.SISTEMA, $"✅ Optimización completada: {totalFreed} MB liberados");
                    ShowNotification("Optimización de Memoria", 
                        $"Memoria liberada: {totalFreed} MB\n" +
                        $"Disposables limpiados: {result.DisposablesCleaned}\n" +
                        $"Memoria actual: {memoryAfter} MB", 
                        ToolTipIcon.Info);
                    
                    UpdateMemoryStats();
                }
            }
            catch (Exception ex)
            {
                SafeLog($"Error en optimización: {ex.Message}");
                ShowNotification("Error", $"Error al optimizar: {ex.Message}", ToolTipIcon.Error);
            }
        }

        private void OnStartQueueClick(object sender, EventArgs e)
        {
            try
            {
                int resumed = 0;

                if (downloadManager != null)
                {
                    var snapshot = downloadManager.GetQueueSnapshot();
                    foreach (var task in snapshot.Where(t => t.Status == DownloadStatus.Paused))
                    {
                        if (downloadManager.ResumeTask(task))
                        {
                            resumed++;
                        }
                    }

                    if (resumed > 0)
                    {
                        downloadManager.Start();
                    }
                }
                else
                {
                    // MEJORA FASE 1.3: ReadLock para snapshot, WriteLock para modificar
                    var tasksToResume = ReadLocked(downloadQueueLock, () =>
                        downloadQueue
                            .Where(t => t.Status == DownloadStatus.Paused)
                            .ToList());

                    foreach (var task in tasksToResume)
                    {
                        WriteLocked(downloadQueueLock, () => task.Status = DownloadStatus.Queued);
                        UpdateDownloadUI(task, "⏳ En cola");
                    }

                    resumed = tasksToResume.Count;

                    foreach (var task in tasksToResume)
                    {
                        // MEJORA #26: Eliminar Task.Run redundante
                        _ = ProcessDownload(task);
                    }
                }

                if (resumed > 0)
                {
                    AutoLog($"▶️ {resumed} descarga(s) reanudada(s)");
                    ShowDarkDialog(
                        $"✅ Se reanudaron {resumed} descarga(s).\n\nLas descargas comenzarán automáticamente según la capacidad disponible.",
                        "Cola Iniciada",
                        MessageBoxButtons.OK,
                        "✅");
                }
                else
                {
                    ShowDarkDialog(
                        "No hay descargas pausadas para reanudar.",
                        "Cola Iniciada",
                        MessageBoxButtons.OK,
                        "ℹ️");
                }
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error al iniciar cola: {ex.Message}");
                ShowDarkDialog($"Error al iniciar cola:\n{ex.Message}", "Error", MessageBoxButtons.OK, "❌");
            }
        }

        private void OnClearQueueClick(object sender, EventArgs e)
        {
            try
            {
                // MEJORA FASE 1.3: ReadLock para Count
                (int totalTasks, int completedTasks) = ReadLocked(downloadQueueLock, () =>
                    (downloadQueue.Count, downloadQueue.Count(t => t.Status == DownloadStatus.Completed)));

                var result = ShowDarkDialog(
                    $"⚠️ ADVERTENCIA: Esta acción eliminará TODA la cola de descargas.\n\n" +
                    $"📊 Estado actual:\n" +
                    $"   • Total de tareas: {totalTasks}\n" +
                    $"   • Completadas: {completedTasks}\n" +
                    $"   • Pendientes/En progreso: {totalTasks - completedTasks}\n\n" +
                    $"🛑 Se cancelarán todas las descargas activas.\n" +
                    $"🗑️ Se eliminarán todas las tareas de la cola.\n\n" +
                    $"Esta acción NO se puede deshacer.\n\n" +
                    $"¿Estás seguro de que quieres continuar?",
                    "Eliminar Cola de Descargas",
                    MessageBoxButtons.YesNo,
                    "⚠️");

                if (result != DialogResult.Yes)
                    return;

                // MEJORA FASE 1.3: WriteLock para ToList + Remove
                List<DownloadTask> removedTasks = new List<DownloadTask>();
                WriteLocked(downloadQueueLock, () =>
                {
                    foreach (var task in downloadQueue.ToList())
                    {
                        if (task.Status == DownloadStatus.Downloading)
                        {
                            try { task.CancellationToken?.Cancel(); } catch { }
                        }

                        removedTasks.Add(task);
                        downloadQueue.Remove(task);
                    }
                });

                SafeInvoke(() => lvDownloads.Items.Clear());

                foreach (var task in removedTasks)
                {
                    SafeInvoke(() =>
                    {
                        if (task.ListViewItem != null && lvDownloads.Items.Contains(task.ListViewItem))
                        {
                            lvDownloads.Items.Remove(task.ListViewItem);
                        }
                    });
                }

                AutoLog($"🗑️ Cola de descargas eliminada completamente ({removedTasks.Count} tareas)");

                ShowDarkDialog(
                    $"✅ Cola de descargas eliminada.\n\n" +
                    $"Se eliminaron {removedTasks.Count} tarea(s).\n" +
                    $"Todas las descargas activas fueron canceladas.",
                    "Cola Eliminada",
                    MessageBoxButtons.OK,
                    "✅");
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error al eliminar cola: {ex.Message}");
                ShowDarkDialog($"Error al eliminar cola:\n{ex.Message}", "Error", MessageBoxButtons.OK, "❌");
            }
        }

        /// <summary>
        /// Limpia completamente la cola de descargas sin confirmación
        /// Útil para scripts o automatización
        /// </summary>
        private void ClearDownloadQueueSilent()
        {
            try
            {
                // MEJORA FASE 1.3: WriteLock para ToList + Remove
                List<DownloadTask> removedTasks = new List<DownloadTask>();
                WriteLocked(downloadQueueLock, () =>
                {
                    foreach (var task in downloadQueue.ToList())
                    {
                        if (task.Status == DownloadStatus.Downloading)
                        {
                            try { task.CancellationToken?.Cancel(); } catch { }
                        }

                        removedTasks.Add(task);
                        downloadQueue.Remove(task);
                    }
                });

                SafeInvoke(() => lvDownloads.Items.Clear());

                // Borrar también el archivo de cola guardado
                try
                {
                    var dataDir = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.ApplicationData), "SlskDown");
                    var filePath = Path.Combine(dataDir, "cola_descargas.json");
                    if (System.IO.File.Exists(filePath))
                    {
                        System.IO.File.Delete(filePath);
                        AutoLog($"🗑️ Archivo de cola eliminado: {filePath}");
                    }
                }
                catch (Exception ex)
                {
                    AutoLog($"⚠️ No se pudo eliminar archivo de cola: {ex.Message}");
                }

                AutoLog($"🗑️ Cola de descargas eliminada completamente ({removedTasks.Count} tareas)");
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error al eliminar cola: {ex.Message}");
            }
        }

        /// <summary>
        /// Guarda la cola de descargas pendientes en un archivo JSON automáticamente
        /// </summary>
        private void SaveDownloadQueue()
        {
            try
            {
                // MEJORA FASE 1.3: ReadLock para snapshot de solo lectura
                var pendingTasks = ReadLocked(downloadQueueLock, () =>
                    downloadQueue
                        .Where(t => t.Status == DownloadStatus.Queued || 
                                   t.Status == DownloadStatus.Paused ||
                                   t.Status == DownloadStatus.Downloading)
                        .ToList());

                if (pendingTasks.Count == 0)
                {
                    AutoLog("⚠️ No hay archivos pendientes en la cola para guardar");
                    return;
                }

                // Guardar automáticamente en el directorio de datos de la aplicación
                var dataDir = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.ApplicationData), "SlskDown");
                System.IO.Directory.CreateDirectory(dataDir); // Asegurar que existe
                
                var filePath = Path.Combine(dataDir, "cola_descargas.json");

                // Crear una estructura serializable con solo los datos necesarios
                var queueData = pendingTasks.Select(t => new
                {
                    Username = t.File?.Author ?? t.File?.Username ?? "Unknown",
                    Filename = t.File?.FileName ?? "Unknown",
                    Directory = t.File?.Directory ?? "",
                    SizeBytes = t.File?.SizeBytes ?? 0,
                    LocalPath = t.LocalPath,
                    IsSpanish = t.File?.IsSpanish ?? false,
                    IsDocument = t.File?.IsDocument ?? false
                }).ToList();

                var json = System.Text.Json.JsonSerializer.Serialize(queueData, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
                System.IO.File.WriteAllText(filePath, json, System.Text.Encoding.UTF8);

                AutoLog($"💾 Cola guardada automáticamente: {pendingTasks.Count} archivo(s) pendiente(s) en {filePath}");
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error al guardar cola automáticamente: {ex.Message}");
            }
        }

        /// <summary>
        /// Carga una cola de descargas desde un archivo JSON automáticamente
        /// </summary>
        private void LoadDownloadQueue()
        {
            try
            {
                Log("🔄 Iniciando carga automática de cola de descargas...");
                
                // Cargar automáticamente desde el directorio de datos de la aplicación
                var dataDir = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.ApplicationData), "SlskDown");
                var filePath = Path.Combine(dataDir, "cola_descargas.json");
                
                Log($"📁 Buscando archivo de cola en: {filePath}");

                if (!System.IO.File.Exists(filePath))
                {
                    Log("ℹ️ No hay cola de descargas guardada para cargar");
                    return;
                }

                var json = System.IO.File.ReadAllText(filePath, System.Text.Encoding.UTF8);
                var queueData = System.Text.Json.JsonSerializer.Deserialize<List<Dictionary<string, System.Text.Json.JsonElement>>>(json);

                if (queueData == null || queueData.Count == 0)
                {
                    Log("⚠️ El archivo de cola está vacío o no es válido");
                    return;
                }

                int added = 0;
                int skipped = 0;

                foreach (var item in queueData)
                {
                    try
                    {
                        // MEJORA #21: Usar TryGetValue para evitar múltiples búsquedas en diccionario
                        item.TryGetValue("Username", out var usernameObj);
                        item.TryGetValue("Filename", out var filenameObj);
                        item.TryGetValue("Directory", out var directoryObj);
                        item.TryGetValue("SizeBytes", out var sizeObj);
                        item.TryGetValue("IsSpanish", out var spanishObj);
                        item.TryGetValue("IsDocument", out var documentObj);
                        
                        var username = usernameObj.ValueKind != System.Text.Json.JsonValueKind.Undefined ? usernameObj.ToString() : "Unknown";
                        
                        // Reconstruir AutoSearchFileResult desde los datos guardados
                        var file = new AutoSearchFileResult
                        {
                            Author = username,
                            Username = username,
                            FileName = filenameObj.ValueKind != System.Text.Json.JsonValueKind.Undefined ? filenameObj.ToString() : "Unknown",
                            Directory = directoryObj.ValueKind != System.Text.Json.JsonValueKind.Undefined ? directoryObj.ToString() : "",
                            SizeBytes = sizeObj.ValueKind != System.Text.Json.JsonValueKind.Undefined ? Convert.ToInt64(sizeObj.GetInt64()) : 0,
                            IsSpanish = spanishObj.ValueKind != System.Text.Json.JsonValueKind.Undefined && spanishObj.GetBoolean(),
                            IsDocument = documentObj.ValueKind != System.Text.Json.JsonValueKind.Undefined && documentObj.GetBoolean(),
                            Timestamp = DateTime.Now
                        };

                        // MEJORA FASE 1.3: ReadLock para Any
                        bool alreadyExists = ReadLocked(downloadQueueLock, () =>
                            downloadQueue.Any(t => 
                                t.File?.FileName == file.FileName && 
                                t.File?.Author == file.Author));

                        if (alreadyExists)
                        {
                            skipped++;
                            continue;
                        }

                        // Añadir a la cola
                        item.TryGetValue("LocalPath", out var localPathObj);
                        var localPath = localPathObj.ValueKind != System.Text.Json.JsonValueKind.Undefined ? localPathObj.ToString() : Path.Combine(downloadDir, file.FileName);

                        var task = new DownloadTask
                        {
                            File = file,
                            LocalPath = localPath,
                            Status = DownloadStatus.Queued
                        };

                        // MEJORA FASE 1.3: WriteLock para Add
                        WriteLocked(downloadQueueLock, () => downloadQueue.Add(task));
                        
                        // MEJORA NICOTINE+: Agregar a UserQueueManager para fairness
                        _userQueueManager?.Enqueue(task);
                        
                        // MEJORA FASE 1.3: ReadLock para Count
                        int queuePosition = ReadLocked(downloadQueueLock, () => downloadQueue.Count);
                        
                        // MEJORA NICOTINE+: Publicar evento DownloadQueued
                        _eventBus?.Publish(SystemEvents.DownloadQueued, new
                        {
                            FileName = file.FileName,
                            Username = file.Username,
                            QueuePosition = queuePosition,
                            UserQueueSize = _userQueueManager?.GetUserQueueSize(file.Username) ?? 0,
                            Timestamp = DateTime.UtcNow
                        });

                        // Crear ListViewItem para la UI (solo si lvDownloads ya está inicializado)
                        if (lvDownloads != null)
                        {
                            SafeInvoke(() =>
                            {
                                try
                                {
                                    if (lvDownloads != null && lvDownloads.IsHandleCreated)
                                    {
                                        var downloadItem = new ListViewItem(file.FileName);
                                        EnsureDownloadSubItems(downloadItem);
                                        downloadItem.Tag = task;
                                        task.ListViewItem = downloadItem;
                                        UpdateListViewItemColumns(task, downloadItem);
                                        lvDownloads.Items.Add(downloadItem);
                                    }
                                }
                                catch (Exception uiEx)
                                {
                                    // Ignorar errores UI durante inicialización
                                    System.Diagnostics.Debug.WriteLine($"UI error durante carga de cola: {uiEx.Message}");
                                }
                            });
                        }
                        added++;
                    }
                    catch (Exception ex)
                    {
                        Log($"⚠️ Error procesando archivo de cola: {ex.Message}");
                        skipped++;
                    }
                }

                Log($"✅ Cola cargada automáticamente: {added} archivo(s) añadido(s), {skipped} omitido(s) desde {filePath}");
                
                // Iniciar el gestor de descargas si hay archivos en la cola
                if (added > 0 && downloadManager != null)
                {
                    downloadManager.Start();
                    Log("▶️ Gestor de descargas iniciado automáticamente");
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error al cargar cola automáticamente: {ex.Message}");
            }
        }

        private async void OnResetAllClick(object sender, EventArgs e)
        {
            var result = ShowDarkDialog(
                "⚠️ ADVERTENCIA: Esta acción:\n\n" +
                "🛑 DETENDRÁ todas las descargas activas\n" +
                "🗑️ ELIMINARÁ todos los datos:\n\n" +
                "• Base de datos SQLite completa\n" +
                "• Cachés (búsqueda, Calibre, países, batch)\n" +
                "• Resultados de búsqueda automática (CSV y JSON)\n" +
                "• Historial de descargas y cola de descargas\n" +
                "• Estadísticas y progreso de purga\n" +
                "• Favoritos y búsquedas recientes\n" +
                "• Blacklist de usuarios y autores\n" +
                "• Watchlist y Wishlist\n" +
                "• Lista de autores\n" +
                "• Memoria caché (metadata, deduplicación, etc.)\n\n" +
                "NO se eliminará la configuración de usuario/contraseña.\n\n" +
                "¿Estás seguro de que quieres continuar?",
                "Reset Completo",
                MessageBoxButtons.YesNo,
                "⚠️");

            if (result == DialogResult.Yes)
            {
                try
                {
                    AutoLog("═══════════════════════════════════════");
                    AutoLog("🔥 INICIANDO RESET COMPLETO");
                    AutoLog("═══════════════════════════════════════");

                    var filesToDelete = new[]
                    {
                        Path.Combine(dataDir, "search_cache.json"),
                        calibreCacheFile,
                        countryCachePath,
                        progressPath,
                        dbPath,
                        autoResultsCsvPath,
                        autoSearchResultsJsonPath,
                        downloadHistoryPath,
                        statsPath,
                        Path.Combine(dataDir, "purge_progress.json"),
                        favoritesPath,
                        historyPath,
                        blacklistAuthorsFile,
                        blacklistPath,
                        watchlistPath,
                        wishlistPath,
                        downloadQueuePath,
                        authorsPath,
                        Path.Combine(dataDir, "last_authors_file.txt")
                    };

                    int deleted = 0;
                    long totalSize = 0;

                    foreach (var path in filesToDelete)
                    {
                        try
                        {
                            if (System.IO.File.Exists(path))
                            {
                                // MEJORA #27: Usar caché de FileInfo
                                var size = GetCachedFileInfo(path).Length;
                                System.IO.File.Delete(path);
                                deleted++;
                                totalSize += size;
                                AutoLog($"   ✅ Eliminado: {Path.GetFileName(path)} ({FormatFileSize(size)})");
                            }
                        }
                        catch (Exception ex)
                        {
                            AutoLog($"   ❌ Error eliminando {Path.GetFileName(path)}: {ex.Message}");
                        }
                    }

                    // MEJORA #37: ConfigureAwait(false) en loop de monitoreo
                    await Task.Delay(1000).ConfigureAwait(false);

                    // MEJORA FASE 1.3: ReadLock para snapshot, WriteLock para modificar
                    var tasksToCancel = ReadLocked(downloadQueueLock, () => downloadQueue.ToList());
                    foreach (var task in tasksToCancel)
                    {
                        try 
                        { 
                            WriteLocked(downloadQueueLock, () => task.CancellationToken?.Cancel()); 
                        } 
                        catch (Exception ex) 
                        { 
                            AutoLog($"⚠️ Error cancelando tarea: {ex.Message}"); 
                        }
                    }

                    try
                    {
                        dbConnection?.Close();
                        dbConnection?.Dispose();
                        dbConnection = null;
                    }
                    catch (Exception ex)
                    {
                        AutoLog($"⚠️ Error cerrando dbConnection: {ex.Message}");
                    }

                    lock (autoSearchResultsLock) { autoSearchResults.Clear(); }
                    // MEJORA FASE 1.3: WriteLock para Clear
                    WriteLocked(downloadQueueLock, () => downloadQueue.Clear());
                    lock (downloadHistoryLock) { downloadHistory.Clear(); }
                    lock (providerStatsLock) { providerStats.Clear(); }
                    lock (authorIndexLock) { filesByAuthorIndex.Clear(); }

                    await _searchCacheManager.ClearAsync();
                    blacklistedAuthors.Clear();
                    carbarherFilesCache.Clear();
                    carbarherCacheLoaded = false;
                    wishlist.Clear();
                    fileExistsCache.Clear();
                    hashToFilePath.Clear();
                    allAuthorsData.Clear();
                    filteredAuthorsData.Clear();

                    SafeInvoke(() =>
                    {
                        if (lvDownloads != null) lvDownloads.Items.Clear();
                        if (lvAutoAuthors != null) lvAutoAuthors.Items.Clear();
                    });

                    AutoLog("");
                    AutoLog($"✅ Reset completado:");
                    AutoLog($"   📁 {deleted} archivos eliminados");
                    AutoLog($"   💾 {FormatFileSize(totalSize)} liberados");
                    AutoLog($"   🔄 Memoria limpiada");
                    AutoLog("═══════════════════════════════════════");
                    AutoLog("");

                    ShowDarkDialog(
                        $"✅ Reset completado exitosamente\n\n" +
                        $"• {deleted} archivos eliminados\n" +
                        $"• {FormatFileSize(totalSize)} liberados\n\n" +
                        "La aplicación ha vuelto a condiciones iniciales.",
                        "Reset Completo",
                        MessageBoxButtons.OK,
                        "✅");
                }
                catch (Exception ex)
                {
                    AutoLog($"❌ Error durante reset: {ex.Message}");
                    ShowDarkDialog($"Error durante reset:\n{ex.Message}", "Error", MessageBoxButtons.OK, "❌");
                }
            }
        }

        private async Task ConnectToSoulseek()
        {
            if (isConnecting)
            {
                Log("⚠️ Ya hay un proceso de conexión en curso, ignorando solicitud duplicada");
                return;
            }
            
            // Circuit Breaker: Verificar estado
            if (connectionCircuit == CircuitState.Open)
            {
                if (DateTime.UtcNow.Subtract(circuitOpenTime) < circuitOpenDuration)
                {
                    var remainingTime = circuitOpenDuration.Subtract(DateTime.UtcNow.Subtract(circuitOpenTime));
                    Log($"🚫 CIRCUIT BREAKER ABIERTO - Esperando {remainingTime.TotalMinutes:F1} minutos");
                    throw new InvalidOperationException($"Circuit breaker abierto - reintentar en {remainingTime.TotalMinutes:F1} minutos");
                }
                else
                {
                    // Transición a HalfOpen
                    connectionCircuit = CircuitState.HalfOpen;
                    Log("🔄 Circuit Breaker en modo HALF-OPEN - Probando conexión");
                }
            }
            
            // POOL DE CONEXIONES: Intentar failover si hay clientes en pool
            if (clientPool != null && clientPool.Count > 0 && currentClientIndex < clientPool.Count)
            {
                Log($"🔄 Intentando failover con cliente del pool #{currentClientIndex + 1}");
                try
                {
                    var poolClient = clientPool[currentClientIndex];
                    if (poolClient != null && !poolClient.State.HasFlag(SoulseekClientStates.Disconnected))
                    {
                        client = poolClient;
                        Log($"✅ Failover exitoso - usando cliente del pool #{currentClientIndex + 1}");
                        return;
                    }
                    else
                    {
                        Log($"⚠️ Cliente del pool #{currentClientIndex + 1} no disponible, limpiando...");
                        clientPool.RemoveAt(currentClientIndex);
                        if (poolClient != null) poolClient.Dispose();
                    }
                }
                catch (Exception ex)
                {
                    Log($"❌ Failover del pool falló: {ex.Message}");
                }
            }
            
            var stackTrace = new System.Diagnostics.StackTrace(1, false);
            var callerMethod = stackTrace.GetFrame(0)?.GetMethod()?.Name ?? "Unknown";
            
            // Verificar si ya hay una conexión en curso
            bool shouldConnect = false;
            lock (this)
            {
                if (isConnecting)
                {
                    Log($"⚠️ Ya hay un intento de conexión en curso - ignorando llamada desde {callerMethod}");
                    return;
                }
                
                // Verificar backoff antes de conectar
                if (DateTime.UtcNow < nextAllowedConnectAttempt)
                {
                    var wait = nextAllowedConnectAttempt.Subtract(DateTime.UtcNow);
                    Log($"⏳ Conexión pospuesta {wait.TotalSeconds:F0}s - respetando backoff");
                    return;
                }

                // Si ya hay un cliente conectado, no reconstruir la sesión
                if (client != null && client.State.HasFlag(SoulseekClientStates.Connected))
                {
                    Log("ℹ️ Cliente ya conectado: reutilizando sesión existente");
                    shouldConnect = false;
                    return;
                }

                isConnecting = true;
                shouldConnect = true;
            }
            
            if (!shouldConnect)
                return;
            
            Log($"🔄 ConnectToSoulseek llamado desde: {callerMethod}");
            nextAllowedConnectAttempt = DateTime.UtcNow.AddSeconds(10);
            
            if (client != null && client.State.HasFlag(SoulseekClientStates.Connected))
            {
                Log("Ya está conectado");
                lock (this)
                {
                    isConnecting = false;
                }
                return;
            }

            // Prompt for credentials if they are empty
            if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
            {
                Log("⚠️ Credenciales vacías. Solicitando al usuario...");
                SafeBeginInvoke(() =>
                {
                    ShowDarkDialog("Por favor, introduce tu nombre de usuario y contraseña de Soulseek en la pestaña 'Configuración'.",
                                   "Credenciales Requeridas",
                                   MessageBoxButtons.OK,
                                   "⚠️");
                    tabControl.SelectedIndex = 7; // Navegar a la pestaña de configuración (índice 7)
                });
                isConnecting = false;
                return;
            }
            
            try
            {
                UpdateControlEnabled(btnConnect, false);
                UpdateControlText(lblStatus, "Conectando...");
                UpdateControl(lblStatus, c => c.ForeColor = Color.Orange);
                
                if (string.IsNullOrWhiteSpace(username))
                {
                    Log("❌ Error: Usuario vacío");
                    throw new Exception("El nombre de usuario no puede estar vacío");
                }
                if (string.IsNullOrWhiteSpace(password))
                {
                    Log("❌ Error: Contraseña vacía");
                    throw new Exception("La contraseña no puede estar vacía");
                }
                
                Log($"🔐 Intentando conectar como: {username}");
                
                int maxAttempts = 5;
                bool connected = false;
                bool tcpWorked = false; // Declarar fuera del bucle para usar en catch
                
                // CRÍTICO: Resetear contador de timeouts al inicio de cada intento de conexión
                // Esto evita acumular timeouts entre diferentes llamadas a ConnectToSoulseek
                consecutiveTimeouts = 0;
                
                for (int attempt = 1; attempt <= maxAttempts && !connected; attempt++)
                {
                    try
                    {
                        if (client != null)
                        {
                            if (client.State.HasFlag(SoulseekClientStates.Connected) || client.State.HasFlag(SoulseekClientStates.LoggedIn))
                            {
                                Log("ℹ️ Cliente existente sigue conectado, reutilizando sin dispose");
                            }
                            else
                            {
                                try { client.Dispose(); } catch (Exception ex) { AutoLog($"⚠️ Error disposing client: {ex.Message}"); }
                                client = null;
                            }
                        }
                        
                        int randomPort = Random.Shared.Next(50000, 60000);
                        int selectedPort = enableUploads ? listenPort : randomPort;

                        bool useListener = enableUploads;

                        Log($"Intento {attempt}/{maxAttempts} - Puerto: {randomPort}");
                        Log($"   Usuario: {username}");
                        Log($"   Servidor: server.slsknet.org:2242");
                        Log($"   Listener: {(useListener ? "HABILITADO" : "DESHABILITADO")} (puerto {selectedPort})");
                        Log($"   Red distribuida: DESHABILITADA");
                        Log($"   Configurando cliente con opciones minimalistas...");
                        
                        // Opciones minimalistas para conexión más estable
                        // Red distribuida y listener deshabilitados durante conexión inicial
                        var options = new SoulseekClientOptions(
                            listenPort: selectedPort,
                            enableDistributedNetwork: false,
                            enableListener: useListener,
                            autoAcknowledgePrivateMessages: false,
                            autoAcknowledgePrivilegeNotifications: false,
                            acceptPrivateRoomInvitations: false,
                            serverConnectionOptions: new ConnectionOptions(
                                connectTimeout: 30000,  // 30 segundos (alineado con stress test)
                                inactivityTimeout: 1800000,  // 30 minutos
                                configureSocket: (socket) =>
                                {
                                    // MEJORA #48: TCP Keep-Alive nativo (como Nicotine+)
                                    // Más eficiente que búsquedas ficticias, transparente para el servidor
                                    try
                                    {
                                        socket.SetSocketOption(SocketOptionLevel.Socket, SocketOptionName.KeepAlive, true);
                                        
                                        // Windows: Configurar tiempos de keep-alive
                                        // keepAliveValues: [onoff (1), keepalivetime (60000ms), keepaliveinterval (10000ms)]
                                        byte[] keepAliveValues = new byte[12];
                                        BitConverter.GetBytes(1).CopyTo(keepAliveValues, 0);      // Enable
                                        BitConverter.GetBytes(60000).CopyTo(keepAliveValues, 4);  // 60 segundos idle
                                        BitConverter.GetBytes(10000).CopyTo(keepAliveValues, 8);  // 10 segundos interval
                                        socket.IOControl(IOControlCode.KeepAliveValues, keepAliveValues, null);
                                        
                                        Log("   ✅ TCP Keep-Alive nativo habilitado (60s idle, 10s interval)");
                                    }
                                    catch (Exception ex)
                                    {
                                        Log($"   ⚠️ No se pudo configurar TCP Keep-Alive: {ex.Message}");
                                    }
                                }
                            ),
                            // MEJORA: Opciones de transferencia más conservadoras para evitar desconexiones
                            transferConnectionOptions: new ConnectionOptions(
                                connectTimeout: 20000,  // 20 segundos timeout para transferencias
                                inactivityTimeout: 60000  // 60 segundos inactividad (reducido de default)
                            ),
                            userEndPointCache: null,
                            maximumConcurrentUploads: Math.Max(1, maxConcurrentUploads),
                            maximumUploadSpeed: maxUploadSpeedKib > 0 ? maxUploadSpeedKib : int.MaxValue,
                            enqueueDownload: OnEnqueueDownload,
                            placeInQueueResolver: OnPlaceInQueueResolver,
                            browseResponseResolver: BrowseResponseResolver,
                            directoryContentsResolver: DirectoryContentsResponseResolver,
                            userInfoResolver: UserInfoResolver,
                            searchResponseResolver: SearchResponseResolver
                        );
                        
                        client = new SoulseekClient(options);
                        Log($"   Cliente creado, suscribiendo eventos...");
                        
                        // INTEGRACIÓN MULTI-RED: Inicializar orquestador
                        InitializeNetworkOrchestrator();
                        
                        // Suscribirse al evento de desconexión para auto-reconexión
                        client.Disconnected += async (sender, args) =>
                        {
                            Log($"⚠️ Desconexión detectada: {args.Message} (isConnecting={isConnecting})");
                            
                            // Si estamos en proceso de conexión inicial, solo loggear y salir
                            // (ConnectToSoulseek manejará el error)
                            if (isConnecting)
                            {
                                Log($"⚠️ Desconexión durante conexión inicial - dejando que ConnectToSoulseek maneje el error");
                                return;
                            }
                            
                            AutoLog($"🔴 DESCONECTADO DE SOULSEEK - Razón: {args.Message}");
                            
                            // MEJORA NICOTINE+: Publicar evento de desconexión
                            _eventBus?.Publish(SlskDown.Core.SystemEvents.ServerDisconnect, new { Reason = args.Message });
                            
                            // Notificación toast de desconexión
                            SafeInvoke(() => ToastManager.Show(
                                "Desconectado",
                                $"Razón: {args.Message}\nIntentando reconectar...",
                                ToastType.Warning,
                                4000
                            ));
                            
                            // Detener keep-alive timer
                            StopKeepAliveTimer();
                            
                            // MEJORA #1: Detener Health Check Service
                            try
                            {
                                healthCheckService?.Stop();
                                Log("⏸️ Health Check Service detenido por desconexión");
                            }
                            catch (Exception hcEx)
                            {
                                Log($"⚠️ Error deteniendo Health Check Service: {hcEx.Message}");
                            }

                            // Registrar desconexión para lógica anti-ráfagas de purga (ventana 30m)
                            try
                            {
                                var nowDisc = DateTime.UtcNow;
                                disconnectEvents.Enqueue(nowDisc);
                                while (disconnectEvents.Count > 0 && (nowDisc - disconnectEvents.Peek()).TotalMinutes > 30)
                                    disconnectEvents.Dequeue();
                            }
                            catch (Exception ex) { AutoLog($"⚠️ Error procesando eventos de desconexión: {ex.Message}"); }
                            
                            // DETECTAR SI ES POR USO EXCESIVO Y PAUSAR PURGA EXTENDIDA
                            bool isExcessiveUse = args.Message.Contains("Remote connection closed") || 
                                                 args.Message.Contains("Read error") ||
                                                 args.Message.Contains("Connection lost");
                            
                            // Registrar desconexión limpia del servidor
                            if (args.Message.Contains("Remote connection closed"))
                            {
                                lastCleanDisconnect = DateTime.UtcNow;
                                Log($"📊 Desconexión limpia registrada a las {DateTime.Now:HH:mm:ss}");
                            }
                            
                            if (isExcessiveUse && autoPurgeRunning)
                            {
                                AutoLog("🚫 Desconexión por posible uso excesivo detectada");
                                AutoLog("⏸️ PAUSANDO PURGA POR 15 MINUTOS PARA EVITAR BLOQUEO...");
                                
                                // Pausar extendida para evitar bloqueo inmediato al reconectar
                                autoPurgePausedByExcessiveUse = true;
                                autoPurgePausedByDisconnection = true;
                                excessiveUsePauseTime = DateTime.UtcNow;
                                // Aplicar cooldown anti-bloqueo
                                ApplyBanCooldown(args.Message ?? "Desconexión por uso excesivo");
                            }
                            else
                            {
                                // PAUSAR NORMALMENTE TODOS LOS PROCESOS
                                AutoLog("⏸️ PAUSANDO TODOS LOS PROCESOS...");
                            }
                            
                            // 1. Pausar búsquedas automáticas
                            if (autoSearchRunning)
                            {
                                autoSearchPausedByDisconnection = true;
                                LogEx(LogLevel.WARN, LogCategory.BUSQUEDA, "⏸️  [PAUSADA] Búsqueda automática por desconexión");
                            }
                            
                            // 2. Pausar purga automática
                            if (autoPurgeRunning)
                            {
                                autoPurgePausedByDisconnection = true;
                                autoPurgeNeedsRestart = true;
                                LogEx(LogLevel.WARN, LogCategory.PURGA, "⏸️  [PAUSADA] Purga automática por desconexión");
                            }
                            
                            // MEJORA FASE 1.3: ReadLock para Any + Count
                            (bool hasActive, int activeDownloads) = ReadLocked(downloadQueueLock, () =>
                            {
                                bool hasActiveDownloads = downloadQueue.Any(t => t.Status == DownloadStatus.Downloading || t.Status == DownloadStatus.Queued);
                                int active = hasActiveDownloads ? downloadQueue.Count(t => t.Status == DownloadStatus.Downloading) : 0;
                                return (hasActiveDownloads, active);
                            });
                            
                            if (hasActive)
                            {
                                downloadsPausedByDisconnection = true;
                                
                                // MEJORA: Logging detallado del estado
                                int queuedCount = ReadLocked(downloadQueueLock, () =>
                                    downloadQueue.Count(t => t.Status == DownloadStatus.Queued));
                                
                                LogEx(LogLevel.WARN, LogCategory.DESCARGA, 
                                    $"⏸️  [PAUSADAS] {activeDownloads} activas, {queuedCount} en cola - Desconexión detectada");
                                
                                // MEJORA: Guardar checkpoint inmediatamente para no perder progreso
                                _ = Task.Run(async () =>
                                {
                                    try
                                    {
                                        await downloadManager?.SaveQueueAsync();
                                        LogEx(LogLevel.INFO, LogCategory.DESCARGA, 
                                            $"💾 Checkpoint guardado: {activeDownloads + queuedCount} descargas preservadas");
                                    }
                                    catch (Exception ex)
                                    {
                                        LogEx(LogLevel.ERROR, LogCategory.DESCARGA, $"❌ Error guardando checkpoint: {ex.Message}");
                                    }
                                });
                            }
                            
                            // AUTO-THROTTLING: Detectar desconexiones frecuentes y reducir concurrencia
                            var timeSinceLastDisconnect = DateTime.Now - lastDisconnectionTime;
                            if (timeSinceLastDisconnect.TotalMinutes < 5) // Desconexiones en menos de 5 minutos
                            {
                                consecutiveDisconnections++;
                                
                                if (consecutiveDisconnections >= 2 && !autoThrottlingActive)
                                {
                                    autoThrottlingActive = true;
                                    originalMaxSimultaneousDownloads = maxSimultaneousDownloads;
                                    maxSimultaneousDownloads = 1; // Reducir a 1 descarga simultánea
                                    AutoLog($"⚠️ AUTO-THROTTLING ACTIVADO: Reduciendo a {maxSimultaneousDownloads} descarga simultánea por desconexiones frecuentes");
                                    AutoLog($"💡 Se restaurará automáticamente después de 10 minutos sin desconexiones");
                                }
                                else if (consecutiveDisconnections >= 3)
                                {
                                    AutoLog($"🔴 ADVERTENCIA: {consecutiveDisconnections} desconexiones consecutivas detectadas");
                                    AutoLog($"💡 Considera reducir manualmente las descargas simultáneas en Configuración");
                                }
                            }
                            else
                            {
                                // Reset si han pasado más de 5 minutos desde la última desconexión
                                consecutiveDisconnections = 1;
                            }
                            
                            lastDisconnectionTime = DateTime.Now;
                            
                            SafeBeginInvoke(() =>
                            {
                                lblStatus.Text = "Desconectado";
                                lblStatus.ForeColor = Color.Red;
                            });
                            
                            // LIMPIEZA EXHAUSTIVA INSPIRADA EN NICOTINE+
                            await PerformExhaustiveDisconnectionCleanup();
                            
                            // Activar auto-reconexión si está habilitada
                            Log($"[DEBUG] autoReconnect={autoReconnect}, isReconnecting={isReconnecting}");
                            if (autoReconnect && !isReconnecting)
                            {
                                // Respetar cooldown por posible bloqueo
                                if (DateTime.UtcNow < banCooldownUntil)
                                {
                                    var wait = banCooldownUntil - DateTime.UtcNow;
                                    Log($"⏳ Reconexión aplazada por posible bloqueo: {wait.TotalMinutes:F0} min restantes");
                                }
                                else
                                {
                                    AutoLog("🔄 Iniciando auto-reconexión en 2 segundos...");
                                    await Task.Delay(2000).ConfigureAwait(false); // MEJORA #37
                                    Log("🔄 Llamando a CheckAndReconnect()...");
                                    // MEJORA #26: Eliminar Task.Run redundante
                                    _ = CheckAndReconnect();
                                }
                            }
                            else if (!autoReconnect)
                            {
                                Log("⚠️ Auto-reconexión deshabilitada");
                            }
                            else if (isReconnecting)
                            {
                                Log("⚠️ Ya hay una reconexión en curso");
                            }
                        };
                        
                        // MEJORA PROTOCOLO SOULSEEK: Suscribirse a eventos del protocolo oficial
                        Log($"   📋 Configurando handlers de protocolo Soulseek...");
                        
                        // MEJORA #1: Excluded Search Phrases (CRÍTICO - Compliance)
                        // Suscribirse al evento para recibir frases prohibidas del servidor
                        try {
                            // Intentar suscribirse al evento si existe en Soulseek.NET
                            var eventInfo = client.GetType().GetEvent("ExcludedSearchPhrasesReceived");
                            if (eventInfo != null) {
                                EventHandler<IReadOnlyCollection<string>> handler = (sender, phrases) => {
                                    _excludedPhrases.Clear();
                                    foreach (var phrase in phrases) {
                                        _excludedPhrases.Add(phrase);
                                    }
                                    LogEx(LogLevel.WARN, LogCategory.SISTEMA, $"📋 Frases prohibidas actualizadas: {phrases.Count} frases");
                                    LogEx(LogLevel.INFO, LogCategory.SISTEMA, $"   💡 Los resultados con estas frases serán filtrados automáticamente");
                                };
                                eventInfo.AddEventHandler(client, handler);
                                Log($"   ✅ Suscrito a ExcludedSearchPhrasesReceived");
                            } else {
                                Log($"   ⚠️ ExcludedSearchPhrasesReceived no disponible en esta versión de Soulseek.NET");
                            }
                        } catch (Exception exEvent) {
                            Log($"   ⚠️ Error suscribiendo a eventos: {exEvent.Message}");
                        }
                        
                        Log($"   ⏱️ WishlistSearch: Intervalo default {_wishlistInterval}s ({_wishlistInterval/60}min)");
                        Log($"   🚫 ExcludedPhrases: {_excludedPhrases.Count} frases prohibidas cargadas");
                        Log($"   🎨 Recommendations: Sistema listo para recibir recomendaciones");
                        
                        // Diagnóstico de red antes de conectar
                        Log($"   🔍 Diagnóstico de red:");
                        Log($"   🌐 Resolviendo DNS: server.slsknet.org...");
                        tcpWorked = false; // Resetear para este intento
                        string resolvedIp = "desconocida";
                        try
                        {
                            // Resolver DNS primero
                            var dnsStart = DateTime.Now;
                            var addresses = await System.Net.Dns.GetHostAddressesAsync("server.slsknet.org");
                            var dnsTime = (DateTime.Now - dnsStart).TotalMilliseconds;
                            if (addresses.Length > 0)
                            {
                                resolvedIp = addresses[0].ToString();
                                Log($"   ✅ DNS resuelto en {dnsTime:F0}ms → {resolvedIp}");
                            }
                            else
                            {
                                Log($"   ⚠️ DNS no devolvió direcciones");
                            }
                            
                            // Probar conexión TCP
                            Log($"   🔌 Probando conexión TCP a {resolvedIp}:2242...");
                            using (var tcpClient = new System.Net.Sockets.TcpClient())
                            {
                                var tcpStart = DateTime.Now;
                                var connectTask = tcpClient.ConnectAsync("server.slsknet.org", 2242);
                                if (await Task.WhenAny(connectTask, Task.Delay(3000)) == connectTask)
                                {
                                    var tcpTime = (DateTime.Now - tcpStart).TotalMilliseconds;
                                    if (tcpClient.Connected)
                                    {
                                        tcpWorked = true;
                                        Log($"   ✅ Puerto 2242 accesible en {tcpTime:F0}ms (TCP handshake exitoso)");
                                        
                                        // Información adicional del socket
                                        var localEp = tcpClient.Client.LocalEndPoint?.ToString() ?? "desconocido";
                                        var remoteEp = tcpClient.Client.RemoteEndPoint?.ToString() ?? "desconocido";
                                        Log($"   📊 Local: {localEp} → Remoto: {remoteEp}");
                                    }
                                    else
                                    {
                                        Log($"   ❌ Puerto 2242 rechazado después de {tcpTime:F0}ms (TCP handshake fallido)");
                                    }
                                }
                                else
                                {
                                    Log($"   ⚠️ Puerto 2242 timeout después de 3s (posible firewall)");
                                }
                            }
                        }
                        catch (System.Net.Sockets.SocketException sockEx)
                        {
                            Log($"   ❌ Error de socket: {sockEx.SocketErrorCode} - {sockEx.Message}");
                        }
                        catch (Exception diagEx)
                        {
                            Log($"   ❌ Error en diagnóstico: {diagEx.GetType().Name} - {diagEx.Message}");
                        }
                        
                        if (tcpWorked && attempt > 1)
                        {
                            Log($"   💡 TCP funciona pero Soulseek timeout - posible bloqueo temporal del servidor");
                            Log($"   💡 Esperando más tiempo entre reintentos para evitar bloqueo de IP...");
                            
                            // MEJORA #1: Detección temprana de bloqueo (4 timeouts en lugar de 7)
                            if (consecutiveTimeouts >= 4)
                            {
                                Log($"🚨 PATRÓN DE BLOQUEO DETECTADO - {consecutiveTimeouts} timeouts con TCP funcionando");
                                Log($"⏸️ PAUSA PREVENTIVA: 10 minutos para evitar bloqueo completo");
                                
                                // MEJORA #2: Registrar evento de bloqueo preventivo
                                RecordBlockEvent();
                                
                                // CRÍTICO: Resetear AMBOS flags antes de pausa preventiva
                                lock (this)
                                {
                                    isConnecting = false;
                                    isReconnecting = false;
                                    Log($"[DEBUG] isConnecting e isReconnecting reseteados antes de pausa preventiva (10 min)");
                                }
                                
                                await DelayWithCancellation(TimeSpan.FromMinutes(10), appCts?.Token ?? CancellationToken.None);
                                
                                lock (this)
                                {
                                    isConnecting = true;
                                    Log($"[DEBUG] isConnecting establecido a true después de pausa preventiva");
                                }
                                
                                consecutiveTimeouts = 0;
                                Log($"✅ Pausa preventiva finalizada - reintentando con contador reseteado");
                            }
                            else if (consecutiveTimeouts >= 2)
                            {
                                Log($"🚨 POSIBLE BLOQUEO: {consecutiveTimeouts} timeouts consecutivos con TCP funcionando");
                            }
                        }
                        else if (!tcpWorked)
                        {
                            // Si TCP no funciona, saltar intento de Soulseek y aplicar backoff conservador
                            consecutiveTimeouts = 0;
                            var delaySeconds = GetBackoffDelaySeconds(attempt);
                            var recommended = GetRecommendedCooldownSeconds();
                            if (recommended > 0)
                            {
                                var recInt = (int)Math.Ceiling(recommended);
                                if (recInt > delaySeconds) delaySeconds = recInt;
                            }
                            var delay = TimeSpan.FromSeconds(delaySeconds);
                            var jitter = GetJitter(delay);
                            var totalDelay = delay + jitter;
                            nextAllowedConnectAttempt = DateTime.UtcNow + totalDelay;
                            Log($"   ❌ Puerto 2242 inaccesible. Saltando intento de login y esperando {totalDelay.TotalSeconds:F0}s...");
                            SafeBeginInvoke(() =>
                            {
                                var recText = recommended > 0 ? $" (recomendado: {Math.Ceiling(recommended)}s)" : string.Empty;
                                if (lblStatus != null)
                                {
                                    lblStatus.Text = $"Conexión TCP fallida. Reintentando en {delaySeconds}s{recText}...";
                                    lblStatus.ForeColor = Color.Orange;
                                }
                            });
                            
                            // CRÍTICO: Resetear isConnecting antes de espera larga
                            lock (this)
                            {
                                isConnecting = false;
                                Log($"[DEBUG] isConnecting reseteado a false antes de espera TCP de {totalDelay.TotalSeconds:F0}s");
                            }
                            
                            await DelayWithCancellation(totalDelay, appCts?.Token ?? CancellationToken.None);
                            
                            // Restablecer isConnecting para siguiente intento
                            lock (this)
                            {
                                isConnecting = true;
                                Log($"[DEBUG] isConnecting establecido a true después de espera TCP");
                            }
                            
                            continue;
                        }
                        
                        Log($"   📡 Iniciando ConnectAsync (timeout interno Soulseek.NET: ~5s)...");
                        Log($"   🔑 Usuario: {username} | Puerto local: {selectedPort}");
                        Log($"   🌐 Servidor: server.slsknet.org:2242");
                        var connectStart = DateTime.Now;
                        
                        // Nota: Soulseek.NET tiene un timeout interno hardcodeado de ~5 segundos
                        // Estrategia: fast-retry inmediato si el primer intento expira, antes del backoff largo
                        // IMPORTANTE: Si TCP funciona pero Soulseek timeout, NO hacer fast retries (rate limiting del servidor)
                        bool connectionSucceeded = false;
                        Exception lastException = null;
                        int maxFastRetries = tcpWorked ? 0 : 2; // Si TCP funciona, solo 1 intento (no retries)
                        
                        if (tcpWorked)
                        {
                            Log($"   🛡️ TCP funciona - deshabilitando fast retries para evitar rate limiting del servidor");
                        }
                        
                        for (int fastRetry = 0; fastRetry <= maxFastRetries && !connectionSucceeded; fastRetry++)
                        {
                            try
                            {
                                if (fastRetry > 0)
                                {
                                    Log($"⏱️ Fast retry {fastRetry}/3 después de {(fastRetry * 2)}s...");
                                    await Task.Delay(2000).ConfigureAwait(false);
                                }
                                
                                Log($"   🔌 Intentando handshake Soulseek (retry {fastRetry + 1}/3)...");
                                Log($"   📊 Estado del cliente antes: {client?.State}");
                                Log($"   📊 Username length: {username?.Length ?? 0}, Password length: {password?.Length ?? 0}");
                                var handshakeStart = DateTime.Now;
                                
                                using (var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15)))
                                {
                                    try
                                    {
                                        await client.ConnectAsync(username, password, cts.Token);
                                    }
                                    catch (Exception connEx)
                                    {
                                        Log($"   ❌ ConnectAsync lanzó excepción: {connEx.GetType().Name}");
                                        Log($"   📊 Mensaje: {connEx.Message}");
                                        if (connEx.InnerException != null)
                                        {
                                            Log($"   📊 Inner: {connEx.InnerException.GetType().Name} - {connEx.InnerException.Message}");
                                        }
                                        throw;
                                    }
                                }
                                
                                var handshakeDuration = (DateTime.Now - handshakeStart).TotalSeconds;
                                Log($"   ✅ Handshake exitoso en {handshakeDuration:F2}s");
                                Log($"   📊 Estado del cliente después: {client?.State}");
                                connectionSucceeded = true;
                            }
                            catch (TimeoutException ex)
                            {
                                var elapsed = (DateTime.Now - connectStart).TotalSeconds;
                                lastException = ex;
                                Log($"   ⏱️ Timeout en handshake después de {elapsed:F2}s");
                                Log($"   📊 Detalles: {ex.Message}");
                                if (fastRetry < 2)
                                {
                                    Log($"   🔄 Preparando fast retry {fastRetry + 2}/3...");
                                }
                                else
                                {
                                    Log($"   ❌ Todos los fast retries agotados");
                                }
                            }
                            catch (InvalidOperationException ex) when (ex.Message.Contains("already connected", StringComparison.OrdinalIgnoreCase))
                            {
                                Log("   ℹ️ ConnectAsync indicó que el cliente ya estaba conectado");
                                Log($"   📊 Mensaje: {ex.Message}");
                                connectionSucceeded = client?.State.HasFlag(SoulseekClientStates.Connected) == true;
                                if (!connectionSucceeded)
                                {
                                    throw;
                                }
                            }
                            catch (Exception ex)
                            {
                                var elapsed = (DateTime.Now - connectStart).TotalSeconds;
                                lastException = ex;
                                Log($"   ❌ Error en handshake después de {elapsed:F2}s: {ex.GetType().Name}");
                                Log($"   📊 Mensaje: {ex.Message}");
                                if (ex.InnerException != null)
                                {
                                    Log($"   📊 Inner: {ex.InnerException.Message}");
                                }
                                break; // No reintentar en errores no-timeout
                            }
                        }
                        
                        if (!connectionSucceeded && lastException != null)
                        {
                            throw lastException;
                        }
                        
                        var connectDuration = (DateTime.Now - connectStart).TotalSeconds;
                        Log($"   ✅ ConnectAsync completado en {connectDuration:F1}s (incluyendo retries)");
                        Log($"   📊 Estado del cliente: Connected={client?.State == SoulseekClientStates.Connected}");
                        
                        Log($"✅ Conexión exitosa en puerto {selectedPort}");
                        Log($"   📊 Tiempo total de conexión: {connectDuration:F1}s");
                        Log($"   📊 Fast retries usados: {(connectionSucceeded ? "exitoso" : "fallido")}");
                        AutoLog($"✅ CONECTADO A SOULSEEK - Usuario: {username}");
                        RecordCooldownFromLastFailure(DateTime.UtcNow);
                        
                        // MEJORA NICOTINE+: Publicar evento de conexión
                        _eventBus?.Publish(SlskDown.Core.SystemEvents.ServerLogin, new { Username = username, Port = randomPort });
                        
                        // Notificación toast de conexión exitosa
                        SafeInvoke(() => ToastManager.Show(
                            "Conectado",
                            $"Usuario: {username}\nPuerto: {randomPort}",
                            ToastType.Success,
                            3000
                        ));
                        
                        // Reset contador de timeouts en conexión exitosa
                        consecutiveTimeouts = 0;
                        
                        // ACTUALIZAR HEALTH SCORE después de conexión exitosa
                        UpdateConnectionHealthScore();
                        
                        // MEJORA #1: Inicializar Health Check Service
                        try
                        {
                            healthCheckService?.Dispose(); // Limpiar instancia anterior si existe
                            healthCheckService = new HealthCheckService(
                                client,
                                AutoLog,
                                async () => await CheckAndReconnect()
                            );
                            healthCheckService.Start();
                            Log("✅ Health Check Service iniciado");
                        }
                        catch (Exception hcEx)
                        {
                            Log($"⚠️ Error iniciando Health Check Service: {hcEx.Message}");
                        }
                        
                        // MEJORA: Inicializar servicio de notificaciones
                        try
                        {
                            if (notificationService == null)
                            {
                                notificationService = new SlskDown.Core.NotificationService(this, this.Icon);
                                Log("✅ Notification Service iniciado");
                            }
                        }
                        catch (Exception notifEx)
                        {
                            Log($"⚠️ Error iniciando Notification Service: {notifEx.Message}");
                        }
                        
                        // POOL DE CONEXIONES: Agregar cliente exitoso al pool
                        if (client != null && clientPool.Count < maxPoolSize)
                        {
                            clientPool.Add(client);
                            Log($"📦 Cliente agregado al pool ({clientPool.Count}/{maxPoolSize})");
                        }
                        
                        UpdateControlText(btnConnect, "Desconectar");
                        UpdateControlEnabled(btnConnect, true);
                        UpdateControlEnabled(btnSearch, true);
                        UpdateNetworkStatusLabel();
                        
                        connected = true;
                        
                        // Modo Stealth: Warm-up gradual
                        // MEJORA #26: Eliminar Task.Run redundante
                        _ = StealthWarmup();
                        
                        // FIX: Reactivar keep-alive timer porque Auto-Tuner actualiza lastActivityTime
                        // cada 30s, lo que impide que TCP Keep-Alive nativo se active (solo funciona sin tráfico)
                        // CRÍTICO: Debe ejecutarse en UI thread
                        SafeInvoke(() => StartKeepAliveTimer());
                        Log("✅ Keep-alive timer activado (necesario con Auto-Tuner activo)");
                        
                        // REANUDAR PROCESOS 5 SEGUNDOS DESPUÉS DE RECONECTAR
                        if (autoSearchPausedByDisconnection || autoPurgePausedByDisconnection || downloadsPausedByDisconnection)
                        {
                            LogEx(LogLevel.INFO, LogCategory.CONEXION, "Esperando 5 segundos antes de reanudar procesos...");
                            _ = Task.Run(async () =>
                            {
                                await Task.Delay(5000).ConfigureAwait(false); // MEJORA #37
                                
                                // Verificar que sigue conectado
                                if (client != null && (client.State.HasFlag(SoulseekClientStates.Connected) || client.State.HasFlag(SoulseekClientStates.LoggedIn)))
                                {
                                    LogEx(LogLevel.SUCCESS, LogCategory.SISTEMA, "═══════════════════════════════════════════════════");
                                    LogEx(LogLevel.SUCCESS, LogCategory.SISTEMA, "▶️  REANUDANDO PROCESOS TRAS CONEXIÓN INICIAL");
                                    LogEx(LogLevel.SUCCESS, LogCategory.SISTEMA, "═══════════════════════════════════════════════════");
                                    
                                    int tasksResumed = 0;
                                    
                                    // 1. Reanudar búsquedas automáticas
                                    if (autoSearchPausedByDisconnection)
                                    {
                                        autoSearchPausedByDisconnection = false;
                                        tasksResumed++;
                                        LogEx(LogLevel.SUCCESS, LogCategory.BUSQUEDA, "▶️  [REANUDADA] Búsqueda automática");
                                    }
                                    
                                    // 2. Reanudar purga automática
                                    if (autoPurgePausedByDisconnection)
                                    {
                                        autoPurgePausedByDisconnection = false;
                                        tasksResumed++;
                                        LogEx(LogLevel.SUCCESS, LogCategory.PURGA, "▶️  [REANUDADA] Purga automática");
                                        if (autoPurgeNeedsRestart && !autoPurgeRunning)
                                        {
                                            autoPurgeNeedsRestart = false;
                                            LogEx(LogLevel.INFO, LogCategory.PURGA, "🔁 [REINICIANDO] Purga automática desde el principio...");
                                            // MEJORA #26: Eliminar Task.Run redundante
                                            _ = PurgeAuthorsWithoutResults();
                                        }
                                    }
                                    
                                    // 3. Reanudar descargas
                                    if (downloadsPausedByDisconnection)
                                    {
                                        downloadsPausedByDisconnection = false;
                                        tasksResumed++;
                                        
                                        // MEJORA FASE 1.3: ReadLock para Count
                                        int pendingDownloads = ReadLocked(downloadQueueLock, () =>
                                            downloadQueue.Count(t => 
                                                t.Status == DownloadStatus.Queued || 
                                                t.Status == DownloadStatus.Downloading ||
                                                t.Status == DownloadStatus.Paused));
                                        
                                        LogEx(LogLevel.SUCCESS, LogCategory.DESCARGA, $"▶️  [REANUDADAS] Descargas ({pendingDownloads} pendientes en cola)");
                                    }
                                    
                                    LogEx(LogLevel.SUCCESS, LogCategory.SISTEMA, $"═══════════════════════════════════════════════════");
                                    LogEx(LogLevel.SUCCESS, LogCategory.SISTEMA, $"✅ Total de procesos reanudados: {tasksResumed}");
                                    LogEx(LogLevel.SUCCESS, LogCategory.SISTEMA, "═══════════════════════════════════════════════════");
                                }
                                else
                                {
                                    LogEx(LogLevel.ERROR, LogCategory.CONEXION, "No se reanudaron procesos: conexión perdida");
                                }
                            });
                        }
                    }
                    catch (Exception ex)
                    {
                        Log($"❌ Excepción capturada: Tipo={ex.GetType().Name}, Mensaje={ex.Message}");
                        if (ex.InnerException != null)
                        {
                            Log($"   InnerException: {ex.InnerException.GetType().Name} - {ex.InnerException.Message}");
                        }
                        Log($"   StackTrace:\n{ex}");
                        
                        // Dispose completo del cliente y liberación de recursos
                        if (client != null)
                        {
                            try
                            {
                                // Desuscribir eventos para evitar memory leaks
                                client.Disconnected -= null;
                                client.StateChanged -= null;
                                client.PrivateMessageReceived -= null;
                                client.RoomMessageReceived -= null;
                                client.DistributedNetworkStateChanged -= null;
                                client.BrowseProgressUpdated -= null;
                                client.TransferProgressUpdated -= null;
                                
                                // Forzar liberación de recursos
                                client.Dispose();
                                client = null;
                                
                                // MEJORA NICOTINE+: Usar GCHelper para gestión explícita del GC
                                GCHelper.ForceCollect("Reset total - liberación de recursos del cliente");
                                
                                Log($"🧹 Recursos del cliente liberados y GC forzado");
                            }
                            catch (Exception disposeEx)
                            {
                                Log($"⚠️ Error durante dispose del cliente: {disposeEx.Message}");
                                client = null;
                            }
                        }
                        
                        if (attempt < maxAttempts)
                        {
                            Log($"❌ Intento {attempt} falló: {ex.GetType().Name}");
                            Log($"   📊 Mensaje: {ex.Message}");
                            if (ex.InnerException != null)
                            {
                                Log($"   📊 Inner Exception: {ex.InnerException.GetType().Name} - {ex.InnerException.Message}");
                            }
                            Log($"   📊 Timeouts consecutivos: {consecutiveTimeouts}");
                            Log($"   📊 TCP funcionó: {tcpWorked}");

                        // Errores que no deben reintentarse
                        if (ex.Message.Contains("Invalid credentials") || 
                            ex.Message.Contains("Login failed") ||
                            ex.Message.Contains("Invalid username") ||
                            ex.Message.Contains("Invalid password"))
                        {
                            Log("⚠️ Error de autenticación - no se reintentará");
                            UpdateControlText(lblStatus, "Error de autenticación");
                            UpdateControl(lblStatus, c => c.ForeColor = Color.Red);
                            throw;
                        }

                        // Timeout o error de red - reintentar con backoff adaptativo
                        if (lastFailureTime == DateTime.MinValue) lastFailureTime = DateTime.UtcNow;
                        var delaySeconds = GetBackoffDelaySeconds(attempt);
                        var recommended = GetRecommendedCooldownSeconds();
                        if (recommended > 0)
                        {
                            var recInt = (int)Math.Ceiling(recommended);
                            if (recInt > delaySeconds) delaySeconds = recInt;
                        }
                        var isTimeoutException = ex is TimeoutException ||
                            ex.InnerException is TimeoutException ||
                            ex.Message.Contains("timed out", StringComparison.OrdinalIgnoreCase);

                        if (isTimeoutException)
                        {
                            consecutiveTimeouts = Math.Min(consecutiveTimeouts + 1, 10);
                            lastConnectionIssue = DateTime.UtcNow;
                            
                            // DETECCIÓN: Reconexión después de desconexión limpia del servidor
                            var timeSinceCleanDisconnect = DateTime.UtcNow - lastCleanDisconnect;
                            bool isReconnectAfterCleanDisconnect = timeSinceCleanDisconnect.TotalSeconds < 30;
                            
                            if (isReconnectAfterCleanDisconnect && attempt == 1)
                            {
                                // El servidor cerró la conexión y ahora nos bloquea temporalmente
                                delaySeconds = Math.Max(delaySeconds, 120); // Mínimo 2 minutos
                                Log($"🔄 Reconexión después de desconexión limpia detectada");
                                Log($"⏱️ Aplicando delay extendido de {delaySeconds}s para evitar rate limiting");
                                Log($"💡 El servidor Soulseek suele bloquear reconexiones inmediatas después de cerrar la conexión");
                            }
                            // OPTIMIZACIÓN: Si TCP funciona, reducir delay (es congestión, no bloqueo)
                            else if (tcpWorked && delaySeconds > 15 && !isReconnectAfterCleanDisconnect)
                            {
                                delaySeconds = Math.Min(delaySeconds, 15);
                                Log($"ℹ️ TCP funciona - reduciendo delay a {delaySeconds}s (congestión temporal)");
                            }
                            
                            // OPTIMIZACIÓN: Si acabamos de esperar un cooldown largo, no aplicar otro
                            var timeSinceLastCooldown = DateTime.UtcNow - lastAntiBlockCooldown;
                            bool justFinishedCooldown = timeSinceLastCooldown.TotalMinutes < 5;
                            
                            // CIRCUIT BREAKER: Incrementar contador de fallos (pero no si acabamos de terminar cooldown)
                            if (!justFinishedCooldown)
                            {
                                circuitFailureCount++;
                                if (circuitFailureCount >= circuitFailureThreshold)
                                {
                                    connectionCircuit = CircuitState.Open;
                                    circuitOpenTime = DateTime.UtcNow;
                                    Log($"🚫 CIRCUIT BREAKER ABIERTO - {circuitFailureCount} fallos consecutivos");
                                    Log($"⏳ Circuit breaker abierto por {circuitOpenDuration.TotalMinutes} minutos");
                                    throw new InvalidOperationException($"Circuit breaker abierto por {circuitOpenDuration.TotalMinutes} minutos");
                                }
                            }
                            else
                            {
                                Log($"ℹ️ Timeout después de cooldown - no incrementando circuit breaker");
                            }
                            
                            // ACTIVAR MODO CONSERVADOR TRAS PRIMER TIMEOUT
                            if (!conservativeMode && consecutiveTimeouts >= 1)
                            {
                                conservativeMode = true;
                                AutoLog("🛡️ MODO CONSERVADOR ACTIVADO - reduciendo agresividad de purga");
                            }
                            
                            // SUGERENCIA: Si TCP funciona pero Soulseek timeout, puede ser bloqueo de cuenta
                            if (tcpWorked && consecutiveTimeouts >= 3)
                            {
                                Log("⚠️ ═══════════════════════════════════════════════════════════");
                                Log("⚠️ POSIBLE PROBLEMA DE CUENTA O BLOQUEO DEL SERVIDOR");
                                Log("⚠️ ═══════════════════════════════════════════════════════════");
                                Log("⚠️ TCP funciona correctamente pero el handshake Soulseek falla");
                                Log("⚠️ ");
                                Log("⚠️ Posibles causas:");
                                Log("⚠️ 1. Credenciales incorrectas (usuario/contraseña)");
                                Log("⚠️ 2. Cuenta suspendida o bloqueada por el servidor");
                                Log("⚠️ 3. Demasiados intentos de conexión desde esta IP");
                                Log("⚠️ 4. Servidor Soulseek en mantenimiento");
                                Log("⚠️ ");
                                Log("⚠️ Recomendaciones:");
                                Log("⚠️ - Verifica tus credenciales en la pestaña Configuración");
                                Log("⚠️ - Intenta conectar con el cliente oficial de Soulseek");
                                Log("⚠️ - Espera 15-30 minutos antes de reintentar");
                                Log("⚠️ ═══════════════════════════════════════════════════════════");
                            }
                            
                            // DETECCIÓN DE VENTANA DE BLOQUEO DEL SERVIDOR (solo si no acabamos de terminar cooldown)
                            // Aumentado de 3 a 6 para evitar falsos positivos cuando el servidor está sobrecargado
                            if (consecutiveTimeouts >= 6 && !justFinishedCooldown)
                            {
                                Log($"🚫 VENTANA DE BLOQUEO DETECTADA - {consecutiveTimeouts} timeouts consecutivos");
                                Log($"⏳ El servidor Soulseek ha bloqueado temporalmente esta IP");
                                Log($"🕐 Esperando 15 minutos para que se levante el bloqueo...");
                                
                                // MEJORA #2: Registrar evento de bloqueo para aprendizaje
                                RecordBlockEvent();
                                
                                // CRÍTICO: Resetear AMBOS flags antes de espera de 15 minutos
                                // Esto permite que el timer de reconexión funcione normalmente durante la espera
                                lock (this)
                            {
                                isConnecting = false;
                                isReconnecting = false;
                                isReconnectCoolingDown = true;
                                Log($"[DEBUG] Flags reseteados antes de espera de bloqueo (15 min)");
                            }
                            
                            // Esperar ventana de desbloqueo (15 minutos) de forma cancelable
                            await DelayWithCancellation(TimeSpan.FromMinutes(15), appCts?.Token ?? CancellationToken.None);
                            
                            lock (this)
                            {
                                isReconnectCoolingDown = false;
                                isConnecting = true;
                                Log($"[DEBUG] isConnecting restablecido tras espera de bloqueo");
                            }
                            
                            // Resetear contador después de esperar
                            consecutiveTimeouts = 0;
                            lastAntiBlockCooldown = DateTime.UtcNow;
                            Log($"✅ Ventana de bloqueo finalizada - reintentando conexión");
                            }
                            else if (justFinishedCooldown)
                            {
                                Log($"ℹ️ Timeout después de cooldown de {timeSinceLastCooldown.TotalMinutes:F1}m - usando delay reducido");
                                // Usar delay mínimo si acabamos de terminar un cooldown
                                delaySeconds = Math.Min(delaySeconds, 30);
                            }
                            
                            // Aplicar penalty solo si no acabamos de terminar cooldown
                            if (!justFinishedCooldown)
                            {
                                var timeoutPenalty = GetTimeoutPenaltyDelaySeconds(consecutiveTimeouts);
                                if (timeoutPenalty > delaySeconds)
                                {
                                    delaySeconds = timeoutPenalty;
                                }
                                
                                // Mensaje claro sobre el delay y la razón
                                if (delaySeconds >= 60)
                                {
                                    Log($"⌛ Timeout consecutivo #{consecutiveTimeouts} - aplicando espera de {delaySeconds / 60}m para evitar bloqueos del servidor");
                                    Log($"   💡 El servidor Soulseek puede estar limitando conexiones desde esta IP");
                                    Log($"   💡 Esperando tiempo suficiente para que el servidor resetee el límite");
                                }
                                else
                                {
                                    Log($"⌛ Timeout consecutivo #{consecutiveTimeouts} - aplicando espera de {delaySeconds}s para evitar bloqueos del servidor");
                                }
                            }
                        }
                        else
                        {
                            consecutiveTimeouts = 0;
                            
                            // DESACTIVAR MODO CONSERVADOR TRAS 15 MIN DE CONEXIÓN ESTABLE
                            if (conservativeMode && DateTime.UtcNow.Subtract(lastConnectionIssue).TotalMinutes > 15)
                            {
                                conservativeMode = false;
                                AutoLog("🚀 MODO CONSERVADOR DESACTIVADO - conexión estable por 15+ minutos");
                            }
                        }

                        var delay = TimeSpan.FromSeconds(delaySeconds);
                        var jitter = isTimeoutException ? TimeSpan.Zero : GetJitter(delay);
                        var totalDelay = delay + jitter;
                        PauseAutoTuningDuringIncident(totalDelay);
                        nextAllowedConnectAttempt = DateTime.UtcNow + totalDelay;
                        
                        Log($"⏳ Esperando {totalDelay.TotalSeconds:F0}s antes del siguiente intento...");
                        Log($"   📊 Tipo de error: {ex.GetType().Name}");
                        Log($"   📊 Base delay: {delaySeconds}s | Jitter: {jitter.TotalSeconds:F1}s | Total: {totalDelay.TotalSeconds:F0}s");
                        Log($"   📊 Próximo intento permitido: {nextAllowedConnectAttempt:HH:mm:ss}");
                        if (recommended > 0)
                        {
                            Log($"   📊 Cooldown recomendado por historial: {Math.Ceiling(recommended)}s");
                        }
                        
                        // CRÍTICO: Resetear isConnecting antes de espera larga
                        lock (this)
                        {
                            isConnecting = false;
                            Log($"[DEBUG] isConnecting e isReconnecting reseteados antes de espera de {totalDelay.TotalSeconds:F0}s");
                            lastCooldownStateChange = DateTime.UtcNow;
                        }

                        // Limitar uso de CPU durante espera de reconexión
                        await DelayWithCancellation(totalDelay, appCts?.Token ?? CancellationToken.None);
                        if (totalDelay.TotalSeconds >= 60)
                        {
                            consecutiveTimeouts = 0;
                            lastAntiBlockCooldown = DateTime.UtcNow;
                        }

                        // Restablecer isConnecting antes del siguiente intento
                        lock (this)
                        {
                            isConnecting = true;
                            Log($"[DEBUG] isConnecting establecido a true para siguiente intento");
                        }
                        
                        // Pequeña pausa adicional para reducir estrés de CPU
                        await DelayWithCancellation(TimeSpan.FromMilliseconds(100), appCts?.Token ?? CancellationToken.None);
                        }
                        else
                        {
                            Log($"❌ Error final de conexión después de {maxAttempts} intentos: {ex.Message}");
                            Log($"💡 Sugerencia: Verifica tu conexión a Internet y las credenciales de Soulseek");
                            UpdateControlText(btnConnect, "Conectar");
                            UpdateControlEnabled(btnConnect, true);
                            UpdateControlText(lblStatus, "Error de conexión");
                            UpdateControl(lblStatus, c => c.ForeColor = Color.Red);
                            
                            // Activar reconexión automática si está habilitada
                            if (autoReconnect && !isReconnecting)
                            {
                                Log("🔄 Activando reconexión automática después de fallo de conexión...");
                                // MEJORA #26: Eliminar Task.Run redundante
                                _ = CheckAndReconnect();
                            }
                            
                            // Lanzar excepción para que el llamador sepa que falló
                            throw;
                        }
                    }
                }
            }
            finally
            {
                lock (this)
                {
                    isConnecting = false;
                    isReconnectCoolingDown = false;
                    lastReconnectSkipLog = DateTime.MinValue;
                    lastCooldownLog = DateTime.MinValue;
                }
                
                // CIRCUIT BREAKER: Resetear contadores en conexión exitosa
                if (client != null && client.State.HasFlag(SoulseekClientStates.Connected))
                {
                    circuitFailureCount = 0;
                    if (connectionCircuit == CircuitState.HalfOpen)
                    {
                        connectionCircuit = CircuitState.Closed;
                        Log("✅ Circuit Breaker CERRADO - Conexión estable recuperada");
                    }
                }
            }
        }

        private async Task ConnectAsync()
        {
            if (client != null && client.State.HasFlag(SoulseekClientStates.Connected))
            {
                // Desconectar
                client.Dispose();
                client = null;
                
                // POOL DE CONEXIONES: Limpiar pool al desconectar
                if (clientPool != null)
                {
                    foreach (var poolClient in clientPool)
                    {
                        try { poolClient?.Dispose(); } catch (Exception ex) { AutoLog($"⚠️ Error disposing poolClient: {ex.Message}"); }
                    }
                    clientPool.Clear();
                    currentClientIndex = 0;
                    AutoLog("🔌 Pool de conexiones limpiado");
                }
                
                if (btnConnect != null) btnConnect.Text = "Conectar";
                if (btnSearch != null) btnSearch.Enabled = false;
                UpdateNetworkStatusLabel();
                Log("Desconectado manualmente");
            }
            else
            {
                // Conectar
                await ConnectToSoulseek();
            }
        }
        
        /// <summary>
        /// Actualiza el label de estado mostrando el estado de todas las redes habilitadas
        /// </summary>
        private void UpdateNetworkStatusLabel()
        {
            if (lblStatus == null) return;
            
            SafeInvoke(() =>
            {
                var statusParts = new List<string>();
                var allConnected = true;
                var anyConnected = false;
                
                // Estado de Soulseek
                if (_networkConfig?.SoulseekEnabled == true)
                {
                    bool slskConnected = client != null && client.State.HasFlag(SoulseekClientStates.Connected);
                    statusParts.Add($"🔵 Soulseek: {(slskConnected ? "✅" : "❌")}");
                    if (slskConnected) anyConnected = true;
                    else allConnected = false;
                }
                
                // Actualizar label
                if (statusParts.Count == 0)
                {
                    lblStatus.Text = "● Sin redes habilitadas";
                    lblStatus.ForeColor = Color.Gray;
                }
                else
                {
                    lblStatus.Text = string.Join(" | ", statusParts);
                    lblStatus.ForeColor = allConnected ? Color.FromArgb(0, 200, 0) : 
                                         anyConnected ? Color.Orange : Color.Gray;
                }
            });
        }
        
        private (int totalFiles, int processedResponses, int processedFiles, int filteredBySize, int filteredByExt, int filteredBySpanish, int filteredByBlacklist) 
            ProcessAndDisplayResults(List<Soulseek.SearchResponse> responses, long minSizeBytes, long maxSizeBytes, string extFilter,
            int totalFiles, int processedResponses, int processedFiles,
            int filteredBySize, int filteredByExt, int filteredBySpanish, int filteredByBlacklist)
        {
            // MEJORA #31: Procesar respuestas en paralelo para mejor rendimiento
            var lockObj = new object();
            var newResults = new System.Collections.Concurrent.ConcurrentBag<SearchResultItem>();
            bool spanishOnlyChecked = false;
            SafeInvoke(() => spanishOnlyChecked = chkSpanishOnly.Checked);
            
            // MEJORA #6: Limitar a 75% de cores para evitar saturación de CPU
            int maxParallelism = Math.Max(1, (int)(Environment.ProcessorCount * 0.75));
            Parallel.ForEach(responses, new ParallelOptions { MaxDegreeOfParallelism = maxParallelism }, response =>
            {
                lock (lockObj) { processedResponses++; }
                
                if (blacklist.Contains(response.Username))
                {
                    lock (lockObj) { filteredByBlacklist++; }
                    return;
                }
                
                foreach (var file in response.Files.Take(500))
                {
                    lock (lockObj) { processedFiles++; }
                    
                    if (minSizeBytes > 0 && file.Size < minSizeBytes)
                    {
                        lock (lockObj) { filteredBySize++; }
                        continue;
                    }
                    if (maxSizeBytes < long.MaxValue && file.Size > maxSizeBytes)
                    {
                        lock (lockObj) { filteredBySize++; }
                        continue;
                    }
                    
                    // MEJORA #13: Cachear extensión para evitar calcularla dos veces
                    string fileExt = Path.GetExtension(file.Filename).ToLower();
                    if (!MatchesCategory(fileExt, extFilter))
                    {
                        lock (lockObj) { filteredByExt++; }
                        continue;
                    }
                    
                    if (spanishOnlyChecked && !IsSpanishText(file.Filename))
                    {
                        lock (lockObj) { filteredBySpanish++; }
                        continue;
                    }
                    
                    // Crear SearchResultItem (reutilizar fileExt ya calculado)
                    var searchItem = new SearchResultItem
                    {
                        Username = response.Username,
                        Filename = Path.GetFileName(file.Filename),
                        Size = file.Size,
                        Extension = fileExt, // Reutilizar en lugar de recalcular
                        FolderPath = Path.GetDirectoryName(file.Filename) ?? "",
                        UploadSpeed = response.UploadSpeed,
                        Network = "Soulseek" // Red de origen
                    };
                    newResults.Add(searchItem);
                    lock (lockObj) { totalFiles++; }
                }
            });
            
            // Agregar resultados al final
            allResults.AddRange(newResults);
            
            // Actualizar Virtual ListView
            UpdateSearchResults(allResults);
            SafeInvoke(() => lblStatus.Text = $"Buscando... {totalFiles:N0} encontrados");
            
            return (totalFiles, processedResponses, processedFiles, filteredBySize, filteredByExt, filteredBySpanish, filteredByBlacklist);
        }
        
        private async Task SearchAsync()
        {
            if (client == null || string.IsNullOrWhiteSpace(cmbSearch.Text)) 
                return;
            
            // Guardar en historial (thread-safe)
            string searchText = "";
            SafeInvoke(() => searchText = cmbSearch.Text);
            
            if (!string.IsNullOrWhiteSpace(searchText) && !searchHistory.Contains(searchText))
            {
                searchHistory.Insert(0, searchText);
                if (searchHistory.Count > 20) searchHistory.RemoveAt(20);
                
                SafeInvoke(() =>
                {
                    cmbSearch.Items.Clear();
                    cmbSearch.Items.AddRange(searchHistory.ToArray());
                });
                
                SaveSearchHistory();
            }
            
            // Estadísticas
            totalSearches++;
            
            // MEJORA NICOTINE+: Verificar caché de búsquedas
            if (_searchCacheManager != null)
            {
                try
                {
                    var cachedResults = await _searchCacheManager.TryGetAsync(searchText);
                    if (cachedResults != null)
                    {
                        var age = DateTime.UtcNow - cachedResults.Timestamp;
                        if (age < TimeSpan.FromHours(24))
                        {
                            Log($"📦 Usando resultados cacheados ({cachedResults.Results.Count} archivos, edad: {age.TotalHours:F1}h)");
                            _eventBus?.Publish(SystemEvents.CacheHit, new { Query = searchText, ResultCount = cachedResults.Results.Count, Age = age });
                            
                            SafeInvoke(() =>
                            {
                                autoSearchResults.Clear();
                                autoSearchResults.AddRange(cachedResults.Results);
                                UpdateSearchResults();
                            });
                            return;
                        }
                        else
                        {
                            Log($"⏱️ Caché expirado ({age.TotalHours:F1}h), realizando nueva búsqueda");
                        }
                    }
                    else
                    {
                        _eventBus?.Publish(SystemEvents.CacheMiss, new { Query = searchText });
                    }
                }
                catch (Exception cacheEx)
                {
                    Log($"⚠️ Error leyendo caché: {cacheEx.Message}");
                }
            }
            
            // Búsqueda múltiple (separada por comas)
            var searchTerms = cmbSearch.Text.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries)
                .Select(t => t.Trim())
                .Where(t => !string.IsNullOrEmpty(t))
                .ToList();
            
            if (searchTerms.Count > 1)
            {
                Log($"Búsqueda múltiple: {searchTerms.Count} términos (máx {maxParallelSearches} simultáneos)");
                await SearchMultipleTerms(searchTerms);
                return;
            }
            
            // INTEGRACIÓN MULTI-RED: Buscar según configuración de red preferida
            if (_networkOrchestrator != null && _networkConfig.SoulseekEnabled)
            {
                try
                {
                    // Determinar en qué redes buscar según configuración
                    List<string> targetNetworks = new List<string>();
                    
                    string preferredNetwork = _networkConfig.PreferredNetwork;
                    if (preferredNetwork == "Soulseek" && _networkConfig.SoulseekEnabled)
                    {
                        targetNetworks.Add("Soulseek");
                        Log($"🔵 Búsqueda solo en Soulseek");
                    }
                    else // Cualquier otro valor
                    {
                        if (_networkConfig.SoulseekEnabled) targetNetworks.Add("Soulseek");
                        Log($"🔵 Búsqueda en Soulseek");
                    }
                    
                    if (targetNetworks.Count == 0)
                    {
                        Log($"⚠️ No hay redes activas para buscar");
                        return;
                    }
                    
                    // Crear SearchRequest
                    var searchRequest = new SlskDown.Core.SearchRequest
                    {
                        SearchId = Guid.NewGuid().ToString(),
                        Query = searchText,
                        Timeout = TimeSpan.FromSeconds(30),
                        MaxResults = 1000
                    };
                    
                    var multiNetResponse = await _networkOrchestrator.SearchAsync(searchRequest, targetNetworks);
                    var multiNetResults = multiNetResponse.DeduplicatedResults;
                    
                    if (multiNetResults != null && multiNetResults.Any())
                    {
                        Log($"✅ Multi-red: {multiNetResults.Count} resultados totales");
                        foreach (var netGroup in multiNetResults.GroupBy(r => r.NetworkSource))
                        {
                            Log($"   📡 {netGroup.Key}: {netGroup.Count()} resultados");
                        }
                        
                        // Convertir resultados multi-red a formato interno
                        var convertedResults = multiNetResults.Select(r =>
                        {
                            // Metadata de resultados
                            string authorOrHash = "";
                            if (r.Metadata != null && r.Metadata.ContainsKey("Ed2kHash"))
                            {
                                authorOrHash = r.Metadata["Ed2kHash"].ToString(); // Usar Author temporalmente para hash
                            }
                            
                            var result = new AutoSearchFileResult
                            {
                                FileName = r.FileName,
                                Username = r.Username,
                                SizeBytes = r.SizeBytes,
                                SizeReadable = FormatFileSize(r.SizeBytes),
                                Directory = System.IO.Path.GetDirectoryName(r.FileName) ?? "",
                                Network = r.NetworkSource, // Guardar red de origen
                                Timestamp = DateTime.UtcNow,
                                Author = authorOrHash
                            };
                            
                            return result;
                        }).ToList();
                        
                        SafeInvoke(() =>
                        {
                            autoSearchResults.Clear();
                            autoSearchResults.AddRange(convertedResults);
                            UpdateSearchResults();
                        });
                        
                        // Cachear resultados
                        await _searchCacheManager.SetAsync(searchText, convertedResults);
                        
                        return;
                    }
                    else
                    {
                        Log($"⚠️ Multi-red: Sin resultados, continuando con búsqueda Soulseek standalone");
                    }
                }
                catch (Exception multiEx)
                {
                    Log($"⚠️ Error en búsqueda multi-red: {multiEx.Message}");
                    Log($"   Continuando con búsqueda Soulseek standalone");
                }
            }
            
            if (client == null || !client.State.HasFlag(SoulseekClientStates.Connected))
            {
                if (lblStatus != null)
                {
                    lblStatus.Text = "❌ No conectado - Presiona el botón CONECTAR primero";
                    lblStatus.ForeColor = Color.Red;
                }
                Log($"Error: Cliente no conectado. Estado actual: {client?.State.ToString() ?? "null"}");
                
                // Verificar si está en proceso de conexión
                if (btnConnect != null && btnConnect.Text == "Conectar" && btnConnect.Enabled == false)
                {
                    // Mensaje ya mostrado en logs
                }
                else
                {
                    Log("⚠️ Debes conectarte a Soulseek antes de buscar");
                }
                return;
            }
            
            Log($"Iniciando búsqueda: {cmbSearch.Text}");
            Log($"Estado del cliente: {client.State}");
            Log($"Red distribuida: {enableDistributedNetwork}");
            
            // MEJORA NICOTINE+: Publicar evento de búsqueda iniciada
            _eventBus?.Publish(SystemEvents.SearchStarted, new
            {
                Query = cmbSearch.Text,
                Timestamp = DateTime.UtcNow
            });

            try
            {
                Log("Creando CancellationTokenSource...");
                // Crear nuevo CancellationTokenSource
                searchCancellationTokenSource?.Cancel();
                searchCancellationTokenSource = new System.Threading.CancellationTokenSource();
                
                Log("Actualizando controles UI...");
                if (btnSearch != null) btnSearch.Enabled = false;
                if (btnStopSearch != null) btnStopSearch.Enabled = true;
                if (lblStatus != null) lblStatus.Text = "Buscando...";
                
                Log("Limpiando resultados anteriores...");
                ClearSearchResults();
                allResults.Clear();
                
                Log("Calculando parámetros de búsqueda...");
                // Interpretar 0 como sin límite (int.MaxValue)
                int actualResponseLimit = responseLimit == 0 ? int.MaxValue : Math.Min(responseLimit, 50);
                int actualFileLimit = fileLimit == 0 ? int.MaxValue : fileLimit;
                int actualTimeout = searchTimeout == 0 ? int.MaxValue : Math.Min(searchTimeout, 10) * 1000;
                
                Log($"Parámetros: responseLimit={actualResponseLimit}, fileLimit={actualFileLimit}, timeout={actualTimeout/1000}s");
                
                Log("Creando SearchOptions...");
                var searchOptions = new Soulseek.SearchOptions(
                    filterResponses: true,
                    maximumPeerQueueLength: actualResponseLimit,
                    searchTimeout: actualTimeout
                );
                
                Log($"Iniciando búsqueda en red Soulseek...");
                Log($"Término de búsqueda: '{cmbSearch.Text}'");
                
                Log("Obteniendo filtros...");
                long minSizeBytes = numMinSize != null ? (long)(numMinSize.Value * 1024) : 0;
                long maxSizeBytes = numMaxSize != null && numMaxSize.Value > 0 ? (long)(numMaxSize.Value * 1024) : long.MaxValue;
                string extFilter = cmbExtension?.SelectedItem?.ToString();
                bool spanishOnly = chkSpanishOnly?.Checked ?? false; // Capturar valor antes del thread
                
                string maxSizeStr = maxSizeBytes == long.MaxValue ? "sin límite" : $"{maxSizeBytes/1024}KB";
                Log($"Filtros: minSize={minSizeBytes/1024}KB, maxSize={maxSizeStr}, ext={extFilter}, español={spanishOnly}");
                
                int processedResponses = 0;
                int processedFiles = 0;
                int filteredBySize = 0;
                int filteredByExt = 0;
                int filteredBySpanish = 0;
                int filteredByBlacklist = 0;
                int totalFiles = 0;
                
                // Búsqueda continua inteligente: continúa mientras haya respuestas nuevas
                if (continuousSearch && actualTimeout > 2000)
                {
                    Log($"🔄 Modo búsqueda continua inteligente: mostrando resultados cada 2 segundos...");
                    Log($"⏹️ Se detendrá después de 3 búsquedas consecutivas sin resultados nuevos");
                    
                    int maxIterations = actualTimeout / 2000;
                    var allResponses = new List<Soulseek.SearchResponse>();
                    // MEJORA #24: Estimar ~50 usuarios por búsqueda
                    var seenUsers = new HashSet<string>(50);
                    int emptySearches = 0;
                    int iteration = 0;
                    
                    while (iteration < maxIterations && emptySearches < 3)
                    {
                        searchCancellationTokenSource.Token.ThrowIfCancellationRequested();
                        iteration++;
                        
                        Log($"📡 Búsqueda {iteration} (2s)...");
                        
                        // Modo Stealth: Delay variable entre búsquedas
                        await ApplyStealthDelay();
                        
                        // Idea #12: Rate limiting por operación (búsquedas)
                        await ThrottleSearchRate();
                        
                        // THROTTLING ADAPTATIVO: Verificar nivel actual
                        await ApplyAdaptiveThrottling();
                        
                        var shortOptions = new Soulseek.SearchOptions(
                            filterResponses: true,
                            maximumPeerQueueLength: Math.Min(actualResponseLimit, 50),
                            searchTimeout: 2000  // 2 segundos
                        );
                        
                        var searchStart = DateTime.UtcNow;
                        var searchResult = await ExecuteWithReconnect(
                            () => client.SearchAsync(
                                SearchQuery.FromText(cmbSearch.Text),
                                options: shortOptions
                            ),
                            "search short"
                        );
                        var searchDuration = (DateTime.UtcNow - searchStart).TotalMilliseconds;
                        lastActivityTime = DateTime.UtcNow; // Idea #11: sticky session
                        
                        // Actualizar throttling basado en respuesta
                        UpdateThrottlingBasedOnResponse(searchDuration, searchResult.Responses.Count);
                        
                        // ACTUALIZAR HEALTH SCORE después de cada búsqueda
                        UpdateConnectionHealthScore();
                        
                        // Filtrar respuestas nuevas (no repetidas)
                        var newResponses = searchResult.Responses
                            .Where(r => !seenUsers.Contains(r.Username))
                            .ToList();
                        
                        if (newResponses.Count == 0)
                        {
                            emptySearches++;
                            Log($"⚠️ Sin respuestas nuevas ({emptySearches}/3)");
                            
                            if (emptySearches >= 3)
                            {
                                Log($"⏹️ Deteniendo búsqueda: 3 intentos consecutivos sin resultados nuevos");
                                break;
                            }
                        }
                        else
                        {
                            emptySearches = 0;  // Resetear contador si hay respuestas nuevas
                            
                            foreach (var r in newResponses)
                            {
                                seenUsers.Add(r.Username);
                                allResponses.Add(r);
                            }
                            
                            Log($"✅ +{newResponses.Count} respuestas nuevas (total: {allResponses.Count})");
                            
                            // Procesar y mostrar resultados nuevos inmediatamente
                            foreach (var response in newResponses)
                            {
                                processedResponses++;
                                
                                // Filtrar usuarios de blacklist
                                if (blacklist.Contains(response.Username))
                                {
                                    filteredByBlacklist++;
                                    continue;
                                }
                                
                                foreach (var file in response.Files.Take(500))
                                {
                                    processedFiles++;
                                    
                                    // Descartar archivos de tamaño 0
                                    if (file.Size == 0)
                                    {
                                        filteredBySize++;
                                        continue;
                                    }
                                    
                                    // Descartar archivos sin extensión
                                    string fileExt = Path.GetExtension(file.Filename);
                                    if (string.IsNullOrEmpty(fileExt))
                                    {
                                        filteredByExt++;
                                        continue;
                                    }
                                    fileExt = fileExt.ToLower();
                                    
                                    // Filtrar archivos que ya tiene carbarher
                                    string fileName = Path.GetFileName(file.Filename);
                                    if (carbarherCacheLoaded && carbarherFilesCache.Contains(fileName))
                                    {
                                        filteredByBlacklist++;
                                        continue;
                                    }
                                    
                                    if (minSizeBytes > 0 && file.Size < minSizeBytes)
                                    {
                                        filteredBySize++;
                                        continue;
                                    }
                                    if (maxSizeBytes < long.MaxValue && file.Size > maxSizeBytes)
                                    {
                                        filteredBySize++;
                                        continue;
                                    }
                                    if (!MatchesCategory(fileExt, extFilter))
                                    {
                                        filteredByExt++;
                                        continue;
                                    }
                                    
                                    // Filtro de idioma español
                                    if (spanishOnly && !IsSpanishText(file.Filename))
                                    {
                                        filteredBySpanish++;
                                        continue;
                                    }
                                    
                                    // Crear SearchResultItem en lugar de ListViewItem
                                    var searchItem = new SearchResultItem
                                    {
                                        Username = response.Username,
                                        Filename = Path.GetFileName(file.Filename),
                                        Size = file.Size,
                                        Extension = fileExt,
                                        FolderPath = Path.GetDirectoryName(file.Filename) ?? "",
                                        Bitrate = file.BitRate ?? 0,
                                        Length = file.Length ?? 0,
                                        UploadSpeed = response.UploadSpeed,
                                        QueueLength = response.QueueLength,
                                        FreeUploadSlots = 0,
                                        Network = "Soulseek" // Red de origen
                                    };
                                    
                                    allResults.Add(searchItem);
                                    totalFiles++;
                                    
                                    // Actualizar grilla progresivamente cada 50 archivos (reducir carga UI)
                                    if (totalFiles % 50 == 0)
                                    {
                                        UpdateSearchResults(allResults);
                                        SafeInvoke(() =>
                                        {
                                            if (lblResultsCount != null) lblResultsCount.Text = $"{totalFiles:N0} archivos...";
                                            if (lblStatus != null) lblStatus.Text = $"Buscando... {totalFiles:N0} encontrados";
                                        });
                                    }
                                }
                            }
                        }
                    }
                    
                    Log($"✅ Búsqueda continua completada. Total: {allResponses.Count} respuestas en {iteration} búsquedas");
                    
                    // Forzar actualización final (ignorar throttle)
                    lastUpdateTime = DateTime.MinValue;
                    UpdateSearchResults(allResults);
                    var results = allResponses;
                }
                else
                {
                    // Búsqueda normal (una sola vez) con retry automático
                    Log($"⏳ Esperando respuestas (timeout: {actualTimeout/1000}s)...");
                    
                    totalSearches++;
                    var searchResult = await RetryPolicy.ExecuteWithRetry(
                        async () => await ExecuteWithReconnect(
                            () => client.SearchAsync(
                                SearchQuery.FromText(cmbSearch.Text),
                                options: searchOptions
                            ),
                            "search main"
                        ),
                        maxAttempts: 3,
                        initialDelayMs: 1000,
                        onRetry: (attempt, ex) =>
                        {
                            Log($"🔄 Reintentando búsqueda (intento {attempt}/3): {ex.Message}");
                        }
                    );
                    successfulSearches++;
                    
                    Log($"✅ Búsqueda completada. Total respuestas recibidas: {searchResult.Responses.Count()}");
                    
                    var results = searchResult.Responses;
                    Log($"Procesando {results.Count()} respuestas...");
                    
                    foreach (var response in results)
                    {
                        // Verificar cancelación
                        searchCancellationTokenSource.Token.ThrowIfCancellationRequested();
                        
                        processedResponses++;
                        
                        // Filtrar usuarios en lista negra
                        if (blacklist.Contains(response.Username))
                    {
                        Log($"Usuario bloqueado: {response.Username}");
                        filteredByBlacklist++;
                        continue;
                    }
                    
                        // Filtrar usuario carbarher
                        if (response.Username.Equals("carbarher", StringComparison.OrdinalIgnoreCase))
                        {
                            Log($"Usuario filtrado (cbh): {response.Username}");
                            filteredByBlacklist++;
                            continue;
                        }
                    
                    int filesInResponse = response.Files.Count();
                    Log($"Usuario {response.Username}: {filesInResponse} archivos");
                    
                    // Procesar archivos en paralelo para mayor velocidad
                    var validFiles = new System.Collections.Concurrent.ConcurrentBag<SearchResultItem>();
                    var localFilteredSize = 0;
                    var localFilteredExt = 0;
                    var localFilteredSpanish = 0;
                    var localFilteredBlacklist = 0;
                    
                    // MEJORA #6: Limitar a 75% de cores
                    int maxParallelism = Math.Max(1, (int)(Environment.ProcessorCount * 0.75));
                    System.Threading.Tasks.Parallel.ForEach(
                        response.Files.Take(500),
                        new System.Threading.Tasks.ParallelOptions { MaxDegreeOfParallelism = maxParallelism },
                        file =>
                        {
                            System.Threading.Interlocked.Increment(ref processedFiles);
                            
                            // Descartar archivos de tamaño 0
                            if (file.Size == 0)
                            {
                                System.Threading.Interlocked.Increment(ref localFilteredSize);
                                return;
                            }
                            
                            // Descartar archivos sin extensión
                            string fileExt = Path.GetExtension(file.Filename);
                            if (string.IsNullOrEmpty(fileExt))
                            {
                                System.Threading.Interlocked.Increment(ref localFilteredExt);
                                return;
                            }
                            fileExt = fileExt.ToLower();
                            
                            // Filtrar archivos que ya tiene carbarher
                            string fileName = Path.GetFileName(file.Filename);
                            if (carbarherCacheLoaded && carbarherFilesCache.Contains(fileName))
                            {
                                System.Threading.Interlocked.Increment(ref localFilteredBlacklist);
                                return;
                            }
                            
                            // Aplicar filtros de tamaño
                            if (minSizeBytes > 0 && file.Size < minSizeBytes)
                            {
                                System.Threading.Interlocked.Increment(ref localFilteredSize);
                                return;
                            }
                            if (maxSizeBytes < long.MaxValue && file.Size > maxSizeBytes)
                            {
                                System.Threading.Interlocked.Increment(ref localFilteredSize);
                                return;
                            }
                            if (!MatchesCategory(fileExt, extFilter))
                            {
                                System.Threading.Interlocked.Increment(ref localFilteredExt);
                                return;
                            }
                            
                            // Filtro de idioma español (thread-safe con LRU Cache)
                            if (chkSpanishOnly.Checked && !IsSpanishText(file.Filename))
                            {
                                System.Threading.Interlocked.Increment(ref localFilteredSpanish);
                                return;
                            }
                            
                            // Crear SearchResultItem
                            var searchItem = new SearchResultItem
                            {
                                Username = response.Username,
                                Filename = Path.GetFileName(file.Filename),
                                Size = file.Size,
                                Extension = fileExt,
                                FolderPath = Path.GetDirectoryName(file.Filename) ?? "",
                                Bitrate = file.BitRate ?? 0,
                                Length = file.Length ?? 0,
                                UploadSpeed = response.UploadSpeed,
                                QueueLength = response.QueueLength,
                                Network = "Soulseek" // Red de origen
                            };
                            
                            // Filtro de calidad (SIEMPRE ACTIVO con mínimo 60)
                            var qualityScore = QualityFilter.EvaluateQuality(searchItem);
                            searchItem.QualityScore = qualityScore.Score;
                            
                            const int MIN_QUALITY_THRESHOLD = 60;
                            if (qualityScore.Score < MIN_QUALITY_THRESHOLD)
                            {
                                return; // Filtrar por baja calidad
                            }
                            
                            validFiles.Add(searchItem);
                        });
                    
                    // Agregar resultados válidos
                    filteredBySize += localFilteredSize;
                    filteredByExt += localFilteredExt;
                    filteredBySpanish += localFilteredSpanish;
                    filteredByBlacklist += localFilteredBlacklist;
                    
                    foreach (var item in validFiles)
                    {
                        allResults.Add(item);
                        totalFiles++;
                    }
                    
                    // Actualizar UI cada 10 archivos (más inmediato)
                    if (totalFiles % 10 == 0)
                    {
                        UpdateSearchResults(allResults);
                        SafeInvoke(() => lblStatus.Text = $"Buscando... {totalFiles:N0} encontrados");
                    }
                    }  // Cierre del foreach
                }  // Cierre del else
                
                Log($"=== RESUMEN DE BÚSQUEDA ===");
                Log($"Respuestas procesadas: {processedResponses}");
                Log($"Usuarios bloqueados: {filteredByBlacklist}");
                Log($"Archivos procesados: {processedFiles}");
                Log($"Filtrados por tamaño: {filteredBySize}");
                Log($"Filtrados por extensión: {filteredByExt}");
                Log($"Filtrados por idioma español: {filteredBySpanish}");
                Log($"Archivos que pasaron filtros: {totalFiles}");
                Log($"Archivos en allResults: {allResults?.Count ?? 0}");
                
                // Mostrar estadísticas del filtro de idioma
                if (chkSpanishOnly?.Checked ?? false)
                {
                    Log($"=== ESTADÍSTICAS DE FILTRO DE IDIOMA ===");
                    Log(LanguageFilterStats.Instance.GetSummary());
                    // var cacheStats = spanishTextCache.GetStats(); // DESACTIVADO: Dictionary no tiene GetStats
                    Log($"Cache: {spanishTextCache.Count} entradas");
                }
                
                // Actualizar estadísticas
                if (!searchStats.ContainsKey(cmbSearch.Text))
                    searchStats[cmbSearch.Text] = 0;
                searchStats[cmbSearch.Text]++;
                SaveStats();
                
                // Forzar actualización final (ignorar throttle)
                lastUpdateTime = DateTime.MinValue;
                UpdateSearchResults(allResults);
                SafeInvoke(() => 
                {
                    lblStatus.Text = $"{totalFiles:N0} archivos encontrados";
                });
                
                Log($"Búsqueda completada: {totalFiles} archivos");
                
                // MEJORA NICOTINE+: Guardar resultados en caché
                if (_searchCacheManager != null && allResults != null && allResults.Count > 0)
                {
                    try
                    {
                        // Convertir SearchResultItem a AutoSearchFileResult
                        var cacheResults = allResults.Select(r => new AutoSearchFileResult
                        {
                            Filename = r.Filename,
                            FileSize = r.Size,
                            FullPath = Path.Combine(r.FolderPath, r.Filename),
                            BitRate = r.BitRate ?? 0,
                            Duration = r.Duration ?? TimeSpan.Zero,
                            Username = r.Username,
                            SizeBytes = r.Size,
                            Directory = r.FolderPath,
                            Author = string.Empty
                        }).ToList();
                        await _searchCacheManager.SetAsync(searchText, cacheResults);
                        Log($"💾 Resultados guardados en caché ({allResults.Count} archivos)");
                    }
                    catch (Exception cacheEx)
                    {
                        Log($"⚠️ Error guardando en caché: {cacheEx.Message}");
                    }
                }
                
                // MEJORA NICOTINE+: Publicar evento de búsqueda completada
                _eventBus?.Publish(SystemEvents.SearchCompleted, new
                {
                    Query = cmbSearch.Text,
                    ResultCount = totalFiles,
                    ProcessedResponses = processedResponses,
                    FilteredBySize = filteredBySize,
                    FilteredByExtension = filteredByExt,
                    FilteredByLanguage = filteredBySpanish,
                    FilteredByBlacklist = filteredByBlacklist,
                    Timestamp = DateTime.UtcNow
                });
            }
            catch (OperationCanceledException)
            {
                // Forzar actualización final con resultados parciales
                lastUpdateTime = DateTime.MinValue;
                UpdateSearchResults(allResults);
                
                SafeInvoke(() =>
                {
                    if (lblStatus != null) lblStatus.Text = "Búsqueda cancelada";
                    if (lblResultsCount != null) lblResultsCount.Text = $"{allResults.Count} resultados (cancelado)";
                });
                Log("Búsqueda cancelada por el usuario");
            }
            catch (Exception ex) 
            { 
                if (lblStatus != null) lblStatus.Text = $"Error: {ex.Message}";
                Log($"Error en búsqueda: {ex.Message}");
            }
            finally 
            { 
                if (btnSearch != null) btnSearch.Enabled = true;
                if (btnStopSearch != null) btnStopSearch.Enabled = false;
            }
        }
        
        private void StopSearch()
        {
            if (searchCancellationTokenSource != null && !searchCancellationTokenSource.IsCancellationRequested)
            {
                Log("⏹️ Botón DETENER presionado - Cancelando búsqueda...");
                searchCancellationTokenSource.Cancel();
                if (lblStatus != null) lblStatus.Text = "⏹️ Deteniendo búsqueda...";
                if (btnStopSearch != null) btnStopSearch.Enabled = false;
            }
        }
        
        private async Task DownloadMultipleAsync()
        {
            if (lvResults.SelectedItems.Count == 0 || client == null)
                return;
            
            var itemsToDownload = new List<(ListViewItem downloadItem, dynamic result)>();
            
            foreach (ListViewItem selectedItem in lvResults.SelectedItems)
            {
                try
                {
                    dynamic result = selectedItem.Tag;
                    var fileName = Path.GetFileName((string)result.Filename);
                    var username = (string)result.Username;
                    
                    // Verificar blacklist
                    if (blacklist.Contains(username))
                    {
                        Log($"⛔ Usuario bloqueado: {username} - Descarga omitida: {fileName}");
                        continue;
                    }
                    
                    System.IO.Directory.CreateDirectory(downloadDir);
                    
                    var downloadItem = new ListViewItem(fileName);
                    downloadItem.SubItems.Add(username);
                    downloadItem.SubItems.Add("0%");
                    downloadItem.SubItems.Add("En cola...");
                    downloadItem.SubItems.Add(FormatSize((long)result.Size));
                    downloadItem.SubItems.Add(GetMetadataStatusSync(fileName));
                    AddItemWithAutoScroll(lvDownloads, downloadItem);
                    
                    itemsToDownload.Add((downloadItem, result));
                }
                catch { }
            }
            
            tabControl.SelectedIndex = 1;
            
            // Modo Turbo: descargas paralelas
            if (maxParallelDownloads > 1)
            {
                var tasks = new List<Task>();
                using (var semaphore = new System.Threading.SemaphoreSlim(maxParallelDownloads))
                {
                    foreach (var (downloadItem, result) in itemsToDownload)
                    {
                        await semaphore.WaitAsync();
                        
                        var task = Task.Run(async () =>
                        {
                            try
                            {
                                await DownloadFileAsync(downloadItem, result);
                            }
                            finally
                            {
                                semaphore.Release();
                            }
                        });
                        
                        tasks.Add(task);
                    }
                    
                    await Task.WhenAll(tasks);
                }
            }
            else
            {
                // Modo normal: descargas secuenciales
                foreach (var (downloadItem, result) in itemsToDownload)
                {
                    await DownloadFileAsync(downloadItem, result);
                }
            }
        }
        
        /// <summary>
        /// Adaptador para DownloadManager - descarga desde DownloadTask
        /// </summary>
        private async Task DownloadFileFromTask(DownloadTask task)
        {
            if (task == null)
                return;

            await ProcessDownload(task);
        }
        
        private async Task DownloadFileAsync(ListViewItem downloadItem, dynamic result)
        {
            try
            {
                var fileName = Path.GetFileName((string)result.Filename);
                // Descargas manuales van directo a downloadDir (sin subcarpetas)
                // Solo las descargas automáticas usan GetDownloadPath con autor
                var localPath = Path.Combine(downloadDir, fileName);
                var cts = new System.Threading.CancellationTokenSource();
                var username = (string)result.Username;
                
                // Determinar la red de origen
                string network = "Soulseek"; // Por defecto
                try
                {
                    if (result is SearchResultItem searchResult && !string.IsNullOrEmpty(searchResult.Network))
                    {
                        network = searchResult.Network;
                    }
                    else if (result.Network != null)
                    {
                        network = (string)result.Network;
                    }
                }
                catch { }
                
                // MEJORA FASE 1.2: TryAdd thread-safe
                activeDownloads.TryAdd(fileName, cts);
                
                // Registrar inicio de descarga en métricas
                sessionMetrics?.RecordDownloadStarted();
                
                SafeBeginInvoke(() =>
                {
                    downloadItem.SubItems[3].Text = $"Descargando desde {network}...";
                });
                
                // MEJORA FASE 1.2: GetOrAdd thread-safe con ConcurrentDictionary
                var breaker = userCircuitBreakers.GetOrAdd(username, _ => new RetryPolicy.CircuitBreaker(
                    failureThreshold: 3,
                    resetTimeoutSeconds: 300 // 5 minutos
                ));
                
                // Verificar si el circuit breaker está abierto
                if (breaker.State == RetryPolicy.CircuitState.Open)
                {
                    SafeBeginInvoke(() =>
                    {
                        downloadItem.SubItems[3].Text = $"⏸️ Usuario bloqueado temporalmente";
                        downloadItem.ForeColor = Color.Orange;
                    });
                    Log($"⚠️ Circuit breaker abierto para {username} - descarga omitida");
                    return;
                }
                
                // Determinar el cliente correcto según la red de origen
                SoulseekClient downloadClient = client; // Por defecto Soulseek
                
                if (network != "Soulseek" && _networkOrchestrator != null)
                {
                    var networkClient = _networkOrchestrator.GetClient(network);
                    if (networkClient is SlskDown.Core.SoulseekClientAdapter adapter)
                    {
                        downloadClient = adapter.GetUnderlyingClient();
                    }
                    else if (networkClient != null)
                    {
                        SafeBeginInvoke(() =>
                        {
                            downloadItem.SubItems[3].Text = $"❌ Red {network} no soportada";
                            downloadItem.ForeColor = Color.Red;
                        });
                        Log($"⚠️ Descarga desde {network} no implementada");
                        return;
                    }
                }
                
                // Descarga con retry automático y circuit breaker
                totalDownloads++;
                await breaker.Execute(async () =>
                {
                    await RetryPolicy.ExecuteWithRetry(
                        async () =>
                        {
                            await downloadClient.DownloadAsync(
                                username,
                                (string)result.Filename,
                                () => Task.FromResult<Stream>(new FileStream(localPath, FileMode.Create)),
                                (long)result.Size,
                                cancellationToken: cts.Token,
                                options: new TransferOptions(
                                    progressUpdated: async (args) =>
                                    {
                                        // Aplicar límite de ancho de banda si está configurado
                                        if (maxBandwidthKBps > 0 && bandwidthLimiter != null)
                                        {
                                            await bandwidthLimiter.WaitAsync();
                                            bandwidthLimiter.RecordTransfer(args.Transfer.BytesTransferred - (args.Transfer.PreviousBytesTransferred ?? 0));
                                        }
                                        
                                        var percent = (int)((args.Transfer.BytesTransferred / (double)result.Size) * 100);
                                        SafeBeginInvoke(() =>
                                        {
                                            downloadItem.SubItems[2].Text = $"{percent}%";
                                            var speedText = "";
                                            if (args.Transfer.Speed > 0)
                                            {
                                                speedText = $" ({FormatSize(args.Transfer.Speed)}/s)";
                                            }
                                            downloadItem.SubItems[3].Text = $"Descargando... {FormatSize(args.Transfer.BytesTransferred)} / {FormatSize((long)result.Size)}{speedText}";
                                        });
                                    }
                                )
                            );
                        },
                        maxAttempts: 3,
                        initialDelayMs: 2000,
                        onRetry: (attempt, ex) =>
                        {
                            SafeBeginInvoke(() =>
                            {
                                downloadItem.SubItems[3].Text = $"🔄 Reintento {attempt}/3: {ex.Message}";
                                downloadItem.ForeColor = Color.Orange;
                            });
                            Log($"🔄 Reintentando descarga de {fileName} (intento {attempt}/3): {ex.Message}");
                        }
                    );
                    return true;
                });
                
                successfulDownloads++;
                
                // MEJORA #16: Verificar integridad del archivo descargado
                bool integrityValid = false;
                string integrityMessage = "";
                
                try
                {
                    if (fileIntegrityVerifier != null)
                    {
                        var integrityResult = await fileIntegrityVerifier.VerifyFileIntegrityAsync(
                            localPath, 
                            expectedSize: (long)result.Size, 
                            ct: cts.Token
                        );
                        
                        integrityValid = integrityResult.IsValid;
                        
                        if (integrityValid)
                        {
                            integrityMessage = $"✓ Verificado (SHA256: {integrityResult.Checksum?.Substring(0, 8)}...)";
                            Log($"✅ Integridad verificada: {fileName}");
                        }
                        else
                        {
                            integrityMessage = $"⚠️ Verificación falló: {integrityResult.ErrorMessage}";
                            Log($"⚠️ Integridad falló: {fileName} - {integrityResult.ErrorMessage}");
                            
                            // Eliminar archivo corrupto
                            try
                            {
                                if (System.IO.File.Exists(localPath))
                                {
                                    System.IO.File.Delete(localPath);
                                    Log($"🗑️ Archivo corrupto eliminado: {fileName}");
                                }
                            }
                            catch (Exception delEx)
                            {
                                Log($"⚠️ No se pudo eliminar archivo corrupto: {delEx.Message}");
                            }
                            
                            // Marcar para re-descarga si no se ha reintentado muchas veces
                            var retryCount = retryQueue.FirstOrDefault(r => Path.GetFileName(((dynamic)r.result).Filename) == fileName).retryCount;
                            if (retryCount < maxRetries)
                            {
                                retryQueue.Add((result, downloadItem, retryCount + 1));
                                SafeBeginInvoke(() =>
                                {
                                    downloadItem.SubItems[3].Text = $"🔄 Archivo corrupto - reintentando ({retryCount + 1}/{maxRetries})";
                                    downloadItem.ForeColor = Color.Orange;
                                });
                                Log($"🔄 Re-descargando archivo corrupto: {fileName}");
                                
                                // Reintentar después de 5 segundos
                                await Task.Delay(5000);
                                await DownloadFileAsync(downloadItem, result);
                                return;
                            }
                        }
                    }
                    else
                    {
                        integrityValid = true; // Si no hay verificador, asumir válido
                        integrityMessage = "✓ Completado";
                    }
                }
                catch (Exception verifyEx)
                {
                    Log($"⚠️ Error verificando integridad de {fileName}: {verifyEx.Message}");
                    integrityValid = true; // En caso de error, asumir válido para no bloquear
                    integrityMessage = "✓ Completado (verificación omitida)";
                }
                
                // Registrar descarga completada en métricas solo si es válida
                if (integrityValid)
                {
                    var fileSize = (long)result.Size;
                    var speedKBps = fileSize / 1024.0 / 10.0; // Estimación aproximada
                    sessionMetrics?.RecordDownloadCompleted(fileSize, speedKBps);
                }
                
                SafeBeginInvoke(() =>
                {
                    downloadItem.SubItems[2].Text = "100%";
                    downloadItem.SubItems[3].Text = integrityMessage;
                    downloadItem.ForeColor = integrityValid ? Color.LightGreen : Color.Orange;
                });
                
                // Notificación de progreso
                totalDownloadsInSession++;
                if (totalDownloadsInSession % 10 == 0)
                {
                    ShowNotification("Progreso de Descargas", 
                        $"✅ {totalDownloadsInSession} archivos completados en esta sesión", 
                        ToolTipIcon.Info);
                }
                
                // MEJORA FASE 1.2: TryRemove thread-safe
                activeDownloads.TryRemove(fileName, out _);
            }
            catch (OperationCanceledException)
            {
                SafeBeginInvoke(() =>
                {
                    downloadItem.SubItems[3].Text = "⏸️ Cancelado";
                    downloadItem.ForeColor = Color.Orange;
                });
                // MEJORA FASE 1.2: TryRemove thread-safe
                activeDownloads.TryRemove(Path.GetFileName((string)result.Filename), out _);
            }
            catch (Exception ex)
            {
                var fileName = Path.GetFileName((string)result.Filename);
                var username = (string)result.Username;
                
                // Rastrear fallo del archivo
                TrackFileFailure(fileName, username, ex.Message);
                
                // Registrar fallo en métricas
                sessionMetrics?.RecordDownloadFailed();
                
                SafeBeginInvoke(() =>
                {
                    downloadItem.SubItems[3].Text = $"✗ Error: {ex.Message}";
                    downloadItem.ForeColor = Color.Red;
                });
                Log($"Error en descarga: {fileName} - {ex.Message}");
                // MEJORA FASE 1.2: TryRemove thread-safe
                activeDownloads.TryRemove(fileName, out _);
                
                // No reintentar si el archivo está blacklisteado
                if (IsFileBlacklisted(fileName, username))
                {
                    SafeBeginInvoke(() =>
                    {
                        downloadItem.SubItems[3].Text = $"🚫 Blacklisteado (fallos repetidos)";
                        downloadItem.ForeColor = Color.DarkRed;
                    });
                    Log($"🚫 Archivo blacklisteado: {fileName} - No se reintentará");
                    return;
                }
                
                // Agregar a cola de reintentos si está habilitado
                if (maxRetries > 0)
                {
                    var existingRetry = retryQueue.FirstOrDefault(r => Path.GetFileName(((dynamic)r.result).Filename) == fileName);
                    if (existingRetry.result != null)
                    {
                        var retryCount = existingRetry.retryCount + 1;
                        retryQueue.Remove(existingRetry);
                        
                        if (retryCount <= maxRetries)
                        {
                            retryQueue.Add((result, downloadItem, retryCount));
                            SafeBeginInvoke(() =>
                            {
                                downloadItem.SubItems[3].Text = $"🔄 Reintentando ({retryCount}/{maxRetries})...";
                                downloadItem.ForeColor = Color.Orange;
                            });
                            Log($"Reintentando descarga: {fileName} (intento {retryCount}/{maxRetries})");
                            
                            // Reintentar después de 3 segundos
                            await Task.Delay(3000).ConfigureAwait(false); // MEJORA #37
                            await DownloadFileAsync(downloadItem, result);
                        }
                        else
                        {
                            SafeBeginInvoke(() =>
                            {
                                downloadItem.SubItems[3].Text = $"✗ Fallo después de {maxRetries} reintentos";
                                downloadItem.ForeColor = Color.DarkRed;
                            });
                            Log($"Descarga fallida definitivamente: {fileName}");
                        }
                    }
                    else
                    {
                        retryQueue.Add((result, downloadItem, 1));
                        SafeBeginInvoke(() =>
                        {
                            downloadItem.SubItems[3].Text = "🔄 Reintentando (1/" + maxRetries + ")...";
                            downloadItem.ForeColor = Color.Orange;
                        });
                        Log($"Reintentando descarga: {fileName} (intento 1/{maxRetries})");
                        
                        await Task.Delay(3000).ConfigureAwait(false); // MEJORA #37
                        await DownloadFileAsync(downloadItem, result);
                    }
                }
            }
        }
        
        private async Task DownloadAsync()
        {
            if (lvResults.SelectedIndices.Count == 0 || client == null) 
                return;
            
            try
            {
                // Obtener resultado del Tag del item seleccionado
                var selectedItem = lvResults.SelectedItems[0];
                var result = selectedItem.Tag as SearchResultItem;
                
                if (result == null)
                {
                    lblStatus.Text = "Error: Resultado inválido";
                    return;
                }
                
                var fullFilename = Path.Combine(result.FolderPath, result.Filename);
                var localPath = Path.Combine(downloadDir, result.Filename);
                
                System.IO.Directory.CreateDirectory(downloadDir);
                
                // Agregar a lista de descargas
                var downloadItem = new ListViewItem(result.Filename);
                downloadItem.SubItems.Add(result.Username);
                downloadItem.SubItems.Add("0%");
                downloadItem.SubItems.Add("Descargando...");
                downloadItem.SubItems.Add(FormatSize(result.Size));
                downloadItem.SubItems.Add(GetMetadataStatusSync(result.Filename));
                AddItemWithAutoScroll(lvDownloads, downloadItem);
                
                // Cambiar a pestaña de descargas
                tabControl.SelectedIndex = 1;
                
                lblStatus.Text = $"Descargando desde {result.Network}: {result.Filename}...";
                
                // Determinar el cliente correcto según la red de origen
                SoulseekClient downloadClient = client; // Por defecto Soulseek
                
                if (!string.IsNullOrEmpty(result.Network) && result.Network != "Soulseek")
                {
                    // Si es de otra red, intentar obtener el cliente del orquestador
                    if (_networkOrchestrator != null)
                    {
                        var networkClient = _networkOrchestrator.GetClient(result.Network);
                        if (networkClient is SlskDown.Core.SoulseekClientAdapter adapter)
                        {
                            downloadClient = adapter.GetUnderlyingClient();
                        }
                        else
                        {
                            Log($"⚠️ Red no soportada: {result.Network}");
                            lblStatus.Text = "Error: Red no soportada";
                            return;
                        }
                    }
                }
                
                await downloadClient.DownloadAsync(
                    result.Username, 
                    fullFilename, 
                    (Func<Task<Stream>>)(() => Task.FromResult<Stream>(new FileStream(localPath, FileMode.Create))), 
                    result.Size,
                    options: new TransferOptions(
                        progressUpdated: (args) =>
                        {
                            var percent = (int)((args.Transfer.BytesTransferred / (double)result.Size) * 100);
                            SafeBeginInvoke(() =>
                            {
                                downloadItem.SubItems[2].Text = $"{percent}%";
                                downloadItem.SubItems[3].Text = $"Descargando... {FormatSize(args.Transfer.BytesTransferred)} / {FormatSize(result.Size)}";
                            });
                        }
                    )
                );
                
                downloadItem.SubItems[2].Text = "100%";
                downloadItem.SubItems[3].Text = "✓ Completado";
                downloadItem.ForeColor = Color.LimeGreen;
                Log($"Descarga completada desde {result.Network}: {result.Filename}");
                lblStatus.Text = $"✓ Descargado: {result.Filename}";
                
                // Notificación de progreso
                totalDownloadsInSession++;
                if (totalDownloadsInSession % 10 == 0)
                {
                    ShowNotification("Progreso de Descargas", 
                        $"✅ {totalDownloadsInSession} archivos completados en esta sesión", 
                        ToolTipIcon.Info);
                }
                
                // Actualizar estadísticas
                totalDownloads++;
                SaveStats();
            }
            catch (Exception ex) 
            { 
                lblStatus.Text = $"Error: {ex.Message}"; 
            }
        }
        
        private string FormatSize(long bytes)
        {
            string[] sizes = { "B", "KB", "MB", "GB" };
            double len = bytes;
            int order = 0;
            while (len >= 1024 && order < sizes.Length - 1) 
            { 
                order++; 
                len /= 1024; 
            }
            return $"{len:0.##} {sizes[order]}";
        }
        
        private string GetScoreDisplay(string username)
        {
            try
            {
                // Intentar obtener score de SQLite (usando GetAwaiter para evitar deadlock)
                if (database != null)
                {
                    var rating = database.GetSourceRatingAsync(username).ConfigureAwait(false).GetAwaiter().GetResult();
                    if (rating != null)
                    {
                        var score = rating.Score;
                        var stars = GetStarsFromScore(score);
                        return $"{stars} {score:F0}";
                    }
                }
                
                // Fallback: buscar en providerStats (sistema antiguo)
                if (providerStats.TryGetValue(username, out var stats))
                {
                    var successRate = stats.SuccessfulDownloads > 0 
                        ? (double)stats.SuccessfulDownloads / (stats.SuccessfulDownloads + stats.FailedDownloads) * 100 
                        : 0;
                    var stars = GetStarsFromScore(successRate);
                    return $"{stars} {successRate:F0}";
                }
                
                return "⭐ --";  // Usuario nuevo sin historial
            }
            catch
            {
                return "⭐ --";
            }
        }
        
        private string GetStarsFromScore(double score)
        {
            if (score >= 90) return "⭐⭐⭐⭐⭐";
            if (score >= 75) return "⭐⭐⭐⭐";
            if (score >= 60) return "⭐⭐⭐";
            if (score >= 40) return "⭐⭐";
            if (score >= 20) return "⭐";
            return "☆";  // Muy bajo o sin datos
        }
        
        // Actualizar estado con colores y animación
        private void UpdateStatus(string message, StatusType type = StatusType.Info)
        {
            if (lblStatus == null) return;
            
            SafeBeginInvoke(() =>
            {
                lblStatus.Text = message;
                
                // Aplicar colores según el tipo
                switch (type)
                {
                    case StatusType.Success:
                        lblStatus.ForeColor = Color.FromArgb(34, 197, 94);  // Verde
                        lblStatus.BackColor = Color.FromArgb(20, 40, 30);
                        break;
                    case StatusType.Error:
                        lblStatus.ForeColor = Color.FromArgb(239, 68, 68);  // Rojo
                        lblStatus.BackColor = Color.FromArgb(40, 20, 20);
                        break;
                    case StatusType.Warning:
                        lblStatus.ForeColor = Color.FromArgb(251, 191, 36);  // Amarillo
                        lblStatus.BackColor = Color.FromArgb(40, 35, 20);
                        break;
                    case StatusType.Searching:
                        lblStatus.ForeColor = Color.FromArgb(59, 130, 246);  // Azul
                        lblStatus.BackColor = Color.FromArgb(20, 25, 40);
                        break;
                    case StatusType.Downloading:
                        lblStatus.ForeColor = Color.FromArgb(168, 85, 247);  // Púrpura
                        lblStatus.BackColor = Color.FromArgb(35, 20, 40);
                        break;
                    case StatusType.Connected:
                        lblStatus.ForeColor = Color.FromArgb(16, 185, 129);  // Verde azulado
                        lblStatus.BackColor = Color.FromArgb(20, 35, 35);
                        break;
                    case StatusType.Disconnected:
                        lblStatus.ForeColor = Color.FromArgb(160, 160, 160);  // Gris
                        lblStatus.BackColor = Color.FromArgb(30, 30, 35);
                        break;
                    default:  // Info
                        lblStatus.ForeColor = Color.FromArgb(200, 200, 200);
                        lblStatus.BackColor = Color.FromArgb(30, 30, 35);
                        break;
                }
            });
        }
        
        // Enum para tipos de estado
        private enum StatusType
        {
            Info,
            Success,
            Error,
            Warning,
            Searching,
            Downloading,
            Connected,
            Disconnected
        }
        
