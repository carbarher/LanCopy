            var btnStopDownload = CreateCompactButton("⏸️", Color.FromArgb(150, 100, 0), "Detener");
            var btnResumeDownload = CreateCompactButton("▶️", Color.FromArgb(0, 150, 0), "Continuar");
            var btnOpenFolder = CreateCompactButton("📂", Color.FromArgb(60, 120, 60), "Carpeta");
            SafeLog( "CreateVaciarTab: Botones creados\n");
            
