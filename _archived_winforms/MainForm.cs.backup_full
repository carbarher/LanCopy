        #region Disconnection Cleanup (Nicotine+ inspired)

        /// <summary>
        /// Limpieza exhaustiva al desconectar del servidor (inspirado en Nicotine+)
        /// Limpia recursos, resetea estado y prepara para reconexión limpia
        /// </summary>
        private async Task PerformExhaustiveDisconnectionCleanup()
        {
            try
            {
                Log("🧹 Iniciando limpieza exhaustiva por desconexión...");

                // 1. Abortar todas las transferencias activas
                int abortedDownloads = 0;
                lock (downloadQueueLock)
                {
                    var activeDownloads = downloadQueue
                        .Where(d => d.Status == DownloadStatus.Downloading || 
                                   d.Status == DownloadStatus.GettingStatus)
                        .ToList();

                    foreach (var download in activeDownloads)
                    {
                        download.Status = DownloadStatus.ConnectionClosed;
                        download.ErrorMessage = "Desconectado del servidor";
                        abortedDownloads++;
                    }
                }

                if (abortedDownloads > 0)
                {
                    Log($"   ⏸️  Abortadas {abortedDownloads} descargas activas");
                    await downloadManager?.SaveStateAsync();
                }

                // 2. Marcar descargas en cola como "esperando reconexión"
                int queuedDownloads = 0;
                lock (downloadQueueLock)
                {
                    var queued = downloadQueue
                        .Where(d => d.Status == DownloadStatus.Queued)
                        .ToList();

                    foreach (var download in queued)
                    {
                        download.Status = DownloadStatus.UserLoggedOff;
                        queuedDownloads++;
                    }
                }

                if (queuedDownloads > 0)
                {
                    Log($"   ⏸️  Marcadas {queuedDownloads} descargas en cola como 'usuario offline'");
                }

                // 3. Limpiar caché de usuarios online (ya no sabemos quién está online)
                // (No hay variable onlineUsers en MainForm, pero podría agregarse en el futuro)

                // 4. Resetear estadísticas de ancho de banda
                // (downloadManager ya tiene su propio reset)

                // 5. Guardar estado antes de limpiar
                try
                {
                    SaveConfig();
                    Log("   💾 Configuración guardada");
                }
                catch (Exception saveEx)
                {
                    Log($"   ⚠️  Error guardando configuración: {saveEx.Message}");
                }

                // 6. Limpiar timers de keep-alive y health check
                StopKeepAliveTimer();
                Log("   ⏱️  Timers de keep-alive detenidos");

                // 7. Actualizar UI con estado consistente
                SafeBeginInvoke(() =>
                {
                    try
                    {
                        // Actualizar vista de descargas
                        if (lvDownloads != null)
                        {
                            foreach (ListViewItem item in lvDownloads.Items)
                            {
                                var status = item.SubItems[3].Text;
                                if (status == "Downloading" || status == "Descargando")
                                {
                                    item.SubItems[3].Text = "Conexión cerrada";
                                    item.SubItems[3].ForeColor = Color.Orange;
                                }
                            }
                        }
                    }
                    catch (Exception uiEx)
                    {
                        Log($"   ⚠️  Error actualizando UI: {uiEx.Message}");
                    }
                });

                Log("✅ Limpieza exhaustiva completada - sistema listo para reconexión");
            }
            catch (Exception ex)
            {
                Log($"❌ Error en limpieza exhaustiva: {ex.Message}");
            }
        }

        #endregion

        #region Nicotine+ Inspired Services

        /// <summary>
        /// MEJORA #42: Inicializa el detector de duplicados con archivos existentes
        /// OPTIMIZADO: Ahora se ejecuta en segundo plano sin bloquear la UI
        /// </summary>
        private void InitializeDuplicateDetector()
        {
            if (duplicateDetector == null || string.IsNullOrWhiteSpace(downloadDir))
                return;
                
            Log("🔍 Iniciando escaneo de archivos en segundo plano...");
            
            // Ejecutar en background para no bloquear la inicialización
            Task.Run(async () =>
            {
                try
                {
                    // MEJORA NICOTINE+: Usar DirectoryExistsCached
                    if (!DirectoryExistsCached(downloadDir))
                    {
                        SafeLog("⚠️ Directorio de descargas no existe aún");
                        return;
                    }
                    
                    var sw = System.Diagnostics.Stopwatch.StartNew();
                    
                    // Usar EnumerateFiles para mejor rendimiento con muchos archivos
                    var files = System.IO.Directory.EnumerateFiles(downloadDir, "*.*", SearchOption.AllDirectories);
                    int registered = 0;
                    int errors = 0;
                    
                    // Procesar en lotes para no saturar
                    const int BATCH_SIZE = 1000;
                    var batch = new List<(string name, long size, string path)>(BATCH_SIZE);
                    
                    foreach (var filePath in files)
                    {
                        try
                        {
                            var fileInfo = new FileInfo(filePath);
                            batch.Add((fileInfo.Name, fileInfo.Length, filePath));
                            
                            if (batch.Count >= BATCH_SIZE)
                            {
                                // Registrar lote
                                foreach (var item in batch)
                                {
                                    duplicateDetector.RegisterDownload(item.name, item.size, item.path);
                                }
                                registered += batch.Count;
                                batch.Clear();
                                
                                // Pequeña pausa para no saturar
                                await Task.Delay(10);
                            }
                        }
                        catch
                        {
                            errors++;
                        }
                    }
                    
                    // Registrar archivos restantes
                    if (batch.Count > 0)
                    {
                        foreach (var item in batch)
                        {
                            duplicateDetector.RegisterDownload(item.name, item.size, item.path);
                        }
                        registered += batch.Count;
                    }
                    
                    sw.Stop();
                    SafeLog($"✅ Detector de duplicados inicializado: {registered:N0} archivos en {sw.ElapsedMilliseconds:N0}ms" + 
                           (errors > 0 ? $" ({errors} errores ignorados)" : ""));
                }
                catch (Exception ex)
                {
                    SafeLog($"⚠️ Error inicializando detector de duplicados: {ex.Message}");
                }
            });
        }
        
        // MEJORA FASE 1.3: Helpers para ReaderWriterLockSlim
        private T ReadLocked<T>(ReaderWriterLockSlim rwLock, Func<T> action)
        {
            rwLock.EnterReadLock();
            try { return action(); }
            finally { rwLock.ExitReadLock(); }
        }
        
        private void WriteLocked(ReaderWriterLockSlim rwLock, Action action)
        {
            rwLock.EnterWriteLock();
            try { action(); }
            finally { rwLock.ExitWriteLock(); }
        }
        
        /// <summary>
        /// Inicializa servicios inspirados en Nicotine+ y protocolo Soulseek
        /// </summary>
        private void InitializeNicotinePlusServices()
        {
            try
            {
                Log("🎵 Inicializando servicios inspirados en Nicotine+...");

                // 1. Queue Position Tracker
                queuePositionTracker = new SlskDown.Core.QueuePositionTracker();
                queuePositionTracker.OnLog = msg => Log(msg);
                queuePositionTracker.OnPositionUpdated = info =>
                {
                    SafeBeginInvoke(() =>
                    {
                        // Actualizar UI con posición en cola
                        UpdateQueuePositionInUI(info);
                    });
                };
                queuePositionTracker.Start();
                Log("✅ QueuePositionTracker iniciado");

                // 2. Download Request Helper
                if (client != null)
                {
                    downloadRequestHelper = new SlskDown.Core.DownloadRequestHelper(client);
                    downloadRequestHelper.OnLog = msg => Log(msg);
                    Log("✅ DownloadRequestHelper inicializado");
                }

                // 3. Recommendation Service
                if (client != null)
                {
                    recommendationService = new SlskDown.Services.RecommendationService(client);
                    recommendationService.OnLog = msg => Log(msg);
                    Log("✅ RecommendationService inicializado");
                }

                // 4. Audio Quality Filters (inicializar con valores por defecto)
                audioQualityFilters = new SlskDown.Models.AudioQualityFilters
                {
                    MinBitrate = null,          // Sin filtro por defecto
                    LosslessOnly = false,       // Permitir lossy y lossless
                    MinQualityScore = null      // Sin score mínimo
                };
                Log("✅ AudioQualityFilters inicializado");

                Log("🎉 Todos los servicios Nicotine+ inicializados correctamente");
            }
            catch (Exception ex)
            {
                Log($"❌ Error inicializando servicios Nicotine+: {ex.Message}");
            }
        }

        /// <summary>
        /// Actualiza la UI con información de posición en cola
        /// </summary>
        private void UpdateQueuePositionInUI(SlskDown.Core.QueuePositionTracker.QueueInfo info)
        {
            try
            {
                if (lvDownloads == null || info == null) return;

                // Buscar el item en la lista de descargas
                foreach (ListViewItem item in lvDownloads.Items)
                {
                    if (item.Tag is DownloadTask task &&
                        task.File.Username == info.Username &&
                        task.File.FileName == info.Filename)
                    {
                        // Actualizar columna de estado con posición
                        if (task.Status == DownloadStatus.Queued || 
                            task.Status == DownloadStatus.UserLoggedOff)
                        {
                            item.SubItems[3].Text = $"En cola - {info.DisplayText}";
                            item.SubItems[3].ForeColor = Color.Orange;
                        }
                        break;
                    }
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error actualizando posición en UI: {ex.Message}");
            }
        }

        /// <summary>
        /// Obtiene metadatos de audio de un archivo de búsqueda
        /// </summary>
        private SlskDown.Models.AudioMetadata GetAudioMetadata(Soulseek.File file)
        {
            try
            {
                if (file?.Attributes == null || file.Attributes.Count == 0)
                    return null;

                // Convertir IReadOnlyCollection<FileAttribute> a IReadOnlyDictionary<int, int>
                var attributesDict = file.Attributes.ToDictionary(
                    attr => (int)attr.Type,  // Cast enum to int
                    attr => attr.Value
                );

                return SlskDown.Models.AudioMetadata.FromFileAttributes(attributesDict);
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error parseando metadatos de audio: {ex.Message}");
                return null;
            }
        }

        /// <summary>
        /// Formatea información de audio para mostrar en UI
        /// </summary>
        private string FormatAudioQuality(SlskDown.Models.AudioMetadata metadata)
        {
            if (metadata == null) return "";
            return $"{metadata.QualityBadge} {metadata.QualityDescription}";
        }

        /// <summary>
        /// Verifica si un archivo cumple los filtros de calidad de audio.
        /// </summary>
        private bool PassesAudioQualityFilters(SlskDown.Models.AudioMetadata metadata)
        {
            if (audioQualityFilters == null)
            {
                return true;
            }

            return audioQualityFilters.Matches(metadata);
        }

        #endregion
    }
}