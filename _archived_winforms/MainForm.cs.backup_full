            btnStopAuto.FlatAppearance.BorderSize = 0;
            btnStopAuto.Margin = new Padding(3, 3, 8, 3);
            btnStopAuto.Click += async (s, e) =>
            {
                bool anyActive = false;

                if (autoSearchRunning)
                {
                    AutoLog("⏹️ Deteniendo búsqueda automática...");
                    AutoLog("ℹ️ Las descargas activas continuarán");
                    anyActive = true;
                }

                if (autoPurgeRunning)
                {
                    AutoLog("⏹️ Cancelando purga automática...");
                    anyActive = true;
                }

                if (!anyActive)
                {
                    AutoLog("⏹️ No hay procesos automáticos activos.");
                    return;
                }

                // CANCELACIÓN AGRESIVA: Marcar flags primero
                autoSearchRunning = false;
                autoPurgeRunning = false;
                
                // Cancelar token (solo afecta búsqueda, NO descargas)
                try
                {
                    autoSearchCts?.Cancel();
                }
                catch (Exception ex)
                {
                    AutoLog($"⚠️ Error cancelando token: {ex.Message}");
                }
                
                // Esperar un momento para que las tareas se cancelen
                AutoLog("⏳ Esperando que la búsqueda se detenga...");
                await Task.Delay(500).ConfigureAwait(false); // MEJORA #37

                // Guardar resultados al detener manualmente
                if (anyActive)
                {
                    int count;
                    lock (autoSearchResultsLock)
                    {
                        count = autoSearchResults.Count;
                    }
                    if (count > 0)
                    {
                        SaveAutoResultsToCsv();
                        AutoLog($"💾 Guardados {count} archivos en {autoResultsCsvPath}");
                    }
                }
                
                // Eliminar checkpoint si existe
                DeleteCheckpoint();

                // Esperar un poco más para que las colecciones se estabilicen
                await Task.Delay(200).ConfigureAwait(false); // MEJORA #37

                UpdateAutoControlsEnabled();
                AutoLog("✅ Búsqueda detenida - Las descargas continúan");
            };
            rightControls.Controls.Add(btnStopAuto);

            // (Movido al encabezado del log para que sea siempre visible)
            
            // Checkbox para descarga inmediata
            var chkInstantDownload = new CheckBox
            {
                Text = "⚡ Descarga inmediata",
                AutoSize = true,
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9, FontStyle.Bold),
                Checked = instantDownload,
                Margin = new Padding(3, 8, 12, 3)
            };
            chkInstantDownload.CheckedChanged += (s, e) =>
            {
                instantDownload = chkInstantDownload.Checked;
                SaveConfig();
                if (instantDownload)
                {
                    AutoLog("⚡ Descarga inmediata ACTIVADA - Los archivos se descargan al encontrarlos (estilo Nicotine+)");
                }
                else
                {
                    AutoLog("📋 Descarga inmediata DESACTIVADA - Acumular resultados antes de descargar");
                }
            };
            rightControls.Controls.Add(chkInstantDownload);

            btnNextBatch = new Button
            {
                Text = "➡️ Siguiente Lote (100)",
                AutoSize = true,
                BackColor = Color.FromArgb(0, 150, 136),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 9, FontStyle.Bold),
                Padding = new Padding(12, 6, 12, 6),
                Visible = false // Solo visible en modo incremental
            };
            btnNextBatch.FlatAppearance.BorderSize = 0;
            btnNextBatch.Margin = new Padding(3, 3, 8, 3);
            btnNextBatch.Click += async (s, e) => await LoadNextIncrementalBatch();
            rightControls.Controls.Add(btnNextBatch);

            var btnClearLog = new Button
            {
                Text = "🗑️ Limpiar Log",
                AutoSize = true,
                BackColor = Color.FromArgb(60, 60, 60),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 9),
                Padding = new Padding(12, 6, 12, 6)
            };
            btnClearLog.FlatAppearance.BorderSize = 0;
            btnClearLog.Margin = new Padding(3, 3, 8, 3);
            btnClearLog.Click += (s, e) => txtAutoLog.Clear();
            rightControls.Controls.Add(btnClearLog);

            

            btnOpenAutoResults = new Button
            {
                Text = "📄 Abrir resultados",
                AutoSize = true,
                BackColor = Color.FromArgb(60, 120, 60),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 9, FontStyle.Bold),
                Padding = new Padding(12, 6, 12, 6)
            };
            btnOpenAutoResults.FlatAppearance.BorderSize = 0;
            btnOpenAutoResults.Margin = new Padding(3, 3, 8, 3);
            btnOpenAutoResults.Click += (s, e) => OpenAutoResultsCsv();
            rightControls.Controls.Add(btnOpenAutoResults);

            

            rightPanel.Controls.Add(rightControls, 0, 2);

            splitContainer.Panel1.Controls.Add(leftPanel);
            splitContainer.Panel2.Controls.Add(rightPanel);

            mainLayout.Controls.Add(splitContainer, 0, 1);

            parent.Controls.Add(mainLayout);
            
            // === TOOLTIPS PARA PESTAÑA AUTOMÁTICA ===
            var tipsAuto = GetToolTip();
            tipsAuto.SetToolTip(btnStartAuto, "▶️ Iniciar búsqueda automática\nBusca archivos de todos los autores seleccionados\nProcesa en rondas hasta completar todos");
            tipsAuto.SetToolTip(btnStopAuto, "⏹️ Detener búsqueda\nDetiene la búsqueda automática en curso\nLas descargas activas continúan");
            tipsAuto.SetToolTip(chkInstantDownload, "⚡ Descarga inmediata\nDescarga archivos automáticamente al encontrarlos\n(Similar a Nicotine+)");
            tipsAuto.SetToolTip(btnPurge, "🧹 Iniciar purga\nElimina autores sin resultados de la lista\nÚtil para limpiar autores inactivos");
            tipsAuto.SetToolTip(btnNextBatch, "➡️ Siguiente lote\nCarga los próximos 100 autores\n(Solo en modo incremental)");
            tipsAuto.SetToolTip(btnOpenAutoResults, "📄 Abrir resultados\nAbre el archivo CSV con todos los resultados encontrados\nIncluye información de archivos, autores y fechas");
            // btnShowFilterStats no existe en esta versión
            // tipsAuto.SetToolTip(btnShowFilterStats, "📊 Ver estadísticas\nMuestra estadísticas detalladas del filtro de idioma\nIncluye cache hits, análisis realizados, etc.");

            void AdjustAutoSplit()
            {
                try
                {
                    if (splitContainer.ClientSize.Width <= 0)
                        return;

                    var available = splitContainer.ClientSize.Width; // ancho útil
                    var minLeft = splitContainer.Panel1MinSize;
                    var minRight = splitContainer.Panel2MinSize;
                    var splitter = splitContainer.SplitterWidth;

                    // Calcular 50% exacto
                    var desired = available / 2;

                    // Asegurar que respeta los mínimos
                    if (desired < minLeft)
                        desired = minLeft;
                    var maxDistance = available - splitter - minRight;
                    if (desired > maxDistance)
                        desired = maxDistance;

                    // Aplicar solo si es válido
                    if (maxDistance >= minLeft && desired >= minLeft && desired <= maxDistance)
                    {
                        if (splitContainer.SplitterDistance != desired)
                            splitContainer.SplitterDistance = desired;
                    }
                }
                catch { /* evitar error de rango en inicialización */ }
            }

            parent.HandleCreated += (_, _) => AdjustAutoSplit();
            parent.Resize += (_, _) => AdjustAutoSplit();
            parent.VisibleChanged += (_, _) => { if (parent.Visible) AdjustAutoSplit(); };
            splitContainer.SizeChanged += (_, _) => AdjustAutoSplit();
            
            // Ajustar también cuando el TabControl cambie de pestaña
            if (parent.Parent is TabControl tabControl)
            {
                tabControl.SelectedIndexChanged += (_, _) => 
                {
                    if (tabControl.SelectedTab == parent)
                        AdjustAutoSplit();
                };
            }

            // Cargar última ruta de archivo si existe
            LoadLastAuthorsFile();
            
            // Cargar resultados automáticos desde SQLite al iniciar
            Task.Run(() =>
            {
                try
                {
                    lock (autoSearchResultsLock)
                    {
                        if (autoSearchResults.Count == 0)
                        {
                            LoadFilesFromDatabase();
                        }
                    }
                    
                    // Actualizar UI en el hilo principal
                    if (autoSearchResults.Count > 0)
                    {
                        this.SafeInvoke(() =>
                        {
                            AutoLog($"📊 Cargados {autoSearchResults.Count:N0} archivos desde base de datos");
                        });
                    }
                }
                catch (Exception ex)
                {
                    AutoLog($"⚠️ Error cargando datos iniciales: {ex.Message}");
                }
            });
            
            // Inicializar estado de botones
            UpdateAutoControlsEnabled();
            RefreshAutoSummary();
        }
        
        private void LoadLastAuthorsFile()
        {
            try
            {
                var configFile = Path.Combine(dataDir, "auto_config.json");
                if (System.IO.File.Exists(configFile))
                {
                    var json = System.IO.File.ReadAllText(configFile);
                    var config = JsonSerializer.Deserialize<Dictionary<string, string>>(json);
                    if (config != null && config.ContainsKey("lastAuthorsFile"))
                    {
                        lastAuthorsFilePath = config["lastAuthorsFile"];
                        // NUEVO: Cargar automáticamente si existe (async para no bloquear UI)
                        if (System.IO.File.Exists(lastAuthorsFilePath))
                        {
                            AutoLog($"💡 Cargando automáticamente: {Path.GetFileName(lastAuthorsFilePath)}");
                            _ = LoadAuthorsFromFileAsync(lastAuthorsFilePath);
                            return;
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error al cargar configuración: {ex.Message}");
            }
            
            AutoLog("📚 Selecciona un archivo TXT con la lista de autores");
        }
        
        private void SelectAndLoadAuthorsFile()
        {
            var initialDir = !string.IsNullOrEmpty(lastAuthorsFilePath) ? Path.GetDirectoryName(lastAuthorsFilePath) : "";
            var filePath = DarkFileDialog.ShowOpenDialog(this, "Seleccionar archivo de autores", "Archivos de texto (*.txt)|*.txt|Todos los archivos (*.*)|*.*", initialDir);
            
            if (!string.IsNullOrWhiteSpace(filePath))
            {
                lastAuthorsFilePath = filePath;
                SaveLastAuthorsFile();
                
                // MODO INCREMENTAL AUTOMÁTICO
                StartIncrementalMode(filePath);
            }
        }
        
        private void SaveLastAuthorsFile()
        {
            try
            {
                var config = new Dictionary<string, string>
                {
                    ["lastAuthorsFile"] = lastAuthorsFilePath
                };
                var json = JsonSerializer.Serialize(config);
                var configFile = Path.Combine(dataDir, "auto_config.json");
                System.IO.File.WriteAllText(configFile, json);
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error al guardar configuración: {ex.Message}");
            }
        }
        
        private void DeleteSelectedAuthors()
        {
            var checkedAuthors = filteredAuthorsData.Where(a => a.IsChecked).ToList();
            
            if (checkedAuthors.Count == 0)
            {
                AutoLog("⚠️ No hay autores seleccionados para borrar");
                return;
            }
            
            var count = checkedAuthors.Count;
            var result = MessageBox.Show(
                $"¿Borrar {count} autor(es) seleccionado(s)?",
                "Confirmar borrado",
                MessageBoxButtons.YesNo,
                MessageBoxIcon.Question
            );
            
            if (result == DialogResult.Yes)
            {
                // Remover de ambas listas
                foreach (var author in checkedAuthors)
                {
                    allAuthorsData.Remove(author);
                    filteredAuthorsData.Remove(author);
                    authorIndex.Remove(author.Name);
                }
                
                // Actualizar el ListView
                RefreshAuthorsListView();
                UpdateAuthorCount();
                
                AutoLog($"🗑️ Borrados {count} autor(es)");
                
                // Guardar cambios en el archivo
                SaveAuthorsToFile();
            }
        }
        
        /// <summary>
        /// MEJORA #46: Purgar autores sin archivos disponibles usando StealthPurgeManager
        /// Valida todos los autores de la grilla y elimina los que no tienen archivos
        /// </summary>
        private async Task PurgeAuthorsWithoutFiles()
        {
            if (allAuthorsData.Count == 0)
            {
                AutoLog("⚠️ No hay autores en la lista");
                return;
            }
            
            // Verificar conexión
            if (client == null || 
                !client.State.HasFlag(SoulseekClientStates.Connected) || 
                !client.State.HasFlag(SoulseekClientStates.LoggedIn))
            {
                AutoLog("❌ Debes estar conectado para purgar autores");
                return;
            }
            
            var result = DarkMessageBox.Show(
                $"¿Validar {allAuthorsData.Count} autores y eliminar los que no tienen archivos?\n\n" +
                "Esto se realizará con modo stealth para evitar desconexiones.",
                "Confirmar purga",
                MessageBoxButtons.YesNo,
                MessageBoxIcon.Question
            );
            
            if (result != DialogResult.Yes)
                return;
            
            AutoLog($"🔍 Iniciando purga inteligente con StealthPurgeManager ({allAuthorsData.Count} autores)...");
            
            // Configurar callbacks de UI para el StealthPurgeManager
            var uiCallbacks = new SlskDown.Core.PurgeUICallbacks
            {
                OnProgress = (processed, total, percentage, validated, removed, speed, eta) =>
                {
                    SafeInvoke(() =>
                    {
                        // Actualizar EnhancedProgressControl
                        if (enhancedProgressControl != null)
                        {
                            var progress = new PurgeProgress
                            {
                                ProcessedItems = processed,
                                TotalItems = total,
                                ValidItems = validated,
                                InvalidItems = removed,
                                StartTime = DateTime.UtcNow.AddSeconds(-(processed / Math.Max(speed, 1)))
                            };
                            
                            // Determinar modo según velocidad
                            var mode = speed switch
                            {
                                < 5 => StealthPurgeManager.StealthMode.UltraStealth,
                                < 10 => StealthPurgeManager.StealthMode.Stealth,
                                _ => StealthPurgeManager.StealthMode.Conservative
                            };
                            
                            enhancedProgressControl.UpdateProgress(progress, mode);
                        }
                        
                        // Mantener lblPurgeStats como respaldo
                        if (lblPurgeStats != null)
                        {
                            lblPurgeStats.Text = $"📊 {processed}/{total} ({percentage:F1}%) | " +
                                                $"✅ {validated} | 🗑️ {removed} | " +
                                                $"⚡ {speed:F1}/min | ⏱️ ETA: {eta}";
                        }
                    });
                },
                
                OnAuthorValidated = (authorName, hasFiles, filesCount) =>
                {
                    if (!hasFiles)
                    {
                        SafeInvoke(() => 
                        {
                            var toRemove = new List<string> { authorName };
                            int dummyRemoved = 0;
                            RemoveAuthorsFromUIBatch(toRemove, 1, 1, ref dummyRemoved);
                        });
                    }
                    else
                    {
                        SafeInvoke(() => MarkAuthorAsValidated(authorName, filesCount));
                    }
                },
                
                OnLog = (message) => AutoLog(message),
                
                OnCompleted = (processed, removed, remaining, duration) =>
                {
                    AutoLog($"✅ Purga completada en {duration.TotalMinutes:F1} minutos: " +
                           $"🗑️ {removed} eliminados | 📊 {remaining} autores restantes");
                    
                    // Guardar autores válidos
                    var validAuthors = allAuthorsData.Where(a => !string.IsNullOrEmpty(a.Name)).Select(a => a.Name).ToList();
                    SaveAuthorsToFile(validAuthors);
                }
            };
            
            // Mostrar controles de progreso
            SafeInvoke(() =>
            {
                if (btnPurge != null) 
                {
                    btnPurge.Enabled = false;
                    btnPurge.Text = "⏳ Purgando...";
                }
                if (btnCancelPurge != null) btnCancelPurge.Visible = true;
                if (enhancedProgressControl != null)
                {
                    enhancedProgressControl.Visible = true;
                    enhancedProgressControl.Reset();
                }
                if (lblPurgeStats != null)
                {
                    lblPurgeStats.Visible = true;
                    lblPurgeStats.Text = "Iniciando...";
                }
            });
            
            try
            {
                // Obtener lista de autores
                var authorNames = allAuthorsData.Select(a => a.Name).ToList();
                
                // Ejecutar purga con StealthPurgeManager
                var purgeResult = await _stealthPurgeManager.PurgeAuthorsAsync(
                    authorNames,
                    uiCallbacks,
                    _purgeCts.Token);
                
                // Publicar evento de purga completada
                _eventBus?.Publish(SystemEvents.PurgeCompleted, new
                {
                    ProcessedAuthors = purgeResult.ProcessedCount,
                    RemovedAuthors = purgeResult.RemovedCount,
                    RemainingAuthors = purgeResult.RemainingCount,
                    Timestamp = DateTime.UtcNow
                });
            }
            catch (OperationCanceledException)
            {
                AutoLog("⏹️ Purga cancelada");
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error durante la purga: {ex.Message}");
            }
            finally
            {
                // Restaurar UI
                SafeInvoke(() =>
                {
                    if (btnPurge != null)
                    {
                        btnPurge.Enabled = true;
                        btnPurge.Text = "🔍 Purgar";
                    }
                    if (btnCancelPurge != null) btnCancelPurge.Visible = false;
                    if (enhancedProgressControl != null)
                    {
                        enhancedProgressControl.Stop();
                        enhancedProgressControl.Visible = false;
                    }
                    if (lblPurgeStats != null) lblPurgeStats.Visible = false;
                });
            }
        }
        
        /// <summary>
        /// OPTIMIZACIÓN: Cancelar purga en progreso
        /// </summary>
        private void CancelPurge()
        {
            if (_purgeCts != null && !_purgeCts.IsCancellationRequested)
            {
                AutoLog("⏹️ Cancelando purga...");
                _purgeCts.Cancel();
            }
            
            // Restaurar UI inmediatamente
            SafeInvoke(() =>
            {
                if (btnPurge != null)
                {
                    btnPurge.Enabled = true;
                    btnPurge.Text = "🔍 Purgar";
                }
                if (btnCancelPurge != null) btnCancelPurge.Visible = false;
                if (enhancedProgressControl != null)
                {
                    enhancedProgressControl.Stop();
                    enhancedProgressControl.Visible = false;
                }
                if (lblPurgeStats != null) lblPurgeStats.Visible = false;
            });
        }
        
        private async Task DownloadSelectedAuthorsFiles()
        {
            var checkedAuthors = filteredAuthorsData.Where(a => a.IsChecked).ToList();
            
            if (checkedAuthors.Count == 0)
            {
                AutoLog("⚠️ No hay autores seleccionados para descargar");
                DarkMessageBox.Show("Selecciona al menos un autor para descargar sus archivos", "Sin selección", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }
            
            // Obtener archivos de los autores seleccionados (con filtros aplicados)
            List<AutoSearchFileResult> filesToDownload;
            int totalFilesBeforeFilters;
            int totalFilesAfterFilters;
            int filteredByGarbage = 0;
            int filteredByDocument = 0;
            int filteredByLanguage = 0;
            int filteredByBlacklist = 0;
            
            bool checkSpanish = chkAutoSpanishDocuments?.Checked ?? false;
            
            lock (autoSearchResultsLock)
            {
                // MEJORA #18: Usar HashSet para evitar O(n*m) - reducir de O(n*m) a O(n)
                var checkedAuthorNames = new HashSet<string>(
                    checkedAuthors.Select(a => a.Name),
                    StringComparer.OrdinalIgnoreCase
                );
                
                var allFiles = autoSearchResults
                    .Where(f => checkedAuthorNames.Contains(f.Author))
                    .ToList();
                
                totalFilesBeforeFilters = allFiles.Count;
                
                // Aplicar filtros (igual que en la búsqueda automática)
                var filteredFiles = new List<AutoSearchFileResult>();
                
                foreach (var file in allFiles)
                {
                    // Filtro 1: Tamaño > 0
                    if (file.SizeBytes == 0) continue;
                    
                    // Filtro 2: No debe ser archivo basura
                    if (IsGarbageFile(file.FileName))
                    {
                        filteredByGarbage++;
                        continue;
                    }
                    
                    // Filtro 3: Debe ser documento
                    if (!IsDocumentFile(file.FileName))
                    {
                        filteredByDocument++;
                        continue;
                    }
                    
                    // Filtro 4: Idioma español (si está activado)
                    if (checkSpanish && !IsSpanishText(file.FileName))
                    {
                        filteredByLanguage++;
                        continue;
                    }
                    
                    // Filtro 5: No debe estar blacklisteado
                    if (IsFileBlacklisted(file.FileName, file.Username))
                    {
                        filteredByBlacklist++;
                        continue;
                    }
                    
                    filteredFiles.Add(file);
                }
                
                totalFilesAfterFilters = filteredFiles.Count;
                
                // Eliminar duplicados por nombre de archivo (mantener el de mejor proveedor)
                filesToDownload = filteredFiles
                    .GroupBy(f => f.FileName, StringComparer.OrdinalIgnoreCase)
                    .Select(g => g.OrderByDescending(f => GetProviderScore(f.Username)).First())
                    .ToList();
            }
            
            if (filesToDownload.Count == 0)
            {
                AutoLog($"⚠️ No hay archivos disponibles para los {checkedAuthors.Count} autor(es) seleccionado(s)");
                DarkMessageBox.Show(
                    $"No se encontraron archivos para los autores seleccionados.\n\nEjecuta una búsqueda automática primero.",
                    "Sin archivos",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Information
                );
                return;
            }
            
            var downloadPath = txtDownloadDir?.Text ?? Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments), "SlskDown");
            
            // Contar archivos existentes vs nuevos
            int existingFiles = 0;
            int newFiles = 0;
            foreach (var file in filesToDownload)
            {
                var fullPath = GetDownloadPath(file.FileName, file.Author);
                if (IsFileDownloaded(fullPath))
                    existingFiles++;
                else
                    newFiles++;
            }
            
            if (newFiles == 0)
            {
                DarkMessageBox.Show(
                    $"Todos los archivos ({existingFiles}) ya están descargados.\n\nUsa el botón '🔄 Redescargar' si quieres descargarlos de nuevo.",
                    "Archivos existentes",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Information
                );
                AutoLog($"⚠️ {existingFiles} archivo(s) ya descargado(s), omitidos");
                return;
            }
            
            string message = existingFiles == 0
                ? $"¿Descargar {newFiles} archivo(s) de {checkedAuthors.Count} autor(es)?"
                : $"¿Descargar {newFiles} archivo(s) nuevo(s) de {checkedAuthors.Count} autor(es)?\n({existingFiles} ya descargado(s) serán omitidos)";
            
            var result = MessageBox.Show(message, "Confirmar descarga", MessageBoxButtons.YesNo, MessageBoxIcon.Question);
            
            if (result == DialogResult.Yes)
            {
                AutoLog("═══════════════════════════════════════");
                AutoLog("📥 INICIANDO DESCARGA DE AUTORES SELECCIONADOS");
                AutoLog($"📊 Autores: {checkedAuthors.Count}");
                AutoLog($"📄 Archivos totales encontrados: {totalFilesBeforeFilters}");
                
                // Mostrar estadísticas de filtrado
                if (totalFilesBeforeFilters > totalFilesAfterFilters)
                {
                    AutoLog($"🔍 Filtros aplicados:");
                    if (filteredByGarbage > 0)
                        AutoLog($"   🗑️ Archivos basura: {filteredByGarbage}");
                    if (filteredByDocument > 0)
                        AutoLog($"   📋 No documentos: {filteredByDocument}");
                    if (filteredByLanguage > 0)
                        AutoLog($"   🌍 Otros idiomas: {filteredByLanguage}");
                    if (filteredByBlacklist > 0)
                        AutoLog($"   🚫 Blacklisteados: {filteredByBlacklist}");
                    AutoLog($"   ✅ Archivos válidos: {totalFilesAfterFilters}");
                }
                
                // Mostrar duplicados eliminados
                int duplicatesRemoved = totalFilesAfterFilters - filesToDownload.Count;
                if (duplicatesRemoved > 0)
                {
                    AutoLog($"   🔄 Duplicados eliminados: {duplicatesRemoved}");
                }
                
                AutoLog($"📄 Archivos únicos a procesar: {filesToDownload.Count}");
                AutoLog($"   • Nuevos a descargar: {newFiles}");
                AutoLog($"   • Ya descargados (omitidos): {existingFiles}");
                AutoLog($"📁 Destino: {downloadPath}");
                AutoLog("═══════════════════════════════════════");
                
                // Crear directorio si no existe
                if (!System.IO.Directory.Exists(downloadPath))
                {
                    System.IO.Directory.CreateDirectory(downloadPath);
                    AutoLog($"📂 Carpeta creada: {downloadPath}");
                }
                
                int added = 0;
                int skipped = 0;
                
                foreach (var file in filesToDownload)
                {
                    var fullPath = GetDownloadPath(file.FileName, file.Author);
                    
                    if (IsFileDownloaded(fullPath))
                    {
                        skipped++;
                    }
                    else
                    {
                        // Crear ListViewItem para la grilla de descargas
                        ListViewItem downloadItem = null;
                        SafeInvoke(() =>
                        {
                            downloadItem = new ListViewItem(file.FileName);
                            // Agregar indicador premium al username
                            string usernameDisplay = premiumUsers.Contains(file.Username) ? $"⭐ {file.Username}" : file.Username;
                            downloadItem.SubItems.Add(usernameDisplay);
                            downloadItem.SubItems.Add("0%");
                            downloadItem.SubItems.Add("⏳ En cola");
                            downloadItem.SubItems.Add(file.SizeReadable);
                            downloadItem.SubItems.Add(GetMetadataStatusSync(file.FileName));
                            downloadItem.Tag = file;
                            lvDownloads.Items.Add(downloadItem);
                        });
                        
                        AddToDownloadQueue(file, fullPath, downloadItem);
                        added++;
                    }
                }
                
                AutoLog($"✅ {added} archivo(s) agregado(s) a la cola de descargas");
                if (skipped > 0)
                    AutoLog($"⏭️ {skipped} archivo(s) omitido(s) (ya descargados)");
                AutoLog("═══════════════════════════════════════");
                
                // Cambiar a pestaña de descargas
                if (added > 0)
                {
                    SafeInvoke(() =>
                    {
                        var tabControl = (TabControl)this.Controls.Find("tabControl", true).FirstOrDefault();
                        if (tabControl != null)
                        {
                            for (int i = 0; i < tabControl.TabPages.Count; i++)
                            {
                                if (tabControl.TabPages[i].Text.Contains("Descargas"))
                                {
                                    tabControl.SelectedIndex = i;
                                    break;
                                }
                            }
                        }
                    });
                }
            }
        }
        
        private void SaveAuthorsToFile(IEnumerable<string>? authorsToPersist = null)
        {
            if (string.IsNullOrEmpty(lastAuthorsFilePath))
            {
                AutoLog("⚠️ No hay archivo cargado para guardar");
                return;
            }
            
            try
            {
                List<string> authors;

                if (authorsToPersist != null)
                {
                    authors = new List<string>();
                    var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

                    foreach (var author in authorsToPersist)
                    {
                        if (string.IsNullOrWhiteSpace(author))
                            continue;

                        var normalized = author.Trim();
                        if (seen.Add(normalized))
                        {
                            authors.Add(normalized);
                        }
                    }
                }
                else
                {
                    authors = allAuthorsData.Select(a => a.Name).ToList();
                }
                
                // Guardar con UTF-8 para preservar caracteres especiales
                System.IO.File.WriteAllLines(lastAuthorsFilePath, authors, System.Text.Encoding.UTF8);
                if (authors.Count == 0)
                {
                    AutoLog($"💾 Archivo {Path.GetFileName(lastAuthorsFilePath)} limpiado (0 autores)");
                }
                else
                {
                    AutoLog($"💾 Guardados {authors.Count} autores en {Path.GetFileName(lastAuthorsFilePath)}");
                }
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error al guardar archivo: {ex.Message}");
                DarkMessageBox.Show($"Error al guardar:\n{ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
        private async Task LoadAuthorsListAsync()
        {
            try
            {
                var filePath = DarkFileDialog.ShowOpenDialog(this, "Cargar lista de autores", "TXT|*.txt|Todos|*.*");
                if (string.IsNullOrWhiteSpace(filePath))
                {
                    return; // Usuario canceló
                }
                
                await LoadAuthorsFromFileAsync(filePath);
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error al cargar lista: {ex.Message}");
                DarkMessageBox.Show($"Error al cargar lista:\n{ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
        private async Task LoadAuthorsFromFileAsync(string filePath)
        {
            try
            {
                if (!System.IO.File.Exists(filePath))
                {
                    AutoLog($"❌ No se encontró el archivo: {filePath}");
                    return;
                }
                
                AutoLog($"⏳ Cargando autores desde {Path.GetFileName(filePath)}...");
                var sw = System.Diagnostics.Stopwatch.StartNew();
                
                // Leer archivo en background thread
                var authorsFromFile = await Task.Run(() => 
                {
                    return System.IO.File.ReadAllLines(filePath, System.Text.Encoding.UTF8)
                        .Where(line => !string.IsNullOrWhiteSpace(line))
                        .Select(line => line.Trim())
                        .ToList();
                });
                
                AutoLog($"   📄 Leídos {authorsFromFile.Count:N0} autores del archivo");
                
                // PROCESAMIENTO EN CHUNKS DE 1000 AUTORES
                const int CHUNK_SIZE = 1000;
                int totalChunks = (int)Math.Ceiling((double)authorsFromFile.Count / CHUNK_SIZE);
                AutoLog($"   📦 Dividiendo en {totalChunks} chunks de {CHUNK_SIZE} autores");
                AutoLog($"   🔄 Expandiendo variantes (puntos/tildes)...");
                
                var expanded = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                
                for (int chunkIndex = 0; chunkIndex < totalChunks; chunkIndex++)
                {
                    int startIdx = chunkIndex * CHUNK_SIZE;
                    int count = Math.Min(CHUNK_SIZE, authorsFromFile.Count - startIdx);
                    var chunk = authorsFromFile.Skip(startIdx).Take(count).ToList();
                    
                    AutoLog($"      📦 Chunk {chunkIndex + 1}/{totalChunks}: Procesando {count} autores ({startIdx:N0}-{startIdx + count - 1:N0})...");
                    
                    // Procesar chunk en background
                    await Task.Run(() =>
                    {
                        foreach (var author in chunk)
                        {
                            // Agregar versión original
                            expanded.Add(author);
                            
                            // Generar variantes normalizadas para deduplicación
                            // Ejemplos: "A. E. Nombre" → "A A Nombre", "AA Nombre", "A. A. Nombre", "A.A. Nombre"
                            
                            // Variante sin puntos
                            if (author.Contains('.'))
                            {
                                var withoutDots = author.Replace(".", "");
                                if (!string.IsNullOrWhiteSpace(withoutDots))
                                {
                                    expanded.Add(withoutDots); // A E Nombre
                                    
                                    // Variante sin puntos y con espacios normalizados
                                    var normalized = RegexWhitespaceNormalize.Replace(withoutDots, " ").Trim();
                                    if (!string.IsNullOrWhiteSpace(normalized))
                                    {
                                        expanded.Add(normalized); // AA Nombre (espacios múltiples → uno)
                                    }
                                }
                                
                                // Variante con puntos pero sin espacios entre iniciales
                                // "A. E. Nombre" → "A.E. Nombre"
                                var withDotsNoSpaces = System.Text.RegularExpressions.Regex.Replace(
                                    author, 
                                    @"\.(\s+)(?=[A-Z]\.)", // Punto seguido de espacios y otra inicial con punto
                                    "."  // Reemplazar por solo punto
                                );
                                if (withDotsNoSpaces != author && !string.IsNullOrWhiteSpace(withDotsNoSpaces))
                                {
                                    expanded.Add(withDotsNoSpaces); // A.E. Nombre
                                }
                            }
                            
                            // Variante sin tildes
                            var withoutAccents = RemoveAccents(author);
                            expanded.Add(withoutAccents);
                            
                            // NUEVAS VARIACIONES: Solo iniciales con puntos
                            if (author.Contains('.'))
                            {
                                // Extraer solo las iniciales con puntos: "A. A. Pepito" → "A.A."
                                var initialsOnly = System.Text.RegularExpressions.Regex.Match(
                                    author, 
                                    @"(?:[A-Z]\.\s*)+"  // Capturar secuencias de "A. "
                                ).Value.Trim();
                                
                                if (!string.IsNullOrWhiteSpace(initialsOnly) && initialsOnly.Length > 2)
                                {
                                    expanded.Add(initialsOnly); // A.A.
                                }
                                
                                // Variante: Espacios garantizados después de puntos
                                // "A.A.Pepito" → "A. A. Pepito"
                                var withSpacesAfterDots = System.Text.RegularExpressions.Regex.Replace(
                                    author, 
                                    @"\.([A-Z])",  // Punto seguido de letra
                                    ". $1"         // Reemplazar por punto, espacio, letra
                                );
                                if (withSpacesAfterDots != author && !string.IsNullOrWhiteSpace(withSpacesAfterDots))
                                {
                                    expanded.Add(withSpacesAfterDots);
                                }
                            }
                            
                            // Variante sin puntos ni tildes
                            if (author.Contains('.'))
                            {
                                var withoutDotsOrAccents = RemoveAccents(author.Replace(".", ""));
                                if (!string.IsNullOrWhiteSpace(withoutDotsOrAccents))
                                {
                                    expanded.Add(withoutDotsOrAccents);
                                    
                                    // Variante completamente normalizada (sin puntos, sin tildes, espacios normalizados)
                                    var fullyNormalized = RegexWhitespaceNormalize.Replace(withoutDotsOrAccents, " ").Trim();
                                    if (!string.IsNullOrWhiteSpace(fullyNormalized))
                                    {
                                        expanded.Add(fullyNormalized);
                                    }
                                }
                            }
                        }
                    });
                    
                    AutoLog($"      ✅ Chunk {chunkIndex + 1}/{totalChunks} completado ({expanded.Count:N0} autores únicos acumulados)");
                    
                    // Pequeño delay para que la UI responda
                    await Task.Delay(10).ConfigureAwait(false); // MEJORA #37
                }
                
                AutoLog($"   🔍 Deduplicando y ordenando {expanded.Count:N0} autores...");
                var authors = await Task.Run(() => expanded.OrderBy(a => a).ToArray());
                
                if (authors.Length == 0)
                {
                    AutoLog($"⚠️ El archivo está vacío: {Path.GetFileName(filePath)}");
                    return;
                }
                
                // Usar VirtualMode para cargar eficientemente (en UI thread)
                await LoadAuthorsIntoVirtualListAsync(authors);
                
                // Forzar actualización de la grilla (ignorar throttling)
                lastAuthorsRefresh = DateTime.MinValue;
                
                sw.Stop();
                var originalCount = authorsFromFile.Count;
                var expandedCount = expanded.Count;
                var finalCount = authors.Length;
                
                AutoLog($"✅ Cargados {finalCount:N0} autores únicos en {sw.Elapsed.TotalSeconds:F1}s");
                if (expandedCount > originalCount)
                {
                    AutoLog($"   📝 Expandidos: {originalCount:N0} → {expandedCount:N0} (variantes sin puntos/tildes)");
                    AutoLog($"   🔍 Únicos: {finalCount:N0} (después de deduplicar)");
                }
                AutoLog($"   ⚡ Procesado en {totalChunks} chunks de {CHUNK_SIZE} autores (evita bloqueos)");
                
                // También mostrar en log principal
                Log($"📚 Cargados {finalCount:N0} autores desde {Path.GetFileName(filePath)}");
                
                // MEJORA #46: Validación automática desactivada (usar botón 'Purgar' manualmente)
                // AutoLog($"");
                // AutoLog($"🔍 Validando autores automáticamente...");
                // AutoLog($"   💡 Esto puede tardar unos minutos. Usa 'Purgar' después para eliminar los que no tienen obras.");
                // _ = ValidateAuthorsAfterLoad();
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error al cargar autores: {ex.Message}");
            }
        }
        
        // ============================================
        // MODO INCREMENTAL: Cargar 1000 → Purgar → Guardar → Siguiente 1000
        // ============================================
        
        private void StartIncrementalMode(string filePath)
        {
            try
            {
                incrementalSourceFile = filePath;
                incrementalTempFile = Path.Combine(
                    Path.GetDirectoryName(incrementalSourceFile),
                    Path.GetFileNameWithoutExtension(incrementalSourceFile) + "_no_purgados.txt"
                );
                
                // SOLO CONTAR LÍNEAS - NO CARGAR EN MEMORIA
                totalLinesInFile = System.IO.File.ReadLines(incrementalSourceFile)
                    .Count(line => !string.IsNullOrWhiteSpace(line));
                
                currentLineIndex = 0;
                
                AutoLog($"📦 MODO INCREMENTAL ACTIVADO (SIN CARGAR EN MEMORIA)");
                AutoLog($"   📄 Archivo: {Path.GetFileName(incrementalSourceFile)}");
                AutoLog($"   📊 Total autores: {totalLinesInFile:N0}");
                AutoLog($"   📦 Lotes de {INCREMENTAL_BATCH_SIZE}: {Math.Ceiling((double)totalLinesInFile / INCREMENTAL_BATCH_SIZE):N0}");
                AutoLog($"   💾 Guardará no purgados en: {Path.GetFileName(incrementalTempFile)}");
                AutoLog($"   🚀 Modo streaming: Lee del disco solo lo necesario");
                AutoLog($"");
                AutoLog($"🎯 FLUJO:");
                AutoLog($"   1️⃣ Cargar 100 autores");
                AutoLog($"   2️⃣ Purgar con '🧹 Iniciar Purga'");
                AutoLog($"   3️⃣ Clic en '➡️ Siguiente Lote' (guarda no purgados y carga siguientes 100)");
                AutoLog($"   4️⃣ Repetir hasta terminar");
                
                // Mostrar botón de siguiente lote
                if (btnNextBatch != null)
                    btnNextBatch.Visible = true;
                
                // Cargar primer lote
                _ = LoadNextIncrementalBatch();
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error al iniciar modo incremental: {ex.Message}");
            }
        }
        
        private async Task LoadNextIncrementalBatch()
        {
            try
            {
                // PASO 1: Guardar autores actuales que NO fueron purgados (si hay autores cargados)
                if (currentLineIndex > 0 && allAuthorsData.Count > 0)
                {
                    AutoLog($"💾 Guardando autores no purgados del lote anterior...");
                    var nonPurgedAuthors = allAuthorsData.Select(a => a.Name).ToList();
                    
                    // Append al archivo temporal
                    await Task.Run(() =>
                    {
                        System.IO.File.AppendAllLines(incrementalTempFile, nonPurgedAuthors);
                    });
                    
                    AutoLog($"   ✅ Guardados {nonPurgedAuthors.Count:N0} autores no purgados");
                }
                
                // PASO 2: Limpiar lista actual
                allAuthorsData.Clear();
                filteredAuthorsData.Clear();
                authorIndex.Clear();
                RefreshAuthorsListView();
                
                // PASO 3: Leer siguiente lote de 100 líneas DEL ARCHIVO (streaming)
                var batch = await Task.Run(() =>
                {
                    var lines = new List<string>();
                    int linesRead = 0;
                    int targetLines = INCREMENTAL_BATCH_SIZE;
                    
                    using (var reader = new StreamReader(incrementalSourceFile))
                    {
                        string line;
                        int lineNumber = 0;
                        
                        while ((line = reader.ReadLine()) != null)
                        {
                            // Saltar líneas hasta llegar a currentLineIndex
                            if (lineNumber < currentLineIndex)
                            {
                                lineNumber++;
                                continue;
                            }
                            
                            // Leer solo líneas no vacías
                            if (!string.IsNullOrWhiteSpace(line))
                            {
                                lines.Add(line.Trim());
                                linesRead++;
                                
                                if (linesRead >= targetLines)
                                    break;
                            }
                            
                            lineNumber++;
                        }
                    }
                    
                    return lines;
                });
                
                // Verificar si terminamos
                if (batch.Count == 0)
                {
                    AutoLog($"");
                    AutoLog($"✅ MODO INCREMENTAL COMPLETADO");
                    AutoLog($"   📊 Todos los lotes procesados");
                    if (System.IO.File.Exists(incrementalTempFile))
                    {
                        var nonPurgedCount = System.IO.File.ReadLines(incrementalTempFile).Count();
                        AutoLog($"   💾 Autores no purgados guardados: {nonPurgedCount:N0}");
                        AutoLog($"   📁 Archivo: {Path.GetFileName(incrementalTempFile)}");
                    }
                    
                    if (btnNextBatch != null)
                        btnNextBatch.Visible = false;
                    
                    return;
                }
                
                int totalBatches = (int)Math.Ceiling((double)totalLinesInFile / INCREMENTAL_BATCH_SIZE);
                int currentBatch = (currentLineIndex / INCREMENTAL_BATCH_SIZE) + 1;
                
                AutoLog($"");
                AutoLog($"📦 LOTE {currentBatch}/{totalBatches}");
                AutoLog($"   📊 Leyendo {batch.Count:N0} autores del disco (líneas {currentLineIndex:N0} - {currentLineIndex + batch.Count - 1:N0})");
                AutoLog($"   ⏳ Expandiendo variantes...");
                
                // PASO 4: Expandir variantes (sin puntos/tildes)
                // Genera: "A A Nombre", "AA Nombre", "A. A. Nombre", "A.A. Nombre"
                var expanded = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                await Task.Run(() =>
                {
                    foreach (var author in batch)
                    {
                        // Original
                        expanded.Add(author);
                        
                        // Variante sin puntos
                        if (author.Contains('.'))
                        {
                            var withoutDots = author.Replace(".", "");
                            if (!string.IsNullOrWhiteSpace(withoutDots))
                            {
                                expanded.Add(withoutDots); // A E Nombre
                                
                                // Variante sin puntos y espacios normalizados
                                var normalized = RegexWhitespaceNormalize.Replace(withoutDots, " ").Trim();
                                if (!string.IsNullOrWhiteSpace(normalized))
                                {
                                    expanded.Add(normalized); // AA Nombre
                                }
                            }
                            
                            // Variante con puntos pero sin espacios entre iniciales
                            // "A. E. Nombre" → "A.E. Nombre"
                            var withDotsNoSpaces = System.Text.RegularExpressions.Regex.Replace(
                                author, 
                                @"\.(\s+)(?=[A-Z]\.)", 
                                "."
                            );
                            if (withDotsNoSpaces != author && !string.IsNullOrWhiteSpace(withDotsNoSpaces))
                            {
                                expanded.Add(withDotsNoSpaces); // A.E. Nombre
                            }
                        }
                        
                        // Variante sin tildes
                        var withoutAccents = RemoveAccents(author);
                        if (!string.IsNullOrWhiteSpace(withoutAccents))
                        {
                            expanded.Add(withoutAccents);
                        }
                        
                        // Variante sin puntos ni tildes
                        if (author.Contains('.'))
                        {
                            var withoutDotsOrAccents = RemoveAccents(author.Replace(".", ""));
                            if (!string.IsNullOrWhiteSpace(withoutDotsOrAccents))
                            {
                                expanded.Add(withoutDotsOrAccents);
                                
                                // Completamente normalizada
                                var fullyNormalized = RegexWhitespaceNormalize.Replace(withoutDotsOrAccents, " ").Trim();
                                if (!string.IsNullOrWhiteSpace(fullyNormalized))
                                {
                                    expanded.Add(fullyNormalized);
                                }
                            }
                        }
                    }
                });
                
                var authors = expanded.OrderBy(a => a).ToArray();
                
                // PASO 5: Cargar en lista virtual
                await LoadAuthorsIntoVirtualListAsync(authors);
                
                // Forzar actualización de la grilla (ignorar throttling)
                lastAuthorsRefresh = DateTime.MinValue;
                
                AutoLog($"   ✅ Cargados {authors.Length:N0} autores únicos (expandidos desde {batch.Count:N0})");
                AutoLog($"   🧹 Ahora usa 'Iniciar Purga' para purgar este lote");
                AutoLog($"   ➡️ Después usa 'Siguiente Lote' para continuar");
                
                // Avanzar índice de línea
                currentLineIndex += batch.Count;
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error al cargar siguiente lote: {ex.Message}");
            }
        }
        
        private readonly string autoLogFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "auto_log.txt");
        private readonly string diagnosticLogFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "diagnostic_log.txt");
        private System.Threading.Timer logFlushTimer;
        private readonly object logFlushLock = new object();

        private void AutoLog(string message)
        {
            if (message != null && message.IndexOf("Agregado a cola", StringComparison.OrdinalIgnoreCase) >= 0)
            {
                try { secondaryLogger?.Invoke(message); } catch {}
                return;
            }
            if (txtAutoLog != null)
            {
                // OPTIMIZACIÓN: Usar StringBuilder cacheado
                var sb = GetStringBuilder();
                
                // Agregar estado de conexión (sin hora)
                bool isConnected = client != null && 
                    (client.State.HasFlag(SoulseekClientStates.Connected) || 
                     client.State.HasFlag(SoulseekClientStates.LoggedIn));
                sb.Append(isConnected ? "[SI] " : "[NO] ");
                
                sb.Append(message);
                sb.Append("\r\n");
                // Autoscroll: solo si el usuario estaba al final antes de agregar
                bool wasAtEnd = (txtAutoLog.SelectionStart + txtAutoLog.SelectionLength) >= txtAutoLog.TextLength;
                txtAutoLog.AppendText(sb.ToString());
                if (wasAtEnd)
                {
                    txtAutoLog.SelectionStart = txtAutoLog.TextLength;
                    txtAutoLog.SelectionLength = 0;
                    txtAutoLog.ScrollToCaret();
                }
            }
            
            // También escribir en logger secundario si existe (ventana de descargas)
            secondaryLogger?.Invoke(message);
        }
        
        /// <summary>
        /// Log crítico que se escribe INMEDIATAMENTE a disco (para diagnóstico de crashes)
        /// </summary>
        private void CriticalLog(string message)
        {
            try
            {
                // MEJORA #28: Usar UtcNow (más rápido que Now)
                var timestamp = DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss.fff");
                var logMessage = $"[{timestamp}] {message}\r\n";
                
                // Escribir a archivo con flush inmediato
                lock (logFlushLock)
                {
                    System.IO.File.AppendAllText(diagnosticLogFile, logMessage, System.Text.Encoding.UTF8);
                }
                
                // También mostrar en UI
                AutoLog(message);
            }
            catch
            {
                // Si falla el log, al menos intentar mostrar en UI
                try { AutoLog(message); } catch { }
            }
        }
        
        private void UpdateAuthorInList(string authorName, int totalFiles, string status, bool reset = false)
        {
            // OPTIMIZACIÓN: Usar batch updates si está habilitado
            if (useBatchUIUpdates && pendingAutoSearchUIUpdates != null)
            {
                // Agregar a cola para procesamiento en batch
                pendingAutoSearchUIUpdates.Enqueue((authorName, totalFiles, status, null));
            }
            else
            {
                // Actualización directa (legacy)
                UpdateAuthorData(authorName, totalFiles, status);
            }
        }
        
        /// <summary>
        /// MEJORA #4: Procesa actualizaciones UI en batch (hasta MAX_UI_UPDATES_PER_BATCH por tick)
        /// </summary>
        private void ProcessAutoSearchUIBatch()
        {
            if (pendingAutoSearchUIUpdates == null || pendingAutoSearchUIUpdates.IsEmpty)
                return;
            
            int processed = 0;
            
            while (processed < MAX_UI_UPDATES_PER_BATCH && pendingAutoSearchUIUpdates.TryDequeue(out var update))
            {
                try
                {
                    UpdateAuthorData(update.author, update.filesCount, update.status);
                    processed++;
                }
                catch { }
            }
        }
        
        /// <summary>
        /// MEJORA #46: Validación rápida de autor (solo verifica SI tiene archivos, sin descargar lista)
        /// Mucho más rápido y usa menos ancho de banda que una búsqueda completa
        /// </summary>
        private async Task<(bool hasFiles, int responseCount)> QuickValidateAuthor(
            string author,
            CancellationToken cancellationToken)
        {
            try
            {
                // Verificar conexión
                if (client == null || 
                    !client.State.HasFlag(SoulseekClientStates.Connected) || 
                    !client.State.HasFlag(SoulseekClientStates.LoggedIn))
                {
                    return (false, 0);
                }
                
                // Búsqueda ultra-rápida: solo verificar SI hay resultados
                var (search, responses) = await client.SearchAsync(
                    SearchQuery.FromText(author),
                    options: new Soulseek.SearchOptions(
                        searchTimeout: 5000,        // 5 segundos (conservador)
                        responseLimit: 1,           // Solo 1 respuesta para verificar existencia
                        filterResponses: false,     // No filtrar
                        minimumResponseFileCount: 1 // Al menos 1 archivo
                    ),
                    cancellationToken: cancellationToken);
                
                int responseCount = responses?.Count ?? 0;
                bool hasFiles = responseCount > 0;
                return (hasFiles, responseCount);
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error validando {author}: {ex.Message}");
                return (false, 0);
            }
        }
        
        /// <summary>
        /// Validar un solo autor y devolver si tiene archivos
        /// </summary>
        private async Task<bool> QuickValidateSingleAuthor(string author, CancellationToken cancellationToken)
        {
            var (hasFiles, _) = await QuickValidateAuthor(author, cancellationToken);
            return hasFiles;
        }
        
        /// <summary>
        /// MEJORA #46: Validación masiva de autores en paralelo (ultra-rápido)
        /// Útil para pre-filtrar listas grandes antes de búsqueda completa
        /// </summary>
        private async Task<Dictionary<string, (bool hasFiles, int responseCount)>> QuickValidateAuthors(
            List<string> authors,
            CancellationToken cancellationToken,
            int maxParallel = 10)
        {
            var results = new ConcurrentDictionary<string, (bool, int)>();
            var semaphore = new SemaphoreSlim(maxParallel, maxParallel);
            
            var tasks = authors.Select(async author =>
            {
                await semaphore.WaitAsync(cancellationToken).ConfigureAwait(false);
                try
                {
                    var (hasFiles, count) = await QuickValidateAuthor(author, cancellationToken).ConfigureAwait(false);
                    results[author] = (hasFiles, count);
                    
                    // Log progreso
                    var icon = hasFiles ? "✅" : "❌";
                    var detail = hasFiles ? $"({count} usuarios)" : "(sin archivos)";
                    AutoLog($"{icon} {author} {detail}");
                }
                finally
                {
                    semaphore.Release();
                }
            });
            
            await Task.WhenAll(tasks).ConfigureAwait(false);
            
            return results.ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
        }
        
        /// <summary>
        /// MEJORA #46: Validar todos los autores después de cargar y actualizar la grilla con número de obras
        /// </summary>
        private async Task ValidateAuthorsAfterLoad()
        {
            if (allAuthorsData.Count == 0)
            {
                AutoLog("⚠️ No hay autores para validar");
                return;
            }
            
            // Verificar conexión
            if (client == null || 
                !client.State.HasFlag(SoulseekClientStates.Connected) || 
                !client.State.HasFlag(SoulseekClientStates.LoggedIn))
            {
                AutoLog("⚠️ Debes estar conectado para validar autores");
                AutoLog("   💡 Conéctate y luego usa el botón 'Purgar' para validar");
                return;
            }
            
            var sw = System.Diagnostics.Stopwatch.StartNew();
            var cts = new CancellationTokenSource();
            var authorNames = allAuthorsData.Select(a => a.Name).ToList();
            
            try
            {
                AutoLog($"⏳ Validando {authorNames.Count:N0} autores (10 en paralelo)...");
                
                // Validar todos en paralelo
                var validationResults = await QuickValidateAuthors(authorNames, cts.Token, maxParallel: 10);
                
                // Actualizar la grilla con el número de obras
                int authorsWithFiles = 0;
                int authorsWithoutFiles = 0;
                
                foreach (var author in allAuthorsData)
                {
                    if (validationResults.TryGetValue(author.Name, out var result))
                    {
                        if (result.hasFiles)
                        {
                            author.FilesCount = result.responseCount; // Actualizar número de obras
                            author.ProvidersCount = result.responseCount; // Número de usuarios que tienen archivos
                            authorsWithFiles++;
                        }
                        else
                        {
                            author.FilesCount = 0;
                            author.ProvidersCount = 0;
                            authorsWithoutFiles++;
                        }
                    }
                }
                
                // Actualizar UI
                RefreshAuthorsListView();
                
                sw.Stop();
                AutoLog($"");
                AutoLog($"✅ Validación completada en {sw.Elapsed.TotalMinutes:F1} minutos");
                AutoLog($"   ✅ Con archivos: {authorsWithFiles:N0} autores");
                AutoLog($"   ❌ Sin archivos: {authorsWithoutFiles:N0} autores");
                AutoLog($"   💡 Usa el botón 'Purgar' para eliminar los {authorsWithoutFiles:N0} autores sin archivos");
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error durante la validación: {ex.Message}");
            }
        }
        
        /// <summary>
        /// Busca archivos de un autor con caché para evitar búsquedas duplicadas
        /// </summary>
        private async Task<List<AutoSearchFileResult>> SearchAuthorWithCache(
            string author, 
            CancellationToken cancellationToken)
        {
            // Verificar caché primero
            if (authorSearchCache.TryGetValue(author, out var cached))
            {
                if (DateTime.UtcNow - cached.cachedAt < searchCacheExpiration)
                {
                    AutoLog($"✅ Caché hit para {author} ({cached.results.Count} archivos, edad: {(DateTime.UtcNow - cached.cachedAt).TotalHours:F1}h)");
                    return cached.results;
                }
                else
                {
                    // Caché expirado, remover
                    authorSearchCache.TryRemove(author, out _);
                }
            }
            
            // No está en caché o expiró, realizar búsqueda
            var validFiles = new List<AutoSearchFileResult>();
            
            try
            {
                long autoMinSearchSizeKB = 0;
                // SafeInvoke(() => autoMinSearchSizeKB = (long)(numAutoMinSearchSize?.Value ?? 0)); // TODO: Definir numAutoMinSearchSize
                
                // Buscar en Soulseek
                if (_networkConfig.SoulseekEnabled)
                {
                    // Verificar conexión Soulseek
                    if (client != null && 
                        client.State.HasFlag(SoulseekClientStates.Connected) && 
                        client.State.HasFlag(SoulseekClientStates.LoggedIn))
                    {
                        try
                        {
                            var results = await client.SearchAsync(
                                SearchQuery.FromText(author),
                                options: new Soulseek.SearchOptions(
                                    searchTimeout: 3000,
                                    maximumPeerQueueLength: 15000,
                                    filterResponses: true,
                                    responseLimit: 1,
                                    minimumResponseFileCount: 1,
                                    minimumPeerUploadSpeed: 0),
                                cancellationToken: cancellationToken);
                            
                            var responses = results.Responses;
                            
                            if (responses != null)
                            {
                                int slskCount = 0;
                                foreach (var response in responses)
                                {
                                    if (response.Files == null) continue;
                                    foreach (var f in response.Files)
                                    {
                                        if (!IsDocumentFile(f.Filename)) continue;
                                        bool isSpanish = IsSpanishText(f.Filename);
                                        if (chkAutoSpanishDocuments?.Checked == true && !isSpanish) continue;
                                        if (autoMinSearchSizeKB > 0 && f.Size < (long)autoMinSearchSizeKB * 1024L) continue;
                                        
                                        validFiles.Add(new AutoSearchFileResult
                                        {
                                            Author = author,
                                            FileName = f.Filename,
                                            Directory = "",
                                            SizeBytes = f.Size,
                                            SizeReadable = FormatFileSize(f.Size),
                                            IsSpanish = isSpanish,
                                            IsDocument = IsDocumentFile(f.Filename),
                                            Timestamp = DateTime.Now,
                                            Username = response.Username,
                                            Network = "Soulseek"
                                        });
                                        slskCount++;
                                    }
                                }
                                
                                if (slskCount > 0)
                                {
                                    AutoLog($"🔵 Soulseek: {slskCount} resultados para {author}");
                                }
                            }
                        }
                        catch (Exception slskEx)
                        {
                            AutoLog($"⚠️ Error en búsqueda Soulseek para {author}: {slskEx.Message}");
                        }
                    }
                    else
                    {
                        AutoLog($"⚠️ Soulseek habilitado pero no conectado para {author}");
                    }
                }
                
                // Guardar en caché
                if (validFiles.Any())
                {
                    authorSearchCache[author] = (validFiles, DateTime.UtcNow);
                    
                    // Log detallado por red
                    var byNetwork = validFiles.GroupBy(f => f.Network).ToDictionary(g => g.Key, g => g.Count());
                    var networkSummary = string.Join(", ", byNetwork.Select(kv => $"{kv.Key}: {kv.Value}"));
                    AutoLog($"💾 Caché guardado para {author} ({validFiles.Count} archivos - {networkSummary})");
                }
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error buscando {author}: {ex.Message}");
            }
            
            return validFiles;
        }
        
        private void UpdateAuthorStatus(string authorName, string status)
        {
            // Búsqueda O(1) con índice
            if (authorIndex.TryGetValue(authorName, out var author))
            {
                author.Status = status;
                
                // OPTIMIZACIÓN: Actualizar solo el item específico en lugar de refrescar toda la lista
                if (lvAutoAuthors != null && lvAutoAuthors.InvokeRequired)
                {
                    lvAutoAuthors.BeginInvoke(new Action(() => UpdateSingleAuthorItem(authorName, status)));
                }
                else
                {
                    UpdateSingleAuthorItem(authorName, status);
                }
            }
        }
        
        // MEJORA #7: Actualizar UI de progreso con ETA
        private void UpdatePurgeProgressUI()
        {
            if (purgeProgressTracker == null) return;
            
            try
            {
                var progressString = purgeProgressTracker.GetProgressString(includeETA: true, includeSpeed: true);
                var progressBar = purgeProgressTracker.GetProgressBar(20);
                
                SafeInvoke(() =>
                {
                    if (lblPurgeProgress != null)
                    {
                        lblPurgeProgress.Text = $"⏳ {progressString}";
                        lblPurgeProgress.Visible = true;
                    }
                    
                    if (lblAutoProgress != null)
                    {
                        lblAutoProgress.Text = $"{progressBar} {progressString}";
                    }
                });
                
                // Log periódico (cada 10 autores)
                if (purgeProgressTracker.ItemsProcessed % 10 == 0)
                {
                    AutoLog($"📊 {purgeProgressTracker.GetCompactSummary()}");
                }
            }
            catch
            {
                // Ignorar errores de UI
            }
        }
        
        private void UpdateSingleAuthorItem(string authorName, string status)
        {
            if (lvAutoAuthors == null) return;
            
            try
            {
                // Buscar el índice del autor en filteredAuthorsData
                int index = filteredAuthorsData.FindIndex(a => a.Name.Equals(authorName, StringComparison.OrdinalIgnoreCase));
                
                if (index >= 0 && index < lvAutoAuthors.Items.Count)
                {
                    // Actualizar solo el subitem de estado (columna 2)
                    lvAutoAuthors.Items[index].SubItems[2].Text = status ?? "";
                    try { lvAutoAuthors.RedrawItems(index, index, true); } catch { try { lvAutoAuthors.Invalidate(lvAutoAuthors.Items[index].Bounds); } catch { } }
                }
            }
            catch
            {
                // Si falla, ignorar (no bloquear la purga)
            }
        }
        
        private void UpdateSingleAuthorItemFull(string authorName, int filesCount, string status, Color? foreColor)
        {
            if (lvAutoAuthors == null) return;
            
            try
            {
                // Buscar el índice del autor en filteredAuthorsData
                int index = filteredAuthorsData.FindIndex(a => a.Name.Equals(authorName, StringComparison.OrdinalIgnoreCase));
                
                if (index >= 0 && index < lvAutoAuthors.Items.Count)
                {
                    var item = lvAutoAuthors.Items[index];
                    var author = filteredAuthorsData[index];
                    
                    // Actualizar archivos (columna 1)
                    item.SubItems[1].Text = filesCount.ToString();
                    
                    // MEJORA #5: Agregar icono al estado para mejor visualización
                    string statusIcon = UIColors.GetStatusIcon(status);
                    item.SubItems[2].Text = $"{statusIcon} {status ?? ""}";

                    // Actualizar 'Última búsqueda' (columna 3 si existe)
                    if (item.SubItems.Count > 3)
                    {
                        item.SubItems[3].Text = DateTime.Now.ToString("dd/MM HH:mm");
                    }
                    
                    // Actualizar 'Procesado' (columna 4)
                    if (item.SubItems.Count > 4)
                    {
                        item.SubItems[4].Text = author.IsProcessed ? "✅ Sí" : "⏳ No";
                    }
                    else if (item.SubItems.Count == 4)
                    {
                        item.SubItems.Add(author.IsProcessed ? "✅ Sí" : "⏳ No");
                    }
                    
                    // MEJORA #5: Usar color de fondo basado en estado para mejor contraste
                    if (foreColor.HasValue)
                    {
                        item.BackColor = foreColor.Value;
                        item.ForeColor = Color.Black; // Texto negro para mejor contraste
                    }
                    else
                    {
                        // Si no se especifica color, usar el helper
                        item.BackColor = UIColors.GetStatusColor(status);
                        item.ForeColor = Color.Black;
                    }
                    
                    try { lvAutoAuthors.RedrawItems(index, index, true); } catch { try { lvAutoAuthors.Invalidate(item.Bounds); } catch { } }
                }
            }
            catch
            {
                // Si falla, ignorar (no bloquear la purga)
            }
        }
        
        private void ViewAuthorUniqueFiles()
        {
            try
            {
                AutoLog($"🔍 DEBUG: ViewAuthorUniqueFiles iniciado");
                AutoLog($"🔍 DEBUG: lvAutoAuthors.SelectedIndices.Count = {lvAutoAuthors.SelectedIndices.Count}");
                
                if (lvAutoAuthors.SelectedIndices.Count == 0)
                {
                    AutoLog("⚠️ No hay autores seleccionados para visualizar");
                    return;
                }

                int selectedIndex = lvAutoAuthors.SelectedIndices[0];
                AutoLog($"🔍 DEBUG: selectedIndex = {selectedIndex}");
                
                // Verificar que filteredAuthorsData tenga datos
                AutoLog($"🔍 DEBUG: filteredAuthorsData.Count = {filteredAuthorsData?.Count ?? -1}");
                if (filteredAuthorsData == null || filteredAuthorsData.Count == 0)
                {
                    AutoLog("⚠️ No hay datos de autores cargados. Intenta refrescar la lista.");
                    return;
                }
                
                if (selectedIndex < 0 || selectedIndex >= filteredAuthorsData.Count)
                {
                    AutoLog($"⚠️ Índice seleccionado ({selectedIndex}) fuera de rango (0-{filteredAuthorsData.Count - 1})");
                    return;
                }

                var authorName = filteredAuthorsData[selectedIndex].Name;
                AutoLog($"🔍 DEBUG: authorName = '{authorName}'");
                var normalizedAuthorName = ValidationHelpers.NormalizeAuthorName(authorName);
                AutoLog($"🔍 DEBUG: normalizedAuthorName = '{normalizedAuthorName}'");

                List<AutoSearchFileResult> authorFiles;
                lock (autoSearchResultsLock)
                {
                    AutoLog($"🔍 DEBUG: autoSearchResults.Count = {autoSearchResults.Count}");
                    authorFiles = autoSearchResults
                        .Where(r => ValidationHelpers.NormalizeAuthorName(r.Author) == normalizedAuthorName
                                 && !r.FileName.StartsWith("[Autor]"))
                        .OrderByDescending(r => r.Timestamp)
                        .ToList();
                }
                
                AutoLog($"🔍 DEBUG: authorFiles.Count = {authorFiles.Count}");

                if (authorFiles.Count == 0)
                {
                    AutoLog($"📄 {authorName}: No hay archivos registrados aún");
                    return;
                }
                
                AutoLog($"✅ DEBUG: Mostrando ventana con {authorFiles.Count} archivos");
                
                var filesForm = new Form
            {
                Text = $"📄 Archivos de {authorName}",
                Size = new Size(1600, 900),
                BackColor = Color.FromArgb(25, 25, 25),
                ForeColor = Color.White,
                StartPosition = FormStartPosition.CenterParent
            };

            var filesListView = new ListView
            {
                Location = new Point(10, 10),
                Size = new Size(1560, 800),
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                View = View.Details,
                FullRowSelect = true,
                GridLines = true,
                MultiSelect = false
            };

            // MEJORA #3: Agregar ordenamiento por columnas
            int sortColumn = -1;
            SortOrder sortOrder = SortOrder.None;
            
            filesListView.ColumnClick += (s, e) =>
            {
                // Si se hace clic en la misma columna, cambiar orden
                if (e.Column == sortColumn)
                {
                    sortOrder = sortOrder == SortOrder.Ascending ? SortOrder.Descending : SortOrder.Ascending;
                }
                else
                {
                    sortColumn = e.Column;
                    sortOrder = SortOrder.Ascending;
                }
                
                // Ordenar usando un comparador personalizado
                filesListView.ListViewItemSorter = new ListViewItemComparer(e.Column, sortOrder);
                filesListView.Sort();
                
                AutoLog($"📊 Ordenando por columna {e.Column} ({sortOrder})");
            };

            filesListView.Columns.Add("Archivo", -2);
            filesListView.Columns.Add("Tamaño", -2);
            filesListView.Columns.Add("Extensión", -2);
            filesListView.Columns.Add("Español", -2);
            filesListView.Columns.Add("Documento", -2);
            filesListView.Columns.Add("Fecha", -2);
            filesListView.SizeChanged += (s, e) => {
                if (filesListView.Columns.Count >= 6) {
                    int w = filesListView.ClientSize.Width;
                    filesListView.Columns[0].Width = (int)(w * 0.45);
                    filesListView.Columns[1].Width = (int)(w * 0.12);
                    filesListView.Columns[2].Width = (int)(w * 0.10);
                    filesListView.Columns[3].Width = (int)(w * 0.08);
                    filesListView.Columns[4].Width = (int)(w * 0.10);
                    filesListView.Columns[5].Width = (int)(w * 0.15);
                }
            };
            
            // MEJORA #6: Abrir ubicación del archivo en explorador con doble clic
            filesListView.DoubleClick += (s, e) =>
            {
                if (filesListView.SelectedItems.Count > 0)
                {
                    var selectedItem = filesListView.SelectedItems[0];
                    var fileName = selectedItem.Text;
                    
                    // Buscar el archivo en la carpeta de descargas
                    var filePath = Path.Combine(downloadDir, fileName);
                    
                    if (System.IO.File.Exists(filePath))
                    {
                        try
                        {
                            // Abrir explorador y seleccionar el archivo
                            System.Diagnostics.Process.Start("explorer.exe", $"/select,\"{filePath}\"");
                            AutoLog($"📂 Abriendo ubicación: {filePath}");
                        }
                        catch (Exception ex)
                        {
                            AutoLog($"❌ Error al abrir explorador: {ex.Message}");
                        }
                    }
                    else
                    {
                        // Buscar en subdirectorios
                        try
                        {
                            var files = System.IO.Directory.GetFiles(downloadDir, fileName, SearchOption.AllDirectories);
                            if (files.Length > 0)
                            {
                                System.Diagnostics.Process.Start("explorer.exe", $"/select,\"{files[0]}\"");
                                AutoLog($"📂 Abriendo ubicación: {files[0]}");
                            }
                            else
                            {
                                AutoLog($"⚠️ Archivo no encontrado en descargas: {fileName}");
                                DarkMessageBox.Show($"El archivo no se encuentra en la carpeta de descargas:\n{fileName}", 
                                    "Archivo no encontrado", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                            }
                        }
                        catch (Exception ex)
                        {
                            AutoLog($"❌ Error buscando archivo: {ex.Message}");
                        }
                    }
                }
            };

            foreach (var file in authorFiles)
            {
                var item = new ListViewItem(file.FileName)
                {
                    BackColor = Color.FromArgb(30, 30, 30),
                    ForeColor = file.IsSpanish && file.IsDocument ? UIColors.FileSpanish : 
                                file.IsSpanish ? UIColors.FileSpanish : 
                                file.IsDocument ? UIColors.FileDocument : UIColors.FileNonSpanish
                };
                item.SubItems.Add(file.SizeReadable);
                item.SubItems.Add(Path.GetExtension(file.FileName));
                item.SubItems.Add(file.IsSpanish ? "✅" : "❌");
                item.SubItems.Add(file.IsDocument ? "📄" : "❌");
                item.SubItems.Add(file.Timestamp.ToString("yyyy-MM-dd HH:mm:ss"));
                filesListView.Items.Add(item);
            }

            var statusLabel = new Label
            {
                Text = $"📊 Total: {authorFiles.Count} archivos únicos | Español: {authorFiles.Count(f => f.IsSpanish)} | Documentos: {authorFiles.Count(f => f.IsDocument)}",
                Dock = DockStyle.Bottom,
                Height = 30,
                BackColor = Color.FromArgb(35, 35, 35),
                ForeColor = Color.LightGray,
                TextAlign = ContentAlignment.MiddleLeft,
                Padding = new Padding(10, 0, 0, 0),
                Font = new Font("Segoe UI", 9, FontStyle.Bold)
            };

                filesForm.Controls.Add(filesListView);
                filesForm.Controls.Add(statusLabel);

                AutoLog($"📄 Mostrando {authorFiles.Count} archivos de {authorName}");
                filesForm.ShowDialog(this);
            }
            catch (Exception ex)
            {
                AutoLog($"❌ ERROR en ViewAuthorUniqueFiles: {ex.Message}");
                AutoLog($"❌ StackTrace: {ex.StackTrace}");
            }
        }

        private void DeleteSelectedAuthorsFromContext()
        {
            if (lvAutoAuthors.SelectedIndices.Count == 0)
            {
                AutoLog("⚠️ No hay autores seleccionados para borrar");
                return;
            }
            
            int selectedIndex = lvAutoAuthors.SelectedIndices[0];
            if (selectedIndex < 0 || selectedIndex >= filteredAuthorsData.Count)
                return;
                
            var authorName = filteredAuthorsData[selectedIndex].Name;
            var normalizedAuthorName = ValidationHelpers.NormalizeAuthorName(authorName);
            
            // Filtrar archivos del autor desde autoSearchResults (excluir registros ficticios)
            List<AutoSearchFileResult> authorFiles;
            lock (autoSearchResultsLock)
            {
                authorFiles = autoSearchResults
                    .Where(r => ValidationHelpers.NormalizeAuthorName(r.Author) == normalizedAuthorName
                             && !r.FileName.StartsWith("[Autor]"))
                    .OrderByDescending(r => r.Timestamp)
                    .ToList();
            }
            
            if (authorFiles.Count == 0)
            {
                AutoLog($"📄 {authorName}: No hay archivos registrados aún");
                return;
            }
            
            // Crear ventana para mostrar archivos
            var filesForm = new Form
            {
                Text = $"📄 Archivos de {authorName}",
                Size = new Size(1600, 900),
                BackColor = Color.FromArgb(25, 25, 25),
                ForeColor = Color.White,
                StartPosition = FormStartPosition.CenterParent
            };
            
            // Usar ListView normal (no virtual) para esta ventana
            var filesListView = new ListView
            {
                Location = new Point(10, 10),
                Size = new Size(1560, 800),
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                View = View.Details,
                FullRowSelect = true,
                GridLines = true,
                MultiSelect = false
            };
            
            // Configurar columnas
            filesListView.Columns.Add("Archivo", -2);
            filesListView.Columns.Add("Tamaño", -2);
            filesListView.Columns.Add("Extensión", -2);
            filesListView.Columns.Add("Español", -2);
            filesListView.Columns.Add("Documento", -2);
            filesListView.Columns.Add("Fecha", -2);
            filesListView.SizeChanged += (s, e) => {
                if (filesListView.Columns.Count >= 6) {
                    int w = filesListView.ClientSize.Width;
                    filesListView.Columns[0].Width = (int)(w * 0.45);
                    filesListView.Columns[1].Width = (int)(w * 0.12);
                    filesListView.Columns[2].Width = (int)(w * 0.10);
                    filesListView.Columns[3].Width = (int)(w * 0.08);
                    filesListView.Columns[4].Width = (int)(w * 0.10);
                    filesListView.Columns[5].Width = (int)(w * 0.15);
                }
            };
            
            // Agregar archivos
            foreach (var file in authorFiles)
            {
                var item = new ListViewItem(file.FileName);
                item.SubItems.Add(file.SizeReadable);
                item.SubItems.Add(Path.GetExtension(file.FileName));
                item.SubItems.Add(file.IsSpanish ? "✅" : "❌");
                item.SubItems.Add(file.IsDocument ? "📄" : "❌");
                item.SubItems.Add(file.Timestamp.ToString("yyyy-MM-dd HH:mm:ss"));
                item.BackColor = Color.FromArgb(30, 30, 30);
                item.ForeColor = file.IsSpanish && file.IsDocument ? UIColors.FileSpanish : 
                                 file.IsSpanish ? UIColors.FileSpanish : 
                                 file.IsDocument ? UIColors.FileDocument : UIColors.FileNonSpanish;
                filesListView.Items.Add(item);
            }
            
            var statusLabel = new Label
            {
                Text = $"📊 Total: {authorFiles.Count} archivos únicos | Español: {authorFiles.Count(f => f.IsSpanish)} | Documentos: {authorFiles.Count(f => f.IsDocument)}",
                Dock = DockStyle.Bottom,
                Height = 30,
                BackColor = Color.FromArgb(35, 35, 35),
                ForeColor = Color.LightGray,
                TextAlign = ContentAlignment.MiddleLeft,
                Padding = new Padding(10, 0, 0, 0),
                Font = new Font("Segoe UI", 9, FontStyle.Bold)
            };
            
            filesForm.Controls.Add(filesListView);
            filesForm.Controls.Add(statusLabel);
            
            AutoLog($"📄 Mostrando {authorFiles.Count} archivos de {authorName}");
            filesForm.ShowDialog();
        }
        
        private bool autoSearchRunning = false;
        private bool autoPurgeRunning = false;
        private bool autoPurgeUserPaused = false;
        private bool autoSearchPausedByDisconnection = false;
        private bool autoPurgePausedByDisconnection = false;
        private bool downloadsPausedByDisconnection = false;
        private bool autoPurgeNeedsRestart = false;
        private bool ultraSafePurgeMode = true;
        private bool pausedAutoTuningByPurge = false;
        private bool isAutoTuningPaused = false;
        private int scheduledReconnectsCount = 0;

        private void EnsureAutoTuningState(bool shouldPause)
        {
            if (autoTuner == null || !useAutoTuning)
                return;

            if (shouldPause)
            {
                if (isAutoTuningPaused)
                    return;

                try
                {
                    autoTuner.SetEnabled(false);
                    isAutoTuningPaused = true;
                    AutoLog("🛑 Auto-Tuning pausado");
                }
                catch (Exception tunerEx)
                {
                    Log($"⚠️ Error pausando Auto-Tuning: {tunerEx.Message}");
                }
            }
            else
            {
                if (!isAutoTuningPaused)
                    return;

                try
                {
                    autoTuner.SetEnabled(true);
                    isAutoTuningPaused = false;
                    AutoLog("🟢 Auto-Tuning reanudado");
                }
                catch (Exception tunerEx)
                {
                    Log($"⚠️ Error reanudando Auto-Tuning: {tunerEx.Message}");
                }
            }
        }
        private bool pausedKeepAliveByPurge = false;
        private int purgeMaxPerMinute = 20; // Permitir hasta 20 búsquedas por minuto (menos agresivo)
        private System.Collections.Generic.Queue<DateTime> purgeSearchTimes = new System.Collections.Generic.Queue<DateTime>();
        private int consecutivePurgeTimeouts = 0;
        private System.Collections.Generic.Queue<DateTime> disconnectEvents = new System.Collections.Generic.Queue<DateTime>();
        private int purgeMaxActiveDownloads = 0; // 0 = no descargas durante purga
        private bool purgeRequireNoUploads = true;
        private double purgeMaxLatencyMs = 800.0;
        private DateTime lastActivityTime = DateTime.UtcNow;
        private System.Collections.Generic.Queue<DateTime> searchRateTimes = new System.Collections.Generic.Queue<DateTime>();
        private int maxSearchesPerMinute = 30; // Aumentado de 10 a 30 para mayor velocidad
        private Random portRng = new Random();
        private CancellationTokenSource? autoSearchCts;
