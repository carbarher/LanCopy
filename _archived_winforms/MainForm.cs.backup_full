            topLeftPanel.RowStyles.Add(new RowStyle(SizeType.Absolute, 26f)); // Fila 3: 26px
            SafeLog( "CreateVaciarTab: topLeftPanel creado\n");

            SafeLog( "CreateVaciarTab: Creando botones...\n");
            // Botones compactos
            var btnNextAuthor = CreateCompactButton("🔄", Color.FromArgb(0, 150, 215), "Actualizar");
            var btnVerifyIntegrity = CreateCompactButton("✅", Color.FromArgb(180, 50, 50), "Verificar");
            var btnDashboard = CreateCompactButton("📊", Color.FromArgb(50, 150, 200), "Dashboard");
