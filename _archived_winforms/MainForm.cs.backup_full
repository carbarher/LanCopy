                Log($"✅ Detección idioma: '{testSpanish}' → {langEs}");
                AutoLog($"✅ Detección idioma: '{testEnglish}' → {langEn}");
                Log($"✅ Detección idioma: '{testEnglish}' → {langEn}");
                
