                btnPanel.Controls.Add(btnClose);
                btnPanel.Controls.Add(btnDownload);
                
                mainPanel.Controls.Add(btnPanel, 0, 2);
                
                synopsisForm.Controls.Add(mainPanel);
                synopsisForm.ShowDialog();
                
                Log($"📖 Sinopsis mostrada: {metadata.Title}");
