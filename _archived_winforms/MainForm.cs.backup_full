        {
            try
            {
                // ODS es un ZIP con content.xml
                using (var archive = System.IO.Compression.ZipFile.OpenRead(filePath))
                {
                    var contentEntry = archive.GetEntry("content.xml");
                    if (contentEntry == null) return null;
                    
                    using (var stream = contentEntry.Open())
                    using (var reader = new StreamReader(stream))
                    {
                        string content = reader.ReadToEnd();
                        // OPTIMIZACIÓN: Usar Regex compilado cacheado
                        content = RegexHtmlTags.Replace(content, " ");
                        // MEJORA #31: Usar indexador de rango
                        return content.Length > 50000 ? content[..50000] : content;
                    }
                }
            }
            catch
            {
                return null;
            }
        }
        
        private string ExtractOdpText(string filePath)
        {
            try
            {
                // ODP es un ZIP con content.xml
                using (var archive = System.IO.Compression.ZipFile.OpenRead(filePath))
                {
                    var contentEntry = archive.GetEntry("content.xml");
                    if (contentEntry == null) return null;
                    
                    using (var stream = contentEntry.Open())
                    using (var reader = new StreamReader(stream))
                    {
                        string content = reader.ReadToEnd();
                        // OPTIMIZACIÓN: Usar Regex compilado cacheado
                        content = RegexHtmlTags.Replace(content, " ");
                        // MEJORA #31: Usar indexador de rango
                        return content.Length > 50000 ? content[..50000] : content;
                    }
                }
            }
            catch
            {
                return null;
            }
        }
        
        private string ExtractRtfText(string filePath)
        {
            try
            {
                // OPTIMIZACIÓN: Usar ArrayPool para buffer de lectura
                // RTF es texto plano con códigos de formato
                const int maxBytes = 100 * 1024;
                var buffer = System.Buffers.ArrayPool<byte>.Shared.Rent(maxBytes);
                try
                {
                    int bytesRead;
                    
                    using (FileStream fs = new FileStream(filePath, FileMode.Open, FileAccess.Read, FileShare.Read))
                    {
                        bytesRead = fs.Read(buffer, 0, Math.Min(maxBytes, (int)fs.Length));
                    }
                    
                    string content = System.Text.Encoding.UTF8.GetString(buffer, 0, bytesRead);
                    
                    // OPTIMIZACIÓN: Usar Regex compilados cacheados
                    content = RegexRtfCodes.Replace(content, " ");
                    content = RegexRtfBraces.Replace(content, " ");
                    
                    return content;
                }
                finally
                {
                    System.Buffers.ArrayPool<byte>.Shared.Return(buffer);
                }
            }
            catch
            {
                return null;
            }
        }
        
        private string ExtractLegacyOfficeText(string filePath)
        {
            try
            {
                // OPTIMIZACIÓN: Usar ArrayPool para buffer de lectura
                // Para formatos binarios antiguos (.doc, .xls, .ppt), intentar extracción básica
                // Estos formatos son complejos, pero podemos extraer strings legibles
                const int maxBytes = 200 * 1024;
                var buffer = System.Buffers.ArrayPool<byte>.Shared.Rent(maxBytes);
                try
                {
                    int bytesRead;
                    
                    using (FileStream fs = new FileStream(filePath, FileMode.Open, FileAccess.Read, FileShare.Read))
                    {
                        bytesRead = fs.Read(buffer, 0, Math.Min(maxBytes, (int)fs.Length));
                    }
                
                // Buscar secuencias de texto legible (al menos 4 caracteres consecutivos)
                var textBuilder = new System.Text.StringBuilder();
                var currentWord = new System.Text.StringBuilder();
                
                for (int i = 0; i < bytesRead; i++)
                {
                    byte b = buffer[i];
                    
                    // Caracteres imprimibles ASCII y extendidos
                    if ((b >= 32 && b <= 126) || (b >= 160 && b <= 255))
                    {
                        currentWord.Append((char)b);
                    }
                    else
                    {
                        if (currentWord.Length >= 4)
                        {
                            textBuilder.Append(currentWord);
                            textBuilder.Append(" ");
                        }
                        currentWord.Clear();
                    }
                    
                    // Limitar a ~50KB
                    if (textBuilder.Length > 50000)
                        break;
                }
                
                // Agregar última palabra si es válida
                if (currentWord.Length >= 4)
                {
                    textBuilder.Append(currentWord);
                }
                
                return textBuilder.Length > 100 ? textBuilder.ToString() : null;
                }
                finally
                {
                    System.Buffers.ArrayPool<byte>.Shared.Return(buffer);
                }
            }
            catch
            {
                return null;
            }
        }
        
        private void UpdateFilterButtons()
        {
            if (btnFilterAll == null || btnFilterSpanish == null || btnFilterNonSpanish == null)
                return;
            
            // Resetear todos los botones
            btnFilterAll.BackColor = Color.FromArgb(70, 70, 70);
            btnFilterSpanish.BackColor = Color.FromArgb(40, 80, 40);
            btnFilterNonSpanish.BackColor = Color.FromArgb(80, 40, 40);
            
            btnFilterAll.Font = new Font("Segoe UI", 8, FontStyle.Regular);
            btnFilterSpanish.Font = new Font("Segoe UI", 8, FontStyle.Regular);
            btnFilterNonSpanish.Font = new Font("Segoe UI", 8, FontStyle.Regular);
            
            // Resaltar el botón activo
            if (historyFilter == "all")
            {
                btnFilterAll.BackColor = Color.FromArgb(100, 100, 100);
                btnFilterAll.Font = new Font("Segoe UI", 8, FontStyle.Bold);
            }
            else if (historyFilter == "spanish")
            {
                btnFilterSpanish.BackColor = Color.FromArgb(60, 120, 60);
                btnFilterSpanish.Font = new Font("Segoe UI", 8, FontStyle.Bold);
            }
            else if (historyFilter == "non-spanish")
            {
                btnFilterNonSpanish.BackColor = Color.FromArgb(120, 60, 60);
                btnFilterNonSpanish.Font = new Font("Segoe UI", 8, FontStyle.Bold);
            }
        }
        
        private TabPage CreateHistoryTab()
