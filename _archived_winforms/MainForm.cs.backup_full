        private void CreateAdvancedFiltersPanel(Control parentPanel)
        {
            pnlAdvancedFilters = new Panel
            {
                Dock = DockStyle.Top,
                AutoSize = true,
                AutoSizeMode = AutoSizeMode.GrowAndShrink,
                BackColor = Color.FromArgb(38, 38, 38),
                Padding = new Padding(20, 16, 20, 16),
                Margin = new Padding(0),
                Visible = true // Siempre visible
            };

            // FILA ÚNICA: Todos los controles en una sola línea
            var row1 = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = false,
                AutoSize = true,
                Margin = new Padding(0)
            };

            row1.Controls.Add(new Label { Text = "📏 Tamaño (KB):", AutoSize = true, ForeColor = Color.White, Font = new Font("Segoe UI", 9, FontStyle.Bold), Margin = new Padding(0, 6, 10, 0) });
            
            numMinSize = new NumericUpDown { Width = 90, BackColor = Color.FromArgb(50, 50, 55), ForeColor = Color.White, Minimum = 0, Maximum = 1000000, DecimalPlaces = 0 };
            numMinSize.Margin = new Padding(0, 0, 8, 0);
            numMinSize.ValueChanged += (s, e) => ApplyAdvancedFilters();
            row1.Controls.Add(numMinSize);

            row1.Controls.Add(new Label { Text = "→", AutoSize = true, ForeColor = Color.Gray, Margin = new Padding(0, 6, 8, 0) });

            numMaxSize = new NumericUpDown { Width = 90, BackColor = Color.FromArgb(50, 50, 55), ForeColor = Color.White, Minimum = 0, Maximum = 1000000, DecimalPlaces = 0 };
            numMaxSize.Margin = new Padding(0, 0, 30, 0);
            numMaxSize.ValueChanged += (s, e) => ApplyAdvancedFilters();
            row1.Controls.Add(numMaxSize);

            row1.Controls.Add(new Label { Text = "📄 Formato:", AutoSize = true, ForeColor = Color.White, Font = new Font("Segoe UI", 9, FontStyle.Bold), Margin = new Padding(0, 6, 10, 0) });

            cmbExtensionFilter = new ComboBox { Width = 160, BackColor = Color.FromArgb(50, 50, 55), ForeColor = Color.White, DropDownStyle = ComboBoxStyle.DropDownList };
            cmbExtensionFilter.Items.AddRange(new object[] { 
                "Todos", 
                "📚 Libros/Docs", 
                "🎨 Comics", 
                "🎵 Audio", 
                "🎬 Video", 
                "🖼️ Imágenes", 
                "🗃️ Comprimidos" 
            });
            cmbExtensionFilter.SelectedIndex = 0;
            cmbExtensionFilter.Margin = new Padding(0, 0, 30, 0);
            cmbExtensionFilter.SelectedIndexChanged += (s, e) => ApplyAdvancedFilters();
            row1.Controls.Add(cmbExtensionFilter);

            row1.Controls.Add(new Label { Text = "⬇️ Ordenar:", AutoSize = true, ForeColor = Color.White, Font = new Font("Segoe UI", 9, FontStyle.Bold), Margin = new Padding(0, 6, 10, 0) });

            cmbSortBy = new ComboBox { Width = 150, BackColor = Color.FromArgb(50, 50, 55), ForeColor = Color.White, DropDownStyle = ComboBoxStyle.DropDownList };
            cmbSortBy.Items.AddRange(new object[] { "Relevancia", "Tamaño ↑", "Tamaño ↓", "Nombre A-Z", "Usuario A-Z", "Velocidad ↑" });
            cmbSortBy.SelectedIndex = 0;
            cmbSortBy.Margin = new Padding(0, 0, 30, 0);
            cmbSortBy.SelectedIndexChanged += (s, e) => ApplyAdvancedFilters();
            row1.Controls.Add(cmbSortBy);

            var chkSpanishFilter = new CheckBox 
            { 
                Text = "🇪🇸 Solo español", 
                AutoSize = true, 
                ForeColor = Color.White, 
                BackColor = Color.FromArgb(38, 38, 38),
                Font = new Font("Segoe UI", 10, FontStyle.Bold), 
                Margin = new Padding(0, 4, 30, 0), 
                Name = "chkSpanishFilter",
                FlatStyle = FlatStyle.Flat,
                UseVisualStyleBackColor = false
            };
            chkSpanishFilter.FlatAppearance.BorderSize = 0;
            chkSpanishFilter.CheckedChanged += (s, e) => ApplyAdvancedFilters();
            row1.Controls.Add(chkSpanishFilter);

            pnlAdvancedFilters.Controls.Add(row1);
            parentPanel.Controls.Add(pnlAdvancedFilters);
        }

        private void ToggleAdvancedFilters()
        {
            advancedFiltersVisible = !advancedFiltersVisible;

            if (advancedFiltersVisible)
            {
                pnlAdvancedFilters.Visible = true;
                btnToggleFilters.Text = "⚙️ Ocultar";
            }
            else
            {
                pnlAdvancedFilters.Visible = false;
                btnToggleFilters.Text = "⚙️ Filtros";
            }
        }
        
        private void ApplyAdvancedFilters()
        {
            if (allResults.Count == 0) return;
            
            var filtered = new List<SearchResultItem>(allResults);
            
            // Filtro por tamaño (en KB)
            if (numMinSize.Value > 0)
            {
                long minBytes = (long)(numMinSize.Value * 1024);
                filtered = filtered.Where(r => r.Size >= minBytes).ToList();
            }
            
            if (numMaxSize.Value > 0)
            {
                long maxBytes = (long)(numMaxSize.Value * 1024);
                filtered = filtered.Where(r => r.Size <= maxBytes).ToList();
            }
            
            // Filtro por tipo de archivo
            if (cmbExtensionFilter.SelectedIndex > 0)
            {
                string filterType = cmbExtensionFilter.SelectedItem.ToString();
                
                // MEJORA #19: Usar HashSet para evitar O(n*m) - reducir de O(n*m) a O(n)
                HashSet<string> allowedExts = null;
                
                if (filterType.Contains("Libros/Docs"))
                {
                    allowedExts = new HashSet<string>(StringComparer.OrdinalIgnoreCase) 
                        { ".epub", ".mobi", ".azw", ".azw3", ".pdf", ".doc", ".docx", ".txt", ".rtf", ".odt", ".fb2", ".djvu", ".lit" };
                }
                else if (filterType.Contains("Comics"))
                {
                    allowedExts = new HashSet<string>(StringComparer.OrdinalIgnoreCase) 
                        { ".cbr", ".cbz", ".cb7", ".cbt" };
                }
                else if (filterType.Contains("Audio"))
                {
                    allowedExts = new HashSet<string>(StringComparer.OrdinalIgnoreCase) 
                        { ".mp3", ".flac", ".m4a", ".aac", ".ogg", ".opus", ".wav", ".wma", ".ape", ".alac", ".aiff" };
                }
                else if (filterType.Contains("Video"))
                {
                    allowedExts = new HashSet<string>(StringComparer.OrdinalIgnoreCase) 
                        { ".mp4", ".mkv", ".avi", ".mov", ".wmv", ".flv", ".webm", ".m4v", ".mpg", ".mpeg" };
                }
                else if (filterType.Contains("Imágenes"))
                {
                    allowedExts = new HashSet<string>(StringComparer.OrdinalIgnoreCase) 
                        { ".jpg", ".jpeg", ".png", ".gif", ".bmp", ".webp", ".svg", ".tiff", ".ico", ".heic", ".heif" };
                }
                else if (filterType.Contains("Comprimidos"))
                {
                    allowedExts = new HashSet<string>(StringComparer.OrdinalIgnoreCase) 
                        { ".zip", ".rar", ".7z", ".tar", ".gz", ".bz2", ".xz", ".iso" };
                }
                
                if (allowedExts != null)
                {
                    filtered = filtered.Where(r => allowedExts.Contains(r.Extension)).ToList();
                }
            }
            
            
            // Filtro por idioma español
            var chkSpanish = pnlAdvancedFilters.Controls.Find("chkSpanishFilter", true).FirstOrDefault() as CheckBox;
            if (chkSpanish != null && chkSpanish.Checked)
            {
                filtered = filtered.Where(r => IsSpanishText(r.Filename) || IsSpanishText(r.FolderPath)).ToList();
            }
            
            // Ordenar
            switch (cmbSortBy.SelectedIndex)
            {
                case 1: // Tamaño ↑
                    filtered = filtered.OrderBy(r => r.Size).ToList();
                    break;
                case 2: // Tamaño ↓
                    filtered = filtered.OrderByDescending(r => r.Size).ToList();
                    break;
                case 3: // Nombre A-Z
                    filtered = filtered.OrderBy(r => r.Filename).ToList();
                    break;
                case 4: // Usuario A-Z
                    filtered = filtered.OrderBy(r => r.Username).ToList();
                    break;
                case 5: // Velocidad ↑
                    filtered = filtered.OrderByDescending(r => r.UploadSpeed).ToList();
                    break;
            }
            
            // Aplicar filtro de texto también
            // MEJORA #9: IndexOf es más eficiente que ToLower().Contains()
            if (!string.IsNullOrWhiteSpace(txtFilterResults.Text))
            {
                var filterText = txtFilterResults.Text;
                filtered = filtered.Where(r => 
                    r.Filename.IndexOf(filterText, StringComparison.OrdinalIgnoreCase) >= 0 || 
                    r.Username.IndexOf(filterText, StringComparison.OrdinalIgnoreCase) >= 0 ||
                    r.FolderPath.IndexOf(filterText, StringComparison.OrdinalIgnoreCase) >= 0
                ).ToList();
            }
            
            UpdateSearchResults(filtered);
            SafeInvoke(() => lblResultsCount.Text = $"{filtered.Count:N0} / {allResults.Count:N0} archivos");
        }
        
        private void UpdateDownloadListView()
        {
            // Método auxiliar para refrescar la vista de descargas
            lock (downloadQueueLock)
            {
                var snapshot = downloadQueue.ToList();

                lvDownloads.BeginUpdate();
                lvDownloads.Items.Clear();

                for (int index = 0; index < snapshot.Count; index++)
                {
                    var task = snapshot[index];
                    var item = new ListViewItem(string.Empty);
                    item.Tag = task;
                    EnsureDownloadSubItems(item);
                    task.ListViewItem = item;
                    UpdateListViewItemColumns(task, item);
                    lvDownloads.Items.Add(item);
                }

                lvDownloads.EndUpdate();
            }
        }
        
        private string GetStatusText(DownloadStatus status)
        {
            return status switch
            {
                DownloadStatus.Queued => "⏳ En cola",
                DownloadStatus.Downloading => "⬇️ Descargando",
                DownloadStatus.Completed => "✅ Completado",
                DownloadStatus.Failed => "❌ Fallido",
                DownloadStatus.Cancelled => "🚫 Cancelado",
                DownloadStatus.Paused => "⏸️ Pausado",
                _ => "❓ Desconocido"
            };
        }
        
        private Color GetStatusColor(DownloadStatus status)
        {
            return status switch
            {
                DownloadStatus.Queued => UIColors.DownloadQueued,
                DownloadStatus.Downloading => UIColors.DownloadActive,
                DownloadStatus.Completed => UIColors.DownloadCompleted,
                DownloadStatus.Failed => UIColors.DownloadFailed,
                DownloadStatus.Cancelled => UIColors.DownloadPaused,
                DownloadStatus.Paused => UIColors.DownloadPaused,
                _ => Color.White
            };
        }

        private string FormatEta(TimeSpan eta)
        {
            if (eta == TimeSpan.MaxValue || eta.TotalSeconds <= 0)
                return string.Empty;

            if (eta.TotalHours >= 1)
                return $"{(int)eta.TotalHours}h {eta.Minutes}m";

            if (eta.TotalMinutes >= 1)
                return $"{eta.Minutes}m {eta.Seconds}s";

            return $"{eta.Seconds}s";
        }

        private void EnsureDownloadSubItems(ListViewItem item)
        {
            if (item == null)
                return;

            while (item.SubItems.Count <= DOWNLOAD_COL_FAILURES)
            {
                item.SubItems.Add(string.Empty);
            }
        }

        private void UpdateListViewItemColumns(DownloadTask task, ListViewItem item)
        {
            if (task == null || item == null)
                return;

            EnsureDownloadSubItems(item);

            item.UseItemStyleForSubItems = true;

            item.SubItems[DOWNLOAD_COL_FILE].Text = Path.GetFileName(task.File.FileName);

            var usernameDisplay = premiumUsers.Contains(task.File.Username)
                ? $"⭐ {task.File.Username}"
                : task.File.Username;
            item.SubItems[DOWNLOAD_COL_USER].Text = usernameDisplay;

            var progressText = task.ProgressPercent > 0 ? $"{task.ProgressPercent:F1}%" : "0%";
            if (task.Status == DownloadStatus.Downloading)
            {
                var etaText = FormatEta(task.EstimatedTimeRemaining);
                if (!string.IsNullOrEmpty(etaText))
                {
                    progressText = $"{progressText} (ETA: {etaText})";
                }
            }
            item.SubItems[DOWNLOAD_COL_PROGRESS].Text = progressText;

            item.SubItems[DOWNLOAD_COL_STATUS].Text = GetStatusText(task.Status);
            item.SubItems[DOWNLOAD_COL_SIZE].Text = task.File.SizeReadable;

            item.SubItems[DOWNLOAD_COL_ATTEMPTS].Text = task.RetryCount > 0
                ? $"{task.RetryCount}/{task.MaxRetries}"
                : "0";

            ProviderStats providerStatsSnapshot = downloadManager?.GetProviderStatsSnapshot(task.File.Username);

            // Fallas
            int failures = providerStatsSnapshot?.FailedDownloads ?? 0;
            item.SubItems[DOWNLOAD_COL_FAILURES].Text = failures > 0 ? failures.ToString() : "0";

            item.ForeColor = GetStatusColor(task.Status);

            // MEJORA #30: Usar pool de StringBuilder
            var tooltipBuilder = GetStringBuilder();
            tooltipBuilder.AppendLine($"📦 Archivo: {task.File.FileName}");
            tooltipBuilder.AppendLine($"👤 Proveedor: {task.File.Username}");
            tooltipBuilder.AppendLine($"📊 Prioridad: {downloadManager?.QueueStrategy}");

            if (providerStatsSnapshot != null)
            {
                tooltipBuilder.AppendLine($"✅ Éxitos: {providerStatsSnapshot.SuccessfulDownloads}");
                tooltipBuilder.AppendLine($"❌ Fallos: {providerStatsSnapshot.FailedDownloads}");
                tooltipBuilder.AppendLine($"⚖️ Ratio éxito: {providerStatsSnapshot.SuccessfulDownloads}/{providerStatsSnapshot.TotalDownloads} ({(providerStatsSnapshot.TotalDownloads > 0 ? providerStatsSnapshot.SuccessfulDownloads / (double)providerStatsSnapshot.TotalDownloads * 100 : 0):F1}%)");
                tooltipBuilder.AppendLine($"🚀 Velocidad media: {FormatSpeed(providerStatsSnapshot.AverageSpeed)}");
            }

            if (downloadManager != null && downloadManager.TryGetBlacklistInfo(task.File.Username, out var blacklistFailures, out var hoursRemaining))
            {
                // Usuario en blacklist - mostrar advertencia en tooltip
                tooltipBuilder.AppendLine($"⛔ Blacklist temporal: {blacklistFailures} fallos, libera en {hoursRemaining:F1}h");
            }

            // Alertas por acercarse al umbral de blacklist
            if (providerStatsSnapshot != null && downloadManager != null)
            {
                int threshold = downloadManager.Config?.ProviderBlacklistThreshold ?? providerBlacklistThreshold;
                if (threshold > 0 && failures >= threshold - 1)
                {
                    item.SubItems[DOWNLOAD_COL_FAILURES].ForeColor = Color.OrangeRed;
                    tooltipBuilder.AppendLine($"⚠️ Al límite de blacklist ({failures}/{threshold})");
                }
                else
                {
                    item.SubItems[DOWNLOAD_COL_FAILURES].ForeColor = Color.Empty;
                }
            }

            // Descargas lentas
            if (task.Status == DownloadStatus.Downloading && task.SlowDownloadChecks > 0)
            {
                tooltipBuilder.AppendLine($"🐌 Intentos l: {task.SlowDownloadChecks}/{SLOW_DOWNLOAD_THRESHOLD_CHECKS}");
                if (task.SlowDownloadChecks >= SLOW_DOWNLOAD_THRESHOLD_CHECKS)
                {
                    item.SubItems[DOWNLOAD_COL_PROGRESS].ForeColor = Color.Orange;
                }
            }
            else
            {
                item.SubItems[DOWNLOAD_COL_PROGRESS].ForeColor = Color.Empty;
            }

            item.ToolTipText = tooltipBuilder.ToString().TrimEnd();
        }
        
        private async Task<string> GetMetadataStatus(string fileName)
        {
            try
            {
                var (title, author) = ParseFileName(fileName);
                if (string.IsNullOrEmpty(title)) return "❌";
                
                // Verificar si hay metadata en caché
                string cacheKey = $"synopsis_{title}_{author}";
                var cachedMetadata = GetCachedMetadata<BookMetadata>(cacheKey);
                
                if (cachedMetadata != null)
                {
                    return "✅";
                }
                
                // Si no está en caché, intentar buscar (sin bloquear UI)
                var metadata = await FetchBookMetadataFromGoogleBooks(title, author);
                if (metadata != null && !string.IsNullOrEmpty(metadata.Synopsis))
                {
                    SetCachedMetadata(cacheKey, metadata);
                    return "✅";
                }
                
                // Intentar Open Library
                metadata = await FetchBookMetadataFromOpenLibrary(title, author);
                if (metadata != null && !string.IsNullOrEmpty(metadata.Synopsis))
                {
                    SetCachedMetadata(cacheKey, metadata);
                    return "✅";
                }
                
                return "❌";
            }
            catch
            {
                return "❓";
            }
        }
        
        private string GetMetadataStatusSync(string fileName)
        {
            try
            {
                var (title, author) = ParseFileName(fileName);
                if (string.IsNullOrEmpty(title)) return "❌";
                
                // Solo verificar caché (sin hacer peticiones HTTP)
                string cacheKey = $"synopsis_{title}_{author}";
                var cachedMetadata = GetCachedMetadata<BookMetadata>(cacheKey);
                
                return cachedMetadata != null ? "✅" : "❓";
            }
            catch
            {
                return "❓";
            }
        }

        // Comparador personalizado para ListView
        public class ListViewItemComparer : System.Collections.IComparer
        {
            private int col;
            private SortOrder order;
            private Func<ListViewItem, int, IComparable> customSortFunc;
            
            // Constructor original (2 argumentos) - para compatibilidad
            public ListViewItemComparer(int column, SortOrder order)
            {
                col = column;
                this.order = order;
                customSortFunc = null;
            }
            
            // Constructor mejorado (3 argumentos) - con función personalizada
            public ListViewItemComparer(int column, bool ascending, Func<ListViewItem, int, IComparable> sortFunc)
            {
                col = column;
                order = ascending ? SortOrder.Ascending : SortOrder.Descending;
                customSortFunc = sortFunc;
            }
            
            // Propiedades para actualizar dinámicamente
            public int ColumnIndex
            {
                get { return col; }
                set { col = value; }
            }
            
            public bool Ascending
            {
                get { return order == SortOrder.Ascending; }
                set { order = value ? SortOrder.Ascending : SortOrder.Descending; }
            }
            
            public int Compare(object x, object y)
            {
                int returnVal;
                
                var itemX = (ListViewItem)x;
                var itemY = (ListViewItem)y;
                
                // Si hay función personalizada, usarla
                if (customSortFunc != null)
                {
                    try
                    {
                        var valueX = customSortFunc(itemX, col);
                        var valueY = customSortFunc(itemY, col);
                        returnVal = valueX.CompareTo(valueY);
                    }
                    catch
                    {
                        // Fallback a comparación de texto
                        returnVal = String.Compare(itemX.SubItems[col].Text, itemY.SubItems[col].Text);
                    }
                }
                else
                {
                    // Comparación estándar
                    var textX = itemX.SubItems[col].Text;
                    var textY = itemY.SubItems[col].Text;
                    
                    // Manejo especial para columna Score (contiene estrellas + número)
                    if (textX.Contains("⭐") || textX.Contains("☆"))
                    {
                        // Extraer el número después de las estrellas
                        var partsX = textX.Split(' ');
                        var partsY = textY.Split(' ');
                        
                        if (partsX.Length > 1 && partsY.Length > 1 &&
                            double.TryParse(partsX[partsX.Length - 1], out double scoreX) &&
                            double.TryParse(partsY[partsY.Length - 1], out double scoreY))
                        {
                            returnVal = scoreX.CompareTo(scoreY);
                        }
                        else
                        {
                            // Si no hay número, los usuarios sin score van al final
                            if (textX.Contains("--")) returnVal = -1;
                            else if (textY.Contains("--")) returnVal = 1;
                            else returnVal = 0;
                        }
                    }
                    // Intentar comparar como números
                    // MEJORA #10: Usar AsSpan para evitar allocaciones de Replace
                    else if (TryParseNumericValue(textX, out double numX) && TryParseNumericValue(textY, out double numY))
                    {
                        returnVal = numX.CompareTo(numY);
                    }
                    else
                    {
                        // Comparar como texto
                        returnVal = String.Compare(textX, textY);
                    }
                }
                
                // Invertir si es descendente
                if (order == SortOrder.Descending)
                    returnVal *= -1;
                
                return returnVal;
            }
        }
        
        // MEJORA #10: Helper para parsear valores numéricos sin allocaciones de Replace
        private static bool TryParseNumericValue(string text, out double result)
        {
            result = 0;
            if (string.IsNullOrEmpty(text)) return false;
            
            // Usar Span para evitar allocaciones
            ReadOnlySpan<char> span = text.AsSpan();
            Span<char> buffer = stackalloc char[span.Length];
            int writeIndex = 0;
            
            // Copiar solo dígitos, punto decimal y signo menos
            for (int i = 0; i < span.Length; i++)
            {
                char c = span[i];
                if (char.IsDigit(c) || c == '.' || c == '-')
                {
                    buffer[writeIndex++] = c;
                }
            }
            
            return double.TryParse(buffer.Slice(0, writeIndex), out result);
        }
        
        // ═══════════════════════════════════════════════════════════
        // FUNCIONES DE WISHLIST
        // ═══════════════════════════════════════════════════════════
        
        private void AddToWishlist()
        {
            var dialog = new Form
            {
                Text = "Agregar a Lista de Deseos",
                Size = new Size(450, 280),
                StartPosition = FormStartPosition.CenterParent,
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.White,
                FormBorderStyle = FormBorderStyle.FixedDialog,
                MaximizeBox = false,
                MinimizeBox = false
            };
            
            var lblSearch = new Label { Text = "Término de búsqueda:", Location = new Point(20, 20), AutoSize = true, ForeColor = Color.White };
            var txtSearch = new TextBox { Location = new Point(20, 45), Size = new Size(400, 25), BackColor = Color.FromArgb(50, 50, 50), ForeColor = Color.White };
            
            var lblAuthor = new Label { Text = "Autor (opcional):", Location = new Point(20, 80), AutoSize = true, ForeColor = Color.White };
            var txtAuthor = new TextBox { Location = new Point(20, 105), Size = new Size(400, 25), BackColor = Color.FromArgb(50, 50, 50), ForeColor = Color.White };
            
            var lblNotes = new Label { Text = "Notas (opcional):", Location = new Point(20, 140), AutoSize = true, ForeColor = Color.White };
            var txtNotes = new TextBox { Location = new Point(20, 165), Size = new Size(400, 25), BackColor = Color.FromArgb(50, 50, 50), ForeColor = Color.White };
            
            var btnOk = new Button { Text = "Agregar", Location = new Point(250, 200), Size = new Size(80, 30), DialogResult = DialogResult.OK };
            var btnCancel = new Button { Text = "Cancelar", Location = new Point(340, 200), Size = new Size(80, 30), DialogResult = DialogResult.Cancel };
            
            dialog.Controls.AddRange(new Control[] { lblSearch, txtSearch, lblAuthor, txtAuthor, lblNotes, txtNotes, btnOk, btnCancel });
            dialog.AcceptButton = btnOk;
            dialog.CancelButton = btnCancel;
            
            if (dialog.ShowDialog() == DialogResult.OK && !string.IsNullOrWhiteSpace(txtSearch.Text))
            {
                var item = new WishlistItem
                {
                    SearchTerm = txtSearch.Text.Trim(),
                    Author = txtAuthor.Text.Trim(),
                    DateAdded = DateTime.Now,
                    Notes = txtNotes.Text.Trim(),
                    AutoSearch = true
                };
                
                wishlist.Add(item);
                SaveWishlist();
                RefreshWishlistUI(null, "");
                Log($"⭐ Agregado a wishlist: {item.SearchTerm}");
            }
        }
        
        private void RemoveFromWishlist()
        {
            var lvWishlist = FindWishlistView();
            if (lvWishlist == null || lvWishlist.SelectedItems.Count == 0) return;
            
            var selectedIndex = lvWishlist.SelectedIndices[0];
            if (selectedIndex >= 0 && selectedIndex < wishlist.Count)
            {
                var item = wishlist[selectedIndex];
                wishlist.RemoveAt(selectedIndex);
                SaveWishlist();
                RefreshWishlistUI(lvWishlist, "");
                Log($"🗑️ Eliminado de wishlist: {item.SearchTerm}");
            }
        }
        
        private async Task SearchWishlistItems()
        {
            if (wishlist.Count == 0)
            {
                DarkMessageBox.Show("La lista de deseos está vacía.", "Wishlist", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }
            
            Log($"🔍 Buscando {wishlist.Count} item(s) de la wishlist...");
            
            foreach (var item in wishlist.Where(i => i.AutoSearch))
            {
                try
                {
                    Log($"🔍 Buscando: {item.SearchTerm}");
                    item.LastSearched = DateTime.Now;
                    
                    var searchClient = GetClientFromPool();
                    var searchResults = await searchClient.SearchAsync(
                        SearchQuery.FromText(item.SearchTerm),
                        options: new Soulseek.SearchOptions(
                            searchTimeout: 15000,
                            filterResponses: true,
                            minimumResponseFileCount: 1
                        )
                    );
                    
                    int foundCount = searchResults.Responses.Sum(r => r.Files.Count());
                    item.TimesFound += foundCount;
                    
                    if (foundCount > 0)
                    {
                        Log($"✅ Encontrados {foundCount} archivo(s) para: {item.SearchTerm}");
                        // Aquí podrías agregar lógica para auto-descargar
                    }
                    else
                    {
                        Log($"❌ No se encontraron resultados para: {item.SearchTerm}");
                    }
                    
                    await Task.Delay(1000); // Pausa entre búsquedas
                }
                catch (Exception ex)
                {
                    Log($"❌ Error buscando {item.SearchTerm}: {ex.Message}");
                }
            }
            
            SaveWishlist();
            RefreshWishlistUI(null, "");
            Log("✅ Búsqueda de wishlist completada");
        }
        
        private void LoadWishlist()
        {
            try
            {
                if (System.IO.File.Exists(wishlistPath))
                {
                    var json = System.IO.File.ReadAllText(wishlistPath);
                    wishlist = JsonSerializer.Deserialize<List<WishlistItem>>(json) ?? new List<WishlistItem>();
                    Log($"📋 Wishlist cargada: {wishlist.Count} item(s)");
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error cargando wishlist: {ex.Message}");
            }
        }
        
        private void SaveWishlist()
        {
            try
            {
                var options = new JsonSerializerOptions { WriteIndented = true };
                var json = JsonSerializer.Serialize(wishlist, options);
                System.IO.File.WriteAllText(wishlistPath, json);
            }
            catch (Exception ex)
            {
                Log($"❌ Error guardando wishlist: {ex.Message}");
            }
        }
        
        // OPT #9: Métodos para caché de autores sin español
        private void LoadNoSpanishAuthorsCache()
        {
            try
            {
                if (System.IO.File.Exists(noSpanishCachePath))
                {
                    var authors = System.IO.File.ReadAllLines(noSpanishCachePath);
                    foreach (var author in authors)
                    {
                        if (!string.IsNullOrWhiteSpace(author))
                        {
                            authorsWithoutSpanishWorks.Add(author.Trim());
                        }
                    }
                    Log($"💾 Caché de autores sin español: {authorsWithoutSpanishWorks.Count} autores");
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error cargando caché de autores sin español: {ex.Message}");
            }
        }
        
        private void SaveNoSpanishAuthorsCache()
        {
            try
            {
                var sortedAuthors = authorsWithoutSpanishWorks.OrderBy(a => a).ToList();
                System.IO.File.WriteAllLines(noSpanishCachePath, sortedAuthors);
                AutoLog($"💾 Guardados {authorsWithoutSpanishWorks.Count} autores sin español en caché");
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error guardando caché de autores sin español: {ex.Message}");
            }
        }
        
        private void RefreshWishlistUI(ListView lvWishlist, string filterText = "")
        {
            if (lvWishlist == null)
            {
                lvWishlist = FindWishlistView();
            }
            
            if (lvWishlist == null) return;
            
            SafeInvoke(() =>
            {
                lvWishlist.Items.Clear();
                
                // Filtrar items si hay texto de búsqueda
                var itemsToShow = wishlist.AsEnumerable();
                if (!string.IsNullOrWhiteSpace(filterText))
                {
                    var filter = filterText.ToLowerInvariant();
                    itemsToShow = itemsToShow.Where(item =>
                        item.SearchTerm.ToLowerInvariant().Contains(filter) ||
                        (item.Author != null && item.Author.ToLowerInvariant().Contains(filter)) ||
                        (item.Notes != null && item.Notes.ToLowerInvariant().Contains(filter)));
                }
                
                foreach (var item in itemsToShow)
                {
                    var lvi = new ListViewItem(item.SearchTerm);
                    lvi.SubItems.Add(item.Author ?? "-");
                    lvi.SubItems.Add(item.DateAdded.ToString("dd/MM/yyyy"));
                    lvi.SubItems.Add(item.LastSearched?.ToString("dd/MM/yyyy HH:mm") ?? "Nunca");
                    lvi.SubItems.Add(item.TimesFound.ToString());
                    lvi.SubItems.Add(item.AutoSearch ? "Sí" : "No");
                    lvi.SubItems.Add(item.Notes ?? "-");
                    lvWishlist.Items.Add(lvi);
                }
            });
        }
        
        private ListView FindWishlistView()
        {
            foreach (TabPage tab in tabControl.TabPages)
            {
                if (tab.Text.Contains("Lista de Deseos"))
                {
                    return FindControlRecursive<ListView>(tab, "wishlistView");
                }
            }
            return null;
        }
        
        private T FindControlRecursive<T>(Control parent, string tag) where T : Control
        {
            foreach (Control ctrl in parent.Controls)
            {
                if (ctrl is T && ctrl.Tag?.ToString() == tag)
                    return (T)ctrl;
                    
                var found = FindControlRecursive<T>(ctrl, tag);
                if (found != null)
                    return found;
            }
            return null;
        }
        
        private void StartWishlistTimer()
        {
            if (wishlistSearchTimer == null)
            {
                wishlistSearchTimer = new System.Windows.Forms.Timer();
                wishlistSearchTimer.Interval = wishlistSearchIntervalMinutes * 60 * 1000;
                wishlistSearchTimer.Tick += async (s, e) => await SearchWishlistItems();
            }
            
            wishlistSearchTimer.Start();
            Log($"⏰ Timer de wishlist iniciado (cada {wishlistSearchIntervalMinutes} min)");
        }
        
        private void StopWishlistTimer()
        {
            wishlistSearchTimer?.Stop();
            Log("⏸️ Timer de wishlist detenido");
        }
        
