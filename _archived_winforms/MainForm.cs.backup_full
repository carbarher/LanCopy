                    lvDownloads.Columns[5].Width = (int)(w * 0.04);  // Intentos
                    lvDownloads.Columns[6].Width = (int)(w * 0.03);  // Fallas
                }
            };

            var downloadsContext = new ContextMenuStrip
            {
                BackColor = Color.FromArgb(45, 45, 50),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 10)
            };
            downloadsContext.ShowItemToolTips = true;
            var miPause = new ToolStripMenuItem("⏸️ Pausar", null, (s, e) => PauseSelectedDownload()) { ToolTipText = "Pausar descargas seleccionadas" };
            var miResume = new ToolStripMenuItem("▶️ Reanudar", null, (s, e) => ResumeSelectedDownload()) { ToolTipText = "Reanudar descargas seleccionadas" };
            var miCancel = new ToolStripMenuItem("❌ Cancelar", null, (s, e) => CancelSelectedDownload()) { ToolTipText = "Cancelar descargas seleccionadas" };
            var miOpenFolder = new ToolStripMenuItem("📁 Abrir Carpeta", null, (s, e) => OpenDownloadFolder()) { ToolTipText = "Abrir carpeta de descargas" };
            downloadsContext.Items.Add(miPause);
            downloadsContext.Items.Add(miResume);
            downloadsContext.Items.Add(miCancel);
            downloadsContext.Items.Add(new ToolStripSeparator());
            downloadsContext.Items.Add(miOpenFolder);
            lvDownloads.ContextMenuStrip = downloadsContext;

            downloadsLayout.Controls.Add(lvDownloads, 0, 2);

            var statsPanel = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 4,
                AutoSize = true,
                BackColor = Color.FromArgb(30, 30, 32),
                Padding = new Padding(20, 12, 20, 12),
                Margin = new Padding(0, 16, 0, 0)
            };
            statsPanel.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 25f));
            statsPanel.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 25f));
            statsPanel.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 25f));
            statsPanel.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 25f));

            lblDownloadStats = new Label
            {
                Text = "Total descargas: 0",
                ForeColor = Color.White,
                AutoSize = true,
                Font = new Font("Segoe UI", 10, FontStyle.Bold)
            };
            statsPanel.Controls.Add(lblDownloadStats, 0, 0);

            lblDownloadSpeed = new Label
            {
                Text = "Velocidad total: 0 KB/s",
                ForeColor = Color.LightGray,
                AutoSize = true,
                Font = new Font("Segoe UI", 9)
            };
            statsPanel.Controls.Add(lblDownloadSpeed, 1, 0);

            lblDownloadQueue = new Label
            {
                Text = "En cola: 0 | Activas: 0 | Pausadas: 0",
                ForeColor = Color.LightGray,
                AutoSize = true,
                Font = new Font("Segoe UI", 9)
            };
            statsPanel.Controls.Add(lblDownloadQueue, 2, 0);

            lblDownloadErrors = new Label
            {
                Text = "Errores recientes: 0",
                ForeColor = Color.FromArgb(255, 180, 120),
                AutoSize = true,
                Font = new Font("Segoe UI", 9)
            };
            statsPanel.Controls.Add(lblDownloadErrors, 3, 0);

            downloadsLayout.Controls.Add(statsPanel, 0, 3);
            parent.Controls.Add(downloadsLayout);

            var tipsDl = GetToolTip();
            tipsDl.SetToolTip(filtersToggle, "Mostrar/ocultar filtros de estado de descargas");
            tipsDl.SetToolTip(chkActive, "Mostrar descargas en curso");
            tipsDl.SetToolTip(chkPaused, "Mostrar descargas pausadas");
            tipsDl.SetToolTip(chkCompleted, "Mostrar descargas completadas");
            tipsDl.SetToolTip(chkFailed, "Mostrar descargas fallidas");
            tipsDl.SetToolTip(chkQueued, "Mostrar descargas en cola");
            tipsDl.SetToolTip(btnStartDownloads, "Iniciar el procesamiento de la cola de descargas");
            tipsDl.SetToolTip(btnStopDownloads, "Pausar todas las descargas activas");
            tipsDl.SetToolTip(btnRetrySel, "Reintentar descargas fallidas/pendientes seleccionadas");
            tipsDl.SetToolTip(btnClearCompleted, "Quitar de la lista las descargas completadas o canceladas");
            tipsDl.SetToolTip(btnClearQueue, "Vaciar toda la cola de descargas");
            tipsDl.SetToolTip(btnOpenFolder2, "Abrir la carpeta de descargas");
            tipsDl.SetToolTip(lvDownloads, "Lista de descargas con prioridad actual, progreso y estado");
            tipsDl.SetToolTip(lblDownloadStats, "Conteo total de descargas listadas");
            tipsDl.SetToolTip(lblDownloadSpeed, "Velocidad total combinada de descargas activas");
            tipsDl.SetToolTip(lblDownloadQueue, "Resumen de elementos en cola, activos y pausados");
            tipsDl.SetToolTip(lblDownloadErrors, "Número de errores recientes de descarga");

            // Configurar persistencia de ancho de columnas
            SetupColumnWidthPersistence(lvDownloads, "lvDownloads");

            // Inicialmente ocultar el panel de filtros
            filterFlow.Visible = false;
            
            // Evento para mostrar/ocultar filtros avanzados
            filtersToggle.CheckedChanged += (s, e) =>
            {
                filterFlow.Visible = filtersToggle.Checked;
                controlsLayout.Height = filtersToggle.Checked ? controlsLayout.PreferredSize.Height : actionsFlow.Height + 32;
            };
            
            // Implementar filtros de descargas
            void ApplyFilters()
            {
                if (lvDownloads.InvokeRequired)
                {
                    lvDownloads.BeginInvoke(new Action(ApplyFilters));
                    return;
                }
                
                lvDownloads.BeginUpdate();
                try
                {
                    // MEJORA FASE 1.3: ReadLock para iteración
                    downloadQueueLock.EnterReadLock();
                    try
                    {
                        lvDownloads.Items.Clear();
                        foreach (var task in downloadQueue)
                        {
                            bool show = false;
                            
                            if (chkActive.Checked && task.Status == DownloadStatus.Downloading)
                                show = true;
                            if (chkPaused.Checked && task.Status == DownloadStatus.Paused)
                                show = true;
                            if (chkCompleted.Checked && task.Status == DownloadStatus.Completed)
                                show = true;
                            if (chkFailed.Checked && task.Status == DownloadStatus.Failed)
                                show = true;
                            if (chkQueued.Checked && task.Status == DownloadStatus.Queued)
                                show = true;
                            
                            if (show && task.ListViewItem != null)
                            {
                                AddItemWithAutoScroll(lvDownloads, task.ListViewItem);
                            }
                        }
                    }
                    finally
                    {
                        downloadQueueLock.ExitReadLock();
                    }
                }
                finally
                {
                    lvDownloads.EndUpdate();
                }
            }
            
            chkActive.CheckedChanged += (s, e) => ApplyFilters();
            chkPaused.CheckedChanged += (s, e) => ApplyFilters();
            chkCompleted.CheckedChanged += (s, e) => ApplyFilters();
            chkFailed.CheckedChanged += (s, e) => ApplyFilters();
            chkQueued.CheckedChanged += (s, e) => ApplyFilters();
        }
        
        private async Task InitializeSoulseekClient()
        {
            try
            {
                SafeLog("Inicializando cliente Soulseek...\n");
                
                // El cliente se inicializará cuando el usuario haga clic en "Conectar"
                // Por ahora solo preparamos las variables
                
                SafeLog("Cliente Soulseek preparado\n");
            }
            catch (Exception ex)
            {
                SafeLog($"ERROR al inicializar cliente: {ex.Message}\n");
                throw;
            }
        }
        
