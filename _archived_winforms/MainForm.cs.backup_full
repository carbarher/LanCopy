        // ===== BAN-AWARE COOLDOWN =====
        private TimeSpan GetBanCooldownForStrike(int strike)
        {
            // Perfil reducido: 1→15m, 2→45m, 3→90m, 4+→180m
            int minutes = strike <= 1 ? 15 : strike == 2 ? 45 : strike == 3 ? 90 : 180;
            var baseDelay = TimeSpan.FromMinutes(minutes);
            var jitter = GetJitter(baseDelay); // ~15%
            // Limitar jitter a ±10% para consistencia
            var maxJitter = TimeSpan.FromMilliseconds(baseDelay.TotalMilliseconds * 0.10);
            if (jitter > maxJitter) jitter = maxJitter;
            return baseDelay + jitter;
        }

        private void ApplyBanCooldown(string reason)
        {
            // Debounce: no escalar strikes si el último evento fue hace <30 minutos
            var minInterval = TimeSpan.FromMinutes(30);
            if (lastBanEventAt != DateTime.MinValue && (DateTime.UtcNow - lastBanEventAt) < minInterval)
            {
                Log($"⏳ Evento de posible bloqueo dentro de {minInterval.TotalMinutes:F0}m. Manteniendo cooldown actual sin escalar strike.");
                return;
            }
            // Resetear strikes si pasó 24h desde el último evento
            if (lastBanEventAt != DateTime.MinValue && (DateTime.UtcNow - lastBanEventAt) > TimeSpan.FromHours(24))
            {
                banStrikeCount = 0;
            }
            banStrikeCount++;
            lastBanEventAt = DateTime.UtcNow;

            var cooldown = GetBanCooldownForStrike(banStrikeCount);
            banCooldownUntil = DateTime.UtcNow + cooldown;
            nextAllowedReconnect = banCooldownUntil; // Respetar en el monitor
            lastAntiBlockCooldown = banCooldownUntil; // OPTIMIZACIÓN: Rastrear fin de cooldown

            LogEx(LogLevel.WARN, LogCategory.CONEXION, $"Pausa anti-bloqueo: strike {banStrikeCount}, {cooldown.TotalMinutes:F0} min. Razón: {reason}");
            AutoLog($"🛑 Pausa anti-bloqueo activada: {cooldown.TotalMinutes:F0} min (strike {banStrikeCount})");

            // Rotar puerto tras cooldown (idea #1)
            RotateListenPort();

            try { SaveConfig(); } catch (Exception ex) { AutoLog($"⚠️ Error guardando config tras cooldown: {ex.Message}"); }
        }

        private void RotateListenPort()
        {
            try
            {
                var oldPort = listenPort;
                
                // Modo stealth: evitar reutilizar puertos recientes
                int newPort;
                int attempts = 0;
                do
                {
                    newPort = portRng.Next(50000, 60001);
                    attempts++;
                } while (usedPorts.Contains(newPort) && attempts < 20);
                
                listenPort = newPort;
                usedPorts.Add(newPort);
                
                // Mantener solo los últimos 50 puertos usados
                if (usedPorts.Count > 50)
                {
                    usedPorts.RemoveAt(0);
                }
                
                lastPortRotation = DateTime.UtcNow;
                LogEx(LogLevel.INFO, LogCategory.STEALTH, $"Puerto rotado: {oldPort} → {listenPort}");
                try { SaveConfig(); } catch (Exception ex) { AutoLog($"⚠️ Error guardando config tras rotación: {ex.Message}"); }
            }
            catch (Exception ex)
            {
                LogEx(LogLevel.ERROR, LogCategory.STEALTH, $"Error rotando puerto: {ex.Message}");
            }
        }
        
        // Modo Stealth: Calcular delay variable entre búsquedas
        private async Task ApplyStealthDelay()
        {
            if (!stealthMode) return;
            
            try
            {
                // Calcular intervalo basado en historial reciente
                var now = DateTime.UtcNow;
                if (lastSearchTime != DateTime.MinValue)
                {
                    var lastInterval = now - lastSearchTime;
                    searchIntervals.Enqueue(lastInterval);
                    
                    // Mantener solo los últimos 10 intervalos
                    if (searchIntervals.Count > 10)
                        searchIntervals.Dequeue();
                }
                
                // Calcular delay variable: base + jitter + adaptación
                int baseDelay = 2000; // 2 segundos base
                int jitter = stealthRandom.Next(500, 2000); // 0.5-2s de jitter
                
                // Adaptación: si los últimos intervalos fueron muy cortos, aumentar delay
                if (searchIntervals.Count >= 5)
                {
                    var avgInterval = searchIntervals.Average(ts => ts.TotalMilliseconds);
                    if (avgInterval < 3000) // Si promedio < 3s, agregar penalización
                    {
                        jitter += stealthRandom.Next(1000, 3000);
                        AutoLog($"🕵️ Stealth: Intervalos cortos detectados, aumentando delay");
                    }
                }
                
                int totalDelay = baseDelay + jitter;
                AutoLog($"🕵️ Stealth delay: {totalDelay}ms");
                
                await Task.Delay(totalDelay).ConfigureAwait(false); // MEJORA #37
                lastSearchTime = DateTime.UtcNow;
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error en stealth delay: {ex.Message}");
            }
        }
        
        // Modo Stealth: Warm-up gradual al conectar
        private async Task StealthWarmup()
        {
            if (!stealthMode) return;
            
            try
            {
                AutoLog("🕵️ Iniciando warm-up stealth...");
                
                // FIX: Eliminar pings múltiples que saturan el servidor
                // El timer de keep-alive ya maneja esto cada 90s
                // Esperar 5-10 segundos para estabilizar la conexión
                int warmupDelay = stealthRandom.Next(5000, 10000);
                await Task.Delay(warmupDelay).ConfigureAwait(false); // MEJORA #37
                
                AutoLog("✅ Warm-up completado (keep-alive manejado por timer)");
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error en warm-up: {ex.Message}");
            }
        }

        private void CheckPortRotation()
        {
            try
            {
                if (lastPortRotation == DateTime.MinValue)
                    lastPortRotation = DateTime.UtcNow;
                if (DateTime.UtcNow - lastPortRotation >= portRotationInterval)
                {
                    RotateListenPort();
                }
            }
            catch (Exception ex) { AutoLog($"⚠️ Error en health-based throttling: {ex.Message}"); }
        }

        private void ApplyHealthBasedThrottling()
        {
            // DESACTIVADO: No modificar automáticamente las descargas del usuario
            // El usuario tiene control total sobre maxParallelDownloads
            return;
            
            try
            {
                if (connectionHealthScore < 50)
                {
                    if (maxParallelDownloads > 3)
                    {
                        int oldValue = maxParallelDownloads;
                        maxParallelDownloads = Math.Max(2, maxParallelDownloads / 2);
                        LogEx(LogLevel.WARN, LogCategory.DESCARGA, $"Health {connectionHealthScore:F0}: reduciendo descargas paralelas a {maxParallelDownloads}");
                        
                        // Actualizar UI
                        SafeInvoke(() =>
                        {
                            if (numParallelDownloads != null)
                            {
                                if (maxParallelDownloads > numParallelDownloads.Maximum)
                                    numParallelDownloads.Maximum = maxParallelDownloads;
                                if (maxParallelDownloads < numParallelDownloads.Minimum)
                                    numParallelDownloads.Minimum = maxParallelDownloads;
                                numParallelDownloads.Value = maxParallelDownloads;
                            }
                        });
                    }
                    if (autoPurgeRunning)
                    {
                        autoPurgePausedByDisconnection = true;
                        LogEx(LogLevel.WARN, LogCategory.PURGA, $"Health {connectionHealthScore:F0}: pausando purga automática");
                    }
                }
                else if (connectionHealthScore > 70)
                {
                    if (autoPurgePausedByDisconnection && !autoPurgeRunning)
                    {
                        autoPurgePausedByDisconnection = false;
                        LogEx(LogLevel.SUCCESS, LogCategory.PURGA, $"Health {connectionHealthScore:F0}: reanudando purga automática");
                    }
                }
            }
            catch (Exception ex) { AutoLog($"⚠️ Error aplicando throttling basado en salud: {ex.Message}"); }
        }

        private Task<UserInfo> UserInfoResolver(string requesterUsername, IPEndPoint endpoint)
        {
            try
            {
                int files;
                int dirs;
                lock (shareIndexLock)
                {
                    files = shareIndex.Count;
                    var set = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                    foreach (var it in shareIndex)
                    {
                        var d = Path.GetDirectoryName(it.RelativePath) ?? ".";
                        d = d.Replace('/', '\\');
                        if (string.IsNullOrEmpty(d)) d = ".";
                        set.Add(d);
                    }
                    dirs = Math.Max(1, set.Count);
                }
                int used = GetActiveUploadsCount();
                bool hasFree = used < Math.Max(1, maxConcurrentUploads);
                return Task.FromResult(new UserInfo(string.Empty, files, dirs, hasFree));
            }
            catch
            {
                return Task.FromResult(new UserInfo(string.Empty, 0, 0, false));
            }
        }

        private void AddSharedFolder()
        {
            try
            {
                var path = DarkFolderBrowserDialog.ShowDialog(this, "Seleccionar carpeta para compartir");
                if (!string.IsNullOrWhiteSpace(path))
                {
                    if (!sharedDirs.Contains(path, StringComparer.OrdinalIgnoreCase))
                    {
                        sharedDirs.Add(path);
                        if (lstSharedDirs != null) lstSharedDirs.Items.Add(path);
                        SaveConfig();
                        InitializeSharing();
                        Log($"📁 Carpeta compartida agregada: {path}");
                    }
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error agregando carpeta compartida: {ex.Message}");
            }
        }

        private void RemoveSelectedSharedFolder()
        {
            try
            {
                if (lstSharedDirs == null || lstSharedDirs.SelectedItem == null) return;
                var path = lstSharedDirs.SelectedItem.ToString();
                if (!string.IsNullOrWhiteSpace(path))
                {
                    sharedDirs.RemoveAll(d => string.Equals(d, path, StringComparison.OrdinalIgnoreCase));
                    lstSharedDirs.Items.Remove(lstSharedDirs.SelectedItem);
                    SaveConfig();
                    InitializeSharing();
                    Log($"🗑️ Carpeta compartida eliminada: {path}");
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error eliminando carpeta compartida: {ex.Message}");
            }
        }

        private Task OnEnqueueDownload(string username, IPEndPoint endpoint, string requestedPath)
        {
            try
            {
                if (!enableUploads)
                {
                    if (shareVerboseLogging) Log($"🚫 Enqueue rechazado (uploads off) de {username}: '{requestedPath}'");
                    throw new DownloadEnqueueException("Subidas deshabilitadas por configuración");
                }

                if (string.IsNullOrWhiteSpace(requestedPath))
                {
                    if (shareVerboseLogging) Log($"🚫 Enqueue con ruta inválida de {username}");
                    throw new DownloadEnqueueException("Ruta solicitada inválida");
                }

                string normalized = requestedPath.Replace('/', System.IO.Path.DirectorySeparatorChar).Replace('\\', System.IO.Path.DirectorySeparatorChar);

                bool found = false;
                foreach (var root in sharedDirs)
                {
                    try
                    {
                        if (string.IsNullOrWhiteSpace(root)) continue;
                        var candidate = System.IO.Path.Combine(root, normalized);
                        // MEJORA NICOTINE+: Usar PathCache para evitar llamadas repetidas a GetFullPath
                        var full = _pathCache?.GetNormalized(candidate) ?? System.IO.Path.GetFullPath(candidate);
                        var fullRoot = _pathCache?.GetNormalized(root) ?? System.IO.Path.GetFullPath(root);
                        if (full.StartsWith(fullRoot, StringComparison.OrdinalIgnoreCase) && System.IO.File.Exists(full))
                        {
                            found = true;
                            break;
                        }
                    }
                    catch (Exception ex) { AutoLog($"⚠️ Error en búsqueda de índice: {ex.Message}"); }
                }

                if (!found)
                {
                    lastEnqueueAt = DateTime.UtcNow;
                    lastEnqueueUser = username;
                    lastEnqueuePath = normalized;
                    lastEnqueueAccepted = false;
                    if (shareVerboseLogging) Log($"🚫 Enqueue rechazado (no compartido) de {username}: '{normalized}'");
                    throw new DownloadEnqueueException("Archivo no compartido o no encontrado");
                }
                lastEnqueueAt = DateTime.UtcNow;
                lastEnqueueUser = username;
                lastEnqueuePath = normalized;
                lastEnqueueAccepted = true;
                if (shareVerboseLogging) Log($"⬆️ Enqueue aceptado de {username}: '{normalized}'");
                return Task.CompletedTask;
            }
            catch (DownloadEnqueueException)
            {
                throw;
            }
            catch (Exception ex)
            {
                throw new DownloadEnqueueException($"Error validando solicitud: {ex.Message}");
            }
        }

        private Task<int?> OnPlaceInQueueResolver(string username, IPEndPoint endpoint, string requestedPath)
        {
            try
            {
                if (!enableUploads)
                {
                    if (shareVerboseLogging) Log($"ℹ️ Queue position consultada con uploads off por {username}: '{requestedPath}'");
                    return Task.FromResult<int?>(null);
                }
                int used = GetActiveUploadsCount();
                int limit = Math.Max(1, maxConcurrentUploads);
                int free = Math.Max(0, limit - used);
                int pos = free > 0 ? 0 : (used - limit + 1);
                if (shareVerboseLogging) Log($"🧮 Queue position {pos} para {username}: '{requestedPath}' (usadas {used}/{limit})");
                return Task.FromResult<int?>(pos);
            }
            catch
            {
                return Task.FromResult<int?>(null);
            }
        }

        private int GetActiveUploadsCount()
        {
            try
            {
                if (client == null) return 0;
                var uploads = client.Uploads;
                if (uploads == null) return 0;
                return uploads.Count;
            }
            catch { return 0; }
        }

        private int GetActiveDownloadsCount()
        {
            try
            {
                // MEJORA FASE 1.3: ReadLock para consulta
                return ReadLocked(downloadQueueLock, () => 
                    downloadQueue.Count(t => t.Status == DownloadStatus.Downloading));
            }
            catch { return 0; }
        }

        private Task<BrowseResponse> BrowseResponseResolver(string username, IPEndPoint endpoint)
        {
            try
            {
                var directories = new List<Soulseek.Directory>();
                foreach (var root in sharedDirs)
                {
                    if (string.IsNullOrWhiteSpace(root) || !System.IO.Directory.Exists(root)) continue;
                    var allDirs = System.IO.Directory.GetDirectories(root, "*", SearchOption.AllDirectories);
                    foreach (var dir in allDirs.Prepend(root))
                    {
                        try
                        {
                            var files = System.IO.Directory.GetFiles(dir)
                                .Select(f =>
                                {
                                    var fi = new FileInfo(f);
                                    return new Soulseek.File(1, Path.GetFileName(f), fi.Length, Path.GetExtension(f));
                                });
                            var rel = Path.GetRelativePath(root, dir);
                            var dirName = string.IsNullOrEmpty(rel) ? "." : rel.Replace('/', '\\');
                            directories.Add(new Soulseek.Directory(dirName, files));
                        }
                        catch { }
                    }
                }
                lastBrowseAt = DateTime.UtcNow;
                lastBrowseUser = username;
                lastBrowseDirs = directories.Count;
                if (shareVerboseLogging) Log($"🧭 Browse entrante de {username}: {directories.Count} carpetas");
                return Task.FromResult(new BrowseResponse(directories));
            }
            catch (Exception ex)
            {
                Log($"BrowseResponseResolver error: {ex.Message}");
                return Task.FromResult(new BrowseResponse(Enumerable.Empty<Soulseek.Directory>()));
            }
        }

        private Task<IEnumerable<Soulseek.Directory>> DirectoryContentsResponseResolver(string username, IPEndPoint endpoint, int token, string directory)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(directory))
                    return Task.FromResult(Enumerable.Empty<Soulseek.Directory>());

                var dirRel = directory.Replace('/', Path.DirectorySeparatorChar).Replace('\\', Path.DirectorySeparatorChar);
                string existingRoot = null;
                string dirPath = null;
                foreach (var root in sharedDirs)
                {
                    try
                    {
                        // MEJORA NICOTINE+: Usar PathCache
                        var candidate = _pathCache?.GetNormalized(Path.Combine(root, dirRel)) ?? Path.GetFullPath(Path.Combine(root, dirRel));
                        if (System.IO.Directory.Exists(candidate))
                        {
                            existingRoot = _pathCache?.GetNormalized(root) ?? Path.GetFullPath(root);
                            dirPath = candidate;
                            break;
                        }
                    }
                    catch { }
                }

                if (dirPath == null)
                {
                    if (shareVerboseLogging) Log($"📂 Contenidos solicitados no válidos por {username}: '{directory}'");
                    return Task.FromResult(Enumerable.Empty<Soulseek.Directory>());
                }

                static Soulseek.Directory MakeDirectory(string fsPath, string label)
                {
                    IEnumerable<Soulseek.File> files = Enumerable.Empty<Soulseek.File>();
                    try
                    {
                        files = System.IO.Directory.GetFiles(fsPath)
                            .Select(f =>
                            {
                                var fi = new FileInfo(f);
                                return new Soulseek.File(1, Path.GetFileName(f), fi.Length, Path.GetExtension(f));
                            });
                    }
                    catch { }
                    return new Soulseek.Directory(label, files);
                }

                var relThis = Path.GetRelativePath(existingRoot, dirPath).Replace('/', '\\');
                var list = new List<Soulseek.Directory> { MakeDirectory(dirPath, string.IsNullOrEmpty(relThis) ? "." : relThis) };
                try
                {
                    foreach (var sub in System.IO.Directory.GetDirectories(dirPath))
                    {
                        var rel = Path.GetRelativePath(existingRoot, sub).Replace('/', '\\');
                        list.Add(MakeDirectory(sub, string.IsNullOrEmpty(rel) ? "." : rel));
                    }
                }
                catch { }
                lastDirContentsAt = DateTime.UtcNow;
                lastDirUser = username;
                lastDirLabel = string.IsNullOrEmpty(relThis) ? "." : relThis;
                lastDirEntries = list.Count;
                if (shareVerboseLogging) Log($"📂 Contenidos para {username} en '{(string.IsNullOrEmpty(relThis) ? "." : relThis)}': {list.Count} entradas");
                return Task.FromResult(list.AsEnumerable());
            }
            catch (Exception ex)
            {
                Log($"DirectoryContentsResolver error: {ex.Message}");
                return Task.FromResult(Enumerable.Empty<Soulseek.Directory>());
            }
        }

        // MEJORA #1: Método helper para verificar frases prohibidas
        private bool ContainsExcludedPhrase(string path, string filename)
        {
            if (_excludedPhrases.Count == 0) return false;
            
            var fullPath = $"{path}/{filename}".ToLowerInvariant();
            return _excludedPhrases.Any(phrase => fullPath.Contains(phrase.ToLowerInvariant()));
        }
        
        private Task<Soulseek.SearchResponse> SearchResponseResolver(string requesterUsername, int token, SearchQuery query)
        {
            try
            {
                var q = (query?.SearchText ?? string.Empty).Trim();
                if (q.Length < 3)
                    return Task.FromResult<Soulseek.SearchResponse>(null);

                var results = new List<Soulseek.File>();
                
                // MEJORA NICOTINE+: Intentar usar WordIndex para búsqueda O(1)
                if (_wordIndex != null)
                {
                    var matchingIds = _wordIndex.SearchIds(q);
                    lock (shareIndexLock)
                    {
                        foreach (var id in matchingIds)
                        {
                            if (id >= 0 && id < shareIndex.Count)
                            {
                                var it = shareIndex[id];
                                var remotePath = it.RelativePath.Replace('/', '\\');
                                
                                // MEJORA #1: Filtrar frases prohibidas (Compliance)
                                if (!ContainsExcludedPhrase(it.RelativePath, Path.GetFileName(it.RelativePath)))
                                {
                                    results.Add(new Soulseek.File(1, remotePath, it.Size, it.Ext));
                                    if (results.Count >= Math.Max(1, responseLimit)) break;
                                }
                            }
                        }
                    }
                }
                else
                {
                    // Fallback: búsqueda lineal tradicional
                    List<(string RelativePath, string FullPath, long Size, string Ext)> idx;
                    lock (shareIndexLock)
                    {
                        idx = new List<(string RelativePath, string FullPath, long Size, string Ext)>(shareIndex);
                    }
                    if (idx.Count > 0)
                    {
                        foreach (var it in idx)
                        {
                            var relNorm = it.RelativePath;
                            if (relNorm.IndexOf(q, StringComparison.OrdinalIgnoreCase) >= 0)
                            {
                                var remotePath = relNorm.Replace('/', '\\');
                                
                                // MEJORA #1: Filtrar frases prohibidas (Compliance)
                                if (!ContainsExcludedPhrase(it.RelativePath, Path.GetFileName(it.RelativePath)))
                                {
                                    results.Add(new Soulseek.File(1, remotePath, it.Size, it.Ext));
                                    if (results.Count >= Math.Max(1, responseLimit)) break;
                                }
                            }
                        }
                    }
                    else
                    {
                        // Si shareIndex está vacío, buscar directamente en archivos
                        foreach (var root in sharedDirs)
                    {
                        if (string.IsNullOrWhiteSpace(root) || !System.IO.Directory.Exists(root)) continue;
                        try
                        {
                            foreach (var file in System.IO.Directory.EnumerateFiles(root, "*", SearchOption.AllDirectories))
                            {
                                var name = Path.GetFileName(file);
                                var rel = Path.GetRelativePath(root, file);
                                if (rel.IndexOf(q, StringComparison.OrdinalIgnoreCase) >= 0)
                                {
                                    var fi = new FileInfo(file);
                                    var remotePath = rel.Replace('/', '\\');
                                    
                                    // MEJORA #1: Filtrar frases prohibidas (Compliance)
                                    if (!ContainsExcludedPhrase(rel, name))
                                    {
                                        results.Add(new Soulseek.File(1, remotePath, fi.Length, Path.GetExtension(file)));
                                        if (results.Count >= Math.Max(1, responseLimit)) break;
                                    }
                                }
                            }
                        }
                        catch { }
                        if (results.Count >= Math.Max(1, responseLimit)) break;
                    }
                    }
                }

                lastIncomingSearchAt = DateTime.UtcNow;
                lastIncomingSearchUser = requesterUsername;
                lastIncomingSearchText = q;
                lastIncomingSearchResults = results.Count;
                if (shareVerboseLogging) Log($"🔎 Búsqueda entrante de {requesterUsername}: '{q}' -> {results.Count} resultados");
                if (results.Count == 0)
                    return Task.FromResult<Soulseek.SearchResponse>(null);

                var resp = new Soulseek.SearchResponse(
                    username,
                    token,
                    hasFreeUploadSlot: true,
                    uploadSpeed: maxUploadSpeedKib > 0 ? maxUploadSpeedKib : 0,
                    queueLength: 0,
                    fileList: results);

                return Task.FromResult(resp);
            }
            catch (Exception ex)
            {
                Log($"SearchResponseResolver error: {ex.Message}");
                return Task.FromResult<Soulseek.SearchResponse>(null);
            }
        }

        private void InitializeSharing()
        {
            try
            {
                LoadShareIndex();
                var sw = Stopwatch.StartNew();
                BuildShareIndex();
                sw.Stop();
                int count;
                lock (shareIndexLock)
                {
                    count = shareIndex.Count;
                }
                lastShareIndexBuildAt = DateTime.UtcNow;
                lastShareIndexCount = count;
                lastShareIndexMs = sw.ElapsedMilliseconds;
                Log($"📚 Índice de compartidos: {count} archivos en {sw.ElapsedMilliseconds} ms");
                SaveShareIndex();

                StartShareWatchers();
                Log($"👂 Watchers activos: {shareWatchers.Count}");
            }
            catch (Exception ex)
            {
                Log($"InitializeSharing error: {ex.Message}");
            }
        }

        private void RebuildShareIndex()
        {
            try
            {
                var sw = Stopwatch.StartNew();
                BuildShareIndex();
                sw.Stop();
                int count;
                lock (shareIndexLock)
                {
                    count = shareIndex.Count;
                    
                    // MEJORA NICOTINE+: Reconstruir WordIndex después de rebuild completo
                    if (_wordIndex != null)
                    {
                        _wordIndex.Clear();
                        for (int i = 0; i < shareIndex.Count; i++)
                        {
                            _wordIndex.AddWithId(i, shareIndex[i].RelativePath);
                        }
                        AutoLog($"✅ WordIndex reconstruido con {count} archivos");
                    }
                }
                lastShareIndexBuildAt = DateTime.UtcNow;
                lastShareIndexCount = count;
                lastShareIndexMs = sw.ElapsedMilliseconds;
                SaveShareIndex();
                Log($"🔄 Reconstruido índice: {count} archivos en {sw.ElapsedMilliseconds} ms");
            }
            catch (Exception ex)
            {
                Log($"Reconstrucción de índice falló: {ex.Message}");
            }
        }

        private async Task TestListenerPort()
        {
            try
            {
                int port = listenPort;
                using (var tcp = new System.Net.Sockets.TcpClient())
                {
                    var task = tcp.ConnectAsync("127.0.0.1", port);
                    if (await Task.WhenAny(task, Task.Delay(2000)) == task && tcp.Connected)
                    {
                        Log($"🧪 Listener prueba local OK en puerto {port}");
                    }
                    else
                    {
                        Log($"🧪 Listener prueba local FALLÓ en puerto {port}");
                    }
                }
            }
            catch (Exception ex)
            {
                Log($"🧪 Prueba de listener error: {ex.Message}");
            }
        }

        private void BuildShareIndex()
        {
            var list = new List<(string RelativePath, string FullPath, long Size, string Ext)>();
            foreach (var root in sharedDirs)
            {
                if (string.IsNullOrWhiteSpace(root) || !System.IO.Directory.Exists(root)) continue;
                try
                {
                    foreach (var f in System.IO.Directory.EnumerateFiles(root, "*", SearchOption.AllDirectories))
                    {
                        try
                        {
                            var fi = new FileInfo(f);
                            var rel = Path.GetRelativePath(root, fi.FullName);
                            list.Add((rel, fi.FullName, fi.Length, Path.GetExtension(f)));
                        }
                        catch (Exception ex) { AutoLog($"⚠️ Error procesando archivo compartido: {ex.Message}"); }
                    }
                }
                catch (Exception ex) { AutoLog($"⚠️ Error construyendo índice de compartidos: {ex.Message}"); }
            }
            lock (shareIndexLock)
            {
                shareIndex = list;
            }
        }

        private void SaveShareIndex()
        {
            try
            {
                List<(string RelativePath, string FullPath, long Size, string Ext)> snapshot;
                lock (shareIndexLock)
                {
                    snapshot = new List<(string RelativePath, string FullPath, long Size, string Ext)>(shareIndex);
                }
                var data = snapshot.Select(x => new { x.RelativePath, x.FullPath, x.Size, x.Ext }).ToList();
                var json = JsonSerializer.Serialize(data);
                System.IO.File.WriteAllText(shareIndexPath, json);
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error guardando índice de shares: {ex.Message}");
            }
        }

        private void LoadShareIndex()
        {
            try
            {
                if (!System.IO.File.Exists(shareIndexPath)) return;
                var json = System.IO.File.ReadAllText(shareIndexPath);
                var data = JsonSerializer.Deserialize<List<Dictionary<string, object>>>(json);
                if (data == null) return;
                var list = new List<(string RelativePath, string FullPath, long Size, string Ext)>();
                foreach (var it in data)
                {
                    try
                    {
                        // MEJORA #20: Usar TryGetValue para evitar doble búsqueda en diccionario
                        it.TryGetValue("RelativePath", out var relObj);
                        it.TryGetValue("FullPath", out var fullObj);
                        it.TryGetValue("Ext", out var extObj);
                        
                        var rel = relObj?.ToString();
                        var full = fullObj?.ToString();
                        var ext = extObj?.ToString();
                        
                        long size = 0;
                        if (it.TryGetValue("Size", out var sizeObj))
                            long.TryParse(sizeObj?.ToString(), out size);
                            
                        if (!string.IsNullOrWhiteSpace(rel) && !string.IsNullOrWhiteSpace(full))
                            list.Add((rel, full, size, ext ?? string.Empty));
                    }
                    catch { }
                }
                lock (shareIndexLock)
                {
                    shareIndex = list;
                }
                lastShareIndexBuildAt = DateTime.UtcNow;
                lastShareIndexCount = list.Count;
                lastShareIndexMs = 0;
                Log($"📦 Índice precargado: {list.Count} archivos");
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error cargando índice de shares: {ex.Message}");
            }
        }

        private void StartShareWatchers()
        {
            StopShareWatchers();
            foreach (var root in sharedDirs)
            {
                if (string.IsNullOrWhiteSpace(root) || !System.IO.Directory.Exists(root)) continue;
                try
                {
                    var w = new FileSystemWatcher(root)
                    {
                        IncludeSubdirectories = true,
                        EnableRaisingEvents = true,
                        NotifyFilter = NotifyFilters.FileName | NotifyFilters.Size | NotifyFilters.LastWrite
                    };
                    w.Created += (s, e) => OnFsCreated(e.FullPath);
                    w.Changed += (s, e) => OnFsChanged(e.FullPath);
                    w.Deleted += (s, e) => OnFsDeleted(e.FullPath);
                    w.Renamed += (s, e) => { OnFsDeleted(e.OldFullPath); OnFsCreated(e.FullPath); };
                    shareWatchers.Add(w);
                }
                catch (Exception ex) { AutoLog($"⚠️ Error iniciando FileSystemWatcher: {ex.Message}"); }
            }
        }

        private void StopShareWatchers()
        {
            foreach (var w in shareWatchers)
            {
                try { w.EnableRaisingEvents = false; w.Dispose(); } catch (Exception ex) { AutoLog($"⚠️ Error deteniendo watcher: {ex.Message}"); }
            }
            shareWatchers.Clear();
        }

        private void OnFsCreated(string fullPath)
        {
            try
            {
                if (!System.IO.File.Exists(fullPath)) return;
                if (!IsSharedPath(fullPath)) return;
                var fi = new FileInfo(fullPath);
                lock (shareIndexLock)
                {
                    shareIndex.RemoveAll(x => string.Equals(x.FullPath, fi.FullName, StringComparison.OrdinalIgnoreCase));
                    if (TryGetShareRoot(fi.FullName, out var root))
                    {
                        var rel = Path.GetRelativePath(root, fi.FullName);
                        shareIndex.Add((rel, fi.FullName, fi.Length, Path.GetExtension(fi.FullName)));
                        
                        // MEJORA NICOTINE+: Agregar al WordIndex
                        _wordIndex?.AddWithId(shareIndex.Count - 1, rel);
                    }
                }
            }
            catch (Exception ex) { AutoLog($"⚠️ Error en OnFsCreated: {ex.Message}"); }
        }

        private void OnFsChanged(string fullPath)
        {
            try
            {
                if (!System.IO.File.Exists(fullPath)) return;
                if (!IsSharedPath(fullPath)) return;
                var fi = new FileInfo(fullPath);
                lock (shareIndexLock)
                {
                    for (int i = 0; i < shareIndex.Count; i++)
                    {
                        if (string.Equals(shareIndex[i].FullPath, fi.FullName, StringComparison.OrdinalIgnoreCase))
                        {
                            if (TryGetShareRoot(fi.FullName, out var root))
                            {
                                var rel = Path.GetRelativePath(root, fi.FullName);
                                shareIndex[i] = (rel, fi.FullName, fi.Length, Path.GetExtension(fi.FullName));
                            }
                            return;
                        }
                    }
                    if (TryGetShareRoot(fi.FullName, out var root2))
                    {
                        var rel2 = Path.GetRelativePath(root2, fi.FullName);
                        shareIndex.Add((rel2, fi.FullName, fi.Length, Path.GetExtension(fi.FullName)));
                        
                        // MEJORA NICOTINE+: Agregar al WordIndex
                        _wordIndex?.AddWithId(shareIndex.Count - 1, rel2);
                    }
                }
            }
            catch (Exception ex) { AutoLog($"⚠️ Error en OnFsChanged: {ex.Message}"); }
        }

        private void OnFsDeleted(string fullPath)
        {
            try
            {
                lock (shareIndexLock)
                {
                    var countBefore = shareIndex.Count;
                    shareIndex.RemoveAll(x => string.Equals(x.FullPath, fullPath, StringComparison.OrdinalIgnoreCase));
                    
                    // MEJORA NICOTINE+: Si se eliminó algo, reconstruir WordIndex
                    if (shareIndex.Count < countBefore && _wordIndex != null)
                    {
                        _wordIndex.Clear();
                        for (int i = 0; i < shareIndex.Count; i++)
                        {
                            _wordIndex.AddWithId(i, shareIndex[i].RelativePath);
                        }
                    }
                }
            }
            catch (Exception ex) { AutoLog($"⚠️ Error en OnFsDeleted: {ex.Message}"); }
        }

        private bool IsSharedPath(string path)
        {
            try
            {
                // MEJORA NICOTINE+: Usar PathCache
                var full = _pathCache?.GetNormalized(path) ?? Path.GetFullPath(path);
                foreach (var root in sharedDirs)
                {
                    if (string.IsNullOrWhiteSpace(root)) continue;
                    var fullRoot = _pathCache?.GetNormalized(root) ?? Path.GetFullPath(root);
                    if (full.StartsWith(fullRoot, StringComparison.OrdinalIgnoreCase)) return true;
                }
            }
            catch { }
            return false;
        }

        private bool TryGetShareRoot(string fullPath, out string root)
        {
            root = null;
            try
            {
                // MEJORA NICOTINE+: Usar PathCache
                var full = _pathCache?.GetNormalized(fullPath) ?? Path.GetFullPath(fullPath);
                foreach (var r in sharedDirs)
                {
                    if (string.IsNullOrWhiteSpace(r)) continue;
                    var fr = _pathCache?.GetNormalized(r) ?? Path.GetFullPath(r);
                    if (full.StartsWith(fr, StringComparison.OrdinalIgnoreCase))
                    {
                        root = fr;
                        return true;
                    }
                }
            }
            catch { }
            return false;
        }
        
