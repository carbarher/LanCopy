            // Asegurar que la contraseña NO esté encriptada visualmente
            txtPassword.UseSystemPasswordChar = false;
            txtPassword.PasswordChar = '\0';
            accountSection.Controls.Add(passRow);
            
            leftColumn.Controls.Add(accountSection);

            // === SECCIÓN CARPETAS ===
