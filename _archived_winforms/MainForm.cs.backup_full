            memorySection.Controls.Add(btnOptimizeMemory);
            
            // Nota informativa
            var infoLabel = new Label
            {
                Text = "💡 La limpieza automática está siempre activa",
                ForeColor = Color.Gray,
                Font = new Font("Segoe UI", 8),
                AutoSize = true,
                Margin = new Padding(0, 4, 0, 0)
            };
            memorySection.Controls.Add(infoLabel);
            
            leftColumn.Controls.Add(memorySection);

            // === SECCIÓN FILTROS ===
            var filtersSection = CreateConfigSectionPanel("🔁 FILTROS Y REINTENTOS");
            
            NumericUpDown numAltControl = null;
            NumericUpDown numMinFileSizeControl = null;
            
            var retriesRow = CreateNumericRow("Reintentos:", out numMaxRetries, maxRetries, 0, 10, (s, e) => { maxRetries = (int)numMaxRetries.Value; OnRetrySettingsChanged(); });
            var altRow = CreateNumericRow("Alternativos:", out numAltControl, maxAlternativeRetries, 0, 100, (s, e) =>
            {
                maxAlternativeRetries = (int)numAltControl.Value;
                if (maxAlternativeRetries > maxTotalAttempts)
                {
                    maxAlternativeRetries = maxTotalAttempts;
                    numAltControl.Value = maxTotalAttempts;
                }
                OnRetrySettingsChanged();
            });
            altRow.Controls.Add(CreateSmallLabel("(sujeto al límite total)"));

            var totalAttemptsRow = CreateNumericRow("Intentos totales:", out numMaxTotalAttempts, maxTotalAttempts, 1, 100, (s, e) =>
            {
                maxTotalAttempts = (int)numMaxTotalAttempts.Value;
                if (maxAlternativeRetries > maxTotalAttempts)
                {
                    maxAlternativeRetries = maxTotalAttempts;
                    numAltControl.Value = maxTotalAttempts;
                }
                OnRetrySettingsChanged();
            });
            var blacklistThresholdRow = CreateNumericRow("Fallas bloqueo:", out numBlacklistThreshold, providerBlacklistThreshold, 1, 10, (s, e) =>
            {
                providerBlacklistThreshold = (int)numBlacklistThreshold.Value;
                OnRetrySettingsChanged();
            });
            var blacklistHoursRow = CreateNumericRow("Duración bloqueo (h):", out numBlacklistHours, (decimal)providerBlacklistHours, 1, 72, (s, e) =>
            {
                providerBlacklistHours = (double)numBlacklistHours.Value;
                OnRetrySettingsChanged();
            });
            numBlacklistHours.DecimalPlaces = 1;
            numBlacklistHours.Increment = 0.5M;

            var sizeRow = CreateNumericRow("Tamaño mín (KB):", out numMinFileSizeControl, minFileSizeKB, 0, 1048576, (s, e) => { minFileSizeKB = (int)numMinFileSizeControl.Value; SaveConfig(); });
            sizeRow.Controls.Add(CreateSmallLabel("(0 = sin límite)"));
            
            filtersSection.Controls.Add(retriesRow);
            filtersSection.Controls.Add(altRow);
            filtersSection.Controls.Add(totalAttemptsRow);
            filtersSection.Controls.Add(blacklistThresholdRow);
            filtersSection.Controls.Add(blacklistHoursRow);
            filtersSection.Controls.Add(sizeRow);
            
            leftColumn.Controls.Add(filtersSection);

            // === SECCIÓN OPTIMIZACIONES ===
            var optSection = CreateConfigSectionPanel("🚀 OPTIMIZACIONES");
            
            var chkVirtualListView = CreateCheckBox("🔷 Virtual ListView", useVirtualListView, (s, e) => { useVirtualListView = ((CheckBox)s).Checked; SaveConfig(); });
            var chkSQLite = CreateCheckBox("💾 SQLite (>10K resultados)", useSQLiteForLargeResults, (s, e) => { useSQLiteForLargeResults = ((CheckBox)s).Checked; SaveConfig(); });
            var chkRust = CreateCheckBox("🦀 Rust (10-50x)", useRustOptimizations, (s, e) => 
            { 
                useRustOptimizations = ((CheckBox)s).Checked; 
                if (useRustOptimizations && !RustSearchOptimizer.IsRustAvailable())
                {
                    useRustOptimizations = false;
                    ((CheckBox)s).Checked = false;
                    Log("⚠️ Rust no disponible");
                }
                SaveConfig();
            });
            var chkOptDownloadMgr = CreateCheckBox("⚡ Download Manager Paralelo", useOptimizedDownloadManager, (s, e) => { useOptimizedDownloadManager = ((CheckBox)s).Checked; SaveConfig(); });
            var chkVirtualDownloads = CreateCheckBox("📋 Virtual Downloads", useVirtualDownloadsList, (s, e) => { useVirtualDownloadsList = ((CheckBox)s).Checked; SaveConfig(); });
            var chkMemoryOpt = CreateCheckBox("💾 Memoria (-50% RAM)", useStringInterning && useLZ4Compression, (s, e) => 
            { 
                bool enabled = ((CheckBox)s).Checked;
                useStringInterning = useLZ4Compression = useObjectPooling = enabled;
                SaveConfig();
            });
            var chkNetworkOpt = CreateCheckBox("🌐 Red (-30% timeouts)", useAdaptiveTimeout && useCircuitBreaker, (s, e) => 
            { 
                bool enabled = ((CheckBox)s).Checked;
                useAdaptiveTimeout = useCircuitBreaker = useSmartRetry = enabled;
                SaveConfig();
            });
            var chkDiskOpt = CreateCheckBox("💿 Disco (-50% espacio)", useAsyncIO && useHardLinks, (s, e) => 
            { 
                bool enabled = ((CheckBox)s).Checked;
                useAsyncIO = useHardLinks = usePreAllocation = enabled;
                SaveConfig();
            });
            
            optSection.Controls.Add(chkVirtualListView);
            optSection.Controls.Add(chkSQLite);
            optSection.Controls.Add(chkRust);
            optSection.Controls.Add(chkOptDownloadMgr);
            optSection.Controls.Add(chkVirtualDownloads);
            optSection.Controls.Add(chkMemoryOpt);
            optSection.Controls.Add(chkNetworkOpt);
            optSection.Controls.Add(chkDiskOpt);
            
            // Filtro de calidad (Nicotine+ inspired) - Minimalista
            bool isQualityFilterEnabled = audioQualityFilters?.MinBitrate != null;
            var chkQualityFilter = CreateCheckBox("🎵 Filtrar baja calidad (audio <192kbps)", isQualityFilterEnabled, (s, e) => 
            { 
                bool enabled = ((CheckBox)s).Checked;
                if (enabled)
                {
                    audioQualityFilters.MinBitrate = 192;
                    audioQualityFilters.MinQualityScore = 50;
                    Log("✅ Filtro de calidad activado: mínimo 192kbps");
                }
                else
                {
                    audioQualityFilters.MinBitrate = null;
                    audioQualityFilters.MinQualityScore = null;
                    Log("❌ Filtro de calidad desactivado");
                }
                SaveConfig();
            });
            optSection.Controls.Add(chkQualityFilter);
            
            var btnPerfStats = CreateButton("📊 Estadísticas", Color.FromArgb(0, 122, 204), ShowPerformanceStats);
            btnPerfStats.Width = 180;
            btnPerfStats.Margin = new Padding(0, 8, 0, 0);
            optSection.Controls.Add(btnPerfStats);
            
            // NUEVO: Botón Dashboard Visual
            var btnDashboard = CreateButton("📈 Dashboard Visual", Color.FromArgb(0, 150, 136), ShowDashboard);
            btnDashboard.Width = 180;
            btnDashboard.Margin = new Padding(0, 8, 0, 0);
            optSection.Controls.Add(btnDashboard);
            
            // NUEVO: Botones Geo-Aware
            var btnGeoMap = CreateButton("🗺️ Mapa Mundial", Color.FromArgb(0, 120, 215));
            btnGeoMap.Width = 180;
            btnGeoMap.Margin = new Padding(0, 4, 0, 0);
            btnGeoMap.Click += (s, e) => 
            {
                try
                {
                    if (geoService == null)
                    {
                        DarkMessageBox.Show("El servicio de geolocalización no está inicializado.", "Mapa no disponible", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                        return;
                    }
                    AutoLog("🗺️ Abriendo Mapa Mundial de Proveedores...");
                    var mapForm = new SlskDown.UI.GeoMapForm(geoService);
                    mapForm.Show();
                    AutoLog("✅ Mapa abierto exitosamente");
                }
                catch (Exception ex)
                {
                    AutoLog($"❌ Error abriendo mapa: {ex.Message}");
                    DarkMessageBox.Show($"Error al abrir el mapa mundial:\n\n{ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            };
            optSection.Controls.Add(btnGeoMap);
            
            var btnGeoPanel = CreateButton("🌍 Control Geo-Aware", Color.FromArgb(0, 150, 100));
            btnGeoPanel.Width = 180;
            btnGeoPanel.Margin = new Padding(0, 4, 0, 0);
            btnGeoPanel.Click += (s, e) => 
            {
                try
                {
                    if (geoService == null || geoPrioritizer == null)
                    {
                        DarkMessageBox.Show("El sistema Geo-Aware no está inicializado.", "Panel no disponible", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                        return;
                    }
                    AutoLog("🌍 Abriendo Panel de Control Geo-Aware...");
                    var panel = new SlskDown.UI.GeoControlPanel(geoService, geoPrioritizer);
                    panel.ShowDialog();
                    geoAwareEnabled = panel.GeoAwareEnabled;
                    AutoLog($"✅ Panel cerrado - Geo-Aware: {(geoAwareEnabled ? "Habilitado" : "Deshabilitado")}");
                }
                catch (Exception ex)
                {
                    AutoLog($"❌ Error abriendo panel Geo-Aware: {ex.Message}");
                    DarkMessageBox.Show($"Error al abrir el panel de control:\n\n{ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            };
            optSection.Controls.Add(btnGeoPanel);
            
            leftColumn.Controls.Add(optSection);

