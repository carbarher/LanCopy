    public class ListViewItemComparer : System.Collections.IComparer
    {
        private int col;
        private bool ascending;

        public ListViewItemComparer(int column, bool ascending)
        {
            col = column;
            this.ascending = ascending;
        }

        public int Compare(object? x, object? y)
        {
            if (x == null || y == null) return 0;
            
            var itemX = (ListViewItem)x;
            var itemY = (ListViewItem)y;
            
            string strX = itemX.SubItems[col].Text;
            string strY = itemY.SubItems[col].Text;

            int result;
            
            // Intentar comparar como números si es posible
            if (long.TryParse(strX.Replace(" MB", "").Replace(" KB", "").Replace(" GB", ""), out long numX) &&
                long.TryParse(strY.Replace(" MB", "").Replace(" KB", "").Replace(" GB", ""), out long numY))
            {
                result = numX.CompareTo(numY);
            }
            else
            {
                result = string.Compare(strX, strY);
            }

            return ascending ? result : -result;
        }
    }
