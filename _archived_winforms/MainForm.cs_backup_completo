            if (selected.Tag is not SearchResult baseResult) return;
            string username = baseResult.Username;

            var browseForm = new Form
            {
                Text = $"Archivos de {username}",
                Size = new Size(900, 600),
                StartPosition = FormStartPosition.CenterScreen,
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.White
            };

            // Árbol de carpetas/archivos
            var tv = new TreeView
            {
                Dock = DockStyle.Fill,
                BackColor = Color.FromArgb(45, 45, 45),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                ShowRootLines = true,
                ShowLines = true
            };

            // Obtener todo el share (sin filtrar) y construir árbol de carpetas (optimizado con diccionario)
            var files = await BrowseUserFilesAsync(username);
            long totalBytes = 0; int count = 0;
            var nodeByPath = new Dictionary<string, TreeNode>(StringComparer.OrdinalIgnoreCase);
            tv.BeginUpdate();
            tv.Nodes.Clear();
            foreach (var f in files)
            {
                var dir = f.Directory;
                // OPTIMIZACIÓN: Usar ReadOnlySpan para split sin allocations
                ReadOnlySpan<char> dirSpan = dir?.Replace('/', '\\').AsSpan() ?? ReadOnlySpan<char>.Empty;
                var parts = dirSpan.IsEmpty ? 
                    Array.Empty<string>() : 
                    dirSpan.ToString().Split('\\', StringSplitOptions.RemoveEmptyEntries);
                TreeNodeCollection cur = tv.Nodes;
                string currentPath = "";
                foreach (var p in parts)
                {
                    currentPath = string.IsNullOrEmpty(currentPath) ? p : currentPath + "\\" + p;
                    if (!nodeByPath.TryGetValue(currentPath, out var node))
                    {
                        node = new TreeNode(p);
                        cur.Add(node);
                        nodeByPath[currentPath] = node;
                    }
                    cur = node.Nodes;
                }
                var fileName = Path.GetFileName(f.Filename);
                var leaf = new TreeNode($"{fileName}  ({FormatFileSize(f.Size)})");
                // Guardamos SearchResult para posibles descargas futuras
                leaf.Tag = new SearchResult { Username = username, Filename = f.Filename, Size = f.Size, Extension = f.Extension };
                cur.Add(leaf);
                totalBytes += f.Size; count++;
            }
            tv.EndUpdate();
            tv.ExpandAll();
            browseForm.Text = $"Archivos de {username} — {count} ítems, {FormatFileSize(totalBytes)}";

            // Clic izquierdo: si es archivo, descargar; si es carpeta, preguntar y descargar todo lo que cuelga
            tv.NodeMouseClick += async (s2, e2) =>
            {
                if (e2.Button != MouseButtons.Left) return;
                if (e2.Node == null) return;

                // Archivo (hoja)
                if (e2.Node.Tag is SearchResult single)
                {
                    // Evitar duplicados
                    string k = $"{single.Username}|{single.Filename}";
                    if (!activeDownloads.ContainsKey($"{single.Username}_{single.Filename}"))
                    {
                        await DownloadFile(single);
                    }
                    return;
                }

                // Carpeta: contar y confirmar
                var toDownload = new List<SearchResult>();
                void Collect(TreeNode n)
                {
                    if (n.Tag is SearchResult sr) toDownload.Add(sr);
                    foreach (TreeNode c in n.Nodes) Collect(c);
                }
                Collect(e2.Node);
                if (toDownload.Count == 0) return;

                // De-duplicar por usuario+archivo y saltar descargas ya activas
                var unique = new List<SearchResult>();
                var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                foreach (var sr in toDownload)
                {
                    string key1 = $"{sr.Username}|{sr.Filename}";
                    string keyActive = $"{sr.Username}_{sr.Filename}";
                    if (seen.Contains(key1)) continue;
                    if (activeDownloads.ContainsKey(keyActive)) continue;
                    seen.Add(key1);
                    unique.Add(sr);
                }
                if (unique.Count == 0) return;

                var confirm = DarkMessageBox.Show(
                    $"Descargar {unique.Count} archivos de:\n{e2.Node.FullPath}?",
                    "Descargar carpeta",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Question);
                if (confirm != DialogResult.Yes) return;

                await Task.Run(async () =>
                {
                    foreach (var sr in unique)
                    {
                        await DownloadFile(sr);
                    }
                });
            };

            // Mostrar sólo árbol centrado
            browseForm.Controls.Add(tv);
            browseForm.Show(this);
        }

        private class UserSharedFile
        {
            public string Filename { get; set; } = string.Empty;
            public long Size { get; set; }
            public string Extension { get; set; } = string.Empty;
            public string Directory { get; set; } = string.Empty;
        }

        private async Task<List<UserSharedFile>> BrowseUserFilesAsync(string username)
        {
            var list = new List<UserSharedFile>();
            // Intentar via cliente usando reflexión para no romper compilación si cambia la API
            try
            {
                if (client != null)
                {
                    // OPTIMIZACIÓN: Cachear MethodInfo para evitar reflexión repetida
                    if (cachedBrowseMethod == null)
                    {
                        var t = client.GetType();
                        cachedBrowseMethod = t.GetMethod("BrowseAsync") ?? t.GetMethod("BrowseUserAsync") ?? t.GetMethod("GetSharedFilesAsync");
                    }
                    
                    var mi = cachedBrowseMethod;
                    if (mi != null)
                    {
                        var taskObj = mi.Invoke(client, new object?[] { username });
                        if (taskObj is Task browseTask)
                        {
                            await browseTask.ConfigureAwait(false);
                            var resultProp = browseTask.GetType().GetProperty("Result");
                            var result = resultProp?.GetValue(browseTask);
                            if (result != null)
                            {
                                // Intentar propiedades comunes: Files, SharedFiles
                                var filesProp = result.GetType().GetProperty("Files") ?? result.GetType().GetProperty("SharedFiles");
                                var filesEnum = filesProp?.GetValue(result) as System.Collections.IEnumerable;
                                if (filesEnum != null)
                                {
                                    foreach (var f in filesEnum)
                                    {
                                        string filename = (f.GetType().GetProperty("Filename")?.GetValue(f)?.ToString()) ??
                                                          (f.GetType().GetProperty("FileName")?.GetValue(f)?.ToString()) ?? string.Empty;
                                        long size = 0;
                                        var sizeObj = f.GetType().GetProperty("Size")?.GetValue(f);
                                        if (sizeObj is long l) size = l; else if (sizeObj is int i) size = i; else if (sizeObj is double d) size = (long)d;
                                        string dir = (f.GetType().GetProperty("Directory")?.GetValue(f)?.ToString()) ?? string.Empty;
                                        var ext = Path.GetExtension(filename)?.Trim('.').ToLower() ?? "";
                                        if (!string.IsNullOrWhiteSpace(filename))
                                        {
                                            list.Add(new UserSharedFile { Filename = filename, Size = size, Directory = dir, Extension = ext });
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
            catch { /* ignorar, caemos al fallback */ }

            if (list.Count == 0)
            {
                // Fallback: usar resultados ya listados del mismo usuario
                foreach (ListViewItem it in resultsListView.Items)
                {
                    if (it.Tag is SearchResult r && r.Username == username)
                    {
                        var ext = Path.GetExtension(r.Filename)?.Trim('.').ToLower() ?? r.Extension;
                        list.Add(new UserSharedFile
                        {
                            Filename = r.Filename,
                            Size = r.Size,
                            Extension = ext,
                            Directory = Path.GetDirectoryName(r.Filename) ?? string.Empty
                        });
                    }
                }
            }

            return list;
        }
        
