                                    catch (Exception ex)
                                    {
                                        this.Invoke((MethodInvoker)delegate
                                        {
                                            authorSearchLog.AppendText($"      ❌ Error: {ex.Message}\r\n");
                                            authorSearchLog.SelectionStart = authorSearchLog.Text.Length;
                                            authorSearchLog.ScrollToCaret();
                                        });
                                    }
                                }
                                
                                this.Invoke((MethodInvoker)delegate
                                {
                                    authorSearchLog.AppendText($"\r\n  ✅ Todas las descargas iniciadas para {author}\r\n\r\n");
                                    authorSearchLog.SelectionStart = authorSearchLog.Text.Length;
                                    authorSearchLog.ScrollToCaret();
                                });
                            }
                            */
                            
                            // SIMULACIÓN: Solo marcar como descargado sin descargar realmente
                            if (filesToDownload.Count > 0)
                            {
                                // Contar archivos nuevos encontrados en esta pasada
                                filesFoundThisPass += filesToDownload.Count;
                                
                                // Reiniciar contador de pasadas vacías para este autor (encontró archivos)
                                authorEmptyPassCount[author] = 0;
                                this.Invoke((MethodInvoker)delegate
                                {
                                    authorSearchLog.AppendText($"  💾 Simulando descarga de {filesToDownload.Count} archivos (sin descargar realmente)...\r\n\r\n");
                                    authorSearchLog.SelectionStart = authorSearchLog.Text.Length;
                                    authorSearchLog.ScrollToCaret();
                                });
                                
                                int downloadIndex = 0;
                                foreach (var (file, username) in filesToDownload)
                                {
                                    downloadIndex++;
                                    string filename = Path.GetFileName(file.Filename);
                                    
                                    // Mostrar en log
                                    this.Invoke((MethodInvoker)delegate
                                    {
                                        string sizeStr = file.Size > 1024 * 1024 ? $"{file.Size / (1024.0 * 1024.0):F1} MB" : $"{file.Size / 1024.0:F1} KB";
                                        authorSearchLog.AppendText($"  [{downloadIndex}/{filesToDownload.Count}] 💾 Simulado: {filename} ({sizeStr})\r\n");
                                        authorSearchLog.SelectionStart = authorSearchLog.Text.Length;
                                        authorSearchLog.ScrollToCaret();
                                    });
                                    
                                    // Marcar como descargado en el tracking JSON
                                    _downloadTracking?.MarkAsDownloaded(file.Filename, username, file.Size, author);
                                    
                                    // OPTIMIZACIÓN: Usar WriteBuffer para batch writes
                                    try
                                    {
                                        // Formato CSV con pipe: filename|author|size|date
                                        string csvLine = $"{filename}|{author}|{file.Size}|{DateTime.Now:yyyy-MM-dd HH:mm:ss}";
                                        writeBuffer.Add(csvLine);
                                        
                                        // Flush si es necesario (cada 10 archivos o 30s)
                                        if (writeBuffer.ShouldFlush())
                                        {
                                            string downloadedFilesFullPath = Path.IsPathRooted(downloadedFilesListPath) 
                                                ? downloadedFilesListPath 
                                                : Path.Combine(AppDomain.CurrentDomain.BaseDirectory, downloadedFilesListPath);
                                            
                                            var linesToWrite = writeBuffer.Flush();
                                            System.IO.File.AppendAllLines(downloadedFilesFullPath, linesToWrite);
                                        }
                                    }
                                    catch (Exception ex)
                                    {
                                        Console.WriteLine($"Error escribiendo en TXT: {ex.Message}");
                                    }
                                    
                                    // Pequeño delay para simular descarga
                                    await Task.Delay(100);
                                }
                                
                                // OPTIMIZACIÓN: Flush final del buffer
                                if (writeBuffer.Count > 0)
                                {
                                    try
                                    {
                                        string downloadedFilesFullPath = Path.IsPathRooted(downloadedFilesListPath) 
                                            ? downloadedFilesListPath 
                                            : Path.Combine(AppDomain.CurrentDomain.BaseDirectory, downloadedFilesListPath);
                                        
                                        var linesToWrite = writeBuffer.Flush();
                                        System.IO.File.AppendAllLines(downloadedFilesFullPath, linesToWrite);
                                    }
                                    catch (Exception ex)
                                    {
                                        Console.WriteLine($"Error en flush final: {ex.Message}");
                                    }
                                }
                                
                                // Incrementar contador global
                                totalDownloadsQueued += filesToDownload.Count;
                                
                                this.Invoke((MethodInvoker)delegate
                                {
                                    authorSearchLog.AppendText($"\r\n  ✅ Simulación completada para {author} ({filesToDownload.Count} archivos)\r\n\r\n");
                                    authorSearchLog.SelectionStart = authorSearchLog.Text.Length;
                                    authorSearchLog.ScrollToCaret();
                                });
                            }
                            else
                            {
                                // Incrementar contador de pasadas vacías para este autor
                                authorEmptyPassCount[author]++;
                                
                                this.Invoke((MethodInvoker)delegate
                                {
                                    authorSearchLog.AppendText($"  📂 No se encontraron libros nuevos para descargar\r\n");
                                    authorSearchLog.AppendText($"  ⚠️ Pasadas vacías consecutivas: {authorEmptyPassCount[author]}/3\r\n\r\n");
                                    authorSearchLog.SelectionStart = authorSearchLog.Text.Length;
                                    authorSearchLog.ScrollToCaret();
                                });
                                
                                // Si lleva 3 pasadas vacías, eliminar al autor
                                if (authorEmptyPassCount[author] >= 3)
                                {
                                    this.Invoke((MethodInvoker)delegate
                                    {
                                        authorSearchLog.AppendText($"  🗑️ ELIMINANDO AUTOR: {author}\r\n");
                                        authorSearchLog.AppendText($"     ❌ 3 pasadas sin archivos nuevos\r\n\r\n");
                                        authorSearchLog.SelectionStart = authorSearchLog.Text.Length;
                                        authorSearchLog.ScrollToCaret();
                                    });
                                    
                                    // Eliminar del diccionario (ya no se procesará en futuras pasadas)
                                    authorEmptyPassCount.Remove(author);
                                    
                                    // También eliminar del ListBox visual
                                    this.Invoke((MethodInvoker)delegate
                                    {
                                        int index = authorsListBox.Items.IndexOf(author);
                                        if (index >= 0)
                                        {
                                            authorsListBox.Items.RemoveAt(index);
                                        }
                                    });
                                }
                            }
                            
                            // Esperar 1 segundo entre búsquedas (antes 2s)
                            await Task.Delay(1000);
                        }
                        catch (Exception ex)
                        {
                            this.Invoke((MethodInvoker)delegate
                            {
                                authorSearchLog.AppendText($"  ❌ Error: {ex.Message}\r\n\r\n");
                                authorSearchLog.SelectionStart = authorSearchLog.Text.Length;
                                authorSearchLog.ScrollToCaret();
                            });
                        }
                    } // Cierre del foreach de autores
                    
                    // Al final de cada pasada, verificar si se encontraron archivos nuevos
                    int remainingAuthors = authorEmptyPassCount.Count;
                    int eliminatedAuthors = selectedAuthors.Count - remainingAuthors;
                    
                    this.Invoke((MethodInvoker)delegate
                    {
                        authorSearchLog.AppendText($"\r\n========================================\r\n");
                        authorSearchLog.AppendText($"📊 RESUMEN PASADA {passNumber}\r\n");
                        authorSearchLog.AppendText($"  📥 Archivos nuevos encontrados: {filesFoundThisPass}\r\n");
                        authorSearchLog.AppendText($"  👥 Autores activos: {remainingAuthors}/{selectedAuthors.Count}\r\n");
                        if (eliminatedAuthors > 0)
                        {
                            authorSearchLog.AppendText($"  🗑️ Autores eliminados: {eliminatedAuthors}\r\n");
                        }
                        authorSearchLog.AppendText($"========================================\r\n");
                        authorSearchLog.SelectionStart = authorSearchLog.Text.Length;
                        authorSearchLog.ScrollToCaret();
                    });
                    
                    // Si no se encontraron archivos nuevos O no quedan autores activos, detener
                    if (filesFoundThisPass == 0 || authorEmptyPassCount.Count == 0)
                    {
                        string stopReason = filesFoundThisPass == 0 
                            ? "No hay más archivos nuevos" 
                            : "Todos los autores han sido eliminados";
                            
                        this.Invoke((MethodInvoker)delegate
                        {
                            authorSearchLog.AppendText($"\r\n🏁 BÚSQUEDA COMPLETADA - {stopReason}\r\n");
                            authorSearchLog.AppendText($"Total de pasadas: {passNumber}\r\n");
                            if (authorEmptyPassCount.Count == 0)
                            {
                                authorSearchLog.AppendText($"🗑️ Todos los autores eliminados por inactividad\r\n");
                            }
                            authorSearchLog.SelectionStart = authorSearchLog.Text.Length;
                            authorSearchLog.ScrollToCaret();
                        });
                        break; // Salir del bucle while
                    }
                    
                    passNumber++; // Incrementar para la siguiente pasada
                    
                    // Pequeña pausa entre pasadas para no sobrecargar
                    await Task.Delay(2000);
                }
                
                // Ciclo completado - mostrar resumen final
                this.Invoke((MethodInvoker)delegate
                {
                    authorSearchLog.AppendText($"\r\n");
                    authorSearchLog.AppendText($"\r\n========================================\r\n");
                    authorSearchLog.AppendText($"✅ BÚSQUEDA AUTOMÁTICA COMPLETADA\r\n");
                    authorSearchLog.AppendText($"========================================\r\n");
                    authorSearchLog.AppendText($"📚 Total autores procesados: {selectedAuthors.Count}\r\n");
                    authorSearchLog.AppendText($"📥 Total descargas encoladas: {totalDownloadsQueued}\r\n");
                    authorSearchLog.AppendText($"⏰ Finalizado: {DateTime.Now:HH:mm:ss}\r\n");
                    authorSearchLog.AppendText($"========================================\r\n");
                    authorSearchLog.AppendText($"\r\n");
                    authorSearchLog.SelectionStart = authorSearchLog.Text.Length;
                    authorSearchLog.ScrollToCaret();
                    
                    // Restaurar botón
                    startAuthorSearchButton.Text = "🚀 Iniciar Búsqueda Ultra-Rápida";
                    startAuthorSearchButton.BackColor = Color.FromArgb(0, 120, 215);
                    startAuthorSearchButton.Enabled = true;
                    
                    // Mostrar ventana informativa
                    DarkMessageBox.Show(
                        $"✅ Búsqueda automática completada\n\n" +
                        $"📚 Autores procesados: {selectedAuthors.Count}\n" +
                        $"📥 Descargas encoladas: {totalDownloadsQueued}\n" +
                        $"⏰ Finalizado: {DateTime.Now:HH:mm:ss}\n\n" +
                        $"Revisa el log para ver los detalles de cada búsqueda.",
                        "Búsqueda Completada",
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Information
                    );
                });
        }

        private void LoadWatchlist()
        {
            try
            {
                string watchlistFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "watchlist.txt");
                if (System.IO.File.Exists(watchlistFile))
                {
                    watchlistTerms = System.IO.File.ReadAllLines(watchlistFile).ToList();
                    watchlistBox.Items.Clear();
                    foreach (var term in watchlistTerms)
                    {
                        if (!string.IsNullOrWhiteSpace(term))
                            watchlistBox.Items.Add(term);
                    }
                }
            }
            catch { }
        }
        
        private void SaveWatchlist()
        {
            try
            {
                string watchlistFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "watchlist.txt");
                watchlistTerms = watchlistBox.Items.Cast<string>().ToList();
                System.IO.File.WriteAllLines(watchlistFile, watchlistTerms);
                
