        private bool IsFileAlreadyDownloaded(string filename)
        {
            try
            {
                string downloadedFilesFullPath = Path.IsPathRooted(downloadedFilesListPath) 
                    ? downloadedFilesListPath 
                    : Path.Combine(AppDomain.CurrentDomain.BaseDirectory, downloadedFilesListPath);
                
                if (!System.IO.File.Exists(downloadedFilesFullPath))
                    return false;
                
                string[] downloadedFiles = System.IO.File.ReadAllLines(downloadedFilesFullPath);
                return downloadedFiles.Any(line => line.Trim().Equals(filename, StringComparison.OrdinalIgnoreCase));
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error verificando archivo descargado: {ex.Message}");
                return false;
            }
        }
        
