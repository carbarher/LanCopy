        private async void DownloadSelected()
        {
            if (resultsListView.SelectedItems.Count == 0)
            {
                DarkMessageBox.Show("Selecciona al menos un archivo", "Descargar", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            int count = resultsListView.SelectedItems.Count;
            if (DarkMessageBox.Show($"¿Descargar {count} archivo(s) en paralelo?", "Confirmar", MessageBoxButtons.YesNo, MessageBoxIcon.Question) != DialogResult.Yes)
                return;

            // Descargas en paralelo (máximo 3 simultáneas)
            var downloadTasks = new List<Task>();
            var semaphore = new System.Threading.SemaphoreSlim(3, 3);
            
            foreach (ListViewItem item in resultsListView.SelectedItems)
            {
                var result = (SearchResult)item.Tag;
                var task = Task.Run(async () =>
                {
                    await semaphore.WaitAsync();
                    try
                    {
                        await DownloadFile(result);
                    }
                    finally
                    {
                        semaphore.Release();
                    }
                });
                downloadTasks.Add(task);
            }

            statusLabel.Text = $"✓ Iniciadas {count} descargas en paralelo (máx 3 simultáneas)";
        }

        private async Task DownloadFile(SearchResult result)
        {
            if (client == null)
            {
                this.Invoke(() => statusLabel.Text = "❌ Error: No estás conectado a Soulseek");
                return;
            }

            string downloadKey = $"{result.Username}_{result.Filename}".ToLowerInvariant();
            
            try
            {
                var localFilename = Path.Combine(downloadDir, Path.GetFileName(result.Filename));
                
                // Verificar si existe descarga parcial
                long startPosition = 0;
                string partialFile = localFilename + ".partial";
                if (System.IO.File.Exists(partialFile))
                {
                    startPosition = new FileInfo(partialFile).Length;
                    localFilename = partialFile;
                }
                else if (System.IO.File.Exists(localFilename))
                {
                    // Archivo ya existe completo
                    statusLabel.Text = $"⚠️ {Path.GetFileName(result.Filename)} ya existe";
                    return;
                }
                else
                {
                    localFilename = partialFile;
                }
                
                var downloadInfo = new DownloadInfo
                {
                    Filename = Path.GetFileName(result.Filename),
                    Username = result.Username,
                    TotalBytes = result.Size,
                    BytesTransferred = startPosition,
                    Status = startPosition > 0 ? "Reanudando..." : "Descargando...",
                    StartTime = DateTime.Now
                };
                
                activeDownloads[downloadKey] = downloadInfo;
                
                var downloadItem = new ListViewItem(downloadInfo.Filename);
                downloadItem.SubItems.Add(downloadInfo.Username);
                downloadItem.SubItems.Add("0%");
                downloadItem.SubItems.Add(downloadInfo.Status);
                downloadItem.Tag = downloadKey;
                
                this.Invoke(() =>
                {
                    downloadsListView.Items.Add(downloadItem);
                    UpdateDownloadsCount();
                });

                // (11) Reintentos con backoff y (5) throttle de progreso
                int maxRetries = 3;
                int attempt = 0;
                DateTime lastUi = DateTime.MinValue;
                int lastPercent = -1;
                Exception? lastError = null;
                
                // Timeout de descarga: 60 segundos sin recibir datos
                var downloadCts = new CancellationTokenSource();
                var lastDataReceived = DateTime.Now;
                var timeoutSeconds = 60;
                
                // Timer para verificar timeout
                var timeoutTimer = new System.Threading.Timer(_ =>
                {
                    if ((DateTime.Now - lastDataReceived).TotalSeconds > timeoutSeconds)
                    {
                        downloadCts.Cancel();
                    }
                }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
                
                try
                {
                    while (attempt < maxRetries)
                    {
                        try
                        {
                            await client.DownloadAsync(
                                result.Username,
                                result.Filename,
                                () => Task.FromResult<Stream>(new FileStream(localFilename, startPosition > 0 ? FileMode.Append : FileMode.Create)),
                                result.Size,
                                startOffset: startPosition,
                                options: new TransferOptions(
                                    progressUpdated: (args) =>
                                    {
                                        // REINICIAR TIMEOUT: Actualizar timestamp al recibir datos
                                        lastDataReceived = DateTime.Now;
                                        
                                        var totalTransferred = startPosition + args.Transfer.BytesTransferred;
                                        var percent = (int)((totalTransferred / (double)result.Size) * 100);
                                        downloadInfo.BytesTransferred = totalTransferred;
                                        // Throttle: actualizar si pasó 500ms o cambió el % (reducir parpadeo)
                                        var now = DateTime.UtcNow;
                                        if (percent != lastPercent || (now - lastUi).TotalMilliseconds > 500)
                                        {
                                            lastPercent = percent;
                                            lastUi = now;
                                            this.Invoke(() =>
                                            {
                                                foreach (ListViewItem item in downloadsListView.Items)
                                            {
                                                if (item.Tag?.ToString() == downloadKey)
                                                {
                                                    item.SubItems[2].Text = $"{percent}%";
                                                    break;
                                                }
                                            }
                                        });
                                    }
                                }
                            )
                        );
                        lastError = null;
                        break;
                    }
                    catch (Exception ex)
                    {
                        lastError = ex;
                        attempt++;
                        if (attempt >= maxRetries) throw;
                        await Task.Delay(500 * attempt);
                    }
                }
                }
                finally
                {
                    timeoutTimer.Dispose();
                    downloadCts.Dispose();
                }

                // Renombrar archivo .partial a nombre final
                string finalFilename = localFilename.Replace(".partial", "");
                
                if (System.IO.File.Exists(localFilename) && localFilename.EndsWith(".partial"))
                {
                    System.IO.File.Move(localFilename, finalFilename, true);
                }

                downloadInfo.Status = "✓ Completado";
                
                // Escribir en el archivo TXT formato CSV con pipe - SIN DUPLICADOS
                try
                {
                    string downloadedFilesFullPath = Path.IsPathRooted(downloadedFilesListPath) 
                        ? downloadedFilesListPath 
                        : Path.Combine(AppDomain.CurrentDomain.BaseDirectory, downloadedFilesListPath);
                    
                    string filename = Path.GetFileName(result.Filename);
                    
                    // Leer archivos existentes para evitar duplicados (solo comparar nombre)
                    HashSet<string> existingFiles = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                    if (System.IO.File.Exists(downloadedFilesFullPath))
                    {
                        var lines = System.IO.File.ReadAllLines(downloadedFilesFullPath);
                        foreach (var line in lines)
                        {
                            if (!string.IsNullOrWhiteSpace(line))
                            {
                                // Extraer solo el nombre del archivo (primer campo)
                                var parts = line.Split('|');
                                if (parts.Length > 0)
                                    existingFiles.Add(parts[0].Trim());
                            }
                        }
                    }
                    
                    // Solo agregar si no existe
                    if (!existingFiles.Contains(filename))
                    {
                        // Formato CSV con pipe: filename|author|size|date
                        // Nota: author no está disponible aquí, usar "Unknown"
                        string csvLine = $"{filename}|Unknown|{result.Size}|{DateTime.Now:yyyy-MM-dd HH:mm:ss}";
                        System.IO.File.AppendAllText(downloadedFilesFullPath, csvLine + Environment.NewLine);
                        _logger?.Debug($"Archivo agregado al TXT (CSV): {filename}");
                    }
                    else
                    {
                        _logger?.Debug($"Archivo ya existe en TXT, no se duplica: {filename}");
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error escribiendo en lista de descargados: {ex.Message}");
                    _logger?.Error($"Error escribiendo en lista de descargados: {ex.Message}", ex);
                }
                
                // Guardar en historial de descargas (21) - solo si no está en modo incógnito
                if (!incognitoModeCheckBox.Checked)
                {
                    var historyEntry = new DownloadHistoryEntry
                    {
                        Filename = Path.GetFileName(result.Filename),
                        Username = result.Username,
                        Size = result.Size,
                        CompletedDate = DateTime.Now,
                        MD5Hash = "",
                        AvgSpeed = result.Size / (DateTime.Now - downloadInfo.StartTime).TotalSeconds / 1024 // KB/s
                    };
                    SaveDownloadHistory(historyEntry);
                }
                
                this.Invoke(() =>
                {
                    foreach (ListViewItem item in downloadsListView.Items)
                    {
                        if (item.Tag?.ToString() == downloadKey)
                        {
                            item.SubItems[2].Text = "100%";
                            item.SubItems[3].Text = downloadInfo.Status;
                            item.ForeColor = Color.LimeGreen;
                            break;
                        }
                    }
                    activeDownloads.Remove(downloadKey);
                    UpdateDownloadsCount();
                });
                
                // Registrar estadísticas de descarga (solo si no está en modo incógnito)
                if (!incognitoModeCheckBox.Checked && _stats != null)
                {
                    double speedKBps = result.Size / (DateTime.Now - downloadInfo.StartTime).TotalSeconds / 1024;
                    _stats.RecordDownload(result.Filename, result.Size, speedKBps, result.Username);
                }
                
                statusLabel.Text = $"✓ Descargado: {Path.GetFileName(result.Filename)}";
            }
            catch (Exception ex)
            {
                string errorMsg = $"Error descargando {Path.GetFileName(result.Filename)}: {ex.Message}";
                Console.WriteLine(errorMsg);
                
                this.Invoke(() =>
                {
                    // Actualizar el item en la lista de descargas con el error
                    foreach (ListViewItem item in downloadsListView.Items)
                    {
                        if (item.Tag?.ToString() == downloadKey)
                        {
                            item.SubItems[3].Text = $"❌ Error: {ex.Message}";
                            item.ForeColor = Color.Red;
                            break;
                        }
                    }
                    
                    statusLabel.Text = $"❌ {errorMsg}";
                    activeDownloads.Remove(downloadKey);
                    UpdateDownloadsCount();
                });
                
                // Mostrar MessageBox con el error detallado
                this.Invoke(() =>
                {
                    DarkMessageBox.Show(
                        $"Error al descargar:\n\n" +
                        $"Archivo: {Path.GetFileName(result.Filename)}\n" +
                        $"Usuario: {result.Username}\n" +
                        $"Error: {ex.Message}\n\n" +
                        $"Detalles técnicos:\n{ex.GetType().Name}",
                        "Error de Descarga",
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Error
                    );
                });
            }
        }

