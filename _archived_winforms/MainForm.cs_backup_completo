        private async void SearchButton_Click(object? sender, EventArgs e)
        {
            // Si está buscando, cancelar
            if (searchCts != null && !searchCts.IsCancellationRequested)
            {
                searchCts.Cancel();
                searchButton.Text = "🔍 Buscar";
                statusLabel.Text = "Búsqueda cancelada";
                downloadProgress.Style = ProgressBarStyle.Continuous;
                downloadProgress.Value = 0;
                UpdateSearchProgress("Búsqueda cancelada por el usuario", 0);
                return;
            }
            
            if (string.IsNullOrWhiteSpace(searchBox.Text))
                return;
            
            // Verificar conexión antes de buscar - usar ToString() porque el estado puede ser múltiple
            bool isConnected = false;
            if (client != null)
            {
                string stateStr = client.State.ToString();
                isConnected = stateStr.Contains("Connected") || stateStr.Contains("LoggedIn");
            }
            
            if (!isConnected)
            {
                var message = client == null 
                    ? "No estás conectado a Soulseek.\n\nHaz clic en el botón 'Conectar' primero."
                    : $"Conexión perdida (Estado: {client.State}).\n\nReconectando automáticamente...";
                
                DarkMessageBox.Show(message, "No conectado", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                
                // Si el cliente existe pero está desconectado, intentar reconectar
                if (client != null && client.State == SoulseekClientStates.Disconnected && !isReconnecting)
                {
                    _ = HandleDisconnectionWithRetry();
                }
                return;
            }

            try
            {
                string query = searchBox.Text.Trim();
                
                // FUNCIONALIDAD NUEVA: Registrar búsqueda en dashboard
                _performanceDashboard?.RecordSearch(query);
                
                // OPTIMIZACIÓN NIVEL 3: Verificar caché primero
                if (searchCache != null && searchCache.TryGet(query, out var cachedResults))
                {
                    _logger?.Info($"Resultados obtenidos del caché para: {query}");
                    statusLabel.Text = $"✅ {cachedResults.Count} resultados (caché)";
                    
                    // FUNCIONALIDAD NUEVA: Registrar cache hit
                    _performanceDashboard?.RecordCacheHit();
                    
                    // Mostrar resultados del caché
                    foreach (var result in cachedResults)
                    {
                        var item = VirtualListViewOptimization.CreateListViewItem(result);
                        resultsListView.Items.Add(item);
                    }
                    
                    resultsCountLabel.Text = $"📊 Resultados: {cachedResults.Count}";
                    return;
                }
                
                // FUNCIONALIDAD NUEVA: Registrar cache miss
                _performanceDashboard?.RecordCacheMiss();
                
                // OPTIMIZACIÓN NIVEL 3: Throttling de búsquedas
                if (searchThrottler != null)
                {
                    var (searches, max, wait) = searchThrottler.GetStats();
                    if (wait > TimeSpan.Zero)
                    {
                        statusLabel.Text = $"⏳ Esperando {wait.TotalSeconds:F0}s (rate limit)...";
                        await searchThrottler.WaitForSearchSlotAsync();
                    }
                }
                
                int timeoutSecs = (int)(searchTimeoutBox?.Value ?? defaultSearchTimeoutSecs);
                searchCts?.Cancel();
                searchCts = new System.Threading.CancellationTokenSource(TimeSpan.FromSeconds(timeoutSecs));
                var ct = searchCts.Token;
                
                // Cambiar botón a "Cancelar"
                searchButton.Text = "❌ Cancelar";
                
                resultsListView.Items.Clear();
                statusLabel.Text = $"Buscando '{query}'... (timeout {timeoutSecs}s)";
                downloadProgress.Style = ProgressBarStyle.Marquee;
                searchStopwatch.Restart();
                
                // Actualizar indicadores de progreso
                UpdateSearchProgress($"Iniciando búsqueda: '{query}'...", 5);

                // Guardar en historial (solo si no está en modo incógnito)
                if (!incognitoModeCheckBox.Checked)
                {
                    SaveSearchHistory(query);
                }

                // Siempre forzar búsqueda nueva en cada clic

                // OPTIMIZACIÓN: Búsqueda múltiple sin LINQ innecesario
                List<string> searchTerms = new List<string>();
                if (multiSearchCheckBox.Checked)
                {
                    var parts = query.Split(',');
                    foreach (var part in parts)
                    {
                        var trimmed = part.Trim();
                        if (!string.IsNullOrEmpty(trimmed))
                            searchTerms.Add(trimmed);
                    }
                    statusLabel.Text = $"Buscando {searchTerms.Count} términos... (timeout {timeoutSecs}s)";
                }
                else
                {
                    searchTerms.Add(query);
                }

                // Obtener valores de configuración con fallback
                int timeout = searchTimeoutBox != null ? (int)searchTimeoutBox.Value * 1000 : defaultSearchTimeoutSecs * 1000;
                int respLimit = responseLimitBox != null ? (int)responseLimitBox.Value : 100;
                int fLimit = fileLimitBox != null ? (int)fileLimitBox.Value : 200;
                
                // Debug: Mostrar valores de configuración
                Console.WriteLine($"[Search] Timeout: {timeout}ms ({timeout/1000}s), RespLimit: {respLimit}, FileLimit: {fLimit}");
                statusLabel.Text = $"Buscando '{query}'... (timeout {timeout/1000}s, respuestas {respLimit}, archivos {fLimit})";
                
                var searchOptions = new SearchOptions(
                    searchTimeout: timeout,
                    responseLimit: respLimit,
                    fileLimit: fLimit
                );

                // OPTIMIZACIÓN: Obtener filtros y preparar HashSets para búsquedas O(1)
                int minSize = (int)minSizeBox.Value * 1024; // KB a bytes
                int maxSize = (int)maxSizeBox.Value * 1024;
                int minSpeed = (int)minSpeedBox.Value; // KB/s
                string extension = extensionBox.Text.Trim().ToLower();
                
                // OPTIMIZACIÓN: Crear HashSet de extensiones permitidas una sola vez
                HashSet<string>? allowedExtensions = null;
                if (!string.IsNullOrEmpty(extension))
                {
                    allowedExtensions = new HashSet<string>();
                    foreach (var ext in extension.Split(','))
                    {
                        var trimmed = ext.Trim();
                        if (!string.IsNullOrEmpty(trimmed))
                            allowedExtensions.Add(trimmed);
                    }
                }
                
                // OPTIMIZACIÓN: HashSets estáticos para filtros de libros
                var bookExtensions = new HashSet<string> { "pdf", "epub", "mobi", "azw", "azw3", "djvu", "doc", "docx", "txt", "rtf", "odt" };
                var comicExtensions = new HashSet<string> { "cbr", "cbz", "cb7", "cbt" };

                int totalResults = 0;
                int filteredOut = 0;
                var perUserCounts = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
                int maxPerUser = 200; // (8) límite por usuario
                
                // OPTIMIZACIÓN: Realizar búsquedas con paralelismo limitado
                // Usar capacity inicial para evitar reallocations
                var allSearchResults = new List<SearchResponse>(respLimit * searchTerms.Count);
                int termIndex = 0;
                int maxConcurrency = 3;
                var sem = new System.Threading.SemaphoreSlim(maxConcurrency, maxConcurrency);
                var tasks = new List<Task>(searchTerms.Count);
                foreach (var term in searchTerms)
                {
                    await sem.WaitAsync(ct).ConfigureAwait(false);
                    var localTermIndex = ++termIndex;
                    var localTerm = term;
                    tasks.Add(Task.Run(async () =>
                    {
                        try
                        {
                            if (ct.IsCancellationRequested) return;
                            this.Invoke(() => statusLabel.Text = $"Buscando término {localTermIndex}/{searchTerms.Count}: '{localTerm}'... (timeout {timeoutSecs}s, {searchStopwatch.Elapsed:mm\\:ss})");
                            var searchQuery = SearchQuery.FromText(localTerm);
                            var searchResult = await client!.SearchAsync(searchQuery, options: searchOptions).ConfigureAwait(false);
                            lock (allSearchResults) { allSearchResults.AddRange(searchResult.Responses); }
                        }
                        finally { sem.Release(); }
                    }, ct));
                }
                await Task.WhenAll(tasks).ConfigureAwait(false);

                // OPTIMIZACIÓN: Preparar para agregar items en lotes con ArrayPool
                int batchSize = 50; // Agregar de 50 en 50 para reducir parpadeo
                var itemsToAdd = new List<ListViewItem>(batchSize);
                var itemArray = listViewItemPool.Rent(batchSize); // Array rentado para mejor rendimiento
                
                // OPTIMIZACIÓN: Limpiar HashSet de duplicados al inicio de nueva búsqueda
                processedFileKeys.Clear();
                
                // OPTIMIZACIÓN: Verificar límite de resultados
                int resultsAdded = 0;
                
                // OPTIMIZACIÓN: Convertir blacklist a HashSet con comparador case-insensitive
                var blacklistSet = new HashSet<string>(blacklistedUsers, StringComparer.OrdinalIgnoreCase);
                
                foreach (var response in allSearchResults)
                {
                    // OPTIMIZACIÓN: Filtro de blacklist O(1) lookup
                    if (blacklistSet.Contains(response.Username))
                    {
                        // OPTIMIZACIÓN: .Count property es O(1), .Count() method puede ser O(n)
                        filteredOut += response.Files.Count;
                        continue;
                    }
                    
                    // Filtro de velocidad mínima
                    if (minSpeed > 0 && response.UploadSpeed < minSpeed * 1024)
                    {
                        filteredOut += response.Files.Count;
                        continue;
                    }
                    
                    foreach (var file in response.Files)
                    {
                        if (ct.IsCancellationRequested) break;
                        
                        // OPTIMIZACIÓN: Cachear extensión (se usa 3-4 veces)
                        var ext = Path.GetExtension(file.Filename).TrimStart('.');
                        var extLower = ext.ToLower();
                        
                        // OPTIMIZACIÓN: Aplicar filtros con HashSets precalculados
                        if (minSize > 0 && file.Size < minSize) { filteredOut++; continue; }
                        if (maxSize > 0 && file.Size > maxSize) { filteredOut++; continue; }
                        
                        // OPTIMIZACIÓN: Usar HashSet precalculado para extensiones (O(1) lookup)
                        if (allowedExtensions != null)
                        {
                            if (!allowedExtensions.Contains(extLower)) { filteredOut++; continue; }
                        }
                        
                        // Filtro de idioma español
                        if (spanishOnlyCheckBox.Checked)
                        {
                            if (!IsSpanishContent(file.Filename))
                            {
                                filteredOut++;
                                continue;
                            }
                        }
                        
                        // OPTIMIZACIÓN: Filtro de "Solo Libros" usando HashSets precalculados y extensión cacheada
                        if (booksOnlyCheckBox.Checked)
                        {
                            // Debe ser un documento Y no un comic
                            if (!bookExtensions.Contains(extLower) || comicExtensions.Contains(extLower))
                            {
                                filteredOut++;
                                continue;
                            }
                        }

                        // OPTIMIZACIÓN: Extraer información (reusar ext ya calculada)
                        var filename = Path.GetFileName(file.Filename);
                        var directory = Path.GetDirectoryName(file.Filename) ?? "";
                        var duration = file.Length.HasValue ? TimeSpan.FromSeconds(file.Length.Value).ToString(@"mm\:ss") : "";

                        var item = new ListViewItem(response.Username);
                        item.SubItems.Add("...");  // País (cargando)
                        item.SubItems.Add(filename);
                        item.SubItems.Add(FormatFileSize(file.Size));
                        item.SubItems.Add(ext);
                        item.SubItems.Add(directory);  // Carpeta (sin bitrate ni duration)
                        
                        item.Tag = new SearchResult
                        {
                            Username = response.Username,
                            Filename = file.Filename,
                            Size = file.Size,
                            BitRate = file.BitRate,
                            Length = file.Length,
                            Extension = ext,
                            Directory = directory
                        };
                        
                        // OPTIMIZACIÓN: Detección de duplicados O(1) con HashSet
                        // Usar string.Concat es más eficiente que interpolación para 2 valores
                        string fileKey = string.Concat(file.Filename, "_", file.Size.ToString());
                        
                        if (!processedFileKeys.Contains(fileKey))
                        {
                            // OPTIMIZACIÓN: Verificar límite máximo de resultados
                            if (resultsAdded >= MAX_TOTAL_RESULTS)
                            {
                                statusLabel.Text = $"⚠️ Límite de {MAX_TOTAL_RESULTS} resultados alcanzado";
                                break;
                            }
                            
                            processedFileKeys.Add(fileKey);
                            var result = (SearchResult)item.Tag;
                            filteredResults.Add(result);
                            totalResults++;
                            resultsAdded++;
                            itemsToAdd.Add(item);
                            
                            // Agregar al ListView en lotes para reducir parpadeo
                            if (itemsToAdd.Count >= batchSize)
                            {
                                var batch = itemsToAdd.ToArray();
                                itemsToAdd.Clear();
                                
                                this.Invoke(() =>
                                {
                                    resultsListView.BeginUpdate();
                                    resultsListView.Items.AddRange(batch);
                                    resultsListView.EndUpdate();
                                    UpdateResultsCount(totalResults);
                                    statusLabel.Text = $"📥 {totalResults} resultados encontrados...";
                                });
                            }
                        }
                    }
                }
                
                // Agregar items restantes
                if (itemsToAdd.Count > 0)
                {
                    var batch = itemsToAdd.ToArray();
                    this.Invoke(() =>
                    {
                        resultsListView.BeginUpdate();
                        resultsListView.Items.AddRange(batch);
                        resultsListView.EndUpdate();
                        UpdateResultsCount(totalResults);
                    });
                }

                // OPTIMIZACIÓN NIVEL 3: Cachear resultados de búsqueda
                if (searchCache != null && totalResults > 0)
                {
                    var resultsToCache = new List<SearchResult>();
                    foreach (ListViewItem item in resultsListView.Items)
                    {
                        if (item.Tag is SearchResult result)
                        {
                            resultsToCache.Add(result);
                        }
                    }
                    searchCache.Add(query, resultsToCache);
                    _logger?.Info($"Resultados cacheados para: {query} ({resultsToCache.Count} items)");
                }
                
                // Detener cronómetro y mostrar tiempo real
                searchStopwatch.Stop();
                double elapsedSeconds = searchStopwatch.Elapsed.TotalSeconds;
                string timeMsg = elapsedSeconds < timeoutSecs 
                    ? $" en {elapsedSeconds:F1}s" 
                    : $" (timeout {timeoutSecs}s alcanzado)";

                string filterMsg = filteredOut > 0 ? $" ({filteredOut} filtrados/duplicados)" : "";
                statusLabel.Text = $"✓ {totalResults} resultados para '{query}'{timeMsg}{filterMsg}";
                
                // FUNCIONALIDAD NUEVA: Registrar resultados en dashboard
                _performanceDashboard?.RecordResults(totalResults);
                
                // Actualizar indicadores de progreso
                string progressMsg = elapsedSeconds < timeoutSecs 
                    ? $"Búsqueda finalizada: {totalResults} resultados en {elapsedSeconds:F1}s"
                    : $"Búsqueda completada (timeout): {totalResults} resultados";
                UpdateSearchProgress(progressMsg, 100);
                
                // Los resultados ya están cargados en tiempo real
                currentPage = 1;
                UpdateResultsCount(totalResults);
                downloadProgress.Style = ProgressBarStyle.Continuous;
                downloadProgress.Value = 0;
                
                // OPTIMIZACIÓN: Obtener países EN PARALELO usando HashSet para búsquedas O(1)
                var uniqueUsers = new HashSet<string>();
                foreach (ListViewItem item in resultsListView.Items)
                {
                    var result = (SearchResult)item.Tag;
                    uniqueUsers.Add(result.Username);
                }
                
                _ = Task.Run(async () =>
                {
                    // OPTIMIZACIÓN: Procesar usuarios en paralelo con límite de concurrencia mejorado
                    var countryTasks = uniqueUsers.Select(async username =>
                    {
                        await countrySemaphore.WaitAsync().ConfigureAwait(false);
                        try
                        {
                            var country = await GetUserCountry(username).ConfigureAwait(false);
                            return (username, country);
                        }
                        finally
                        {
                            countrySemaphore.Release();
                        }
                    });
                    
                    var countries = await Task.WhenAll(countryTasks);
                    
                    // OPTIMIZACIÓN: Crear diccionario para búsquedas O(1)
                    var countryDict = countries.ToDictionary(c => c.username, c => c.country);
                    
                    // Actualizar UI en el hilo principal
                    this.Invoke((MethodInvoker)delegate
                    {
                        string countryFilter = countryFilterBox.SelectedItem?.ToString() ?? "Todos";
                        var itemsToRemove = new List<ListViewItem>();
                        
                        // OPTIMIZACIÓN: Array estático de países hispanos (evitar recrear en cada iteración)
                        var hispanicCountries = new HashSet<string> { "ES", "MX", "AR", "CO", "CL", "PE", "VE", "EC", "GT", "CU", "BO", "DO", "HN", "PY", "SV", "NI", "CR", "PA", "UY", "PR" };
                        
                        foreach (ListViewItem item in resultsListView.Items)
                        {
                            var result = (SearchResult)item.Tag;
                            
                            // OPTIMIZACIÓN: Búsqueda O(1) en diccionario
                            if (countryDict.TryGetValue(result.Username, out var country))
                            {
                                item.SubItems[1].Text = country;
                                
                                // Aplicar filtro de país (SOLO por país del usuario, NO por nombre del archivo)
                                bool shouldShow = countryFilter == "Todos" ||
                                                (countryFilter == "España" && country == "ES") ||
                                                (countryFilter == "Hispano" && hispanicCountries.Contains(country));
                                
                                if (!shouldShow)
                                {
                                    itemsToRemove.Add(item);
                                }
                            }
                        }
                        
                        // Eliminar items filtrados
                        foreach (var item in itemsToRemove)
                        {
                            resultsListView.Items.Remove(item);
                        }
                        
                        if (itemsToRemove.Count > 0)
                        {
                            int visibleCount = resultsListView.Items.Count;
                            UpdateResultsCount(visibleCount);
                            statusLabel.Text = $"✓ {visibleCount} resultados visibles (filtrados por país)";
                        }
                    });
                });
                
                // Auto-descarga de mejores resultados
                if (autoDownloadCheckBox.Checked && resultsListView.Items.Count > 0)
                {
                    int limit = (int)autoDownloadLimit.Value;
                    int downloaded = 0;
                    
                    // Ordenar por tamaño (más grande = mejor calidad generalmente)
                    var sortedItems = resultsListView.Items.Cast<ListViewItem>()
                        .OrderByDescending(item => ((SearchResult)item.Tag).Size)
                        .Take(limit)
                        .ToList();
                    
                    statusLabel.Text = $"🔄 Iniciando auto-descarga de {Math.Min(limit, sortedItems.Count)} archivos...";
                    
                    foreach (var item in sortedItems)
                    {
                        var result = (SearchResult)item.Tag;
                        downloaded++;
                        
                        // Log detallado de cada descarga
                        string fileName = Path.GetFileName(result.Filename);
                        string fileSize = FormatFileSize(result.Size);
                        string userName = result.Username;
                        
                        this.Invoke(() => {
                            statusLabel.Text = $"📥 Auto-descarga {downloaded}/{sortedItems.Count}: {fileName} ({fileSize}) de {userName}";
                        });
                        
                        _ = Task.Run(async () =>
                        {
                            await downloadSemaphore.WaitAsync().ConfigureAwait(false);
                            try
                            {
                                await DownloadFile(result).ConfigureAwait(false);
                            }
                            finally
                            {
                                downloadSemaphore.Release();
                            }
                        });
                        
                        // OPTIMIZACIÓN: ConfigureAwait(false) para no capturar contexto de UI
                        await Task.Delay(500).ConfigureAwait(false);
                    }
                    
                    statusLabel.Text = $"✓ {totalResults} resultados. Auto-descarga completada: {downloaded} archivos en cola";
                }
                
                // Registrar estadísticas de búsqueda (solo si no está en modo incógnito)
                if (!incognitoModeCheckBox.Checked && _stats != null)
                {
                    _stats.RecordSearch(query, totalResults);
                }
                
                // Cambiar a pestaña de resultados
                tabControl.SelectedIndex = 0;
            }
            catch (Exception ex)
            {
                statusLabel.Text = $"✗ Error: {ex.Message}";
                
                // Detectar si es un error de conexión
                bool isConnectionError = ex.Message.Contains("connection is closed") || 
                                        ex.Message.Contains("connection was closed") ||
                                        ex.Message.Contains("Tcp connection") ||
                                        ex.Message.Contains("not connected") ||
                                        ex is System.Net.Sockets.SocketException;
                
                if (isConnectionError)
                {
                    var result = DarkMessageBox.Show(
                        $"Error de conexión durante la búsqueda:\n{ex.Message}\n\n¿Intentar reconectar?",
                        "Error de Conexión",
                        MessageBoxButtons.YesNo,
                        MessageBoxIcon.Warning);
                    
                    if (result == DialogResult.Yes)
                    {
                        statusLabel.Text = "Reconectando...";
                        _ = Task.Run(async () =>
                        {
                            try
                            {
                                await HandleDisconnectionWithRetry();
                            }
                            catch { }
                        });
                    }
                }
                else
                {
                    DarkMessageBox.Show($"Error en búsqueda: {ex.Message}", "Error",
                        MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            }
            finally
            {
                // Restaurar botón a "Buscar"
                searchButton.Text = "🔍 Buscar";
                downloadProgress.Style = ProgressBarStyle.Continuous;
                searchCts = null;
            }
        }

        private async void ResultsListView_DoubleClick(object? sender, EventArgs e)
        {
            if (resultsListView.SelectedItems.Count == 0 || client == null)
                return;

            var selectedItem = resultsListView.SelectedItems[0];
            var result = (SearchResult)selectedItem.Tag;

            try
            {
                var localFilename = Path.Combine(downloadDir, Path.GetFileName(result.Filename));
                string downloadKey = $"{result.Username}_{result.Filename}";
                
                // Agregar a la tabla de descargas
                var downloadInfo = new DownloadInfo
                {
                    Filename = Path.GetFileName(result.Filename),
                    Username = result.Username,
                    TotalBytes = result.Size,
                    BytesTransferred = 0,
                    Status = "Descargando...",
                    StartTime = DateTime.Now
                };
                
                activeDownloads[downloadKey] = downloadInfo;
                
                var downloadItem = new ListViewItem(downloadInfo.Filename);
                downloadItem.SubItems.Add(downloadInfo.Username);
                downloadItem.SubItems.Add("0%");
                downloadItem.SubItems.Add(downloadInfo.Status);
                downloadItem.Tag = downloadKey;
                
                this.Invoke(() =>
                {
                    downloadsListView.Items.Add(downloadItem);
                    UpdateDownloadsCount();
                    tabControl.SelectedIndex = 1; // Cambiar a pestaña de descargas
                });

                statusLabel.Text = $"Descargando: {Path.GetFileName(result.Filename)}...";
                downloadProgress.Value = 0;

                // Timeout de descarga: 60 segundos sin recibir datos
                var downloadCts = new CancellationTokenSource();
                var lastDataReceived = DateTime.Now;
                var timeoutSeconds = 60;
                
                // Timer para verificar timeout
                var timeoutTimer = new System.Threading.Timer(_ =>
                {
                    if ((DateTime.Now - lastDataReceived).TotalSeconds > timeoutSeconds)
                    {
                        downloadCts.Cancel();
                    }
                }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
                
                try
                {
                    await client.DownloadAsync(
                        result.Username,
                        result.Filename,
                        () => Task.FromResult<Stream>(new FileStream(localFilename, FileMode.Create)),
                        result.Size,
                        options: new TransferOptions(
                            progressUpdated: (args) =>
                            {
                                // REINICIAR TIMEOUT: Actualizar timestamp al recibir datos
                                lastDataReceived = DateTime.Now;
                                
                                var percent = (int)((args.Transfer.BytesTransferred / (double)result.Size) * 100);
                                downloadInfo.BytesTransferred = args.Transfer.BytesTransferred;
                                
                                this.Invoke(() =>
                                {
                                    downloadProgress.Value = Math.Min(percent, 100);
                                    statusLabel.Text = $"Descargando: {Path.GetFileName(result.Filename)} - {percent}%";
                                    
                                    // Actualizar tabla de descargas
                                    foreach (ListViewItem item in downloadsListView.Items)
                                    {
                                        if (item.Tag?.ToString() == downloadKey)
                                        {
                                            item.SubItems[2].Text = $"{percent}%";
                                            break;
                                        }
                                    }
                                });
                            }
                        ),
                        cancellationToken: downloadCts.Token
                    );
                }
                finally
                {
                    timeoutTimer.Dispose();
                    downloadCts.Dispose();
                }

                downloadProgress.Value = 100;
                downloadInfo.Status = "✓ Completado";
                statusLabel.Text = $"✓ Descargado: {Path.GetFileName(result.Filename)} ({FormatFileSize(result.Size)})";

                // FUNCIONALIDAD NUEVA: Notificar descarga completada
                _notificationManager?.NotifyDownloadCompleted(
                    Path.GetFileName(result.Filename),
                    result.Username
                );
                
                // FUNCIONALIDAD NUEVA: Registrar descarga en dashboard
                if (_performanceDashboard != null)
                {
                    double elapsedSeconds = (DateTime.Now - downloadInfo.StartTime).TotalSeconds;
                    double speedMBps = (result.Size / (1024.0 * 1024.0)) / Math.Max(1, elapsedSeconds);
                    _performanceDashboard.RecordDownload(result.Username, speedMBps);
                }
                
                // FUNCIONALIDAD NUEVA: Auto-agregar a Calibre si es un eBook
                if (_calibreIntegration?.IsAvailable == true)
                {
                    var extension = Path.GetExtension(result.Filename).ToLower();
                    var ebookExtensions = new[] { ".epub", ".pdf", ".mobi", ".azw3", ".fb2", ".djvu" };
                    
                    if (ebookExtensions.Contains(extension))
                    {
                        _ = Task.Run(async () =>
                        {
                            try
                            {
                                var filePath = Path.Combine(downloadDir, Path.GetFileName(result.Filename));
                                var title = Path.GetFileNameWithoutExtension(result.Filename);
                                var tags = new[] { "SlskDown", "Auto-agregado" };
                                
                                var added = await _calibreIntegration.AddBookAsync(
                                    filePath: filePath,
                                    author: result.Username,
                                    title: title,
                                    tags: tags
                                );
                                
                                if (added)
                                {
                                    _logger?.Info($"📚 Libro agregado a Calibre: {title}");
                                    
                                    this.Invoke(() =>
                                    {
                                        _notificationManager?.ShowNotification(
                                            "Libro agregado a Calibre",
                                            $"{title}\npor {result.Username}",
                                            ToolTipIcon.Info
                                        );
                                    });
                                }
                            }
                            catch (Exception ex)
                            {
                                _logger?.Error($"Error agregando a Calibre: {ex.Message}", ex);
                            }
                        });
                    }
                }

                // Actualizar estado en tabla
                this.Invoke(() =>
                {
                    foreach (ListViewItem item in downloadsListView.Items)
                    {
                        if (item.Tag?.ToString() == downloadKey)
                        {
                            item.SubItems[2].Text = "100%";
                            item.SubItems[3].Text = downloadInfo.Status;
                            item.ForeColor = Color.LimeGreen;
                            break;
                        }
                    }
                });

                // Remover de descargas activas después de 5 segundos
                await Task.Delay(5000);
                activeDownloads.Remove(downloadKey);
                UpdateDownloadsCount();
            }
            catch (Exception ex)
            {
                statusLabel.Text = $"✗ Error descargando: {ex.Message}";
                
                // Actualizar estado de error en tabla
                this.Invoke(() =>
                {
                    string downloadKey = $"{result.Username}_{result.Filename}";
                    foreach (ListViewItem item in downloadsListView.Items)
                    {
                        if (item.Tag?.ToString() == downloadKey)
                        {
                            item.SubItems[3].Text = "✗ Error";
                            item.ForeColor = Color.Red;
                            break;
                        }
                    }
                    
                    if (activeDownloads.ContainsKey(downloadKey))
                    {
                        activeDownloads.Remove(downloadKey);
                        UpdateDownloadsCount();
                    }
                });
                
                DarkMessageBox.Show($"Error al descargar: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        // OPTIMIZACIÓN: HttpClient estático reutilizable (mejor rendimiento)
        private static readonly System.Net.Http.HttpClient sharedHttpClient = new System.Net.Http.HttpClient
        {
            Timeout = TimeSpan.FromSeconds(5)
        };
        
        // OPTIMIZACIÓN: Regex compilado estático para parsear JSON de países
        private static readonly System.Text.RegularExpressions.Regex countryCodeRegex = 
            new System.Text.RegularExpressions.Regex(
                "\"countryCode\":\"([A-Z]{2})\"",
                System.Text.RegularExpressions.RegexOptions.Compiled
            );
        
        private async ValueTask<string> GetUserCountry(string username)
        {
            // OPTIMIZACIÓN: Verificar MemoryCache primero con expiración
            if (countryCache.TryGetValue(username, out string? cachedCountry))
            {
                return cachedCountry ?? "??";
            }

            try
            {
                if (client != null)
                {
                    // Obtener IP del usuario
                    var endpoint = await client.GetUserEndPointAsync(username);
                    string ip = endpoint.Address.ToString();
                    
                    // OPTIMIZACIÓN: Usar HttpClient compartido (evita crear/destruir en cada llamada)
                    try
                    {
                        var response = await sharedHttpClient.GetStringAsync($"http://ip-api.com/json/{ip}?fields=countryCode");
                        
                        // OPTIMIZACIÓN: Usar Regex compilado estático
                        var match = countryCodeRegex.Match(response);
                        if (match.Success)
                        {
                            string country = match.Groups[1].Value;
                            countryCache.Set(username, country, TimeSpan.FromHours(1)); // Cache por 1 hora
                            SaveCountryCache(); // Guardar caché actualizado
                            return country;
                        }
                    }
                    catch
                    {
                        // Si falla la API, intentar con API alternativa
                        try
                        {
                            var response2 = await sharedHttpClient.GetStringAsync($"https://ipapi.co/{ip}/country/");
                            string country = response2.Trim();
                            if (country.Length == 2)
                            {
                                countryCache.Set(username, country, TimeSpan.FromHours(1)); // Cache por 1 hora
                                SaveCountryCache(); // Guardar caché actualizado
                                return country;
                            }
                        }
                        catch
                        {
                            // Ambas APIs fallaron
                        }
                    }
                }
            }
            catch
            {
                // Si falla, usar placeholder
            }

            userCountryCache[username] = "??";
            return "??";
        }

        /// <summary>
        /// Carga el caché de países desde archivo
        /// </summary>
        private void LoadCountryCache()
        {
            try
            {
                string cacheFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "country_cache.json");
                if (System.IO.File.Exists(cacheFile))
                {
                    // OPTIMIZACIÓN: Usar FileStream para JSON grande
                    using var stream = System.IO.File.OpenRead(cacheFile);
                    var cache = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(stream);
                    if (cache != null)
                    {
                        userCountryCache = cache;
                        _logger?.Info($"Caché de países cargado: {cache.Count} entradas");
                    }
                }
            }
            catch (Exception ex)
            {
                _logger?.Error("Error cargando caché de países", ex);
                Console.WriteLine($"Error cargando caché de países: {ex.Message}");
            }
        }

        /// <summary>
        /// Guarda el caché de países a archivo
        /// </summary>
        private void SaveCountryCache()
        {
            try
            {
                string cacheFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "country_cache.json");
                var json = System.Text.Json.JsonSerializer.Serialize(userCountryCache, JsonOptions);
                System.IO.File.WriteAllText(cacheFile, json);
                _logger?.Debug($"Caché de países guardado: {userCountryCache.Count} entradas");
            }
            catch (Exception ex)
            {
                _logger?.Error("Error guardando caché de países", ex);
                Console.WriteLine($"Error guardando caché de países: {ex.Message}");
            }
        }

        private string FormatFileSize(long bytes)
        {
            string[] sizes = { "B", "KB", "MB", "GB" };
            double len = bytes;
            int order = 0;
            while (len >= 1024 && order < sizes.Length - 1)
            {
                order++;
                len = len / 1024;
            }
            return $"{len:0.##} {sizes[order]}";
        }

        private void LoadSearchHistory()
        {
            try
            {
                string historyFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "search_history.json");
                if (System.IO.File.Exists(historyFile))
                {
                    string json = System.IO.File.ReadAllText(historyFile);
                    searchHistory = System.Text.Json.JsonSerializer.Deserialize<List<string>>(json) ?? new List<string>();
                    // OPTIMIZACIÓN: AddRange es más eficiente que loop con Add
                    searchBox.Items.Clear();
                    searchBox.Items.AddRange(searchHistory.Take(50).ToArray());
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error cargando historial: {ex.Message}");
            }
        }

        private void SaveSearchHistory(string query)
        {
            try
            {
                if (!searchHistory.Contains(query))
                {
                    searchHistory.Insert(0, query);
                    if (searchHistory.Count > 50)
                    {
                        searchHistory = searchHistory.Take(50).ToList();
                    }

                    string historyFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "search_history.json");
                    string json = System.Text.Json.JsonSerializer.Serialize(searchHistory);
                    System.IO.File.WriteAllText(historyFile, json);

                    // OPTIMIZACIÓN: AddRange en lugar de loop
                    searchBox.Items.Clear();
                    searchBox.Items.AddRange(searchHistory.ToArray());
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error guardando historial: {ex.Message}");
            }
        }

