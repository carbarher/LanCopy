        public string GetBestTime()
        {
            if (SeenOnline.Count < 3) return "Datos insuficientes";
            
            var hourGroups = SeenOnline.GroupBy(d => d.Hour)
                .OrderByDescending(g => g.Count())
                .First();
            
            return $"{hourGroups.Key:00}:00 - {(hourGroups.Key + 1):00}:00";
        }
        
        public int CalculateRating()
        {
            int rating = 3; // Base
            
            // Velocidad
            if (AvgSpeed > 500) rating = 5;
            else if (AvgSpeed > 200) rating = 4;
            else if (AvgSpeed < 50) rating = 2;
            
            // Éxito
            int total = SuccessfulDownloads + FailedDownloads;
            if (total > 0)
            {
                double successRate = (double)SuccessfulDownloads / total;
                if (successRate < 0.5) rating = Math.Max(1, rating - 1);
                if (successRate > 0.9) rating = Math.Min(5, rating + 1);
            }
            
            return rating;
        }
    }

    public class RecommendationEngine
    {
        public static List<string> GetRecommendations(List<DownloadHistoryEntry> history, List<SearchResult> currentResults)
        {
            var recommendations = new List<string>();
            
            // OPTIMIZACIÓN: Analizar patrones de descarga - usar HashSet para lookups O(1)
            var commonExtensions = new HashSet<string>(
                history.GroupBy(h => Path.GetExtension(h.Filename).ToLower())
                    .OrderByDescending(g => g.Count())
                    .Take(3)
                    .Select(g => g.Key)
            );
            
            var commonUsers = new HashSet<string>(
                history.GroupBy(h => h.Username)
                    .OrderByDescending(g => g.Count())
                    .Take(5)
                    .Select(g => g.Key)
            );
            
            // Generar recomendaciones
            foreach (var result in currentResults.Take(100))
            {
                int score = 0;
                
                // +30 si es de usuario conocido
                if (commonUsers.Contains(result.Username))
                    score += 30;
                
                // +20 si es extensión común
                if (commonExtensions.Contains(result.Extension.ToLower()))
                    score += 20;
                
                // Eliminada verificación de bitrate (siempre +20 base)
                
                // +15 si es tamaño razonable (10-500MB)
                long sizeMB = result.Size / (1024 * 1024);
                if (sizeMB >= 10 && sizeMB <= 500)
                    score += 15;
                
                // +15 si el nombre parece de calidad
                if (result.Filename.Contains("FLAC", StringComparison.OrdinalIgnoreCase) ||
                    result.Filename.Contains("320", StringComparison.OrdinalIgnoreCase))
                    score += 15;
                
                if (score >= 50)
                {
                    recommendations.Add($"{Path.GetFileName(result.Filename)} (Score: {score})");
                }
            }
            
            return recommendations.Take(10).ToList();
        }
        
        public static int DetectQuality(SearchResult result)
        {
            int quality = 50; // Base
            
            // Eliminada sección de bitrate (siempre +20 base)
            quality += 20;
            
            // Tamaño
            long sizeMB = result.Size / (1024 * 1024);
            if (sizeMB > 100) quality += 10;
            else if (sizeMB < 5) quality -= 20;
            
            // Nombre
            string filename = result.Filename.ToLower();
            if (filename.Contains("flac")) quality += 20;
            if (filename.Contains("320")) quality += 15;
            if (filename.Contains("remaster")) quality += 10;
            if (filename.Contains("low") || filename.Contains("128")) quality -= 20;
            
            return Math.Max(0, Math.Min(100, quality));
        }
    }

        private void UpdateSpeedGraph(Label speedGraphLabel)
        {
            try
            {
                // Calcular velocidad actual
                double currentSpeed = 0;
                long totalBytesNow = 0;
                
                foreach (var download in activeDownloads.Values)
                {
                    if (download.Status.Contains("Descargando"))
                    {
                        totalBytesNow += download.BytesTransferred;
                    }
                }
                
                var elapsed = (DateTime.Now - lastSpeedUpdate).TotalSeconds;
                if (elapsed > 0)
                {
                    currentSpeed = totalBytesNow / elapsed / 1024; // KB/s
                    lastSpeedUpdate = DateTime.Now;
                }
                
                // Agregar a historial (máximo 20 puntos)
                speedHistory.Add(currentSpeed);
                if (speedHistory.Count > 20)
                    speedHistory.RemoveAt(0);
                
                // Generar gráfico ASCII
                string graph = GenerateASCIIGraph(speedHistory);
                double avgSpeed = speedHistory.Count > 0 ? speedHistory.Average() : 0;
                
                speedGraphLabel.Text = $"📊 {avgSpeed:F1} KB/s {graph}";
            }
            catch { }
        }
        
        private string GenerateASCIIGraph(List<double> data)
        {
            if (data.Count == 0) return "▁▁▁▁▁▁▁▁▁▁";
            
            double max = data.Max();
            if (max == 0) return "▁▁▁▁▁▁▁▁▁▁";
            
            char[] bars = { '▁', '▂', '▃', '▄', '▅', '▆', '▇', '█' };
            var graph = new System.Text.StringBuilder();
            
            foreach (var value in data.TakeLast(10))
            {
                int barIndex = (int)((value / max) * (bars.Length - 1));
                graph.Append(bars[Math.Max(0, Math.Min(barIndex, bars.Length - 1))]);
            }
            
            // Rellenar con barras vacías si hay menos de 10 puntos
            while (graph.Length < 10)
                graph.Insert(0, '▁');
            
            return graph.ToString();
        }

