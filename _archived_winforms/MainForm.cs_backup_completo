        private void BackupConfiguration()
        {
            try
            {
                string backupDir = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "backups");
                System.IO.Directory.CreateDirectory(backupDir);
                
                string timestamp = DateTime.Now.ToString("yyyyMMdd_HHmmss");
                string backupFile = Path.Combine(backupDir, $"backup_{timestamp}.zip");
                
                // Crear backup de todos los archivos de configuración
                var filesToBackup = new[]
                {
                    "config.json",
                    "user_preferences.json",
                    "search_history.json",
                    "favorites.json",
                    "blacklist.json",
                    "downloaded_files.json"  // UNIFICADO: Ahora contiene todo el historial
                };
                
                using (var zip = System.IO.Compression.ZipFile.Open(backupFile, System.IO.Compression.ZipArchiveMode.Create))
                {
                    foreach (var file in filesToBackup)
                    {
                        string fullPath = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, file);
                        if (System.IO.File.Exists(fullPath))
                        {
                            ZipFileExtensions.CreateEntryFromFile(zip, fullPath, file);
                        }
                    }
                }
                
                // Limpiar backups viejos (mantener solo últimos 5)
                var backupFiles = System.IO.Directory.GetFiles(backupDir, "backup_*.zip")
                    .OrderByDescending(f => f)
                    .Skip(5);
                
                foreach (var oldBackup in backupFiles)
                {
                    System.IO.File.Delete(oldBackup);
                }
                
                DarkMessageBox.Show($"✓ Backup creado:\n{backupFile}\n\n(Se mantienen los últimos 5 backups)", "Backup completado", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                DarkMessageBox.Show($"Error creando backup: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

