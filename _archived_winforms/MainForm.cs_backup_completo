            string testFile = Path.Combine(basePath, "test_location.txt");
            System.IO.File.WriteAllText(testFile, $"BasePath: {basePath}\nDateTime: {DateTime.Now}");
            
            // LOGGING EXTREMO: Ver quién llama a SaveConfigSilent
            var traceInfo = new System.Diagnostics.StackTrace(true);
            string callerMethod = traceInfo.GetFrame(1)?.GetMethod()?.Name ?? "Unknown";
            string callerClass = traceInfo.GetFrame(1)?.GetMethod()?.DeclaringType?.Name ?? "Unknown";
            
            Console.WriteLine("========================================");
            Console.WriteLine($"[SaveConfigSilent] 🔥 LLAMADO DESDE: {callerClass}.{callerMethod}");
