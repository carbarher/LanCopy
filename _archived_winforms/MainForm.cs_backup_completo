        /// <summary>
        /// Inicializa todos los servicios usando el contenedor de DI
        /// </summary>
        private void InitializeServices()
        {
            try
            {
                var container = ServiceContainer.Instance;
                
                // Resolver servicios
                _securityService = container.Resolve<ISecurityService>();
                _configService = container.Resolve<IConfigService>();
                _logger = container.Resolve<ILoggingService>();
                _cache = container.Resolve<ICacheService>();
                _downloadTracking = container.Resolve<IDownloadTrackingService>();
                _stats = container.Resolve<IStatsService>();
                
                _logger.Info("Servicios inicializados correctamente (incluyendo estadísticas)");
            }
            catch (Exception ex)
            {
                DarkMessageBox.Show($"Error al inicializar servicios: {ex.Message}", 
                    "Error de Inicialización", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                
                // Fallback: crear servicios manualmente si falla el contenedor
                _logger = new LoggingService();
                _cache = new CacheService();
                _securityService = new SecurityService();
                _configService = new ConfigService(_securityService);
                _downloadTracking = new DownloadTrackingService(_logger);
                _stats = new StatsService(_logger);
            }
        }

