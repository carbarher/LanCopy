        private void SetupKeyboardShortcuts()
        {
            // Ctrl+A - Seleccionar todo
            this.KeyPreview = true;
            this.KeyDown += (s, e) =>
            {
                if (e.Control && e.KeyCode == Keys.A && tabControl.SelectedIndex == 0)
                {
                    foreach (ListViewItem item in resultsListView.Items)
                        item.Selected = true;
                    e.Handled = true;
                }
                // Ctrl+D - Descargar selección
                else if (e.Control && e.KeyCode == Keys.D)
                {
                    DownloadSelected();
                    e.Handled = true;
                }
                // F5 - Actualizar
                else if (e.KeyCode == Keys.F5)
                {
                    if (tabControl.SelectedIndex == 1)
                        UpdateDownloadsCount();
                    e.Handled = true;
                }
                // Delete - Limpiar
                else if (e.KeyCode == Keys.Delete && e.Control)
                {
                    ClearButton_Click(null, EventArgs.Empty);
                    e.Handled = true;
                }
                // Escape - Limpiar filtro
                else if (e.KeyCode == Keys.Escape)
                {
                    filterTextBox.Clear();
                    e.Handled = true;
                }
            };
        }

        private async Task AutoConnect()
        {
            try
            {
                // Verificar que existan credenciales
                if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
                {
                    UpdateConnectionStatus("Sin credenciales", Color.Red);
                    statusLabel.Text = "⚠️ Configura usuario y contraseña en la pestaña Config";
                    
                    DarkMessageBox.Show(
                        "No hay credenciales configuradas.\n\n" +
                        "Ve a la pestaña '⚙️ Config' y configura:\n" +
                        "• Usuario de Soulseek\n" +
                        "• Contraseña\n" +
                        "• Carpeta de descargas\n\n" +
                        "Luego haz clic en 'Guardar' y en 'Conectar'.",
                        "Credenciales Requeridas",
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Warning
                    );
                    return;
                }
                
                UpdateConnectionStatus("Conectando...", Color.Yellow);
                statusLabel.Text = $"Conectando a Soulseek como '{username}'...";
                UpdateSearchProgress("Iniciando conexión...", 10);

                // Crear cliente con puerto aleatorio
                var options = new SoulseekClientOptions(
                    listenPort: new Random().Next(50000, 60000),
                    enableDistributedNetwork: false
                );
                client = new SoulseekClient(options);
                
                // Suscribirse al evento de cambio de estado para detectar desconexiones
                client.StateChanged += async (sender, args) =>
                {
                    if (args.State == SoulseekClientStates.Disconnected && !isDisposing && !isReconnecting)
                    {
                        UpdateConnectionStatus("Desconectado", Color.Red);
                        statusLabel.Invoke(() => statusLabel.Text = "⚠ Conexión perdida - Intentando reconectar...");
                        
                        // Intentar reconectar automáticamente (solo si no hay otro intento en curso)
                        await HandleDisconnectionWithRetry();
                    }
                };
                
                // Conectar con timeout de 30 segundos
                var connectTask = client.ConnectAsync(username, password).ConfigureAwait(false);
                var timeoutTask = Task.Delay(30000);
                var completedTask = await Task.WhenAny(connectTask, timeoutTask);
                
                if (completedTask == timeoutTask)
                {
                    client?.Dispose();
                    client = null;
                    throw new TimeoutException("Timeout de conexión (30s)");
                }
                
                await connectTask; // Asegurar que se complete sin errores

                UpdateConnectionStatus("Conectado", Color.LimeGreen);
                searchButton.Invoke(() => searchButton.Enabled = true);
                connectButton.Invoke(() => 
                {
                    connectButton.Text = "Desconectar";
                    connectButton.BackColor = Color.FromArgb(150, 0, 0);
                });
                statusLabel.Invoke(() => statusLabel.Text = $"✓ Conectado a Soulseek como '{username}' - Listo para buscar");
                UpdateSearchProgress("Conexión establecida", 100);
            }
            catch (Exception ex)
            {
                client?.Dispose();
                client = null;
                UpdateConnectionStatus("Error", Color.Red);
                
                string errorDetail = ex.Message;
                string errorType = ex.GetType().Name;
                
                // Mensajes más específicos según el tipo de error
                if (ex is TimeoutException)
                {
                    errorDetail = "Timeout - El servidor no responde. Verifica tu conexión a Internet.";
                }
                else if (ex.Message.Contains("authentication", StringComparison.OrdinalIgnoreCase) || 
                         ex.Message.Contains("login", StringComparison.OrdinalIgnoreCase))
                {
                    errorDetail = "Usuario o contraseña incorrectos. Ve a Config y verifica tus credenciales.";
                }
                else if (ex.Message.Contains("network", StringComparison.OrdinalIgnoreCase) ||
                         ex.Message.Contains("connection", StringComparison.OrdinalIgnoreCase))
                {
                    errorDetail = "Error de red. Verifica tu conexión a Internet o firewall.";
                }
                
                statusLabel.Text = $"✗ Error: {errorDetail}";
                UpdateSearchProgress("Error de conexión", 0);
                
                // Mostrar MessageBox con información detallada
                DarkMessageBox.Show(
                    $"No se pudo conectar a Soulseek:\n\n" +
                    $"Error: {errorDetail}\n" +
                    $"Tipo: {errorType}\n\n" +
                    $"Posibles soluciones:\n" +
                    $"• Verifica tu conexión a Internet\n" +
                    $"• Verifica usuario y contraseña en Config\n" +
                    $"• Verifica que el firewall no bloquee la aplicación\n" +
                    $"• Intenta de nuevo en unos segundos",
                    "Error de Conexión",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Error
                );
            }
        }

        private async void ConnectButton_Click(object? sender, EventArgs e)
        {
            if (client != null && connectButton.Text == "Desconectar")
            {
                // Desconectar
                try
                {
                    client.Dispose();
                    client = null;
                    connectionStatus.Text = "● Desconectado";
                    connectionStatus.ForeColor = Color.Red;
                    searchButton.Enabled = false;
                    connectButton.Text = "Conectar";
                    connectButton.BackColor = Color.FromArgb(0, 120, 215);
                    statusLabel.Text = "Desconectado";
                }
                catch (Exception ex)
                {
                    statusLabel.Text = $"Error al desconectar: {ex.Message}";
                }
            }
            else
            {
                // Conectar usando AutoConnect para evitar duplicación de código
                try
                {
                    connectButton.Enabled = false;
                    await AutoConnect();
                }
                catch (Exception ex)
                {
                    DarkMessageBox.Show($"Error al conectar: {ex.Message}", "Error", 
                        MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
                finally
                {
                    connectButton.Enabled = true;
                }
            }
        }

