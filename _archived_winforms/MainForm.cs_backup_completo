                stats.AppendLine($"   blacklist.json: {(System.IO.File.Exists(Path.Combine(baseDir, "blacklist.json")) ? "✓" : "✗")}\n");
                
                stats.AppendLine("═══════════════════════════════════════════════════════");
                stats.AppendLine($"Actualizado: {DateTime.Now:dd/MM/yyyy HH:mm:ss}");
                stats.AppendLine();
                // Heatmap de actividad (18)
                stats.AppendLine("🔥 HEATMAP DE ACTIVIDAD (últimas 24h):");
                var hourActivity = new int[24];
                foreach (var h in history.Where(h => h.CompletedDate > DateTime.Now.AddDays(-1)))
                {
                    hourActivity[h.CompletedDate.Hour]++;
                }
                
                int maxActivity = hourActivity.Max();
                if (maxActivity > 0)
                {
                    for (int hour = 0; hour < 24; hour++)
                    {
                        int bars = hourActivity[hour] * 10 / maxActivity;
                        string bar = new string('█', bars) + new string('░', 10 - bars);
                        stats.AppendLine($"   {hour:00}:00 {bar} ({hourActivity[hour]})");
                    }
                }
