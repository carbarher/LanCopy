    private void BlacklistUser()
        {
            if (resultsListView.SelectedItems.Count > 0)
            {
                var username = resultsListView.SelectedItems[0].Text.ToLower();
                if (!blacklistedUsers.Contains(username))
                {
                    blacklistedUsers.Add(username);
                    
                    // Actualizar UI del blacklistBox
                    if (blacklistBox != null && !blacklistBox.Items.Contains(username))
                    {
                        blacklistBox.Items.Add(username);
                    }
                    
                    SaveBlacklist();
                    UpdateBlacklistStats();
                    
                    // Eliminar todos los resultados de este usuario (con BeginUpdate/EndUpdate)
                    resultsListView.BeginUpdate();
                    var itemsToRemove = new List<ListViewItem>();
                    foreach (ListViewItem item in resultsListView.Items)
                    {
                        if (item.Text.ToLower() == username)
                        {
                            itemsToRemove.Add(item);
                        }
                    }
                    foreach (var item in itemsToRemove)
                    {
                        resultsListView.Items.Remove(item);
                    }
                    resultsListView.EndUpdate();
                    UpdateResultsCount(resultsListView.Items.Count);
                    
                    DarkMessageBox.Show($"✓ Usuario '{username}' bloqueado\n\n{itemsToRemove.Count} resultados eliminados.", "Blacklist", MessageBoxButtons.OK, MessageBoxIcon.Information);
                }
                else
                {
                    DarkMessageBox.Show($"Usuario '{username}' ya está bloqueado", "Blacklist", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                }
            }
        }

