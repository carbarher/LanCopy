        private void SaveColumnWidths()
        {
            try
            {
                var resultsWidths = resultsListView.Columns.Cast<ColumnHeader>().Select(c => c.Width).ToList();
                var downloadsWidths = downloadsListView.Columns.Cast<ColumnHeader>().Select(c => c.Width).ToList();
                var obj = new
                {
                    resultsWidths,
                    downloadsWidths
                };
                string file = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "columns_settings.json");
                var json = System.Text.Json.JsonSerializer.Serialize(obj, JsonOptions);
                System.IO.File.WriteAllText(file, json);
            }
            catch { }
        }

        private void LoadColumnWidths()
        {
            try
            {
                string file = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "columns_settings.json");
                if (!System.IO.File.Exists(file)) return;
                var json = System.IO.File.ReadAllText(file);
                var doc = System.Text.Json.JsonDocument.Parse(json);
                if (doc.RootElement.TryGetProperty("resultsWidths", out var rw) && rw.ValueKind == System.Text.Json.JsonValueKind.Array)
                {
                    for (int i = 0; i < Math.Min(resultsListView.Columns.Count, rw.GetArrayLength()); i++)
                    {
                        try { resultsListView.Columns[i].Width = rw[i].GetInt32(); } catch { }
                    }
                }
                if (doc.RootElement.TryGetProperty("downloadsWidths", out var dw) && dw.ValueKind == System.Text.Json.JsonValueKind.Array)
                {
                    for (int i = 0; i < Math.Min(downloadsListView.Columns.Count, dw.GetArrayLength()); i++)
                    {
                        try { downloadsListView.Columns[i].Width = dw[i].GetInt32(); } catch { }
                    }
                }
            }
            catch { }
        }

