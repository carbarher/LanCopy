        /// <summary>
        /// Inicializa optimizaciones avanzadas (Nivel 3)
        /// </summary>
        private void InitializeAdvancedOptimizations()
        {
            try
            {
                // 1. SearchCache - Caché de búsquedas (30 min, 50 entradas)
                searchCache = new SearchCache(maxEntries: 50, maxAgeMinutes: 30);
                _logger?.Info("SearchCache inicializado: 50 entradas, 30 min TTL");
                
                // 2. SearchThrottler - Rate limiting (20 búsquedas/min, 1s delay)
                searchThrottler = new SearchThrottler(
                    maxSearchesPerMinute: 20,
                    minDelayMs: 1000
                );
                _logger?.Info("SearchThrottler inicializado: 20/min, 1s delay");
                
                // 3. LogCompressor - Compresión de logs (7 días → comprimir, 30 días → eliminar)
                string logsDir = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "logs");
                logCompressor = new LogCompressor(logsDir, 
                    daysBeforeCompress: 7, 
                    daysBeforeDelete: 30
                );
                _logger?.Info("LogCompressor inicializado: 7d comprimir, 30d eliminar");
                
                // Ejecutar compresión inicial en background
                Task.Run(async () =>
                {
                    await Task.Delay(5000); // Esperar 5s después del inicio
                    var result = await logCompressor.CompressOldLogsAsync();
                    if (result.compressed > 0 || result.deleted > 0)
                    {
                        _logger?.Info($"Compresión inicial: {result.compressed} comprimidos, {result.deleted} eliminados, {result.savedBytes / (1024 * 1024)} MB ahorrados");
                    }
                });
                
                // Timer para compresión periódica (cada 24 horas)
                var compressionTimer = new System.Threading.Timer(async _ =>
                {
                    try
                    {
                        var result = await logCompressor.CompressOldLogsAsync();
                        _logger?.Info($"Compresión periódica: {result.compressed} comprimidos, {result.deleted} eliminados");
                    }
                    catch (Exception ex)
                    {
                        _logger?.Error("Error en compresión periódica", ex);
                    }
                }, null, TimeSpan.FromHours(24), TimeSpan.FromHours(24));
                
                // 4. MemoryMonitor - Monitor de memoria (500 MB warning, 1 GB critical, check cada 30s)
                memoryMonitor = new MemoryMonitor(
                    warningThresholdMB: 500,
                    criticalThresholdMB: 1000,
                    checkIntervalSeconds: 30
                );
                
                // Eventos de memoria
                memoryMonitor.MemoryWarning += (s, e) =>
                {
                    _logger?.Warning($"⚠️ Memoria alta: {e.CurrentMemoryMB} MB (umbral: {e.ThresholdMB} MB)");
                    
                    this.Invoke((MethodInvoker)delegate
                    {
                        statusLabel.Text = $"⚠️ Memoria: {e.CurrentMemoryMB} MB";
                        statusLabel.ForeColor = Color.Orange;
                    });
                };
                
                memoryMonitor.MemoryCritical += (s, e) =>
                {
                    _logger?.Error($"❌ Memoria crítica: {e.CurrentMemoryMB} MB (umbral: {e.ThresholdMB} MB)");
                    
                    this.Invoke((MethodInvoker)delegate
                    {
                        statusLabel.Text = $"❌ Memoria crítica: {e.CurrentMemoryMB} MB";
                        statusLabel.ForeColor = Color.Red;
                        
                        // Limpiar resultados si hay demasiados
                        if (resultsListView.Items.Count > 1000)
                        {
                            var toRemove = resultsListView.Items.Count - 500;
                            for (int i = 0; i < toRemove; i++)
                            {
                                resultsListView.Items.RemoveAt(0);
                            }
                            _logger?.Info($"Limpieza automática: {toRemove} resultados eliminados");
                        }
                    });
                };
                
                _logger?.Info("MemoryMonitor inicializado: 500 MB warning, 1 GB critical");
                
                // 5. LazyTabLoader - Se inicializará después de crear el TabControl
                // (se hace en InitializeComponents)
                
                _logger?.Info("✅ Optimizaciones avanzadas (Nivel 3) inicializadas correctamente");
            }
            catch (Exception ex)
            {
                _logger?.Error("Error inicializando optimizaciones avanzadas", ex);
                Console.WriteLine($"Error en optimizaciones avanzadas: {ex.Message}");
            }
        }
        
