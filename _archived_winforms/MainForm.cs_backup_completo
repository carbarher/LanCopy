        private string GetFileType(string extension)
        {
            var ext = extension.ToLower();
            if (new[] { "mp3", "flac", "wav", "m4a", "ogg", "wma" }.Contains(ext))
                return "Audio";
            if (new[] { "mp4", "avi", "mkv", "mov", "wmv", "flv" }.Contains(ext))
                return "Video";
            if (new[] { "pdf", "epub", "mobi", "azw", "azw3", "djvu" }.Contains(ext))
                return "Libro/Documento";
            if (new[] { "cbr", "cbz", "cb7", "cbt" }.Contains(ext))
                return "Comic";
            if (new[] { "jpg", "jpeg", "png", "gif", "bmp", "webp" }.Contains(ext))
                return "Imagen";
            if (new[] { "zip", "rar", "7z", "tar", "gz" }.Contains(ext))
                return "Archivo comprimido";
            return "Otro";
        }
        
        private string EstimateQuality(SearchResult result)
        {
            // Eliminada estimación por bitrate - solo por tamaño
            long sizeMB = result.Size / (1024 * 1024);
            if (sizeMB > 100) return "⭐⭐⭐⭐ Alta (archivo grande)";
            if (sizeMB > 50) return "⭐⭐⭐ Media";
            if (sizeMB > 10) return "⭐⭐ Baja";
            return "⭐ Muy baja";
        }

