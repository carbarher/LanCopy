        private async void WatchlistTimer_Tick(object? sender, EventArgs e)
        {
            if (watchlistBox.Items.Count == 0 || client == null) return;
            
            // Detener el timer para evitar ejecuciones superpuestas
            watchlistTimer.Stop();
            
            watchlistLog.AppendText($"\r\n========================================\r\n");
            watchlistLog.AppendText($"🔍 BÚSQUEDA AUTOMÁTICA - {DateTime.Now:HH:mm:ss}\r\n");
            watchlistLog.AppendText($"========================================\r\n");
            
            foreach (string term in watchlistBox.Items)
            {
                try
                {
                    watchlistLog.AppendText($"\r\n🔎 Buscando: {term}\r\n");
                    
                    var searchQuery = SearchQuery.FromText(term);
                    
                    // Usar configuración del usuario
                    int timeout = defaultSearchTimeoutSecs * 1000;
                    int respLimit = 100;
                    int fLimit = 200;
                    
                    this.Invoke((MethodInvoker)delegate
                    {
                        if (searchTimeoutBox != null) timeout = (int)searchTimeoutBox.Value * 1000;
                        if (responseLimitBox != null) respLimit = (int)responseLimitBox.Value;
                        if (fileLimitBox != null) fLimit = (int)fileLimitBox.Value;
                    });
                    
                    var searchOptions = new SearchOptions(
                        searchTimeout: timeout,
                        responseLimit: respLimit,
                        fileLimit: fLimit
                    );
                    
                    var searchResult = await client.SearchAsync(searchQuery, options: searchOptions).ConfigureAwait(false);
                    
                    int totalFiles = 0;
                    foreach (var response in searchResult.Responses)
                    {
                        // OPTIMIZACIÓN: Usar .Count property
                        totalFiles += response.Files.Count;
                    }
                    
                    watchlistLog.AppendText($"  ✅ Encontrados: {totalFiles} archivos\r\n");
                    
                    if (totalFiles > 0)
                    {
                        // Notificar si hay resultados nuevos
                        statusLabel.Text = $"👁️ Watchlist: {totalFiles} resultados para '{term}'";
                    }
                    
                    await Task.Delay(2000); // Esperar 2s entre búsquedas
                }
                catch (Exception ex)
                {
                    watchlistLog.AppendText($"  ❌ Error: {ex.Message}\r\n");
                }
            }
            
            watchlistLog.AppendText($"\r\n✅ Búsqueda completada. Próxima búsqueda en 1 hora...\r\n");
            watchlistLog.SelectionStart = watchlistLog.Text.Length;
            watchlistLog.ScrollToCaret();
            
            // Reiniciar el timer para la próxima ejecución
            watchlistTimer.Start();
        }

        private void ViewDownloadHistory_Click(object? sender, EventArgs e)
        {
            try
            {
                // Usar el archivo configurado en la configuración
                string historyFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, 
                    string.IsNullOrEmpty(downloadedFilesListPath) ? "downloaded_files.txt" : downloadedFilesListPath);
                
                if (!System.IO.File.Exists(historyFile))
                {
                    DarkMessageBox.Show($"No existe el archivo de tracking:\n{historyFile}\n\nSe creará automáticamente al descargar archivos.", 
                        "Archivo de Tracking", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    return;
                }
                
                // Leer el archivo CSV con pipe (filename|author|size|date)
                var lines = System.IO.File.ReadAllLines(historyFile);
                var downloadedFiles = lines.Where(l => !string.IsNullOrWhiteSpace(l)).ToList();
                
                if (downloadedFiles.Count == 0)
                {
                    DarkMessageBox.Show("El archivo de tracking está vacío.\n\nSe irá llenando automáticamente al descargar archivos.", 
                        "Archivo de Tracking", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    return;
                }
                
                // Crear ventana para mostrar el historial
                var historyForm = new Form
                {
                    Text = $"📋 Archivos Descargados - {Path.GetFileName(historyFile)}",
                    Size = new Size(1100, 600),
                    StartPosition = FormStartPosition.CenterParent,
                    BackColor = Color.FromArgb(30, 30, 30),
                    ForeColor = Color.White
                };
                
                var listView = new ListView
                {
                    Dock = DockStyle.Fill,
                    View = View.Details,
                    FullRowSelect = true,
                    GridLines = true,
                    BackColor = Color.FromArgb(45, 45, 45),
                    ForeColor = Color.White,
                    Font = new Font("Consolas", 9)
                };
                
                listView.Columns.Add("#", 50);
                listView.Columns.Add("Archivo", 350);
                listView.Columns.Add("Autor", 200);
                listView.Columns.Add("Tamaño", 100);
                listView.Columns.Add("Fecha", 150);
                
                // Variables para ordenamiento
                int sortColumn = -1;
                bool sortAscending = true;
                
                // Evento para ordenar al hacer clic en columna
                listView.ColumnClick += (s, ev) =>
                {
                    // Si es la misma columna, invertir orden
                    if (ev.Column == sortColumn)
                    {
                        sortAscending = !sortAscending;
                    }
                    else
                    {
                        sortColumn = ev.Column;
                        sortAscending = true;
                    }
                    
                    // Obtener todos los items
                    var items = new List<ListViewItem>();
                    foreach (ListViewItem item in listView.Items)
                    {
                        items.Add(item);
                    }
                    
                    // Ordenar según la columna
                    items.Sort((a, b) =>
                    {
                        string textA = a.SubItems[sortColumn].Text;
                        string textB = b.SubItems[sortColumn].Text;
                        
                        int comparison = 0;
                        
                        // Ordenamiento especial para columnas numéricas
                        if (sortColumn == 0) // # (número)
                        {
                            if (int.TryParse(textA, out int numA) && int.TryParse(textB, out int numB))
                            {
                                comparison = numA.CompareTo(numB);
                            }
                        }
                        else if (sortColumn == 3) // Tamaño
                        {
                            // Extraer valor numérico del tamaño
                            double sizeA = ParseSize(textA);
                            double sizeB = ParseSize(textB);
                            comparison = sizeA.CompareTo(sizeB);
                        }
                        else if (sortColumn == 4) // Fecha
                        {
                            if (DateTime.TryParse(textA, out DateTime dateA) && DateTime.TryParse(textB, out DateTime dateB))
                            {
                                comparison = dateA.CompareTo(dateB);
                            }
                            else
                            {
                                comparison = string.Compare(textA, textB, StringComparison.OrdinalIgnoreCase);
                            }
                        }
                        else // Texto (Archivo, Autor)
                        {
                            comparison = string.Compare(textA, textB, StringComparison.OrdinalIgnoreCase);
                        }
                        
                        return sortAscending ? comparison : -comparison;
                    });
                    
                    // Recargar items ordenados
                    listView.Items.Clear();
                    listView.Items.AddRange(items.ToArray());
                    
                    // Actualizar indicador visual en columna
                    for (int i = 0; i < listView.Columns.Count; i++)
                    {
                        var col = listView.Columns[i];
                        string baseText = col.Text.TrimEnd('▲', '▼', ' ');
                        if (i == sortColumn)
                        {
                            col.Text = baseText + (sortAscending ? " ▲" : " ▼");
                        }
                        else
                        {
                            col.Text = baseText;
                        }
                    }
                };
                
                // Función auxiliar para parsear tamaños
                double ParseSize(string sizeText)
                {
                    try
                    {
                        var parts = sizeText.Split(' ');
                        if (parts.Length == 2)
                        {
                            double value = double.Parse(parts[0]);
                            string unit = parts[1].ToUpper();
                            if (unit == "MB") return value * 1024 * 1024;
                            if (unit == "KB") return value * 1024;
                            if (unit == "GB") return value * 1024 * 1024 * 1024;
                        }
                    }
                    catch { }
                    return 0;
                }
                
                // Agregar archivos a la lista (parsear CSV con pipe)
                int index = 1;
                foreach (var line in downloadedFiles)
                {
                    var parts = line.Split('|');
                    if (parts.Length >= 4)
                    {
                        var item = new ListViewItem(index.ToString());
                        item.SubItems.Add(parts[0].Trim()); // Filename
                        item.SubItems.Add(parts[1].Trim()); // Author
                        
                        // Formatear tamaño
                        if (long.TryParse(parts[2].Trim(), out long size))
                        {
                            string sizeStr = size > 1024 * 1024 ? $"{size / (1024.0 * 1024.0):F1} MB" : $"{size / 1024.0:F1} KB";
                            item.SubItems.Add(sizeStr);
                        }
                        else
                        {
                            item.SubItems.Add(parts[2].Trim());
                        }
                        
                        item.SubItems.Add(parts[3].Trim()); // Date
                        item.Tag = line; // Guardar línea completa para menú contextual
                        listView.Items.Add(item);
                        index++;
                    }
                }
                
                // Agregar menú contextual
                var contextMenu = new ContextMenuStrip();
                contextMenu.Items.Add("📋 Copiar nombre", null, (s, ev) => {
                    if (listView.SelectedItems.Count > 0)
                    {
                        string filename = listView.SelectedItems[0].SubItems[1].Text;
                        Clipboard.SetText(filename);
                        DarkMessageBox.Show($"Copiado: {filename}", "Portapapeles", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    }
                });
                contextMenu.Items.Add("👤 Copiar autor", null, (s, ev) => {
                    if (listView.SelectedItems.Count > 0)
                    {
                        string author = listView.SelectedItems[0].SubItems[2].Text;
                        Clipboard.SetText(author);
                        DarkMessageBox.Show($"Copiado: {author}", "Portapapeles", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    }
                });
                contextMenu.Items.Add(new ToolStripSeparator());
                contextMenu.Items.Add("🗑️ Eliminar entrada", null, (s, ev) => {
                    if (listView.SelectedItems.Count > 0)
                    {
                        var result = DarkMessageBox.Show("¿Eliminar esta entrada del historial?", "Confirmar", MessageBoxButtons.YesNo, MessageBoxIcon.Question);
                        if (result == DialogResult.Yes)
                        {
                            string lineToRemove = listView.SelectedItems[0].Tag?.ToString() ?? "";
                            var allLines = System.IO.File.ReadAllLines(historyFile).ToList();
                            allLines.Remove(lineToRemove);
                            System.IO.File.WriteAllLines(historyFile, allLines);
                            listView.Items.Remove(listView.SelectedItems[0]);
                            DarkMessageBox.Show("Entrada eliminada", "Historial", MessageBoxButtons.OK, MessageBoxIcon.Information);
                        }
                    }
                });
                listView.ContextMenuStrip = contextMenu;
                
                var statsLabel = new Label
                {
                    Text = $"📊 Total de archivos descargados: {downloadedFiles.Count} | Archivo: {Path.GetFileName(historyFile)}",
                    Dock = DockStyle.Bottom,
                    Height = 30,
                    TextAlign = ContentAlignment.MiddleLeft,
                    Padding = new Padding(10, 0, 0, 0),
                    BackColor = Color.FromArgb(20, 20, 20),
                    ForeColor = Color.LightGray
                };
                
                var buttonPanel = new Panel
                {
                    Dock = DockStyle.Bottom,
                    Height = 50,
                    BackColor = Color.FromArgb(20, 20, 20)
                };
                
                var clearButton = new Button
                {
                    Text = "🗑️ Limpiar Archivo",
                    Location = new Point(10, 10),
                    Size = new Size(150, 30),
                    BackColor = Color.FromArgb(200, 50, 50),
                    ForeColor = Color.White,
                    FlatStyle = FlatStyle.Flat
                };
                clearButton.FlatAppearance.BorderSize = 0;
                clearButton.Click += (s, ev) =>
                {
                    var result = DarkMessageBox.Show(
                        "⚠️ ¡ADVERTENCIA! ESTA ACCIÓN NO SE PUEDE DESHACER ⚠️\n\n" +
                        "🗑️ Estás a punto de BORRAR PERMANENTEMENTE:\n" +
                        "   • Todo el historial visible en esta ventana\n" +
                        "   • El registro interno de descargas\n" +
