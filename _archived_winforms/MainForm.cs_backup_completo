        // Manejo mejorado de desconexiones
        private async Task HandleDisconnectionWithRetry()
        {
            if (isReconnecting) return; // Ya hay un intento de reconexión en curso
            
            isReconnecting = true; // Activar bandera
            
            try
            {
                int retryCount = 0;
                int maxRetries = 3; // Reducido de 5 a 3 intentos
                
                // Limpiar cliente existente antes de reconectar
                try
                {
                    if (client != null)
                    {
                        client.Dispose();
                        client = null;
                    }
                }
                catch { }
                
                while (retryCount < maxRetries && !isDisposing)
            {
                try
                {
                    // Espera de 1 segundo antes de cada intento
                    await Task.Delay(1000);
                    
                    UpdateConnectionStatus("Reconectando...", Color.Orange);
                    statusLabel.Invoke(() => statusLabel.Text = $"⟳ Reintento {retryCount + 1}/{maxRetries}...");
                    
                    // Backoff adicional: 3s, 6s, 12s (después de la espera inicial de 1s)
                    int delayMs = Math.Min(3000 * (int)Math.Pow(2, retryCount), 15000);
                    await Task.Delay(delayMs);
                    
                    // Crear cliente nuevo con timeout más corto
                    var options = new SoulseekClientOptions(
                        listenPort: new Random().Next(50000, 60000),
                        enableDistributedNetwork: false
                    );
                    client = new SoulseekClient(options);
                    
                    // Conectar con timeout de 15 segundos (más corto que AutoConnect)
                    var connectTask = client.ConnectAsync(username, password).ConfigureAwait(false);
                    var timeoutTask = Task.Delay(15000);
                    var completedTask = await Task.WhenAny(connectTask, timeoutTask);
                    
                    if (completedTask == timeoutTask)
                    {
                        client?.Dispose();
                        client = null;
                        throw new TimeoutException("Timeout de reconexión (15s)");
                    }
                    
                    await connectTask;
                    
                    UpdateConnectionStatus("Conectado", Color.LimeGreen);
                    statusLabel.Invoke(() => statusLabel.Text = "✓ Reconexión exitosa");
                    searchButton.Invoke(() => searchButton.Enabled = true);
                    connectButton.Invoke(() => 
                    {
                        connectButton.Text = "Desconectar";
                        connectButton.BackColor = Color.FromArgb(150, 0, 0);
                    });
                    return;
                }
                catch (Exception ex)
                {
                    retryCount++;
                    string errorType = ex is TimeoutException ? "Timeout" : ex.GetType().Name;
                    UpdateConnectionStatus($"Reintento {retryCount}/{maxRetries}", Color.Orange);
                    statusLabel.Invoke(() => statusLabel.Text = $"⚠ Error: {errorType} - Reintento {retryCount}/{maxRetries}");
                    
                    if (retryCount >= maxRetries)
                    {
                        UpdateConnectionStatus("Desconectado", Color.Red);
                        statusLabel.Invoke(() => statusLabel.Text = "✗ Reconexión fallida - Haz clic en Conectar manualmente");
                        
                        // Actualizar UI para reflejar desconexión
                        connectButton.Invoke(() =>
                        {
                            connectButton.Text = "Conectar";
                            connectButton.BackColor = Color.FromArgb(0, 120, 215);
                        });
                        searchButton.Invoke(() => searchButton.Enabled = false);
                        
                        // NO mostrar MessageBox - solo actualizar la barra de estado
                        // El usuario puede reconectar manualmente si lo desea
                    }
                }
                }
            }
            finally
            {
                isReconnecting = false; // Desactivar bandera siempre
            }
        }
        
