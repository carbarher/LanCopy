                stats.AppendLine($"   Total descargado (sesión): {FormatFileSize(totalBytes)}");
                stats.AppendLine($"   Total descargado (histórico): {FormatFileSize(totalHistorical)}\n");
                
                // OPTIMIZACIÓN: Análisis de usuarios - materializar query una sola vez
                stats.AppendLine(" ANÁLISIS DE USUARIOS:");
                var topUsers = history.GroupBy(h => h.Username)
                    .Select(g => new { Username = g.Key, Count = g.Count(), TotalSize = g.Sum(h => h.Size) })
                    .OrderByDescending(u => u.Count)
                    .Take(5)
                    .ToList(); // Materializar para evitar doble enumeración
                
                if (topUsers.Count > 0)
                {
                    stats.AppendLine("   Top 5 usuarios (más descargas):");
                    foreach (var user in topUsers)
                    {
                        stats.AppendLine($"      • {user.Username}: {user.Count} archivos ({FormatFileSize(user.TotalSize)})");
