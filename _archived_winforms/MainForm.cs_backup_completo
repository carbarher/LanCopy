        private void FilterDebounceTimer_Tick(object? sender, EventArgs e)
        {
            filterDebounceTimer?.Stop();
            
            string filter = filterTextBox.Text.Trim();
            
            // OPTIMIZACIÓN: Filtrar directamente sobre el ListView sin duplicar datos
            if (string.IsNullOrEmpty(filter))
            {
                // Mostrar todos los items
                resultsListView.BeginUpdate();
                foreach (ListViewItem item in resultsListView.Items)
                {
                    item.Remove();
                    resultsListView.Items.Add(item);
                }
                resultsListView.EndUpdate();
                return;
            }
            
            string filterLower = filter.ToLower();
            
            resultsListView.BeginUpdate();
            
            // OPTIMIZACIÓN: Ocultar/mostrar items sin recrearlos
            var itemsToShow = new List<ListViewItem>();
            var itemsToHide = new List<ListViewItem>();
            
            foreach (ListViewItem item in resultsListView.Items)
            {
                var result = (SearchResult)item.Tag;
                // OPTIMIZACIÓN: Usar IndexOf con StringComparison en lugar de ToLower() + Contains
                bool matches = result.Filename.IndexOf(filter, StringComparison.OrdinalIgnoreCase) >= 0 ||
                              result.Username.IndexOf(filter, StringComparison.OrdinalIgnoreCase) >= 0 ||
                              result.Extension.IndexOf(filter, StringComparison.OrdinalIgnoreCase) >= 0;
                
                if (!matches)
                {
                    itemsToHide.Add(item);
                }
            }
            
            // Remover items que no coinciden
            foreach (var item in itemsToHide)
            {
                resultsListView.Items.Remove(item);
            }
            
            resultsListView.EndUpdate();
            
            int visibleCount = resultsListView.Items.Count;
            UpdateResultsCount(visibleCount);
            statusLabel.Text = $"🔍 {visibleCount} resultados (filtrados por '{filter}')";
        }

