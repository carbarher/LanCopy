        private bool IsSpanishContent(string filename)
        {
            // OPTIMIZACIÓN: Búsquedas case-insensitive sin ToLower() completo
            
            // OPTIMIZACIÓN: Verificación rápida de caracteres españoles (sin ToLower)
            if (filename.IndexOf('ñ', StringComparison.OrdinalIgnoreCase) >= 0 ||
                filename.IndexOf('Ñ') >= 0)
                return true;
            
            string lower = filename.ToLower();
            
            // OPTIMIZACIÓN: Verificación temprana de acentos españoles
            if (lower.Contains("á") || lower.Contains("é") || lower.Contains("í") || 
                lower.Contains("ó") || lower.Contains("ú"))
            {
                // Si tiene acentos, verificar que NO tenga palabras de otros idiomas
                bool hasOtherLanguage = englishKeywordsSet.Any(keyword => lower.Contains(keyword)) ||
                                       italianKeywordsSet.Any(keyword => lower.Contains(keyword)) ||
                                       germanKeywordsSet.Any(keyword => lower.Contains(keyword));
                if (!hasOtherLanguage)
                    return true;
            }
            
            // OPTIMIZACIÓN: Contar palabras de cada idioma (early exit si encuentra otros idiomas)
            int englishCount = 0;
            foreach (var keyword in englishKeywordsSet)
            {
                if (lower.Contains(keyword))
                {
                    englishCount++;
                    if (englishCount >= 1) return false; // Early exit
                }
            }
            
            int italianCount = 0;
            foreach (var keyword in italianKeywordsSet)
            {
                if (lower.Contains(keyword))
                {
                    italianCount++;
                    if (italianCount >= 1) return false; // Early exit
                }
            }
            
            int germanCount = 0;
            foreach (var keyword in germanKeywordsSet)
            {
                if (lower.Contains(keyword))
                {
                    germanCount++;
                    if (germanCount >= 1) return false; // Early exit
                }
            }
            
            // Contar palabras españolas
            int spanishCount = 0;
            foreach (var keyword in spanishKeywordsSet)
            {
                if (lower.Contains(keyword))
                {
                    spanishCount++;
                    if (spanishCount >= 2) return true; // Early exit
                }
            }
            
            return false;
        }

