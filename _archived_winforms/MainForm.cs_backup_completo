        private void CleanupOldFiles()
        {
            try
            {
                var result = DarkMessageBox.Show(
                    "¿Eliminar archivos descargados hace más de 30 días?\n\nEsto NO eliminará los archivos, solo limpiará el historial.",
                    "Limpieza automática",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Question);
                
                if (result == DialogResult.Yes)
                {
                    var history = LoadDownloadHistory();
                    var cutoffDate = DateTime.Now.AddDays(-30);
                    var oldEntries = history.Where(h => h.CompletedDate < cutoffDate).ToList();
                    
                    if (oldEntries.Count > 0)
                    {
                        // Eliminar del historial
                        var newHistory = history.Where(h => h.CompletedDate >= cutoffDate).ToList();
                        // UNIFICADO: Usar el mismo archivo
                        string historyFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "downloaded_files.json");
                        string json = System.Text.Json.JsonSerializer.Serialize(newHistory, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
                        System.IO.File.WriteAllText(historyFile, json);
                        
                        DarkMessageBox.Show($"✓ Limpiados {oldEntries.Count} registros del historial", "Limpieza completada", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    }
                    else
                    {
                        DarkMessageBox.Show("No hay archivos viejos para limpiar", "Limpieza", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    }
                }
            }
            catch (Exception ex)
