        private Dictionary<string, (string hash, DateTime validated)> validationCache = new Dictionary<string, (string, DateTime)>();
        
        // Optimización #9: Renderizado diferido de UI
        private System.Windows.Forms.Timer uiUpdateTimer;
        private Queue<Action> pendingUIUpdates = new Queue<Action>();
