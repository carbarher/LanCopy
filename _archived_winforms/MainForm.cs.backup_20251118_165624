        private int[] GetBloomHashes(string key)
        {
            var hashes = new int[BLOOM_HASHES];
            var hash1 = key.GetHashCode();
            var hash2 = key.Reverse().ToString().GetHashCode();
            
            for (int i = 0; i < BLOOM_HASHES; i++)
            {
                hashes[i] = Math.Abs((hash1 + i * hash2) % BLOOM_SIZE);
            }
            return hashes;
        }
        
        private void BloomAdd(string key)
        {
            if (bloomFilter == null) return;
            foreach (var hash in GetBloomHashes(key))
            {
                bloomFilter[hash] = true;
            }
        }
        
        private bool BloomMightContain(string key)
        {
            if (bloomFilter == null) return true; // Si no hay bloom, asumir que puede existir
            foreach (var hash in GetBloomHashes(key))
            {
                if (!bloomFilter[hash]) return false; // Definitivamente NO existe
            }
            return true; // Puede existir (o falso positivo)
        }
        
