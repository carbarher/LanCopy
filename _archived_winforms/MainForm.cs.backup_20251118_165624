            {
                SafeLog($"Error en ConnectButton_Click: {ex.Message}\n");
                MessageBox.Show($"Error al conectar: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
