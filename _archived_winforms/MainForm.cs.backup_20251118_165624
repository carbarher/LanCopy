        private void CancelAllDownloads()
        {
            var result = MessageBox.Show("¿Cancelar TODAS las descargas activas?\n\nEsto cancelará todas las descargas en curso y pendientes.", 
                "Confirmar Cancelación Masiva", MessageBoxButtons.YesNo, MessageBoxIcon.Warning);
            
            if (result == DialogResult.Yes)
            {
                try
                {
                    int cancelledCount = 0;
                    
                    lock (downloadQueueLock)
                    {
                        var activeTasks = downloadQueue
                            .Where(t => t.Status == DownloadStatus.Downloading || 
                                       t.Status == DownloadStatus.Pending || 
                                       t.Status == DownloadStatus.Paused)
                            .ToList();
                        
                        foreach (var task in activeTasks)
                        {
                            task.Status = DownloadStatus.Cancelled;
                            task.CancellationToken?.Cancel();
                            UpdateDownloadUI(task, "❌ Cancelado");
                            cancelledCount++;
                        }
                    }
                    
                    SafeLog($"❌ Canceladas {cancelledCount} descargas");
                    UpdateProgressDisplay();
                    
                    if (cancelledCount > 0)
                    {
                        MessageBox.Show($"Se cancelaron {cancelledCount} descargas", 
                            "Cancelación Completa", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    }
                }
                catch (Exception ex)
                {
                    SafeLog($"❌ Error cancelando descargas: {ex.Message}");
                    MessageBox.Show($"Error al cancelar descargas: {ex.Message}", 
                        "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            }

            RefreshAutoSummary();
        }

        private void RefreshAutoSummary()
        {
            if (!IsHandleCreated)
                return;

            if (InvokeRequired)
            {
                SafeBeginInvoke(() => RefreshAutoSummary());
                return;
            }

            if (lblAutoSummaryCounts != null)
            {
                int totalAuthors = allAuthorsData?.Count ?? 0;
                int selectedAuthors = filteredAuthorsData?.Count(a => a.IsChecked) ?? 0;
                lblAutoSummaryCounts.Text = $"Autores cargados: {totalAuthors:N0} | Seleccionados: {selectedAuthors:N0}";
            }

            if (lblAutoSummaryStatus != null)
            {
                string statusText = "Estado: En espera";
                if (autoPurgeRunning)
                    statusText = "Estado: Purga en curso";
                else if (autoSearchRunning)
                    statusText = "Estado: Búsqueda automática";

                lblAutoSummaryStatus.Text = statusText;
            }
        }
        
        private void ClearCompletedDownloads()
        {
            try
            {
                int removedCount = 0;
                
                lock (downloadQueueLock)
                {
                    var completedTasks = downloadQueue
                        .Where(t => t.Status == DownloadStatus.Completed || t.Status == DownloadStatus.Cancelled)
                        .ToList();
                    
                    foreach (var task in completedTasks)
                    {
                        downloadQueue.Remove(task);
                        
                        SafeInvoke(() =>
                        {
                            if (task.ListViewItem != null && lvDownloads.Items.Contains(task.ListViewItem))
                            {
                                lvDownloads.Items.Remove(task.ListViewItem);
                            }
                        });
                        
                        removedCount++;
                    }
                }
                
                if (removedCount > 0)
                {
                    SafeLog($"🗑️ Limpiadas {removedCount} descargas completadas/canceladas");
                    UpdateProgressDisplay();
                }
                else
                {
                    MessageBox.Show("No hay descargas completadas para limpiar", "Info", MessageBoxButtons.OK, MessageBoxIcon.Information);
                }
            }
            catch (Exception ex)
            {
                SafeLog($"❌ Error limpiando descargas: {ex.Message}");
            }
        }
        
        private void PauseSelectedDownload()
        {
            if (lvDownloads.SelectedItems.Count == 0)
            {
                MessageBox.Show("Selecciona una descarga primero", "Info", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            var task = lvDownloads.SelectedItems[0].Tag as DownloadTask;
            if (task == null) return;

            lock (downloadQueueLock)
            {
                if (task.Status == DownloadStatus.Downloading)
                {
                    task.Status = DownloadStatus.Paused;
                    task.CancellationToken?.Cancel();
                    UpdateDownloadUI(task, "⏸️ Pausado");
                    SafeLog($"⏸️ Descarga pausada: {task.File.FileName}");
                }
                else if (task.Status == DownloadStatus.Pending)
                {
                    task.Status = DownloadStatus.Paused;
                    UpdateDownloadUI(task, "⏸️ Pausado");
                    SafeLog($"⏸️ Descarga pausada: {task.File.FileName}");
                }
            }
        }
        
        private void ResumeSelectedDownload()
        {
            if (lvDownloads.SelectedItems.Count == 0)
            {
                MessageBox.Show("Selecciona una descarga primero", "Info", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            var task = lvDownloads.SelectedItems[0].Tag as DownloadTask;
            if (task == null) return;

            lock (downloadQueueLock)
            {
                if (task.Status == DownloadStatus.Paused)
                {
                    task.Status = DownloadStatus.Pending;
                    task.CancellationToken = new CancellationTokenSource();
                    UpdateDownloadUI(task, "⏳ Pendiente");
                    SafeLog($"▶️ Descarga reanudada: {task.File.FileName}");
                }
            }
        }
        
        private void CancelSelectedDownload()
        {
            if (lvDownloads.SelectedItems.Count == 0)
            {
                MessageBox.Show("Selecciona una descarga primero", "Info", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            var task = lvDownloads.SelectedItems[0].Tag as DownloadTask;
            if (task == null) return;

            var result = MessageBox.Show($"¿Cancelar descarga de:\n{task.File.FileName}?", 
                "Confirmar Cancelación", MessageBoxButtons.YesNo, MessageBoxIcon.Warning);
            
            if (result == DialogResult.Yes)
            {
                lock (downloadQueueLock)
                {
                    task.Status = DownloadStatus.Cancelled;
                    task.CancellationToken?.Cancel();
                    UpdateDownloadUI(task, "❌ Cancelado");
                    SafeLog($"❌ Descarga cancelada: {task.File.FileName}");
                }
            }
        }
        
