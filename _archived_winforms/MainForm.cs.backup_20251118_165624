                if (splitContainer.Width <= 0)
                    return;

                var available = splitContainer.Width;
                var minLeft = splitContainer.Panel1MinSize;
                const int desiredRightMin = 320;

                var desired = Math.Max(minLeft, available / 2);
                var maxAllowed = available - desiredRightMin;
                if (maxAllowed < minLeft)
                    maxAllowed = available - 80; // permitir más espacio cuando la ventana es estrecha
                desired = Math.Min(desired, Math.Max(minLeft, maxAllowed));

                desired = Math.Max(minLeft, Math.Min(desired, available - splitContainer.Panel2MinSize));

                if (desired >= minLeft && desired <= available - splitContainer.Panel2MinSize)
                {
                    splitContainer.SplitterDistance = desired;
                }
            }

            parent.HandleCreated += (_, _) => AdjustAutoSplit();
            parent.Resize += (_, _) => AdjustAutoSplit();
            splitContainer.SizeChanged += (_, _) => AdjustAutoSplit();

            // Cargar última ruta de archivo si existe
            LoadLastAuthorsFile();
            
            // Cargar resultados automáticos desde SQLite al iniciar
            Task.Run(() =>
            {
                try
                {
                    lock (autoSearchResultsLock)
                    {
                        if (autoSearchResults.Count == 0)
                        {
                            LoadFilesFromDatabase();
                        }
                    }
                    
                    // Actualizar UI en el hilo principal
                    if (autoSearchResults.Count > 0)
                    {
                        this.SafeInvoke(() =>
                        {
                            AutoLog($"📊 Cargados {autoSearchResults.Count:N0} archivos desde base de datos");
                        });
                    }
                }
                catch (Exception ex)
                {
                    AutoLog($"⚠️ Error cargando datos iniciales: {ex.Message}");
                }
            });
            
            // Inicializar estado de botones
            UpdateAutoControlsEnabled();
            RefreshAutoSummary();
        }
        
