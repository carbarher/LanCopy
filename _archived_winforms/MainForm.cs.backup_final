        private async Task<bool> AutoDetectDuplicate(string fileName, string downloadPath)
        {
            if (!autoMode) return false;
            
            try
            {
                // Usar Rust para detección rápida de duplicados
                var existingFiles = System.IO.Directory.GetFiles(downloadDir, "*.epub", SearchOption.AllDirectories)
                    .Concat(System.IO.Directory.GetFiles(downloadDir, "*.mobi", SearchOption.AllDirectories))
                    .Concat(System.IO.Directory.GetFiles(downloadDir, "*.pdf", SearchOption.AllDirectories))
                    .Select(f => Path.GetFileName(f))
                    .ToList();
                
                foreach (var existing in existingFiles)
                {
                    double similarity = SlskDownCore.CalculateSimilarity(fileName, existing);
                    if (similarity > 0.85) // 85% similar
                    {
                        AutoLog($"🤖 Duplicado detectado: {fileName} ≈ {existing} ({similarity:P0})");
                        
                        var result = MessageBox.Show(
                            $"Archivo similar encontrado:\n\n" +
                            $"Nuevo: {fileName}\n" +
                            $"Existente: {existing}\n" +
                            $"Similitud: {similarity:P0}\n\n" +
                            $"¿Descargar de todos modos?",
                            "Duplicado Detectado",
                            MessageBoxButtons.YesNo,
                            MessageBoxIcon.Question
                        );
                        
                        return result == DialogResult.No;
                    }
                }
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error en auto-detección de duplicados: {ex.Message}");
            }
            
            return false;
        }
        
        // ============================================================================
        // OPTIMIZACIONES MASIVAS - CHECKPOINT SYSTEM
        // ============================================================================
        
        private async Task SaveProgressCheckpoint(int processed, List<string> allAuthors)
        {
            try
            {
                var checkpoint = new
                {
                    ProcessedCount = processed,
                    TotalCount = allAuthors.Count,
                    RemainingAuthors = allAuthors.Skip(processed).ToList(),
                    Timestamp = DateTime.Now,
                    TotalResults = autoSearchResults.Count
                };
                
                var json = JsonSerializer.Serialize(checkpoint, new JsonSerializerOptions { WriteIndented = true });
                await System.IO.File.WriteAllTextAsync(checkpointPath, json);
                
                AutoLog($"💾 Checkpoint guardado: {processed}/{allAuthors.Count} autores procesados");
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error guardando checkpoint: {ex.Message}");
            }
        }
        
        private async Task<List<string>> LoadCheckpointIfExists(List<string> authors)
        {
            try
            {
                if (!System.IO.File.Exists(checkpointPath))
                    return authors;
                
                var json = await System.IO.File.ReadAllTextAsync(checkpointPath);
                var checkpoint = JsonSerializer.Deserialize<JsonElement>(json);
                
                var processed = checkpoint.GetProperty("ProcessedCount").GetInt32();
                var total = checkpoint.GetProperty("TotalCount").GetInt32();
                var timestamp = checkpoint.GetProperty("Timestamp").GetDateTime();
                var totalResults = checkpoint.GetProperty("TotalResults").GetInt32();
                
                // Solo usar checkpoint si es reciente (menos de 24h)
                if ((DateTime.Now - timestamp).TotalHours > 24)
                {
                    AutoLog("⏰ Checkpoint antiguo (>24h), ignorando");
                    System.IO.File.Delete(checkpointPath);
                    return authors;
                }
                
                var result = MessageBox.Show(
                    $"🔄 CHECKPOINT ENCONTRADO\n\n" +
                    $"Fecha: {timestamp:dd/MM/yyyy HH:mm}\n" +
                    $"Procesados: {processed}/{total} autores\n" +
                    $"Resultados: {totalResults:N0} archivos\n" +
                    $"Restantes: {total - processed} autores\n\n" +
                    $"¿Continuar desde el checkpoint?",
                    "Recuperar Progreso",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Question
                );
                
                if (result == DialogResult.Yes)
                {
                    var remaining = checkpoint.GetProperty("RemainingAuthors")
                        .EnumerateArray()
                        .Select(e => e.GetString())
                        .ToList();
                    
                    AutoLog($"✅ Continuando desde checkpoint: {remaining.Count} autores restantes");
                    return remaining;
                }
                else
                {
                    System.IO.File.Delete(checkpointPath);
                    AutoLog("🔄 Checkpoint descartado, iniciando búsqueda completa");
                }
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error cargando checkpoint: {ex.Message}");
            }
            
            return authors;
        }
        
        private void DeleteCheckpoint()
        {
            try
            {
                if (System.IO.File.Exists(checkpointPath))
                {
                    System.IO.File.Delete(checkpointPath);
                    AutoLog("🗑️ Checkpoint eliminado");
                }
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error eliminando checkpoint: {ex.Message}");
            }
        }

        private void LvAutoAuthors_ColumnClick(object sender, ColumnClickEventArgs e)
        {
            // Si se hace clic en la misma columna, invertir el orden
            if (e.Column == sortColumn)
            {
                sortAscending = !sortAscending;
            }
            else
            {
                sortColumn = e.Column;
                sortAscending = true;
            }

            // Ordenar filteredAuthorsData según la columna
            switch (sortColumn)
            {
                case 0: // Autor (Nombre)
                    filteredAuthorsData = sortAscending
                        ? filteredAuthorsData.OrderBy(a => a.Name).ToList()
                        : filteredAuthorsData.OrderByDescending(a => a.Name).ToList();
                    break;
                case 1: // Archivos
                    filteredAuthorsData = sortAscending
                        ? filteredAuthorsData.OrderBy(a => a.FilesCount).ToList()
                        : filteredAuthorsData.OrderByDescending(a => a.FilesCount).ToList();
                    break;
                case 2: // Estado
                    filteredAuthorsData = sortAscending
                        ? filteredAuthorsData.OrderBy(a => a.Status).ToList()
                        : filteredAuthorsData.OrderByDescending(a => a.Status).ToList();
                    break;
            }

            // Actualizar encabezados de columnas con indicadores visuales
            string[] columnNames = { "Autor", "Archivos", "Estado" };
            for (int i = 0; i < lvAutoAuthors.Columns.Count && i < columnNames.Length; i++)
            {
                string header = columnNames[i];
                if (i == sortColumn)
                {
                    header += sortAscending ? " ▲" : " ▼";
                }
                lvAutoAuthors.Columns[i].Text = header;
            }

            // Recargar items en modo normal
            RefreshAuthorsListView();
        }
        
        private List<AuthorData> FilterAuthorsInternal(List<AuthorData> authors, string searchText)
        {
            if (string.IsNullOrWhiteSpace(searchText))
                return authors;

            try
            {
                if (SlskDown.Core.RustSearchIndex.IsRustAvailable() && authorSearchIndex == null)
                {
                    IndexAuthorsForSearch();
                }

                if (authorSearchIndex != null)
                {
                    var matches = SearchAuthorIntelligentSilent(searchText.Trim());
                    if (matches.Count > 0)
                    {
                        var matchSet = new HashSet<string>(matches, StringComparer.OrdinalIgnoreCase);
                        return authors.Where(a => matchSet.Contains(a.Name)).ToList();
                    }
                }
            }
            catch
            {
            }

            var search = searchText.ToLowerInvariant();
            return authors.Where(a => a.Name.ToLowerInvariant().Contains(search)).ToList();
        }

        private void ApplyCurrentFilters()
        {
            var filtered = new List<AuthorData>(allAuthorsData);

            // Aplicar filtro de texto si existe
            if (!string.IsNullOrWhiteSpace(txtFilterAuthors?.Text))
            {
                var search = txtFilterAuthors.Text.Trim();
                filtered = FilterAuthorsInternal(filtered, search);
            }

            if (chkCanonicalOnly?.Checked == true)
            {
                filtered = filtered
                    .Where(a => a.IsCanonical)
                    .ToList();
            }

            filteredAuthorsData = filtered;
        }
        
        private void LoadAuthorsIntoVirtualList(string[] authorNames)
        {
            allAuthorsData.Clear();
            authorIndex.Clear();
            
            foreach (var name in authorNames)
            {
                if (!string.IsNullOrWhiteSpace(name))
                {
                    var authorData = new AuthorData
                    {
                        Name = name.Trim(),
                        FilesCount = 0,
                        Status = "Listo",
                        ForeColor = Color.White,
                        IsChecked = true
                    };
                    allAuthorsData.Add(authorData);
                    authorIndex[authorData.Name] = authorData;
                }
            }

            filteredAuthorsData = new List<AuthorData>(allAuthorsData);
            RefreshAuthorsListView();
            UpdateAuthorCount();
            System.IO.File.Delete(checkpointPath); // Reset auto search resume state
        }

        private void ClearAutoSearchState(string reason = "Estado limpiado")
        {
            try
            {
                autoSearchWasRunning = false;
                currentAuthorIndex = 0;
                currentPass = 0;

                var statePath = autoSearchStateFile;
                var directory = Path.GetDirectoryName(statePath);
                if (!string.IsNullOrEmpty(directory) && !Directory.Exists(directory))
                {
                    Directory.CreateDirectory(directory);
                }

                var clearedState = new AutoSearchState();
                clearedState.Clear();
                clearedState.Save(statePath);

                DeleteCheckpoint();
                AutoLog($"🧹 Auto-búsqueda reiniciada ({reason})");
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error limpiando estado de auto-búsqueda: {ex.Message}");
            }
        }

        // Inicialización de infraestructura de búsqueda avanzada
        private void RefreshSearchWorkflowInstance()
        {
            if (client == null)
            {
                searchWorkflow = null;
                return;
            }

            searchFilterService ??= new SearchFilterService(MatchesCategory);
            searchRateLimiter ??= new SearchRateLimiterAdapter(
                async ct => await WaitForRateLimitAsync("workflow").ConfigureAwait(false));

            searchWorkflow = new SearchWorkflow(client, searchFilterService, searchRateLimiter, null, null, AutoLog);
        }

        private void InitializeSearchInfrastructure()
        {
            RefreshSearchWorkflowInstance();
        }

        private async Task InitializePhase1ComponentsAsync()
        {
            try
            {
                // 1. Inicializar BootstrapNodeManager
                
                // 2. Inicializar AdvancedSearchFilter
                advancedSearchFilter = new Core.AdvancedSearchFilter(Log);
                advancedSearchFilter.ExcludeFakes = true;
                advancedSearchFilter.ExcludeLowQuality = false;
                Log("✅ Filtro Avanzado: Inicializado (detección de fakes activada)");
                
                // 3. Inicializar StatisticsManager
