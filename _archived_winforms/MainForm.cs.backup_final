            catch (Exception ex)
            {
                Log($"⚠️ Error inicializando componentes Fase 1: {ex.Message}");
            }
        }

        private async Task EnsureUniversalAuthorsSeedAsync()
        {
            if (slskDatabase == null)
            {
                return;
            }

            try
            {
                var universalClassicAuthors = new[]
                {
                    "Homero",
                    "Homer",
                    "Hesíodo",
                    "Esquilo",
                    "Sófocles",
                    "Sophocles",
                    "Eurípides",
                    "Aristófanes",
                    "Heródoto",
                    "Tucídides",
                    "Jenofonte",
                    "Platón",
                    "Aristóteles",
                    "Plutarco",
                    "Virgilio",
                    "Horacio",
                    "Ovidio",
                    "Cicerón",
                    "Séneca",
                    "Tácito",
                    "Suetonio",
                    "Julio César",
                    "Tito Livio",
                    "Lucrecio",
                    "Catulo"
                };

                int PriorityFor(string author)
                {
                    for (int i = 0; i < universalClassicAuthors.Length; i++)
                    {
                        if (string.Equals(universalClassicAuthors[i], author, StringComparison.OrdinalIgnoreCase))
                        {
                            return 1000 - i;
                        }
                    }

                    return 0;
                }

                await slskDatabase.BulkInsertAuthorsAsync(
                    universalClassicAuthors,
                    "UniversalSeed",
                    IsCanonicalAuthorName,
                    PriorityFor).ConfigureAwait(false);
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error sembrando autores universales: {ex.Message}");
            }
        }

        private void LoadWatchlist()
        {
            try
            {
                string watchlistFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "watchlist.txt");
                if (!File.Exists(watchlistFile))
                {
                    return;
                }

                var lines = File.ReadAllLines(watchlistFile);
                watchlist.Clear();
                foreach (var line in lines)
                {
                    if (!string.IsNullOrWhiteSpace(line))
                    {
                        watchlist.Add(line.Trim());
                    }
                }
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error cargando watchlist: {ex.Message}");
            }
        }

        private async Task LoadAuthorsFromDB()
        {
            await LoadAuthorsFromDatabaseAsync().ConfigureAwait(false);
        }
        
        private void RefreshAuthorsListView()
        {
            if (lvAutoAuthors == null) return;
            
            // Guardar posición del scroll y selección
            int topIndex = -1;
            string? topAuthorName = null;
            var selectedIndices = new List<int>();
            var selectedAuthorNames = new List<string>();
            
            try
            {
                if (lvAutoAuthors.TopItem != null)
                {
                    topIndex = lvAutoAuthors.TopItem.Index;
                    topAuthorName = lvAutoAuthors.TopItem.Text;
                }
                
                foreach (int index in lvAutoAuthors.SelectedIndices)
                {
                    selectedIndices.Add(index);
                    if (index >= 0 && index < lvAutoAuthors.Items.Count)
                    {
                        selectedAuthorNames.Add(lvAutoAuthors.Items[index].Text);
                    }
                }
            }
            catch { }
            
            lvAutoAuthors.BeginUpdate();
            lvAutoAuthors.Items.Clear();

            if (filteredAuthorsData.Count > 0)
            {
                var listItems = new ListViewItem[filteredAuthorsData.Count];
                for (int i = 0; i < filteredAuthorsData.Count; i++)
                {
                    var author = filteredAuthorsData[i];
                    var displayName = author.IsCanonical
                        ? $"{author.Name}  ⭐"
                        : author.Name;

                    var itemColor = author.ForeColor;
                    if (author.IsCanonical && (itemColor.IsEmpty || itemColor == Color.White || itemColor == Color.LightGray))
                    {
                        itemColor = Color.Gold;
                    }

                    var item = new ListViewItem(displayName)
                    {
                        ForeColor = itemColor,
                        Tag = author
                    };
                    item.SubItems.Add(author.FilesCount.ToString());

                    var statusText = author.Status ?? string.Empty;
                    if (author.IsCanonical)
                    {
                        statusText = string.IsNullOrWhiteSpace(statusText)
                            ? "⭐ Prioridad canónica"
                            : $"⭐ {statusText}";
                    }

                    item.SubItems.Add(statusText);
                    listItems[i] = item;
                }

                lvAutoAuthors.Items.AddRange(listItems);
            }

            lvAutoAuthors.EndUpdate();
            
            // Restaurar posición del scroll
            try
            {
                if (!string.IsNullOrEmpty(topAuthorName))
                {
                    for (int i = 0; i < lvAutoAuthors.Items.Count; i++)
                    {
                        if (string.Equals(lvAutoAuthors.Items[i].Text, topAuthorName, StringComparison.OrdinalIgnoreCase))
                        {
                            lvAutoAuthors.TopItem = lvAutoAuthors.Items[i];
                            topIndex = i;
                            break;
                        }
                    }
                }

                if (topIndex >= 0 && topIndex < lvAutoAuthors.Items.Count)
                {
                    lvAutoAuthors.TopItem = lvAutoAuthors.Items[topIndex];
                }
                
                // Restaurar selección
                if (selectedAuthorNames.Count > 0)
                {
                    foreach (var name in selectedAuthorNames)
                    {
                        for (int i = 0; i < lvAutoAuthors.Items.Count; i++)
                        {
                            if (string.Equals(lvAutoAuthors.Items[i].Text, name, StringComparison.OrdinalIgnoreCase))
                            {
                                lvAutoAuthors.Items[i].Selected = true;
                            }
                        }
                    }
                }
                else
                {
                    foreach (int index in selectedIndices)
                    {
                        if (index < lvAutoAuthors.Items.Count)
                        {
                            lvAutoAuthors.Items[index].Selected = true;
                        }
                    }
                }
            }
            catch { }
        }
        
        private string[] GetAllAuthorsFromVirtualList()
        {
            return allAuthorsData.Select(a => a.Name).ToArray();
        }

        private string[] GetCheckedAuthorsFromVirtualList()
        {
            return filteredAuthorsData.Where(a => a.IsChecked).Select(a => a.Name).ToArray();
        }
        
        private void FilterAuthors(string searchText)
        {
            if (string.IsNullOrWhiteSpace(searchText))
            {
                filteredAuthorsData = new List<AuthorData>(allAuthorsData);
            }
            else
            {
                try
                {
                    if (SlskDown.Core.RustSearchIndex.IsRustAvailable() && authorSearchIndex == null)
                    {
                        IndexAuthorsForSearch();
                    }

                    if (authorSearchIndex != null)
                    {
                        var matches = SearchAuthorIntelligentSilent(searchText.Trim());
                        if (matches.Count > 0)
                        {
                            var matchSet = new HashSet<string>(matches, StringComparer.OrdinalIgnoreCase);
                            filteredAuthorsData = allAuthorsData
                                .Where(a => !string.IsNullOrEmpty(a.Name) && matchSet.Contains(a.Name))
                                .ToList();
                        }
                        else
                        {
                            filteredAuthorsData = new List<AuthorData>();
                        }
                    }
                    else
                    {
                        var filter = searchText.Trim();
                        filteredAuthorsData = allAuthorsData
                            .Where(a => !string.IsNullOrEmpty(a.Name) && a.Name.Contains(filter, StringComparison.OrdinalIgnoreCase))
                            .ToList();
                    }
                }
                catch
                {
                    var filter = searchText.Trim();
                    filteredAuthorsData = allAuthorsData
                        .Where(a => !string.IsNullOrEmpty(a.Name) && a.Name.Contains(filter, StringComparison.OrdinalIgnoreCase))
                        .ToList();
                }
            }

            RefreshAuthorsListView();
            UpdateAuthorCount();
        }

        private void UpdateAuthorCount()
        {
            var countLabel = lblAuthorCount;
            if (countLabel == null)
            {
                return;
            }

            int total = allAuthorsData.Count;
            int filtered = filteredAuthorsData.Count;

            int valid = 0;
            int canonicalFiltered = 0;

            foreach (var author in filteredAuthorsData)
            {
                if (author.FilesCount > 0)
                {
                    valid++;
                }

                if (author.IsCanonical)
                {
                    canonicalFiltered++;
                }
            }

            var culture = CultureInfo.CurrentCulture;
            var canonicalFilteredPct = filtered > 0
                ? (double)canonicalFiltered / filtered
                : 0d;
            var canonicalChunk = canonicalFiltered > 0
                ? $" | {canonicalFiltered.ToString("N0", culture)} priorizados ({canonicalFilteredPct.ToString("P0", culture)})"
                : string.Empty;

            var duplicates = duplicateAuthorTotalCount;
            var duplicateChunk = duplicates > 0
                ? $" | 🧬 {duplicates.ToString("N0", culture)} duplicados potenciales"
                : string.Empty;

            countLabel.Text = total == filtered
                ? $"{total:N0} autores | {valid:N0} válidos{canonicalChunk}{duplicateChunk}"
                : $"{filtered:N0} de {total:N0} autores | {valid:N0} válidos{canonicalChunk}{duplicateChunk}";
        }

        private void UpdateAuthorData(string authorName, int filesCount, string status, Color? foreColor = null)
        {
            if (authorIndex.TryGetValue(authorName, out var author))
            {
                author.FilesCount = filesCount;
                author.Status = status;
                if (foreColor.HasValue)
                    author.ForeColor = foreColor.Value;

                // Usar batch updater si está disponible
                if (authorsUpdater != null)
                {
                    authorsUpdater.QueueUpdate(() =>
                    {
                        RefreshAuthorsListView();
                        UpdateAuthorCount();
                    });
                }
                else
                {
                    RefreshAuthorsListView();
                    UpdateAuthorCount();
                }

                // Vaciado tab fue consolidado en Automático - código eliminado
            }
        }
        
        // Helper method para logging seguro (no falla si el archivo está bloqueado)
        private void SafeLog(string message)
        {
            try
            {
                string connectionStatus = "N";
                try
                {
                    if (client != null && client.State.HasFlag(SoulseekClientStates.Connected))
                    {
                        connectionStatus = "S";
                    }
                }
                catch
                {
                    // Ignorar errores al verificar estado de conexión
                }
                
                var logMessage = $"[{DateTime.Now:HH:mm:ss}][{connectionStatus}] {message}";
                System.IO.File.AppendAllText(System.IO.Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "program_start.txt"), logMessage);
            }
            catch
            {
                // Ignorar errores de logging
            }
        }
        
        // OwnerDraw methods for dark theme ListView headers
        private void ListView_DrawColumnHeader(object sender, DrawListViewColumnHeaderEventArgs e)
        {
            using (var brush = new SolidBrush(Color.FromArgb(40, 40, 45)))
            {
                e.Graphics.FillRectangle(brush, e.Bounds);
            }
            
            using (var pen = new Pen(Color.FromArgb(60, 60, 65)))
            {
                e.Graphics.DrawLine(pen, e.Bounds.Left, e.Bounds.Bottom - 1, e.Bounds.Right, e.Bounds.Bottom - 1);
                e.Graphics.DrawLine(pen, e.Bounds.Right - 1, e.Bounds.Top, e.Bounds.Right - 1, e.Bounds.Bottom);
            }
            
            var textFormat = TextFormatFlags.Left | TextFormatFlags.VerticalCenter | TextFormatFlags.EndEllipsis;
            var textBounds = new Rectangle(e.Bounds.X + 5, e.Bounds.Y, e.Bounds.Width - 10, e.Bounds.Height);
            TextRenderer.DrawText(e.Graphics, e.Header.Text, AuthorListFonts.Header, textBounds, Color.FromArgb(200, 200, 205), textFormat);
        }
        
        private void ListView_DrawItem(object sender, DrawListViewItemEventArgs e)
        {
            Color backColor = e.Item.Selected ? Color.FromArgb(0, 122, 204) : Color.FromArgb(25, 25, 28);

            if (e.Item.Tag is AuthorData authorData)
            {
                if (authorData.IsPotentialDuplicate)
                {
                    backColor = e.Item.Selected ? Color.FromArgb(130, 80, 30) : Color.FromArgb(45, 30, 20);
                }
                else if (authorData.IsCanonical)
                {
                    backColor = e.Item.Selected ? Color.FromArgb(90, 50, 130) : Color.FromArgb(45, 30, 60);
                }
            }

            using (var brush = new SolidBrush(backColor))
            {
                e.Graphics.FillRectangle(brush, e.Bounds);
            }
            
            if (e.Item.Selected)
            {
                e.DrawFocusRectangle();
            }
        }
        
        private void ListView_DrawSubItem(object sender, DrawListViewSubItemEventArgs e)
        {
            // Dibujar fondo
            var backColor = e.Item.Selected ? Color.FromArgb(0, 122, 204) : Color.FromArgb(25, 25, 28);
            if (e.Item.Tag is AuthorData dupData && dupData.IsPotentialDuplicate)
            {
                backColor = e.Item.Selected ? Color.FromArgb(130, 80, 30) : Color.FromArgb(45, 30, 20);
            }
            using (var brush = new SolidBrush(backColor))
            {
                e.Graphics.FillRectangle(brush, e.Bounds);
            }
            
            // Determinar color de texto
            var textColor = e.Item.Selected ? Color.White : e.Item.ForeColor;
            if (textColor == Color.Empty || textColor == Color.Black)
            {
                textColor = Color.FromArgb(240, 240, 245); // Blanco suave por defecto
            }
            
            // Dibujar texto
            var textFormat = TextFormatFlags.Left | TextFormatFlags.VerticalCenter | TextFormatFlags.EndEllipsis;
            var textBounds = new Rectangle(e.Bounds.X + 4, e.Bounds.Y, e.Bounds.Width - 8, e.Bounds.Height);
            TextRenderer.DrawText(e.Graphics, e.SubItem.Text, AuthorListFonts.Item, e.Bounds, textColor, textFormat);
        }

        private void ShowDuplicateAuthorsDialog()
        {
            if (duplicateAuthorGroups == null || duplicateAuthorGroups.Count == 0)
            {
                MessageBox.Show("No hay duplicados potenciales detectados actualmente.", "Duplicados", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            using var dialog = new Form
            {
                Text = "Autores duplicados potenciales",
                StartPosition = FormStartPosition.CenterParent,
                BackColor = Color.FromArgb(30, 30, 35),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9f),
                Width = 680,
                Height = 520,
                MinimizeBox = false,
                MaximizeBox = false,
                ShowInTaskbar = false,
                FormBorderStyle = FormBorderStyle.FixedDialog
            };

            var lblSummary = new Label
            {
                Dock = DockStyle.Top,
                Height = 48,
                TextAlign = ContentAlignment.MiddleLeft,
                Text = $"Se detectaron {duplicateAuthorGroups.Count:N0} grupos | {duplicateAuthorTotalCount:N0} nombres",
                ForeColor = Color.Gainsboro,
                Padding = new Padding(12, 8, 12, 4)
            };
            dialog.Controls.Add(lblSummary);

            var lstGroups = new ListView
            {
                Dock = DockStyle.Fill,
                View = View.Details,
                FullRowSelect = true,
                HideSelection = false,
                BackColor = Color.FromArgb(25, 25, 30),
                ForeColor = Color.White,
                HeaderStyle = ColumnHeaderStyle.Nonclickable,
                MultiSelect = false
            };
            lstGroups.Columns.Add("Normalizado", 220);
            lstGroups.Columns.Add("Miembros", 420);
            foreach (var group in duplicateAuthorGroups.OrderByDescending(g => g.Members.Count))
            {
                var item = new ListViewItem(group.NormalizedKey)
                {
                    Tag = group
                };
                item.SubItems.Add(string.Join(", ", group.Members));
                lstGroups.Items.Add(item);
            }
            dialog.Controls.Add(lstGroups);

            var pnlButtons = new FlowLayoutPanel
            {
                Dock = DockStyle.Bottom,
                FlowDirection = FlowDirection.RightToLeft,
                Height = 54,
                Padding = new Padding(12),
                BackColor = Color.FromArgb(24, 24, 28)
            };
            dialog.Controls.Add(pnlButtons);

            var btnClose = new Button
            {
                Text = "Cerrar",
                DialogResult = DialogResult.Cancel,
                Width = 120,
                Height = 32,
                BackColor = Color.FromArgb(70, 70, 75),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat
            };
            btnClose.FlatAppearance.BorderSize = 0;

            var btnMerge = new Button
            {
                Text = "🧬 Fusionar selección",
                Width = 170,
                Height = 32,
                BackColor = Color.FromArgb(200, 120, 40),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat
            };
            btnMerge.FlatAppearance.BorderSize = 0;

            var btnExport = new Button
            {
                Text = "📄 Exportar lista",
                Width = 150,
                Height = 32,
                BackColor = Color.FromArgb(40, 120, 200),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat
            };
            btnExport.FlatAppearance.BorderSize = 0;

            pnlButtons.Controls.AddRange(new Control[] { btnClose, btnMerge, btnExport });

            btnExport.Click += (_, _) => ExportDuplicateGroups();
            btnMerge.Click += async (_, _) =>
            {
                if (lstGroups.SelectedItems.Count == 0)
                {
                    MessageBox.Show(dialog, "Selecciona un grupo para fusionar.", "Duplicados", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    return;
                }

                var group = (AuthorNormalizer.AuthorDuplicateGroup)lstGroups.SelectedItems[0].Tag;
                await MergeDuplicateGroupAsync(group).ConfigureAwait(false);
                dialog.DialogResult = DialogResult.OK;
                dialog.Close();
            };

            dialog.AcceptButton = btnMerge;
            dialog.CancelButton = btnClose;

            dialog.ShowDialog(this);
        }

        private void ExportDuplicateGroups()
        {
            if (duplicateAuthorGroups == null || duplicateAuthorGroups.Count == 0)
            {
                MessageBox.Show("No hay duplicados para exportar.", "Duplicados", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            using var sfd = new SaveFileDialog
            {
                Filter = "CSV|*.csv",
                Title = "Exportar duplicados de autores",
                FileName = "author_duplicates.csv"
            };

            if (sfd.ShowDialog(this) != DialogResult.OK)
            {
                return;
            }

            try
            {
                var lines = new List<string> { "Normalized,Members" };
                foreach (var group in duplicateAuthorGroups)
                {
                    var membersCsv = string.Join(";", group.Members.Select(m => m.Replace("\"", "''")));
                    var normalized = group.NormalizedKey.Replace("\"", "''");
                    lines.Add($"\"{normalized}\",\"{membersCsv}\"");
                }

                File.WriteAllLines(sfd.FileName, lines);
                MessageBox.Show("Duplicados exportados correctamente.", "Duplicados", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error exportando duplicados:\n{ex.Message}", "Duplicados", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private void RecalculateDuplicateGroups(List<AuthorData> authorData)
        {
            var duplicates = new List<AuthorNormalizer.AuthorDuplicateGroup>();
            var duplicateMembers = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            var seenGroupKeys = new HashSet<string>(StringComparer.Ordinal);

            // 1. Agrupar por NormalizedName almacenado en BD para detectar duplicados exactos sin FFI
            var normalizedGroups = authorData
                .Where(a => !string.IsNullOrWhiteSpace(a.NormalizedName))
                .GroupBy(a => a.NormalizedName!, StringComparer.OrdinalIgnoreCase);

            foreach (var group in normalizedGroups)
            {
                var members = group
                    .Select(a => a.Name)
                    .Where(name => !string.IsNullOrWhiteSpace(name))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .OrderBy(name => name, StringComparer.OrdinalIgnoreCase)
                    .ToArray();

                if (members.Length < 2)
                {
                    continue;
                }

                var groupKey = string.Join("|", members);
                if (!seenGroupKeys.Add(groupKey))
                {
                    continue;
                }

                duplicates.Add(new AuthorNormalizer.AuthorDuplicateGroup
                {
                    NormalizedKey = group.Key,
                    Members = members
                });

                foreach (var member in members)
                {
                    duplicateMembers.Add(member);
                }
            }

            // 2. Enviar sólo candidatos restantes al motor Rust para similitud difusa
            var rustCandidates = authorData
                .Where(a => !duplicateMembers.Contains(a.Name))
                .Select(a => a.Name)
                .Where(name => !string.IsNullOrWhiteSpace(name))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (rustCandidates.Count > 1)
            {
                var fuzzyGroups = AuthorNormalizer.FindDuplicateGroups(rustCandidates);

                foreach (var group in fuzzyGroups)
                {
                    var members = group.Members
                        .Where(name => !string.IsNullOrWhiteSpace(name))
                        .Distinct(StringComparer.OrdinalIgnoreCase)
                        .OrderBy(name => name, StringComparer.OrdinalIgnoreCase)
                        .ToArray();

                    if (members.Length < 2)
                    {
                        continue;
                    }

                    var groupKey = string.Join("|", members);
                    if (!seenGroupKeys.Add(groupKey))
                    {
                        continue;
                    }

                    duplicates.Add(new AuthorNormalizer.AuthorDuplicateGroup
                    {
                        NormalizedKey = string.IsNullOrWhiteSpace(group.NormalizedKey)
                            ? AuthorNormalizer.Normalize(members[0])
                            : group.NormalizedKey,
                        Members = members
                    });

                    foreach (var member in members)
                    {
                        duplicateMembers.Add(member);
                    }
                }
            }

            duplicateAuthorGroups = duplicates
                .OrderByDescending(g => g.Members.Count)
                .ThenBy(g => g.NormalizedKey, StringComparer.OrdinalIgnoreCase)
                .ToList();

            duplicateAuthorTotalCount = duplicateAuthorGroups.Sum(group => group.Members.Count);

            foreach (var author in authorData)
            {
                author.IsPotentialDuplicate = duplicateMembers.Contains(author.Name);
            }

            SafeInvoke(UpdateAuthorCount);
        }

        private async Task MergeDuplicateGroupAsync(AuthorNormalizer.AuthorDuplicateGroup group)
        {
            if (group == null || group.Members.Count < 2)
            {
                return;
            }

            var canonicalName = group.Members
                .OrderByDescending(name => IsCanonicalAuthorName(name))
                .ThenBy(name => name.Length)
                .ThenBy(name => name, StringComparer.OrdinalIgnoreCase)
                .First();

            var namesToMerge = group.Members
                .Where(name => !string.Equals(name, canonicalName, StringComparison.OrdinalIgnoreCase))
                .ToList();

            if (namesToMerge.Count == 0)
            {
                return;
            }

            var confirmationMessage = "Se fusionarán los siguientes autores en '" + canonicalName + "':\n\n" + string.Join("\n", namesToMerge);
            var confirmResult = MessageBox.Show(confirmationMessage, "Confirmar fusión", MessageBoxButtons.YesNo, MessageBoxIcon.Question);
            if (confirmResult != DialogResult.Yes)
            {
                return;
            }

            try
            {
                foreach (var name in namesToMerge)
                {
                    if (authorIndex.TryGetValue(name, out var authorData))
                    {
                        authorData.Name = canonicalName;
                        authorData.IsPotentialDuplicate = false;
                        authorData.IsCanonical = IsCanonicalAuthorName(canonicalName);
                        authorData.NormalizedName = AuthorNormalizer.Normalize(canonicalName);
                        authorIndex.Remove(name);
                    }
                }

                await slskDatabase.BulkInsertAuthorsAsync(
                    new[] { canonicalName },
                    "Fusion",
                    IsCanonicalAuthorName,
                    author => author.StartsWith(canonicalName, StringComparison.OrdinalIgnoreCase) ? 100 : 0).ConfigureAwait(false);

                await DeleteAuthorsFromDatabaseAsync(namesToMerge).ConfigureAwait(false);

                await LoadAuthorsFromDatabaseAsync().ConfigureAwait(false);
                MessageBox.Show("Fusión completada.", "Duplicados", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error fusionando autores:\n{ex.Message}", "Duplicados", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
        // ===== ORDENACIÓN DE COLUMNAS =====
        
        private void LvResults_ColumnClick(object sender, ColumnClickEventArgs e)
        {
            if (e.Column == lvResultsSortColumn)
            {
                // Cambiar dirección de ordenación
                lvResultsSortOrder = lvResultsSortOrder == SortOrder.Ascending ? SortOrder.Descending : SortOrder.Ascending;
            }
            else
            {
                // Nueva columna, ordenar ascendente
                lvResultsSortColumn = e.Column;
                lvResultsSortOrder = SortOrder.Ascending;
            }

            if (lvResults.VirtualMode)
            {
                SortAllResultsInPlace();
                virtualResultsCache.Clear();
                lvResults.VirtualListSize = allResults?.Count ?? 0;
                lvResults.Invalidate();
            }
            else
            {
                lvResults.ListViewItemSorter = new ListViewItemComparer(e.Column, lvResultsSortOrder);
                lvResults.Sort();
            }
            
            // Actualizar encabezados con indicadores visuales
            UpdateColumnHeaders(lvResults, lvResultsSortColumn, lvResultsSortOrder);
        }

        private void SortAllResultsInPlace()
        {
            if (allResults == null || allResults.Count <= 1)
            {
                return;
            }

            int column = lvResultsSortColumn;
            var descending = lvResultsSortOrder == SortOrder.Descending;

            int CompareString(string a, string b)
            {
                return string.Compare(a ?? string.Empty, b ?? string.Empty, StringComparison.OrdinalIgnoreCase);
            }

            int CompareLong(long a, long b)
            {
                return a.CompareTo(b);
            }

            int CompareInt(int a, int b)
            {
                return a.CompareTo(b);
            }

            int Compare(SearchResultItem x, SearchResultItem y)
            {
                if (ReferenceEquals(x, y)) return 0;
                if (x == null) return -1;
                if (y == null) return 1;

                int result;
                switch (column)
                {
                    case 0:
                        result = CompareString(x.Filename, y.Filename);
                        break;
                    case 1:
                        result = CompareString(x.Extension, y.Extension);
                        break;
                    case 2:
                        result = CompareString(x.Username, y.Username);
                        break;
                    case 3:
                        result = CompareLong(x.Size, y.Size);
                        break;
                    case 4:
                        result = CompareInt(x.UploadSpeed, y.UploadSpeed);
                        break;
                    case 5:
                        result = CompareString(x.FolderPath, y.FolderPath);
                        break;
                    default:
                        result = CompareString(x.Filename, y.Filename);
                        break;
                }

                return descending ? -result : result;
            }

            allResults.Sort(Compare);
        }
        
