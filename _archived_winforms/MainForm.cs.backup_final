            }
        }

        private static string ExtractPdfStreamsText(byte[] buffer, int count, int maxChars)
        {
            try
            {
                var asciiText = Encoding.ASCII.GetString(buffer, 0, count);
                var sb = new StringBuilder(Math.Min(maxChars, 8192));

                var flateRegex = new Regex(@"(?s)/Filter\s*/FlateDecode[^\S\r\n]*.*?stream\r?\n(.*?)endstream", RegexOptions.Compiled);

                foreach (Match match in flateRegex.Matches(asciiText))
                {
                    if (sb.Length >= maxChars)
                        break;

                    int streamStart = match.Groups[1].Index;
                    int streamLength = match.Groups[1].Length;

                    if (streamStart < 0 || streamLength <= 0 || streamStart + streamLength > count)
                        continue;

                    // Ajustar posibles retornos de carro iniciales
                    while (streamLength > 0 && (buffer[streamStart] == 0x0D || buffer[streamStart] == 0x0A))
                    {
                        streamStart++;
                        streamLength--;
                    }

                    if (streamLength <= 2)
                        continue;

                    var streamData = new byte[streamLength];
                    Buffer.BlockCopy(buffer, streamStart, streamData, 0, streamLength);

                    string decompressed = TryDecompressPdfStream(streamData);
                    if (string.IsNullOrEmpty(decompressed))
                        continue;

                    decompressed = StripMarkup(decompressed);

                    if (decompressed.Length > maxChars - sb.Length)
                    {
                        sb.Append(decompressed.AsSpan(0, maxChars - sb.Length));
                    }
                    else
                    {
                        sb.Append(decompressed);
                    }
                }

                if (sb.Length < maxChars)
                {
                    // Como fallback adicional, extraer texto literal entre paréntesis
                    var literalRegex = new Regex(@"\(([^\)]{1,256})\)", RegexOptions.Compiled);
                    foreach (Match match in literalRegex.Matches(asciiText))
                    {
                        if (sb.Length >= maxChars)
                            break;
                        var literal = match.Groups[1].Value.Replace("\\n", " ").Replace("\\r", " ");
                        if (literal.Length > maxChars - sb.Length)
                        {
                            sb.Append(literal.AsSpan(0, maxChars - sb.Length));
                        }
                        else
                        {
                            sb.Append(literal);
                        }
                    }
                }

                return sb.ToString();
            }
            catch
            {
                return string.Empty;
            }
        }

        private static string TryDecompressPdfStream(byte[] data)
        {
            // Algunos streams incluyen cabeceras zlib (2 bytes). Probamos con y sin ellas.
            foreach (var skip in new[] { 0, 2 })
            {
                if (data.Length <= skip + 2)
                    continue;

                try
                {
                    using var ms = new MemoryStream(data, skip, data.Length - skip);
                    using var deflate = new DeflateStream(ms, CompressionMode.Decompress);
                    using var reader = new StreamReader(deflate, Encoding.UTF8, true, 8192);
                    var text = reader.ReadToEnd();
                    if (!string.IsNullOrWhiteSpace(text))
                        return text;
                }
                catch
                {
                    // Ignoramos este intento y probamos el siguiente.
                }
            }

            return string.Empty;
        }

        private static string StripMarkup(string text)
        {
            if (string.IsNullOrEmpty(text))
                return text;

            var sb = new StringBuilder(text.Length);
            bool insideTag = false;

            foreach (var ch in text)
            {
                if (ch == '<')
                {
                    insideTag = true;
                    continue;
                }

                if (ch == '>')
                {
                    insideTag = false;
                    continue;
                }

                if (!insideTag)
                {
                    sb.Append(ch);
                }
            }

            return sb.ToString();
        }
        
