        private string GetIncompleteDownloadPath(string targetPath, AutoSearchFileResult file)
        {
            try
            {
                var incompleteDir = downloadManagerConfig?.IncompleteDownloadsDirectory;
                if (string.IsNullOrWhiteSpace(incompleteDir))
                {
                    incompleteDir = Path.Combine(downloadDir ?? string.Empty, "incomplete");
                }

                if (string.IsNullOrWhiteSpace(incompleteDir))
                {
                    return targetPath;
                }

                Directory.CreateDirectory(incompleteDir);

                var originalName = Path.GetFileName(string.IsNullOrWhiteSpace(file?.FileName) ? targetPath : file.FileName);
                if (string.IsNullOrWhiteSpace(originalName))
                {
                    originalName = Path.GetFileName(targetPath);
                }

                var invalid = Path.GetInvalidFileNameChars();
                var safeName = new string(originalName.Select(ch => invalid.Contains(ch) ? '_' : ch).ToArray());
                if (string.IsNullOrWhiteSpace(safeName))
                {
                    safeName = "download.tmp";
                }

                var prefix = Guid.NewGuid().ToString("N");
                return Path.Combine(incompleteDir, $"{prefix}_{safeName}");
            }
            catch
            {
                return targetPath;
            }
        }

        private sealed class ZeroByteDownloadedFileException : IOException
        {
            public ZeroByteDownloadedFileException(string message) : base(message)
            {
            }
        }

        private string MoveToMiscFolder(string filePath)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(filePath) || !System.IO.File.Exists(filePath))
                {
                    return filePath;
                }

                var baseDir = txtDownloadDir?.Text;
                if (string.IsNullOrWhiteSpace(baseDir))
                {
                    baseDir = downloadDir;
                }

                var targetDir = Path.Combine(baseDir ?? string.Empty, "Varios");
                Directory.CreateDirectory(targetDir);

                var fileName = Path.GetFileName(filePath);
                var targetPath = Path.Combine(targetDir, fileName);

                if (System.IO.File.Exists(targetPath))
                {
                    var nameWithoutExt = Path.GetFileNameWithoutExtension(fileName);
                    var ext = Path.GetExtension(fileName);
                    var counter = 1;
                    do
                    {
                        targetPath = Path.Combine(targetDir, $"{nameWithoutExt}_{counter}{ext}");
                        counter++;
                    } while (System.IO.File.Exists(targetPath));
                }

                System.IO.File.Move(filePath, targetPath);
                return targetPath;
            }
            catch
            {
                return filePath;
            }
        }

        private void FinalizeNonDocumentDownload(DownloadTask task)
        {
            if (task?.File == null)
            {
                return;
            }

            var originalHistoryFileName = task.File.FileName;
            var finalHistoryFileName = Path.GetFileName(task.LocalPath) ?? originalHistoryFileName;
            var historyRootDir = txtDownloadDir?.Text ?? downloadDir;

            ShowNotification(
                "Descarga completada",
                $"✅ {task.File.FileName}\n\nTamaño: {task.File.SizeReadable} | Velocidad: {task.SpeedMBps:F2} MB/s",
                ToolTipIcon.Info);

            lock (downloadHistoryLock)
            {
                var relativePath = GetRelativePathSafe(task.LocalPath, historyRootDir);
                downloadHistory.Add(new DownloadHistoryRecord
                {
                    FileName = finalHistoryFileName,
                    Author = task.File.Author,
                    Username = task.File.Username,
                    SizeBytes = task.File.SizeBytes,
                    DownloadedAt = DateTime.Now,
                    CompletedAt = DateTime.Now,
                    Status = "Completed",
                    SpeedMBps = task.SpeedMBps,
                    Hash = null,
                    RelativePath = relativePath,
                    IsSpanish = null,
                    IsDuplicate = task.IsDuplicate,
                    DuplicateOf = task.DuplicateOf
                });

                if (!string.Equals(originalHistoryFileName, finalHistoryFileName, StringComparison.OrdinalIgnoreCase))
                {
                    downloadHistoryCache.Remove(originalHistoryFileName);
                }

                downloadHistoryCache.Add(finalHistoryFileName);
            }

            statistics.TotalFilesDownloaded++;
            statistics.TotalBytesDownloaded += task.File.SizeBytes;
            RecordDownloadOutcome(true);
            SaveStatistics();
            MarkDownloadStatsDirty();
            
            // Verificar integridad del archivo descargado
            if (integrityChecker != null && !string.IsNullOrWhiteSpace(task.LocalPath) && File.Exists(task.LocalPath))
            {
                _ = Task.Run(async () =>
                {
                    try
                    {
                        var hash = await integrityChecker.ComputeHashAsync(task.LocalPath, HashAlgorithmType.SHA256);
                        if (!string.IsNullOrWhiteSpace(hash) && hash.Length >= 16)
                        {
                            Log($" Integridad verificada: {Path.GetFileName(task.LocalPath)} - SHA256: {hash[..16]}...");
                        }
                        else
                        {
                            Log($" Integridad verificada: {Path.GetFileName(task.LocalPath)}");
                        }
                    }
                    catch (Exception ex)
                    {
                        Log($" Error verificando integridad: {ex.Message}");
                    }
                });
            }
            
            UpdateProviderStats(task.File.Username, true, task.SpeedMBps, task.File.SizeBytes);
            SaveProviderStatsToDatabase();

            EnqueueDownloadUiUpdate(task, " Completado ");
        }

        private SlskDown.Core.QueuePositionTracker? queuePositionTracker;

        private void InitializeQueuePositionTracker()
        {
            try
            {
                if (queuePositionTracker != null)
                {
                    return;
                }

                queuePositionTracker = new SlskDown.Core.QueuePositionTracker
                {
                    OnLog = msg =>
                    {
                        try
                        {
                            SafeLog(msg + "\n");
                        }
                        catch
                        {
                        }
                    },
                    OnPositionUpdated = info =>
                    {
                        try
                        {
                            UpdateQueuePositionInUI(info);
                        }
                        catch
                        {
                        }
                    }
                };

                queuePositionTracker.Start();
            }
            catch
            {
            }
        }

        private void UpdateQueuePositionInUI(SlskDown.Core.QueuePositionTracker.QueueInfo info)
        {
            if (info == null)
            {
                return;
            }

            List<DownloadTask> tasks;
            lock (downloadQueueLock)
            {
                tasks = downloadQueue
                    .Where(t => t?.File != null)
                    .Where(t => t.Status == DownloadStatus.Queued)
                    .Where(t => string.Equals(t.File.Username, info.Username, StringComparison.OrdinalIgnoreCase))
                    .Where(t => string.Equals(t.File.FileName, info.Filename, StringComparison.OrdinalIgnoreCase))
                    .ToList();
            }

            foreach (var task in tasks)
            {
                try
                {
                    task.QueuePosition = info.Position;
                    var status = $"{GetStatusText(task.Status)} - {info.DisplayText}";
                    task.UiStatusText = status;
                    EnqueueDownloadUiUpdate(task, status);
                }
                catch
                {
                }
            }
        }

        private async Task RequestQueuePositionAsync(DownloadTask task)
        {
            if (task?.File == null)
            {
                return;
            }

            var username = task.File.Username;
            var filename = task.File.FileName;
            if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(filename))
            {
                return;
            }

            try
            {
                queuePositionTracker?.TrackFile(username, filename);
            }
            catch
            {
            }

            try
            {
                if (queuePositionTracker != null && !queuePositionTracker.ShouldRequestPosition(username, filename))
                {
                    return;
                }

                using var timeoutCts = new CancellationTokenSource(TimeSpan.FromSeconds(3));
                var userInfo = await GetUserInfoCachedAsync(username, ttl: TimeSpan.FromSeconds(30), requestTimeout: TimeSpan.FromSeconds(3), cancellationToken: timeoutCts.Token);
                if (userInfo == null)
                {
                    return;
                }

                var estimatedPos = userInfo.HasFreeUploadSlot ? 0 : Math.Max(0, userInfo.QueueLength);

                try
                {
                    queuePositionTracker?.UpdatePosition(username, filename, estimatedPos);
                }
                catch
                {
                }

                try
                {
                    task.QueuePosition = estimatedPos;
                    var display = queuePositionTracker?.GetPosition(username, filename)?.DisplayText;
                    if (!string.IsNullOrWhiteSpace(display))
                    {
                        var status = $"{GetStatusText(task.Status)} - {display}";
                        task.UiStatusText = status;
                        EnqueueDownloadUiUpdate(task, status);
                    }
                }
                catch
                {
                }
            }
            catch
            {
            }
        }

        private void UntrackQueuePosition(DownloadTask? task)
        {
            try
            {
                if (task?.File == null)
                {
                    return;
                }

                queuePositionTracker?.UntrackFile(task.File.Username, task.File.FileName);
            }
            catch
            {
            }
        }

        private sealed class DownloadEvent
        {
            public required DownloadTask Task { get; init; }
        }

        private void EnqueueDownloadUiUpdate(DownloadTask task, string status)
        {
            try
            {
                if (task == null)
                {
                    return;
                }

                pendingDownloadUiStatuses[task] = status ?? string.Empty;
                downloadUiUpdateChannel.Writer.TryWrite(new DownloadEvent { Task = task });
                MarkDownloadStatsDirty();
            }
            catch
            {
            }
        }

        private void StartDownloadUiChannelConsumer()
        {
            if (downloadUiChannelStarted)
            {
                return;
            }

            downloadUiChannelStarted = true;
            downloadUiChannelCts = new CancellationTokenSource();
            var token = downloadUiChannelCts.Token;

            _ = Task.Run(async () =>
            {
                var reader = downloadUiUpdateChannel.Reader;
                try
                {
                    while (await reader.WaitToReadAsync(token).ConfigureAwait(false))
                    {
                        var unique = new HashSet<DownloadTask>();
                        while (reader.TryRead(out var ev))
                        {
                            var task = ev?.Task;
                            if (task != null)
                            {
                                unique.Add(task);
                            }
                        }

                        foreach (var task in unique)
                        {
                            if (pendingDownloadUiStatuses.TryGetValue(task, out var status))
                            {
                                UpdateDownloadUI(task, status);
                            }
                        }

                        await Task.Delay(25, token).ConfigureAwait(false);
                    }
                }
                catch (OperationCanceledException)
                {
                }
                catch
                {
                }
            }, token);
        }

        private void ScanAndOfferSanitizePlaintextCredentials()
        {
            if (string.IsNullOrWhiteSpace(dataDir) || !System.IO.Directory.Exists(dataDir))
            {
                return;
            }

            var candidates = new List<string>();
            var configPath = Path.Combine(dataDir, "config.json");
            if (System.IO.File.Exists(configPath))
            {
                candidates.Add(configPath);
            }

            var backupDir = Path.Combine(dataDir, "backups");
            if (System.IO.Directory.Exists(backupDir))
            {
                candidates.AddRange(System.IO.Directory.GetFiles(backupDir, "config_*.json"));
            }

            var flagged = new List<string>();
            foreach (var path in candidates)
            {
                if (FileHasPlaintextCredentials(path))
                {
                    flagged.Add(path);
                }
            }

            if (flagged.Count == 0)
            {
                return;
            }

            var preview = string.Join("\n", flagged
                .Take(10)
                .Select(p => "- " + Path.GetFileName(p)));
            var more = flagged.Count > 10 ? $"\n... y {flagged.Count - 10} más" : string.Empty;
            var message =
                "Se detectaron credenciales en texto plano en archivos de configuración/backups.\n\n" +
                "¿Quieres limpiarlas ahora? (Se creará un .bak antes de modificar)\n\n" +
                preview +
                more;

            var result = MessageBox.Show(
                message,
                "Seguridad",
                MessageBoxButtons.YesNo,
                MessageBoxIcon.Warning);

            if (result != DialogResult.Yes)
            {
                return;
            }

            var cleaned = 0;
            foreach (var path in flagged)
            {
                if (TrySanitizeConfigJsonFile(path))
                {
                    cleaned++;
                }
            }

            AutoLog($"🧽 Limpieza de credenciales en claro: {cleaned}/{flagged.Count} archivos");
        }

        private static bool FileHasPlaintextCredentials(string path)
        {
            try
            {
                var text = System.IO.File.ReadAllText(path);
                if (string.IsNullOrWhiteSpace(text))
                {
                    return false;
                }

                if (!text.Contains("\"password\"", StringComparison.OrdinalIgnoreCase) &&
                    !text.Contains("\"username\"", StringComparison.OrdinalIgnoreCase))
                {
                    return false;
                }

                var data = JsonSerializer.Deserialize<Dictionary<string, object>>(text);
                if (data == null)
                {
                    return false;
                }

                var user = TryGetString(data, "username");
                var pass = TryGetString(data, "password");
                return !string.IsNullOrWhiteSpace(user) || !string.IsNullOrWhiteSpace(pass);
            }
            catch
            {
                return false;
            }
        }

        private string MoveCorruptDownloadedFile(string filePath)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(filePath) || !File.Exists(filePath))
                {
                    return filePath;
                }

                return quarantineService?.MoveToCorrupt(filePath, downloadDir) ?? filePath;
            }
            catch
            {
                return filePath;
            }
        }

        private static string? TryGetString(Dictionary<string, object> data, string key)
        {
            if (!data.TryGetValue(key, out var value) || value == null)
            {
                return null;
            }

            if (value is string str)
            {
                return str;
            }

            if (value is JsonElement element)
            {
                if (element.ValueKind == JsonValueKind.String)
                {
                    return element.GetString();
                }
            }

            return null;
        }

        private static bool TrySanitizeConfigJsonFile(string path)
        {
            try
            {
                var text = System.IO.File.ReadAllText(path);
                var data = JsonSerializer.Deserialize<Dictionary<string, object>>(text);
                if (data == null)
                {
                    return false;
                }

                var had = false;
                var user = TryGetString(data, "username");
                var pass = TryGetString(data, "password");
                if (!string.IsNullOrWhiteSpace(user))
                {
                    data["username"] = "";
                    had = true;
                }
                if (!string.IsNullOrWhiteSpace(pass))
                {
                    data["password"] = "";
                    had = true;
                }

                if (!had)
                {
                    return false;
                }

                var bakPath = path + ".bak";
                System.IO.File.Copy(path, bakPath, true);

                var json = JsonSerializer.Serialize(data, new JsonSerializerOptions
                {
                    WriteIndented = true
                });
                System.IO.File.WriteAllText(path, json, Encoding.UTF8);
                return true;
            }
            catch
            {
                return false;
            }
        }

