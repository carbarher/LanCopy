                FlatStyle = FlatStyle.Flat,
                Padding = new Padding(8, 4, 8, 4),
                Margin = new Padding(3, 3, 3, 3),
                Font = new Font("Segoe UI", 9)
            };
            btn.FlatAppearance.BorderSize = 0;
            return btn;
        }

        private void OpenDownloadsWindow()
        {
            int savedWidth = 1400;
            int savedHeight = 700;
            int savedX = -1;
            int savedY = -1;
            int savedState = (int)FormWindowState.Normal;

            try
            {
                if (configManager != null)
                {
                    savedWidth = configManager.GetValue("autoDownloadsWindowWidth", savedWidth);
                    savedHeight = configManager.GetValue("autoDownloadsWindowHeight", savedHeight);
                    savedX = configManager.GetValue("autoDownloadsWindowX", savedX);
                    savedY = configManager.GetValue("autoDownloadsWindowY", savedY);
                    savedState = configManager.GetValue("autoDownloadsWindowState", savedState);
                }
            }
            catch
            {
            }

            var downloadsForm = new Form
            {
                Text = "📥 Descargas Automáticas - SlskDown",
                Size = new Size(savedWidth, savedHeight),
                StartPosition = (savedX >= 0 && savedY >= 0) ? FormStartPosition.Manual : FormStartPosition.CenterParent,
                BackColor = Color.FromArgb(24, 24, 24),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                MinimumSize = new Size(1000, 600)
            };

            if (savedX >= 0 && savedY >= 0)
            {
                downloadsForm.Location = new Point(savedX, savedY);
            }

            try
            {
                downloadsForm.WindowState = (FormWindowState)savedState;
            }
            catch
            {
                downloadsForm.WindowState = FormWindowState.Normal;
            }

            var persistTimer = new System.Windows.Forms.Timer { Interval = 500 };
            persistTimer.Tick += (s, e) =>
            {
                persistTimer.Stop();
                try
                {
                    if (configManager == null)
                    {
                        return;
                    }

                    var state = downloadsForm.WindowState;
                    var bounds = (state == FormWindowState.Normal) ? downloadsForm.Bounds : downloadsForm.RestoreBounds;

                    configManager.SetValue("autoDownloadsWindowWidth", bounds.Width);
                    configManager.SetValue("autoDownloadsWindowHeight", bounds.Height);
                    configManager.SetValue("autoDownloadsWindowX", bounds.X);
                    configManager.SetValue("autoDownloadsWindowY", bounds.Y);
                    configManager.SetValue("autoDownloadsWindowState", (int)state);
                    configManager.Save();
                }
                catch
                {
                }
            };

            void SchedulePersist()
            {
                try
                {
                    persistTimer.Stop();
                    persistTimer.Start();
                }
                catch
                {
                }
            }

            downloadsForm.ResizeEnd += (s, e) => SchedulePersist();
            downloadsForm.LocationChanged += (s, e) =>
            {
                if (downloadsForm.WindowState == FormWindowState.Normal)
                {
                    SchedulePersist();
                }
            };

            var mainLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 2,
                RowCount = 4,
                Padding = new Padding(10)
