                if (textLower.Contains(" falso ")) spanishScore += 2;
                if (textLower.Contains(" completo ")) spanishScore += 2;
                if (textLower.Contains(" entero ")) spanishScore += 2;
                if (textLower.Contains(" medio ")) spanishScore += 1;
                if (textLower.Contains(" doble ")) spanishScore += 2;
                if (textLower.Contains(" triple ")) spanishScore += 2;
                
                // Sustantivos españoles comunes (NUEVO)
                if (textLower.Contains(" vida ")) spanishScore += 2;
                if (textLower.Contains(" muerte ")) spanishScore += 2;
                if (textLower.Contains(" tiempo ")) spanishScore += 2;
                if (textLower.Contains(" día ") || textLower.Contains(" dia ")) spanishScore += 2;
                if (textLower.Contains(" noche ")) spanishScore += 2;
                if (textLower.Contains(" año ") || textLower.Contains(" ano ")) spanishScore += 2;
                if (textLower.Contains(" mes ")) spanishScore += 1;
                if (textLower.Contains(" semana ")) spanishScore += 2;
                if (textLower.Contains(" hora ")) spanishScore += 2;
                if (textLower.Contains(" momento ")) spanishScore += 2;
                if (textLower.Contains(" vez ")) spanishScore += 2;
                if (textLower.Contains(" veces ")) spanishScore += 2;
                if (textLower.Contains(" mundo ")) spanishScore += 2;
                if (textLower.Contains(" tierra ")) spanishScore += 2;
                if (textLower.Contains(" cielo ")) spanishScore += 2;
                if (textLower.Contains(" mar ")) spanishScore += 1;
                if (textLower.Contains(" agua ")) spanishScore += 2;
                if (textLower.Contains(" fuego ")) spanishScore += 2;
                if (textLower.Contains(" aire ")) spanishScore += 2;
                if (textLower.Contains(" luz ")) spanishScore += 2;
                if (textLower.Contains(" sombra ")) spanishScore += 2;
                if (textLower.Contains(" casa ")) spanishScore += 2;
                if (textLower.Contains(" puerta ")) spanishScore += 2;
                if (textLower.Contains(" ventana ")) spanishScore += 2;
                if (textLower.Contains(" camino ")) spanishScore += 2;
                if (textLower.Contains(" calle ")) spanishScore += 2;
                if (textLower.Contains(" ciudad ")) spanishScore += 2;
                if (textLower.Contains(" pueblo ")) spanishScore += 2;
                if (textLower.Contains(" país ") || textLower.Contains(" pais ")) spanishScore += 2;
                if (textLower.Contains(" reino ")) spanishScore += 2;
                if (textLower.Contains(" imperio ")) spanishScore += 2;
                if (textLower.Contains(" guerra ")) spanishScore += 2;
                if (textLower.Contains(" paz ")) spanishScore += 2;
