                html.AppendLine("        <table id='resultsTable'>");
                html.AppendLine("            <thead>");
                html.AppendLine("                <tr>");
                html.AppendLine("                    <th>Estado</th>");
                html.AppendLine("                    <th>Autor</th>");
                html.AppendLine("                    <th>Archivo</th>");
                html.AppendLine("                    <th>Tamaño</th>");
                html.AppendLine("                    <th>Usuario</th>");
                html.AppendLine("                    <th>Español</th>");
                html.AppendLine("                    <th>Doc</th>");
                html.AppendLine("                    <th>Fecha</th>");
                html.AppendLine("                </tr>");
                html.AppendLine("            </thead>");
                html.AppendLine("            <tbody>");
                
                foreach (ListViewItem item in listView.Items)
                {
                    var file = (AutoSearchFileResult)item.Tag;
                    var statusClass = item.SubItems[0].Text.Contains("✓") ? "status-downloaded" : "status-pending";
                    
                    html.AppendLine("                <tr>");
                    html.AppendLine($"                    <td class='{statusClass}'>{System.Web.HttpUtility.HtmlEncode(item.SubItems[0].Text)}</td>");
                    html.AppendLine($"                    <td>{System.Web.HttpUtility.HtmlEncode(file.Author)}</td>");
                    html.AppendLine($"                    <td>{System.Web.HttpUtility.HtmlEncode(file.FileName)}</td>");
                    html.AppendLine($"                    <td>{System.Web.HttpUtility.HtmlEncode(file.SizeReadable)}</td>");
                    html.AppendLine($"                    <td>{System.Web.HttpUtility.HtmlEncode(file.Username)}</td>");
                    html.AppendLine($"                    <td><span class='badge badge-{(file.IsSpanish ? "yes" : "no")}'>{(file.IsSpanish ? "Sí" : "No")}</span></td>");
                    html.AppendLine($"                    <td><span class='badge badge-{(file.IsDocument ? "yes" : "no")}'>{(file.IsDocument ? "Sí" : "No")}</span></td>");
                    html.AppendLine($"                    <td>{file.Timestamp:yyyy-MM-dd HH:mm}</td>");
                    html.AppendLine("                </tr>");
                }
                
                html.AppendLine("            </tbody>");
                html.AppendLine("        </table>");
                html.AppendLine($"        <div class='footer'>Generado el {DateTime.Now:dd/MM/yyyy HH:mm:ss} por SlskDown</div>");
                html.AppendLine("    </div>");
                
                // JavaScript para búsqueda
                html.AppendLine("    <script>");
                html.AppendLine("        function filterTable() {");
                html.AppendLine("            var input = document.getElementById('searchInput');");
                html.AppendLine("            var filter = input.value.toUpperCase();");
                html.AppendLine("            var table = document.getElementById('resultsTable');");
                html.AppendLine("            var tr = table.getElementsByTagName('tr');");
                html.AppendLine("            for (var i = 1; i < tr.length; i++) {");
                html.AppendLine("                var td = tr[i].getElementsByTagName('td');");
                html.AppendLine("                var found = false;");
                html.AppendLine("                for (var j = 0; j < td.length; j++) {");
                html.AppendLine("                    if (td[j].innerHTML.toUpperCase().indexOf(filter) > -1) {");
                html.AppendLine("                        found = true;");
                html.AppendLine("                        break;");
                html.AppendLine("                    }");
                html.AppendLine("                }");
                html.AppendLine("                tr[i].style.display = found ? '' : 'none';");
                html.AppendLine("            }");
                html.AppendLine("        }");
                html.AppendLine("    </script>");
                html.AppendLine("</body>");
                html.AppendLine("</html>");
                
                System.IO.File.WriteAllText(htmlPath, html.ToString(), Encoding.UTF8);
                
                // Abrir en navegador
                Process.Start(new ProcessStartInfo { FileName = htmlPath, UseShellExecute = true });
                
                AutoLog($"💾 Exportado a HTML: {htmlPath}");
                MessageBox.Show($"Exportado exitosamente a:\n{htmlPath}\n\nEl archivo se ha abierto en tu navegador.", "Exportar HTML", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error exportando a HTML: {ex.Message}");
                MessageBox.Show($"Error al exportar: {ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private async Task PurgeAuthorsWithoutResults()
        {
            if (IsTxtSearchRunning)
            {
                AutoLog("⚠️ Purga bloqueada: hay una búsqueda TXT en curso");
                return;
            }

            if (allAuthorsData.Count == 0 || client == null || 
                (!client.State.HasFlag(SoulseekClientStates.Connected) && !client.State.HasFlag(SoulseekClientStates.LoggedIn)))
            {
                AutoLog(" No se puede purgar: lista vacía o no conectado.");
                return;
            }

            var allAuthors = (chkCanonicalOnly?.Checked == true
                    ? allAuthorsData.Where(a => a.IsCanonical)
                    : allAuthorsData)
                .Select(a => a.Name)
                .ToList();
            if (allAuthors.Count == 0) return;

            // OPTIMIZACIÓN: Cargar caché de purga
            LoadPurgeCache();

            var purgeCacheSnapshot = new Dictionary<string, (bool hasFiles, int filesCount, DateTime lastCheck)>(
                purgeCache,
                StringComparer.OrdinalIgnoreCase);

            AutoLog("");
            AutoLog($"🧹 PURGA: Verificando {allAuthors.Count} autores...");
            AutoLog($"📦 Caché: {purgeCache.Count} autores en caché");
            AutoLog($"⏳ Filtrando autores en background thread...");
            
            // OPTIMIZACIÓN: Filtrar autores en background thread para no bloquear UI
            var filterResult = await Task.Run(() =>
            {
                var authorsToCheck = new List<string>();
                var authorsToRemove = new List<string>();
                var skippedInvalid = 0;
                var skippedCached = 0;
                var logBuffer = new List<string>();
                
                // Crear diccionario para búsquedas O(1)
                var authorDict = allAuthorsData.ToDictionary(a => a.Name, StringComparer.OrdinalIgnoreCase);
                
                int processed = 0;
                foreach (var author in allAuthors)
                {
                    processed++;
                    
                    // Reportar progreso cada 100 autores
                    if (processed % 100 == 0)
                    {
                        var progress = (processed * 100) / allAuthors.Count;
                        this.Invoke((Action)(() => AutoLogThrottled($"    📊 Progreso: {processed}/{allAuthors.Count} ({progress}%)", 2000)));
                    }
                    
                    if (ShouldSkipPurgeCheck(author, out string reason))
                    {
                        if (reason.Contains("inválido"))
                        {
                            skippedInvalid++;
                            logBuffer.Add($"    ⏭️ Skip: {author} ({reason})");
                            authorsToRemove.Add(author);
                        }
                        else if (reason.Contains("caché"))
                        {
                            skippedCached++;
                            if (purgeCache.TryGetValue(author, out var cached))
                            {
                                if (!cached.hasFiles)
                                {
                                    authorsToRemove.Add(author);
                                    logBuffer.Add($"    ❌ {author}: Sin archivos (caché)");
                                }
                                else
                                {
                                    logBuffer.Add($"    ✅ {author}: {cached.filesCount} archivos (caché)");
                                }
                            }
                        }
                    }
                    else
                    {
                        authorsToCheck.Add(author);
                    }
                }
                
                return new { authorsToCheck, authorsToRemove, skippedInvalid, skippedCached, logBuffer };
            });
            
            // Aplicar eliminaciones en UI thread (rápido)
            foreach (var author in filterResult.authorsToRemove)
            {
                var authorData = allAuthorsData.FirstOrDefault(a => a.Name.Equals(author, StringComparison.OrdinalIgnoreCase));
                if (authorData != null)
                {
                    allAuthorsData.Remove(authorData);
                }
            }
            
            // Escribir logs bufereados
            foreach (var log in filterResult.logBuffer.Take(50)) // Solo primeros 50 para no saturar
            {
                AutoLog(log);
            }
            if (filterResult.logBuffer.Count > 50)
            {
                AutoLog($"    ... y {filterResult.logBuffer.Count - 50} mensajes más");
            }
            
            var authorsToCheck = filterResult.authorsToCheck;
            AutoLog($"📊 Filtrado: {authorsToCheck.Count} a verificar, {filterResult.skippedInvalid} inválidos, {filterResult.skippedCached} en caché");
            AutoLog("");

            autoPurgeRunning = true;

            autoPurgeCts?.Dispose();
            autoPurgeCts = new CancellationTokenSource();
            var cancellationToken = autoPurgeCts.Token;

            // Habilitar botón Detener DIRECTAMENTE
            if (btnStopAuto != null)
            {
                btnStopAuto.Enabled = true;
                btnStopAuto.BackColor = Color.FromArgb(0, 255, 0); // Verde
                btnStopAuto.Refresh();
            }
            if (btnPurge != null)
                btnPurge.Enabled = false;
            if (btnStartAuto != null)
                btnStartAuto.Enabled = false;
                
            AutoLog("✅ Botón Detener HABILITADO");

            var authorsWithFiles = new HashSet<string>();
            var authorsWithoutFiles = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

            // OPTIMIZACIÓN: Solo verificar autores que no están en caché
            foreach (var author in authorsToCheck)
            {
                UpdateAuthorData(author, 0, "⏳ En cola");
            }

            try
            {
                // Obtener paralelismo óptimo (adaptativo o fijo), respetando el máximo configurado
                int currentPurgeParallelism;
                if (useAdaptiveParallelism)
                {
                    var adaptiveValue = adaptivePurge.GetOptimalParallelism();
                    currentPurgeParallelism = Math.Min(adaptiveValue, maxParallelPurgeSearches);
                }
                else
                {
                    currentPurgeParallelism = maxParallelPurgeSearches;
                }
                
                AutoLog($"🧹 Purga con paralelismo: {currentPurgeParallelism}");
                if (useAdaptiveParallelism)
                {
                    AutoLog($"📊 {adaptivePurge.GetStatusSummary()}");
                }

                // OPTIMIZACIÓN: pipeline con Channel + pool fijo de workers (evita crear una Task por autor)
                int processedCount = 0;

                int totalAuthorsToCheck = authorsToCheck.Count;
                int uiStep = Math.Max(1, totalAuthorsToCheck / 20);   // ~5% de resolución
                int logStep = Math.Max(1, totalAuthorsToCheck / 10);  // ~10% de resolución

                var channel = Channel.CreateBounded<string>(new BoundedChannelOptions(Math.Max(16, currentPurgeParallelism * 4))
                {
                    SingleWriter = true,
                    SingleReader = false,
                    FullMode = BoundedChannelFullMode.Wait
                });

                async Task ProcessPurgeAuthorAsync(string author, int current)
                {
                    if (!autoPurgeRunning || cancellationToken.IsCancellationRequested)
                    {
                        return;
                    }

                    if (lblPurgeProgress != null && (current % uiStep == 0 || current == totalAuthorsToCheck))
                    {
                        this.Invoke((MethodInvoker)delegate
                        {
                            lblPurgeProgress.Text = $"🔍 {current}/{totalAuthorsToCheck} ({current * 100 / Math.Max(1, totalAuthorsToCheck)}%)";
                            lblPurgeProgress.Visible = true;
                        });
                    }

                    if (current % logStep == 0 || current == 1 || current == totalAuthorsToCheck)
                    {
                        AutoLog($"    🔍 Progreso: {current}/{totalAuthorsToCheck} ({current * 100 / Math.Max(1, totalAuthorsToCheck)}%)");
                    }

                    UpdateAuthorStatus(author, "🔍 Buscando...");

                    await WaitForRateLimitAsync("purge");

                    var results = await client.SearchAsync(SearchQuery.FromText(author),
                        options: new Soulseek.SearchOptions(
                            searchTimeout: 5000,
                            maximumPeerQueueLength: 100,
                            filterResponses: true,
                            minimumResponseFileCount: 1,
                            minimumPeerUploadSpeed: 0),
                        cancellationToken: cancellationToken);

                    var responses = results.Responses;
                    var filesCount = responses?.Sum(r => r.Files?.Count ?? 0) ?? 0;
                    bool hasValid = filesCount > 0;

                    if (hasValid)
                    {
                        lock (authorsWithFiles)
                        {
                            authorsWithFiles.Add(author);
                        }

                        if (current % 50 == 0)
                        {
                            AutoLog($"        ✅ {author}: {filesCount} archivos válidos");
                        }

                        UpdateAuthorData(author, filesCount, "✅ Válido", Color.LightGreen);

                        lock (purgeCache)
                        {
                            purgeCache[author] = (true, filesCount, DateTime.Now);
                        }

                        if (useAdaptiveParallelism)
                        {
                            adaptivePurge.RecordResult(true);
                        }
                    }
                    else
                    {
                        lock (authorsWithoutFiles)
                        {
                            authorsWithoutFiles.Add(author);
                        }

                        if (current % 50 == 0)
                        {
                            AutoLog($"        ❌ {author}: Sin archivos, será eliminado");
                        }

                        UpdateAuthorData(author, filesCount, "❌ Eliminado", Color.LightCoral);

                        lock (purgeCache)
                        {
                            purgeCache[author] = (false, 0, DateTime.Now);
                        }

                        if (useAdaptiveParallelism)
                        {
                            adaptivePurge.RecordResult(false);
                        }
                    }
                }

                var workers = Enumerable.Range(0, currentPurgeParallelism)
                    .Select(_ => Task.Run(async () =>
                    {
                        await foreach (var author in channel.Reader.ReadAllAsync(cancellationToken))
                        {
                            var current = Interlocked.Increment(ref processedCount);
                            try
                            {
                                await ProcessPurgeAuthorAsync(author, current);
                            }
                            catch (OperationCanceledException)
                            {
                                UpdateAuthorData(author, 0, "⏹️ Cancelado", Color.Gray);
                                if (useAdaptiveParallelism)
                                {
                                    adaptivePurge.RecordResult(false);
                                }
                            }
                            catch (Exception ex)
                            {
                                if (current % 50 == 0)
                                {
                                    AutoLog($"        ⚠️ Error en {author}: {ex.Message}");
                                }
                                UpdateAuthorData(author, 0, "⚠️ Error", Color.Khaki);
                                if (useAdaptiveParallelism)
                                {
                                    adaptivePurge.RecordResult(false);
                                }
                            }
                        }
                    }, cancellationToken))
                    .ToArray();

                try
                {
                    foreach (var author in authorsToCheck)
                    {
                        await channel.Writer.WriteAsync(author, cancellationToken);
                    }

                    channel.Writer.TryComplete();
                    await Task.WhenAll(workers);
                }
                catch (OperationCanceledException)
                {
                    // Cancelación global: no eliminar autores en base a resultados parciales
                }
                finally
                {
                    channel.Writer.TryComplete();
                }

                var completedAllAuthors = !cancellationToken.IsCancellationRequested && processedCount >= totalAuthorsToCheck;
                if (!completedAllAuthors)
                {
                    AutoLog($"\n⏹️ PURGA INTERRUMPIDA: {authorsWithFiles.Count} con archivos válidos verificados (sin eliminaciones)\n");

                    lock (purgeCache)
                    {
                        purgeCache.Clear();
                        foreach (var kvp in purgeCacheSnapshot)
                        {
                            purgeCache[kvp.Key] = kvp.Value;
                        }
                    }
                }
                else
                {
                    var toRemove = allAuthorsData
                        .Where(a => authorsWithoutFiles.Contains(a.Name))
                        .ToList();

                    AutoLog($"🗑️ Eliminando {toRemove.Count} autores sin archivos...");
                    foreach (var author in toRemove)
                    {
                        allAuthorsData.Remove(author);
                    }

                    filteredAuthorsData = new List<AuthorData>(allAuthorsData);
                    RefreshAuthorsListView();
                    UpdateAuthorCount();

                    AutoLog($"\n✅ PURGA COMPLETADA: {authorsWithFiles.Count} con archivos válidos, {toRemove.Count} eliminados\n");

                    // OPTIMIZACIÓN: Guardar caché de purga
                    SavePurgeCache();
                }
            }
            finally
            {
                autoPurgeRunning = false;
                
                // Ocultar label de progreso
                if (lblPurgeProgress != null)
                {
                    lblPurgeProgress.Visible = false;
                }
                
                // Restaurar botones DIRECTAMENTE
                if (btnStopAuto != null)
                {
                    btnStopAuto.Enabled = false;
                    btnStopAuto.BackColor = Color.FromArgb(150, 0, 0); // Rojo oscuro
                    btnStopAuto.Refresh();
                }
                if (btnPurge != null)
                    btnPurge.Enabled = true;
                if (btnStartAuto != null)
                    btnStartAuto.Enabled = true;
                    
                AutoLog("✅ Botones restaurados");
            }
        }

        // ============================================
        // MÉTODOS HELPER OPTIMIZADOS
        // ============================================

        /// <summary>
        /// Ejecuta una acción en el thread de UI de forma segura
        /// </summary>
        private void SafeInvoke(Action action)
        {
            if (isShuttingDown || IsDisposed || Disposing)
            {
                return;
            }

            if (InvokeRequired)
            {
                try
                {
                    BeginInvoke(action); // No bloqueante - evita deadlocks
                }
                catch (ObjectDisposedException)
                {
                    // Control ya destruido, ignorar
                }
                catch (InvalidOperationException)
                {
                    // Thread de destino ya no existe, ignorar
                }
            }
            else
            {
                try
                {
                    action();
                }
                catch (ObjectDisposedException)
                {
                    // Control ya destruido, ignorar
                }
                catch (InvalidOperationException)
                {
                    // Thread de destino ya no existe, ignorar
                }
            }
        }

        private void SafeInvokeBlocking(Action action)
        {
            if (isShuttingDown || IsDisposed || Disposing)
            {
                return;
            }

            if (InvokeRequired)
            {
                try
                {
                    Invoke(action);
                }
                catch (ObjectDisposedException)
                {
                }
                catch (InvalidOperationException)
                {
                }
            }
            else
            {
                try
                {
                    action();
                }
                catch (ObjectDisposedException)
                {
                }
                catch (InvalidOperationException)
                {
                }
            }
        }

        /// <summary>
        /// Actualiza un control de forma thread-safe
        /// </summary>
        private void UpdateControl(Control control, Action<Control> updateAction)
        {
            if (control == null) return;
            SafeInvoke(() => updateAction(control));
        }
        
        /// <summary>
        /// Ejecuta una acción en el thread de UI de forma asíncrona (no bloqueante)
        /// Usar cuando NO necesitas esperar el resultado
        /// </summary>
        private void SafeBeginInvoke(Action action)
        {
            if (isShuttingDown || IsDisposed || Disposing) return;
            
            try
            {
                void Wrapped()
                {
                    if (isShuttingDown || IsDisposed || Disposing)
                    {
                        return;
                    }

                    try
                    {
                        action();
                    }
                    catch (ObjectDisposedException)
                    {
                    }
                    catch (InvalidOperationException)
                    {
                    }
                }

                if (!IsHandleCreated)
                {
                    void Handler(object? sender, EventArgs args)
                    {
                        try
                        {
                            HandleCreated -= Handler;
                        }
                        catch
                        {
                        }

                        SafeBeginInvoke(Wrapped);
                    }

                    try
                    {
                        HandleCreated += Handler;
                    }
                    catch
                    {
                    }
                    return;
                }

                if (InvokeRequired)
                    BeginInvoke((Action)Wrapped);
                else
                    Wrapped();
            }
            catch (ObjectDisposedException)
            {
                // Control ya destruido, ignorar
            }
            catch (InvalidOperationException)
            {
                // Handle cerrado, ignorar
            }
        }

        /// <summary>
        /// Actualiza el texto de un control de forma thread-safe
        /// </summary>
        private void UpdateControlText(Control? control, string text)
        {
            if (control == null) return;
            SafeInvoke(() => control.Text = text);
        }

        /// <summary>
        /// Actualiza el estado enabled de un control de forma thread-safe
        /// </summary>
        private void UpdateControlEnabled(Control? control, bool enabled)
        {
            if (control == null) return;
            SafeInvoke(() => control.Enabled = enabled);
        }
        
        private DateTime lastUpdateTime = DateTime.MinValue;
        private const int UPDATE_THROTTLE_MS = 500; // Actualizar UI máximo cada 500ms
        private const int DOWNLOADS_VIRTUAL_MODE_THRESHOLD = 500;
        
        /// <summary>
        /// Actualiza los resultados de búsqueda usando Virtual ListView cuando >1000 items
        /// </summary>
        private void UpdateSearchResults(List<SearchResultItem> items)
        {
            // LOG DETALLADO: Verificar qué se está mostrando en la grilla
            Log($"🖥️ DEBUG: UpdateSearchResults recibió {items?.Count ?? 0} items");
            if (items != null && items.Count > 0)
            {
                for (int i = 0; i < Math.Min(3, items.Count); i++)
                {
                    Log($"   [{i+1}] {items[i].Filename}");
                }
            }
            
            // Throttling: solo actualizar si han pasado 500ms desde la última actualización
            var now = DateTime.Now;
            if ((now - lastUpdateTime).TotalMilliseconds < UPDATE_THROTTLE_MS)
            {
                Log($"⏭️ DEBUG: Throttling - saltando actualización (última hace {(now - lastUpdateTime).TotalMilliseconds}ms)");
                return; // Saltar esta actualización para no saturar el UI thread
            }
            lastUpdateTime = now;

            var totalCount = items?.Count ?? 0;
            var uiLimit = responseLimit > 0 ? Math.Min(responseLimit, totalCount) : totalCount;
            if (uiLimit < totalCount)
            {
                items = items.Take(uiLimit).ToList();
            }
            
            SafeInvokeBlocking(() =>
            {
                const int VIRTUAL_MODE_THRESHOLD = 1000;
                bool useVirtualMode = items.Count > VIRTUAL_MODE_THRESHOLD;

                if (useVirtualMode && !lvResults.VirtualMode)
                {
                    lvResults.BeginUpdate();
                    lvResults.Items.Clear();
                    lvResults.VirtualMode = true;
                    lvResults.EndUpdate();
                }
                else if (!useVirtualMode && lvResults.VirtualMode)
                {
                    lvResults.BeginUpdate();
                    lvResults.VirtualMode = false;
                    lvResults.Items.Clear();
                    lvResults.EndUpdate();
                }

                if (useVirtualMode)
                {
                    // OPTIMIZACIÓN DÍA 2: Usar VirtualListCache en lugar de Dictionary
                    virtualResultsCache.Clear();
                    resultsCache.SetDataSource(items);
                    lvResults.VirtualListSize = items.Count;
                    lvResults.Invalidate();
                    lblResultsCount.Text = totalCount == items.Count
                        ? $"{items.Count:N0} archivos (modo virtual)"
                        : $"{items.Count:N0} / {totalCount:N0} archivos (modo virtual)";
                }
                else
                {
                    // Suspender redibujado durante actualización masiva
                    lvResults.BeginUpdate();
                    try
                    {
                        lvResults.Items.Clear();
                        
                        // Crear array de items para agregar en batch
                        var listItems = new ListViewItem[items.Count];
                        for (int i = 0; i < items.Count; i++)
                        {
                            listItems[i] = CreateSearchResultListItem(items[i]);
                        }
                        
                        // Agregar todos los items de una vez (más rápido que Add individual)
                        lvResults.Items.AddRange(listItems);
                        lblResultsCount.Text = totalCount == items.Count
                            ? $"{items.Count:N0} archivos"
                            : $"{items.Count:N0} / {totalCount:N0} archivos";
                    }
                    finally
                    {
                        lvResults.EndUpdate();
                    }

                    lvResults.Invalidate();
                }

                if (totalCount > items.Count && lblStatus != null)
                {
                    lblStatus.Text = $"Mostrando {items.Count:N0} de {totalCount:N0} (limitado por ResponseLimit)";
                }
            });
        }

        private ListViewItem CreateSearchResultListItem(SearchResultItem item)
        {
            // Verificar si el archivo ya fue descargado
            var fileHash = $"{item.Filename}_{item.Username}_{item.Size}".ToLowerInvariant();
            var isDownloaded = downloadedFileHashes.Contains(fileHash);
            
            var fileName = isDownloaded ? $"✅ {item.Filename}" : item.Filename;
            var listItem = new ListViewItem(fileName);
            listItem.SubItems.Add(item.Extension);
            listItem.SubItems.Add(item.Username);
            listItem.SubItems.Add(FormatSize(item.Size));
            listItem.SubItems.Add(item.UploadSpeed > 0 ? $"{item.UploadSpeed / 1024.0:F1} KB/s" : "-");
            
            // Color diferente para archivos descargados
            if (listItem.ForeColor == System.Drawing.Color.Empty)
            {
                listItem.ForeColor = System.Drawing.Color.Gray;
            }
            listItem.SubItems.Add(item.FolderPath);
            listItem.Tag = item;

            try
            {
                listItem.ToolTipText = GetRankTooltipCached(item);
            }
            catch
            {
            }
            
            // Aplicar colores según calidad
            if (item.Extension.ToLower() == ".flac")
                listItem.ForeColor = Color.FromArgb(50, 255, 255);
            else if (item.Size > 100 * 1024 * 1024)
                listItem.ForeColor = Color.FromArgb(255, 80, 80);
            
            return listItem;
        }

        private string GetRankTooltipCached(SearchResultItem item)
        {
            var key = $"{item.Filename}|{item.Username}|{item.Size}|{item.Extension}|{item.UploadSpeed}|{item.QueueLength}|{item.FreeUploadSlots}";

            lock (rankTooltipCacheLock)
            {
                if (rankTooltipCache.TryGetValue(key, out var cached))
                {
                    return cached;
                }
            }

            var tooltip = BuildRankTooltip(item);

            lock (rankTooltipCacheLock)
            {
                if (rankTooltipCache.Count >= RankTooltipCacheMaxEntries)
                {
                    rankTooltipCache.Clear();
                }
                rankTooltipCache[key] = tooltip;
            }

            return tooltip;
        }

        private string BuildRankTooltip(SearchResultItem item)
        {
            var parsed = ParseFileName(item.Filename);
            var author = string.IsNullOrWhiteSpace(item.Author) ? parsed.author : item.Author;

            var candidate = new SlskDown.Core.CandidateFileInfo
            {
                FileName = item.Filename ?? string.Empty,
                Extension = string.IsNullOrWhiteSpace(item.Extension) ? Path.GetExtension(item.Filename) : item.Extension,
                Username = item.Username ?? string.Empty,
                FolderPath = item.FolderPath,
                SizeBytes = item.Size,
                UploadSpeed = item.UploadSpeed,
                QueueLength = item.QueueLength,
                FreeUploadSlots = item.FreeUploadSlots,
                Author = author,
                Network = string.IsNullOrWhiteSpace(item.Network) ? "Soulseek" : item.Network
            };

            var ranked = candidateRanker.Rank(candidate, author, parsed.title);
            var reasons = ranked.Reasons ?? new List<string>();

            var limitedReasons = reasons.Count > 12
                ? reasons.Take(12).Concat(new[] { "..." }).ToList()
                : reasons;

            var header = $"Rank: {ranked.Score:F1}/100";
            if (!string.IsNullOrWhiteSpace(author) || !string.IsNullOrWhiteSpace(parsed.title))
            {
                header += $"\nTarget: {(string.IsNullOrWhiteSpace(author) ? "?" : author)} | {(string.IsNullOrWhiteSpace(parsed.title) ? "?" : parsed.title)}";
            }

            var tooltip = header + "\n" + string.Join("\n", limitedReasons);
            return tooltip.Length > 1500 ? tooltip.Substring(0, 1500) : tooltip;
        }

        private readonly Dictionary<int, ListViewItem> virtualResultsCache = new Dictionary<int, ListViewItem>();

        private readonly object downloadVirtualLock = new object();
        private List<DownloadTask> downloadVirtualSnapshot = new List<DownloadTask>();
        private readonly Dictionary<int, ListViewItem> virtualDownloadsCache = new Dictionary<int, ListViewItem>();

        private void LvResults_RetrieveVirtualItem(object sender, RetrieveVirtualItemEventArgs e)
        {
            // OPTIMIZACIÓN DÍA 2: Usar VirtualListCache (reduce 80-90% de llamadas)
            var cachedItem = resultsCache.GetItem(e.ItemIndex);
            if (cachedItem != null)
            {
                e.Item = CreateSearchResultListItem(cachedItem);
                return;
            }

            // Fallback: usar método anterior si el caché falla
            if (virtualResultsCache.TryGetValue(e.ItemIndex, out var cached))
            {
                e.Item = cached;
                return;
            }

            if (e.ItemIndex >= 0 && e.ItemIndex < allResults.Count)
            {
                var item = CreateSearchResultListItem(allResults[e.ItemIndex]);
                virtualResultsCache[e.ItemIndex] = item;
                e.Item = item;
            }
        }

        private void LvResults_CacheVirtualItems(object sender, CacheVirtualItemsEventArgs e)
        {
            // OPTIMIZACIÓN DÍA 2: Pre-cargar items en VirtualListCache
            for (int i = e.StartIndex; i <= e.EndIndex && i < lvResults.VirtualListSize; i++)
            {
                resultsCache.GetItem(i);
            }
        }

        private void LvDownloads_RetrieveVirtualItem(object sender, RetrieveVirtualItemEventArgs e)
        {
            // OPTIMIZACIÓN DÍA 2: Usar VirtualListCache (reduce 80-90% de llamadas)
            var cachedTask = downloadsCache.GetItem(e.ItemIndex);
            if (cachedTask != null)
            {
                e.Item = CreateDownloadListViewItem(cachedTask);
                return;
            }

            // Fallback: usar método anterior si el caché falla
            if (virtualDownloadsCache.TryGetValue(e.ItemIndex, out var cached))
            {
                e.Item = cached;
                return;
            }

            DownloadTask task;
            lock (downloadVirtualLock)
            {
                if (e.ItemIndex < 0 || e.ItemIndex >= downloadVirtualSnapshot.Count)
                {
                    return;
                }
                task = downloadVirtualSnapshot[e.ItemIndex];
            }

            var item = CreateDownloadListViewItem(task);
            virtualDownloadsCache[e.ItemIndex] = item;
            e.Item = item;
        }

        private void LvDownloads_CacheVirtualItems(object sender, CacheVirtualItemsEventArgs e)
        {
            // OPTIMIZACIÓN DÍA 2: Pre-cargar items en VirtualListCache
            for (int i = e.StartIndex; i <= e.EndIndex && i < lvDownloads.VirtualListSize; i++)
            {
                downloadsCache.GetItem(i);
            }
        }

        private ListViewItem CreateDownloadListViewItem(DownloadTask task)
        {
            var fileName = task?.File?.FileName ?? string.Empty;
            var username = task?.File?.Username ?? string.Empty;
            var size = task?.File?.SizeReadable ?? string.Empty;

            var progress = task != null && task.ProgressPercent > 0
                ? $"{task.ProgressPercent:F1}%"
                : "0%";

            var statusText = task == null
                ? string.Empty
                : (string.IsNullOrWhiteSpace(task.UiStatusText) ? GetStatusText(task.Status) : task.UiStatusText);

            // Extraer autor y extensión
            var author = ExtractAuthorFromFilename(fileName) ?? "-";
            var extension = Path.GetExtension(fileName)?.TrimStart('.').ToUpperInvariant() ?? "-";

            var item = new ListViewItem(Path.GetFileName(fileName));
            item.SubItems.Add(author);           // Columna 1: Autor
            item.SubItems.Add(extension);        // Columna 2: Extensión
            item.SubItems.Add(username);         // Columna 3: Usuario
            item.SubItems.Add(progress);         // Columna 4: Progreso
            item.SubItems.Add(statusText);       // Columna 5: Estado
            item.SubItems.Add(size);             // Columna 6: Tamaño
            item.SubItems.Add("");               // Columna 7: Metadata
            item.Tag = task;

            if (task != null && task.IsDuplicate && task.Status == DownloadStatus.Completed)
            {
                item.ForeColor = Color.MediumPurple;
            }
            else
            {
                item.ForeColor = task?.Status switch
                {
                    DownloadStatus.Completed => Color.FromArgb(0, 200, 0),
                    DownloadStatus.Failed => Color.FromArgb(200, 0, 0),
                    DownloadStatus.Downloading => Color.FromArgb(100, 200, 255),
                    DownloadStatus.Paused => Color.Gray,
                    _ => Color.White
                };
            }

            return item;
        }

        // OPTIMIZACIÓN DÍA 2: Métodos para VirtualListCache de lvLibrary
        private void LvLibrary_RetrieveVirtualItem(object sender, RetrieveVirtualItemEventArgs e)
        {
            var cachedItem = libraryCache.GetItem(e.ItemIndex);
            if (cachedItem != null)
            {
                e.Item = CreateLibraryListViewItem(cachedItem);
            }
        }

        private void LvLibrary_CacheVirtualItems(object sender, CacheVirtualItemsEventArgs e)
        {
            for (int i = e.StartIndex; i <= e.EndIndex && i < lvLibrary.VirtualListSize; i++)
            {
                libraryCache.GetItem(i);
            }
        }

        private ListViewItem CreateLibraryListViewItem(LibraryItem item)
        {
            var listItem = new ListViewItem(item.FileName);
            listItem.SubItems.Add(item.Title ?? "-");
            listItem.SubItems.Add(item.Author ?? "-");
            listItem.SubItems.Add(item.PublicationYear?.ToString() ?? "-");
            listItem.SubItems.Add(item.Publisher ?? "-");
            listItem.SubItems.Add(FormatFileSize(item.Size));
            listItem.SubItems.Add(item.DateAdded.ToString("yyyy-MM-dd HH:mm"));
            listItem.SubItems.Add(item.Read ? "✓" : "");
            listItem.Tag = item;
            return listItem;
        }

        private IOrderedEnumerable<DownloadTask> SortDownloadsSnapshot(IEnumerable<DownloadTask> tasks)
        {
            Func<DownloadTask, object> keySelector = lvDownloadsSortColumn switch
            {
                0 => t => Path.GetFileName(t?.File?.FileName ?? string.Empty),     // Archivo
                1 => t => ExtractAuthorFromFilename(t?.File?.FileName) ?? "-",     // Autor
                2 => t => Path.GetExtension(t?.File?.FileName)?.TrimStart('.').ToUpperInvariant() ?? "-", // Extensión
                3 => t => t?.File?.Username ?? string.Empty,                       // Usuario
                4 => t => t?.ProgressPercent ?? 0.0,                               // Progreso
                5 => t => string.IsNullOrWhiteSpace(t?.UiStatusText) ? GetStatusText(t?.Status ?? DownloadStatus.Queued) : t.UiStatusText, // Estado
                6 => t => t?.File?.SizeBytes ?? 0,                                 // Tamaño
                7 => t => string.Empty,                                            // Metadata
                _ => t => Path.GetFileName(t?.File?.FileName ?? string.Empty)
            };

            return lvDownloadsSortOrder == SortOrder.Descending
                ? tasks.OrderByDescending(keySelector)
                : tasks.OrderBy(keySelector);
        }
        
        /// <summary>
        /// Agrega resultados incrementalmente
        /// </summary>
        private void AddSearchResults(List<SearchResultItem> newItems)
        {
            // Deduplicar usando BloomFilter antes de procesar
            if (resultDeduplicator != null)
            {
                var deduplicated = new List<SearchResultItem>();
                foreach (var item in newItems)
                {
                    var key = $"{item.Filename}|{item.Size}|{item.Username}";
                    if (!resultDeduplicator.MightContain(key))
                    {
                        resultDeduplicator.Add(key);
                        deduplicated.Add(item);
                    }
                }
                newItems = deduplicated;
                
                if (newItems.Count == 0)
                {
                    return; // Todos duplicados
                }
            }
            
            // APLICAR TODOS LOS FILTROS antes de agregar a la UI
            IEnumerable<SearchResultItem> filtered = newItems;
            
            // Filtro por tamaño (en KB)
            if (numMinSize != null && numMinSize.Value > 0)
            {
                long minBytes = (long)numMinSize.Value * 1024;
                filtered = filtered.Where(r => r.Size >= minBytes);
            }
            
            if (numMaxSize != null && numMaxSize.Value > 0)
            {
                long maxBytes = (long)numMaxSize.Value * 1024;
                filtered = filtered.Where(r => r.Size <= maxBytes);
            }
            
            // Filtro por formato/extensión
            if (cmbExtensionFilter != null && cmbExtensionFilter.SelectedIndex > 0)
            {
                var filterSet = ExtensionFilterMap.TryGetValue(cmbExtensionFilter.SelectedIndex, out var extensions)
                    ? extensions
                    : null;
                
                if (filterSet != null && filterSet.Count > 0)
                {
                    filtered = filtered.Where(r => filterSet.Contains(r.Extension));
                }
            }
            
            // Filtro por slots libres
            if (chkOnlyFreeSlots != null && chkOnlyFreeSlots.Checked)
            {
                filtered = filtered.Where(r => r.FreeUploadSlots > 0);
            }
            
            // Filtro para excluir archivos ya descargados
            if (chkExcludeDownloaded?.Checked == true)
            {
                filtered = filtered.Where(r => !IsAlreadyDownloaded(r.Filename, r.Username, r.Size));
            }
            
            // Filtro por idioma español
            if (pnlAdvancedFilters != null)
            {
                var chkSpanish = pnlAdvancedFilters.Controls.Find("chkSpanishFilter", true).FirstOrDefault() as CheckBox;
                if (chkSpanish?.Checked == true)
                {
                    filtered = filtered.Where(r => IsSpanishText(r.Filename) || IsSpanishText(r.FolderPath));
                }
            }
            
            // Filtro por texto de búsqueda
            if (txtFilterResults != null && !string.IsNullOrWhiteSpace(txtFilterResults.Text))
            {
                var filterText = txtFilterResults.Text;
                filtered = filtered.Where(r =>
                    r.Filename.Contains(filterText, StringComparison.OrdinalIgnoreCase) ||
                    r.Username.Contains(filterText, StringComparison.OrdinalIgnoreCase) ||
                    r.FolderPath.Contains(filterText, StringComparison.OrdinalIgnoreCase));
            }
            
            newItems = filtered.ToList();
            
            if (newItems.Count == 0)
            {
                return; // Ningún resultado coincide con los filtros
            }
            
            // Throttling: solo actualizar si han pasado 500ms desde la última actualización
            var now = DateTime.Now;
            if ((now - lastResultsUpdate).TotalMilliseconds < 500 && !forceResultsUpdate)
            {
                pendingResults.AddRange(newItems);
                return;
            }
            
            SafeInvokeBlocking(() =>
            {
                // using (PerformanceMetrics.Instance.Track("AddSearchResults"))
                {
                    // Suspender redibujado durante actualización masiva
                    lvResults.BeginUpdate();
                    try
                    {
                        // Crear array de items para agregar en batch
                        var listItems = new ListViewItem[newItems.Count];
                        for (int i = 0; i < newItems.Count; i++)
                        {
                            var item = newItems[i];
                            var listItem = new ListViewItem(item.Filename);
                            listItem.SubItems.Add(item.Extension);
                            listItem.SubItems.Add(item.Username);
                            listItem.SubItems.Add(FormatSize(item.Size));
                            listItem.SubItems.Add(item.UploadSpeed > 0 ? $"{item.UploadSpeed / 1024:F0} KB/s" : "-");
                            listItem.SubItems.Add(item.FolderPath);
                            listItem.Tag = item;

                            try
                            {
                                listItem.ToolTipText = GetRankTooltipCached(item);
                            }
                            catch
                            {
                            }
                            
                            // Aplicar colores según calidad
                            if (item.Extension.ToLower() == ".flac")
                                listItem.ForeColor = Color.FromArgb(50, 255, 255);
                            else if (item.Size > 100 * 1024 * 1024)
                                listItem.ForeColor = Color.FromArgb(255, 80, 80);
                            
                            listItems[i] = listItem;
                        }
                        
                        // Agregar todos los items de una vez (más rápido que Add individual)
                        lvResults.Items.AddRange(listItems);
                        lblResultsCount.Text = $"{lvResults.Items.Count:N0} archivos";
                    }
                    finally
                    {
                        // Reanudar redibujado
                        lvResults.EndUpdate();
                    }

                    lvResults.Invalidate();
                    lvResults.Update();
                    lvResults.Refresh();
                }
            });

            lastResultsUpdate = now;
            forceResultsUpdate = false;
        }
        
        /// <summary>
        /// Limpia los resultados de búsqueda
        /// </summary>
        private void ClearSearchResults()
        {
            SafeInvokeBlocking(() =>
            {
                virtualResultsCache.Clear();

                if (lvResults.VirtualMode)
                {
                    lvResults.VirtualListSize = 0;
                }

                lvResults.Items.Clear();
                lblResultsCount.Text = "0 archivos";

                lvResults.Invalidate();
                lvResults.Update();
                lvResults.Refresh();
            });
        }
        
