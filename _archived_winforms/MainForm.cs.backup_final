                html.AppendLine("        .stat-value { font-size: 2em; font-weight: bold; color: #4CAF50; }");
                html.AppendLine("        .stat-label { font-size: 0.9em; color: #888; margin-top: 5px; }");
                html.AppendLine("        .search-box { margin: 20px 0; }");
                html.AppendLine("        .search-box input { width: 100%; padding: 15px; font-size: 16px; border: 2px solid #4CAF50; border-radius: 5px; background: #1e1e1e; color: #e0e0e0; }");
                html.AppendLine("        table { width: 100%; border-collapse: collapse; margin-top: 20px; background: #1e1e1e; border-radius: 8px; overflow: hidden; }");
                html.AppendLine("        th { background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%); color: white; padding: 15px; text-align: left; font-weight: 600; position: sticky; top: 0; z-index: 10; }");
                html.AppendLine("        td { padding: 12px 15px; border-bottom: 1px solid #333; }");
                html.AppendLine("        tr:hover { background: #2d2d2d; }");
                html.AppendLine("        .status-downloaded { color: #4CAF50; font-weight: bold; }");
                html.AppendLine("        .status-pending { color: #FFC107; }");
                html.AppendLine("        .badge { display: inline-block; padding: 4px 8px; border-radius: 3px; font-size: 0.85em; font-weight: bold; }");
                html.AppendLine("        .badge-yes { background: #4CAF50; color: white; }");
                html.AppendLine("        .badge-no { background: #666; color: white; }");
