        private void ResetCanonicalCaches()
        {
            foreach (var key in canonicalMatchCache.Keys.ToList())
            {
                canonicalMatchCache.TryRemove(key, out _);
            }

            foreach (var key in canonicalColorCache.Keys.ToList())
            {
                canonicalColorCache.TryRemove(key, out _);
            }

            canonicalPriorityScore.Clear();
        }

        private Task<string?> GetFileHashAsync(string filePath)
        {
            if (string.IsNullOrWhiteSpace(filePath) || !File.Exists(filePath))
            {
                return Task.FromResult<string?>(null);
            }

            if (blake3BatchHasher != null)
            {
                try
                {
                    return blake3BatchHasher.ComputeAsync(filePath);
                }
                catch (ObjectDisposedException)
                {
                    // Caer al fallback secuencial
                }
            }

            return Task.Run(() => SlskDownCore.HashFileBlake3(filePath));
        }

        private async void OnBenchmarkClick(object sender, EventArgs e)
        {
            try
            {
                btnBenchmark.Enabled = false;
                btnBenchmark.Text = "⏳ Ejecutando benchmark...";

                var sw = Stopwatch.StartNew();
                var stats = await Task.Run(() => RustAdvancedCore.BenchmarkSorting(50000));
                sw.Stop();

                if (stats.ItemsProcessed == 0)
                {
                    var availability = SlskNativeInterop.GetAvailabilitySummary();
                    var nativeSupport = SlskNativeInterop.GetSearchPipelineSupportSummary();
                    ShowDarkDialog(
                        "Rust no está disponible o el benchmark falló. Verifica la instalación del módulo nativo.\n\n" +
                        $"Diagnóstico: {availability}\n" +
                        $"Native: {nativeSupport}",
                        "Benchmark",
                        MessageBoxButtons.OK,
                        "⚠️");
                }
                else
                {
                    var message =
                        $"⚡ Benchmark de ordenamiento (Rust)\n\n" +
                        $"• Items procesados: {stats.ItemsProcessed:N0}\n" +
                        $"• Tiempo Rust: {stats.TimeMs:N0} ms\n" +
                        $"• Throughput: {stats.ItemsPerSecond:N0} items/s\n" +
                        $"• Duración total (incl. preparación): {sw.ElapsedMilliseconds:N0} ms";

                    ShowDarkDialog(message, "Benchmark", MessageBoxButtons.OK, "⚡");
                }
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error ejecutando benchmark: {ex.Message}");
                ShowDarkDialog($"Error ejecutando benchmark:\n{ex.Message}", "Benchmark", MessageBoxButtons.OK, "❌");
            }
            finally
            {
                btnBenchmark.Enabled = true;
                btnBenchmark.Text = "⚡ Benchmark (Rust)";
            }
        }

        private void EnsureDownloadWorkers()
        {
            lock (downloadWorkersLock)
            {
                if (downloadChannel == null)
                {
                    var options = new BoundedChannelOptions(DOWNLOAD_CHANNEL_CAPACITY)
                    {
                        FullMode = BoundedChannelFullMode.Wait,
                        SingleReader = false,
                        SingleWriter = true
                    };
                    downloadChannel = Channel.CreateBounded<DownloadTask>(options);
                }

                if (downloadWorkersCts == null || downloadWorkersCts.IsCancellationRequested)
                {
                    downloadWorkersCts?.Dispose();
                    downloadWorkersCts = new CancellationTokenSource();
                }

                // Ajustar número de workers a maxSimultaneousDownloads (con límites)
                int desiredWorkers = Math.Clamp(maxSimultaneousDownloads, 1, MAX_DOWNLOAD_WORKERS);
                int currentWorkers = downloadWorkers.Count(t => !t.IsCompleted);

                // Limpiar workers completados
                downloadWorkers.RemoveAll(t => t.IsCompleted);

                while (currentWorkers < desiredWorkers)
                {
                    var workerId = $"W{DateTime.Now:HHmmssfff}_{currentWorkers}";
                    var workerTask = Task.Run(async () => await DownloadWorkerLoop(workerId, downloadWorkersCts.Token));
                    downloadWorkers.Add(workerTask);
                    currentWorkers++;
                }
            }
        }

        private void CommitParallelDownloadLimit(int newLimit)
        {
            var clamped = Math.Clamp(newLimit, MIN_ADAPTIVE_PARALLEL, MAX_ADAPTIVE_PARALLEL);
            if (clamped == maxParallelDownloads)
            {
                return;
            }

            maxParallelDownloads = clamped;
            maxSimultaneousDownloads = clamped;

            SafeInvoke(() =>
            {
                if (numParallelDownloads != null)
                {
                    var uiValue = Math.Max(numParallelDownloads.Minimum, Math.Min(numParallelDownloads.Maximum, clamped));
                    if (numParallelDownloads.Value != uiValue)
                    {
                        numParallelDownloads.Value = uiValue;
                    }
                }
            });

            SaveConfig();
        }

        private async Task DownloadWorkerLoop(string workerId, CancellationToken cancellationToken)
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                DownloadTask task;
                try
                {
                    if (downloadChannel == null)
                    {
                        await Task.Delay(200, cancellationToken);
                        continue;
                    }

                    var payload = await downloadChannel.Reader.ReadAsync(cancellationToken);
                    task = payload;
                }
                catch (OperationCanceledException)
                {
                    break;
                }
                catch (ChannelClosedException)
                {
                    break;
                }
                catch (Exception ex)
                {
                    AutoLog($"⚠️ Error leyendo canal de descargas: {ex.Message}");
                    await Task.Delay(500, cancellationToken);
                    continue;
                }

                if (task == null)
                {
                    continue;
                }
                
                // Verificar circuit breaker antes de procesar
                if (IsCircuitBreakerOpen())
                {
                    // Reencolar la tarea para procesarla después
                    task.Status = DownloadStatus.Queued;
                    task.IsScheduled = false;
                    task.ScheduledAt = null;
                    task.AssignedWorkerId = null;
                    
                    // Esperar un poco antes de verificar de nuevo
                    await Task.Delay(5000, cancellationToken);
                    continue;
                }

                try
                {
                    await ProcessDownload(task, workerId);
                }
                catch (Exception ex)
                {
                    AutoLog($"⚠️ Error inesperado en worker {workerId}: {ex.Message}");
                }
                finally
                {
                    downloadQueueService.Update(list =>
                    {
                        if (list.Contains(task))
                        {
                            task.IsScheduled = false;
                            task.ScheduledAt = null;
                            task.AssignedWorkerId = null;
                            task.CompletedAt = DateTime.Now;
                        }
                    });
                }
            }
        }

        private void StopDownloadWorkers()
        {
            lock (downloadWorkersLock)
            {
                try
                {
                    downloadChannel?.Writer.TryComplete();
                }
                catch { }

                if (downloadWorkersCts != null && !downloadWorkersCts.IsCancellationRequested)
                {
                    downloadWorkersCts.Cancel();
                }

                if (downloadWorkers.Count > 0)
                {
                    try
                    {
                        Task.WaitAll(downloadWorkers.ToArray(), TimeSpan.FromSeconds(5));
                    }
                    catch (AggregateException)
                    {
                        // Ignorar cancelaciones
                    }
                    catch (Exception ex)
                    {
                        AutoLog($"⚠️ Error deteniendo workers: {ex.Message}");
                    }
                }

                downloadWorkers.Clear();
                downloadWorkersCts?.Dispose();
                downloadWorkersCts = null;
                downloadChannel = null;
            }
        }

        private void ResetScheduledTasksAfterStop()
        {
            List<DownloadTask> rescheduled = new List<DownloadTask>();

            downloadQueueService.WithQueueLock(list =>
            {
                foreach (var task in list.Where(t => t.IsScheduled).ToList())
                {
                    task.IsScheduled = false;
                    task.ScheduledAt = null;

                    if (task.Status == DownloadStatus.GettingStatus)
                    {
                        task.Status = DownloadStatus.Queued;
                        rescheduled.Add(task);
                    }
                }
            });

            foreach (var task in rescheduled)
            {
                UpdateDownloadUI(task, "⏳ En cola...");
            }
        }

        private void StopDownloadManager()
        {
            if (downloadManager == null)
            {
                return;
            }

            downloadManager.Stop();
            downloadManagerRunning = false;
            StopDownloadWorkers();
            ResetScheduledTasksAfterStop();
        }

        private async Task PrewarmConnectionsIfNeeded(DownloadTask[] pendingTasks)
        {
            if (pendingTasks == null || pendingTasks.Length < MIN_QUEUE_FOR_PREWARM)
            {
                return;
            }

            if (client == null || !client.State.HasFlag(SoulseekClientStates.Connected))
            {
                return;
            }

            if ((DateTime.Now - lastPrewarmTime).TotalSeconds < PREWARM_COOLDOWN_SECONDS)
            {
                return;
            }

            if (!await prewarmSemaphore.WaitAsync(0))
            {
                return;
            }

            try
            {
                var candidateUsers = pendingTasks
                    .Where(t => t?.File != null && !string.IsNullOrWhiteSpace(t.File.Username))
                    .Select(t => t.File.Username)
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .Where(username =>
                    {
                        lock (prewarmLock)
                        {
                            return !prewarmedUsers.Contains(username);
                        }
                    })
                    .Take(2)
                    .ToList();

                if (candidateUsers.Count == 0)
                {
                    return;
                }

                bool anyAttempt = false;
                foreach (var username in candidateUsers)
                {
                    anyAttempt = true;
                    var warmed = await WarmupUserAsync(username);
                    if (!warmed)
                    {
                        continue;
                    }

                    lock (prewarmLock)
                    {
                        if (prewarmedUsers.Add(username))
                        {
                            prewarmedUsersOrder.Enqueue(username);
                        }

                        while (prewarmedUsersOrder.Count > MAX_PREWARM_USERS)
                        {
                            var removed = prewarmedUsersOrder.Dequeue();
                            prewarmedUsers.Remove(removed);
                        }
                    }
                }

                if (anyAttempt)
                {
                    lastPrewarmTime = DateTime.Now;
                }
            }
            finally
            {
                prewarmSemaphore.Release();
            }
        }

        private async Task<bool> WarmupUserAsync(string username)
        {
            if (string.IsNullOrWhiteSpace(username) || client == null)
            {
                return false;
            }

            try
            {
                using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(3));
                var userInfo = await GetUserInfoCachedAsync(username, requestTimeout: TimeSpan.FromSeconds(3), cancellationToken: cts.Token);
                if (userInfo == null)
                {
                    return false;
                }
                AutoLog($"🔥 Precalentamiento: {username} (Queue {userInfo.QueueLength})");
                return true;
            }
            catch (OperationCanceledException)
            {
                Log($"⚠️ Precalentamiento cancelado para {username} (timeout)");
            }
            catch (Exception ex)
            {
                Log($"⚠️ Precalentamiento fallido para {username}: {ex.Message}");
            }

            return false;
        }

        private void ReleasePrewarmedUser(string username)
        {
            if (string.IsNullOrWhiteSpace(username))
            {
                return;
            }

            lock (prewarmLock)
            {
                if (!prewarmedUsers.Remove(username))
                {
                    return;
                }

                if (prewarmedUsersOrder.Count > 0)
                {
                    var remaining = prewarmedUsersOrder
                        .Where(u => !string.Equals(u, username, StringComparison.OrdinalIgnoreCase))
                        .ToList();
                    prewarmedUsersOrder.Clear();
                    foreach (var user in remaining)
                    {
                        prewarmedUsersOrder.Enqueue(user);
                    }
                }
            }
        }

        private async Task SaveQueueSnapshotIfNeeded(IReadOnlyCollection<DownloadTask> pendingTasks)
        {
            if (pendingTasks == null || pendingTasks.Count == 0)
            {
                return;
            }

            var now = DateTime.Now;
            if ((now - lastQueueSnapshotTime).TotalMinutes < QUEUE_SNAPSHOT_INTERVAL_MINUTES &&
                Math.Abs(pendingTasks.Count - lastQueueSnapshotCount) < QUEUE_SNAPSHOT_MIN_DELTA)
            {
                return;
            }

            if (!await queueSnapshotSemaphore.WaitAsync(0))
            {
                return;
            }

            try
            {
                Directory.CreateDirectory(queueSnapshotsDir);

                var snapshotPayload = new
                {
                    capturedAt = now,
                    pendingCount = pendingTasks.Count,
                    items = pendingTasks.Select(t => new
                    {
                        FileName = t.File?.FileName,
                        Username = t.File?.Username,
                        SizeBytes = t.File?.SizeBytes,
                        Progress = t.ProgressPercent,
                        Retries = t.RetryCount,
                        Status = t.Status.ToString(),
                        Speed = t.SpeedMBps,
                        QueuePosition = t.QueuePosition
                    }).ToList()
                };

                var jsonBytes = JsonSerializer.SerializeToUtf8Bytes(snapshotPayload, new JsonSerializerOptions
                {
                    WriteIndented = false
                });

                var snapshotName = $"queue_snapshot_{now:yyyyMMdd_HHmmss}.json.br";
                var snapshotPath = Path.Combine(queueSnapshotsDir, snapshotName);

                using (var fileStream = new FileStream(snapshotPath, FileMode.Create, FileAccess.Write, FileShare.None))
                using (var brotli = new BrotliStream(fileStream, CompressionLevel.Fastest))
                {
                    await brotli.WriteAsync(jsonBytes, 0, jsonBytes.Length);
                }

                lastQueueSnapshotTime = now;
                lastQueueSnapshotCount = pendingTasks.Count;

                var retained = Directory.GetFiles(queueSnapshotsDir, "queue_snapshot_*.json.br")
                    .OrderByDescending(f => f)
                    .Skip(12)
                    .ToList();

                foreach (var path in retained)
                {
                    try
                    {
                        System.IO.File.Delete(path);
                    }
                    catch { }
                }

                Log($"🧊 Snapshot de cola guardado ({pendingTasks.Count} tareas)");
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error guardando snapshot de cola: {ex.Message}");
            }
            finally
            {
                queueSnapshotSemaphore.Release();
            }
        }
        
