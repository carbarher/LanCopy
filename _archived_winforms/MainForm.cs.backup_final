        private Task SaveDownloadQueueAsync() => downloadManager?.SaveQueueAsync() ?? Task.CompletedTask;

        private Task LoadDownloadQueueAsync() => downloadManager?.LoadQueueAsync() ?? Task.CompletedTask;
        
        // ===== FILTROS AVANZADOS =====
        
        private void CreateAdvancedFiltersPanel(Control parentPanel)
        {
            pnlAdvancedFilters = new Panel
            {
                Dock = DockStyle.Top,
                AutoSize = true,
                AutoSizeMode = AutoSizeMode.GrowAndShrink,
                BackColor = Color.FromArgb(38, 38, 38),
                Padding = new Padding(20, 16, 20, 16),
                Margin = new Padding(0),
                Visible = true // Siempre visible
            };

            // FILA ÚNICA: Todos los controles en una sola línea
            var row1 = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                FlowDirection = FlowDirection.LeftToRight,
                WrapContents = false,
                AutoSize = true,
                Margin = new Padding(0)
            };

            row1.Controls.Add(new Label { Text = " Tamaño (KB):", AutoSize = true, ForeColor = Color.White, Font = new Font("Segoe UI", 9, FontStyle.Bold), Margin = new Padding(0, 6, 10, 0) });
            
            numMinSize = new NumericUpDown { Width = 90, BackColor = Color.FromArgb(50, 50, 55), ForeColor = Color.White, Minimum = 0, Maximum = 1000000, DecimalPlaces = 0 };
            numMinSize.Margin = new Padding(0, 0, 8, 0);
            numMinSize.ValueChanged += (s, e) => ApplyAdvancedFilters();
            row1.Controls.Add(numMinSize);

            row1.Controls.Add(new Label { Text = "→", AutoSize = true, ForeColor = Color.Gray, Margin = new Padding(0, 6, 8, 0) });

            numMaxSize = new NumericUpDown { Width = 90, BackColor = Color.FromArgb(50, 50, 55), ForeColor = Color.White, Minimum = 0, Maximum = 1000000, DecimalPlaces = 0 };
            numMaxSize.Margin = new Padding(0, 0, 30, 0);
            numMaxSize.ValueChanged += (s, e) => ApplyAdvancedFilters();
            row1.Controls.Add(numMaxSize);

            row1.Controls.Add(new Label { Text = " Formato:", AutoSize = true, ForeColor = Color.White, Font = new Font("Segoe UI", 9, FontStyle.Bold), Margin = new Padding(0, 6, 10, 0) });

            cmbExtensionFilter = new ComboBox { Width = 160, BackColor = Color.FromArgb(50, 50, 55), ForeColor = Color.White, DropDownStyle = ComboBoxStyle.DropDownList };
            cmbExtensionFilter.Items.AddRange(new object[] { 
                "Todos", 
                " Libros/Docs", 
                " Comics", 
                " Audio", 
                " Video", 
                " Imágenes", 
                " Comprimidos" 
            });
            cmbExtensionFilter.SelectedIndex = 1; // Por defecto: Libros/Docs
            cmbExtensionFilter.Margin = new Padding(0, 0, 30, 0);
            cmbExtensionFilter.SelectedIndexChanged += (s, e) => ApplyAdvancedFilters();
            row1.Controls.Add(cmbExtensionFilter);

            row1.Controls.Add(new Label { Text = " Ordenar:", AutoSize = true, ForeColor = Color.White, Font = new Font("Segoe UI", 9, FontStyle.Bold), Margin = new Padding(0, 6, 10, 0) });

            cmbSortBy = new ComboBox { Width = 150, BackColor = Color.FromArgb(50, 50, 55), ForeColor = Color.White, DropDownStyle = ComboBoxStyle.DropDownList };
            cmbSortBy.Items.AddRange(new object[] { "Relevancia", "Tamaño ↑", "Tamaño ↓", "Nombre A-Z", "Usuario A-Z", "Velocidad ↑" });
            cmbSortBy.SelectedIndex = 0;
            cmbSortBy.Margin = new Padding(0, 0, 30, 0);
            cmbSortBy.SelectedIndexChanged += (s, e) => ApplyAdvancedFilters();
            row1.Controls.Add(cmbSortBy);

            var chkSpanishFilter = new CheckBox { Text = " Solo español", AutoSize = true, ForeColor = Color.White, Font = new Font("Segoe UI", 9), Margin = new Padding(0, 4, 30, 0), Name = "chkSpanishFilter" };
            chkSpanishFilter.CheckedChanged += (s, e) => ApplyAdvancedFilters();
            row1.Controls.Add(chkSpanishFilter);

            chkOnlyFreeSlots = new CheckBox { Text = " Solo slots libres", AutoSize = true, ForeColor = Color.White, Font = new Font("Segoe UI", 9), Margin = new Padding(0, 4, 30, 0), Checked = false };
            chkOnlyFreeSlots.CheckedChanged += (s, e) => ApplyAdvancedFilters();
            row1.Controls.Add(chkOnlyFreeSlots);

            chkExcludeDownloaded = new CheckBox { Text = "✓ Excluir descargados", AutoSize = true, ForeColor = Color.LightGreen, Font = new Font("Segoe UI", 9, FontStyle.Bold), Margin = new Padding(0, 4, 30, 0) };
            chkExcludeDownloaded.CheckedChanged += (s, e) => ApplyAdvancedFilters();
            row1.Controls.Add(chkExcludeDownloaded);

            btnDownloadFiltered = new Button
            {
                Text = "⬇️ Descargar Visibles",
                AutoSize = true,
                BackColor = Color.FromArgb(0, 150, 136),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 9, FontStyle.Bold),
                Padding = new Padding(12, 4, 12, 4),
                Cursor = Cursors.Hand,
                Margin = new Padding(0, 0, 0, 0)
            };
            btnDownloadFiltered.FlatAppearance.BorderSize = 0;
            btnDownloadFiltered.FlatAppearance.MouseOverBackColor = Color.FromArgb(20, 170, 156);
            btnDownloadFiltered.Click += BtnDownloadFiltered_Click;
            row1.Controls.Add(btnDownloadFiltered);

            pnlAdvancedFilters.Controls.Add(row1);
            parentPanel.Controls.Add(pnlAdvancedFilters);
        }

        private void ToggleAdvancedFilters()
        {
            advancedFiltersVisible = !advancedFiltersVisible;

            if (advancedFiltersVisible)
            {
                pnlAdvancedFilters.Visible = true;
                btnToggleFilters.Text = " Ocultar";
            }
            else
            {
                pnlAdvancedFilters.Visible = false;
                btnToggleFilters.Text = " Filtros";
            }
        }
        
        /// <summary>
        /// Aplica los filtros de UI a una lista de resultados sin modificar allResults
        /// </summary>
        private List<SearchResultItem> ApplyUiFiltersToResults(List<SearchResultItem> results)
        {
            if (results == null || results.Count == 0)
                return new List<SearchResultItem>();
            
            IEnumerable<SearchResultItem> filtered = results;
            
            // Obtener valores de filtros de forma segura
            int selectedFilterIndex = 0;
            long minBytes = 0;
            long maxBytes = 0;
            bool onlyFreeSlots = false;
            bool excludeDownloaded = false;
            bool spanishOnly = false;
            string textFilter = string.Empty;
            int sortIndex = 0;
            
            SafeInvokeBlocking(() =>
            {
                selectedFilterIndex = cmbExtensionFilter?.SelectedIndex ?? 0;
                minBytes = numMinSize != null && numMinSize.Value > 0 ? (long)numMinSize.Value * 1024 : 0;
                maxBytes = numMaxSize != null && numMaxSize.Value > 0 ? (long)numMaxSize.Value * 1024 : 0;
                onlyFreeSlots = chkOnlyFreeSlots?.Checked ?? false;
                excludeDownloaded = chkExcludeDownloaded?.Checked ?? false;
                textFilter = txtFilterResults?.Text ?? string.Empty;
                sortIndex = cmbSortBy?.SelectedIndex ?? 0;
                
                var chkSpanish = pnlAdvancedFilters?.Controls.Find("chkSpanishFilter", true).FirstOrDefault() as CheckBox;
                spanishOnly = chkSpanish?.Checked ?? false;
            });
            
            Log($"🔍 DEBUG ApplyUiFiltersToResults: Entrada={results.Count}, FilterIndex={selectedFilterIndex}, MinSize={minBytes}, MaxSize={maxBytes}, FreeSlots={onlyFreeSlots}, ExcludeDownloaded={excludeDownloaded}, Spanish={spanishOnly}, TextFilter='{textFilter}'");
            
            // Filtro por tamaño mínimo
            if (minBytes > 0)
            {
                int before = filtered.Count();
                filtered = filtered.Where(r => r.Size >= minBytes);
                int after = filtered.Count();
                if (before != after) Log($"   📏 Filtro tamaño mínimo: {before} → {after}");
            }
            
            // Filtro por tamaño máximo
            if (maxBytes > 0)
            {
                int before = filtered.Count();
                filtered = filtered.Where(r => r.Size <= maxBytes);
                int after = filtered.Count();
                if (before != after) Log($"   📏 Filtro tamaño máximo: {before} → {after}");
            }
            
            // Filtro por extensión
            if (selectedFilterIndex > 0 && ExtensionFilterMap.TryGetValue(selectedFilterIndex, out var extensions))
            {
                int beforeFilter = filtered.Count();
                filtered = filtered.Where(r => extensions.Contains(r.Extension));
                int afterFilter = filtered.Count();
                
                Log($"   📋 Filtro extensión: {beforeFilter} → {afterFilter} (Extensiones: {string.Join(", ", extensions)})");
            }
            
            // Filtro por slots libres
            if (onlyFreeSlots)
            {
                int before = filtered.Count();
                filtered = filtered.Where(r => r.FreeUploadSlots > 0);
                int after = filtered.Count();
                if (before != after) Log($"   🎰 Filtro slots libres: {before} → {after}");
            }
            
            // Filtro para excluir archivos ya descargados
            if (excludeDownloaded)
            {
                int before = filtered.Count();
                filtered = filtered.Where(r => !IsAlreadyDownloaded(r.Filename, r.Username, r.Size));
                int after = filtered.Count();
                if (before != after) Log($"   ⛔ Filtro excluir descargados: {before} → {after}");
            }
            
            // Filtro por idioma español
            if (spanishOnly)
            {
                int before = filtered.Count();
                filtered = filtered.Where(r => IsSpanishText(r.Filename) || IsSpanishText(r.FolderPath));
                int after = filtered.Count();
                if (before != after) Log($"   🇪🇸 Filtro español: {before} → {after}");
            }
            
            // Filtro por texto de búsqueda
            if (!string.IsNullOrWhiteSpace(textFilter))
            {
                int before = filtered.Count();
                filtered = filtered.Where(r =>
                    r.Filename.Contains(textFilter, StringComparison.OrdinalIgnoreCase) ||
                    r.Username.Contains(textFilter, StringComparison.OrdinalIgnoreCase) ||
                    r.FolderPath.Contains(textFilter, StringComparison.OrdinalIgnoreCase));
                int after = filtered.Count();
                if (before != after) Log($"   🔎 Filtro texto: {before} → {after}");
            }
            
            var filteredList = filtered.ToList();
            
            // Ordenar
            filteredList = sortIndex switch
            {
                1 => filteredList.OrderBy(r => r.Size).ToList(),
                2 => filteredList.OrderByDescending(r => r.Size).ToList(),
                3 => filteredList.OrderBy(r => r.Filename, StringComparer.OrdinalIgnoreCase).ToList(),
                4 => filteredList.OrderBy(r => r.Username, StringComparer.OrdinalIgnoreCase).ToList(),
                5 => filteredList.OrderByDescending(r => r.UploadSpeed).ToList(),
                _ => filteredList
            };
            
            return filteredList;
        }
        
        private void ApplyAdvancedFilters()
        {
            if (allResults.Count == 0) return;
            
            IEnumerable<SearchResultItem> filtered = allResults;
            
            AutoLog($"🔍 Aplicando filtros: Total resultados={allResults.Count}, Filtro seleccionado={cmbExtensionFilter?.SelectedIndex ?? -1}");

            // Filtro por tamaño (en KB)
            long minBytes = numMinSize.Value > 0 ? (long)numMinSize.Value * 1024 : 0;
            if (minBytes > 0)
            {
                filtered = filtered.Where(r => r.Size >= minBytes);
            }

            long maxBytes = numMaxSize.Value > 0 ? (long)numMaxSize.Value * 1024 : 0;
            if (maxBytes > 0)
            {
                filtered = filtered.Where(r => r.Size <= maxBytes);
            }

            // Filtro por tipo de archivo
            var filterSet = ExtensionFilterMap.TryGetValue(cmbExtensionFilter.SelectedIndex, out var extensions)
                ? extensions
                : null;

            if (filterSet != null && filterSet.Count > 0)
            {
                int beforeFilter = filtered.Count();
                filtered = filtered.Where(r => filterSet.Contains(r.Extension));
                int afterFilter = filtered.Count();
                AutoLog($"📋 Filtro de extensión aplicado: {beforeFilter} → {afterFilter} archivos (Extensiones permitidas: {string.Join(", ", extensions.Take(5))})");
            }

            // Filtro por slots libres
            if (chkOnlyFreeSlots.Checked)
            {
                filtered = filtered.Where(r => r.FreeUploadSlots > 0);
            }

            // Filtro para excluir archivos ya descargados
            if (chkExcludeDownloaded?.Checked == true)
            {
                filtered = filtered.Where(r => !IsAlreadyDownloaded(r.Filename, r.Username, r.Size));
            }

            // Filtro por idioma español
            var chkSpanish = pnlAdvancedFilters.Controls.Find("chkSpanishFilter", true).FirstOrDefault() as CheckBox;
            if (chkSpanish?.Checked == true)
            {
                filtered = filtered.Where(r => IsSpanishText(r.Filename) || IsSpanishText(r.FolderPath));
            }

            // Aplicar texto de filtro
            var textFilter = txtFilterResults.Text;
            if (!string.IsNullOrWhiteSpace(textFilter))
            {
                var filterText = textFilter.ToLowerInvariant();
                filtered = filtered.Where(r =>
                    r.Filename.Contains(filterText, StringComparison.OrdinalIgnoreCase) ||
                    r.Username.Contains(filterText, StringComparison.OrdinalIgnoreCase) ||
                    r.FolderPath.Contains(filterText, StringComparison.OrdinalIgnoreCase));
            }

            var filteredList = filtered as List<SearchResultItem> ?? filtered.ToList();

            // Ordenar
            filteredList = cmbSortBy.SelectedIndex switch
            {
                1 => filteredList.OrderBy(r => r.Size).ToList(),
                2 => filteredList.OrderByDescending(r => r.Size).ToList(),
                3 => filteredList.OrderBy(r => r.Filename, StringComparer.OrdinalIgnoreCase).ToList(),
                4 => filteredList.OrderBy(r => r.Username, StringComparer.OrdinalIgnoreCase).ToList(),
                5 => filteredList.OrderByDescending(r => r.UploadSpeed).ToList(),
                _ => filteredList
            };

            UpdateSearchResults(filteredList);
            SafeInvoke(() => lblResultsCount.Text = $"{filteredList.Count:N0} / {allResults.Count:N0} archivos");
        }
        
        private void BtnDownloadFiltered_Click(object sender, EventArgs e)
        {
            try
            {
                // Obtener los items visibles en la grilla
                var visibleItems = new List<SearchResultItem>();
                SafeInvoke(() =>
                {
                    foreach (ListViewItem item in lvResults.Items)
                    {
                        if (item.Tag is SearchResultItem searchResult)
                        {
                            visibleItems.Add(searchResult);
                        }
                    }
                });

                if (visibleItems.Count == 0)
                {
                    MessageBox.Show("No hay archivos visibles para descargar.", "Sin resultados", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    return;
                }

                var confirmResult = MessageBox.Show(
                    $"¿Descargar {visibleItems.Count:N0} archivos visibles en la grilla?\n\n" +
                    "Solo se descargarán los archivos que cumplen con los filtros actuales.",
                    "Confirmar descarga",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Question);

                if (confirmResult != DialogResult.Yes)
                {
                    return;
                }

                int addedCount = 0;
                int skippedCount = 0;

                foreach (var result in visibleItems)
                {
                    try
                    {
                        // Verificar si ya está descargado o en cola
                        if (IsAlreadyDownloaded(result.Filename, result.Username, result.Size))
                        {
                            skippedCount++;
                            continue;
                        }

                        // Crear objeto AutoSearchFileResult para AddToDownloadQueue
                        var fileResult = new AutoSearchFileResult
                        {
                            FileName = result.Filename,
                            Username = result.Username,
                            SizeBytes = result.Size,
                            Network = result.Network
                        };

                        // Determinar ruta local
                        string localPath = Path.Combine(downloadDir, result.Filename);

                        // Agregar a la cola de descargas
                        AddToDownloadQueue(fileResult, localPath, null, false);
                        addedCount++;
                    }
                    catch (Exception ex)
                    {
                        AutoLog($"⚠️ Error agregando {result.Filename}: {ex.Message}");
                        skippedCount++;
                    }
                }

                AutoLog($"✅ Descarga masiva: {addedCount:N0} archivos agregados a la cola, {skippedCount:N0} omitidos");
                
                MessageBox.Show(
                    $"✅ {addedCount:N0} archivos agregados a la cola de descargas\n" +
                    $"⏭️ {skippedCount:N0} archivos omitidos (ya descargados o duplicados)",
                    "Descarga iniciada",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error en descarga masiva: {ex.Message}");
                MessageBox.Show($"Error al iniciar descarga masiva:\n{ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
        // ===== COLA DE DESCARGAS INTELIGENTE =====
        
        private void ScheduleQueuePrioritization(int delayMs = 200)
        {
            if (Interlocked.Exchange(ref queuePrioritizationScheduled, 1) == 1)
            {
                return;
            }

            Task.Run(async () =>
            {
                try
                {
                    await Task.Delay(delayMs);
                    ApplyQueuePrioritization();
                }
                catch (Exception ex)
                {
                    AutoLog($"⚠️ Error reordenando cola: {ex.Message}");
                }
                finally
                {
                    Interlocked.Exchange(ref queuePrioritizationScheduled, 0);
                }
            });
        }

        private void ApplyQueuePrioritization()
        {
            if (queueStrategy == QueuePrioritizationStrategy.Manual)
            {
                return;
            }

            if ((DateTime.Now - lastQueueReorder).TotalMilliseconds < 500)
            {
                return;
            }

            List<DownloadTask> queuedSnapshot;
            lock (downloadQueueLock)
            {
                queuedSnapshot = downloadQueue.Where(t => t.Status == DownloadStatus.Queued).ToList();
            }

            if (queuedSnapshot.Count <= 1)
            {
                return;
            }

            var scoredTasks = queuedSnapshot
                .Select(task => new
                {
                    Task = task,
                    Score = CalculateTaskPriority(task)
                })
                .ToList();

            var reordered = queueStrategy switch
            {
                QueuePrioritizationStrategy.FastestFirst => scoredTasks
                    .OrderByDescending(t => t.Score.ProviderScore)
                    .ThenBy(t => t.Score.SizeMegabytes)
                    .Select(t => t.Task)
                    .ToList(),
                QueuePrioritizationStrategy.SmallestFirst => scoredTasks
                    .OrderBy(t => t.Score.SizeMegabytes)
                    .ThenByDescending(t => t.Score.ProviderScore)
                    .Select(t => t.Task)
                    .ToList(),
                QueuePrioritizationStrategy.LargestFirst => scoredTasks
                    .OrderByDescending(t => t.Score.SizeMegabytes)
                    .ThenByDescending(t => t.Score.ProviderScore)
                    .Select(t => t.Task)
                    .ToList(),
                QueuePrioritizationStrategy.Balanced => scoredTasks
                    .OrderBy(t => t.Score.Composite)
                    .Select(t => t.Task)
                    .ToList(),
                _ => scoredTasks
                    .OrderByDescending(t => t.Score.ProviderScore)
                    .Select(t => t.Task)
                    .ToList()
            };

            bool changed;
            lock (downloadQueueLock)
            {
                changed = ApplyReorderedQueue(reordered);
            }

            if (changed)
            {
                lastQueueReorder = DateTime.Now;
                AutoLogThrottled($"🎯 Priorización actualizada ({queueStrategy})", 2000);
                MarkDownloadStatsDirty();
                MarkDownloadsDirty();
            }
        }

        private bool ApplyReorderedQueue(List<DownloadTask> reorderedQueued)
        {
            if (reorderedQueued == null || reorderedQueued.Count == 0)
            {
                return false;
            }

            var currentQueued = downloadQueue.Where(t => t.Status == DownloadStatus.Queued).ToList();
            if (currentQueued.Count != reorderedQueued.Count || currentQueued.SequenceEqual(reorderedQueued))
            {
                return false;
            }

            int queuedIndex = 0;
            var newQueue = new List<DownloadTask>(downloadQueue.Count);
            foreach (var task in downloadQueue)
            {
                if (task.Status == DownloadStatus.Queued)
                {
                    newQueue.Add(reorderedQueued[queuedIndex++]);
                }
                else
                {
                    newQueue.Add(task);
                }
            }

            downloadQueue.Clear();
            downloadQueue.AddRange(newQueue);
            return true;
        }

        private (double Composite, double ProviderScore, double SizeMegabytes) CalculateTaskPriority(DownloadTask task)
        {
            double providerScore = GetProviderScore(task.File.Username);
            double adaptiveBoost = GetAdaptiveThroughputScore(task.File.Username);
            providerScore += adaptiveBoost * 2;
            double sizeMb = Math.Max(1, task.File.SizeBytes / (1024.0 * 1024.0));
            double retryPenalty = task.RetryCount * 5.0;
            double waitMinutes = task.StartedAt.HasValue
                ? Math.Max(0, (DateTime.Now - task.StartedAt.Value).TotalMinutes)
                : 0;

            double baseScore = sizeMb / Math.Max(1, providerScore + 1);
            baseScore += retryPenalty;
            baseScore -= waitMinutes * 0.2;
            baseScore -= adaptiveBoost;

            return (baseScore, providerScore, sizeMb);
        }

        private void UpdateDownloadListView()
        {
            // Método auxiliar para refrescar la vista de descargas
            // Esto actualizará el orden visual basado en las nuevas prioridades
            if (lvDownloads == null || lvDownloads.IsDisposed)
            {
                return;
            }

            List<DownloadTask> snapshot;
            lock (downloadQueueLock)
            {
                snapshot = SortDownloadsSnapshot(downloadQueue).ToList();
            }

            lock (downloadVirtualLock)
            {
                downloadVirtualSnapshot = snapshot;
                virtualDownloadsCache.Clear();
            }
            
            // OPTIMIZACIÓN DÍA 2: Actualizar VirtualListCache con el snapshot
            downloadsCache.SetDataSource(snapshot);

            var useVirtual = snapshot.Count > DOWNLOADS_VIRTUAL_MODE_THRESHOLD;
            if (useVirtual && !lvDownloads.VirtualMode)
            {
                lvDownloads.BeginUpdate();
                lvDownloads.Items.Clear();
                lvDownloads.VirtualMode = true;
                lvDownloads.EndUpdate();
            }
            else if (!useVirtual && lvDownloads.VirtualMode)
            {
                lvDownloads.BeginUpdate();
                lvDownloads.VirtualMode = false;
                lvDownloads.Items.Clear();
                lvDownloads.EndUpdate();
            }

            if (lvDownloads.VirtualMode)
            {
                lvDownloads.VirtualListSize = snapshot.Count;
                lvDownloads.Invalidate();
                return;
            }

            lvDownloads.BeginUpdate();
            try
            {
                lvDownloads.Items.Clear();

                var listItems = new ListViewItem[snapshot.Count];
                for (int i = 0; i < snapshot.Count; i++)
                {
                    var item = CreateDownloadListViewItem(snapshot[i]);
                    listItems[i] = item;
                    try
                    {
                        snapshot[i].ListViewItem = item;
                    }
                    catch
                    {
                    }
                }

                lvDownloads.Items.AddRange(listItems);
            }
            finally
            {
                lvDownloads.EndUpdate();
            }

            lvDownloads.Invalidate();
        }
        
        private string GetStatusText(Models.DownloadStatus status)
        {
            return status switch
            {
                Models.DownloadStatus.Queued => "⏳ En cola",
                Models.DownloadStatus.Downloading => "⬇️ Descargando",
                Models.DownloadStatus.Completed => "✅ Completado",
                Models.DownloadStatus.Failed => "❌ Fallido",
                Models.DownloadStatus.Cancelled => "🚫 Cancelado",
                Models.DownloadStatus.Paused => "⏸️ Pausado",
                _ => "❓ Desconocido"
            };
        }
        
        private Color GetStatusColor(Models.DownloadStatus status)
        {
            return status switch
            {
                Models.DownloadStatus.Queued => Color.LightGray,
                Models.DownloadStatus.Downloading => Color.LightBlue,
                Models.DownloadStatus.Completed => Color.LightGreen,
                Models.DownloadStatus.Failed => Color.LightCoral,
                Models.DownloadStatus.Cancelled => Color.Orange,
                Models.DownloadStatus.Paused => Color.Yellow,
                _ => Color.White
            };
        }
        
        private async Task<string> GetMetadataStatus(string fileName)
        {
            try
            {
                var (title, author) = ParseFileName(fileName);
                if (string.IsNullOrEmpty(title)) return "❌";
                
                // Verificar si hay metadata en caché
                string cacheKey = $"synopsis_{title}_{author}";
                var cachedMetadata = GetCachedMetadata<BookMetadata>(cacheKey);
                
                if (cachedMetadata != null)
                {
                    return "✅";
                }
                
                // Si no está en caché, intentar buscar (sin bloquear UI)
                var metadata = await FetchBookMetadataFromGoogleBooks(title, author);
                if (metadata != null && !string.IsNullOrEmpty(metadata.Synopsis))
                {
                    SetCachedMetadata(cacheKey, metadata);
                    return "✅";
                }
                
                // Intentar Open Library
                metadata = await FetchBookMetadataFromOpenLibrary(title, author);
                if (metadata != null && !string.IsNullOrEmpty(metadata.Synopsis))
                {
                    SetCachedMetadata(cacheKey, metadata);
                    return "✅";
                }
                
                return "❌";
            }
            catch
            {
                return "❓";
            }
        }
        
        private string GetMetadataStatusSync(string fileName)
        {
            try
            {
                var (title, author) = ParseFileName(fileName);
                if (string.IsNullOrEmpty(title)) return "❌";
                
                // Solo verificar caché (sin hacer peticiones HTTP)
                string cacheKey = $"synopsis_{title}_{author}";
                var cachedMetadata = GetCachedMetadata<BookMetadata>(cacheKey);
                
                return cachedMetadata != null ? "✅" : "❓";
            }
            catch
            {
                return "❓";
            }
        }
        
        // ═══════════════════════════════════════════════════════════
        // ═══════════════════════════════════════════════════════════
        // CACHÉ DE PURGA
        // ═══════════════════════════════════════════════════════════
        
        private void LoadPurgeCache()
        {
            try
            {
                if (!System.IO.File.Exists(purgeCacheFile))
                {
                    AutoLog("📂 Caché de purga no existe, se creará uno nuevo");
                    return;
                }
                
                var json = System.IO.File.ReadAllText(purgeCacheFile);
                var data = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, PurgeCacheEntry>>(json);
                
                if (data != null)
                {
                    purgeCache.Clear();
                    foreach (var kvp in data)
                    {
                        purgeCache[kvp.Key] = (kvp.Value.HasFiles, kvp.Value.FilesCount, kvp.Value.LastCheck);
                    }
                    AutoLog($"✅ Caché de purga cargado: {purgeCache.Count} autores");
                }
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error cargando caché de purga: {ex.Message}");
            }
        }
        
        private void SavePurgeCache()
        {
            try
            {
                var data = purgeCache.ToDictionary(
                    kvp => kvp.Key,
                    kvp => new PurgeCacheEntry
                    {
                        HasFiles = kvp.Value.hasFiles,
                        FilesCount = kvp.Value.filesCount,
                        LastCheck = kvp.Value.lastCheck
                    }
                );
                
                var json = System.Text.Json.JsonSerializer.Serialize(data, new System.Text.Json.JsonSerializerOptions
                {
                    WriteIndented = true
                });
                
                System.IO.File.WriteAllText(purgeCacheFile, json);
                AutoLog($"💾 Caché de purga guardado: {purgeCache.Count} autores");
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error guardando caché de purga: {ex.Message}");
            }
        }
        
        private bool IsInvalidAuthor(string author)
        {
            if (string.IsNullOrWhiteSpace(author))
                return true;
            
            var authorLower = author.ToLowerInvariant().Trim();
            
            // Verificar patrones inválidos
            foreach (var pattern in InvalidAuthorPatterns)
            {
                if (authorLower.Contains(pattern))
                    return true;
            }
            
            // Nombres muy cortos (< 3 caracteres)
            if (authorLower.Length < 3)
                return true;
            
            return false;
        }
        
        private bool ShouldSkipPurgeCheck(string author, out string reason)
        {
            reason = "";
            
            // 1. Verificar si es autor inválido
            if (IsInvalidAuthor(author))
            {
                reason = "Autor inválido";
                return true;
            }
            
            // 2. Verificar caché
            if (purgeCache.TryGetValue(author, out var cached))
            {
                var age = DateTime.Now - cached.lastCheck;
                if (age.TotalDays < PURGE_CACHE_DAYS)
                {
                    reason = $"En caché ({age.Days}d, {(cached.hasFiles ? "✅" : "❌")})";
                    return true;
                }
            }
            
            return false;
        }
        
        // Clase helper para serialización JSON
        private class PurgeCacheEntry
        {
            public bool HasFiles { get; set; }
            public int FilesCount { get; set; }
            public DateTime LastCheck { get; set; }
        }
        
        // ═══════════════════════════════════════════════════════════
        // VALIDACIÓN DE CONFIGURACIÓN
        // ═══════════════════════════════════════════════════════════
        
        private bool ValidateConfig()
        {
            var warnings = new List<string>();
            var errors = new List<string>();
            bool hasChanges = false;
            
            // Validar paralelismo de búsqueda automática
            if (maxParallelAutoSearches < 1 || maxParallelAutoSearches > 256)
            {
                errors.Add($"❌ Búsqueda automática fuera de rango: {maxParallelAutoSearches} (debe estar entre 1-256)");
                maxParallelAutoSearches = Math.Clamp(maxParallelAutoSearches, 1, 256);
                hasChanges = true;
            }
            else if (maxParallelAutoSearches > 200)
            {
                warnings.Add($"⚠️ Búsqueda automática muy alta: {maxParallelAutoSearches} (puede saturar la red)");
            }
            
            // Validar paralelismo de purga
            if (maxParallelPurgeSearches < 1 || maxParallelPurgeSearches > 50)
            {
                errors.Add($"❌ Purga fuera de rango: {maxParallelPurgeSearches} (debe estar entre 1-50)");
                maxParallelPurgeSearches = Math.Clamp(maxParallelPurgeSearches, 1, 50);
                hasChanges = true;
            }
            else if (maxParallelPurgeSearches > 35)
            {
                warnings.Add($"⚠️ Purga muy alta: {maxParallelPurgeSearches} (recomendado: 20-30)");
            }
            
            // Validar descargas simultáneas
            if (maxParallelDownloads < 1 || maxParallelDownloads > 32)
            {
                errors.Add($"❌ Descargas simultáneas fuera de rango: {maxParallelDownloads} (debe estar entre 1-32)");
                maxParallelDownloads = Math.Clamp(maxParallelDownloads, 1, 32);
                maxSimultaneousDownloads = maxParallelDownloads;
                hasChanges = true;
            }
            
            // Validar búsquedas simultáneas
            if (maxParallelSearches < 1 || maxParallelSearches > 15)
            {
                errors.Add($"❌ Búsquedas simultáneas fuera de rango: {maxParallelSearches} (debe estar entre 1-15)");
                maxParallelSearches = Math.Clamp(maxParallelSearches, 1, 15);
                hasChanges = true;
            }
            
            // Validar reintentos
            if (maxRetries < 0 || maxRetries > 10)
            {
                errors.Add($"❌ Reintentos fuera de rango: {maxRetries} (debe estar entre 0-10)");
                maxRetries = Math.Clamp(maxRetries, 0, 10);
                hasChanges = true;
            }
            
            if (maxAlternativeRetries < 0 || maxAlternativeRetries > 10)
            {
                errors.Add($"❌ Reintentos alternativos fuera de rango: {maxAlternativeRetries} (debe estar entre 0-10)");
                maxAlternativeRetries = Math.Clamp(maxAlternativeRetries, 0, 10);
                hasChanges = true;
            }
            
            // Validar timeouts
            if (searchTimeout < 0 || searchTimeout > 999999)
            {
                errors.Add($"❌ Timeout fuera de rango: {searchTimeout}");
                searchTimeout = Math.Clamp(searchTimeout, 0, 999999);
                hasChanges = true;
            }
            
            // Validar tamaño mínimo de archivo
            if (minFileSizeKB < 0 || minFileSizeKB > 1048576)
            {
                errors.Add($"❌ Tamaño mínimo fuera de rango: {minFileSizeKB} KB");
                minFileSizeKB = Math.Clamp(minFileSizeKB, 0, 1048576);
                hasChanges = true;
            }
            
            // Mostrar errores y advertencias si existen
            if (errors.Count > 0 || warnings.Count > 0)
            {
                var message = new StringBuilder();
                
                if (errors.Count > 0)
                {
                    message.AppendLine("ERRORES DE CONFIGURACIÓN:");
                    message.AppendLine(string.Join("\n", errors));
                    message.AppendLine();
                }
                
                if (warnings.Count > 0)
                {
                    message.AppendLine("ADVERTENCIAS:");
                    message.AppendLine(string.Join("\n", warnings));
                    message.AppendLine();
                }
                
                if (hasChanges)
                {
                    message.AppendLine("✅ Los valores se han corregido automáticamente.");
                }
                
                Log($"⚙️ Validación de configuración: {errors.Count} errores, {warnings.Count} advertencias");
                
                // Solo mostrar diálogo si hay errores críticos
                if (errors.Count > 0)
                {
                    SafeInvoke(() =>
                    {
                        MessageBox.Show(message.ToString(), "Validación de Configuración",
                            MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    });
                }
            }
            
            return true; // Siempre retornar true después de corregir
        }
        
        // ═══════════════════════════════════════════════════════════
        // COMPARADOR PERSONALIZADO PARA LISTVIEW (CLASE ANIDADA)
        // ═══════════════════════════════════════════════════════════
        
        // Comparador personalizado para ListView (clase anidada dentro de MainForm)
        public class ListViewItemComparer : System.Collections.IComparer
        {
            private int col;
            private SortOrder order;
            private Func<ListViewItem, int, IComparable> customSortFunc;
            
            // Constructor original (2 argumentos) - para compatibilidad
            public ListViewItemComparer(int column, SortOrder order)
        {
            col = column;
            this.order = order;
            customSortFunc = null;
        }
            
        // Constructor mejorado (3 argumentos) - con función personalizada
        public ListViewItemComparer(int column, bool ascending, Func<ListViewItem, int, IComparable> sortFunc)
        {
            col = column;
            order = ascending ? SortOrder.Ascending : SortOrder.Descending;
            customSortFunc = sortFunc;
        }
            
        // Propiedades para actualizar dinámicamente
        public int ColumnIndex
        {
            get { return col; }
            set { col = value; }
        }
        
        public bool Ascending
        {
            get { return order == SortOrder.Ascending; }
            set { order = value ? SortOrder.Ascending : SortOrder.Descending; }
        }
            
        public int Compare(object x, object y)
        {
            int returnVal;
            
            var itemX = (ListViewItem)x;
            var itemY = (ListViewItem)y;
                
            // Si hay función personalizada, usarla
            if (customSortFunc != null)
            {
                try
                {
                    var valueX = customSortFunc(itemX, col);
                    var valueY = customSortFunc(itemY, col);
                    returnVal = valueX.CompareTo(valueY);
                }
                catch
                {
                    // Fallback a comparación de texto
                    returnVal = String.Compare(itemX.SubItems[col].Text, itemY.SubItems[col].Text);
                }
            }
            else
            {
                // Comparación estándar
                // Intentar comparar como números
                if (double.TryParse(itemX.SubItems[col].Text.Replace(" KB", "").Replace(" MB", "").Replace("%", "").Replace(",", ""), out double numX) &&
                    double.TryParse(itemY.SubItems[col].Text.Replace(" KB", "").Replace(" MB", "").Replace("%", "").Replace(",", ""), out double numY))
                {
                    returnVal = numX.CompareTo(numY);
                }
                else
                {
                    // Comparar como texto
                    returnVal = String.Compare(itemX.SubItems[col].Text, itemY.SubItems[col].Text);
                }
            }
                
            // Invertir si es descendente
            if (order == SortOrder.Descending)
                returnVal *= -1;
            
            return returnVal;
        }
    }  // Fin de clase anidada ListViewItemComparer
        
