        /// <summary>
        /// Actualiza los encabezados de columna con indicadores visuales de ordenamiento
        /// </summary>
        private void UpdateColumnHeaders(ListView listView, int sortColumn, SortOrder sortOrder)
        {
            if (listView == null || listView.Columns.Count == 0)
                return;
            
            // Obtener nombres originales de columnas según el ListView
            string[] columnNames = null;
            
            if (listView == lvResults)
            {
                columnNames = new[] { "Archivo", "Extensión", "Usuario", "Tamaño", "Velocidad", "Carpeta" };
            }
            else if (listView == lvDownloads)
            {
                columnNames = new[] { "Archivo", "Usuario", "Progreso", "Estado", "Tamaño", "Metadata" };
            }
            else if (listView == lvHistory)
            {
                columnNames = new[] { "Archivo", "Fecha", "Usuario", "Tamaño" };
            }
            else
            {
                // Para otros ListViews, usar los textos actuales sin modificar
                return;
            }
            
            // Actualizar cada columna
            for (int i = 0; i < listView.Columns.Count && i < columnNames.Length; i++)
            {
                string header = columnNames[i];
                
                // Agregar indicador si es la columna ordenada
                if (i == sortColumn && sortOrder != SortOrder.None)
                {
                    header += sortOrder == SortOrder.Ascending ? " ▲" : " ▼";
                }
                
                listView.Columns[i].Text = header;
            }
        }
        
        // ===== OPTIMIZACIONES RUST - MÉTODOS HELPER =====
        
        // Extensiones válidas para documentos (compartido)
        private static readonly List<string> validDocExtensions = new List<string>
        {
            "pdf", "epub", "mobi", "azw", "azw3", "djvu", "doc", "docx", 
            "txt", "rtf", "odt", "fb2", "lit", "pdb", "cbr", "cbz"
        };

        private static readonly HashSet<string> spanishKeywordSet = new HashSet<string>(
            new[] { "el", "la", "los", "las", "de", "del", "y", "que", "es", "español", "música", "libro", "autor", "año" },
            StringComparer.OrdinalIgnoreCase);

        private static readonly char[] wordSeparators = { ' ', ',', '.', ';', ':', '\n', '\r', '\t' };
        
        // Diccionario de CRC32 para deduplicación (complementa Bloom Filter)
        private readonly HashSet<uint> downloadedCRC32s = new HashSet<uint>();
        private readonly HashSet<uint> processedCRC32s = new HashSet<uint>();
        
        /// <summary>
        /// Verifica si un archivo tiene extensión válida usando Multi-Pattern Search (1000x más rápido)
        /// </summary>
        private bool HasValidExtension(string filename)
        {
            if (string.IsNullOrEmpty(filename))
                return false;
            
            if (!RustCore.IsAvailable())
            {
                // Fallback C#
                return validDocExtensions.Any(ext =>
                    filename.EndsWith($".{ext}", StringComparison.OrdinalIgnoreCase));
            }
            
            try
            {
                // Rust Aho-Corasick (1000x más rápido para múltiples patrones)
                var found = SlskDown.Core.RustCore.FindPatterns(filename.ToLowerInvariant(), validDocExtensions.ToList());
                return found != null && found.Count > 0;
            }
            catch
            {
                return validDocExtensions.Any(ext =>
                    filename.EndsWith($".{ext}", StringComparison.OrdinalIgnoreCase));
            }
        }
            
        /// <summary>
        /// Mejora de IsSpanishText usando Regex caché (50-100x más rápido)
        /// </summary>
        private bool IsSpanishTextOptimized(string filename)
        {
                if (string.IsNullOrEmpty(filename))
                    return false;
                
                if (!RustCore.IsAvailable())
                    return IsSpanishText(filename);  // Fallback al método existente
                
                try
                {
                    // Usar regex caché para patrones comunes españoles
                    // Este regex se compila una vez y se cachea automáticamente
                    return RustCore.RegexMatch(
                        @"(español|castellano|música|méxico|río|año|señor|niño|españa|español)",
                        filename.ToLowerInvariant()
                    );
                }
                catch
                {
                    return IsSpanishText(filename);
                }
            }
            
        /// <summary>
        /// Verifica si un archivo es duplicado usando Bloom Filter + CRC32
        /// </summary>
        private bool IsDuplicateFileOptimized(string filename, byte[] fileData = null)
        {
                if (string.IsNullOrEmpty(filename))
                    return false;
                
                // Nivel 1: Bloom Filter (nombre) - O(1), ~0.001 ms
                if (useBloomFilterForDedup && downloadedFilesBloomFilter >= 0)
                {
                    if (RustCore.BloomContains(downloadedFilesBloomFilter, filename))
                    {
                        // Probablemente duplicado (1% FPP)
                        
                        // Nivel 2: CRC32 (contenido) - O(n), pero muy rápido (1 ms para 1 MB)
                        if (fileData != null && RustCore.IsAvailable())
                        {
                            try
                            {
                                var crc = SlskDown.Core.RustCore.Crc32(fileData);
                                if (downloadedCRC32s.Contains(crc))
                                {
                                    return true;  // Duplicado confirmado por contenido
                                }
                                else
                                {
                                    // Falso positivo del Bloom Filter
                                    return !downloadedCRC32s.Add(crc);
                                }
                            }
                            catch
                            {
                                // Si falla CRC32, confiar en Bloom Filter
                                return true;
                            }
                        }
                        
                        return true;  // Sin datos de contenido, confiar en Bloom Filter
                    }
                }
                
                return false;
            }
            
        /// <summary>
        /// Verifica integridad de archivo descargado con CRC32 (40x más rápido que MD5)
        /// </summary>
        private async Task<bool> VerifyDownloadIntegrity(string filePath, uint expectedCrc32 = 0)
        {
            if (!System.IO.File.Exists(filePath))
                return true;  // No podemos verificar, asumir OK

            try
            {
                uint actualCrc32;
                using (var stream = new FileStream(
                           filePath,
                           FileMode.Open,
                           FileAccess.Read,
                           FileShare.Read,
                           bufferSize: 1024 * 1024,
                           options: FileOptions.SequentialScan))
                {
                    var buffer = new byte[1024 * 1024];
                    var crc = 0xFFFFFFFFu;
                    int read;
                    while ((read = await stream.ReadAsync(buffer, 0, buffer.Length).ConfigureAwait(false)) > 0)
                    {
                        crc = UpdateCrc32(crc, buffer, read);
                    }
                    actualCrc32 = ~crc;
                }

                var checksumsDir = Path.Combine(dataDir, "crc32");
                Directory.CreateDirectory(checksumsDir);
                var checksumKey = ComputeCrc32Key(filePath).ToString("X8");
                var checksumFile = Path.Combine(checksumsDir, checksumKey + ".crc32");
                await System.IO.File.WriteAllTextAsync(checksumFile, actualCrc32.ToString("X8")).ConfigureAwait(false);

                if (expectedCrc32 != 0 && actualCrc32 != expectedCrc32)
                {
                    Log($"⚠️ Integridad comprometida: {Path.GetFileName(filePath)}");
                    Log($"   CRC32 esperado: {expectedCrc32:X8}, obtenido: {actualCrc32:X8}");
                    return false;
                }

                // Agregar a conjunto de CRC32s descargados
                downloadedCRC32s.Add(actualCrc32);

                return true;
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error verificando integridad: {ex.Message}");
                return true;  // No fallar la descarga por error de verificación
            }
        }

        private static uint UpdateCrc32(uint crc, byte[] buffer, int count)
        {
            for (var i = 0; i < count; i++)
            {
                crc = (crc >> 8) ^ Crc32Table[(crc ^ buffer[i]) & 0xFF];
            }

            return crc;
        }

        private static uint ComputeCrc32Key(string value)
        {
            if (string.IsNullOrEmpty(value))
            {
                return 0;
            }

            var bytes = Encoding.UTF8.GetBytes(value);
            var crc = 0xFFFFFFFFu;
            crc = UpdateCrc32(crc, bytes, bytes.Length);
            return ~crc;
        }

        private static readonly uint[] Crc32Table = CreateCrc32Table();

        private static uint[] CreateCrc32Table()
        {
            var table = new uint[256];
            const uint polynomial = 0xEDB88320u;
            for (var i = 0; i < 256; i++)
            {
                var c = (uint)i;
                for (var j = 0; j < 8; j++)
                {
                    c = (c & 1) != 0 ? (polynomial ^ (c >> 1)) : (c >> 1);
                }
                table[i] = c;
            }

            return table;
        }
            
        /// <summary>
        /// Analiza descripción de archivo con tokenización (40x más rápido)
        /// </summary>
        private int CountSpanishWords(string text)
        {
            if (string.IsNullOrEmpty(text))
                return 0;

            if (!RustCore.IsAvailable())
            {
                var words = text.Split(wordSeparators, StringSplitOptions.RemoveEmptyEntries);
                return words.Count(w => spanishKeywordSet.Contains(w));
            }

            try
            {
                var words = RustCore.Tokenize(text);
                if (words == null) return 0;
                return words.Count(w => spanishKeywordSet.Contains(w));
            }
            catch
            {
                var words = text.Split(wordSeparators, StringSplitOptions.RemoveEmptyEntries);
                return words.Count(w => spanishKeywordSet.Contains(w));
            }
        }
            
        /// <summary>
        /// Codifica nombre de archivo para URL (20x más rápido)
        /// </summary>
        private string UrlEncodeFilename(string filename)
        {
            if (string.IsNullOrEmpty(filename))
                return filename;

            if (!RustCore.IsAvailable())
                return Uri.EscapeDataString(filename);

            try
            {
                return RustCore.UrlEncode(filename) ?? Uri.EscapeDataString(filename);
            }
            catch
            {
                return Uri.EscapeDataString(filename);
            }
        }
            
        /// <summary>
        /// Inicializa diccionarios de CRC32 con archivos ya descargados
        /// </summary>
        private async Task InitializeCRC32Cache()
        {
            if (!RustCore.IsAvailable() || !System.IO.Directory.Exists(downloadDir))
                return;
            
            try
            {
                var files = System.IO.Directory.GetFiles(downloadDir);
                int count = 0;
                
                await Task.Run(() =>
                {
                    foreach (var file in files)
                    {
                        try
                        {
                            var fileData = System.IO.File.ReadAllBytes(file);
                            var crc = SlskDown.Core.RustCore.Crc32(fileData);
                            downloadedCRC32s.Add(crc);
                            count++;
                        }
                        catch
                        {
                            // Ignorar errores en archivos individuales
                        }
                    }
                });
                
                if (count > 0)
                {
                    Log($"✅ Cache CRC32 inicializado: {count} archivos");
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error inicializando cache CRC32: {ex.Message}");
            }
        }
        
        private void ShowPerformanceDashboard()
        {
            try
            {
                if (performanceDashboard == null || performanceDashboard.IsDisposed)
                {
                    performanceDashboard = new PerformanceDashboard(performanceMetrics ?? new SlskDown.UI.PerformanceMetrics());
                }
                
                if (!performanceDashboard.Visible)
                {
                    performanceDashboard.Show();
                }
                else
                {
                    performanceDashboard.BringToFront();
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error mostrando dashboard: {ex.Message}");
            }
        }
        
        private async Task SaveSearchResultsBatchAsync(List<SearchResult> results)
        {
            if (batchInsertHelper == null || results == null || results.Count == 0)
                return;
                
            try
            {
                var records = results.Select(r => new Dictionary<string, object>
                {
                    ["filename"] = r.Filename ?? "",
                    ["size_bytes"] = r.SizeBytes,
                    ["username"] = r.Username ?? "",
                    ["search_query"] = r.Query ?? "",
                    ["timestamp"] = DateTime.UtcNow.ToString("o")
                }).ToList();
                
                var inserted = await batchInsertHelper.BatchInsertAsync(
                    "search_results",
                    records,
                    record => record
                );
                
                if (inserted > 0)
                {
                    Log($"💾 {inserted} resultados guardados en DB (batch)");
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error guardando resultados en batch: {ex.Message}");
            }
        }
        
        // ============================================================================
        // MEJORAS DE ESTABILIDAD Y EFICIENCIA
        // ============================================================================
        
        /// <summary>
        /// Actualiza el dashboard de rate limit en la UI
        /// </summary>
        private void UpdateRateLimitDashboard()
        {
            // Resetear cuota diaria si es un nuevo día
            if (DateTime.Now >= quotaResetTime)
            {
                searchesToday = 0;
                quotaResetTime = DateTime.Today.AddDays(1);
                searchTimestamps.Clear();
                Log($"✅ Cuota diaria reseteada - nuevo límite: {dailySearchQuota}");
            }
            
            // Limpiar timestamps antiguos (más de 1 minuto)
            var oneMinuteAgo = DateTime.UtcNow.AddMinutes(-1);
            searchTimestamps.RemoveAll(t => t < oneMinuteAgo);
            
            // Calcular búsquedas en el último minuto (real)
            var searchesLastMinute = searchTimestamps.Count;
            
            SafeInvoke(() =>
            {
                if (lblRateLimitStatus == null || lblDailyQuota == null)
                    return;
                
                // Actualizar indicador de rate limit
                var rateLimitPercent = (searchesLastMinute / (double)maxSearchesPerMinute) * 100;
                string rateLimitIcon = rateLimitPercent < 50 ? "🟢" : rateLimitPercent < 80 ? "🟡" : "🔴";
                var rateLimitColor = rateLimitPercent < 50 ? Color.LightGreen : rateLimitPercent < 80 ? Color.Yellow : Color.Red;
                
                lblRateLimitStatus.Text = $"{rateLimitIcon} {searchesLastMinute}/{maxSearchesPerMinute}/min";
                lblRateLimitStatus.ForeColor = rateLimitColor;
                
                // Actualizar indicador de cuota diaria
                var quotaPercent = (searchesToday / (double)dailySearchQuota) * 100;
                string quotaIcon = quotaPercent < 50 ? "📊" : quotaPercent < 80 ? "⚠️" : "🚫";
                var quotaColor = quotaPercent < 50 ? Color.LightGreen : quotaPercent < 80 ? Color.Yellow : Color.Red;
                
                lblDailyQuota.Text = $"{quotaIcon} {searchesToday}/{dailySearchQuota} hoy";
                lblDailyQuota.ForeColor = quotaColor;
            });
        }
        
        /// <summary>
        /// Registra una búsqueda y actualiza el dashboard
        /// </summary>
        private void TrackSearch()
        {
            // Registrar timestamp de búsqueda
            searchTimestamps.Add(DateTime.UtcNow);
            
            // Limpiar timestamps antiguos (más de 1 minuto)
            var oneMinuteAgo = DateTime.UtcNow.AddMinutes(-1);
            searchTimestamps.RemoveAll(t => t < oneMinuteAgo);
            
            searchesToday++;
            UpdateRateLimitDashboard();
            
            // Verificar si se alcanzó la cuota diaria
            if (searchesToday >= dailySearchQuota)
            {
                Log($"⚠️ Cuota diaria alcanzada ({searchesToday}/{dailySearchQuota})");
                SafeInvoke(() =>
                {
                    MessageBox.Show(
                        $"Has alcanzado la cuota diaria de búsquedas ({dailySearchQuota}).\n\n" +
                        "La cuota se resetea a medianoche.\n" +
                        "Considera usar un perfil más conservador.",
                        "Cuota diaria alcanzada",
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Warning);
                });
            }
        }
        
        /// <summary>
        /// Verifica si se puede realizar una búsqueda según modo nocturno
        /// </summary>
        private bool CanSearchInNightMode()
        {
            if (!nightModeEnabled)
                return true;
            
            var now = DateTime.Now.TimeOfDay;
            
            // Si el horario nocturno cruza medianoche (ej: 22:00 - 08:00)
            if (nightModeStart > nightModeEnd)
            {
                return now >= nightModeStart || now < nightModeEnd;
            }
            else
            {
                return now >= nightModeStart && now < nightModeEnd;
            }
        }
        
        /// <summary>
        /// Valida un archivo usando caché para evitar validaciones repetidas
        /// </summary>
        private bool ValidateFileWithCache(string filename, long size)
        {
            var cacheKey = $"{filename}_{size}";
            
            lock (validationCacheLock)
            {
                // Verificar si está en caché y no ha expirado
                if (validationCache.TryGetValue(cacheKey, out var cached))
                {
                    if (DateTime.Now - cached.timestamp < validationCacheExpiry)
                    {
                        return cached.isValid;
                    }
                    
                    // Expirado, remover
                    validationCache.Remove(cacheKey);
                }
            }
            
            // Validar y agregar a caché
            bool isValid = ValidateFile(filename, size);
            
            lock (validationCacheLock)
            {
                validationCache[cacheKey] = (isValid, DateTime.Now);
                
                // Limpiar caché si es muy grande (>10000 entradas)
                if (validationCache.Count > 10000)
                {
                    var expired = validationCache
                        .Where(kvp => DateTime.Now - kvp.Value.timestamp >= validationCacheExpiry)
                        .Select(kvp => kvp.Key)
                        .ToList();
                    
                    foreach (var key in expired)
                    {
                        validationCache.Remove(key);
                    }
                }
            }
            
            return isValid;
        }
        
        /// <summary>
        /// Validación básica de archivo (implementación placeholder)
        /// </summary>
        private bool ValidateFile(string filename, long size)
        {
            if (string.IsNullOrWhiteSpace(filename))
                return false;
            
            if (size <= 0)
                return false;
            
            // Validar extensión
            var ext = Path.GetExtension(filename)?.ToLowerInvariant();
            if (string.IsNullOrEmpty(ext))
                return false;
            
            // Lista de extensiones válidas (expandir según necesidad)
            var validExtensions = new[] { ".pdf", ".epub", ".mobi", ".azw3", ".txt", ".doc", ".docx", ".mp3", ".flac", ".mp4", ".mkv", ".avi" };
            
            return validExtensions.Contains(ext);
        }
        
        /// <summary>
        /// Aplica perfil de configuración (Conservador/Normal/Agresivo)
        /// </summary>
        private void ApplySearchProfile(string profile)
        {
            currentProfile = profile;
            
            switch (profile.ToLower())
            {
                case "conservador":
                    maxSearchesPerMinute = 15;
                    dailySearchQuota = 800;
                    Log("📊 Perfil Conservador: 15 búsq/min, 800/día");
                    break;
                    
                case "normal":
                    maxSearchesPerMinute = 30;
                    dailySearchQuota = 1200;
                    Log("📊 Perfil Normal: 30 búsq/min, 1200/día");
                    break;
                    
                case "agresivo":
                    maxSearchesPerMinute = 45;
                    dailySearchQuota = 1800;
                    Log("⚠️ Perfil Agresivo: 45 búsq/min, 1800/día (mayor riesgo de kicks)");
                    break;
                    
                default:
                    Log($"⚠️ Perfil desconocido: {profile}, usando Normal");
                    ApplySearchProfile("Normal");
                    return;
            }
            
            UpdateRateLimitDashboard();
        }
        
        /// <summary>
        /// Calcula el tiempo de espera con backoff exponencial mejorado
        /// </summary>
        private TimeSpan CalculateExponentialBackoff()
        {
            // Backoff exponencial: 2h, 4h, 8h, 16h (máx 24h)
            var hours = Math.Min(Math.Pow(2, reconnectAttempt), 24);
            return TimeSpan.FromHours(hours);
        }
        
        /// <summary>
        /// Agrupa autores similares para búsqueda por lotes
        /// </summary>
        private List<List<string>> GroupAuthorsForBatchSearch(List<string> authors)
        {
            var batches = new List<List<string>>();
            var currentBatch = new List<string>();
            
            foreach (var author in authors)
            {
                currentBatch.Add(author);
                
                // Agrupar en lotes de 3-5 autores
                if (currentBatch.Count >= 3)
                {
                    batches.Add(new List<string>(currentBatch));
                    currentBatch.Clear();
                }
            }
            
            // Agregar último lote si tiene elementos
            if (currentBatch.Count > 0)
            {
                batches.Add(currentBatch);
            }
            
            return batches;
        }
        
        /// <summary>
        /// Crea una búsqueda combinada para múltiples autores
        /// </summary>
        private string CreateBatchSearchQuery(List<string> authors)
        {
            // Combinar autores en una sola búsqueda usando OR
            // Ejemplo: "Charles Dickens" OR "Jane Austen" OR "Mark Twain"
            return string.Join(" OR ", authors.Select(a => $"\"{a}\""));
        }
        
        // ============================================================================
        // MÉTODOS AUXILIARES DE OPTIMIZACIÓN
        // ============================================================================
        
        /// <summary>
        /// Obtiene todas las tareas fallidas de la cola de descargas
        /// Optimización: Método común para evitar código duplicado
        /// </summary>
        private List<DownloadTask> GetFailedTasks()
        {
            return downloadQueueService?.Update(list =>
                list.Where(t => t.Status == DownloadStatus.Failed).ToList()) 
                ?? new List<DownloadTask>();
        }
        
        /// <summary>
        /// Obtiene todas las tareas pausadas de la cola de descargas
        /// Optimización: Método común para evitar código duplicado
        /// </summary>
        private List<DownloadTask> GetPausedTasks()
        {
            return downloadQueueService?.Update(list =>
                list.Where(t => t.Status == DownloadStatus.Paused).ToList()) 
                ?? new List<DownloadTask>();
        }
        
        /// <summary>
        /// Obtiene todas las tareas en cola (queued)
        /// Optimización: Método común para evitar código duplicado
        /// </summary>
        private List<DownloadTask> GetQueuedTasks()
        {
            return downloadQueueService?.Update(list =>
                list.Where(t => t.Status == DownloadStatus.Queued).ToList()) 
                ?? new List<DownloadTask>();
        }
        
        /// <summary>
        /// Limpia cachés si exceden el tamaño máximo
        /// Optimización: Prevenir memory leaks en cachés de autores canónicos
        /// </summary>
        private void CleanupCachesIfNeeded()
        {
            const int MAX_CACHE_SIZE = 10000;
            
            try
            {
                if (canonicalColorCache?.Count > MAX_CACHE_SIZE)
                {
                    canonicalColorCache.Clear();
                    Log($"🧹 Cache de colores limpiado ({MAX_CACHE_SIZE}+ entradas)");
                }
                
                if (canonicalMatchCache?.Count > MAX_CACHE_SIZE)
                {
                    canonicalMatchCache.Clear();
                    Log($"🧹 Cache de coincidencias limpiado ({MAX_CACHE_SIZE}+ entradas)");
                }
                
                if (canonicalPriorityScore?.Count > MAX_CACHE_SIZE)
                {
                    canonicalPriorityScore.Clear();
                    Log($"🧹 Cache de prioridades limpiado ({MAX_CACHE_SIZE}+ entradas)");
                }
                
                if (countryCache?.Count > MAX_CACHE_SIZE)
                {
                    countryCache.Clear();
                    Log($"🧹 Cache de países limpiado ({MAX_CACHE_SIZE}+ entradas)");
                }
            }
            catch (Exception ex)
            {
                Log($"⚠️ Error limpiando cachés: {ex.Message}");
            }
        }
        
        /// <summary>
        /// Sincroniza HashSet con List para búsquedas rápidas
        /// Optimización: Mantener searchHistorySet sincronizado con searchHistory
        /// </summary>
        private void SyncSearchHistorySet()
        {
            try
            {
                searchHistorySet.Clear();
                foreach (var item in searchHistory)
                {
                    searchHistorySet.Add(item);
                }
            }
            catch { }
        }
        
        /// <summary>
        /// Sincroniza HashSet con List para búsquedas rápidas
        /// Optimización: Mantener favoritesSet sincronizado con favorites
        /// </summary>
        private void SyncFavoritesSet()
        {
            try
            {
                favoritesSet.Clear();
                foreach (var item in favorites)
                {
                    favoritesSet.Add(item);
                }
            }
            catch { }
        }
    }
