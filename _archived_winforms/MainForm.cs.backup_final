        private static string ApplyAuthorAliasesToKey(string authorKey)
        {
            if (string.IsNullOrWhiteSpace(authorKey))
            {
                return string.Empty;
            }

            if (AuthorKeyAliasMap == null)
            {
                return authorKey;
            }

            return AuthorKeyAliasMap.TryGetValue(authorKey, out var mapped)
                ? mapped
                : authorKey;
        }

        private static string GetPreferredAuthorName(string authorKey, string fallback)
        {
            if (string.IsNullOrWhiteSpace(authorKey))
            {
                return fallback;
            }

            if (AuthorKeyPreferredNames == null)
            {
                return fallback;
            }

            return AuthorKeyPreferredNames.TryGetValue(authorKey, out var preferred)
                ? preferred
                : fallback;
        }

        private static string CanonicalizeAuthorKey(string value)
        {
            if (string.IsNullOrWhiteSpace(value))
            {
                return string.Empty;
            }

            var trimmed = value.Trim();
            var normalized = trimmed.Normalize(NormalizationForm.FormKC);

            var sb = new StringBuilder(normalized.Length);
            foreach (var ch in normalized)
            {
                var category = CharUnicodeInfo.GetUnicodeCategory(ch);
                if (category == UnicodeCategory.Control || category == UnicodeCategory.Format)
                {
                    continue;
                }

                sb.Append(ch switch
                {
                    'Α' => 'A',
                    'Β' => 'B',
                    'Ε' => 'E',
                    'Ζ' => 'Z',
                    'Η' => 'H',
                    'Ι' => 'I',
                    'Κ' => 'K',
                    'Μ' => 'M',
                    'Ν' => 'N',
                    'Ο' => 'O',
                    'Ρ' => 'P',
                    'Τ' => 'T',
                    'Υ' => 'Y',
                    'Χ' => 'X',
                    'а' => 'a',
                    'е' => 'e',
                    'о' => 'o',
                    'р' => 'p',
                    'с' => 'c',
                    'х' => 'x',
                    'у' => 'y',
                    'і' => 'i',
                    'А' => 'A',
                    'В' => 'B',
                    'Е' => 'E',
                    'К' => 'K',
                    'М' => 'M',
                    'Н' => 'H',
                    'О' => 'O',
                    'Р' => 'P',
                    'С' => 'C',
                    'Т' => 'T',
                    'Х' => 'X',
                    'У' => 'Y',
                    'І' => 'I',
                    'Ј' => 'J',
                    'ј' => 'j',
                    'ϲ' => 'c',
                    'ο' => 'o',
                    _ => ch
                });
            }

            var noMarks = sb.ToString().Normalize(NormalizationForm.FormKD);
            sb.Clear();
            foreach (var ch in noMarks)
            {
                var category = CharUnicodeInfo.GetUnicodeCategory(ch);
                if (category == UnicodeCategory.NonSpacingMark)
                {
                    continue;
                }

                if (char.IsLetterOrDigit(ch))
                {
                    sb.Append(char.ToLowerInvariant(ch));
                }
            }

            return sb.ToString();
        }

        private static string[] LoadCanonicalAuthors()
        {
            try
            {
                var baseDir = AppDomain.CurrentDomain.BaseDirectory;
                var canonicalPath = Path.Combine(baseDir, "Data", "canonical_authors_priority.txt");

                if (File.Exists(canonicalPath))
                {
                    var authors = new List<string>();
                    var seen = new HashSet<string>(StringComparer.Ordinal);

                    var fileNormalizedKeys = new List<string>();

                    foreach (var rawLine in File.ReadAllLines(canonicalPath))
                    {
                        var line = rawLine?.Trim();
                        if (string.IsNullOrWhiteSpace(line))
                        {
                            continue;
                        }

                        var key = CanonicalizeAuthorKey(line);
                        if (string.IsNullOrWhiteSpace(key))
                        {
                            continue;
                        }

                        fileNormalizedKeys.Add(key);

                        if (seen.Add(key))
                        {
                            authors.Add(line);
                        }
                    }

                    var authorArray = authors.ToArray();

                    if (authorArray.Length > 0)
                    {
                        var dedupedKeys = authorArray.Select(CanonicalizeAuthorKey).Where(k => !string.IsNullOrWhiteSpace(k)).ToArray();
                        var needsRewrite = fileNormalizedKeys.Count != dedupedKeys.Length;
                        if (!needsRewrite)
                        {
                            for (var i = 0; i < dedupedKeys.Length; i++)
                            {
                                if (!string.Equals(fileNormalizedKeys[i], dedupedKeys[i], StringComparison.Ordinal))
                                {
                                    needsRewrite = true;
                                    break;
                                }
                            }
                        }

                        if (needsRewrite)
                        {
                            File.WriteAllLines(canonicalPath, authorArray);
                        }

                        try
                        {
                            var countPath = Path.Combine(baseDir, "Data", "canonical_count.txt");
                            File.WriteAllText(countPath, authorArray.Length.ToString());
                        }
                        catch
                        {
                        }

                        return authorArray;
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[MainForm] Error cargando autores canónicos: {ex.Message}");
            }

            return new[]
            {
                "William Shakespeare",
                "León Tolstói",
                "Dante Alighieri",
                "Miguel de Cervantes",
                "Gabriel García Márquez",
                "Jorge Luis Borges",
                "Federico García Lorca",
                "Benito Pérez Galdós",
                "Lope de Vega",
                "Pedro Calderón de la Barca",
                "Pablo Neruda",
                "Mario Vargas Llosa",
                "Julio Cortázar",
                "Isabel Allende",
                "Fiódor Dostoyevski",
                "Charles Dickens",
                "Homero",
                "Víctor Hugo",
                "James Joyce",
                "Franz Kafka",
                "Johann Wolfgang von Goethe",
                "Jane Austen",
                "Honoré de Balzac",
                "Gustave Flaubert",
                "Edgar Allan Poe",
                "Herman Melville",
                "Antón Chéjov",
                "Marcel Proust",
                "Virginia Woolf",
                "Mark Twain"
            };
        }

        private async void MainForm_Shown(object sender, EventArgs e)
        {
            if (isShuttingDown || IsDisposed || Disposing)
            {
                return;
            }

            try
            {
                await Task.Run(async () => await LoadDownloadQueueAsync());
            }
            catch
            {
            }

            try
            {
                MarkDownloadsDirty();
                MarkDownloadStatsDirty();
            }
            catch
            {
            }

            try
            {
                StartRustWarmup();
            }
            catch
            {
            }
        }

        private void StartRustWarmup()
        {
            if (Interlocked.Exchange(ref rustWarmupStarted, 1) == 1)
            {
                return;
            }

            _ = Task.Run(() => RunRustWarmup());
        }

        private void RunRustWarmup()
        {
            try
            {
                _ = SlskDown.Core.RustAdvancedCore.IsAvailable();
            }
            catch
            {
            }

            try
            {
                _ = SlskDown.Core.RustAdvancedCore.NormalizeAuthorName("warmup");
            }
            catch
            {
            }

            try
            {
                _ = SlskNativeInterop.IsAvailable;
                if (SlskNativeInterop.IsAvailable)
                {
                    var warmupList = new List<SearchResultItem>(10);
                    for (int i = 0; i < 10; i++)
                    {
                        warmupList.Add(new SearchResultItem
                        {
                            Filename = $"warmup_{i}.epub",
                            Extension = ".epub",
                            Username = "warmup",
                            Size = 1024 + i,
                            QualityScore = 100 - i
                        });
                    }

                    _ = SlskNativeInterop.TrySortByQualityNativeTable(warmupList, out _);
                    _ = SlskNativeInterop.TryFilterSearchResultsNativeTable(
                        warmupList,
                        minSize: 0,
                        maxSize: long.MaxValue,
                        extensions: new List<string> { ".epub" },
                        spanishOnly: false,
                        minQuality: 0,
                        out _);
                    _ = SlskNativeInterop.TryProcessSearchResultsNativeTableInPlace(
                        warmupList,
                        minSize: 0,
                        maxSize: long.MaxValue,
                        extensions: new List<string> { ".epub" },
                        spanishOnly: false,
                        minQuality: 0,
                        getProviderScore: _ => 0);
                }
            }
            catch
            {
            }

            try
            {
                _ = RustFileOperations.IsAvailable();
            }
            catch
            {
            }
        }

