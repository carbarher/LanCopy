        private void AddToWishlist()
        {
            var dialog = new Form
            {
                Text = "Agregar a Lista de Deseos",
                Size = new Size(450, 280),
                StartPosition = FormStartPosition.CenterParent,
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.White,
                FormBorderStyle = FormBorderStyle.FixedDialog,
                MaximizeBox = false,
                MinimizeBox = false
            };
            
            var lblSearch = new Label { Text = "Término de búsqueda:", Location = new Point(20, 20), AutoSize = true, ForeColor = Color.White };
            var txtSearch = new TextBox { Location = new Point(20, 45), Size = new Size(400, 25), BackColor = Color.FromArgb(50, 50, 50), ForeColor = Color.White };
            
            var lblAuthor = new Label { Text = "Autor (opcional):", Location = new Point(20, 80), AutoSize = true, ForeColor = Color.White };
            var txtAuthor = new TextBox { Location = new Point(20, 105), Size = new Size(400, 25), BackColor = Color.FromArgb(50, 50, 50), ForeColor = Color.White };
            
            var lblNotes = new Label { Text = "Notas (opcional):", Location = new Point(20, 140), AutoSize = true, ForeColor = Color.White };
            var txtNotes = new TextBox { Location = new Point(20, 165), Size = new Size(400, 25), BackColor = Color.FromArgb(50, 50, 50), ForeColor = Color.White };
            
            var btnOk = new Button { Text = "Agregar", Location = new Point(250, 200), Size = new Size(80, 30), DialogResult = DialogResult.OK };
            var btnCancel = new Button { Text = "Cancelar", Location = new Point(340, 200), Size = new Size(80, 30), DialogResult = DialogResult.Cancel };
            
            dialog.Controls.AddRange(new Control[] { lblSearch, txtSearch, lblAuthor, txtAuthor, lblNotes, txtNotes, btnOk, btnCancel });
            dialog.AcceptButton = btnOk;
            dialog.CancelButton = btnCancel;
            
            if (dialog.ShowDialog() == DialogResult.OK && !string.IsNullOrWhiteSpace(txtSearch.Text))
            {
                var item = new WishlistItem
                {
                    SearchTerm = txtSearch.Text.Trim(),
                    Author = txtAuthor.Text.Trim(),
                    DateAdded = DateTime.Now,
                    Notes = txtNotes.Text.Trim(),
                    AutoSearch = true,
                    ItemType = "term"
                };
                
                wishlist.Add(item);
                SaveWishlist();
                RefreshWishlistUI(null, "");
                Log($"⭐ Agregado a wishlist: {item.SearchTerm}");
            }
        }
        
        private void RemoveFromWishlist()
        {
            var lvWishlist = FindWishlistView();
            if (lvWishlist == null || lvWishlist.SelectedItems.Count == 0) return;
            
            var selectedIndex = lvWishlist.SelectedIndices[0];
            if (selectedIndex >= 0 && selectedIndex < wishlist.Count)
            {
                var item = wishlist[selectedIndex];
                wishlist.RemoveAt(selectedIndex);
                SaveWishlist();
                RefreshWishlistUI(lvWishlist, "");
                Log($"🗑️ Eliminado de wishlist: {item.SearchTerm}");
            }
        }
        
        private async Task SearchWishlistItems()
        {
            if (wishlist.Count == 0)
            {
                MessageBox.Show("La lista de deseos está vacía.", "Wishlist", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }
            
            // CRÍTICO: Limitar a máximo 10 items por sesión para evitar flood
            var itemsToSearch = wishlist
                .Where(i => i.AutoSearch)
                .Where(i =>
                {
                    if (chkCanonicalOnly?.Checked != true)
                    {
                        return true;
                    }

                    if (!string.Equals(i.ItemType, "author", StringComparison.OrdinalIgnoreCase))
                    {
                        return true;
                    }

                    var author = string.IsNullOrWhiteSpace(i.Author) ? i.SearchTerm : i.Author;
                    return !string.IsNullOrWhiteSpace(author) && IsCanonicalAuthorName(author);
                })
                .Take(10) // Límite de seguridad
                .ToList();
            
            Log($"🔍 Buscando {itemsToSearch.Count}/{wishlist.Count(i => i.AutoSearch)} item(s) de la wishlist (máx 10)...");
            
            foreach (var item in itemsToSearch)
            {
                try
                {
                    Log($"🔍 Buscando: {item.SearchTerm}");
                    item.LastSearched = DateTime.Now;
                    
                    // ⚡ CRÍTICO: Aplicar rate limiter para evitar bypass
                    await WaitForRateLimitAsync("wishlist");
                    
                    var searchClient = client;
                    var searchResults = await searchClient.SearchAsync(
                        SearchQuery.FromText(item.SearchTerm),
                        options: new Soulseek.SearchOptions(
                            searchTimeout: 10000, // Reducido de 15s a 10s
                            filterResponses: true,
                            minimumResponseFileCount: 1
                        )
                    );

                    if (string.Equals(item.ItemType, "author", StringComparison.OrdinalIgnoreCase))
                    {
                        int addedNew = 0;
                        foreach (var response in searchResults.Responses)
                        {
                            foreach (var file in response.Files)
                            {
                                var fileName = Path.GetFileName(file.Filename ?? string.Empty);
                                if (string.IsNullOrWhiteSpace(fileName))
                                {
                                    continue;
                                }

                                if (!IsDocumentFile(fileName))
                                {
                                    continue;
                                }

                                if (file.Size == 0)
                                {
                                    continue;
                                }

                                var key = DedupeKeyHelpers.BuildProviderFileKey(fileName, response.Username, file.Size, normalizeFileName: true);
                                if (item.SeenKeys != null && item.SeenKeys.Contains(key))
                                {
                                    continue;
                                }

                                if (IsAlreadyDownloaded(fileName, response.Username, file.Size))
                                {
                                    continue;
                                }

                                item.SeenKeys ??= new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                                item.SeenKeys.Add(key);

                                var detectionText = Path.GetFileNameWithoutExtension(fileName);
                                if (string.IsNullOrWhiteSpace(detectionText))
                                {
                                    detectionText = fileName;
                                }

                                var newFile = new AutoSearchFileResult
                                {
                                    Author = item.Author ?? item.SearchTerm,
                                    Username = response.Username,
                                    FileName = fileName,
                                    Directory = Path.GetDirectoryName(file.Filename) ?? string.Empty,
                                    SizeBytes = file.Size,
                                    SizeReadable = FormatFileSize(file.Size),
                                    IsSpanish = IsSpanishText(detectionText, allowRust: false),
                                    IsDocument = true,
                                    Timestamp = DateTime.Now
                                };

                                lock (autoSearchResultsLock)
                                {
                                    autoSearchResults.Add(newFile);
                                }

                                addedNew++;
                            }
                        }

                        item.TimesFound += addedNew;
                        Log(addedNew > 0
                            ? $"🆕 {addedNew} novedad(es) para autor validado: {item.SearchTerm}"
                            : $"✅ Sin novedades para: {item.SearchTerm}");
                    }
                    else
                    {
                        int foundCount = searchResults.Responses.Sum(r => r.Files.Count());
                        item.TimesFound += foundCount;
                        if (foundCount > 0)
                        {
                            Log($"✅ Encontrados {foundCount} archivo(s) para: {item.SearchTerm}");
                        }
                        else
                        {
                            Log($"❌ No se encontraron resultados para: {item.SearchTerm}");
                        }
                    }
                    
                    // ⚡ CORREGIDO: De 1000ms a 2000ms (consistente con otras búsquedas)
                    await Task.Delay(2000);
                }
                catch (Exception ex)
                {
                    Log($"❌ Error buscando {item.SearchTerm}: {ex.Message}");
                }
            }
            
            SaveWishlist();
            RefreshWishlistUI(null, "");
            Log($"✅ Búsqueda de wishlist completada ({itemsToSearch.Count} items buscados)");
        }

        private void ValidateCheckedAuthorsAsValidated()
        {
            try
            {
                LoadWishlist();
            }
            catch
            {
            }

            var source = filteredAuthorsData != null && filteredAuthorsData.Count > 0
                ? filteredAuthorsData
                : allAuthorsData;

            if (source == null || source.Count == 0)
            {
                AutoLog("⚠️ No hay autores para validar");
                return;
            }

            var authorsToAdd = source
                .Where(a => a != null && a.IsChecked)
                .Select(a => a.Name)
                .Where(name => !string.IsNullOrWhiteSpace(name))
                .Select(name => name.Trim())
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (authorsToAdd.Count == 0)
            {
                AutoLog("⚠️ No hay autores marcados para validar");
                return;
            }

            int added = 0;
            foreach (var author in authorsToAdd)
            {
                bool exists = wishlist.Any(w =>
                    string.Equals(w.ItemType, "author", StringComparison.OrdinalIgnoreCase) &&
                    (string.Equals(w.SearchTerm, author, StringComparison.OrdinalIgnoreCase) ||
                     string.Equals(w.Author, author, StringComparison.OrdinalIgnoreCase)));

                if (exists)
                {
                    continue;
                }

                wishlist.Add(new WishlistItem
                {
                    SearchTerm = author,
                    Author = author,
                    DateAdded = DateTime.Now,
                    Notes = "Validado",
                    AutoSearch = true,
                    ItemType = "author",
                    SeenKeys = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                });
                added++;
            }

            SaveWishlist();
            RefreshWishlistUI(null, "");
            AutoLog($"⭐ Autores validados añadidos: {added:N0} (seleccionados: {authorsToAdd.Count:N0})");
        }

        private async Task SearchValidatedAuthorsNewWorksAsync()
        {
            if (wishlist == null || wishlist.Count == 0)
            {
                LoadWishlist();
            }

            var validated = wishlist
                .Where(i => i.AutoSearch)
                .Where(i => string.Equals(i.ItemType, "author", StringComparison.OrdinalIgnoreCase))
                .ToList();

            if (chkCanonicalOnly?.Checked == true)
            {
                var before = validated.Count;
                validated = validated
                    .Where(i =>
                    {
                        var author = string.IsNullOrWhiteSpace(i.Author) ? i.SearchTerm : i.Author;
                        return !string.IsNullOrWhiteSpace(author) && IsCanonicalAuthorName(author);
                    })
                    .ToList();

                if (before > 0 && validated.Count != before)
                {
                    Log($"⭐ Solo priorizados (validados): {validated.Count}/{before} autor(es)");
                }
            }

            if (validated.Count == 0)
            {
                Log("⚠️ No hay autores validados en la wishlist (ItemType=author)");
                return;
            }

            int totalNew = 0;
            Log($"🆕 Revisando novedades de {validated.Count} autor(es) validados...");

            foreach (var item in validated)
            {
                try
                {
                    item.LastSearched = DateTime.Now;
                    await WaitForRateLimitAsync("validated-authors");

                    var searchClient = client;
                    var query = string.IsNullOrWhiteSpace(item.SearchTerm) ? item.Author : item.SearchTerm;
                    if (string.IsNullOrWhiteSpace(query))
                    {
                        continue;
                    }

                    var searchResults = await searchClient.SearchAsync(
                        SearchQuery.FromText(query),
                        options: new Soulseek.SearchOptions(
                            searchTimeout: 10000,
                            filterResponses: true,
                            minimumResponseFileCount: 1
                        )
                    );

                    int addedNew = 0;
                    foreach (var response in searchResults.Responses)
                    {
                        foreach (var file in response.Files)
                        {
                            var fileName = Path.GetFileName(file.Filename ?? string.Empty);
                            if (string.IsNullOrWhiteSpace(fileName))
                            {
                                continue;
                            }

                            if (!IsDocumentFile(fileName))
                            {
                                continue;
                            }

                            if (file.Size == 0)
                            {
                                continue;
                            }

                            var key = DedupeKeyHelpers.BuildProviderFileKey(fileName, response.Username, file.Size, normalizeFileName: true);
                            item.SeenKeys ??= new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                            if (item.SeenKeys.Contains(key))
                            {
                                continue;
                            }

                            if (IsAlreadyDownloaded(fileName, response.Username, file.Size))
                            {
                                continue;
                            }

                            item.SeenKeys.Add(key);

                            var detectionText = Path.GetFileNameWithoutExtension(fileName);
                            if (string.IsNullOrWhiteSpace(detectionText))
                            {
                                detectionText = fileName;
                            }

                            var newFile = new AutoSearchFileResult
                            {
                                Author = item.Author ?? item.SearchTerm,
                                Username = response.Username,
                                FileName = fileName,
                                Directory = Path.GetDirectoryName(file.Filename) ?? string.Empty,
                                SizeBytes = file.Size,
                                SizeReadable = FormatFileSize(file.Size),
                                IsSpanish = IsSpanishText(detectionText, allowRust: false),
                                IsDocument = true,
                                Timestamp = DateTime.Now
                            };

                            lock (autoSearchResultsLock)
                            {
                                autoSearchResults.Add(newFile);
                            }

                            addedNew++;
                        }
                    }

                    item.TimesFound += addedNew;
                    totalNew += addedNew;

                    Log(addedNew > 0
                        ? $"🆕 {addedNew} novedad(es): {query}"
                        : $"✅ Sin novedades: {query}");

                    await Task.Delay(2000);
                }
                catch (Exception ex)
                {
                    Log($"❌ Error revisando novedades ({item.SearchTerm}): {ex.Message}");
                }
            }

            SaveWishlist();
            RefreshWishlistUI(null, "");
            Log($"✅ Revisión completada. Novedades totales: {totalNew}");
        }
        
        private void LoadWishlist()
        {
            try
            {
                if (System.IO.File.Exists(wishlistPath))
                {
                    var json = System.IO.File.ReadAllText(wishlistPath);
                    wishlist = JsonSerializer.Deserialize<List<WishlistItem>>(json) ?? new List<WishlistItem>();
                    Log($"📋 Wishlist cargada: {wishlist.Count} item(s)");
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error cargando wishlist: {ex.Message}");
            }
        }
        
        private void SaveWishlist()
        {
            try
            {
                var options = new JsonSerializerOptions { WriteIndented = true };
                var json = JsonSerializer.Serialize(wishlist, options);
                System.IO.File.WriteAllText(wishlistPath, json);
            }
            catch (Exception ex)
            {
                Log($"❌ Error guardando wishlist: {ex.Message}");
            }
        }
        
        private void UpdateWishlistUI(string filterText)
        {
            if (lvWishlist == null)
            {
                lvWishlist = FindWishlistView();
            }

            var wishlistView = lvWishlist;
            if (wishlistView == null)
            {
                return;
            }

            SafeInvoke(() =>
            {
                wishlistView.BeginUpdate();
                try
                {
                    wishlistView.Items.Clear();

                    IEnumerable<WishlistItem> filteredItems = wishlist;

                    if (!string.IsNullOrWhiteSpace(filterText))
                    {
                        var filter = filterText.Trim();
                        filteredItems = filteredItems.Where(item =>
                            (!string.IsNullOrEmpty(item.SearchTerm) && item.SearchTerm.IndexOf(filter, StringComparison.OrdinalIgnoreCase) >= 0) ||
                            (!string.IsNullOrEmpty(item.Author) && item.Author.IndexOf(filter, StringComparison.OrdinalIgnoreCase) >= 0) ||
                            (!string.IsNullOrEmpty(item.Notes) && item.Notes.IndexOf(filter, StringComparison.OrdinalIgnoreCase) >= 0));
                    }

                    var filteredList = filteredItems as IList<WishlistItem> ?? filteredItems.ToList();
                    if (filteredList.Count == 0)
                    {
                        return;
                    }

                    var listItems = new ListViewItem[filteredList.Count];
                    for (int i = 0; i < filteredList.Count; i++)
                    {
                        var item = filteredList[i];
                        var listItem = new ListViewItem(item.SearchTerm ?? string.Empty)
                        {
                            Tag = item
                        };

                        listItem.SubItems.Add(item.Author ?? "-");
                        listItem.SubItems.Add(item.DateAdded.ToString("dd/MM/yyyy"));
                        listItem.SubItems.Add(item.LastSearched?.ToString("dd/MM/yyyy HH:mm") ?? "Nunca");
                        listItem.SubItems.Add(item.TimesFound.ToString());
                        listItem.SubItems.Add(item.AutoSearch ? "Sí" : "No");
                        listItem.SubItems.Add(item.Notes ?? "-");

                        listItems[i] = listItem;
                    }

                    wishlistView.Items.AddRange(listItems);
                }
                finally
                {
                    wishlistView.EndUpdate();
                }
            });
        }
        
        private ListView FindWishlistView()
        {
            foreach (TabPage tab in tabControl.TabPages)
            {
                if (tab.Text.Contains("Lista de Deseos"))
                {
                    return FindControlRecursive<ListView>(tab, "wishlistView");
                }
            }
            return null;
        }
        
        private T FindControlRecursive<T>(Control parent, string tag) where T : Control
        {
            foreach (Control ctrl in parent.Controls)
            {
                if (ctrl is T && ctrl.Tag?.ToString() == tag)
                    return (T)ctrl;
                    
                var found = FindControlRecursive<T>(ctrl, tag);
                if (found != null)
                    return found;
            }
            return null;
        }
        
        private void StartWishlistTimer()
        {
            if (wishlistSearchTimer == null)
            {
                wishlistSearchTimer = new System.Windows.Forms.Timer();
                wishlistSearchTimer.Interval = wishlistSearchIntervalMinutes * 60 * 1000;
                wishlistSearchTimer.Tick += async (s, e) => await SearchWishlistItems();
            }
            
            wishlistSearchTimer.Start();
            Log($"⏰ Timer de wishlist iniciado (cada {wishlistSearchIntervalMinutes} min)");
        }
        
        private void StopWishlistTimer()
        {
            wishlistSearchTimer?.Stop();
            Log("⏸️ Timer de wishlist detenido");
        }
        
        // ═══════════════════════════════════════════════════════════
        // VELOCIDAD ADAPTATIVA
        // ═══════════════════════════════════════════════════════════
        
        private void UpdateAdaptiveSpeed(double speedMBps)
        {
            lock (recentSpeeds)
            {
                recentSpeeds.Add(speedMBps);
                
                // Mantener solo las últimas N velocidades
                if (recentSpeeds.Count > SPEED_HISTORY_SIZE)
                {
                    recentSpeeds.RemoveAt(0);
                }
                
                // Calcular velocidad promedio
                averageDownloadSpeed = recentSpeeds.Average();
                
                // Ajustar descargas paralelas según velocidad
                AdjustParallelDownloads();
            }
        }
        
        private void AdjustParallelDownloads()
        {
            if (!adaptiveSpeed) return;

            double failureRatio = GetRecentFailureRatio();

            int activeDownloads;
            int queuedDownloads;

            lock (downloadQueueLock)
            {
                activeDownloads = downloadQueue.Count(t => t.Status == DownloadStatus.Downloading);
                queuedDownloads = downloadQueue.Count(t => t.Status == DownloadStatus.Queued);
            }

            bool hasDemand = queuedDownloads > 0 || activeDownloads >= maxParallelDownloads;
            bool highSpeed = averageDownloadSpeed >= SPEED_INCREASE_THRESHOLD;
            bool lowSpeed = averageDownloadSpeed <= SPEED_DECREASE_THRESHOLD;
            bool lowFailure = failureRatio <= RETRY_SAFE_THRESHOLD;
            bool highFailure = failureRatio >= RETRY_DECREASE_THRESHOLD;

            if (hasDemand && highSpeed && lowFailure)
            {
                adaptiveIncreaseVotes++;
                adaptiveDecreaseVotes = Math.Max(0, adaptiveDecreaseVotes - 1);
            }
            else if (highFailure || lowSpeed)
            {
                adaptiveDecreaseVotes++;
                adaptiveIncreaseVotes = Math.Max(0, adaptiveIncreaseVotes - 1);
            }
            else
            {
                if (adaptiveIncreaseVotes > 0) adaptiveIncreaseVotes--;
                if (adaptiveDecreaseVotes > 0) adaptiveDecreaseVotes--;
            }

            bool cooldownElapsed = (DateTime.Now - lastParallelAdjustment).TotalSeconds >= ADAPTIVE_ADJUSTMENT_COOLDOWN_SECONDS;
            int newMaxParallel = maxParallelDownloads;

            if (cooldownElapsed && adaptiveIncreaseVotes >= ADAPTIVE_VOTE_THRESHOLD && maxParallelDownloads < MAX_ADAPTIVE_PARALLEL)
            {
                newMaxParallel = Math.Min(maxParallelDownloads + 1, MAX_ADAPTIVE_PARALLEL);
                adaptiveIncreaseVotes = 0;
                adaptiveDecreaseVotes = 0;
                lastParallelAdjustment = DateTime.Now;
                Log($"🚀 Ajuste adaptativo: +1 slot (Velocidad {averageDownloadSpeed:F2} MB/s, fallos {failureRatio:P0})");
            }
            else if (cooldownElapsed && adaptiveDecreaseVotes >= ADAPTIVE_VOTE_THRESHOLD && maxParallelDownloads > MIN_ADAPTIVE_PARALLEL)
            {
                newMaxParallel = Math.Max(maxParallelDownloads - 1, MIN_ADAPTIVE_PARALLEL);
                adaptiveIncreaseVotes = 0;
                adaptiveDecreaseVotes = 0;
                lastParallelAdjustment = DateTime.Now;
                Log($"🐢 Ajuste adaptativo: -1 slot (Velocidad {averageDownloadSpeed:F2} MB/s, fallos {failureRatio:P0})");
            }

            if (newMaxParallel != maxParallelDownloads)
            {
                CommitParallelDownloadLimit(newMaxParallel);
            }
        }

        private void RecordDownloadOutcome(bool success)
        {
            lock (recentDownloadOutcomes)
            {
                recentDownloadOutcomes.Enqueue(success);
                while (recentDownloadOutcomes.Count > MAX_OUTCOME_HISTORY)
                {
                    recentDownloadOutcomes.Dequeue();
                }
            }
        }

        private double GetRecentFailureRatio()
        {
            lock (recentDownloadOutcomes)
            {
                if (recentDownloadOutcomes.Count == 0)
                    return 0;

                int failures = 0;
                foreach (var outcome in recentDownloadOutcomes)
                {
                    if (!outcome)
                    {
                        failures++;
                    }
                }
                return failures / (double)recentDownloadOutcomes.Count;
            }
        }
        
