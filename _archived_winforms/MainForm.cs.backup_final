            {
                Size = new Size(200, 25),
                BackColor = Color.FromArgb(50, 50, 50),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                PlaceholderText = "🔍 Filtrar...",
                Margin = new Padding(10, 5, 0, 0)
            };
            
            topPanel.Controls.Add(btnAdd);
            topPanel.Controls.Add(btnRemove);
            topPanel.Controls.Add(btnSearchNow);
            topPanel.Controls.Add(btnCheckValidated);
            topPanel.Controls.Add(chkAutoSearch);
            topPanel.Controls.Add(txtWishlistSearch);
            
            // ListView para mostrar items de wishlist
