            {
                Dock = DockStyle.Fill,
                View = View.Details,
                FullRowSelect = true,
                GridLines = true,
                VirtualMode = false,
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                BorderStyle = BorderStyle.None
            };
            
            lvWishlist.Columns.Add("Término de Búsqueda", 250);
            lvWishlist.Columns.Add("Autor", 150);
            lvWishlist.Columns.Add("Agregado", 120);
            lvWishlist.Columns.Add("Última Búsqueda", 120);
            lvWishlist.Columns.Add("Encontrados", 80);
            lvWishlist.Columns.Add("Auto", 60);
            lvWishlist.Columns.Add("Notas", 200);
            
            // Cargar wishlist
            LoadWishlist();
            RefreshWishlistUI(lvWishlist, "");
            
            // Búsqueda incremental
            txtWishlistSearch.TextChanged += (s, e) =>
            {
                RefreshWishlistUI(lvWishlist, txtWishlistSearch.Text);
            };
            
            // Guardar referencia al ListView
            lvWishlist.Tag = "wishlistView";

            this.lvWishlist = lvWishlist;
            
            mainPanel.Controls.Add(lvWishlist);
            mainPanel.Controls.Add(topPanel);
            parent.Controls.Add(mainPanel);
            
            // Iniciar timer si está habilitado
            if (wishlistAutoSearchEnabled)
            {
                StartWishlistTimer();
            }
        }

        private void CreateSeriesTab(TabPage parent)
        {
            parent.BackColor = Color.FromArgb(18, 18, 18);
            
            var mainLayout = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 1,
                RowCount = 3,
                Padding = new Padding(10),
                BackColor = Color.FromArgb(18, 18, 18)
            };
            mainLayout.RowStyles.Add(new RowStyle(SizeType.Absolute, 60)); // Botones
            mainLayout.RowStyles.Add(new RowStyle(SizeType.Percent, 100)); // Lista de series
            mainLayout.RowStyles.Add(new RowStyle(SizeType.Absolute, 150)); // Log
            
            // Panel de botones
            var btnPanel = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                FlowDirection = FlowDirection.LeftToRight,
                BackColor = Color.FromArgb(30, 30, 30),
                Padding = new Padding(5)
            };
            
            var btnScanLibrary = CreateButton("🔍 Escanear Biblioteca", Color.FromArgb(0, 120, 215));
            var btnSearchMissing = CreateButton("🔎 Buscar Faltantes", Color.FromArgb(0, 150, 0));
            var btnRefresh = CreateButton("🔄 Actualizar", Color.FromArgb(100, 100, 100));
            var btnExport = CreateButton("💾 Exportar", Color.FromArgb(150, 100, 0));
            
            btnPanel.Controls.Add(btnScanLibrary);
            btnPanel.Controls.Add(btnSearchMissing);
            btnPanel.Controls.Add(btnRefresh);
            btnPanel.Controls.Add(btnExport);
            
            mainLayout.Controls.Add(btnPanel, 0, 0);
            
            // ListView para mostrar series
            var lvSeries = new ListView
            {
                Dock = DockStyle.Fill,
                View = View.Details,
                FullRowSelect = true,
                GridLines = true,
                VirtualMode = false,
                BackColor = Color.FromArgb(30, 30, 30),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 9),
                BorderStyle = BorderStyle.None,
                CheckBoxes = true
            };
            
            lvSeries.Columns.Add("Serie", 300);
            lvSeries.Columns.Add("Autor", 150);
            lvSeries.Columns.Add("Progreso", 100);
            lvSeries.Columns.Add("Faltantes", 80);
            lvSeries.Columns.Add("Estado", 100);
            
            mainLayout.Controls.Add(lvSeries, 0, 1);
            
            // TextBox de log
            var txtSeriesLog = new TextBox
            {
                Dock = DockStyle.Fill,
                Multiline = true,
                ReadOnly = true,
                BackColor = Color.FromArgb(20, 20, 20),
                ForeColor = Color.LightGray,
                Font = new Font("Consolas", 9),
                BorderStyle = BorderStyle.None,
                ScrollBars = ScrollBars.Vertical
            };
            
            mainLayout.Controls.Add(txtSeriesLog, 0, 2);
            
            // Helper para log
            void LogSeries(string message)
            {
                SafeInvoke(() =>
                {
                    txtSeriesLog.AppendText($"[{DateTime.Now:HH:mm:ss}] {message}\r\n");
                    txtSeriesLog.SelectionStart = txtSeriesLog.Text.Length;
                    txtSeriesLog.ScrollToCaret();
                });
            }
            
            // Evento: Escanear biblioteca
            btnScanLibrary.Click += async (s, e) =>
            {
                try
                {
                    btnScanLibrary.Enabled = false;
                    LogSeries("🔍 Escaneando biblioteca...");
                    
                    // Obtener todos los archivos descargados
                    var downloadedFiles = new List<string>();
                    
                    if (System.IO.Directory.Exists(downloadDir))
                    {
                        var files = System.IO.Directory.GetFiles(downloadDir, "*.*", SearchOption.AllDirectories)
                            .Where(f => f.EndsWith(".epub", StringComparison.OrdinalIgnoreCase) ||
                                       f.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) ||
                                       f.EndsWith(".mobi", StringComparison.OrdinalIgnoreCase))
                            .Select(f => Path.GetFileName(f))
                            .ToList();
                        
                        downloadedFiles.AddRange(files);
                    }
                    
                    LogSeries($"📚 Encontrados {downloadedFiles.Count} libros");
                    
                    // Detectar series
                    var seriesList = SeriesDetector.DetectSeries(downloadedFiles);
                    
                    LogSeries($"📊 Detectadas {seriesList.Count} series");
                    
                    // Actualizar ListView
                    lvSeries.Items.Clear();
                    
                    foreach (var series in seriesList)
                    {
                        var item = new ListViewItem(series.SeriesName);
                        item.SubItems.Add(series.Author);
                        item.SubItems.Add($"{series.DownloadedBooks}/{series.TotalBooks} ({series.CompletionPercentage:F0}%)");
                        item.SubItems.Add(series.MissingNumbers.Count.ToString());
                        item.SubItems.Add(series.IsComplete ? "✅ Completa" : "⚠️ Incompleta");
                        item.Tag = series;
                        
                        // Marcar incompletas
                        if (!series.IsComplete)
                        {
                            item.ForeColor = Color.Yellow;
                        }
                        
                        lvSeries.Items.Add(item);
                    }
                    
                    LogSeries($"✅ Escaneo completado");
                    
                    // Mostrar resumen
                    var incomplete = seriesList.Count(s => !s.IsComplete);
                    if (incomplete > 0)
                    {
                        LogSeries($"⚠️ {incomplete} series incompletas encontradas");
                    }
                }
                catch (Exception ex)
                {
                    LogSeries($"❌ Error: {ex.Message}");
                }
                finally
                {
                    btnScanLibrary.Enabled = true;
                }
            };
            
            // Evento: Buscar faltantes
            btnSearchMissing.Click += async (s, e) =>
            {
                try
                {
                    var checkedSeries = lvSeries.CheckedItems.Cast<ListViewItem>()
                        .Select(i => i.Tag as SeriesDetector.SeriesInfo)
                        .Where(s => s != null && !s.IsComplete)
                        .ToList();
                    
                    if (checkedSeries.Count == 0)
                    {
                        LogSeries("⚠️ Selecciona series incompletas para buscar");
                        return;
                    }
                    
                    btnSearchMissing.Enabled = false;
                    LogSeries($"🔎 Buscando libros faltantes de {checkedSeries.Count} series...");
                    
                    foreach (var series in checkedSeries)
                    {
                        LogSeries($"📖 Serie: {series.SeriesName} - Faltan: {string.Join(", ", series.MissingNumbers)}");
                        
                        var searchTerms = SeriesDetector.GenerateSearchTerms(series);
                        
                        foreach (var term in searchTerms.Take(3)) // Limitar a 3 búsquedas por serie
                        {
                            LogSeries($"   🔍 Buscando: {term}");
                            
                            // Agregar a la cola de búsqueda
                            // SafeInvoke(() =>
                            // {
                            //     if (txtSearch != null)
                            //     {
                            //         txtSearch.Text = term;
                            //     }
                            // });
                            
                            await Task.Delay(2000); // Pausa entre búsquedas (aumentado para evitar flood)
                        }
                    }
                    
                    LogSeries($"✅ Búsqueda completada");
                }
                catch (Exception ex)
                {
                    LogSeries($"❌ Error: {ex.Message}");
                }
                finally
                {
                    btnSearchMissing.Enabled = true;
                }
            };
            
            // Evento: Actualizar
            btnRefresh.Click += (s, e) =>
            {
                btnScanLibrary.PerformClick();
            };
            
            // Evento: Exportar
            btnExport.Click += (s, e) =>
            {
                try
                {
                    var seriesList = lvSeries.Items.Cast<ListViewItem>()
                        .Select(i => i.Tag as SeriesDetector.SeriesInfo)
                        .Where(s => s != null)
                        .ToList();
                    
                    if (seriesList.Count == 0)
                    {
                        LogSeries("⚠️ No hay series para exportar");
                        return;
                    }
                    
                    var exportPath = Path.Combine(dataDir, "series_report.txt");
                    var lines = new List<string>();
                    
                    lines.Add("═══════════════════════════════════════════════════════");
                    lines.Add($"REPORTE DE SERIES - {DateTime.Now:dd/MM/yyyy HH:mm}");
                    lines.Add("═══════════════════════════════════════════════════════");
                    lines.Add("");
                    
                    foreach (var series in seriesList.OrderBy(s => s.Author).ThenBy(s => s.SeriesName))
                    {
                        lines.Add(SeriesDetector.FormatSeriesInfo(series));
                        
                        if (!series.IsComplete)
                        {
                            lines.Add($"  → Términos de búsqueda:");
                            var terms = SeriesDetector.GenerateSearchTerms(series);
                            foreach (var term in terms.Take(3))
                            {
                                lines.Add($"     • {term}");
                            }
                        }
                        
                        lines.Add("");
                    }
                    
                    System.IO.File.WriteAllLines(exportPath, lines);
                    LogSeries($"💾 Reporte exportado: {exportPath}");
                    
                    System.Diagnostics.Process.Start("notepad.exe", exportPath);
                }
                catch (Exception ex)
                {
                    LogSeries($"❌ Error exportando: {ex.Message}");
                }
            };
            
            parent.Controls.Add(mainLayout);
            
            LogSeries("📚 Pestaña de Series lista");
            LogSeries("💡 Haz clic en 'Escanear Biblioteca' para comenzar");
        }

        private Task StartDownloadManager()
        {
            if (downloadManager == null)
            {
                return Task.CompletedTask;
            }

            if (!downloadManagerRunning)
            {
                downloadManagerRunning = true;
                EnsureDownloadWorkers();
                downloadManager.Start();
            }

            return Task.CompletedTask;
        }

        private CandidateQueueService GetCandidateQueueService()
        {
            if (candidateQueueService != null)
            {
                return candidateQueueService;
            }

            candidateQueueService = new CandidateQueueService(candidateQueuePath);
            candidateQueueService.Load();
            return candidateQueueService;
        }

        private void ShowCandidateQueueDialog()
        {
            var service = GetCandidateQueueService();

            using var dialog = new SlskDown.UI.CandidateQueueForm(
                service,
                candidateQueueDryRun,
                async (approved, dryRun) => await ProcessApprovedCandidatesAsync(approved, dryRun));

            dialog.ShowDialog(this);

            candidateQueueDryRun = dialog.DryRunEnabled;
            SaveConfig();
        }

        private async Task ProcessApprovedCandidatesAsync(IReadOnlyList<SlskDown.Core.CandidateQueueItem> approved, bool dryRun)
        {
            if (approved == null || approved.Count == 0)
            {
                return;
            }

            var service = GetCandidateQueueService();

            if (dryRun)
            {
                foreach (var item in approved)
                {
                    AutoLog($"🧪 Dry-run: {item.File.FileName} | {item.File.Username} | {item.Score:F1}");
                }
                return;
            }

            var idsEnqueued = new List<string>();

            SafeInvoke(() => lvDownloads?.BeginUpdate());

            foreach (var item in approved)
            {
                var author = item.File.Author;
                if (string.IsNullOrWhiteSpace(author))
                {
                    var parsed = ParseFileName(item.File.FileName);
                    author = parsed.author;
                }

                var file = new AutoSearchFileResult
                {
                    Author = author ?? string.Empty,
                    Username = item.File.Username,
                    FileName = item.File.FileName,
                    Directory = item.File.FolderPath ?? string.Empty,
                    SizeBytes = item.File.SizeBytes,
                    SizeReadable = FormatFileSize(item.File.SizeBytes),
                    IsSpanish = true,
                    IsDocument = true,
                    Timestamp = DateTime.Now,
                    Network = item.File.Network
                };

                var localPath = GetDownloadPath(file.FileName, file.Author);
                var downloadItem = CreateQueuedDownloadListViewItem(file);

                SafeInvoke(() =>
                {
                    if (lvDownloads != null && lvDownloads.VirtualMode)
                    {
                        MarkDownloadsDirty();
                        return;
                    }

                    AddListViewItemPreservingScroll(lvDownloads, downloadItem);
                });

                AddToDownloadQueue(file, localPath, downloadItem, forceRedownload: false);
                idsEnqueued.Add(item.Id);
            }

            SafeInvoke(() => lvDownloads?.EndUpdate());

            if (idsEnqueued.Count > 0)
            {
                service.MarkEnqueued(idsEnqueued);
                service.ScheduleSave();
            }

            if (downloadsRequireManualStart)
            {
                AutoLog($"📥 {idsEnqueued.Count} aprobado(s) encolado(s). Pulsa '🚀 Procesar cola' para iniciar.");
            }
            else
            {
                AutoLog($"📥 {idsEnqueued.Count} aprobado(s) encolado(s).");
            }

            await Task.CompletedTask;
        }

        private ListViewItem CreateQueuedDownloadListViewItem(AutoSearchFileResult file)
        {
            var item = new ListViewItem(file.FileName);
            item.SubItems.Add(file.Username);
            item.SubItems.Add("0%");
            item.SubItems.Add("⏳ En cola");
            item.SubItems.Add(file.SizeReadable);
            item.Tag = file;
            item.ForeColor = Color.LightGray;
            return item;
        }

        private void AddSelectedResultsToCandidates()
        {
            try
            {
                if (lvResults.SelectedIndices == null || lvResults.SelectedIndices.Count == 0)
                {
                    return;
                }

                var service = GetCandidateQueueService();

                var selectedIndices = lvResults.SelectedIndices.Cast<int>()
                    .Where(i => i >= 0 && i < allResults.Count)
                    .ToList();

                var existingSnapshot = service.GetSnapshot();
                var enqueuedKeys = new HashSet<string>(
                    existingSnapshot
                        .Where(i => i.Status == CandidateQueueItemStatus.Enqueued)
                        .Select(i => $"{i.File.FileName}|{i.File.Username}|{i.File.SizeBytes}".ToLowerInvariant()),
                    StringComparer.Ordinal);
                var seenSelectionKeys = new HashSet<string>(StringComparer.Ordinal);

                var candidates = new List<CandidateFileInfo>(selectedIndices.Count);
                var targets = new List<(string? targetAuthor, string? targetTitle)>(selectedIndices.Count);

                foreach (var index in selectedIndices)
                {
                    var result = allResults[index];
                    var parsed = ParseFileName(result.Filename);
                    var author = string.IsNullOrWhiteSpace(result.Author) ? parsed.author : result.Author;

                    var dedupKey = DedupeKeyHelpers.BuildProviderFileKey(result.Filename, result.Username, result.Size, normalizeFileName: false);
                    if (enqueuedKeys.Contains(dedupKey))
                    {
                        continue;
                    }

                    if (!seenSelectionKeys.Add(dedupKey))
                    {
                        continue;
                    }

                    candidates.Add(new CandidateFileInfo
                    {
                        FileName = result.Filename,
                        Extension = result.Extension,
                        Username = result.Username,
                        FolderPath = result.FolderPath,
                        SizeBytes = result.Size,
                        UploadSpeed = result.UploadSpeed,
                        QueueLength = result.QueueLength,
                        FreeUploadSlots = result.FreeUploadSlots,
                        Author = author,
                        Network = result.Network
                    });

                    targets.Add((author, parsed.title));
                }

                var rankedByKey = new Dictionary<string, RankedCandidate>(StringComparer.OrdinalIgnoreCase);

                if (candidateRankerMode != CandidateRankerMode.CSharp)
                {
                    var rustOk = SlskDown.Core.RustCandidateRanker.TryRankCandidates(candidates, targets, out var rustRanked, out _);

                    if (rustOk)
                    {
                        foreach (var ranked in rustRanked)
                        {
                            var key = DedupeKeyHelpers.BuildProviderFileKey(ranked.File.FileName, ranked.File.Username, ranked.File.SizeBytes, normalizeFileName: false);
                            rankedByKey[key] = ranked;
                        }
                    }
                    else if (candidateRankerMode == CandidateRankerMode.Rust)
                    {
                        foreach (var candidate in candidates)
                        {
                            var key = DedupeKeyHelpers.BuildProviderFileKey(candidate.FileName, candidate.Username, candidate.SizeBytes, normalizeFileName: false);
                            rankedByKey[key] = new RankedCandidate
                            {
                                File = candidate,
                                Score = 0,
                                Confidence = 0,
                                Reasons = new List<string> { "-rust_failed" }
                            };
                        }
                    }
                }

                int added = 0;
                int updated = 0;

                foreach (var candidate in candidates)
                {
                    var key = $"{candidate.FileName}|{candidate.Username}|{candidate.SizeBytes}".ToLowerInvariant();

                    RankedCandidate ranked;
                    if (!rankedByKey.TryGetValue(key, out ranked))
                    {
                        var parsed = ParseFileName(candidate.FileName);
                        ranked = candidateRankerMode == CandidateRankerMode.Rust
                            ? new RankedCandidate
                            {
                                File = candidate,
                                Score = 0,
                                Reasons = new List<string> { "-rust_failed" }
                            }
                            : candidateRanker.Rank(candidate, candidate.Author, parsed.title);
                    }

                    var parsedFallback = ParseFileName(candidate.FileName);

                    var queueItem = new CandidateQueueItem
                    {
                        File = candidate,
                        Score = ranked.Score,
                        Reasons = ranked.Reasons,
                        TargetAuthor = candidate.Author,
                        TargetTitle = parsedFallback.title
                    };

                    if (service.AddOrUpdateCandidate(queueItem, out var info))
                    {
                        if (string.Equals(info, "Actualizado", StringComparison.OrdinalIgnoreCase))
                        {
                            updated++;
                        }
                        else
                        {
                            added++;
                        }
                    }
                }

                service.ScheduleSave();
                AutoLog($"📝 Candidatos: +{added} agregados, {updated} actualizados");

                var nowUtc = DateTime.UtcNow;
                if ((nowUtc - lastRankerStatsLogUtc) > TimeSpan.FromSeconds(60))
                {
                    lastRankerStatsLogUtc = nowUtc;
                    var stats = SlskDown.Core.RustCandidateRanker.GetStatsSnapshot();
                    AutoLog($"🦀 Ranker stats: hits={stats.CacheHits} misses={stats.CacheMisses} rust_calls={stats.RustCalls} rust_fail={stats.RustFailures} cooldown={stats.CooldownBlocks} cache={stats.CacheSize}");
                }
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error añadiendo a candidatos: {ex.Message}");
            }
        }

        private async Task ProcessDownload(DownloadTask task, string workerId)
        {
            // Validación crítica: task.File no puede ser null
            if (task.File == null)
            {
                AutoLog($"❌ Error crítico: task.File es null en ProcessDownload");
                task.Status = DownloadStatus.Failed;
                task.ErrorMessage = "Archivo inválido (null)";
                UpdateDownloadUI(task, "❌ Error: Archivo inválido");
                return;
            }

            UserInfo? startUserInfo = null;
            var downloadUsername = task.File?.Username;

            AppendDownloadFlowLog("process_start", task, workerId: workerId);

            if (task.Status == DownloadStatus.GettingStatus)
            {
                EnqueueDownloadUiUpdate(task, "🔎 Verificando disponibilidad...");

                try
                {
                    if (client != null && task.File != null && !string.IsNullOrWhiteSpace(downloadUsername))
                    {
                        using var timeoutCts = new CancellationTokenSource(TimeSpan.FromSeconds(4));
                        startUserInfo = await GetUserInfoCachedAsync(downloadUsername, requestTimeout: TimeSpan.FromSeconds(4), cancellationToken: timeoutCts.Token);
                        if (startUserInfo == null)
                        {
                            EnqueueDownloadUiUpdate(task, "⚠️ No se pudo verificar disponibilidad (continuando)...");
                        }

                        if (startUserInfo != null)
                        {
                            var queueLen = startUserInfo.QueueLength;
                            var hasSlot = startUserInfo.HasFreeUploadSlot;
                            if (!hasSlot && queueLen >= 25)
                            {
                                task.Status = DownloadStatus.Failed;
                                task.ErrorMessage = $"Queue alta ({queueLen})";
                                task.LastFailureReason = DownloadFailureReason.QueueFull;

                                try
                                {
                                    downloadManager?.RecordProviderFailure(downloadUsername, DownloadFailureReason.QueueFull);
                                }
                                catch
                                {
                                }

                                EnqueueDownloadUiUpdate(task, $"⛔ Cola llena ({queueLen}) - buscando alternativa...");

                                UntrackQueuePosition(task);

                                if (downloadManager != null)
                                {
                                    await downloadManager.TryFindAlternativeProviderAsync(task);
                                }
                                return;
                            }
                        }
                    }
                }
                catch
                {
                    // Si falla la verificación, continuar
                }
            }

            task.Status = DownloadStatus.Downloading;
            UntrackQueuePosition(task);
            task.StartTime = DateTime.Now;
            task.StartedAt = DateTime.Now;
            task.AssignedWorkerId = workerId;
            task.CancellationToken = new CancellationTokenSource();

            if (task.File != null)
            {
                ReleasePrewarmedUser(task.File.Username);
            }
            
            // Búsqueda proactiva de múltiples fuentes (#5)
            if (!task.IsMultiSource && task.RetryCount == 0 && task.File != null)
            {
                try
                {
                    var sources = await FindMultipleSources(task.File, maxSources: 3);
                    if (sources.Count > 1)
                    {
                        task.IsMultiSource = true;
                        task.AlternativeSources = sources;
                        AutoLog($"🚀 {sources.Count} fuentes encontradas, usando multi-source para: {task.File.FileName}");
                    }
                }
                catch (Exception ex)
                {
                    AutoLog($"⚠️ No se pudieron buscar fuentes múltiples: {ex.Message}");
                }
            }
            
            // Si hay múltiples fuentes, usar descarga multi-source
            if (task.IsMultiSource && task.AlternativeSources.Count > 1 && task.File != null)
            {
                AutoLog($"🚀 Iniciando descarga multi-source: {task.File.FileName}");
                await DownloadMultiSource(task);
                return;
            }

            // Verificar si hay descarga parcial existente
            long startPosition = 0;
            if (System.IO.File.Exists(task.LocalPath))
            {
                var fileInfo = new FileInfo(task.LocalPath);
                if (fileInfo.Length > 0 && fileInfo.Length < task.File.SizeBytes)
                {
                    startPosition = fileInfo.Length;
                    task.BytesDownloaded = startPosition;
                    task.ProgressPercent = (double)startPosition / task.File.SizeBytes * 100;
                    AutoLog($"📥 Reanudando descarga desde {FormatFileSize(startPosition)}: {task.File.FileName}");

                    AppendDownloadFlowLog(
                        "resume_detected",
                        task,
                        workerId: workerId,
                        extra: $"start_offset={startPosition}");
                }
            }

            try
            {
                var finalTarget = string.IsNullOrWhiteSpace(task.TargetPath) ? task.LocalPath : task.TargetPath;
                AutoLog($"📦 Descarga usando temporal: '{task.LocalPath}' → destino: '{finalTarget}'");
            }
            catch
            {
            }

            EnqueueDownloadUiUpdate(task, $"🔵 Descargando... {task.ProgressPercent:F1}%");

            try
            {
                
                // Verificar disponibilidad del usuario antes de descargar (con timeout)
                // NOTA: Esta es una petición al servidor, pero:
                // - Solo se ejecuta antes de descargas (menos frecuente que búsquedas)
                // - Tiene timeout de 5s para evitar bloqueos
                // - El try-catch permite continuar si falla
                try
                {
                    if (startUserInfo != null)
                    {
                        if (startUserInfo.HasFreeUploadSlot || startUserInfo.QueueLength < 10)
                        {
                            AutoLog($"✅ Usuario {downloadUsername} disponible (Queue: {startUserInfo.QueueLength})");
                        }
                        else
                        {
                            AutoLog($"⚠️ Usuario {downloadUsername} ocupado (Queue: {startUserInfo.QueueLength})");
                        }
                    }
                    else
                    {
                        using var timeoutCts = new CancellationTokenSource(TimeSpan.FromSeconds(3));
                        var userInfo = await GetUserInfoCachedAsync(downloadUsername, requestTimeout: TimeSpan.FromSeconds(3), cancellationToken: timeoutCts.Token);
                        if (userInfo != null && (userInfo.HasFreeUploadSlot || userInfo.QueueLength < 10))
                        {
                            AutoLog($"✅ Usuario {downloadUsername} disponible (Queue: {userInfo.QueueLength})");
                        }
                        else
                        {
                            var q = userInfo?.QueueLength;
                            AutoLog($"⚠️ Usuario {downloadUsername} ocupado (Queue: {(q.HasValue ? q.Value.ToString() : "?")})");
                        }
                    }
                }
                catch (OperationCanceledException)
                {
                    AutoLog($"⏱️ Timeout verificando disponibilidad de {downloadUsername}");
                }
                catch
                {
                    // Si falla la verificación, continuar de todos modos
                }
                
                // Validar que Directory no sea nulo antes de usar Path.Combine
                var directory = string.IsNullOrWhiteSpace(task.File.Directory) ? "" : task.File.Directory;
                var remotePath = string.IsNullOrWhiteSpace(directory) 
                    ? task.File.FileName 
                    : Path.Combine(directory, task.File.FileName).Replace("/", "\\");

                AppendDownloadFlowLog(
                    "download_async_start",
                    task,
                    workerId: workerId,
                    extra: $"remote={remotePath};start_offset={startPosition}");
                
                // Optimización #19: Streaming con backpressure (20-30% menos memoria)
                await client.DownloadAsync(
                    task.File.Username,
                    remotePath,
                    () => Task.FromResult<Stream>(new FileStream(
                        task.LocalPath, 
                        FileMode.OpenOrCreate,
                        FileAccess.Write,
                        FileShare.None,
                        bufferSize: 81920, // 80KB buffer (óptimo para streaming)
                        useAsync: true
                    )),
                    task.File.SizeBytes,
                    startOffset: startPosition,
                    cancellationToken: task.CancellationToken.Token,
                    options: new TransferOptions(
                        stateChanged: (args) =>
                        {
                            if (args.Transfer.State.HasFlag(TransferStates.InProgress))
                            {
                                task.BytesDownloaded = startPosition + args.Transfer.BytesTransferred;
                                task.ProgressPercent = (double)task.BytesDownloaded / task.File.SizeBytes * 100;
                                task.SpeedMBps = args.Transfer.AverageSpeed / 1024.0 / 1024.0;
                                task.LastSpeedMeasurement = args.Transfer.AverageSpeed; // En bytes/s para el gráfico
                                
                                var status = $"🔵 {task.ProgressPercent:F1}% - {task.SpeedMBps:F2} MB/s";
                                EnqueueDownloadUiUpdate(task, status);
                            }
                        },
                        progressUpdated: (args) =>
                        {
                            task.BytesDownloaded = startPosition + args.Transfer.BytesTransferred;
                            task.ProgressPercent = (double)task.BytesDownloaded / task.File.SizeBytes * 100;
                            
                            if (task.StartTime.HasValue)
                            {
                                var elapsed = (DateTime.Now - task.StartTime.Value).TotalSeconds;
                                if (elapsed > 0)
                                {
                                    task.SpeedMBps = (task.BytesDownloaded / elapsed) / 1024.0 / 1024.0;
                                }
                            }
                            
                            // Verificar si la descarga es muy lenta y buscar alternativa
                            try
                            {
                                if (task.StartTime.HasValue)
                                {
                                    var elapsedSinceStart = (DateTime.Now - task.StartTime.Value).TotalSeconds;
                                    if (elapsedSinceStart >= SLOW_DOWNLOAD_CHECK_SECONDS)
                                    {
                                        var timeSinceLastCheck = (DateTime.Now - task.LastSpeedCheck).TotalSeconds;
                                        if (timeSinceLastCheck >= SLOW_DOWNLOAD_CHECK_SECONDS)
                                        {
                                            _ = CheckSlowDownloadAndFindAlternative(task);
                                        }
                                    }
                                }
                            }
                            catch
                            {
                            }
                        }
                    )
                );

                AppendDownloadFlowLog("download_async_end", task, workerId: workerId);

                try
                {
                    var targetPath = task.TargetPath;
                    if (!string.IsNullOrWhiteSpace(targetPath) &&
                        !string.Equals(task.LocalPath, targetPath, StringComparison.OrdinalIgnoreCase) &&
                        System.IO.File.Exists(task.LocalPath))
                    {
                        var targetDirectory = Path.GetDirectoryName(targetPath);
                        if (!string.IsNullOrWhiteSpace(targetDirectory))
                        {
                            Directory.CreateDirectory(targetDirectory);
                        }

                        var finalPath = targetPath;
                        if (System.IO.File.Exists(finalPath))
                        {
                            var baseDir = Path.GetDirectoryName(finalPath) ?? downloadDir;
                            var nameWithoutExt = Path.GetFileNameWithoutExtension(finalPath);
                            var ext = Path.GetExtension(finalPath);
                            var counter = 1;
                            do
                            {
                                finalPath = Path.Combine(baseDir, $"{nameWithoutExt}_{counter}{ext}");
                                counter++;
                            } while (System.IO.File.Exists(finalPath));
                        }

                        try
                        {
                            AutoLog($"📁 Moviendo desde temporal: '{task.LocalPath}' → '{finalPath}'");
                        }
                        catch
                        {
                        }

                        AppendDownloadFlowLog(
                            "move_to_final_start",
                            task,
                            workerId: workerId,
                            extra: $"final={finalPath}");

                        System.IO.File.Move(task.LocalPath, finalPath);
                        task.LocalPath = finalPath;
                        task.TargetPath = finalPath;

                        try
                        {
                            AutoLog($"✅ Archivo en destino final: '{finalPath}'");
                        }
                        catch
                        {
                        }

                        AppendDownloadFlowLog(
                            "move_to_final_end",
                            task,
                            workerId: workerId,
                            extra: $"final={finalPath}");
                    }
                }
                catch
                {
                }

                try
                {
                    if (!string.IsNullOrWhiteSpace(task.LocalPath) && System.IO.File.Exists(task.LocalPath))
                    {
                        var fileInfo = new FileInfo(task.LocalPath);
                        if (fileInfo.Length == 0)
                        {
                            try { System.IO.File.Delete(task.LocalPath); } catch { }
                            task.Status = DownloadStatus.Failed;
                            task.EndTime = DateTime.Now;
                            task.LastFailureReason = DownloadFailureReason.FileIo;
                            if (string.IsNullOrWhiteSpace(task.ErrorMessage))
                            {
                                task.ErrorMessage = $"Archivo 0 bytes: {Path.GetFileName(task.LocalPath)}";
                            }
                            throw new ZeroByteDownloadedFileException($"Archivo 0 bytes: {Path.GetFileName(task.LocalPath)}");
                        }
                    }
                }
                catch (ZeroByteDownloadedFileException)
                {
                    throw;
                }
                catch
                {
                }

                try
                {
                    var finalFileName = Path.GetFileName(task.LocalPath) ?? task.File?.FileName ?? string.Empty;
                    var isDocument = IsDocumentFile(finalFileName);
                    if (!isDocument)
                    {
                        var movedToMisc = MoveToMiscFolder(task.LocalPath);
                        if (!string.IsNullOrWhiteSpace(movedToMisc))
                        {
                            task.LocalPath = movedToMisc;
                            task.TargetPath = movedToMisc;
                        }
                    }
                }
                catch
                {
                }

                // Invalidar caché del archivo descargado
                InvalidateFileCache(task.LocalPath);
                
                // 🦀 RUST: Validar integridad y extraer metadatos
                if (!ValidateDownloadedFile(task.LocalPath, task.File.FileName))
                {
                    // Archivo corrupto detectado
                    task.Status = DownloadStatus.Corrupted;
                    task.ErrorMessage = "Archivo corrupto - validación falló";
                    
                    // Mover archivo corrupto a cuarentena
                    try
                    {
                        var originalPath = task.LocalPath;
                        var movedPath = MoveCorruptDownloadedFile(task.LocalPath);
                        InvalidateFileCache(originalPath);
                        InvalidateFileCache(movedPath);

                        AppendQuarantineLog(
                            "corrupted",
                            Path.GetFileName(originalPath) ?? task.File.FileName,
                            originalPath,
                            movedPath,
                            SlskDown.Core.RustFileOperations.IsAvailable() ? "rust" : "fallback");

                        Log($"🧪 Archivo corrupto movido a _Corruptos: {Path.GetFileName(movedPath)}");
                    }
                    catch
                    {
                    }
                    
                    // Marcar para re-descarga si hay reintentos disponibles
                    if (task.RetryCount < maxRetries)
                    {
                        task.AutoRetryEnabled = true;
                        Log($"🔄 Re-descarga programada para archivo corrupto: {task.File.FileName}");
                    }
                    
                    UpdateDownloadUI(task, "❌ Corrupto - En cuarentena");
                    return;
                }
                
                // Verificar integridad con CRC32 (40x más rápido que MD5)
                if (RustCore.IsAvailable() && !string.IsNullOrEmpty(task.LocalPath) && System.IO.File.Exists(task.LocalPath))
                {
                    _ = Task.Run(async () => await VerifyDownloadIntegrity(task.LocalPath));
                }
                
                // Verificar integridad con hash BLAKE3 (ultra-rápido)
                string fileHash = null;
                bool isSpanish = false;
                try
                {
                    // Verificar que el archivo existe y la ruta es válida
                    if (!string.IsNullOrEmpty(task.LocalPath) && System.IO.File.Exists(task.LocalPath))
                    {
                        fileHash = await GetFileHashAsync(task.LocalPath);
                        
                        if (!string.IsNullOrEmpty(fileHash))
                        {
                            AutoLog($"🔐 Hash verificado: {fileHash.Substring(0, 16)}...");
                            
                            // Optimización #15: Verificar duplicados y crear hardlink si existe
                            var duplicatePath = contentDuplicateDetector?.RegisterAndGetExisting(fileHash, task.LocalPath, task.File.SizeBytes);
                            if (duplicatePath != null)
                            {
                                task.IsDuplicate = true;
                                task.DuplicateOf = duplicatePath;
                                AutoLog($"♻️ Duplicado detectado contra índice: {Path.GetFileName(duplicatePath)}");
                            }

                            var existingPath = CheckDuplicateFile(task.LocalPath, fileHash);
                            if (existingPath != null)
                            {
                                // Archivo duplicado encontrado, crear hardlink
                                var fileInfo = new FileInfo(task.LocalPath);
                                var savedSpace = fileInfo.Length;
                                
                                System.IO.File.Delete(task.LocalPath);
                                CreateHardLink(existingPath, task.LocalPath);
                                
                                AutoLog($"💾 Espacio ahorrado: {FormatFileSize(savedSpace)}");
                            }
                        }
                        // Determinar si el archivo es español
                        isSpanish = IsSpanishFileByContent(task.LocalPath);
                    }
                    else
                    {
                        AutoLog($"⚠️ No se puede calcular hash: archivo no existe o ruta inválida");
                    }
                }
                catch (Exception hashEx)
                {
                    AutoLog($"⚠️ No se pudo calcular hash: {hashEx.Message}");
                }
                
                var originalHistoryFileName = task.File.FileName;

                var renamedPath = RenameToLibreFormat(task.LocalPath, task.File.Author);
                if (!string.Equals(renamedPath, task.LocalPath, StringComparison.OrdinalIgnoreCase))
                {
                    task.LocalPath = renamedPath;
                }

                if (!isSpanish)
                {
                    var movedPath = MoveNonSpanishDownloadedFile(task.LocalPath);
                    if (!string.Equals(movedPath, task.LocalPath, StringComparison.OrdinalIgnoreCase))
                    {
                        task.LocalPath = movedPath;
                    }
                }

                var finalHistoryFileName = Path.GetFileName(task.LocalPath) ?? originalHistoryFileName;
                var historyRootDir = txtDownloadDir?.Text ?? downloadDir;
                
                // Notificación de descarga completada
                ShowNotification("Descarga completada", 
                    $"✅ {task.File.FileName}\n\nTamaño: {task.File.SizeReadable} | Velocidad: {task.SpeedMBps:F2} MB/s", 
                    ToolTipIcon.Info);
                
                // Registrar en historial con hash para verificación futura
                lock (downloadHistoryLock)
                {
                    var relativePath = GetRelativePathSafe(task.LocalPath, historyRootDir);
                    downloadHistory.Add(new DownloadHistoryRecord
                    {
                        FileName = finalHistoryFileName,
                        Author = task.File.Author,
                        Username = task.File.Username,
                        SizeBytes = task.File.SizeBytes,
                        DownloadedAt = DateTime.Now,
                        Status = "Completed",
                        SpeedMBps = task.SpeedMBps,
                        Hash = fileHash,
                        RelativePath = relativePath,
                        IsSpanish = isSpanish,
                        IsDuplicate = task.IsDuplicate,
                        DuplicateOf = task.DuplicateOf
                    });

                    if (!string.Equals(originalHistoryFileName, finalHistoryFileName, StringComparison.OrdinalIgnoreCase))
                    {
                        downloadHistoryCache.Remove(originalHistoryFileName);
                    }

                    downloadHistoryCache.Add(finalHistoryFileName);

                    if (!string.IsNullOrWhiteSpace(fileHash))
                    {
                        downloadHistoryHashCache.Add(fileHash);
                    }
                }

                // Actualizar estadísticas
                statistics.TotalFilesDownloaded++;
                statistics.TotalBytesDownloaded += task.File.SizeBytes;

                double throughputMbPerSec = 0;
                if (task.EndTime.HasValue && task.StartTime.HasValue)
                {
                    var downloadTime = (task.EndTime.Value - task.StartTime.Value).TotalSeconds;
                    if (downloadTime > 0)
                    {
                        throughputMbPerSec = (task.File.SizeBytes / 1024.0 / 1024.0) / downloadTime;

                        var totalTime = statistics.TotalDownloadTime.TotalSeconds + downloadTime;
                        statistics.TotalDownloadTime = TimeSpan.FromSeconds(totalTime);
                        statistics.AverageDownloadSpeed = totalTime > 0
                            ? (statistics.TotalBytesDownloaded / totalTime) / 1024.0 / 1024.0
                            : statistics.AverageDownloadSpeed;
                    }
                }

                if (throughputMbPerSec > 0)
                {
                    statistics.LastDownloadSpeed = throughputMbPerSec;
                    statistics.PeakDownloadSpeed = Math.Max(statistics.PeakDownloadSpeed, throughputMbPerSec);

                    statistics.ThroughputSamples++;
                    if (statistics.ThroughputSamples <= 1)
                    {
                        statistics.AverageThroughputPerFile = throughputMbPerSec;
                    }
                    else
                    {
                        var previousTotal = statistics.AverageThroughputPerFile * (statistics.ThroughputSamples - 1);
                        statistics.AverageThroughputPerFile = (previousTotal + throughputMbPerSec) / statistics.ThroughputSamples;
                    }

                    AutoLogThrottled($"📈 Velocidad: {throughputMbPerSec:F2} MB/s | Pico {statistics.PeakDownloadSpeed:F2} MB/s | Media {statistics.AverageThroughputPerFile:F2} MB/s", 5000);
                }

                RecordDownloadOutcome(true);

                SaveDownloadHistory();
                SaveStatistics();
                
                // Optimización #2: Descarga predictiva - pre-buscar siguiente archivo
                lock (downloadQueueLock)
                {
                    var nextTask = downloadQueue
                        .Where(t => t.Status == DownloadStatus.Queued)
                        // .OrderByDescending(t => t.Priority)
                        .FirstOrDefault();
                    
                    if (nextTask != null && nextTask.AlternativeSources.Count == 0 && !IsTxtSearchRunning)
                    {
                        _ = Task.Run(async () =>
                        {
                            try
                            {
                                AutoLog($"🔮 Pre-buscando fuentes para: {nextTask.File.FileName}");
                                var sources = await FindMultipleSources(nextTask.File, maxSources: 3);
                                if (sources.Count > 0)
                                {
                                    nextTask.AlternativeSources.AddRange(sources.Take(3));
                                    AutoLog($"✅ {sources.Count} fuentes pre-cargadas para: {nextTask.File.FileName}");
                                }
                            }
                            catch { }
                        });
                    }
                }
                
                // Actualizar estadísticas del proveedor
                UpdateProviderStats(task.File.Username, true, task.SpeedMBps, task.File.SizeBytes);
                SaveProviderStatsToDatabase();
                
                // Invalidar cache para este archivo
                InvalidateFileCache(task.LocalPath);
                
                // Optimización #1: Caché de validación de archivos
                bool isValidFile = true;
                bool needsValidation = true;
                
                // Verificar caché primero (1000x más rápido)
                if (validationCache.TryGetValue(task.LocalPath, out var cached))
                {
                    // Validar solo si tiene >1 día o tamaño cambió
                    var fileInfo = new FileInfo(task.LocalPath);
                    if ((DateTime.Now - cached.timestamp).TotalDays < 1 && 
                        fileInfo.Length == task.File.SizeBytes)
                    {
                        needsValidation = false;
                        AutoLog($"✅ Validación en caché: {task.File.FileName}");
                    }
                }
                
                if (needsValidation)
                {
                    try
                    {
                        if (!SlskDownCore.ValidateFile(task.LocalPath))
                        {
                            AutoLog($"⚠️ Archivo corrupto detectado: {task.File.FileName}");
                            
                            // Intentar reparar
                            if (SlskDownCore.RepairFile(task.LocalPath))
                            {
                                AutoLog($"✅ Archivo reparado automáticamente: {task.File.FileName}");
                                isValidFile = true;
                            }
                            else
                            {
                                AutoLog($"❌ No se pudo reparar el archivo: {task.File.FileName}");
                                isValidFile = false;
                            }
                        }
                        
                        // Cachear resultado
                        if (isValidFile)
                        {
                            validationCache[task.LocalPath] = (true, DateTime.Now);
                        }
                    }
                    catch (Exception valEx)
                    {
                        AutoLog($"⚠️ Error validando archivo con Rust: {valEx.Message}");
                        // Continuar sin validación Rust
                    }
                }
                
                if (isValidFile)
                {
                    // Registrar descarga exitosa en circuit breaker
                    RecordDownloadSuccess();
                    
                    // Organizar archivo automáticamente
                    var organizedPath = OrganizeDownloadedFile(task.LocalPath, task.File);
                    task.LocalPath = organizedPath;
                    
                    // Eliminar tareas duplicadas de otros proveedores
                    RemoveDuplicateDownloadTasks(task);
                    
                    var statusText = task.IsDuplicate
                        ? "♻️ Completado (duplicado)"
                        : "✅ Completado ✓";
                    EnqueueDownloadUiUpdate(task, statusText);
                    AutoLog($"✅ Descarga completada y verificada: {task.File.FileName}");
                    
                    // MEJORA #5: Verificar hitos de progreso
                    CheckProgressMilestone();
                }
                else
                {
                    EnqueueDownloadUiUpdate(task, "⚠️ Corrupto");
                    AutoLog($"⚠️ Descarga completada pero archivo corrupto: {task.File.FileName}");
                }
            }
            catch (OperationCanceledException)
            {
                // Solo marcar como cancelado si no fue marcado como fallido previamente
                // (las cancelaciones automáticas por lentitud ya están marcadas como Failed)
                if (task.Status != DownloadStatus.Failed)
                {
                    task.Status = DownloadStatus.Cancelled;
                    task.EndTime = DateTime.Now;
                    EnqueueDownloadUiUpdate(task, "⏹️ Cancelado");
                    AutoLog($"⏹️ Descarga cancelada manualmente: {task.File.FileName}");
                    
                    // Eliminar archivo incompleto
                    DeleteIncompleteFile(task.LocalPath, "cancelada");
                }
                else
                {
                    // Ya fue marcado como Failed (cancelación automática)
                    AutoLog($"⚠️ Descarga interrumpida (reintento automático): {task.File.FileName}");
                }
            }
            catch (Exception ex)
            {
                if (ex is ZeroByteDownloadedFileException)
                {
                    throw;
                }
                task.Status = DownloadStatus.Failed;
                task.ErrorMessage = ex.Message;
                task.LastRetryTime = DateTime.Now;
                MarkDownloadStatsDirty();
                RecordDownloadOutcome(false);
                
                // Registrar error en circuit breaker
                RecordDownloadError();

                // Validación crítica: verificar que task.File no sea null
                if (task.File == null)
                {
                    AutoLog($"❌ Error crítico: task.File es null - {ex.Message}");
                    UpdateDownloadUI(task, $"❌ Error: Archivo inválido");
                    return;
                }

                // MEJORA #1: Detección agresiva de usuarios offline
                if (ex.Message.Contains("appears to be offline", StringComparison.OrdinalIgnoreCase))
                {
                    lock (providerBlacklist)
                    {
                        var blockedUntil = DateTime.Now.AddHours(1); // 1 hora de bloqueo para usuarios offline
                        providerBlacklist[task.File.Username] = (PROVIDER_BLACKLIST_THRESHOLD, DateTime.Now, blockedUntil);
                        AutoLog($"⛔ Usuario {task.File.Username} offline detectado, blacklist inmediata (1h)");
                    }

                    lock (providerOfflineLock)
                    {
                        providerOfflineUntilUtc[task.File.Username] = DateTime.UtcNow.AddMinutes(PROVIDER_OFFLINE_COOLDOWN_MINUTES);
                    }
                    
                    // Buscar proveedor alternativo inmediatamente
                    if (downloadManager != null)
                    {
                        _ = Task.Run(() => downloadManager.TryFindAlternativeProviderAsync(task));
                    }
                }
                
                // Modo agresivo para archivos difíciles (#7)
                if (task.RetryCount >= 2)
                {
                    task.MaxRetries = 5; // Más reintentos
                }
                
                // Determinar si se reintentará automáticamente
                if (task.AutoRetryEnabled && task.RetryCount < task.MaxRetries)
                {
                    // MEJORA #8: Mostrar tiempo de espera con backoff exponencial
                    int retryDelay = GetRetryDelay(task.RetryCount);
                    UpdateDownloadUI(task, $"🔄 Error (reintento {task.RetryCount + 1}/{task.MaxRetries} en {retryDelay}s)");
                    AutoLog($"❌ Error: {task.File.FileName} - {ex.Message} (reintento {task.RetryCount + 1}/{task.MaxRetries} en {retryDelay}s)");
                }
                else
                {
                    task.FinalFailureTime = DateTime.Now; // Marcar fallo definitivo (#1)
                    UpdateDownloadUI(task, $"❌ Error: {ex.Message}");
                    AutoLog($"❌ Fallo definitivo: {task.File.FileName} - {ex.Message}");
                    
                    // Eliminar archivo incompleto en fallo definitivo
                    DeleteIncompleteFile(task.LocalPath, "fallida");
                    
                    // Notificación consolidada (#9)
                    ShowNotification("Descarga fallida", 
                        $"❌ {task.File.FileName}\n\nError: {ex.Message}\n\nReintentos: {task.MaxRetries}", 
                        ToolTipIcon.Error);
                    
                    // Intentar buscar proveedor alternativo solo después de agotar reintentos
                    if (downloadManager != null)
                    {
                        _ = Task.Run(() => downloadManager.TryFindAlternativeProviderAsync(task));
                    }
                }
                
                // Actualizar estadísticas del proveedor (fallo) y blacklist temporal (#8)
                UpdateProviderStats(task.File.Username, false, 0, 0);
                SaveProviderStatsToDatabase();
                
                // Agregar a blacklist temporal con tiempo de espera progresivo
                lock (providerBlacklist)
                {
                    int newFailures = 1;
                    DateTime blockedUntil = DateTime.Now;
                    
                    if (providerBlacklist.TryGetValue(task.File.Username, out var data))
                    {
                        // Si ya pasó el tiempo de bloqueo, resetear contador
                        if (DateTime.Now >= data.blockedUntil)
                        {
                            newFailures = 1;
                        }
                        else
                        {
                            newFailures = data.failures + 1;
                        }
                    }
                    
                    // Calcular tiempo de bloqueo progresivo: 1h, 3h, 6h, 12h, 24h
                    int blockHours = newFailures switch
                    {
                        <= 10 => 1,
                        <= 30 => 3,
                        <= 60 => 6,
                        <= 100 => 12,
                        _ => 24
                    };
                    
                    blockedUntil = DateTime.Now.AddHours(blockHours);
                    providerBlacklist[task.File.Username] = (newFailures, DateTime.Now, blockedUntil);
                    
                    if (newFailures >= PROVIDER_BLACKLIST_THRESHOLD)
                    {
                        AutoLog($"⛔ Proveedor {task.File.Username} en blacklist temporal ({newFailures} fallos, bloqueado {blockHours}h hasta {blockedUntil:HH:mm})");
                    }
                }
            }
        }
        
        private async Task SearchFailedInOtherUsers()
        {
            try
            {
                List<DownloadTask> failedTasks;
                lock (downloadQueueLock)
                {
                    failedTasks = downloadQueue.Where(t => t.Status == DownloadStatus.Failed).ToList();
                }
                
                if (failedTasks.Count == 0)
                {
                    MessageBox.Show("No hay archivos fallidos para buscar.", "Sin archivos fallidos", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    return;
                }
                
                var result = MessageBox.Show(
                    $"Se buscarán {failedTasks.Count} archivo(s) fallido(s) en otros usuarios.\n\n" +
                    "Esta operación puede tardar varios minutos.\n\n" +
                    "¿Deseas continuar?",
                    "Buscar en Otros Usuarios",
                    MessageBoxButtons.YesNo,
                    MessageBoxIcon.Question
                );
                
                if (result != DialogResult.Yes)
                    return;
                
                Log($"🔍 Iniciando búsqueda de {failedTasks.Count} archivo(s) fallido(s) en otros usuarios...");
                
                int foundCount = 0;
                int notFoundCount = 0;
                int errorCount = 0;
                
                foreach (var task in failedTasks)
                {
                    try
                    {
                        Log($"🔍 Buscando: {task.File.FileName}");
                        UpdateDownloadUI(task, "🔍 Buscando en otros usuarios...");
                        
                        // ⚡ CRÍTICO: Aplicar rate limiter
                        await WaitForRateLimitAsync("download-search");
                        
                        // Usar cliente del pool para búsqueda
                        var searchClient = client;
                        var searchResults = await searchClient.SearchAsync(
                            SearchQuery.FromText(task.File.FileName),
                            options: new Soulseek.SearchOptions(
                                searchTimeout: 20000,
                                filterResponses: true,
                                minimumResponseFileCount: 1
                            )
                        );
                        
                        // MEJORA #3: Buscar proveedores alternativos excluyendo blacklist
                        var alternatives = searchResults.Responses
                            .Where(r => 
                            {
                                // Excluir proveedor original
                                if (r.Username.Equals(task.File.Username, StringComparison.OrdinalIgnoreCase))
                                    return false;
                                
                                // Excluir proveedores en blacklist temporal
                                lock (providerBlacklist)
                                {
                                    if (providerBlacklist.TryGetValue(r.Username, out var data))
                                    {
                                        if (data.failures >= PROVIDER_BLACKLIST_THRESHOLD && 
                                            DateTime.Now < data.blockedUntil)
                                        {
                                            return false;
                                        }
                                    }
                                }
                                
                                return true;
                            })
                            .SelectMany(r => r.Files.Select(f => new { Response = r, File = f }))
                            .Where(item => 
                                item.File.Filename.Equals(task.File.FileName, StringComparison.OrdinalIgnoreCase) &&
                                Math.Abs(item.File.Size - task.File.SizeBytes) < 1024 * 100) // Tolerancia de 100KB
                            .OrderByDescending(item =>
                            {
                                var stats = GetProviderStats(item.Response.Username);
                                return stats != null ? stats.QualityScore : item.File.Size / 1024.0 / 1024.0;
                            })
                            .ToList();
                        
                        if (alternatives.Count > 0)
                        {
                            var alternative = alternatives.First();
                            Log($"✅ Encontrado en: {alternative.Response.Username} ({alternatives.Count} alternativa(s))");
                            
                            // Crear nuevo AutoSearchFileResult con el proveedor alternativo
                            var newFile = new AutoSearchFileResult
                            {
                                FileName = task.File.FileName,
                                Author = task.File.Author,
                                Username = alternative.Response.Username,
                                Directory = alternative.File.Filename.Contains("\\") ? 
                                    alternative.File.Filename.Substring(0, alternative.File.Filename.LastIndexOf("\\")) : "",
                                SizeBytes = alternative.File.Size,
                                SizeReadable = FormatFileSize(alternative.File.Size),
                                IsSpanish = task.File.IsSpanish,
                                IsDocument = task.File.IsDocument,
                                Timestamp = DateTime.Now
                            };
                            
                            // Actualizar la tarea con el nuevo proveedor
                            task.File = newFile;
                            task.Status = DownloadStatus.Queued;
                            task.RetryCount = 0;
                            task.ErrorMessage = null;
                            task.FinalFailureTime = null;
                            task.LastRetryTime = null;
                            
                            UpdateDownloadUI(task, $"⏳ En cola (nuevo: {alternative.Response.Username})");
                            foundCount++;
                        }
                        else
                        {
                            Log($"❌ No se encontraron alternativas para: {task.File.FileName}");
                            UpdateDownloadUI(task, "❌ Sin alternativas disponibles");
                            notFoundCount++;
                        }
                        
                        // Pequeña pausa entre búsquedas
                        await Task.Delay(500);
                    }
                    catch (Exception ex)
                    {
                        Log($"❌ Error buscando {task.File.FileName}: {ex.Message}");
                        errorCount++;
                    }
                }
                
                var summary = $"Búsqueda completada:\n\n" +
                             $"✅ Encontrados: {foundCount}\n" +
                             $"❌ No encontrados: {notFoundCount}\n" +
                             $"⚠️ Errores: {errorCount}\n\n" +
                             $"Los archivos encontrados se agregarán a la cola de descargas.";
                
                Log($"✅ {summary.Replace("\n", " ")}");
                MessageBox.Show(summary, "Búsqueda Completada", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                Log($"❌ Error en SearchFailedInOtherUsers: {ex.Message}");
                MessageBox.Show($"Error buscando archivos:\n{ex.Message}", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
        private async Task CheckSlowDownloadAndFindAlternative(DownloadTask task)
        {
            try
            {
                // Verificar si ha pasado suficiente tiempo desde el inicio
                var elapsed = (DateTime.Now - task.StartTime).Value.TotalSeconds;
                if (elapsed < SLOW_DOWNLOAD_CHECK_SECONDS)
                    return;
                
                // Verificar si es momento de hacer otra verificación
                var timeSinceLastCheck = (DateTime.Now - task.LastSpeedCheck).TotalSeconds;
                if (timeSinceLastCheck < SLOW_DOWNLOAD_CHECK_SECONDS)
                    return;
                
                // Calcular velocidad actual en KB/s
                long bytesSinceLastCheck = task.BytesDownloaded - task.LastBytesDownloaded;
                double speedKBps = (bytesSinceLastCheck / timeSinceLastCheck) / 1024.0;
                
                task.LastSpeedCheck = DateTime.Now;
                task.LastBytesDownloaded = task.BytesDownloaded;
                
                // Verificar si la velocidad es muy lenta
                if (speedKBps < MIN_SPEED_KBPS)
                {
                    task.SlowDownloadChecks++;
                    AutoLog($"🐌 Descarga lenta detectada: {task.File.FileName} ({speedKBps:F2} KB/s) - Check {task.SlowDownloadChecks}/{SLOW_DOWNLOAD_THRESHOLD_CHECKS}");
                    
                    // Si se alcanza el umbral, buscar alternativa
                    if (task.SlowDownloadChecks >= SLOW_DOWNLOAD_THRESHOLD_CHECKS)
                    {
                        AutoLog($"⚠️ Descarga demasiado lenta, buscando proveedor alternativo: {task.File.FileName}");

                        try
                        {
                            downloadManager?.RecordProviderFailure(task.File.Username, DownloadFailureReason.Timeout);
                        }
                        catch
                        {
                        }
                        
                        // Marcar como fallida (no cancelada) para que se reintente
                        task.Status = DownloadStatus.Failed;
                        task.ErrorMessage = "Velocidad muy lenta (< 10 KB/s)";
                        task.LastFailureReason = DownloadFailureReason.Timeout;
                        task.CancellationToken?.Cancel();
                        
                        UpdateDownloadUI(task, "🔍 Buscando alternativa (muy lento)...");
                        
                        // Buscar proveedor alternativo
                        if (downloadManager != null)
                        {
                            await downloadManager.TryFindAlternativeProviderAsync(task);
                        }
                    }
                }
                else
                {
                    // Resetear contador si la velocidad mejora
                    if (task.SlowDownloadChecks > 0)
                    {
                        AutoLog($"✅ Velocidad mejorada: {task.File.FileName} ({speedKBps:F2} KB/s)");
                        task.SlowDownloadChecks = 0;
                    }
                }
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error verificando velocidad de descarga: {ex.Message}");
            }
        }
        
        private void UpdateRealtimeStats()
        {
            if (lblRealtimeStats == null || downloadQueue == null) return;
            
            try
            {
                int downloading = 0, pending = 0, paused = 0, completed = 0, failed = 0;
                double totalSpeed = 0;
                int activeSpeedCount = 0;
                long totalBytes = 0;
                int withAlternative = 0;
                
                lock (downloadQueueLock)
                {
                    if (downloadQueue.Count == 0)
                    {
                        SafeInvoke(() =>
                        {
                            if (lblRealtimeStats != null)
                                lblRealtimeStats.Text = "📊 Sin descargas activas";
                        });
                        return;
                    }
                    
                    // Optimización: Una sola iteración para todas las estadísticas
                    foreach (var task in downloadQueue)
                    {
                        switch (task.Status)
                        {
                            case DownloadStatus.Downloading:
                                downloading++;
                                if (task.SpeedMBps > 0)
                                {
                                    totalSpeed += task.SpeedMBps;
                                    activeSpeedCount++;
                                }
                                break;
                            case DownloadStatus.Queued:
                                pending++;
                                break;
                            case DownloadStatus.Paused:
                                paused++;
                                break;
                            case DownloadStatus.Completed:
                                completed++;
                                totalBytes += task.File?.SizeBytes ?? 0;
                                break;
                            case DownloadStatus.Failed:
                                failed++;
                                break;
                        }
                    }
                    
                    // Contar archivos con alternativa
                    withAlternative = downloadRetryCount.Count(kvp => kvp.Value > 1 && kvp.Value <= maxAlternativeRetries);
                }
                
                double avgSpeed = activeSpeedCount > 0 ? totalSpeed / activeSpeedCount : 0;
                
                string totalSize = FormatFileSize(totalBytes);
                
                SafeInvoke(() =>
                {
                    if (lblRealtimeStats != null)
                    {
                        var health = downloadManager?.GetProviderHealthSnapshot(maxEntries: 12);
                        var blocked = 0;
                        var cooldowns = 0;
                        var circuits = 0;
                        if (health != null)
                        {
                            blocked = health.Count(h => h.IsBlacklisted || h.CooldownRemaining.HasValue || h.CircuitRemaining.HasValue);
                            cooldowns = health.Count(h => h.CooldownRemaining.HasValue);
                            circuits = health.Count(h => h.CircuitRemaining.HasValue);
                        }

                        lblRealtimeStats.Text = $"⬇️ {downloading} descargando | ⏳ {pending} en cola | ⏸️ {paused} pausadas | " +
                                               $"✅ {completed} ({totalSize}) | ❌ {failed} fallidos | " +
                                               $"🔄 {withAlternative} con alternativa | 📈 {avgSpeed:F1} MB/s" +
                                               $" | ⛔ {blocked} bloqueados (⏳{cooldowns}/🧯{circuits})";
                    }
                });
                
                // Notificar cuando todas las descargas se completen
                var total = downloadQueue.Count;
                if (total > 0 && pending == 0 && downloading == 0 && !allDownloadsCompletedNotified)
                {
                    allDownloadsCompletedNotified = true;
                    ShowNotification("Todas las descargas completadas", 
                        $"🎉 Finalizadas {completed} descargas exitosas\n\n" +
                        $"Total descargado: {totalSize}\n" +
                        $"Fallidas: {failed}", 
                        ToolTipIcon.Info);
                    AutoLog($"🎉 Todas las descargas completadas: {completed} exitosas, {failed} fallidas");
                }
                
                // Resetear flag si hay nuevas descargas
                if (pending > 0 || downloading > 0)
                {
                    allDownloadsCompletedNotified = false;
                }
            }
            catch
            {
                // Ignorar errores en actualización de stats
            }
        }

        private void DeleteIncompleteFile(string filePath, string reason)
        {
            try
            {
                if (System.IO.File.Exists(filePath))
                {
                    var fileInfo = new FileInfo(filePath);
                    long fileSize = fileInfo.Length;
                    
                    System.IO.File.Delete(filePath);
                    AutoLog($"🗑️ Archivo incompleto eliminado ({reason}): {Path.GetFileName(filePath)} ({FormatFileSize(fileSize)})");

                    AppendDownloadFlowLog(
                        "incomplete_deleted",
                        task: null,
                        reason: reason,
                        extra: $"size_bytes={fileSize}",
                        localPathOverride: filePath);
                }
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ No se pudo eliminar archivo incompleto: {ex.Message}");
            }
        }

        private void UpdateDownloadUI(DownloadTask task, string status)
        {
            if (isShuttingDown)
            {
                return;
            }

            status ??= string.Empty;

            var shouldMark = true;
            try
            {
                var nowUtc = DateTime.UtcNow;
                lock (downloadUiThrottleLock)
                {
                    if (downloadUiThrottle.TryGetValue(task, out var prev))
                    {
                        var same = string.Equals(prev.status, status, StringComparison.Ordinal);
                        if (same && (nowUtc - prev.lastUtc).TotalMilliseconds < DOWNLOAD_UI_THROTTLE_MS)
                        {
                            shouldMark = false;
                        }
                    }
                    downloadUiThrottle[task] = (nowUtc, status);
                }
            }
            catch
            {
            }

            try
            {
                task.UiStatusText = status;
            }
            catch
            {
            }

            if (shouldMark)
            {
                MarkDownloadsDirty();
            }
        }

        private void AddToDownloadQueue(AutoSearchFileResult file, string localPath, ListViewItem listItem, bool forceRedownload = false)
        {
            DownloadTask task = null;
            var deferAlternativeSearch = false;
            var cooldownReason = DownloadFailureReason.Unknown;
            var cooldownRemaining = TimeSpan.Zero;
            
            lock (downloadQueueLock)
            {
                // Validar que el archivo no sea basura o tenga nombre inválido
                if (IsGarbageFile(file.FileName))
                {
                    AutoLog($"🗑️ Archivo basura ignorado: {file.FileName}");
                    return;
                }
                
                // Verificar si está blacklisteado
                if (IsFileBlacklisted(file.FileName, file.Username))
                {
                    AutoLog($"🚫 Archivo blacklisteado ignorado: {file.FileName}");
                    return;
                }
                
                // OPTIMIZACIÓN DÍA 3: Usar Bloom filter para detección rápida de duplicados
                // TEMPORAL: Comentado hasta resolver RustInterop - usando verificación directa
                if (downloadQueue.Any(t => t.File.FileName == file.FileName && t.File.Username == file.Username))
                {
                    return;
                }

                try
                {
                    if (!forceRedownload && downloadManager != null
                        && downloadManager.TryGetCooldownInfo(file.Username, out cooldownReason, out cooldownRemaining)
                        && (cooldownReason == DownloadFailureReason.QueueFull || cooldownReason == DownloadFailureReason.Timeout)
                        && cooldownRemaining > TimeSpan.Zero)
                    {
                        deferAlternativeSearch = true;
                    }
                }
                catch
                {
                    deferAlternativeSearch = false;
                }

                if (!deferAlternativeSearch)
                {
                    // Detectar duplicados en carpeta de descargas (si no es forzado)
                    if (!forceRedownload && System.IO.File.Exists(localPath))
                    {
                        var existingFileInfo = new FileInfo(localPath);
                        long sizeDiff = Math.Abs(existingFileInfo.Length - file.SizeBytes);
                        
                        // Si el archivo existe y tiene tamaño similar (±1KB)
                        if (sizeDiff < 1024)
                        {
                            AutoLog($"⚠️ Duplicado detectado: {file.FileName} ya existe ({FormatFileSize(existingFileInfo.Length)})");
                            
                            // Preguntar al usuario
                            var result = MessageBox.Show(
                                $"El archivo ya existe:\n\n{file.FileName}\n\nTamaño existente: {FormatFileSize(existingFileInfo.Length)}\nTamaño nuevo: {file.SizeReadable}\n\n¿Descargar de nuevo?",
                                "Duplicado detectado",
                                MessageBoxButtons.YesNo,
                                MessageBoxIcon.Question
                            );
                            
                            if (result == DialogResult.No)
                            {
                                AutoLog($"⏭️ Descarga omitida: {file.FileName}");
                                if (listItem != null)
                                {
                                    SafeInvoke(() =>
                                    {
                                        if (lvDownloads != null && lvDownloads.VirtualMode)
                                        {
                                            return;
                                        }

                                        listItem.SubItems[5].Text = "⏭️ Ya existe";
                                        listItem.ForeColor = Color.Gray;
                                    });
                                }
                                return;
                            }
                        }
                    }

                    // OPTIMIZACIÓN DÍA 5: Usar Object Pool para reducir allocaciones
                    task = DownloadTaskPool.Instance.Rent();
                    task.File = file;
                    task.TargetPath = localPath;
                    task.LocalPath = GetIncompleteDownloadPath(localPath, file);
                    task.Status = DownloadStatus.Queued;
                    task.ListViewItem = listItem;
                }

                // Habilitar multi-source para archivos grandes (>50MB)
                if (!deferAlternativeSearch && task != null && file.SizeBytes > 50 * 1024 * 1024)
                {
                    _ = Task.Run(async () =>
                    {
                        var sources = await FindMultipleSources(file, 3);
                        if (sources.Count > 1)
                        {
                            task.AlternativeSources = sources;
                            task.IsMultiSource = true;
                            AutoLog($"🚀 Multi-source habilitado para {file.FileName}: {sources.Count} fuentes");
                        }
                    });
                }

                // Todas las descargas se agregan al final de la cola (FIFO)
            }

            if (deferAlternativeSearch)
            {
                AutoLog($"⛔ Proveedor en cooldown ({cooldownReason}, {cooldownRemaining:mm\\:ss}): {file.Username} - buscando alternativa...");
                if (listItem != null)
                {
                    SafeInvoke(() =>
                    {
                        try
                        {
                            if (lvDownloads != null && lvDownloads.VirtualMode)
                            {
                                return;
                            }

                            listItem.SubItems[5].Text = $"🔍 Alternativa ({cooldownReason})...";
                        }
                        catch
                        {
                        }
                    });
                }

                _ = Task.Run(async () =>
                {
                    try
                    {
                        // OPTIMIZACIÓN DÍA 5: Usar Object Pool para reducir allocaciones
                        var seedTask = DownloadTaskPool.Instance.Rent();
                        seedTask.File = file;
                        seedTask.TargetPath = localPath;
                        seedTask.LocalPath = GetIncompleteDownloadPath(localPath, file);
                        seedTask.Status = DownloadStatus.Queued;
                        seedTask.ListViewItem = listItem;
                        seedTask.ErrorMessage = $"Cooldown ({cooldownReason})";
                        seedTask.LastFailureReason = cooldownReason;

                        var result = await downloadManager.TryFindAlternativeProviderAsync(seedTask);
                        if (result != null && result.Success && seedTask.File != null
                            && !string.Equals(seedTask.File.Username, file.Username, StringComparison.OrdinalIgnoreCase))
                        {
                            SafeInvoke(() =>
                            {
                                try
                                {
                                    if (listItem != null)
                                    {
                                        listItem.Tag = seedTask.File;
                                    }
                                }
                                catch
                                {
                                }

                                AddToDownloadQueue(seedTask.File, localPath, listItem, forceRedownload: forceRedownload);
                            });
                            return;
                        }

                        SafeInvoke(() =>
                        {
                            try
                            {
                                if (lvDownloads != null && lvDownloads.VirtualMode)
                                {
                                    return;
                                }

                                if (listItem != null)
                                {
                                    listItem.SubItems[5].Text = $"⛔ Cooldown ({cooldownReason})";
                                    listItem.ForeColor = Color.Gray;
                                }
                            }
                            catch
                            {
                            }
                        });
                    }
                    catch
                    {
                    }
                });

                return;
            }

            var enqueued = false;
            try
            {
                if (downloadManager != null)
                {
                    enqueued = downloadManager.AddToQueue(task);
                }
                else
                {
                    lock (downloadQueueLock)
                    {
                        downloadQueue.Add(task);
                        enqueued = true;
                        
                        // OPTIMIZACIÓN DÍA 3: Agregar al Bloom filter para detección rápida de duplicados
                        // TEMPORAL: Comentado hasta resolver RustInterop
                        /*
                        if (downloadBloomFilter != null && task?.File != null)
                        {
                            var downloadKey = $"{task.File.Username}|{task.File.FileName}";
                            downloadBloomFilter.Add(downloadKey);
                        }
                        */
                    }
                }
            }
            catch
            {
                enqueued = false;
            }

            if (!enqueued)
            {
                return;
            }

            try
            {
                queuePositionTracker?.TrackFile(file.Username, file.FileName);
            }
            catch
            {
            }

            int queueCount;
            lock (downloadQueueLock)
            {
                queueCount = downloadQueue.Count;
                totalDownloadsInSession = Math.Max(totalDownloadsInSession, queueCount);
            }

            AutoLog($"📋 Agregado a cola: {file.FileName} ({queueCount} en cola)");
            
            // Actualizar UI inmediatamente
            UpdateDownloadUI(task, "⏳ En cola...");

            MarkDownloadStatsDirty();
            ScheduleQueuePrioritization();

            // Iniciar gestor si no está corriendo
            if (!downloadManagerRunning && !downloadsRequireManualStart)
            {
                _ = Task.Run(async () => await StartDownloadManager());
            }
            
            // MODO AUTOMÁTICO: Limpiar resultados si hay muchos
            AutoCleanSearchResults();
        }

        private void CancelDownload(DownloadTask task)
        {
            try
            {
                if (downloadManager != null)
                {
                    downloadManager.CancelTask(task, removeFromQueue: task.Status != DownloadStatus.Downloading);
                }
                else
                {
                    if (task.Status == DownloadStatus.Downloading)
                    {
                        task.CancellationToken?.Cancel();
                    }
                    else if (task.Status == DownloadStatus.Queued)
                    {
                        lock (downloadQueueLock)
                        {
                            downloadQueue.Remove(task);
                        }
                        task.Status = DownloadStatus.Cancelled;
                        UpdateDownloadUI(task, "⏹️ Cancelado");
                    }
                }
            }
            catch
            {
            }

            MarkDownloadStatsDirty();
            ScheduleQueuePrioritization();
        }

        private void WriteAllTextAtomic(string path, string content, Encoding encoding)
        {
            var directory = Path.GetDirectoryName(path);
            if (!string.IsNullOrWhiteSpace(directory) && !Directory.Exists(directory))
            {
                Directory.CreateDirectory(directory);
            }

            var tempPath = path + ".tmp";
            System.IO.File.WriteAllText(tempPath, content, encoding);
            System.IO.File.Move(tempPath, path, true);
        }

        private static void AddFileIfExists(ZipArchive archive, string filePath, string entryName)
        {
            if (archive == null)
            {
                return;
            }
            if (string.IsNullOrWhiteSpace(filePath) || string.IsNullOrWhiteSpace(entryName))
            {
                return;
            }
            if (!File.Exists(filePath))
            {
                return;
            }

            archive.CreateEntryFromFile(filePath, entryName, CompressionLevel.Optimal);
        }

        private static void AddTextEntry(ZipArchive archive, string entryName, string content)
        {
            if (archive == null)
            {
                return;
            }
            if (string.IsNullOrWhiteSpace(entryName))
            {
                return;
            }

            var entry = archive.CreateEntry(entryName, CompressionLevel.Optimal);
            using var stream = entry.Open();
            using var writer = new StreamWriter(stream, new UTF8Encoding(encoderShouldEmitUTF8Identifier: false));
            writer.Write(content ?? string.Empty);
        }

        private void WriteAllBytesAtomic(string path, byte[] content)
        {
            var directory = Path.GetDirectoryName(path);
            if (!string.IsNullOrWhiteSpace(directory) && !Directory.Exists(directory))
            {
                Directory.CreateDirectory(directory);
            }

            var tempPath = path + ".tmp";
            System.IO.File.WriteAllBytes(tempPath, content);
            System.IO.File.Move(tempPath, path, true);
        }

        private async Task SaveAutoResultsToJsonAsync()
        {
            // Evitar escrituras concurrentes
            if (!Monitor.TryEnter(jsonSaveLock, 0))
            {
                // Ya hay otra operación de guardado en curso, salir silenciosamente
                return;
            }
            
            try
            {
                List<AutoSearchFileResult> snapshot;
                lock (autoSearchResultsLock)
                {
                    snapshot = autoSearchResults.ToList();
                }

                if (!System.IO.Directory.Exists(dataDir))
                {
                    System.IO.Directory.CreateDirectory(dataDir);
                }

                // Optimización #7: Comprimir con Brotli (70-90% menos espacio)
                var compressedPath = autoSearchResultsJsonPath + ".br";
                var compressedTempPath = compressedPath + ".tmp";
                long originalSize = 0;
                long compressedSize = 0;
                
                await Task.Run(() =>
                {
                    using (var fileStream = System.IO.File.Create(compressedTempPath))
                    using (var brotliStream = new System.IO.Compression.BrotliStream(fileStream, System.IO.Compression.CompressionLevel.Fastest))
                    {
                        var jsonBytes = JsonSerializer.SerializeToUtf8Bytes(snapshot);
                        originalSize = jsonBytes.Length;
                        brotliStream.Write(jsonBytes, 0, jsonBytes.Length);
                        compressedSize = fileStream.Length;
                    }
                });

                System.IO.File.Move(compressedTempPath, compressedPath, true);
                
                var compressionRatio = (1 - (double)compressedSize / originalSize) * 100;
                AutoLog($"💾 JSON comprimido: {snapshot.Count} archivos | {FormatFileSize(originalSize)} → {FormatFileSize(compressedSize)} ({compressionRatio:F1}% reducción)");
            }
            catch (Exception ex)
            {
                try
                {
                    var compressedPath = autoSearchResultsJsonPath + ".br";
                    var compressedTempPath = compressedPath + ".tmp";
                    if (System.IO.File.Exists(compressedTempPath))
                    {
                        System.IO.File.Delete(compressedTempPath);
                    }
                }
                catch
                {
                }
                AutoLog($"❌ Error guardando JSON comprimido: {ex.Message}");
            }
            finally
            {
                Monitor.Exit(jsonSaveLock);
            }
        }

        private void SaveAutoResultsToJson()
        {
            // Versión síncrona para compatibilidad
            _ = SaveAutoResultsToJsonAsync();
        }

        private void LoadAutoResultsFromJson()
        {
            try
            {
                // Optimización #7: Intentar cargar archivo comprimido primero
                var compressedPath = autoSearchResultsJsonPath + ".br";
                List<AutoSearchFileResult> results = null;
                
                if (System.IO.File.Exists(compressedPath))
                {
                    using (var fileStream = System.IO.File.OpenRead(compressedPath))
                    using (var brotliStream = new System.IO.Compression.BrotliStream(fileStream, System.IO.Compression.CompressionMode.Decompress))
                    {
                        results = JsonSerializer.Deserialize<List<AutoSearchFileResult>>(brotliStream);
                    }
                    AutoLog($"📂 Cargados {results?.Count ?? 0} resultados desde JSON comprimido");
                }
                else if (System.IO.File.Exists(autoSearchResultsJsonPath))
                {
                    // Fallback a JSON sin comprimir
                    var json = System.IO.File.ReadAllText(autoSearchResultsJsonPath, Encoding.UTF8);
                    results = JsonSerializer.Deserialize<List<AutoSearchFileResult>>(json);
                    AutoLog($"📂 Cargados {results?.Count ?? 0} resultados desde JSON sin comprimir");
                }
                else
                {
                    AutoLog("📂 No hay resultados previos guardados");
                    return;
                }

                if (results != null && results.Count > 0)
                {
                    lock (autoSearchResultsLock)
                    {
                        autoSearchResults.Clear();
                        autoSearchResults.AddRange(results);
                    }
                }
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error cargando JSON: {ex.Message}");
            }
        }

        private void SaveDownloadHistory()
        {
            try
            {
                List<DownloadHistoryRecord> snapshot;
                lock (downloadHistoryLock)
                {
                    snapshot = downloadHistory.ToList();
                }

                if (!System.IO.Directory.Exists(dataDir))
                {
                    System.IO.Directory.CreateDirectory(dataDir);
                }

                var json = JsonSerializer.Serialize(snapshot, new JsonSerializerOptions { WriteIndented = true });
                WriteAllTextAtomic(downloadHistoryPath, json, Encoding.UTF8);
                
                // Actualizar UI del historial
                UpdateHistoryUI();
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error guardando historial: {ex.Message}");
            }
        }
        
        private void UpdateHistoryUI()
        {
            if (lvHistory == null)
                return;
            
            SafeInvoke(() =>
            {
                try
                {
                    lvHistory.BeginUpdate();
                    
                    // Obtener el último item agregado
                    DownloadHistoryRecord lastItem = null;
                    lock (downloadHistoryLock)
                    {
                        if (downloadHistory.Count > 0)
                            lastItem = downloadHistory[downloadHistory.Count - 1];
                    }
                    
                    if (lastItem != null)
                    {
                        // Verificar si ya existe en la UI
                        bool exists = false;
                        foreach (ListViewItem item in lvHistory.Items)
                        {
                            if (item.SubItems[1].Text == lastItem.FileName && 
                                item.SubItems[0].Text == lastItem.DownloadedAt.ToString("yyyy-MM-dd HH:mm:ss"))
                            {
                                exists = true;
                                break;
                            }
                        }
                        
                        // Si no existe, agregarlo al principio
                        if (!exists)
                        {
                            if (chkHistoryOnlySpanish != null && chkHistoryOnlySpanish.Checked && lastItem.IsSpanish != true)
                            {
                                return;
                            }

                            var listItem = new ListViewItem(lastItem.DownloadedAt.ToString("yyyy-MM-dd HH:mm:ss"));
                            listItem.SubItems.Add(lastItem.FileName);
                            listItem.SubItems.Add(lastItem.Author ?? "-");
                            var extension = Path.GetExtension(lastItem.FileName)?.TrimStart('.').ToUpperInvariant() ?? "-";
                            listItem.SubItems.Add(extension);
                            listItem.SubItems.Add(lastItem.Username);
                            listItem.SubItems.Add(FormatFileSize(lastItem.SizeBytes));
                            listItem.SubItems.Add($"{lastItem.SpeedMBps:F2} MB/s");
                            listItem.SubItems.Add(lastItem.Status);
                            listItem.SubItems.Add(RenderSpanishFlag(lastItem));
                            
                            listItem.ForeColor = lastItem.Status == "Completed" ? Color.LightGreen : Color.Red;
                            
                            // Insertar al principio
                            lvHistory.Items.Insert(0, listItem);
                            
                            // Actualizar estadísticas
                            var completed = downloadHistory.Count(h => h.Status == "Completed");
                            var failed = downloadHistory.Count(h => h.Status == "Failed");
                            var totalSize = FormatFileSize(downloadHistory.Where(h => h.Status == "Completed").Sum(h => h.SizeBytes));
                            
                            // Buscar el label de estadísticas
                            var historyTab = tabControl?.TabPages.Cast<TabPage>().FirstOrDefault(t => t.Text.Contains("Historial"));
                            if (historyTab != null)
                            {
                                var lblStats = historyTab.Controls.OfType<TableLayoutPanel>().FirstOrDefault()
                                    ?.Controls.OfType<FlowLayoutPanel>().FirstOrDefault()
                                    ?.Controls.OfType<Label>().FirstOrDefault(l => l.Text.Contains("Total:"));
                                
                                if (lblStats != null)
                                {
                                    lblStats.Text = $"Total: {downloadHistory.Count} | Mostrando: {lvHistory.Items.Count} | ✅ {completed} | ❌ {failed} | 📦 {totalSize}";
                                }
                            }
                        }
                    }
                }
                finally
                {
                    lvHistory.EndUpdate();
                }
            });
        }

        private void LoadDownloadHistory()
        {
            try
            {
                if (!System.IO.File.Exists(downloadHistoryPath))
                    return;

                var json = System.IO.File.ReadAllText(downloadHistoryPath, Encoding.UTF8);
                var history = JsonSerializer.Deserialize<List<DownloadHistoryRecord>>(json);

                if (history != null)
                {
                    lock (downloadHistoryLock)
                    {
                        downloadHistory.Clear();
                        downloadHistory.AddRange(history);

                        downloadHistoryCache.Clear();
                        downloadHistoryHashCache.Clear();
                        foreach (var record in history)
                        {
                            if (!string.IsNullOrWhiteSpace(record.FileName))
                            {
                                downloadHistoryCache.Add(record.FileName);
                            }
                            if (!string.IsNullOrWhiteSpace(record.Hash))
                            {
                                downloadHistoryHashCache.Add(record.Hash);
                            }
                        }
                    }
                    AutoLog($"📂 Cargado historial: {history.Count} descargas");
                }
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error cargando historial: {ex.Message}");
            }
        }
        
        private void ScanDownloadFolderToHistory(Action<string> log = null)
        {
            try
            {
                var downloadPath = txtDownloadDir?.Text ?? 
                    Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments), "SlskDown");
                
                if (!System.IO.Directory.Exists(downloadPath))
                {
                    log?.Invoke($"⚠️ Carpeta de descargas no existe: {downloadPath}");
                    return;
                }
                
                log?.Invoke("📂 Escaneando carpeta de descargas...");
                log?.Invoke($"   Ruta: {downloadPath}");
                var sw = System.Diagnostics.Stopwatch.StartNew();
                
                var files = System.IO.Directory.GetFiles(downloadPath, "*.*", SearchOption.AllDirectories)
                    .Where(IsHistorySyncCandidateFile)
                    .ToList();
                
                log?.Invoke($"   Encontrados {files.Count:N0} archivos");
                
                var newHistory = new List<DownloadHistoryRecord>(files.Count);
                var newCache = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

                foreach (var filePath in files)
                {
                    try
                    {
                        var effectivePath = filePath;
                        bool? isSpanish = null;
                        try
                        {
                            isSpanish = IsSpanishFileByContent(effectivePath);
                        }
                        catch
                        {
                            isSpanish = null;
                        }

                        if (isSpanish == false)
                        {
                            effectivePath = MoveNonSpanishDownloadedFile(effectivePath);
                        }

                        var fileInfo = new FileInfo(effectivePath);
                        var fileName = Path.GetFileName(effectivePath);

                        if (!newCache.Add(fileName))
                        {
                            continue;
                        }

                        newHistory.Add(new DownloadHistoryRecord
                        {
                            FileName = fileName,
                            Author = "",
                            Hash = "",
                            Username = "",
                            SizeBytes = fileInfo.Length,
                            DownloadedAt = fileInfo.LastWriteTime,
                            Status = "Existente",
                            SpeedMBps = 0,
                            RelativePath = GetRelativePathSafe(effectivePath, downloadPath),
                            IsSpanish = isSpanish
                        });
                    }
                    catch (Exception ex)
                    {
                        log?.Invoke($"⚠️ Error procesando {Path.GetFileName(filePath)}: {ex.Message}");
                    }
                }

                lock (downloadHistoryLock)
                {
                    downloadHistory.Clear();
                    downloadHistory.AddRange(newHistory);
                    downloadHistoryCache.Clear();
                    downloadHistoryHashCache.Clear();
                    foreach (var name in newCache)
                    {
                        downloadHistoryCache.Add(name);
                    }
                }
                
                sw.Stop();
                downloadHistoryLoaded = true;
                log?.Invoke($"✅ Historial de descargas inicializado:");
                log?.Invoke($"   • Total archivos: {downloadHistory.Count:N0}");
                log?.Invoke($"   • Tiempo: {sw.ElapsedMilliseconds:N0}ms ({sw.Elapsed.TotalSeconds:F1}s)");
            }
            catch (Exception ex)
            {
                log?.Invoke($"❌ Error escaneando carpeta de descargas: {ex.Message}");
                downloadHistoryLoaded = true; // Marcar como cargado para no reintentar
            }
        }

        private static bool IsHistorySyncCandidateFile(string filePath)
        {
            if (string.IsNullOrWhiteSpace(filePath))
            {
                return false;
            }

            var fileName = Path.GetFileName(filePath);
            if (string.IsNullOrWhiteSpace(fileName))
            {
                return false;
            }

            var ext = Path.GetExtension(fileName);
            if (string.IsNullOrWhiteSpace(ext))
            {
                return true;
            }

            if (ext.Equals(".zst", StringComparison.OrdinalIgnoreCase))
            {
                return false;
            }

            if (ext.Equals(".crc32", StringComparison.OrdinalIgnoreCase))
            {
                return false;
            }

            if (ext.Equals(".tmp", StringComparison.OrdinalIgnoreCase)
                || ext.Equals(".part", StringComparison.OrdinalIgnoreCase)
                || ext.Equals(".partial", StringComparison.OrdinalIgnoreCase)
                || ext.Equals(".download", StringComparison.OrdinalIgnoreCase)
                || ext.Equals(".aria2", StringComparison.OrdinalIgnoreCase))
            {
                return false;
            }

            return true;
        }
        
        private bool IsAlreadyDownloaded(string fileName, string username, long size)
        {
            // Si el historial no está cargado aún, no filtrar (evitar falsos positivos)
            if (!downloadHistoryLoaded)
                return false;
            
            // Usar HashSet para lookup O(1) en vez de .Any() O(n)
            return downloadHistoryCache.Contains(fileName);
        }

        private void SaveStatistics()
        {
            try
            {
                if (!System.IO.Directory.Exists(dataDir))
                {
                    System.IO.Directory.CreateDirectory(dataDir);
                }

                var json = JsonSerializer.Serialize(statistics, new JsonSerializerOptions { WriteIndented = true });
                lock (jsonSaveLock)
                {
                    for (int attempt = 0; attempt < 3; attempt++)
                    {
                        try
                        {
                            using (var stream = new FileStream(statsPath, FileMode.Create, FileAccess.Write, FileShare.Read))
                            using (var writer = new StreamWriter(stream, Encoding.UTF8))
                            {
                                writer.Write(json);
                            }
                            break;
                        }
                        catch (IOException) when (attempt < 2)
                        {
                            Thread.Sleep(50);
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error guardando estadísticas: {ex.Message}");
            }
        }

        private void LoadStatistics()
        {
            try
            {
                if (!System.IO.File.Exists(statsPath))
                {
                    statistics = new AppStatistics();
                    return;
                }

                var json = System.IO.File.ReadAllText(statsPath, Encoding.UTF8);
                var stats = JsonSerializer.Deserialize<AppStatistics>(json);
                
                if (stats != null)
                {
                    statistics = stats;
                    AutoLog($"📊 Estadísticas cargadas: {statistics.TotalFilesDownloaded} descargas");
                }
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error cargando estadísticas: {ex.Message}");
                statistics = new AppStatistics();
            }
        }

        private async Task<(bool IsValid, string Message)> VerifyFileIntegrity(string filePath, long expectedSize)
        {
            try
            {
                if (!System.IO.File.Exists(filePath))
                    return (false, "Archivo no existe");

                var fileInfo = new FileInfo(filePath);
                
                // Verificar tamaño
                if (fileInfo.Length != expectedSize)
                {
                    return (false, $"Tamaño incorrecto: {fileInfo.Length} bytes (esperado: {expectedSize})");
                }

                // Calcular hash con BLAKE3 (10x más rápido que MD5)
                try
                {
                    var hashString = await Task.Run(() => SlskDownCore.HashFileBlake3(filePath));
                    return (true, $"BLAKE3: {hashString}");
                }
                catch (Exception hashEx)
                {
                    // Fallback a MD5 si Rust falla
                    AutoLog($"⚠️ Error con BLAKE3, usando MD5: {hashEx.Message}");
                    using (var md5 = System.Security.Cryptography.MD5.Create())
                    using (var stream = System.IO.File.OpenRead(filePath))
                    {
                        var hash = await Task.Run(() => md5.ComputeHash(stream));
                        var hashString = BitConverter.ToString(hash).Replace("-", "").ToLowerInvariant();
                        return (true, $"MD5: {hashString}");
                    }
                }
            }
            catch (Exception ex)
            {
                return (false, $"Error: {ex.Message}");
            }
        }
        
        private async Task VerifyDownloadedFiles()
        {
            try
            {
                AutoLog("🔍 Iniciando verificación de archivos descargados...");
                
                var filesToVerify = new List<(string path, long size, string author)>();
                
                // Obtener archivos del historial de descargas
                lock (downloadHistoryLock)
                {
                    foreach (var item in downloadHistory)
                    {
                        var filePath = GetDownloadPath(downloadDir, item.FileName, item.Author);
                        if (System.IO.File.Exists(filePath))
                        {
                            filesToVerify.Add((filePath, item.SizeBytes, item.Author));
                        }
                    }
                }
                
                if (filesToVerify.Count == 0)
                {
                    AutoLog("⚠️ No hay archivos para verificar");
                    MessageBox.Show("No hay archivos descargados para verificar", "Verificación", 
                        MessageBoxButtons.OK, MessageBoxIcon.Information);
                    return;
                }
                
                AutoLog($"📋 Verificando {filesToVerify.Count} archivos...");
                
                int valid = 0;
                int invalid = 0;
                var invalidFiles = new List<string>();
                
                foreach (var (path, size, author) in filesToVerify)
                {
                    var (isValid, message) = await VerifyFileIntegrity(path, size);
                    
                    if (isValid)
                    {
                        valid++;
                    }
                    else
                    {
                        invalid++;
                        invalidFiles.Add($"{Path.GetFileName(path)}: {message}");
                        AutoLog($"❌ {Path.GetFileName(path)}: {message}");
                    }
                }
                
                AutoLog($"✅ Verificación completada: {valid} válidos, {invalid} inválidos");
                
                var resultMessage = $"Verificación completada:\n\n" +
                                   $"✅ Válidos: {valid}\n" +
                                   $"❌ Inválidos: {invalid}";
                
                if (invalidFiles.Count > 0)
                {
                    resultMessage += $"\n\nArchivos con problemas:\n{string.Join("\n", invalidFiles.Take(10))}";
                    if (invalidFiles.Count > 10)
                        resultMessage += $"\n... y {invalidFiles.Count - 10} más";
                }
                
                MessageBox.Show(resultMessage, "Verificación de Archivos", 
                    MessageBoxButtons.OK, invalid > 0 ? MessageBoxIcon.Warning : MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error en verificación: {ex.Message}");
                MessageBox.Show($"Error durante la verificación: {ex.Message}", "Error", 
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
        
        private void ShowDashboard()
        {
            try
            {
                AutoLog("📊 Abriendo Dashboard...");
                
                var dashboardForm = new Form
                {
                    Text = "📊 Dashboard de Estadísticas",
                    Size = new Size(900, 700),
                    BackColor = Color.FromArgb(20, 20, 20),
                    ForeColor = Color.White,
                    StartPosition = FormStartPosition.CenterScreen,
                    FormBorderStyle = FormBorderStyle.Sizable,
                    MinimumSize = new Size(700, 500)
                };
                
                var mainPanel = new Panel
                {
                    Dock = DockStyle.Fill,
                    Padding = new Padding(20),
                    AutoScroll = true
                };
                
                var lblStats = new Label
                {
                    Dock = DockStyle.Fill,
                    Font = new Font("Consolas", 10),
                    TextAlign = ContentAlignment.TopLeft,
                    AutoSize = false
                };
                
                mainPanel.Controls.Add(lblStats);
                dashboardForm.Controls.Add(mainPanel);
                
                // Método para actualizar estadísticas
                Action updateStats = () =>
                {
                    try
                    {
                        var stats = new StringBuilder();
                        
                        stats.AppendLine("═══════════════════════════════════════════════════════════════");
                        stats.AppendLine("📊 DASHBOARD DE ESTADÍSTICAS - ACTUALIZACIÓN EN TIEMPO REAL");
                        stats.AppendLine("═══════════════════════════════════════════════════════════════");
                        stats.AppendLine();
                        
                        // SECCIÓN 1: Biblioteca General
                        stats.AppendLine("📚 BIBLIOTECA GENERAL");
                        stats.AppendLine("─────────────────────────────────────────────────────────────");
                        
                        int totalFiles = 0;
                        long totalSize = 0;
                        int withHash = 0;
                        
                        lock (downloadHistoryLock)
                        {
                            totalFiles = downloadHistory.Count;
                            totalSize = downloadHistory.Sum(h => h.SizeBytes);
                            withHash = downloadHistory.Count(h => !string.IsNullOrEmpty(h.Hash));
                        }
                        
                        stats.AppendLine($"   📁 Total de archivos: {totalFiles:N0}");
                        stats.AppendLine($"   💾 Espacio total: {FormatFileSize(totalSize)}");
                        stats.AppendLine($"   🔐 Con hash: {withHash:N0} ({(totalFiles > 0 ? (withHash * 100.0 / totalFiles) : 0):F1}%)");
                        stats.AppendLine();
                        
                        // SECCIÓN 2: Búsqueda Automática
                        stats.AppendLine("🔍 BÚSQUEDA AUTOMÁTICA");
                        stats.AppendLine("─────────────────────────────────────────────────────────────");
                        
                        int totalAuthors = 0;
                        int totalAutoFiles = 0;
                        
                        lock (autoSearchResultsLock)
                        {
                            totalAutoFiles = autoSearchResults.Count;
                            totalAuthors = autoSearchResults.Select(f => f.Author).Distinct().Count();
                        }
                        
                        stats.AppendLine($"   👥 Autores indexados: {totalAuthors:N0}");
                        stats.AppendLine($"   📄 Archivos encontrados: {totalAutoFiles:N0}");
                        stats.AppendLine($"   ⚡ Paralelismo búsqueda: {maxParallelAutoSearches}");
                        stats.AppendLine($"   🧹 Paralelismo purga: {maxParallelPurgeSearches}");
                        stats.AppendLine();
                        
                        // SECCIÓN 3: Cola de Descargas
                        stats.AppendLine("📥 COLA DE DESCARGAS");
                        stats.AppendLine("─────────────────────────────────────────────────────────────");
                        
                        int queued = 0;
                        int downloading = 0;
                        int completed = 0;
                        int failed = 0;
                        
                        lock (downloadQueueLock)
                        {
                            queued = downloadQueue.Count(t => t.Status == DownloadStatus.Queued);
                            downloading = downloadQueue.Count(t => t.Status == DownloadStatus.Downloading);
                            completed = downloadQueue.Count(t => t.Status == DownloadStatus.Completed);
                            failed = downloadQueue.Count(t => t.Status == DownloadStatus.Failed);
                        }
                        
                        stats.AppendLine($"   ⏳ En cola: {queued:N0}");
                        stats.AppendLine($"   📥 Descargando: {downloading:N0}");
                        stats.AppendLine($"   ✅ Completadas: {completed:N0}");
                        stats.AppendLine($"   ❌ Fallidas: {failed:N0}");
                        stats.AppendLine($"   🔄 Descargas simultáneas: {maxSimultaneousDownloads}");
                        stats.AppendLine();
                        
                        // SECCIÓN 4: Rendimiento
                        stats.AppendLine("⚡ RENDIMIENTO");
                        stats.AppendLine("─────────────────────────────────────────────────────────────");
                        stats.AppendLine($"   🕐 Sesión iniciada: {sessionStartTime:HH:mm:ss}");
                        stats.AppendLine($"   ⏱️ Tiempo activo: {(DateTime.Now - sessionStartTime).ToString(@"hh\:mm\:ss")}");
                        stats.AppendLine($"   💾 Memoria: {GC.GetTotalMemory(false) / 1024 / 1024:N0} MB");
                        stats.AppendLine($"   📦 Total descargado: {FormatFileSize(statistics.TotalBytesDownloaded)}");

                        string FormatSpeed(double value) => value > 0 ? $"{value:F2} MB/s" : "N/A";

                        stats.AppendLine($"   📈 Última velocidad: {FormatSpeed(statistics.LastDownloadSpeed)}");
                        stats.AppendLine($"   🚀 Pico histórico: {FormatSpeed(statistics.PeakDownloadSpeed)}");
                        stats.AppendLine($"   📊 Promedio por archivo: {FormatSpeed(statistics.AverageThroughputPerFile)}");
                        stats.AppendLine($"   🧮 Muestras: {statistics.ThroughputSamples:N0}");
                        stats.AppendLine();

                        stats.AppendLine("═══════════════════════════════════════════════════════════════");
                        stats.AppendLine($"Última actualización: {DateTime.Now:HH:mm:ss}");
                        
                        lblStats.Text = stats.ToString();
                    }
                    catch (Exception ex)
                    {
                        lblStats.Text = $"❌ Error actualizando dashboard: {ex.Message}";
                    }
                };
                
                // Actualizar inmediatamente
                updateStats();
                
                // Timer para actualizar cada 2 segundos
                var updateTimer = new System.Windows.Forms.Timer { Interval = 2000 };
                updateTimer.Tick += (s, e) => updateStats();
                updateTimer.Start();
                
                // Detener timer al cerrar
                dashboardForm.FormClosed += (s, e) =>
                {
                    updateTimer.Stop();
                    updateTimer.Dispose();
                    AutoLog("📊 Dashboard cerrado");
                };
                
                dashboardForm.Show();
                AutoLog("📊 Dashboard abierto");
            }
            catch (Exception ex)
            {
                AutoLog($"❌ Error abriendo dashboard: {ex.Message}");
                MessageBox.Show($"Error abriendo dashboard: {ex.Message}", "Error", 
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private void RemoveDuplicateDownloadTasks(DownloadTask completedTask)
        {
            try
            {
                if (completedTask?.File == null)
                    return;

                var fileName = completedTask.File.FileName;
                var fileSize = completedTask.File.SizeBytes;
                var completedUsername = completedTask.File.Username;

                int removedCount = downloadQueueService.Update(list =>
                {
                    // Buscar todas las tareas del mismo archivo (mismo nombre y tamaño)
                    var duplicates = list
                        .Where(t => t != completedTask && 
                                   t.File != null &&
                                   t.File.FileName.Equals(fileName, StringComparison.OrdinalIgnoreCase) &&
                                   Math.Abs(t.File.SizeBytes - fileSize) < 1024 && // Tolerancia de 1KB
                                   (t.Status == DownloadStatus.Queued || 
                                    t.Status == DownloadStatus.GettingStatus ||
                                    t.Status == DownloadStatus.Paused))
                        .ToList();

                    foreach (var duplicate in duplicates)
                    {
                        list.Remove(duplicate);
                        
                        // Cancelar si tiene token de cancelación activo
                        try
                        {
                            duplicate.CancellationToken?.Cancel();
                        }
                        catch { }
                    }

                    return duplicates.Count;
                });

                if (removedCount > 0)
                {
                    AutoLog($"🧹 Eliminadas {removedCount} tareas duplicadas de otros proveedores para: {fileName}");
                }
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error eliminando tareas duplicadas: {ex.Message}");
            }
        }

        private string OrganizeDownloadedFile(string filePath, AutoSearchFileResult fileInfo)
        {
            try
            {
                if (!System.IO.File.Exists(filePath))
                    return filePath;

                var downloadDir = Path.GetDirectoryName(filePath);
                var fileName = Path.GetFileName(filePath);

                // Crear estructura de carpetas
                string targetFolder = downloadDir;

                // Por idioma
                if (fileInfo.IsSpanish)
                {
                    targetFolder = Path.Combine(targetFolder, "Español");
                }
                else
                {
                    targetFolder = Path.Combine(targetFolder, "Otros_Idiomas");
                }

                // Por tipo
                if (fileInfo.IsDocument)
                {
                    targetFolder = Path.Combine(targetFolder, "Documentos");
                }
                else
                {
                    targetFolder = Path.Combine(targetFolder, "Otros");
                }

                // Por autor (sanitizar nombre)
                var authorFolder = SanitizeFolderName(fileInfo.Author);
                try
                {
                    var leaf = Path.GetFileName(targetFolder.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar));
                    if (!string.Equals(leaf, authorFolder, StringComparison.OrdinalIgnoreCase))
                    {
                        targetFolder = Path.Combine(targetFolder, authorFolder);
                    }
                }
                catch
                {
                    targetFolder = Path.Combine(targetFolder, authorFolder);
                }

                // Crear carpetas si no existen
                if (!System.IO.Directory.Exists(targetFolder))
                {
                    System.IO.Directory.CreateDirectory(targetFolder);
                }

                // Mover archivo
                var newPath = Path.Combine(targetFolder, fileName);
                
                // Si ya existe, agregar número
                int counter = 1;
                while (System.IO.File.Exists(newPath))
                {
                    var nameWithoutExt = Path.GetFileNameWithoutExtension(fileName);
                    var extension = Path.GetExtension(fileName);
                    newPath = Path.Combine(targetFolder, $"{nameWithoutExt}_{counter}{extension}");
                    counter++;
                }

                System.IO.File.Move(filePath, newPath);
                AutoLog($"📁 Organizado: {fileName} → {Path.GetFileName(targetFolder)}");
                
                return newPath;
            }
            catch (Exception ex)
            {
                AutoLog($"⚠️ Error organizando archivo: {ex.Message}");
                return filePath;
            }
        }

        private string SanitizeFolderName(string name)
        {
            if (string.IsNullOrWhiteSpace(name))
                return "Sin_Autor";

            // 🦀 Usar normalización completa (sin tildes, sin puntos, Title Case)
            var normalized = NormalizeAuthorFolderName(name);
            
            // Limitar longitud
            if (normalized.Length > 50)
                normalized = normalized.Substring(0, 50);

            return normalized.Trim();
        }
        
        /// <summary>
        /// Obtiene el path de descarga, organizando por autor si está activado
        /// Estructura: baseDir/Autor/archivo.epub
        /// 🦀 Usa nombres normalizados (sin tildes, sin puntos en iniciales)
        /// </summary>
        private string GetDownloadPath(string baseDir, string fileName, string authorName = null)
        {
            if (organizeByAuthor && !string.IsNullOrWhiteSpace(authorName))
            {
                // 🦀 Estructura: baseDir/Autor (normalizado)
                // Ejemplos: "José E. E. García" -> "Jose E E Garcia"
                var targetDir = Path.Combine(baseDir, SanitizeFolderName(authorName));
                System.IO.Directory.CreateDirectory(targetDir);
                return Path.Combine(targetDir, fileName);
            }
            else
            {
                // Descarga directa en la carpeta base
                return Path.Combine(baseDir, fileName);
            }
        }

