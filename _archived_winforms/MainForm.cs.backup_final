                if (textLower.Contains(" corazón ") || textLower.Contains(" corazon ")) spanishScore += 2;
                if (textLower.Contains(" alma ")) spanishScore += 2;
                if (textLower.Contains(" espíritu ") || textLower.Contains(" espiritu ")) spanishScore += 2;
                if (textLower.Contains(" mente ")) spanishScore += 2;
                if (textLower.Contains(" cuerpo ")) spanishScore += 2;
                if (textLower.Contains(" mano ")) spanishScore += 2;
