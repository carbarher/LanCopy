                        "• El Señor de los Anillos\n" +
                        "• Neuromante",
                        Color.FromArgb(255, 200, 100));
                }
            }
        }
        
        private string GenerateWeeklyReport()
        {
            var report = new ActivityReport
            {
                StartDate = DateTime.Now.AddDays(-7),
                EndDate = DateTime.Now
            };
            
            lock (downloadQueueLock)
            {
                var weekAgo = DateTime.Now.AddDays(-7);
                report.TotalDownloads = downloadQueue.Count(d => d.StartedAt >= weekAgo);
                report.CompletedDownloads = downloadQueue.Count(d => d.Status == DownloadStatus.Completed && d.CompletedAt >= weekAgo);
                report.FailedDownloads = downloadQueue.Count(d => d.Status == DownloadStatus.Failed && d.StartedAt >= weekAgo);
                report.TotalBytes = downloadQueue
                    .Where(d => d.Status == DownloadStatus.Completed && d.CompletedAt >= weekAgo)
                    .Sum(d => d.File?.SizeBytes ?? 0);
                report.AverageSpeed = GetTotalDownloadSpeed();
                
                report.TopAuthors = downloadQueue
                    .Where(d => d.Status == DownloadStatus.Completed && d.CompletedAt >= weekAgo && d.File != null)
                    .GroupBy(d => d.File.Username)
                    .ToDictionary(g => g.Key, g => g.Count());
                
                report.DailyActivity = new Dictionary<string, int>
                {
                    ["Lun"] = downloadQueue.Count(d => d.CompletedAt?.DayOfWeek == DayOfWeek.Monday && d.CompletedAt >= weekAgo),
                    ["Mar"] = downloadQueue.Count(d => d.CompletedAt?.DayOfWeek == DayOfWeek.Tuesday && d.CompletedAt >= weekAgo),
                    ["Mié"] = downloadQueue.Count(d => d.CompletedAt?.DayOfWeek == DayOfWeek.Wednesday && d.CompletedAt >= weekAgo),
                    ["Jue"] = downloadQueue.Count(d => d.CompletedAt?.DayOfWeek == DayOfWeek.Thursday && d.CompletedAt >= weekAgo),
                    ["Vie"] = downloadQueue.Count(d => d.CompletedAt?.DayOfWeek == DayOfWeek.Friday && d.CompletedAt >= weekAgo),
                    ["Sáb"] = downloadQueue.Count(d => d.CompletedAt?.DayOfWeek == DayOfWeek.Saturday && d.CompletedAt >= weekAgo),
                    ["Dom"] = downloadQueue.Count(d => d.CompletedAt?.DayOfWeek == DayOfWeek.Sunday && d.CompletedAt >= weekAgo)
                };
            }
            
            // Obtener estadísticas reales de búsquedas
            report.TotalSearches = (int)totalSearches;
            
            // Calcular resultados totales de la semana
            lock (downloadQueueLock)
            {
                var weekAgo = DateTime.Now.AddDays(-7);
                report.TotalResults = downloadQueue
                    .Where(d => d.StartedAt >= weekAgo)
                    .Sum(d => 1); // Cada descarga representa un resultado encontrado
            }
            
            return ReportGenerator.GenerateWeeklyReport(report);
        }
        
        private string GenerateDailyReport()
        {
            var report = new ActivityReport
            {
                StartDate = DateTime.Today,
                EndDate = DateTime.Now
            };
            
            lock (downloadQueueLock)
            {
                var today = DateTime.Today;
                report.TotalDownloads = downloadQueue.Count(d => d.StartedAt?.Date == today);
                report.CompletedDownloads = downloadQueue.Count(d => d.Status == DownloadStatus.Completed && d.CompletedAt?.Date == today);
                report.FailedDownloads = downloadQueue.Count(d => d.Status == DownloadStatus.Failed && d.StartedAt?.Date == today);
                report.TotalBytes = downloadQueue
                    .Where(d => d.Status == DownloadStatus.Completed && d.CompletedAt?.Date == today)
                    .Sum(d => d.File?.SizeBytes ?? 0);
                report.AverageSpeed = GetTotalDownloadSpeed();
                
                report.TopAuthors = downloadQueue
                    .Where(d => d.Status == DownloadStatus.Completed && d.CompletedAt?.Date == today && d.File != null)
                    .GroupBy(d => d.File.Username)
                    .ToDictionary(g => g.Key, g => g.Count());
            }
            
            return ReportGenerator.GenerateDailyReport(report);
        }
        
        private double GetTotalDownloadSpeed()
        {
            lock (downloadQueueLock)
            {
                return downloadQueue
                    .Where(d => d.Status == DownloadStatus.Downloading)
                    .Sum(d => d.SpeedMBps);
            }
        }
        
        private async Task<string> GetOllamaResponseStreaming(string userMessage, string selectedModel = null)
        {
            try
            {
                // Usar modelo proporcionado o el configurado
                if (string.IsNullOrEmpty(selectedModel))
                    selectedModel = ollamaModel;
                
                // Determinar complejidad
                var complexity = SlskDown.Core.AI.ModelSelector.DetermineComplexity(userMessage);
                
                // Construir contexto optimizado (solo últimos 3 mensajes para consultas simples)
                var maxMessages = complexity == SlskDown.Core.AI.ModelSelector.QueryComplexity.Simple ? 2 : 3;
                var contextPrompt = ChatMemory.BuildPrompt(userMessage, maxMessages: maxMessages);
                
                // Obtener opciones optimizadas según el modelo
                var options = SlskDown.Core.AI.ModelSelector.GetOptimizedOptions(selectedModel);
                
                var requestBody = new
                {
                    model = selectedModel,
                    prompt = contextPrompt,
                    stream = true,
                    options = options
                };
                
                var json = JsonSerializer.Serialize(requestBody);
                var content = new StringContent(json, Encoding.UTF8, "application/json");
                
                var response = await chatHttpClient.PostAsync($"{ollamaUrl}/api/generate", content);
                response.EnsureSuccessStatusCode();
                
                var fullResponse = new StringBuilder();
                var stream = await response.Content.ReadAsStreamAsync();
                using var reader = new System.IO.StreamReader(stream);
                
                // Crear placeholder para la respuesta
                int messageStartIndex = txtChatHistory.TextLength;
                AppendChatMessage("IA", "", Color.FromArgb(100, 200, 255));
                
                while (!reader.EndOfStream)
                {
                    var line = await reader.ReadLineAsync();
                    if (string.IsNullOrEmpty(line)) continue;
                    
                    try
                    {
                        var jsonDoc = JsonDocument.Parse(line);
                        if (jsonDoc.RootElement.TryGetProperty("response", out var responseProperty))
                        {
                            var chunk = responseProperty.GetString();
                            if (!string.IsNullOrEmpty(chunk))
                            {
                                fullResponse.Append(chunk);
                                
                                // Actualizar UI cada 50ms (batch updates para mejor rendimiento)
                                if (fullResponse.Length % 10 == 0) // Solo cada 10 chunks
                                {
                                    SafeInvoke(() =>
                                    {
                                        if (txtChatHistory != null)
                                        {
                                            txtChatHistory.SelectionStart = messageStartIndex;
                                            txtChatHistory.SelectionLength = txtChatHistory.TextLength - messageStartIndex;
                                            txtChatHistory.SelectedText = "";
                                            
                                            txtChatHistory.SelectionColor = Color.FromArgb(100, 200, 255);
                                            txtChatHistory.AppendText(fullResponse.ToString());
                                            txtChatHistory.ScrollToCaret();
                                        }
                                    });
                                }
                            }
                        }
                        
                        if (jsonDoc.RootElement.TryGetProperty("done", out var doneProperty) && 
                            doneProperty.GetBoolean())
                        {
                            break;
                        }
                    }
                    catch { }
                }
                
                // Agregar salto de línea final
                SafeInvoke(() =>
                {
                    if (txtChatHistory != null)
                    {
                        txtChatHistory.AppendText("\n\n");
                        txtChatHistory.ScrollToCaret();
                    }
                });
                
                return fullResponse.ToString();
            }
            catch (HttpRequestException ex)
            {
                throw new Exception($"Error de conexión con Ollama: {ex.Message}");
            }
            catch (Exception ex)
            {
                throw new Exception($"Error procesando respuesta: {ex.Message}");
            }
        }
        
        private async Task<string> GetOllamaResponse(string userMessage)
        {
            try
            {
                var requestBody = new
                {
                    model = ollamaModel,
                    prompt = userMessage,
                    stream = false
                };
                
                var json = JsonSerializer.Serialize(requestBody);
                var content = new StringContent(json, Encoding.UTF8, "application/json");
                
                var response = await chatHttpClient.PostAsync($"{ollamaUrl}/api/generate", content);
                response.EnsureSuccessStatusCode();
                
                var responseText = await response.Content.ReadAsStringAsync();
                var jsonDoc = JsonDocument.Parse(responseText);
                
                if (jsonDoc.RootElement.TryGetProperty("response", out var responseProperty))
                {
                    return responseProperty.GetString() ?? "Sin respuesta";
                }
                
                return "Error: Respuesta inválida de Ollama";
            }
            catch (HttpRequestException ex)
            {
                throw new Exception($"Error de conexión con Ollama: {ex.Message}");
            }
            catch (Exception ex)
            {
                throw new Exception($"Error procesando respuesta: {ex.Message}");
            }
        }

        private void AppendChatMessage(string sender, string message, Color color)
        {
            if (txtChatHistory == null) return;
            
            SafeInvoke(() =>
            {
                try
                {
                    txtChatHistory.SelectionStart = txtChatHistory.TextLength;
                    txtChatHistory.SelectionLength = 0;
                    
                    // Timestamp
                    txtChatHistory.SelectionColor = Color.Gray;
                    txtChatHistory.SelectionFont = new Font("Consolas", 8);
                    txtChatHistory.AppendText($"[{DateTime.Now:HH:mm:ss}] ");
                    
                    // Sender
                    txtChatHistory.SelectionColor = color;
                    txtChatHistory.SelectionFont = new Font("Consolas", 10, FontStyle.Bold);
                    txtChatHistory.AppendText($"{sender}:\n");
                    
                    // Message
                    txtChatHistory.SelectionColor = Color.White;
                    txtChatHistory.SelectionFont = new Font("Consolas", 10);
                    txtChatHistory.AppendText($"{message}\n\n");
                    
                    // Scroll to bottom
                    txtChatHistory.SelectionStart = txtChatHistory.TextLength;
                    txtChatHistory.ScrollToCaret();
                }
                catch (Exception ex)
                {
                    Log($"Error agregando mensaje al chat: {ex.Message}");
                }
            });
        }

        private async Task ExecuteMassSearchCommand(AICommandParser.ParsedCommand command)
        {
            if (command.Authors == null || command.Authors.Count == 0)
                return;

            var totalAuthors = command.Authors.Count;
            var results = new Dictionary<string, int>();
            var totalFiles = 0;

            AppendChatMessage("SISTEMA",
                $"🔍 Iniciando búsqueda masiva de {totalAuthors} autores...\n",
                Color.FromArgb(100, 200, 255));

            for (int i = 0; i < command.Authors.Count; i++)
            {
                var author = command.Authors[i];
                
                AppendChatMessage("SISTEMA",
                    $"[{i + 1}/{totalAuthors}] Buscando: {author}...",
                    Color.FromArgb(150, 150, 150));

                await Task.Run(async () =>
                {
                    SafeInvoke(() =>
                    {
                        // Cambiar a pestaña de búsqueda
                        if (tabControl != null)
                            tabControl.SelectedIndex = 0;

                        // Configurar filtros
                        if (command.SpanishOnly && chkSpanishOnly != null)
                            chkSpanishOnly.Checked = true;

                        if (!string.IsNullOrEmpty(command.Extension) && cmbExtension != null)
                        {
                            for (int j = 0; j < cmbExtension.Items.Count; j++)
                            {
                                if (cmbExtension.Items[j].ToString().Contains(command.Extension, StringComparison.OrdinalIgnoreCase))
                                {
                                    cmbExtension.SelectedIndex = j;
                                    break;
                                }
                            }
                        }

                        // Configurar búsqueda
                        if (cmbSearch != null)
                            cmbSearch.Text = author;
                    });

                    // Ejecutar búsqueda
                    await SearchAsync();

                    // Esperar resultados
                    await Task.Delay(3000);

                    int foundFiles = 0;
                    bool shouldDownload = false;
                    
                    SafeInvoke(() =>
                    {
                        if (lvResults != null)
                        {
                            foundFiles = lvResults.Items.Count;
                            results[author] = foundFiles;
                            totalFiles += foundFiles;

                            // Si es descarga automática, marcar archivos
                            if (command.AutoDownload && foundFiles > 0)
                            {
                                foreach (ListViewItem item in lvResults.Items)
                                    item.Selected = true;
                                shouldDownload = true;
                            }
                        }

                        AppendChatMessage("SISTEMA",
                            $"✅ {author}: {foundFiles} archivos encontrados" +
                            (command.AutoDownload && foundFiles > 0 ? " (descargando...)" : ""),
                            foundFiles > 0 ? Color.FromArgb(50, 255, 50) : Color.FromArgb(255, 200, 100));
                    });
                    
                    // Descargar fuera del SafeInvoke
                    if (shouldDownload)
                    {
                        await DownloadMultipleAsync();
                    }
                });

                // Pausa entre búsquedas para no saturar
                if (i < command.Authors.Count - 1)
                    await Task.Delay(2000);
            }

            // Resumen final
            var summary = new System.Text.StringBuilder();
            summary.AppendLine($"\n📊 RESUMEN DE BÚSQUEDA MASIVA:\n");
            summary.AppendLine($"Total de autores: {totalAuthors}");
            summary.AppendLine($"Total de archivos: {totalFiles}\n");
            summary.AppendLine("Detalles por autor:");

            foreach (var kvp in results.OrderByDescending(x => x.Value))
            {
                summary.AppendLine($"  • {kvp.Key}: {kvp.Value} archivos");
            }

            if (command.AutoDownload && totalFiles > 0)
            {
                summary.AppendLine($"\n⬇️ {totalFiles} archivos agregados a la cola de descarga");
            }

            AppendChatMessage("SISTEMA", summary.ToString(), Color.FromArgb(100, 200, 255));
        }

        private void ClearChatHistory()
        {
            if (txtChatHistory == null) return;
            
            var result = MessageBox.Show(
                "¿Seguro que quieres limpiar todo el historial del chat?",
                "Confirmar",
                MessageBoxButtons.YesNo,
                MessageBoxIcon.Question
            );
            
            if (result == DialogResult.Yes)
            {
                txtChatHistory.Clear();
                AddChatWelcomeMessage();
            }
        }
    }
}
