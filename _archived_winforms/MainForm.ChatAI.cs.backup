                        "❌ Formato incorrecto.\n\nUsa: crea atajo \"nombre\" = comando\n\nEjemplo: crea atajo \"scifi\" = busca autores: Asimov, Clarke",
                        Color.FromArgb(255, 200, 100));
                }
            }
            else if (lower.StartsWith("crea regla"))
            {
                AppendChatMessage("SISTEMA", 
                    "🎯 CREAR REGLA DE AUTO-DESCARGA:\n\n" +
                    "Formato: crea regla \"nombre\" para autor \"X\" auto-descargar\n\n" +
                    "Ejemplo:\n" +
                    "crea regla \"Asimov Auto\" para autor \"Isaac Asimov\" auto-descargar\n\n" +
                    "La regla descargará automáticamente todos los archivos de ese autor.",
                    Color.FromArgb(100, 200, 255));
                
                var match = System.Text.RegularExpressions.Regex.Match(message, @"crea regla\s+[""'](.+?)[""']\s+para autor\s+[""'](.+?)[""']", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                if (match.Success)
                {
                    var ruleName = match.Groups[1].Value.Trim();
                    var author = match.Groups[2].Value.Trim();
                    var rule = RuleEngine.CreateQuickRule(ruleName, author, true);
                    RuleEngine.AddRule(rule);
                    AppendChatMessage("SISTEMA", 
                        $"✅ Regla creada: '{ruleName}'\n\nTodos los archivos de '{author}' se descargarán automáticamente.",
                        Color.FromArgb(50, 255, 50));
                }
            }
            else if (lower.StartsWith("cambia a modo"))
            {
                if (lower.Contains("profesional") || lower.Contains("professional"))
                {
                    ChatPersonality.SetPersonality(PersonalityType.Professional);
                    AppendChatMessage("SISTEMA", "Modo profesional activado. Respuestas formales y técnicas.", Color.FromArgb(100, 200, 255));
                }
                else if (lower.Contains("amigable") || lower.Contains("friendly"))
                {
                    ChatPersonality.SetPersonality(PersonalityType.Friendly);
                    AppendChatMessage("SISTEMA", "¡Modo amigable activado! 😊 Respuestas casuales y con emojis.", Color.FromArgb(100, 200, 255));
                }
                else if (lower.Contains("conciso") || lower.Contains("concise"))
                {
                    ChatPersonality.SetPersonality(PersonalityType.Concise);
                    AppendChatMessage("SISTEMA", "Modo conciso. Respuestas breves.", Color.FromArgb(100, 200, 255));
                }
                else if (lower.Contains("detallado") || lower.Contains("detailed"))
                {
