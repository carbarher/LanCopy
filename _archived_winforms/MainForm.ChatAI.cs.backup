        private void AddChatWelcomeMessage()
        {
            if (txtChatHistory == null) return;
            
            // Cargar memoria, personalidad e historial inteligente
            ChatMemory.Load();
            RuleEngine.LoadRules();
            SlskDown.Core.AI.SmartHistory.Load();
            
            // Inicializar mejoras de IA
            InitializeAIEnhancements();
            
            var greeting = ChatPersonality.GetGreeting();
            
            AppendChatMessage("SISTEMA", 
                $"{greeting}\n\n" +
                "💡 FUNCIONALIDADES AVANZADAS:\n" +
                "• 🔍 Búsqueda masiva: 'busca autores: Asimov, Clarke, Heinlein'\n" +
                "• 📚 Detección de series: Identifica sagas incompletas automáticamente\n" +
                "• 🧠 Búsqueda semántica: 'libros sobre viajes en el tiempo'\n" +
                "• 🎯 Comandos compuestos: 'busca Asimov y descarga solo epub mayores a 1MB'\n" +
                "• 🔧 Diagnóstico automático: 'por qué va lento?'\n" +
                "• 📊 Reportes: 'reporte semanal', 'analiza mi biblioteca'\n" +
                "• ⚡ Atajos: 'crea atajo \"scifi\" = busca autores: Asimov, Clarke'\n" +
                "• 🎭 Personalidad: 'cambia a modo profesional/amigable/conciso'\n\n" +
                "⚡ COMANDOS RÁPIDOS:\n" +
                "• ayuda - Lista completa de comandos\n" +
                "• estado - Ver descargas activas con progreso visual\n" +
                "• estadísticas - Resumen con gráficos\n" +
                "• diagnosticar - Analizar problemas\n" +
                "• reporte semanal - Estadísticas detalladas\n" +
                "• series - Ver series detectadas\n" +
                "• atajos - Ver tus atajos personalizados\n\n" +
                "🚀 EJEMPLOS:\n" +
                "  'busca libros sobre cyberpunk'\n" +
                "  'libros similares a Dune'\n" +
                "  'descarga autores: Verne, Dumas en español'\n" +
                "  'predice cuándo terminarán las descargas'\n" +
                "  'crea regla: auto-descargar todo de Asimov'\n\n" +
                "💾 Recuerdo tu contexto y aprendo de tus preferencias.\n\n" +
                "¿En qué puedo ayudarte?",
                Color.FromArgb(100, 200, 255));
            
            // Mostrar sugerencia proactiva si hay alguna
            ShowProactiveSuggestionIfAvailable();
        }
        
        private void InitializeAIEnhancements()
        {
            try
            {
                // Inicializar TurboMode
                if (ollamaClient != null)
                {
                    turboMode = new SlskDown.Core.AI.TurboMode(ollamaClient)
                    {
                        Enabled = true,
                        FallbackModel = ollamaModel
                    };
                }
                
                // Inicializar ModelPreloader
                modelPreloader = new SlskDown.Core.AI.ModelPreloader(ollamaUrl);
                
                // Pre-cargar modelo en background
                _ = Task.Run(async () =>
                {
                    await modelPreloader.PreloadModelAsync(ollamaModel);
                    SafeInvoke(() =>
                    {
                        if (lblChatStatus != null)
                            lblChatStatus.Text = $"Modelo: {ollamaModel} | ⚡ Precargado";
                    });
                });
                
                // Configurar streaming mejorado
                streamingProcessor.OnWordCompleted += (word) =>
                {
                    // Actualizar UI con palabras completas
                };
            }
            catch (Exception ex)
            {
                Log($"Error inicializando mejoras de IA: {ex.Message}");
            }
        }
        
        private void ShowProactiveSuggestionIfAvailable()
        {
            // Verificar sugerencias cada 5 minutos
            if ((DateTime.Now - lastSuggestionCheck).TotalMinutes < 5)
                return;
            
            lastSuggestionCheck = DateTime.Now;
            var suggestion = proactiveSuggestions.GetNextSuggestion();
            
            if (suggestion != null)
            {
                AppendChatMessage("💡 SUGERENCIA", suggestion.Message, Color.FromArgb(255, 200, 100));
            }
        }

        private Button CreateQuickButton(string text, Color color)
        {
            return new Button
            {
                Text = text,
                Width = 140,
                Height = 35,
                BackColor = color,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 9, FontStyle.Bold),
                Margin = new Padding(0, 0, 8, 0)
            };
        }
        
        private void TxtChatInput_KeyDown(object sender, KeyEventArgs e)
        {
            // Enviar con Ctrl+Enter
            if (e.Control && e.KeyCode == Keys.Enter)
            {
                e.Handled = true;
                e.SuppressKeyPress = true;
                _ = SendChatMessage();
            }
            // Navegar historial con flechas arriba/abajo
            else if (e.KeyCode == Keys.Up)
            {
                e.Handled = true;
                ShowPreviousCommand();
            }
            else if (e.KeyCode == Keys.Down)
            {
                e.Handled = true;
                ShowNextCommand();
            }
        }
        
        private void ShowPreviousCommand()
        {
            if (commandHistory.Count == 0) return;
            
            if (historyIndex == -1)
                historyIndex = commandHistory.Count - 1;
            else if (historyIndex > 0)
                historyIndex--;
            
            if (historyIndex >= 0 && historyIndex < commandHistory.Count)
                txtChatInput.Text = commandHistory[historyIndex];
        }
        
        private void ShowNextCommand()
        {
            if (commandHistory.Count == 0 || historyIndex == -1) return;
            
            if (historyIndex < commandHistory.Count - 1)
            {
                historyIndex++;
                txtChatInput.Text = commandHistory[historyIndex];
            }
            else
            {
                historyIndex = -1;
                txtChatInput.Clear();
            }
        }

        private async Task SendChatMessage()
        {
            if (txtChatInput == null || txtChatHistory == null) return;
            
            string userMessage = txtChatInput.Text.Trim();
            if (string.IsNullOrEmpty(userMessage)) return;
            
            if (isChatProcessing)
            {
                AppendChatMessage("SISTEMA", "Espera a que termine de procesar el mensaje anterior...", Color.Orange);
                return;
            }
            
            try
            {
                isChatProcessing = true;
                btnChatSend.Enabled = false;
                txtChatInput.Enabled = false;
                lblChatStatus.Text = "Pensando...";
                
                // Agregar al historial de comandos
                if (!string.IsNullOrEmpty(userMessage))
                {
                    commandHistory.Add(userMessage);
                    if (commandHistory.Count > 50) // Limitar a 50 comandos
                        commandHistory.RemoveAt(0);
                    historyIndex = -1;
                }
                
                // Mostrar mensaje del usuario
                AppendChatMessage("TÚ", userMessage, Color.FromArgb(50, 255, 50));
                txtChatInput.Clear();
                
                // Detectar si es un comando accionable
                var command = AICommandParser.Parse(userMessage);
                
                if (command.Type != AICommandParser.CommandType.None)
                {
                    // Es un comando - pedir confirmación
                    var confirmMsg = AICommandParser.GenerateConfirmationMessage(command);
                    AppendChatMessage("SISTEMA", 
                        $"He detectado un comando:\n\n{confirmMsg}\n\n¿Quieres que lo ejecute?",
                        Color.FromArgb(255, 200, 100));
                    
                    var result = MessageBox.Show(
                        $"Comando detectado:\n\n{confirmMsg}\n\n¿Ejecutar?",
                        "Confirmar Comando",
                        MessageBoxButtons.YesNo,
                        MessageBoxIcon.Question
                    );
                    
                    if (result == DialogResult.Yes)
                    {
                        // Ejecutar comando
                        AppendChatMessage("SISTEMA", "⏳ Ejecutando comando...", Color.FromArgb(100, 200, 255));
                        
                        if (command.Type == AICommandParser.CommandType.MassSearch || 
                            command.Type == AICommandParser.CommandType.MassSearchAndDownload)
                        {
                            _ = ExecuteMassSearchCommand(command);
                        }
                        else
                        {
                            ExecuteAICommand(command);
                            AppendChatMessage("SISTEMA", "✅ Comando ejecutado. Revisa la pestaña de Búsqueda o Descargas.", Color.FromArgb(50, 255, 50));
                        }
                    }
                    else
                    {
                        AppendChatMessage("SISTEMA", "Comando cancelado.", Color.FromArgb(150, 150, 150));
                    }
                    
                    lblChatStatus.Text = aiEnabled ? $"Modelo: {ollamaModel} | Listo" : "IA Desactivada";
                }
                else
                {
                    // Verificar respuesta predictiva primero
                    var quickResponse = SlskDown.Core.AI.PredictiveResponses.GetQuickResponse(userMessage);
                    if (quickResponse != null)
                    {
                        AppendChatMessage("IA", quickResponse, Color.FromArgb(100, 200, 255));
                        ExecuteOfflineCommand(userMessage);
                        lblChatStatus.Text = "⚡ Respuesta instantánea";
                        
                        // Registrar en métricas
                        aiDashboard.RecordQuery("cache", 0, 0, true);
                        SlskDown.Core.AI.SmartHistory.RecordCommand(userMessage, true);
                    }
                    // Verificar si es comando offline
                    else if (IsOfflineCommand(userMessage))
                    {
                        ExecuteOfflineCommand(userMessage);
                        lblChatStatus.Text = "Comando ejecutado";
                        SlskDown.Core.AI.SmartHistory.RecordCommand(userMessage, true);
                    }
                    else if (!aiEnabled)
                    {
                        AppendChatMessage("ERROR", 
                            "La IA no está activada. Ve a Configuración y activa 'Funcionalidades de IA con Ollama'.",
                            Color.FromArgb(255, 100, 100));
                        lblChatStatus.Text = "❌ IA Desactivada";
                    }
                    else
                    {
                        // Verificar caché
                        if (responseCache.TryGetValue(userMessage.ToLower(), out var cachedResponse))
                        {
                            AppendChatMessage("IA", cachedResponse + "\n\n(⚡ caché)", Color.FromArgb(100, 200, 255));
                            lblChatStatus.Text = $"Modelo: {ollamaModel} | Listo (caché)";
                            aiDashboard.RecordQuery(ollamaModel, 0, cachedResponse.Length / 4, true);
                        }
                        else
                        {
                            // Seleccionar modelo óptimo con TurboMode
                            var selectedModel = ollamaModel;
                            if (turboMode != null && turboMode.Enabled)
                            {
                                selectedModel = await turboMode.SelectOptimalModelAsync(userMessage, ollamaModel);
                                if (selectedModel != ollamaModel)
                                {
                                    lblChatStatus.Text = $"⚡ Usando {selectedModel} (turbo)";
                                }
                            }
                            
                            // Enviar a Ollama con streaming mejorado
                            var startTime = DateTime.Now;
                            string response = await GetOllamaResponseStreaming(userMessage, selectedModel);
                            var elapsed = (DateTime.Now - startTime).TotalMilliseconds;
                            
                            // Registrar métricas
                            aiDashboard.RecordQuery(selectedModel, elapsed, response.Length / 4, false);
                            SlskDown.Core.AI.SmartHistory.RecordCommand(userMessage, true);
                            
                            // Guardar en caché (límite de 100 entradas)
                            if (!string.IsNullOrEmpty(response) && response.Length < 1000)
                            {
                                if (responseCache.Count >= 100)
                                {
                                    // Eliminar la entrada más antigua
                                    var firstKey = responseCache.Keys.First();
                                    responseCache.Remove(firstKey);
                                }
                                responseCache[userMessage.ToLower()] = response;
                            }
                            
                            lblChatStatus.Text = $"Modelo: {ollamaModel} | Listo";
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                AppendChatMessage("ERROR", 
                    $"No se pudo obtener respuesta: {ex.Message}\n\n" +
                    "Verifica que Ollama esté corriendo:\n" +
                    "• Ejecuta: ollama serve\n" +
                    "• Verifica: http://localhost:11434",
                    Color.FromArgb(255, 100, 100));
                lblChatStatus.Text = "Error de conexión";
                Log($"Error en chat IA: {ex.Message}");
            }
            finally
            {
                isChatProcessing = false;
                btnChatSend.Enabled = true;
                txtChatInput.Enabled = true;
                txtChatInput.Focus();
            }
        }

        private bool IsOfflineCommand(string message)
        {
            var lower = message.ToLower().Trim();
            return lower == "ayuda" || lower == "help" ||
                   lower == "estado" || lower == "status" ||
                   lower == "estadísticas" || lower == "stats" ||
                   lower == "pausar" || lower == "pause" ||
                   lower == "reanudar" || lower == "resume" ||
                   lower == "limpiar caché" || lower == "clear cache" ||
                   lower == "series" || lower == "sagas" ||
                   lower == "atajos" || lower == "shortcuts" ||
                   lower == "reglas" || lower == "rules" ||
                   lower == "diagnosticar" || lower == "diagnose" ||
                   lower == "metricas" || lower == "metrics" ||
                   lower.StartsWith("reporte") ||
                   lower.StartsWith("analiza") ||
                   lower.StartsWith("predice") ||
                   lower.StartsWith("crea atajo") ||
                   lower.StartsWith("crea regla") ||
                   lower.StartsWith("cambia a modo") ||
                   lower.StartsWith("libros sobre") ||
                   lower.StartsWith("libros similares");
        }
        
        private void ExecuteOfflineCommand(string message)
        {
            var lower = message.ToLower().Trim();
            
            if (lower == "ayuda" || lower == "help")
            {
                AppendChatMessage("SISTEMA", 
                    "📚 COMANDOS DISPONIBLES:\n\n" +
                    "ACCIONES:\n" +
                    "  • 'bájate todas las obras de [autor] en español'\n" +
                    "  • 'busca libros de [autor]'\n" +
                    "  • 'descarga [autor] en formato epub'\n" +
                    "  • 'agrega a [autor] a la lista'\n\n" +
                    "GESTIÓN:\n" +
                    "  • 'estado' - Ver estado de descargas\n" +
                    "  • 'estadísticas' - Ver estadísticas\n" +
                    "  • 'metricas' - Métricas del sistema\n" +
                    "  • 'reglas' - Ver reglas de automatización\n" +
                    "  • 'pausar' - Pausar todas las descargas\n" +
                    "  • 'reanudar' - Reanudar descargas\n" +
                    "  • 'limpiar caché' - Limpiar caché de respuestas\n\n" +
                    "CONSULTAS:\n" +
                    "  • Pregunta lo que quieras sobre literatura\n" +
                    "  • Pide recomendaciones de autores/libros\n" +
                    "  • Consulta sobre géneros literarios\n\n" +
                    "ATAJOS:\n" +
                    "  • Ctrl+Enter - Enviar mensaje\n" +
                    "  • ↑/↓ - Navegar historial de comandos",
                    Color.FromArgb(100, 200, 255));
            }
            else if (lower == "estado" || lower == "status")
            {
                int total = 0, activas = 0, pausadas = 0, cola = 0;
                lock (downloadQueueLock)
                {
                    total = downloadQueue.Count;
                    activas = downloadQueue.Count(d => d.Status == DownloadStatus.Downloading);
                    pausadas = downloadQueue.Count(d => d.Status == DownloadStatus.Paused);
                    cola = downloadQueue.Count(d => d.Status == DownloadStatus.Queued);
                }
                
                AppendChatMessage("SISTEMA",
                    $"📊 ESTADO DE DESCARGAS:\n\n" +
                    $"Total: {total} archivos\n" +
                    $"⬇️ Activas: {activas}\n" +
                    $"⏸️ Pausadas: {pausadas}\n" +
                    $"📋 En cola: {cola}\n\n" +
                    $"Velocidad total: {FormatSpeed(GetTotalDownloadSpeed())}",
                    Color.FromArgb(100, 200, 255));
            }
            else if (lower == "estadísticas" || lower == "stats")
            {
                int totalFiles = 0;
                long totalSize = 0;
                lock (downloadQueueLock)
                {
                    totalFiles = downloadQueue.Count(d => d.Status == DownloadStatus.Completed);
                    totalSize = downloadQueue.Where(d => d.Status == DownloadStatus.Completed)
                                             .Sum(d => d.File?.SizeBytes ?? 0);
                }
                
                AppendChatMessage("SISTEMA",
                    $"📊 ESTADÍSTICAS:\n\n" +
                    $"✅ Completadas: {totalFiles} archivos\n" +
                    $"💾 Tamaño total: {FormatSize(totalSize)}\n" +
                    $"📅 Sesión actual: {sessionId}",
                    Color.FromArgb(100, 200, 255));
            }
            else if (lower == "pausar" || lower == "pause")
            {
                int paused = 0;
                lock (downloadQueueLock)
                {
                    foreach (var task in downloadQueue)
                    {
                        if (task.Status == DownloadStatus.Downloading || task.Status == DownloadStatus.Queued)
                        {
                            task.Status = DownloadStatus.Paused;
                            paused++;
                        }
                    }
                }
                AppendChatMessage("SISTEMA", $"⏸️ {paused} descarga(s) pausada(s)", Color.FromArgb(255, 200, 100));
            }
            else if (lower == "reanudar" || lower == "resume")
            {
                int resumed = 0;
                lock (downloadQueueLock)
                {
                    foreach (var task in downloadQueue)
                    {
                        if (task.Status == DownloadStatus.Paused)
                        {
                            task.Status = DownloadStatus.Queued;
                            resumed++;
                        }
                    }
                }
                AppendChatMessage("SISTEMA", $"▶️ {resumed} descarga(s) reanudada(s)", Color.FromArgb(50, 255, 50));
            }
            else if (lower == "limpiar caché" || lower == "clear cache")
            {
                int count = responseCache.Count;
                responseCache.Clear();
                AppendChatMessage("SISTEMA", $"🗑️ Caché limpiado ({count} respuestas eliminadas)", Color.FromArgb(100, 200, 255));
            }
            else if (lower == "series" || lower == "sagas")
            {
                List<string> completedFiles;
                lock (downloadQueueLock)
                {
                    completedFiles = downloadQueue
                        .Where(d => d.Status == DownloadStatus.Completed && d.File != null)
                        .Select(d => d.File.FileName)
                        .ToList();
                }
                
                var seriesGroups = SlskDown.Core.SeriesDetector.GroupBySeries(completedFiles);
                if (seriesGroups.Count == 0)
                {
                    AppendChatMessage("SISTEMA", "📚 No se detectaron series en tu biblioteca.", Color.FromArgb(100, 200, 255));
                }
                else
                {
                    var summary = new StringBuilder();
                    summary.AppendLine($"📚 SERIES DETECTADAS: {seriesGroups.Count}\n");
                    
                    foreach (var kvp in seriesGroups.Take(10))
                    {
                        var missing = SlskDown.Core.SeriesDetector.FindMissingVolumes(kvp.Value);
                        var status = missing.Count == 0 && kvp.Value.All(s => s.VolumeNumber.HasValue) 
                            ? "✅ Completa" 
                            : $"⚠️ Faltan {missing.Count} volúmenes";
                        summary.AppendLine($"• {kvp.Key} ({kvp.Value.Count} libros) - {status}");
                    }
                    
                    AppendChatMessage("SISTEMA", summary.ToString(), Color.FromArgb(100, 200, 255));
                }
            }
            else if (lower == "reglas" || lower == "rules")
            {
                var rulesSummary = RuleEngine.GenerateRuleSummary();
                AppendChatMessage("SISTEMA", rulesSummary, Color.FromArgb(100, 200, 255));
            }
            else if (lower == "metricas" || lower == "metrics")
            {
                var metricsSummary = new StringBuilder();
                metricsSummary.AppendLine("📊 MÉTRICAS DEL SISTEMA:\n");
                metricsSummary.AppendLine($"🔍 Búsquedas totales: {totalSearches:N0}");
                metricsSummary.AppendLine($"✅ Búsquedas exitosas: {successfulSearches:N0}");
                metricsSummary.AppendLine($"📈 Tasa de éxito: {(totalSearches > 0 ? (double)successfulSearches / totalSearches * 100 : 0):F1}%");
                metricsSummary.AppendLine();
                metricsSummary.AppendLine($"⬇️ Descargas totales: {totalDownloads:N0}");
                metricsSummary.AppendLine($"✅ Descargas exitosas: {successfulDownloads:N0}");
                metricsSummary.AppendLine($"📈 Tasa de éxito: {(totalDownloads > 0 ? (double)successfulDownloads / totalDownloads * 100 : 0):F1}%");
                
                AppendChatMessage("SISTEMA", metricsSummary.ToString(), Color.FromArgb(100, 200, 255));
