            {
                var match = System.Text.RegularExpressions.Regex.Match(message, @"crea atajo\s+[""'](.+?)[""']\s*=\s*(.+)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                if (match.Success)
                {
                    var name = match.Groups[1].Value.Trim();
                    var command = match.Groups[2].Value.Trim();
                    ChatMemory.AddShortcut(name, command);
                    AppendChatMessage("SISTEMA", 
                        $"✅ Atajo creado: '{name}'\n\nAhora puedes escribir '{name}' y se ejecutará:\n{command}",
                        Color.FromArgb(50, 255, 50));
                }
                else
