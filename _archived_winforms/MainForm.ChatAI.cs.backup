                }
            }
            else if (lower.StartsWith("libros sobre"))
            {
                var concept = message.Substring("libros sobre".Length).Trim();
                var semanticSummary = SemanticSearch.GenerateSemanticSearchSummary(concept);
                
                if (semanticSummary != null)
