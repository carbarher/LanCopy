                {
                    ChatPersonality.SetPersonality(PersonalityType.Humorous);
                    AppendChatMessage("SISTEMA", "¡Modo humor activado! 🎉 Prepárate para respuestas divertidas.", Color.FromArgb(100, 200, 255));
                }
