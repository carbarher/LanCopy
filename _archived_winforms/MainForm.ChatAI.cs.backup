                diagnostics.AddRange(Troubleshooter.DiagnoseDownloadSpeed(currentSpeed, activeDownloads, queueSize));
                
                // Diagnosticar fallos
                var failures = new List<(string, string, int)>();
                lock (downloadQueueLock)
                {
                    failures = downloadQueue
                        .Where(d => d.Status == DownloadStatus.Failed)
