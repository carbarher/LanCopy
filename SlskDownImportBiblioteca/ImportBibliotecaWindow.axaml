<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SlskDownImportBiblioteca.ImportBibliotecaWindow"
        Title="Importar biblioteca externa"
        Width="760" Height="620"
        MinWidth="560" MinHeight="480"
        WindowStartupLocation="CenterScreen">
  <DockPanel Margin="14">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,12,0,0">
      <Button Name="BtnCancelRun" Content="Cancelar importación" IsVisible="False" Click="BtnCancelRun_Click" />
      <Button Name="BtnClose" Content="Cerrar" Click="BtnClose_Click" />
      <Button Name="BtnImport" Content="📥 Importar" Click="BtnImport_Click" />
    </StackPanel>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto,Auto" ColumnDefinitions="*,Auto">
      <TextBlock Grid.Row="0" Grid.ColumnSpan="2" TextWrapping="Wrap" Margin="0,0,0,10"
                 Text="Herramienta independiente (sin Soulseek): motor SlskDownBibliotecaImport + Calibre. Usa el mismo config.json que la app principal (%AppData%\SlskDownAvalonia). La verificación completa post-import solo está en la app principal." />

      <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Origen:" />
      <Button Grid.Row="1" Grid.Column="1" Content="📂" Click="BtnBrowseSource_Click" />

      <TextBox Grid.Row="2" Grid.ColumnSpan="2" Name="TxtSource" Watermark="Carpeta origen" Margin="0,4,0,8" />

      <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Destino (biblioteca / descargas):" />
      <Button Grid.Row="3" Grid.Column="1" Content="📂" Click="BtnBrowseDest_Click" />

      <TextBox Grid.Row="4" Grid.ColumnSpan="2" Name="TxtDest" Watermark="Carpeta de descargas" Margin="0,4,0,8" />

      <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="16" Margin="0,4,0,8">
        <TextBlock VerticalAlignment="Center" Text="Modo: Completo (hash dedup + validación PD)" FontWeight="SemiBold" />
        <CheckBox Name="ChkDryRun" Content="Simulación (dry-run)" />
        <CheckBox Name="ChkPipelineVerify" Content="Post: verificación completa" />
        <CheckBox Name="ChkPipelineTxt" Content="Post: TXTs faltantes" />
      </StackPanel>

      <Border Grid.Row="6" Grid.ColumnSpan="2" BorderThickness="1" CornerRadius="4" Margin="0,4,0,8">
        <ScrollViewer MaxHeight="280">
          <TextBox Name="TxtLog" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                   BorderThickness="0" MinHeight="200" />
        </ScrollViewer>
      </Border>

      <ProgressBar Grid.Row="7" Grid.ColumnSpan="2" Name="Pb" Height="14" IsVisible="False" Minimum="0" Maximum="100" Value="0" />

      <TextBlock Grid.Row="8" Grid.ColumnSpan="2" Name="TxtStatus" TextWrapping="Wrap" Margin="0,6,0,0" />
    </Grid>
  </DockPanel>
</Window>
