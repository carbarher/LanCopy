<Window x:Class="ScoreDown.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎵 Partitura Downloader — Mutopia + CPDL"
        Height="720" Width="1000" MinHeight="600" MinWidth="800"
        Background="#1E1E2E" Foreground="White" FontFamily="Segoe UI" FontSize="13"
    PreviewKeyDown="Window_PreviewKeyDown"
    Closing="Window_Closing">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6D28D9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3D3D5C"/>
                    <Setter Property="Foreground" Value="#888"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="LogActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform X="0" Y="0"/>
                    </TransformGroup>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                             To="0.96" Duration="0:0:0.08"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                             To="0.96" Duration="0:0:0.08"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                             To="1.5" Duration="0:0:0.08"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                             To="1" Duration="0:0:0.12"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                             To="1" Duration="0:0:0.12"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                             To="0" Duration="0:0:0.12"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                             To="1" Duration="0:0:0.12"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                             To="1" Duration="0:0:0.12"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                             To="0" Duration="0:0:0.12"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#7C3AED"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#1E1E2E"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D5C"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#4C1D95"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="toggleButton"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="arrow" Grid.Column="1"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="White" HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#3D3D5C"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="contentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="8,4,24,4"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              TextElement.Foreground="White"/>
                            <TextBox x:Name="PART_EditableTextBox"
                                     Style="{x:Null}"
                                     Background="#2D2D44" Foreground="White" CaretBrush="White"
                                     BorderThickness="0"
                                     HorizontalAlignment="Left" VerticalAlignment="Center"
                                     Margin="8,0,24,0"
                                     Focusable="True" Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border x:Name="dropdownBorder"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="#2D2D44"
                                        BorderBrush="#555"
                                        BorderThickness="1"
                                        CornerRadius="0,0,4,4">
                                    <ScrollViewer>
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="contentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D5C"/>
                </Trigger>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#4C1D95"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="0"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="🎵 Partitura Downloader" FontSize="20" FontWeight="Bold"
                   Foreground="#A78BFA" Margin="0,0,0,12"/>

        <!-- Barra de búsqueda -->
        <Grid Grid.Row="1" Margin="0,0,0,10" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txtSearch" Grid.Row="0" Grid.Column="0"
                     Text="Bach inventions"
                     TextChanged="TxtSearch_TextChanged"
                     KeyDown="TxtSearch_KeyDown"
                     ToolTip="Escribe el nombre de la obra o compositor y pulsa Enter o Buscar"/>
            <Popup x:Name="popComposerSuggestions"
                   Grid.Row="0" Grid.Column="0"
                   PlacementTarget="{Binding ElementName=txtSearch}"
                   Placement="Bottom"
                   AllowsTransparency="True"
                   StaysOpen="False">
                <Border Background="#13131F" BorderBrush="#555" BorderThickness="1" MinWidth="260">
                    <ListBox x:Name="lstComposerSuggestions"
                             MaxHeight="180"
                             MouseDoubleClick="LstComposerSuggestions_MouseDoubleClick"
                             SelectionChanged="LstComposerSuggestions_SelectionChanged"/>
                </Border>
            </Popup>
            <ComboBox x:Name="cmbSource" Grid.Row="0" Grid.Column="1" Width="110"
                      Margin="8,0,0,0" SelectedIndex="0"
                      SelectionChanged="CmbSource_SelectionChanged"
                      Background="#2D2D44" Foreground="White" BorderBrush="#555"
                      ToolTip="Fuente de búsqueda">
                <ComboBoxItem>Mutopia</ComboBoxItem>
                <ComboBoxItem>Musopen</ComboBoxItem>
                <ComboBoxItem>OpenScore</ComboBoxItem>
                <ComboBoxItem>Offline</ComboBoxItem>
                <ComboBoxItem>Todas</ComboBoxItem>
            </ComboBox>
            <Button x:Name="btnSearch" Grid.Row="0" Grid.Column="2" Content="🔍 Buscar"
                    Margin="8,0,0,0" Click="BtnSearch_Click" Visibility="Collapsed"/>
            <Button x:Name="btnCancelSearch" Grid.Row="0" Grid.Column="3" Content="✖ Cancelar"
                    Margin="6,0,0,0" Click="BtnCancelSearch_Click" IsEnabled="False"
                    Background="#991B1B" Visibility="Collapsed"/>

            <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="cmbHistory" Grid.Column="0" Height="26"
                          Margin="0,0,8,0"
                          Background="#2D2D44" Foreground="White" BorderBrush="#555"
                          SelectionChanged="CmbHistory_SelectionChanged"
                          ToolTip="Búsquedas recientes" Visibility="Collapsed"/>
                <TextBlock x:Name="txtCacheStats" Grid.Column="1" VerticalAlignment="Center"
                           Foreground="#A78BFA" Margin="0,0,8,0" Text="Cache H:0 M:0 (0)" Visibility="Collapsed"/>
                <Button x:Name="btnClearCache" Grid.Column="2" Content="🧹 Limpiar cache"
                        Padding="10,4" Click="BtnClearCache_Click" Background="#374151" Visibility="Collapsed"/>
                <Button x:Name="btnFetchCatalog" Grid.Column="3" Content="📥 Catálogo"
                        Padding="10,4" Margin="8,0,0,0" Background="#0F766E"
                        Click="BtnFetchCatalog_Click"
                    ToolTip="Descarga el catálogo completo de la fuente seleccionada" Visibility="Collapsed"/>
                <Button x:Name="btnDownloadAll" Grid.Column="4" Content="🚀 Descargar todo"
                    Padding="10,4" Margin="4,0,0,0" Background="#7C3AED"
                    Click="BtnDownloadAll_Click"
                    ToolTip="Un clic: usa fuente Todas, crea carpeta si falta y descarga todo"/>
                <Button x:Name="btnCancelCatalog" Grid.Column="5" Content="⏹ Detener"
                        Padding="10,4" Margin="4,0,0,0" Background="#991B1B" IsEnabled="False"
                        Click="BtnCancelCatalog_Click"
                        ToolTip="Detener descarga de catálogo" Visibility="Collapsed"/>
            </Grid>

            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtTitleSearch" Grid.Column="0" Margin="0,0,8,0"
                         KeyDown="TxtSearch_KeyDown"
                         ToolTip="Búsqueda avanzada por título" Visibility="Collapsed"/>
                <TextBox x:Name="txtComposerSearch" Grid.Column="1" Margin="0,0,8,0"
                         KeyDown="TxtSearch_KeyDown"
                         ToolTip="Búsqueda avanzada por compositor" Visibility="Collapsed"/>
                <TextBox x:Name="txtTagFilter" Grid.Column="2" Margin="0,0,8,0"
                     TextChanged="TxtTagFilter_TextChanged"
                     ToolTip="Filtrar por tag"/>
                <Button Grid.Column="3" Content="🏷 Lote" Padding="10,6" Margin="0,0,4,0"
                    Background="#0F766E" Click="BtnBulkTag_Click" Visibility="Collapsed"/>
                <Button Grid.Column="4" Content="⬆ Biblioteca" Padding="10,6" Margin="0,0,4,0"
                        Background="#1D4ED8" Click="BtnImportLibrary_Click"/>
                <Button Grid.Column="5" Content="⬇ Biblioteca" Padding="10,6"
                        Background="#065F46" Click="BtnExportLibrary_Click"/>
                <Button Grid.Column="6" Content="🌐 HTML" Padding="10,6" Margin="4,0,0,0"
                    Background="#334155" Click="BtnExportHtml_Click"/>
                <Button Grid.Column="7" Content="📂 Compositor" Padding="10,6" Margin="4,0,0,0"
                    Background="#374151" Click="BtnOpenComposerFolder_Click" Visibility="Collapsed"/>
            </Grid>
        </Grid>

        <!-- Lista de resultados -->
        <Grid Grid.Row="2" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Cabecera con selección global -->
            <Grid Grid.Row="0" Margin="0,0,0,4" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="chkSelectAll" Grid.Column="0" Content="Sel. todo"
                          Checked="ChkSelectAll_Changed" Unchecked="ChkSelectAll_Changed" Margin="4,0,12,0"/>
                <TextBlock x:Name="txtResultCount" Grid.Column="1"
                           Text="Sin resultados" Foreground="#A78BFA" VerticalAlignment="Center"/>
                <ComboBox x:Name="cmbFilterSource" Grid.Column="2" Width="92"
                          Margin="0,0,8,0" SelectedIndex="0"
                          SelectionChanged="FilterChanged"
                          Background="#2D2D44" Foreground="White" BorderBrush="#555"
                          ToolTip="Filtrar por fuente">
                    <ComboBoxItem>Todas</ComboBoxItem>
                    <ComboBoxItem>Mutopia</ComboBoxItem>
                    <ComboBoxItem>CPDL</ComboBoxItem>
                    <ComboBoxItem>OpenScore</ComboBoxItem>
                    <ComboBoxItem>Offline</ComboBoxItem>
                </ComboBox>
            </Grid>

            <!-- Lista + panel lateral -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="0"/>
                    <ColumnDefinition Width="0"/>
                </Grid.ColumnDefinitions>

                <!-- Listado de obras -->
                <ListBox x:Name="lstResults" Grid.Column="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         SelectionMode="Extended"
                         SelectionChanged="LstResults_SelectionChanged"
                         PreviewMouseRightButtonDown="LstResults_PreviewMouseRightButtonDown">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="🌐 Abrir página web" Click="CtxMenuOpenPage_Click"/>
                            <Separator/>
                            <MenuItem Header="✔ Seleccionar" Click="CtxMenuSelect_Click"/>
                            <MenuItem Header="☐ Deseleccionar" Click="CtxMenuDeselect_Click"/>
                            <Separator/>
                            <MenuItem Header="Solo PDF (este grupo)" Click="CtxMenuOnlyPdf_Click"/>
                            <MenuItem Header="Solo MIDI (este grupo)" Click="CtxMenuOnlyMidi_Click"/>
                            <MenuItem Header="Todos los formatos" Click="CtxMenuAllFormats_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                              Margin="0,0,8,0" VerticalAlignment="Center"
                                              Checked="ItemSelectionChanged" Unchecked="ItemSelectionChanged"
                                              Visibility="Collapsed"/>
                                    <StackPanel Grid.Column="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                       Foreground="#E2E8F0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Border Background="#0F766E" CornerRadius="3" Padding="5,2" Margin="0,3,0,2" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UserTag}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding UserTag}" FontSize="10" Foreground="#CCFBF1"/>
                                        </Border>
                                        <ItemsControl ItemsSource="{Binding Files}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#4C1D95" CornerRadius="3"
                                                            Padding="5,2" Margin="0,2,4,0">
                                                        <TextBlock Text="{Binding Label}" FontSize="11"
                                                                   Foreground="#DDD6FE"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                              Background="#3D3D5C" Cursor="SizeWE" Visibility="Collapsed"/>

                <!-- Panel info obra seleccionada -->
                <Border Grid.Column="2" Background="#1A1A30" BorderBrush="#3D3D5C" BorderThickness="1,0,0,0" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="10,8">
                            <TextBlock x:Name="txtInfoHint" Text="← Selecciona una obra"
                                       Foreground="#555" FontStyle="Italic" TextWrapping="Wrap"/>
                            <StackPanel x:Name="pnlInfoContent" Visibility="Collapsed">
                                <TextBlock x:Name="txtInfoTitle" FontWeight="Bold" TextWrapping="Wrap"
                                           Foreground="#E2E8F0" FontSize="13" Margin="0,0,0,4"/>
                                <TextBlock x:Name="txtInfoComposer" Foreground="#A78BFA"
                                           TextWrapping="Wrap" Margin="0,0,0,6" FontSize="12"/>
                                <Border Background="#374151" CornerRadius="3" Padding="5,2"
                                        Margin="0,0,0,10" HorizontalAlignment="Left">
                                    <TextBlock x:Name="txtInfoSource" FontSize="11" Foreground="#DDD6FE"/>
                                </Border>
                                <TextBlock Text="🌐 Página:" Foreground="#888" FontSize="11" Margin="0,0,0,2"/>
                                <TextBlock x:Name="txtInfoUrl" TextWrapping="Wrap" FontSize="11"
                                           Foreground="#60A5FA" Cursor="Hand"
                                           TextDecorations="Underline" Margin="0,0,0,10"
                                           MouseLeftButtonUp="TxtInfoUrl_Click"
                                           ToolTip="Clic para abrir en navegador"/>
                                <TextBlock Text="📄 Archivos:" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                                <ItemsControl x:Name="icInfoFiles">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Label}" Foreground="#DDD6FE"
                                                       FontSize="11" Margin="0,1"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="🏷 Tag:" Foreground="#888" FontSize="11" Margin="0,10,0,4"/>
                                <TextBox x:Name="txtTagEditor" TextChanged="TxtTagEditor_TextChanged"/>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="txtTagStatus" Grid.Column="0" Foreground="#666" FontSize="10" VerticalAlignment="Center"/>
                                    <Button x:Name="btnSaveTag" Grid.Column="1" Content="Guardar tag" Padding="10,5" Margin="8,0,0,0" Click="BtnSaveTag_Click"/>
                                    <Button Grid.Column="2" Content="Limpiar" Padding="10,5" Margin="4,0,0,0" Background="#374151" Click="BtnClearTag_Click"/>
                                </Grid>
                                <TextBlock Text="Vista previa:" Foreground="#888" FontSize="11" Margin="0,10,0,4" Visibility="Collapsed"/>
                                <TextBlock x:Name="txtPreviewHint" Foreground="#94A3B8" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,4" Visibility="Collapsed"/>
                                <Border Background="#0B1020" BorderBrush="#333" BorderThickness="1" Height="220" Visibility="Collapsed">
                                    <Grid>
                                        <WebBrowser x:Name="wbPreview" Visibility="Collapsed"/>
                                        <TextBlock x:Name="txtPreviewFallback" Visibility="Visible"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="#666" Text="Sin vista previa"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- Controles de descarga -->
        <StackPanel Grid.Row="3" Margin="0,10,0,8">
            <!-- Fila 1: Destino -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="📁 Destino:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="txtDestFolder" Grid.Column="1" Text="D:\partituras"
                         ToolTip="Carpeta donde se guardarán los archivos. También puedes arrastrar una carpeta aquí."
                         AllowDrop="True" Drop="TxtDestFolder_Drop" DragOver="TxtDestFolder_DragOver"/>
                <Button Grid.Column="2" Content="📂" Margin="6,0,0,0" Padding="10,7"
                        Click="BtnChooseFolder_Click" ToolTip="Seleccionar carpeta"/>
            </Grid>
            <!-- Fila 2: Acciones -->
            <WrapPanel>
                <Button x:Name="btnDownloadAllBottom" Content="🚀 Descargar todo"
                    Margin="0,0,4,0" Padding="10,7" Background="#7C3AED"
                    Click="BtnDownloadAll_Click"
                    ToolTip="Un clic: usa fuente Todas, crea carpeta si falta y descarga todo"/>
                <CheckBox x:Name="chkEnableMutopia" Content="Mutopia"
                    Margin="0,0,8,0" VerticalAlignment="Center"
                    IsChecked="True" Checked="SourceToggle_Changed" Unchecked="SourceToggle_Changed"
                    ToolTip="Habilitar Mutopia en catálogo/descarga"/>
                <CheckBox x:Name="chkEnableMusopen" Content="Musopen"
                    Margin="0,0,8,0" VerticalAlignment="Center"
                    IsChecked="True" Checked="SourceToggle_Changed" Unchecked="SourceToggle_Changed"
                    ToolTip="Habilitar Musopen en catálogo/descarga"/>
                <CheckBox x:Name="chkEnableOpenScore" Content="OpenScore"
                    Margin="0,0,8,0" VerticalAlignment="Center"
                    IsChecked="True" Checked="SourceToggle_Changed" Unchecked="SourceToggle_Changed"
                    ToolTip="Habilitar OpenScore (CC0 MusicXML) en catálogo/descarga"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>
                <CheckBox x:Name="chkOnlyPdf" Content="Solo PDF"
                    Margin="0,0,8,0" VerticalAlignment="Center"
                    Foreground="#A78BFA"
                    Checked="FilterChanged" Unchecked="FilterChanged"
                    ToolTip="Descargar solo archivos PDF"/>
                <CheckBox x:Name="chkOnlyMidi" Content="Solo MIDI"
                    Margin="0,0,8,0" VerticalAlignment="Center"
                    Foreground="#A78BFA"
                    Checked="FilterChanged" Unchecked="FilterChanged"
                    ToolTip="Descargar solo archivos MIDI"/>
                <CheckBox x:Name="chkOnlyXml" Content="Solo XML"
                    Margin="0,0,8,0" VerticalAlignment="Center"
                    Foreground="#A78BFA"
                    Checked="FilterChanged" Unchecked="FilterChanged"
                    ToolTip="Descargar solo archivos MusicXML/MXL y compatibles MuseScore (MSCZ/MSCX)"/>
                <CheckBox x:Name="chkOnlyClassical" Content="Solo clásica"
                    Margin="0,0,8,0" VerticalAlignment="Center"
                    Foreground="#A78BFA"
                    IsChecked="True"
                    Checked="FilterChanged" Unchecked="FilterChanged"
                    ToolTip="Filtrar resultados por repertorio clásico (compositor/título)"/>
                <Button x:Name="btnExportHtmlBottom" Content="🌐 HTML"
                    Margin="0,0,4,0" Padding="10,7" Background="#334155"
                    Click="BtnExportHtml_Click" ToolTip="Exportar resultados a HTML"/>
                <Button x:Name="btnCancelAllDownloads" Content="⏹ Cancelar"
                    Margin="0,0,4,0" Padding="10,7" Background="#7F1D1D" IsEnabled="False"
                    Click="BtnCancelAllDownloads_Click" ToolTip="Cancelar descargas en curso"/>
                <Button x:Name="btnMusopenSession" Content="🔐 Musopen sesión"
                    Margin="0,0,4,0" Padding="10,7" Background="#1E3A8A"
                    Click="BtnMusopenSession_Click" ToolTip="Iniciar sesión en Musopen para poder descargar partituras"/>
                <Button x:Name="btnConvertAudiveris" Content="🎼 Audiveris"
                    Margin="0,0,4,0" Padding="10,7" Background="#14532D"
                    Click="BtnConvertAudiveris_Click"
                    ToolTip="Convertir PDF/imagen de carpeta destino a MusicXML/MXL (solo los no convertidos)"/>
                <Button x:Name="btnCancelAudiveris" Content="⏹ Parar"
                    Margin="0,0,4,0" Padding="10,7" Background="#991B1B"
                    Click="BtnCancelAudiveris_Click" IsEnabled="False"
                    ToolTip="Cancelar conversión Audiveris en curso"/>
                <CheckBox x:Name="chkAutoConvertAudiveris"
                    Content="🔄 Auto-convertir" Margin="0,0,8,0" VerticalAlignment="Center"
                    IsChecked="True"
                    Checked="ChkAutoConvert_Changed" Unchecked="ChkAutoConvert_Changed"
                    ToolTip="Lanzar Audiveris automáticamente al finalizar cada lote de descargas"/>
                <Button x:Name="btnConvertOemer" Content="🎵 oemer"
                    Margin="0,0,4,0" Padding="10,7" Background="#164E63"
                    Click="BtnConvertOemer_Click"
                    ToolTip="Convertir PDF/imagen con oemer (pip install oemer) a MusicXML"/>
                <Button x:Name="btnCancelOemer" Content="⏹ Parar"
                    Margin="0,0,4,0" Padding="10,7" Background="#991B1B"
                    Click="BtnCancelOemer_Click" IsEnabled="False"
                    ToolTip="Cancelar conversión oemer en curso"/>
                <CheckBox x:Name="chkAutoConvertOemer"
                    Content="🔄 Auto-oemer" Margin="0,0,8,0" VerticalAlignment="Center"
                    IsChecked="False"
                    Checked="ChkAutoConvert_Changed" Unchecked="ChkAutoConvert_Changed"
                    ToolTip="Lanzar oemer automáticamente al finalizar cada lote de descargas"/>
                <Button x:Name="btnDeleteAndRedownload" Content="🗑️ Re-descargar"
                    Margin="0,0,4,0" Padding="10,7" Background="#7F1D1D"
                    Click="BtnDeleteAndRedownload_Click"
                    ToolTip="Borra todos los archivos de la carpeta destino y vuelve a descargar todo"/>
                <Button x:Name="btnGenerateVideo" Content="🎥 Video"
                    Margin="0,0,4,0" Padding="10,7" Background="#7C2D12"
                    Click="BtnGenerateVideo_Click"
                    ToolTip="Generar vídeo MP4 animado de partituras MSCZ/MXL/XML con score-util (requiere Node.js)"/>
                <Button x:Name="btnCancelVideo" Content="⏹ Parar"
                    Margin="0,0,4,0" Padding="10,7" Background="#991B1B"
                    Click="BtnCancelVideo_Click" IsEnabled="False"
                    ToolTip="Cancelar generación de vídeo en curso"/>
                <Button Content="🚪 Salir"
                    Padding="10,7" Background="#374151"
                    Click="BtnExit_Click" ToolTip="Cerrar la aplicación"/>
            </WrapPanel>
            <!-- Botones ocultos usados por code-behind -->
            <StackPanel Visibility="Collapsed">
                <Button x:Name="btnDownload" Content="⬇ Descargar seleccionados"
                        Click="BtnDownload_Click" IsEnabled="False" Background="#065F46" ToolTip="Ctrl+D"/>
                <Button x:Name="btnCancelDownload" Content="✖ Parar"
                        Click="BtnCancelDownload_Click" IsEnabled="False" Background="#991B1B"/>
                <Button x:Name="btnExportJson" Click="BtnExportJson_Click"/>
                <Button x:Name="btnExportCsv" Click="BtnExportCsv_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- Área de log y progreso -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtStatus" Grid.Row="0" Grid.Column="0"
                           Text="Listo. Escribe una búsqueda y pulsa Buscar."
                           Foreground="#A78BFA" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <ProgressBar x:Name="pbProgress" Grid.Row="0" Grid.Column="1"
                             Height="18" Minimum="0" Maximum="100"
                             Foreground="#7C3AED" Background="#3D3D5C"
                             BorderThickness="0"/>
                <TextBlock x:Name="txtFileProgress" Grid.Row="1" Grid.Column="0"
                           Foreground="#666" FontSize="10" Visibility="Collapsed"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                <TextBlock x:Name="txtSourceStatus" Grid.Row="1" Grid.Column="0"
                           HorizontalAlignment="Right" Margin="0,2,8,0"
                           Foreground="#7DD3FC" FontSize="10"
                           Text="Fuentes M:ON C:OFF"/>
                <TextBlock x:Name="txtErrorMiniTable" Grid.Row="1" Grid.Column="0"
                           HorizontalAlignment="Left" Margin="0,2,0,0"
                           Foreground="#F87171" FontSize="10" Text=""
                           ToolTip="Errores por tipo en sesión actual"/>
                <ProgressBar x:Name="pbFileProgress" Grid.Row="1" Grid.Column="1"
                             Height="5" Minimum="0" Maximum="100" Margin="0,2,0,0"
                             Foreground="#A78BFA" Background="#2D2D44" BorderThickness="0"
                             Visibility="Collapsed"/>
                <TextBlock x:Name="txtSessionStats" Grid.Row="0" Grid.Column="0"
                           HorizontalAlignment="Right" Margin="0,0,8,0"
                           Foreground="#666" FontSize="10" Text="S:0 · Obras:0 · Desc:0"/>
            </Grid>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" MinWidth="150" MaxWidth="340"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="#333" BorderThickness="0,0,1,0" Background="#111827">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" MinHeight="60"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="90"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" MinHeight="60"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" MinHeight="60"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="📥 Cola de descarga" Foreground="#A78BFA" Margin="8,6,8,4" FontWeight="SemiBold"/>
                        <ListBox x:Name="lstQueue" Grid.Row="1" Margin="6,0,6,6" BorderThickness="0">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="⏸ Pausar archivo" Click="CtxQueuePause_Click"/>
                                    <MenuItem Header="▶ Reanudar archivo" Click="CtxQueueResume_Click"/>
                                    <MenuItem Header="↻ Reintentar archivo" Click="CtxQueueRetry_Click"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="2,3">
                                        <TextBlock Text="{Binding FileName}" Foreground="#E5E7EB" TextTrimming="CharacterEllipsis" FontSize="11"/>
                                        <TextBlock Text="{Binding Status}" Foreground="#94A3B8" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                        <ProgressBar Value="{Binding Percent}" Minimum="0" Maximum="100" Height="4" Margin="0,3,0,0"
                                                     Foreground="#0EA5E9" Background="#1F2937" BorderThickness="0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock Grid.Row="2" Text="📄 Historial reciente" Foreground="#A78BFA" Margin="8,0,8,4" FontWeight="SemiBold"/>
                        <ListBox x:Name="lstDownloadHistory" Grid.Row="3" Margin="6,0,6,6" BorderThickness="0"
                                 MouseDoubleClick="LstDownloadHistory_MouseDoubleClick">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="📂 Abrir carpeta" Click="CtxHistoryOpenFolder_Click"/>
                                    <MenuItem Header="📄 Abrir archivo" Click="CtxHistoryOpenFile_Click"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="2,2">
                                        <TextBlock Text="{Binding FileName}" Foreground="#E5E7EB" TextTrimming="CharacterEllipsis" FontSize="11"/>
                                        <TextBlock Text="{Binding Summary}" Foreground="#94A3B8" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <DockPanel Grid.Row="4" Margin="8,0,8,4">
                            <Button x:Name="btnResetAudiverisCooldown" DockPanel.Dock="Right"
                                    Content="🔄" FontSize="9" Padding="4,1" Background="Transparent"
                                    Foreground="#6B7280" BorderThickness="0" Cursor="Hand"
                                    ToolTip="Limpiar cooldown y strikes de Audiveris"
                                    Click="BtnResetAudiverisCooldown_Click"/>
                            <TextBlock Text="🎼 Audiveris procesados" Foreground="#34D399" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBlock x:Name="txtAudiverisStatus" Grid.Row="5" Foreground="#6B7280" FontSize="9" Margin="8,0,8,2" TextTrimming="CharacterEllipsis"/>
                        <ListBox x:Name="lstAudiverisLog" Grid.Row="6" Margin="6,0,6,6" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="2,2">
                                        <TextBlock Text="{Binding FileName}" Foreground="#E5E7EB" TextTrimming="CharacterEllipsis" FontSize="11"/>
                                        <TextBlock Text="{Binding Status}" Foreground="#6EE7B7" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <DockPanel Grid.Row="7" Margin="8,0,8,4">
                            <Button x:Name="btnResetOemerCooldown" DockPanel.Dock="Right"
                                    Content="🔄" FontSize="9" Padding="4,1" Background="Transparent"
                                    Foreground="#6B7280" BorderThickness="0" Cursor="Hand"
                                    ToolTip="Limpiar cooldown y strikes de oemer"
                                    Click="BtnResetOemerCooldown_Click"/>
                            <TextBlock Text="🎵 oemer procesados" Foreground="#7DD3FC" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBlock x:Name="txtOemerStatus" Grid.Row="8" Foreground="#6B7280" FontSize="9" Margin="8,0,8,2" TextTrimming="CharacterEllipsis"/>
                        <ListBox x:Name="lstOemerLog" Grid.Row="9" Margin="6,0,6,6" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="2,2">
                                        <TextBlock Text="{Binding FileName}" Foreground="#E5E7EB" TextTrimming="CharacterEllipsis" FontSize="11"/>
                                        <TextBlock Text="{Binding Status}" Foreground="#7DD3FC" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                              Background="#2D2D44" Cursor="SizeWE"/>
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="📝 Log" Foreground="#A78BFA" VerticalAlignment="Center" Margin="2,0,8,0" FontWeight="SemiBold"/>
                        <Button Content="📋 Copiar" Padding="8,4" Margin="0,0,4,0"
                            Style="{StaticResource LogActionButtonStyle}"
                                Background="#1E293B" Click="BtnCopyLog_Click" ToolTip="Copiar log al portapapeles"/>
                        <Button Content="🗑 Borrar" Padding="8,4"
                            Style="{StaticResource LogActionButtonStyle}"
                                Background="#1E293B" Click="BtnClearLog_Click" ToolTip="Limpiar log"/>
                    </StackPanel>
                    <TextBox x:Name="txtLog" Grid.Row="1"
                             IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Visible"
                             Background="#13131F" Foreground="#94A3B8"
                             FontFamily="Consolas" FontSize="11"
                             BorderBrush="#333" Padding="6"
                             />
                </Grid>
            </Grid>
        </Grid>

        <!-- Panel de selección de partituras para vídeo -->
        <Border x:Name="pnlVideoSelect"
                Grid.Row="3" Grid.RowSpan="2"
                Panel.ZIndex="10"
                Visibility="Collapsed"
                Background="#0D1117"
                BorderBrush="#3D3D5C" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Cabecera -->
                <Border Grid.Row="0" Background="#13131F" Padding="12,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="🎥 Seleccionar partituras para vídeo"
                                       FontSize="15" FontWeight="Bold" Foreground="#A78BFA"/>
                            <TextBlock x:Name="txtVideoSelectHint"
                                       Foreground="#9CA3AF" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Button Grid.Row="0" Grid.Column="1" x:Name="btnVideoSelectBack"
                                Content="← Volver" Padding="12,6"
                                Background="#374151" Foreground="White"
                                Click="BtnVideoSelectBack_Click"
                                ToolTip="Volver a la pantalla principal. Para primero si hay generación activa. (Escape)"/>
                        <!-- Fila 2: Filtro + Regenerar + ETA -->
                        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center"
                                       Margin="0,0,5,0" Foreground="#9CA3AF"/>
                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtVideoFilter"
                                         Grid.Column="0"
                                         Background="#1E293B" Foreground="#E5E7EB"
                                         BorderBrush="#374151" Padding="6,4"
                                         TextChanged="TxtVideoFilter_TextChanged"
                                         KeyDown="TxtVideoFilter_KeyDown"
                                         ToolTip="Filtrar por nombre, carpeta o formato (MSCZ/MXL…) · Ctrl+F enfoca filtro · Enter selecciona primer resultado · Escape limpia el filtro"/>
                                <TextBlock Grid.Column="0" Text="nombre, carpeta o formato…" Foreground="#4B5563"
                                           IsHitTestVisible="False" Margin="8,0" VerticalAlignment="Center"
                                           FontStyle="Italic">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtVideoFilter}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Grid.Column="1" x:Name="btnVideoFilterClear"
                                        Content="✕" Padding="6,3" Margin="2,0,0,0"
                                        Background="#374151" Foreground="#9CA3AF"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="BtnVideoFilterClear_Click"
                                        ToolTip="Limpiar filtro (Escape)"
                                        Visibility="Collapsed"/>
                            </Grid>
                            <CheckBox Grid.Column="2" x:Name="chkVideoRegenerate"
                                      Content="🔁 Re-generar" Margin="16,0,0,0"
                                      VerticalAlignment="Center" Foreground="#9CA3AF"
                                      IsChecked="False"
                                      Checked="ChkVideoRegenerate_Changed"
                                      Unchecked="ChkVideoRegenerate_Changed"
                                      ToolTip="Incluir partituras que ya tienen MP4 para regenerarlas (Ctrl+R)"/>
                            <TextBlock Grid.Column="4" x:Name="txtVideoEta"
                                       Foreground="#F59E0B" FontSize="11"
                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                       ToolTip="Tiempo estimado restante y velocidad media por partitura"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Lista de partituras -->
                <Grid Grid.Row="1">
                <ListView x:Name="lstVideoSelect"
                          BorderThickness="0" Background="#0D1117"
                          SelectionMode="Extended"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          MouseDoubleClick="LstVideoSelect_MouseDoubleClick"
                          GridViewColumnHeader.Click="LstVideoSelect_ColumnHeaderClick"
                          PreviewMouseRightButtonDown="LstVideoSelect_PreviewMouseRightButtonDown"
                          KeyDown="LstVideoSelect_KeyDown">
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" Foreground="#9CA3AF"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Padding="6,6,4,2" Background="#111827"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Name}"/>
                                        <TextBlock Foreground="#4B5563" FontSize="10"
                                                   Padding="0,6,0,2" Background="#111827"
                                                   Text="{Binding ItemCount, StringFormat=({0})}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="mnuCtxVideoOpen" Header="▶ Abrir vídeo MP4" Click="CtxVideoOpen_Click"/>
                            <MenuItem x:Name="mnuCtxVideoOpenInMuseScore" Header="🎼 Abrir en MuseScore" Click="CtxVideoOpenInMuseScore_Click"/>
                            <MenuItem Header="📂 Abrir carpeta del ítem" Click="CtxVideoOpenItemFolder_Click"/>
                            <MenuItem x:Name="mnuCtxVideoCopyPath" Header="📋 Copiar ruta" Click="CtxVideoCopyPath_Click"/>
                            <MenuItem x:Name="mnuCtxVideoCopyMp4Path" Header="📋 Copiar ruta de MP4" Click="CtxVideoCopyMp4Path_Click"/>
                            <MenuItem x:Name="mnuCtxVideoCopyAllMp4" Header="📋 Copiar rutas MP4 visibles" Click="CtxVideoCopyAllMp4Paths_Click"/>
                            <MenuItem x:Name="mnuCtxVideoGenerateSingle" Header="🎥 Generar este(os)" Click="CtxVideoGenerateSingle_Click"/>
                            <Separator/>
                            <MenuItem x:Name="mnuCtxVideoSelect" Header="☑ Seleccionar" Click="CtxVideoSelectOne_Click"/>
                            <MenuItem x:Name="mnuCtxVideoDeselect" Header="☐ Deseleccionar" Click="CtxVideoDeselectOne_Click"/>
                            <MenuItem x:Name="mnuCtxVideoSelectFolder" Header="📁 Seleccionar toda la carpeta" Click="CtxVideoSelectFolder_Click"/>
                            <Separator/>
                            <MenuItem x:Name="mnuCtxVideoDelete" Header="🗑 Eliminar MP4 existente" Click="CtxVideoDelete_Click"/>
                            <MenuItem x:Name="mnuCtxVideoClearError" Header="↩ Limpiar error" Click="CtxVideoClearError_Click"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="36">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Checked="VideoSelectItem_CheckChanged"
                                                  Unchecked="VideoSelectItem_CheckChanged"
                                                  HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                                <GridViewColumn.Header>
                                    <CheckBox x:Name="chkVideoSelectHeader"
                                              IsThreeState="True"
                                              ToolTip="Seleccionar / deseleccionar todas las visibles"
                                              Checked="ChkVideoSelectHeader_Checked"
                                              Unchecked="ChkVideoSelectHeader_Unchecked"
                                              Indeterminate="ChkVideoSelectHeader_Indeterminate"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="28">
                                <GridViewColumn.Header>
                                    <TextBlock Text="Est" ToolTip="Estado de generación: ⏳ En curso · ✅ OK · ❌ Error"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StatusIcon}"
                                                   Foreground="{Binding StatusColor}"
                                                   FontSize="13" HorizontalAlignment="Center"
                                                   ToolTip="{Binding StatusLabel}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="56">
                                <GridViewColumn.Header>
                                    <TextBlock Text="Formato" ToolTip="Formato del archivo de partitura. Prioridad: MSCZ &gt; MXL &gt; MusicXML"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding FormatColor}" CornerRadius="3" Padding="5,1">
                                            <TextBlock Text="{Binding FormatTag}" FontSize="10"
                                                       FontWeight="Bold" Foreground="White"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="340">
                                <GridViewColumn.Header>
                                    <TextBlock Text="Nombre" ToolTip="Nombre del archivo de partitura. Tooltip muestra ruta completa."/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" Foreground="#E5E7EB"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding BestFile}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="30">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding HasVideoMark}"
                                                   Foreground="#22C55E" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   ToolTip="{Binding Mp4SizeToolTip}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                                <GridViewColumn.Header>
                                    <TextBlock Text="▶" Foreground="#22C55E" FontSize="10"
                                               ToolTip="Ya tiene vídeo MP4 generado"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn x:Name="colCarpeta" Width="220">
                                <GridViewColumn.Header>
                                    <TextBlock Text="Carpeta" ToolTip="Subcarpeta relativa a la carpeta destino (máx. 45 caracteres)"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FolderShort}" Foreground="#6B7280"
                                                   FontSize="10" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding FolderFull}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#E5E7EB"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="2,4"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1E293B"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1E3A5F"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding HasVideo}" Value="True">
                                    <Setter Property="Foreground" Value="#9CA3AF"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Running">
                                    <Setter Property="Background" Value="#1C2A1C"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Done">
                                    <Setter Property="Background" Value="#0F2318"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Error">
                                    <Setter Property="Background" Value="#2A0F0F"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
                <TextBlock x:Name="txtVideoEmpty"
                           Text="Sin coincidencias para el filtro actual"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#6B7280" FontSize="14" FontStyle="Italic"
                           IsHitTestVisible="False" Panel.ZIndex="1"
                           Visibility="Collapsed"/>
                </Grid>

                <!-- Barra de progreso general -->
                <ProgressBar x:Name="pbVideoGeneral" Grid.Row="2"
                             Minimum="0" Maximum="100" Value="0"
                             Foreground="#7C3AED" Background="#1E293B" BorderThickness="0"
                             ToolTip="Progreso de generación de vídeos. Naranja = hay errores"/>

                <!-- Pie de botones -->
                <Border Grid.Row="3" Background="#13131F" Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                            <Button x:Name="btnVideoSelectAll" Content="☑ Todas"
                                    Margin="0,0,6,0" Padding="10,6" Background="#374151"
                                    Click="BtnVideoSelectAll_Click"
                                    ToolTip="Seleccionar todas las partituras visibles (Ctrl+A)"/>
                            <Button x:Name="btnVideoSelectNone" Content="☐ Ninguna"
                                    Margin="0,0,6,0" Padding="10,6" Background="#374151"
                                    Click="BtnVideoSelectNone_Click"
                                    ToolTip="Deseleccionar todas, incluidas las ocultas por filtro"/>
                            <Button x:Name="btnVideoSelectInvert" Content="⇄ Invertir"
                                    Margin="0,0,6,0" Padding="10,6" Background="#374151"
                                    Click="BtnVideoSelectInvert_Click"
                                    ToolTip="Invertir selección actual (Ctrl+I)"/>
                            <Button x:Name="btnVideoSelectPending" Content="⏳ Pendientes"
                                    Margin="0,0,6,0" Padding="10,6" Background="#1E3A5F"
                                    Click="BtnVideoSelectPending_Click"
                                    ToolTip="Seleccionar partituras sin vídeo MP4 (o todas si Re-generar activo) · Ctrl+P"/>
                            <Button x:Name="btnVideoSelectErrors" Content="⚠ Errores"
                                    Margin="0,0,6,0" Padding="10,6" Background="#4A1010"
                                    IsEnabled="False"
                                    Click="BtnVideoSelectErrors_Click"
                                    ToolTip="Seleccionar solo partituras con error de generación (Ctrl+E)"/>
                            <Button x:Name="btnVideoSelectOpenFolder" Content="📂 Carpeta"
                                    Margin="0,0,6,0" Padding="10,6" Background="#1C3A2B"
                                    Click="BtnVideoSelectOpenFolder_Click"
                                    ToolTip="Abrir carpeta de destino en el Explorador (Ctrl+O)"/>
                            <Button x:Name="btnVideoSelectRefresh" Content="🔄 Actualizar"
                                    Margin="0,0,6,0" Padding="10,6" Background="#374151"
                                    Click="BtnVideoSelectRefresh_Click"
                                    ToolTip="Volver a escanear la carpeta de destino (F5)"/>
                            <TextBlock x:Name="txtVideoSelectCount" VerticalAlignment="Center"
                                       Foreground="#9CA3AF" FontSize="11" Margin="8,0,0,0"/>
                        </WrapPanel>
                        <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                            <Button x:Name="btnVideoSelectGenerate" Content="🎥 Generar (0)"
                                    Margin="0,0,6,0" Padding="14,6" Background="#7C2D12"
                                    FontWeight="SemiBold"
                                    Click="BtnVideoSelectGenerate_Click"
                                    ToolTip="Generar vídeos para las partituras seleccionadas (Ctrl+G)"/>
                            <Button x:Name="btnVideoSelectCancelGen" Content="⏹ Parar"
                                    Padding="10,6" Background="#991B1B" IsEnabled="False"
                                    Click="BtnCancelVideo_Click"
                                    ToolTip="Cancelar generación de vídeo en curso (Escape)"/>
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
